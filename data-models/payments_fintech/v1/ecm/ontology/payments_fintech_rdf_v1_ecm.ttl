    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxTokenRequestsPerDay rdf:type rdf:Property ;
    rdfs:label 'Max Token Requests Per Day' ;
    rdfs:comment 'Upper limit on the number of token requests the requestor may submit in a single day.' ;
    rdfs:domain ind:TokenRequestor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:privacyConsentGiven rdf:type rdf:Property ;
    rdfs:label 'Privacy Consent Given' ;
    rdfs:comment 'Indicates whether the requestor has provided required privacy consent for data processing.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:schemeAffiliation rdf:type rdf:Property ;
    rdfs:label 'Scheme Affiliation' ;
    rdfs:comment 'Payment scheme with which the requestor is affiliated for token issuance.' ;
    rdfs:domain ind:TokenRequestor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenRequestorName rdf:type rdf:Property ;
    rdfs:label 'Token Requestor Name' ;
    rdfs:comment 'Human-readable name of the token requestor organization or entity.' ;
    rdfs:domain ind:TokenRequestor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenRequestorStatus rdf:type rdf:Property ;
    rdfs:label 'Token Requestor Status' ;
    rdfs:comment 'Operational status of the token requestor within the tokenization ecosystem.' ;
    rdfs:domain ind:TokenRequestor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upiId rdf:type rdf:Property ;
    rdfs:label 'Upi Id' ;
    rdfs:comment 'System-generated unique identifier for the UPI virtual payment address record.' ;
    rdfs:domain ind:Upi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkedBankAccountLinkedAccountId rdf:type rdf:Property ;
    rdfs:label 'Linked Bank Account Linked Account Id' ;
    rdfs:comment 'Reference to the bank account that funds are drawn from or credited to for this VPA.' ;
    rdfs:domain ind:Upi ;
    rdf:type owl:ObjectProperty ;
