    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalBatchReference rdf:type rdf:Property ;
    rdfs:label 'Renewal Batch Reference' ;
    rdfs:comment 'Reference to the batch job that will process the renewal.' ;
    rdfs:domain ind:InstrumentExpirySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalEligibilityFlag rdf:type rdf:Property ;
