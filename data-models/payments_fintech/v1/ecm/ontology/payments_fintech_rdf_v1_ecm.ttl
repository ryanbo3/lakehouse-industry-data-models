ind:dynamicCurrencyConversionSupported rdf:type rdf:Property ;
    rdfs:label 'Dynamic Currency Conversion Supported' ;
    rdfs:comment 'Indicates support for Dynamic Currency Conversion during transactions.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hceCredentialStatus rdf:type rdf:Property ;
    rdfs:label 'Hce Credential Status' ;
    rdfs:comment 'Current lifecycle status of the HCE credential.' ;
    rdfs:domain ind:HceCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFraudFlagged rdf:type rdf:Property ;
