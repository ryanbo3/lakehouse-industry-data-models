ind:fraudCaseId rdf:type rdf:Property ;
    rdfs:label 'Fraud Case Id' ;
    rdfs:comment 'Foreign key linking to fraud.fraud_case. Business justification: Risk management report requires each account to reference its primary fraud case for monitoring and compliance.' ;
    rdfs:domain ind:PaymentsFintech ;
