    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaStatus rdf:type rdf:Property ;
    rdfs:label 'Sca Status' ;
    rdfs:comment 'Result of the SCA evaluation for the transaction.' ;
