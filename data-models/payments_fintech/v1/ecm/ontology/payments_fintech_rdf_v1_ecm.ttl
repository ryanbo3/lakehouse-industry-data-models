    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultFlag rdf:type rdf:Property ;
    rdfs:label 'Default Flag' ;
    rdfs:comment 'Indicates whether this acceptance type is the default for newly provisioned terminals.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firmwareVersionRequired rdf:type rdf:Property ;
    rdfs:label 'Firmware Version Required' ;
    rdfs:comment 'Minimum firmware version required for the terminal to support this acceptance type.' ;
    rdfs:domain ind:AcceptanceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hceSupported rdf:type rdf:Property ;
    rdfs:label 'Hce Supported' ;
    rdfs:comment 'True if HCE-based mobile payments are permitted.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPin rdf:type rdf:Property ;
    rdfs:label 'Requires Pin' ;
    rdfs:comment 'Indicates whether a PIN entry is mandatory for this acceptance type.' ;
    rdfs:domain ind:AcceptanceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityCertLevel rdf:type rdf:Property ;
    rdfs:label 'Security Cert Level' ;
    rdfs:comment 'PCI PTS certification level required for terminals using this acceptance type.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareVersionRequired rdf:type rdf:Property ;
    rdfs:label 'Software Version Required' ;
    rdfs:comment 'Minimum software version required for the terminal to support this acceptance type.' ;
    rdfs:domain ind:AcceptanceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsContactless rdf:type rdf:Property ;
    rdfs:label 'Supports Contactless' ;
    rdfs:comment 'True if contactless transactions are permitted under this acceptance type.' ;
    rdfs:domain ind:AcceptanceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsEmv rdf:type rdf:Property ;
    rdfs:label 'Supports Emv' ;
    rdfs:comment 'True if EMV chip transactions are allowed.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsNfc rdf:type rdf:Property ;
    rdfs:label 'Supports Nfc' ;
    rdfs:comment 'True if NFC (near-field communication) is enabled for this acceptance type.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionEnvironment rdf:type rdf:Property ;
    rdfs:label 'Transaction Environment' ;
    rdfs:comment 'Broad environment where the transaction originates, aligning with interchange rules.' ;
    rdfs:domain ind:AcceptanceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalAlertId rdf:type rdf:Property ;
