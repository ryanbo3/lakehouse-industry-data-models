    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryDescription rdf:type rdf:Property ;
    rdfs:label 'Entry Description' ;
    rdfs:comment 'Free-form description supplied by the originator for the ACH entry.' ;
    rdfs:domain ind:AchEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:individualAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Individual Account Number' ;
    rdfs:comment 'Masked account number of the individual (PII, masked for security).' ;
    rdfs:domain ind:AchEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:individualName rdf:type rdf:Property ;
    rdfs:label 'Individual Name' ;
    rdfs:comment 'Full legal name of the account holder (PII).' ;
    rdfs:domain ind:AchEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReturned rdf:type rdf:Property ;
    rdfs:label 'Is Returned' ;
    rdfs:comment 'Indicates whether the ACH entry has been returned.' ;
    rdfs:domain ind:AchEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originatingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Originating Company Code' ;
    rdfs:comment 'Unique identifier of the originating merchant.' ;
    rdfs:domain ind:AchEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originatingCompanyName rdf:type rdf:Property ;
    rdfs:label 'Originating Company Name' ;
    rdfs:comment 'Legal name of the company that originated the ACH entry.' ;
    rdfs:domain ind:AchEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingDfiRouting rdf:type rdf:Property ;
    rdfs:label 'Originating Dfi Routing' ;
    rdfs:comment 'Routing number of the financial institution that originated the ACH entry.' ;
    rdfs:domain ind:AchEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Timestamp' ;
    rdfs:comment 'Timestamp when the ACH entry was processed by the system.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Code' ;
    rdfs:comment 'Unique identifier of the receiving bank.' ;
    rdfs:domain ind:AchEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivingCompanyName rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Name' ;
    rdfs:comment 'Legal name of the receiving financial institution.' ;
    rdfs:domain ind:AchEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingDfiRouting rdf:type rdf:Property ;
    rdfs:label 'Receiving Dfi Routing' ;
    rdfs:comment 'Routing number of the financial institution that receives the ACH entry.' ;
    rdfs:domain ind:AchEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standard code indicating why an ACH entry was returned, if applicable.' ;
    rdfs:domain ind:AchEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return Timestamp' ;
    rdfs:comment 'Timestamp when the return was recorded.' ;
    rdfs:domain ind:AchEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:secCode rdf:type rdf:Property ;
    rdfs:label 'Sec Code' ;
    rdfs:comment 'SEC code indicating the type of ACH entry (e.g., PPD, CCD).' ;
    rdfs:domain ind:AchEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceNumber rdf:type rdf:Property ;
    rdfs:label 'Trace Number' ;
    rdfs:comment 'Unique NACHA-assigned trace number for the ACH transaction.' ;
    rdfs:domain ind:AchEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalAuthAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Original Auth Authorization Id' ;
    rdfs:comment 'Reference to the first authorization attempt when this record is a retry.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Authorization .

ind:amountAuthorized rdf:type rdf:Property ;
    rdfs:label 'Amount Authorized' ;
    rdfs:comment 'The monetary amount that was approved by the issuer.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountRequested rdf:type rdf:Property ;
    rdfs:label 'Amount Requested' ;
    rdfs:comment 'The monetary amount requested for authorization.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Auth Reference Number' ;
    rdfs:comment 'External reference number for the authorization attempt, used for reconciliation and reporting.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authRetryCount rdf:type rdf:Property ;
    rdfs:label 'Auth Retry Count' ;
    rdfs:comment 'Number of authorization attempts made for this transaction.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authSource rdf:type rdf:Property ;
    rdfs:label 'Auth Source' ;
    rdfs:comment 'Origin of the authorization request – real-time or batch processing.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authStatus rdf:type rdf:Property ;
    rdfs:label 'Auth Status' ;
    rdfs:comment 'Current lifecycle status of the authorization attempt.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avsResult rdf:type rdf:Property ;
    rdfs:label 'Avs Result' ;
    rdfs:comment 'Result of the AVS check. [ENUM-REF-CANDIDATE: Y|N|X|U|R|S|D|M|P|I|C|B|E|G|A|N — promote to reference product]' ;
