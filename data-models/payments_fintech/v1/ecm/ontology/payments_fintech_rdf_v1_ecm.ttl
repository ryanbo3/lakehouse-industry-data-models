ind:institutionType rdf:type rdf:Property ;
    rdfs:label 'Institution Type' ;
    rdfs:comment 'Category of the institution (e.g., bank, broker, PSP).' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGpiSupported rdf:type rdf:Property ;
    rdfs:label 'Is Gpi Supported' ;
    rdfs:comment 'True if the institution supports SWIFT Global Payments Innovation.' ;
    rdfs:domain ind:SwiftBic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSepaSupported rdf:type rdf:Property ;
    rdfs:label 'Is Sepa Supported' ;
    rdfs:comment 'True if the institution participates in the SEPA scheme.' ;
    rdfs:domain ind:SwiftBic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9362ComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 9362 Compliance Flag' ;
    rdfs:comment 'Indicates whether the institution complies with ISO 9362 standards.' ;
    rdfs:domain ind:SwiftBic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sepaReachabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Sepa Reachability Flag' ;
    rdfs:comment 'True if the institution can receive SEPA payments.' ;
    rdfs:domain ind:SwiftBic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:swiftBicStatus rdf:type rdf:Property ;
    rdfs:label 'Swift Bic Status' ;
    rdfs:comment 'Overall lifecycle status of the BIC record.' ;
    rdfs:domain ind:SwiftBic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftConnectivityStatus rdf:type rdf:Property ;
    rdfs:label 'Swift Connectivity Status' ;
    rdfs:comment 'Current operational status of the institution on the SWIFT network.' ;
    rdfs:domain ind:SwiftBic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abbreviation rdf:type rdf:Property ;
    rdfs:label 'Abbreviation' ;
    rdfs:comment 'Common abbreviation for the time zone, e.g., \'EST\'.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associatedCountryCodes rdf:type rdf:Property ;
    rdfs:label 'Associated Country Codes' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where the time zone is applicable.' ;
    rdfs:domain ind:Timezone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dstObserved rdf:type rdf:Property ;
    rdfs:label 'Dst Observed' ;
    rdfs:comment 'Indicates whether the time zone observes daylight saving time.' ;
    rdfs:domain ind:Timezone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ianaName rdf:type rdf:Property ;
    rdfs:label 'Iana Name' ;
    rdfs:comment 'Standard IANA time zone identifier, e.g., \'America/New_York\'.' ;
    rdfs:domain ind:Timezone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utcOffsetDst rdf:type rdf:Property ;
    rdfs:label 'Utc Offset Dst' ;
    rdfs:comment 'UTC offset during daylight saving time period, expressed as ±HH:MM.' ;
    rdfs:domain ind:Timezone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utcOffsetStandard rdf:type rdf:Property ;
    rdfs:label 'Utc Offset Standard' ;
    rdfs:comment 'UTC offset during standard (non-DST) period, expressed as ±HH:MM.' ;
    rdfs:domain ind:Timezone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicablePaymentRails rdf:type rdf:Property ;
    rdfs:label 'Applicable Payment Rails' ;
    rdfs:comment 'Comma-separated list of payment rails that can process this transaction type.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackTimeframeDays rdf:type rdf:Property ;
    rdfs:label 'Chargeback Timeframe Days' ;
    rdfs:comment 'Number of days after settlement during which a chargeback may be initiated.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crossBorderFeeIndicator rdf:type rdf:Property ;
    rdfs:label 'Cross Border Fee Indicator' ;
    rdfs:comment 'Indicates whether a cross-border fee is applied, waived, or not applicable.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpact rdf:type rdf:Property ;
    rdfs:label 'Financial Impact' ;
    rdfs:comment 'Indicates whether the transaction type results in a debit, credit, or neutral effect on the account balance.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isChargebackPossible rdf:type rdf:Property ;
    rdfs:label 'Is Chargeback Possible' ;
    rdfs:comment 'True if a chargeback can be filed against this transaction type.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExternal rdf:type rdf:Property ;
    rdfs:label 'Is External' ;
    rdfs:comment 'True if the transaction type is defined by an external payment scheme rather than internal policy.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecurringAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Recurring Allowed' ;
    rdfs:comment 'True if the transaction type can be used in recurring payment schedules.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSettlementRequired rdf:type rdf:Property ;
    rdfs:label 'Is Settlement Required' ;
    rdfs:comment 'Indicates whether the transaction type must go through settlement processing.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso20022MessageType rdf:type rdf:Property ;
    rdfs:label 'Iso 20022 Message Type' ;
    rdfs:comment 'Corresponding ISO 20022 message identifier (e.g., pain.001).' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso8583ProcessingCode rdf:type rdf:Property ;
    rdfs:label 'Iso 8583 Processing Code' ;
    rdfs:comment 'Six-digit processing code defined by ISO 8583 for routing and handling.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAmountLimit rdf:type rdf:Property ;
    rdfs:label 'Max Amount Limit' ;
    rdfs:comment 'Upper monetary limit for transactions of this type.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minAmountLimit rdf:type rdf:Property ;
    rdfs:label 'Min Amount Limit' ;
    rdfs:comment 'Lower monetary threshold for transactions of this type.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingFeeIndicator rdf:type rdf:Property ;
    rdfs:label 'Processing Fee Indicator' ;
    rdfs:comment 'Who bears the processing fee for this transaction type.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurringInterval rdf:type rdf:Property ;
    rdfs:label 'Recurring Interval' ;
    rdfs:comment 'Default interval for recurring instances of this transaction type.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresSca rdf:type rdf:Property ;
    rdfs:label 'Requires Sca' ;
    rdfs:comment 'True if Strong Customer Authentication is required per PSD2.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalEligibilityReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Eligibility Reason' ;
    rdfs:comment 'Business rule description why a type is or isn’t reversible.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalEligible rdf:type rdf:Property ;
    rdfs:label 'Reversal Eligible' ;
    rdfs:comment 'True if the transaction type can be reversed (e.g., refund, void).' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementTreatment rdf:type rdf:Property ;
    rdfs:label 'Settlement Treatment' ;
    rdfs:comment 'Defines how the transaction is settled: immediate, deferred, or netted.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Fee Amount' ;
    rdfs:comment 'Flat fee charged per transaction when fee type is fixed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionFeeType rdf:type rdf:Property ;
    rdfs:label 'Transaction Fee Type' ;
    rdfs:comment 'Method used to calculate any fee associated with the transaction type.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTypeCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Type Code' ;
    rdfs:comment 'Short alphanumeric code representing the transaction type (e.g., PUR for Purchase).' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Transaction Type Description' ;
    rdfs:comment 'Full textual description of the transaction type, its purpose and typical usage.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTypeName rdf:type rdf:Property ;
    rdfs:label 'Transaction Type Name' ;
    rdfs:comment 'Descriptive name of the transaction type (e.g., Purchase, Refund).' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Type Status' ;
    rdfs:comment 'Current lifecycle status of the transaction type.' ;
    rdfs:domain ind:TransactionType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationExposureId rdf:type rdf:Property ;
    rdfs:label 'Concentration Exposure Id' ;
    rdfs:comment 'System-generated unique identifier for each concentration exposure record.' ;
    rdfs:domain ind:ConcentrationExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:concentrationExposureStatus rdf:type rdf:Property ;
    rdfs:label 'Concentration Exposure Status' ;
    rdfs:comment 'Operational status of the exposure record.' ;
    rdfs:domain ind:ConcentrationExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionCode rdf:type rdf:Property ;
    rdfs:label 'Dimension Code' ;
    rdfs:comment 'Code or identifier representing the specific value within the chosen dimension (e.g., MCC code, ISO country code, merchant ID, BIN number, rail identifier).' ;
    rdfs:domain ind:ConcentrationExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionType rdf:type rdf:Property ;
    rdfs:label 'Dimension Type' ;
    rdfs:comment 'Category of concentration risk dimension (e.g., Merchant Category Code, geographic region, single merchant, BIN, settlement rail).' ;
    rdfs:domain ind:ConcentrationExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureCurrency rdf:type rdf:Property ;
    rdfs:label 'Exposure Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the exposure amount.' ;
    rdfs:domain ind:ConcentrationExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureLimit rdf:type rdf:Property ;
    rdfs:label 'Exposure Limit' ;
    rdfs:comment 'Maximum allowed exposure for the dimension before breach, expressed in the reporting currency.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastAssessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Assessed Timestamp' ;
    rdfs:comment 'Timestamp of the most recent risk assessment run that produced the current exposure values.' ;
    rdfs:domain ind:ConcentrationExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:riskModelVersion rdf:type rdf:Property ;
    rdfs:label 'Risk Model Version' ;
    rdfs:comment 'Version string of the risk model applied to this exposure.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationPct rdf:type rdf:Property ;
    rdfs:label 'Utilization Pct' ;
    rdfs:comment 'Percentage of the limit that is currently utilized (exposure_amount / exposure_limit * 100).' ;
    rdfs:domain ind:ConcentrationExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterpartyRiskLimitId rdf:type rdf:Property ;
