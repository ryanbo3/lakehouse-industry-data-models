ind:featureCategory rdf:type rdf:Property ;
    rdfs:label 'Feature Category' ;
    rdfs:comment 'Broad category of the feature (e.g., contactless, international usage). [ENUM-REF-CANDIDATE: contactless|international|ecommerce|atm|recurring|3ds|dcc|bnpl — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InstrumentFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentFeatureStatus rdf:type rdf:Property ;
    rdfs:label 'Instrument Feature Status' ;
    rdfs:comment 'Current lifecycle status of the feature for the instrument.' ;
    rdfs:domain ind:InstrumentFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageResetPeriod rdf:type rdf:Property ;
    rdfs:label 'Usage Reset Period' ;
    rdfs:comment 'Period after which the usage_counter resets.' ;
    rdfs:domain ind:InstrumentFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentIssuanceId rdf:type rdf:Property ;
    rdfs:label 'Instrument Issuance Id' ;
    rdfs:comment 'System-generated unique identifier for the instrument issuance event.' ;
    rdfs:domain ind:InstrumentIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryAddressId rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Id' ;
    rdfs:comment 'Reference to the address where a physical instrument (card, letter) is to be sent.' ;
