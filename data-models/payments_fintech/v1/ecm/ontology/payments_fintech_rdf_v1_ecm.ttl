    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authenticationMessage rdf:type rdf:Property ;
    rdfs:label 'Authentication Message' ;
    rdfs:comment 'Human-readable message describing the authentication outcome.' ;
