    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designatedUse rdf:type rdf:Property ;
    rdfs:label 'Designated Use' ;
    rdfs:comment 'Business purpose for which payouts are made to this account.' ;
    rdfs:domain ind:PartnerSettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerSettlementAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Partner Settlement Account Status' ;
    rdfs:comment 'Current operational status of the settlement account.' ;
    rdfs:domain ind:PartnerSettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlScreeningRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Required Flag' ;
    rdfs:comment 'Indicates whether Anti-Money-Laundering screening is required for partners of this type.' ;
    rdfs:domain ind:PartnerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataPrivacyComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Compliance Flag' ;
    rdfs:comment 'True if the partner type is required to meet data-privacy regulations (e.g., GDPR, CCPA).' ;
    rdfs:domain ind:PartnerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeStructureType rdf:type rdf:Property ;
    rdfs:label 'Fee Structure Type' ;
    rdfs:comment 'Type of fee structure applied to this partner type.' ;
    rdfs:domain ind:PartnerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingBodyStandards rdf:type rdf:Property ;
    rdfs:label 'Governing Body Standards' ;
    rdfs:comment 'Applicable industry standards or regulatory frameworks governing this partner type (e.g., PCI DSS, EMVCo, PSD2, ISO 20022). [ENUM-REF-CANDIDATE: PCI_DSS|EMVCo|PSD2|ISO_20022|FATF|SOX|GDPR|CCPA — promote to reference product]' ;
    rdfs:domain ind:PartnerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Kyc Required Flag' ;
    rdfs:comment 'Indicates whether Know-Your-Customer verification is mandatory for partners of this type.' ;
    rdfs:domain ind:PartnerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkRole rdf:type rdf:Property ;
    rdfs:label 'Network Role' ;
    rdfs:comment 'Specific functional role(s) the partner plays in the payment network (e.g., acquiring, issuing, settlement, tokenization). [ENUM-REF-CANDIDATE: acquiring_bank|issuing_bank|card_scheme|psp|iso|payfac|aggregator|tsp|technology_partner|bnpl_provider|digital_wallet_provider|cross_border_specialist — promote to reference product]' ;
    rdfs:domain ind:PartnerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCategory rdf:type rdf:Property ;
    rdfs:label 'Partner Category' ;
    rdfs:comment 'High-level classification of the partner for regulatory and risk purposes.' ;
    rdfs:domain ind:PartnerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Partner Type Description' ;
    rdfs:comment 'Detailed description of the partner type, its role in the payments ecosystem, and typical services offered.' ;
    rdfs:domain ind:PartnerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueShareModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Model' ;
    rdfs:comment 'Model used to calculate revenue share with partners of this type.' ;
    rdfs:domain ind:PartnerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Surcharge Applicable Flag' ;
    rdfs:comment 'True if transaction surcharges may be applied to this partner type under regulatory rules.' ;
    rdfs:domain ind:PartnerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:typeCode rdf:type rdf:Property ;
    rdfs:label 'Type Code' ;
    rdfs:comment 'Compact alphanumeric code used to reference the partner type in system integrations.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeName rdf:type rdf:Property ;
    rdfs:label 'Type Name' ;
    rdfs:comment 'Human-readable name of the partner type (e.g., Acquiring Bank, Issuing Bank, PSP).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralRecordId rdf:type rdf:Property ;
    rdfs:label 'Referral Record Id' ;
    rdfs:comment 'System-generated unique identifier for the referral record.' ;
    rdfs:domain ind:ReferralRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryReferralEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Referral Employee Id' ;
    rdfs:comment 'Identifier of the internal user or system process that created the record.' ;
    rdfs:domain ind:ReferralRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:referredMerchantId rdf:type rdf:Property ;
    rdfs:label 'Referred Merchant Id' ;
    rdfs:comment 'Unique identifier of the merchant (or sub-merchant) that was referred.' ;
    rdfs:domain ind:ReferralRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Merchant .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Timestamp when the referral was converted into an active merchant (if applicable).' ;
    rdfs:domain ind:ReferralRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:convertedMid rdf:type rdf:Property ;
    rdfs:label 'Converted Mid' ;
    rdfs:comment 'MID assigned to the merchant after successful conversion.' ;
    rdfs:domain ind:ReferralRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fee Eligible Flag' ;
    rdfs:comment 'Indicates whether the referral qualifies for a commission based on program rules.' ;
    rdfs:domain ind:ReferralRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTestReferral rdf:type rdf:Property ;
    rdfs:label 'Is Test Referral' ;
    rdfs:comment 'Indicates whether the referral is a test record used for onboarding or QA.' ;
    rdfs:domain ind:ReferralRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Referral Campaign Code' ;
    rdfs:comment 'Code identifying the marketing or incentive campaign associated with the referral.' ;
    rdfs:domain ind:ReferralRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralChannel rdf:type rdf:Property ;
    rdfs:label 'Referral Channel' ;
    rdfs:comment 'Channel through which the referral was received.' ;
    rdfs:domain ind:ReferralRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralDate rdf:type rdf:Property ;
    rdfs:label 'Referral Date' ;
    rdfs:comment 'Timestamp when the partner submitted the referral.' ;
    rdfs:domain ind:ReferralRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referralFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Referral Fee Amount' ;
    rdfs:comment 'Monetary amount payable to the referring partner for a successful conversion.' ;
    rdfs:domain ind:ReferralRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referralFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Referral Fee Currency' ;
    rdfs:comment 'ISO 4217 currency code for the referral fee.' ;
    rdfs:domain ind:ReferralRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralNumber rdf:type rdf:Property ;
    rdfs:label 'Referral Number' ;
    rdfs:comment 'External reference code assigned to the referral for tracking across systems.' ;
    rdfs:domain ind:ReferralRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Referral Record Status' ;
    rdfs:comment 'Current lifecycle status of the referral.' ;
    rdfs:domain ind:ReferralRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralRegion rdf:type rdf:Property ;
    rdfs:label 'Referral Region' ;
    rdfs:comment 'Three-letter ISO country code representing the geographic region of the referral.' ;
    rdfs:domain ind:ReferralRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralType rdf:type rdf:Property ;
    rdfs:label 'Referral Type' ;
    rdfs:comment 'Category of the referring partner (ISO, PayFac, Agent, etc.).' ;
    rdfs:domain ind:ReferralRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueShareScheduleId rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Schedule Id' ;
    rdfs:comment 'Unique surrogate key for the revenue share schedule record.' ;
    rdfs:domain ind:RevenueShareSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bonusStructureDescription rdf:type rdf:Property ;
    rdfs:label 'Bonus Structure Description' ;
    rdfs:comment 'Free-text description of any bonus or performance-based components of the schedule.' ;
    rdfs:domain ind:RevenueShareSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Incentive Threshold Amount' ;
    rdfs:comment 'Monetary volume threshold that triggers additional incentive payments.' ;
    rdfs:domain ind:RevenueShareSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mdrSplitPercent rdf:type rdf:Property ;
    rdfs:label 'Mdr Split Percent' ;
    rdfs:comment 'Percentage of the MDR that is allocated to the partner.' ;
    rdfs:domain ind:RevenueShareSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msfTier rdf:type rdf:Property ;
    rdfs:label 'Msf Tier' ;
    rdfs:comment 'Tier identifier (e.g., A, B, C) that determines the MSF sharing percentage.' ;
    rdfs:domain ind:RevenueShareSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'How often revenue share amounts are calculated and paid to the partner.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualIncomeRate rdf:type rdf:Property ;
