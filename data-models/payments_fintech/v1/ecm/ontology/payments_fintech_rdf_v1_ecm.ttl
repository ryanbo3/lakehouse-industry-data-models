ind:hierarchyType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Type' ;
    rdfs:comment 'Classification of the relationship (e.g., PayFac to sub-merchant, ISO portfolio, corporate parent-subsidiary, aggregator-merchant).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'True if the child merchant may belong to only this parent; false if multi-parenting is allowed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:merchantHierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Merchant Hierarchy Status' ;
    rdfs:comment 'Operational state of the relationship (e.g., active, pending approval, suspended).' ;
    rdfs:domain ind:MerchantHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line for the merchant location (street number, street name, suite/unit).' ;
    rdfs:domain ind:MerchantLocation ;
