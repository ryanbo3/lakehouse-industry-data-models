ind:isTestVersion rdf:type rdf:Property ;
    rdfs:label 'Is Test Version' ;
    rdfs:comment 'True if the version is intended for testing environments only.' ;
    rdfs:domain ind:Software ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pciValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Pci Validation Status' ;
    rdfs:comment 'PCI validation outcome for the software package.' ;
    rdfs:domain ind:Software ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceCodes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Codes' ;
    rdfs:comment 'Pipe-separated list of regulatory codes applicable to this software (e.g., PCI|EMV|PSD2).' ;
    rdfs:domain ind:Software ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Score' ;
    rdfs:comment 'Numerical risk rating assigned by the security team (0.00-99.99).' ;
    rdfs:domain ind:Software ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:softwareDescription rdf:type rdf:Property ;
    rdfs:label 'Software Description' ;
    rdfs:comment 'Free-form description of the software\'s purpose and functionality.' ;
    rdfs:domain ind:Software ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareName rdf:type rdf:Property ;
    rdfs:label 'Software Name' ;
    rdfs:comment 'Human-readable name of the software package.' ;
    rdfs:domain ind:Software ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareType rdf:type rdf:Property ;
    rdfs:label 'Software Type' ;
    rdfs:comment 'Category of the software component.' ;
    rdfs:domain ind:Software ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRepository rdf:type rdf:Property ;
    rdfs:label 'Source Repository' ;
    rdfs:comment 'URL of the source code repository or binary storage location.' ;
    rdfs:domain ind:Software ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedPaymentSchemes rdf:type rdf:Property ;
    rdfs:label 'Supported Payment Schemes' ;
    rdfs:comment 'Payment schemes that the software version supports.' ;
    rdfs:domain ind:Software ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedTerminalFeatures rdf:type rdf:Property ;
    rdfs:label 'Supported Terminal Features' ;
    rdfs:comment 'Comma-separated list of terminal capabilities enabled by this software (e.g., NFC, EMV, QR).' ;
    rdfs:domain ind:Software ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatePriority rdf:type rdf:Property ;
    rdfs:label 'Update Priority' ;
    rdfs:comment 'Business priority for rolling out this software version.' ;
    rdfs:domain ind:Software ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusEventId rdf:type rdf:Property ;
    rdfs:label 'Status Event Id' ;
    rdfs:comment 'Unique identifier for the terminal status change event.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:statusActorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Status Actor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Status Change Audit logs the employee who performed the status change, needed for operational accountability.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:changeRequestReference rdf:type rdf:Property ;
    rdfs:label 'Change Request Reference' ;
    rdfs:comment 'Reference to the change-request record that authorized the status transition.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReference rdf:type rdf:Property ;
    rdfs:label 'Incident Reference' ;
    rdfs:comment 'Reference number of any incident or ticket linked to the status change.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason Code' ;
    rdfs:comment 'Standardized code describing why the status transition occurred (e.g., fraud_suspicion, hardware_failure, compliance, upgrade, merchant_request).' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalLocation rdf:type rdf:Property ;
    rdfs:label 'Terminal Location' ;
    rdfs:comment 'Physical location identifier (e.g., store code or address) where the terminal is installed.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeConfigId rdf:type rdf:Property ;
    rdfs:label 'Surcharge Config Id' ;
    rdfs:comment 'Unique identifier for the terminal surcharge configuration record.' ;
    rdfs:domain ind:SurchargeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jurisdictionCountryId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Surcharge configuration includes jurisdiction country code; FK to country master enables jurisdiction-specific surcharge compliance and reporting.' ;
    rdfs:domain ind:SurchargeConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:applicableCardScheme rdf:type rdf:Property ;
    rdfs:label 'Applicable Card Scheme' ;
    rdfs:comment 'Card network(s) to which the surcharge configuration applies.' ;
    rdfs:domain ind:SurchargeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableProductType rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Type' ;
    rdfs:comment 'Card product category (e.g., consumer, commercial) for which the surcharge is valid.' ;
    rdfs:domain ind:SurchargeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionStateCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction State Code' ;
    rdfs:comment 'Two-letter state code defining the jurisdictional scope of the surcharge (U.S. only).' ;
    rdfs:domain ind:SurchargeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Merchant Disclosure Flag' ;
    rdfs:comment 'Indicates whether the merchant has satisfied disclosure compliance for this surcharge configuration.' ;
    rdfs:domain ind:SurchargeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Disclosure Required' ;
    rdfs:comment 'Indicates whether regulatory rules require the merchant to disclose the surcharge to the cardholder.' ;
    rdfs:domain ind:SurchargeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surchargeApplicationRule rdf:type rdf:Property ;
    rdfs:label 'Surcharge Application Rule' ;
    rdfs:comment 'Rule defining how the surcharge is aggregated across transactions.' ;
    rdfs:domain ind:SurchargeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeCapAmount rdf:type rdf:Property ;
    rdfs:label 'Surcharge Cap Amount' ;
    rdfs:comment 'Maximum total surcharge amount that can be applied to a single transaction.' ;
    rdfs:domain ind:SurchargeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surchargeCapPercentage rdf:type rdf:Property ;
    rdfs:label 'Surcharge Cap Percentage' ;
    rdfs:comment 'Maximum surcharge expressed as a percentage of the transaction amount.' ;
    rdfs:domain ind:SurchargeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surchargeConfigDescription rdf:type rdf:Property ;
    rdfs:label 'Surcharge Config Description' ;
    rdfs:comment 'Human-readable description of the surcharge rules and purpose.' ;
    rdfs:domain ind:SurchargeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeConfigStatus rdf:type rdf:Property ;
    rdfs:label 'Surcharge Config Status' ;
    rdfs:comment 'Current lifecycle status of the surcharge configuration.' ;
    rdfs:domain ind:SurchargeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeMode rdf:type rdf:Property ;
    rdfs:label 'Surcharge Mode' ;
    rdfs:comment 'Indicates whether the surcharge is calculated as a percentage of the transaction amount or as a fixed monetary amount.' ;
    rdfs:domain ind:SurchargeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeType rdf:type rdf:Property ;
    rdfs:label 'Surcharge Type' ;
    rdfs:comment 'Category of payment instrument for which the surcharge is defined.' ;
    rdfs:domain ind:SurchargeConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tamperEventId rdf:type rdf:Property ;
    rdfs:label 'Tamper Event Id' ;
    rdfs:comment 'Unique identifier for the tamper event record.' ;
    rdfs:domain ind:TamperEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alert Sent Timestamp' ;
    rdfs:comment 'Timestamp when the alert was sent.' ;
    rdfs:domain ind:TamperEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceReportReference rdf:type rdf:Property ;
    rdfs:label 'Compliance Report Reference' ;
    rdfs:comment 'Reference identifier for the compliance report generated for this event.' ;
    rdfs:domain ind:TamperEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDetails rdf:type rdf:Property ;
    rdfs:label 'Event Details' ;
    rdfs:comment 'Free-text description providing additional context about the tamper event.' ;
    rdfs:domain ind:TamperEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAlertSent rdf:type rdf:Property ;
    rdfs:label 'Is Alert Sent' ;
    rdfs:comment 'Flag indicating whether an alert notification was sent to operations.' ;
    rdfs:domain ind:TamperEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isComplianceReported rdf:type rdf:Property ;
    rdfs:label 'Is Compliance Reported' ;
    rdfs:comment 'Indicates whether the tamper event was reported to regulatory compliance.' ;
    rdfs:domain ind:TamperEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTestEvent rdf:type rdf:Property ;
    rdfs:label 'Is Test Event' ;
    rdfs:comment 'Indicates if the event was generated from a test or simulation environment.' ;
    rdfs:domain ind:TamperEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseAction rdf:type rdf:Property ;
    rdfs:label 'Response Action' ;
    rdfs:comment 'Action taken by the terminal in response to the tamper event.' ;
    rdfs:domain ind:TamperEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorReference rdf:type rdf:Property ;
    rdfs:label 'Sensor Reference' ;
    rdfs:comment 'Identifier of the specific sensor that triggered the tamper detection.' ;
    rdfs:domain ind:TamperEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tamperType rdf:type rdf:Property ;
    rdfs:label 'Tamper Type' ;
    rdfs:comment 'Category of tamper detected.' ;
    rdfs:domain ind:TamperEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tidProvisioningId rdf:type rdf:Property ;
    rdfs:label 'Tid Provisioning Id' ;
    rdfs:comment 'System-generated unique identifier for each terminal provisioning record.' ;
    rdfs:domain ind:TidProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acquiringBin rdf:type rdf:Property ;
    rdfs:label 'Acquiring Bin' ;
    rdfs:comment 'Bank Identification Number of the acquiring bank that processes the terminal\'s transactions.' ;
    rdfs:domain ind:TidProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSoftwareUpdate rdf:type rdf:Property ;
    rdfs:label 'Last Software Update' ;
    rdfs:comment 'Timestamp of the most recent software/firmware update applied to the terminal.' ;
    rdfs:domain ind:TidProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:provisioningDate rdf:type rdf:Property ;
    rdfs:label 'Provisioning Date' ;
    rdfs:comment 'Date and time when the terminal was provisioned in the system.' ;
    rdfs:domain ind:TidProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:schemeRegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'Scheme Registration Status' ;
    rdfs:comment 'Current registration status of the terminal with the payment scheme.' ;
    rdfs:domain ind:TidProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityCertification rdf:type rdf:Property ;
    rdfs:label 'Security Certification' ;
    rdfs:comment 'Security certification level of the terminal per PCI PTS standards.' ;
    rdfs:domain ind:TidProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tidProvisioningStatus rdf:type rdf:Property ;
    rdfs:label 'Tid Provisioning Status' ;
    rdfs:comment 'Current operational status of the terminal.' ;
    rdfs:domain ind:TidProvisioning ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:achEntryId rdf:type rdf:Property ;
    rdfs:label 'Ach Entry Id' ;
    rdfs:comment 'System-generated unique identifier for the ACH entry record.' ;
    rdfs:domain ind:AchEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:achEntryStatus rdf:type rdf:Property ;
    rdfs:label 'Ach Entry Status' ;
    rdfs:comment 'Current lifecycle status of the ACH entry.' ;
