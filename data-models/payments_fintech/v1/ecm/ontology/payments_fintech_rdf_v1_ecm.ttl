    rdfs:range xsd:string .

ind:trainingType rdf:type rdf:Property ;
    rdfs:label 'Training Type' ;
    rdfs:comment 'Indicates whether the training is mandatory, optional, refresher, or certification.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeStatus rdf:type rdf:Property ;
    rdfs:label 'Active Status' ;
    rdfs:comment 'Current operational status of the watchlist entry.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:address rdf:type rdf:Property ;
    rdfs:label 'Address' ;
    rdfs:comment 'Physical address associated with the entity on the watchlist.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityAliases rdf:type rdf:Property ;
    rdfs:label 'Entity Aliases' ;
    rdfs:comment 'Comma-separated list of alternative names, spellings, or known aliases for the entity.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityName rdf:type rdf:Property ;
    rdfs:label 'Entity Name' ;
    rdfs:comment 'Legal name of the individual, organization, or vessel as listed on the watchlist.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationNumber rdf:type rdf:Property ;
    rdfs:label 'Identification Number' ;
    rdfs:comment 'Official identifier such as passport number, national ID, or tax ID.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationType rdf:type rdf:Property ;
    rdfs:label 'Identification Type' ;
    rdfs:comment 'Type of the identification number provided.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the watchlist entry.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:listEntryReference rdf:type rdf:Property ;
    rdfs:label 'List Entry Reference' ;
    rdfs:comment 'Identifier used by the source list to reference this entry (e.g., SDN ID).' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listSource rdf:type rdf:Property ;
    rdfs:label 'List Source' ;
    rdfs:comment 'Originating sanctions or watchlist source for the entry.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listVersionDate rdf:type rdf:Property ;
    rdfs:label 'List Version Date' ;
    rdfs:comment 'Date of the version of the source list that contains this entry.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:placeOfBirth rdf:type rdf:Property ;
    rdfs:label 'Place Of Birth' ;
    rdfs:comment 'Geographic location where the individual was born.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsType rdf:type rdf:Property ;
    rdfs:label 'Sanctions Type' ;
    rdfs:comment 'Primary type of sanction applied to the entity.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceUrl rdf:type rdf:Property ;
    rdfs:label 'Source Url' ;
    rdfs:comment 'Web address or document reference where the entry was originally published.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arbitrationCaseId rdf:type rdf:Property ;
    rdfs:label 'Arbitration Case Id' ;
    rdfs:comment 'Unique surrogate identifier for the arbitration case record in the Dispute and Chargeback Management System. Primary key for this entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Analyst Employee Id' ;
    rdfs:comment 'Reference to the internal dispute analyst or case manager responsible for managing this arbitration case. PARTY_REFERENCE (internal workforce) for operational accountability and workload reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cardSchemeId rdf:type rdf:Property ;
    rdfs:label 'Card Scheme Id' ;
    rdfs:comment 'Foreign key linking to reference.reference_card_scheme. Business justification: Arbitration procedures differ by card scheme; linking enables accurate arbitration fee calculation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CardScheme .

ind:chargebackId rdf:type rdf:Property ;
    rdfs:label 'Chargeback Id' ;
    rdfs:comment 'Reference to the parent chargeback record from which this arbitration case was escalated. Links the arbitration proceeding to its originating chargeback dispute lifecycle.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Chargeback .

ind:arbitrationDecision rdf:type rdf:Property ;
    rdfs:label 'Arbitration Decision' ;
    rdfs:comment 'Formal outcome of the card scheme arbitration proceeding. Indicates whether the filing party\'s position was upheld, the respondent prevailed, liability was split, or the case was withdrawn before decision.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arn rdf:type rdf:Property ;
    rdfs:label 'Arn' ;
    rdfs:comment 'Acquirer Reference Number uniquely identifying the original transaction within the card scheme network. Used to link the arbitration case to the specific transaction across issuer, acquirer, and scheme systems. Standard 23-digit identifier per card scheme rules.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCaseFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Case Flag' ;
    rdfs:comment 'Indicates whether this arbitration case has been designated as a compliance case (as opposed to a standard chargeback arbitration). Compliance cases arise from violations of card scheme rules rather than transaction disputes and follow a distinct scheme process.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceViolationType rdf:type rdf:Property ;
    rdfs:label 'Compliance Violation Type' ;
    rdfs:comment 'Type of card scheme rule violation cited in a compliance arbitration case (e.g., late presentment, invalid authorization, data integrity violation). Populated only when compliance_case_flag is true. [ENUM-REF-CANDIDATE: late_presentment|invalid_authorization|data_integrity|security_violation|processing_error|other — promote to reference product]' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Date on which the card scheme issued its formal arbitration decision. Used to track scheme turnaround time and trigger post-decision financial adjustment processing.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionRationale rdf:type rdf:Property ;
    rdfs:label 'Decision Rationale' ;
    rdfs:comment 'Narrative explanation or scheme-provided rationale for the arbitration decision outcome. Documents the basis for liability assignment and supports internal review, representment analysis, and regulatory audit trail.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeAmount rdf:type rdf:Property ;
    rdfs:label 'Dispute Amount' ;
    rdfs:comment 'Gross monetary amount of the original disputed transaction that is the subject of the arbitration. Expressed in the transaction currency. Part of MONETARY_TRIPLET for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeCategory rdf:type rdf:Property ;
    rdfs:label 'Dispute Category' ;
    rdfs:comment 'High-level classification of the dispute type underlying the arbitration case. Groups reason codes into operational categories for reporting and analytics. Aligns with card scheme dispute category frameworks.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the dispute transaction amount (e.g., USD, EUR, GBP). Required for cross-border dispute processing and FX conversion calculations. Part of MONETARY_TRIPLET.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationCycleCount rdf:type rdf:Property ;
    rdfs:label 'Escalation Cycle Count' ;
    rdfs:comment 'Number of dispute lifecycle cycles (chargeback, representment, pre-arbitration) completed before escalation to formal arbitration. Provides context on the dispute history depth and scheme compliance with mandatory pre-arbitration steps.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidencePackageSubmitted rdf:type rdf:Property ;
    rdfs:label 'Evidence Package Submitted' ;
    rdfs:comment 'Indicates whether the responding party has submitted a complete evidence package (representment documentation, transaction records, cardholder communications) in response to the arbitration filing.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Evidence Submission Date' ;
    rdfs:comment 'Date on which the evidence package was submitted to the card scheme for the arbitration proceeding. Used to verify compliance with scheme-mandated evidence submission deadlines.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingParty rdf:type rdf:Property ;
    rdfs:label 'Filing Party' ;
    rdfs:comment 'Identifies which party in the payment chain initiated the arbitration filing with the card scheme. Either the issuing bank (cardholder\'s bank) or the acquiring bank (merchant\'s bank). Determines the direction of liability argument.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Filing Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) when the arbitration case was submitted to the card scheme. Provides exact filing time for SLA tracking and scheme deadline calculations. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:glAdjustmentDate rdf:type rdf:Property ;
    rdfs:label 'Gl Adjustment Date' ;
    rdfs:comment 'Date on which the financial liability adjustment was posted to the General Ledger following the arbitration decision. Used for period-end financial reconciliation and revenue recognition in Oracle Financials.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glAdjustmentPosted rdf:type rdf:Property ;
    rdfs:label 'Gl Adjustment Posted' ;
    rdfs:comment 'Indicates whether the financial liability adjustment resulting from the arbitration decision has been posted to the General Ledger in Oracle Financials. Supports financial close reconciliation and SOX compliance.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hearingDate rdf:type rdf:Property ;
    rdfs:label 'Hearing Date' ;
    rdfs:comment 'Scheduled or actual date of the formal arbitration hearing or review session conducted by the card scheme. May be null if the scheme resolves the case on documentary evidence without a formal hearing.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalCaseNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Case Notes' ;
    rdfs:comment 'Free-text field for internal operational notes, analyst observations, and case management commentary related to the arbitration proceeding. Not shared with the card scheme; used for internal dispute team coordination.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuerBin rdf:type rdf:Property ;
    rdfs:label 'Issuer Bin' ;
    rdfs:comment 'Bank Identification Number (BIN) / Issuer Identification Number (IIN) of the issuing bank involved in the arbitration. Used to identify the card-issuing institution and route scheme communications. 6-8 digit prefix per ISO 7812.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Amount' ;
    rdfs:comment 'Net monetary amount of financial liability assigned to the losing party following the arbitration decision. Represents the final financial obligation resulting from the arbitration outcome. Part of MONETARY_TRIPLET — net total component.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Liability Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the financial liability assignment amount. Ensures accurate multi-currency financial reporting and GL posting.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liableParty rdf:type rdf:Property ;
    rdfs:label 'Liable Party' ;
    rdfs:comment 'Party assigned financial liability by the card scheme arbitration decision. Determines which entity bears the financial loss from the disputed transaction and scheme fees.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mid rdf:type rdf:Property ;
    rdfs:label 'Mid' ;
    rdfs:comment 'Merchant Identification Number assigned by the acquirer to uniquely identify the merchant in card scheme communications. Distinct from the internal merchant_id surrogate key; this is the scheme-facing identifier used in dispute and arbitration filings.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Date' ;
    rdfs:comment 'Date of the original payment transaction that is the subject of the arbitration dispute. Used for aging analysis, scheme filing window compliance verification, and statute of limitations assessment.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preArbitrationCycleCompleted rdf:type rdf:Property ;
    rdfs:label 'Pre Arbitration Cycle Completed' ;
    rdfs:comment 'Indicates whether the mandatory pre-arbitration cycle (second chargeback and pre-arbitration exchange) was completed before escalation to formal arbitration. Required by card scheme rules before arbitration filing is accepted.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:schemeArbitrationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Scheme Arbitration Fee Amount' ;
    rdfs:comment 'Fee charged by the card scheme for processing the arbitration case. Typically assessed against the losing party per scheme rules. Part of MONETARY_TRIPLET — adjustment/fee component. Amount in scheme fee currency.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:schemeCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Scheme Case Number' ;
    rdfs:comment 'Externally assigned arbitration case number issued by the card scheme (Visa or Mastercard) upon formal arbitration filing. This is the BUSINESS_IDENTIFIER used by all parties and the scheme to reference the proceeding. Format varies by scheme.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Scheme Fee Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the scheme arbitration fee amount. May differ from the dispute transaction currency for cross-border cases.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Analyst Employee Id' ;
    rdfs:comment 'Internal surrogate identifier of the dispute analyst or case worker currently assigned to manage and resolve this dispute case. Used for workload management, SLA tracking, and audit trail purposes.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:authorizationId rdf:type rdf:Property ;
    rdfs:label 'Authorization Id' ;
    rdfs:comment 'Foreign key linking to transaction.authorization. Business justification: Case analysts need original auth details (auth code, response) to determine liability and compliance outcomes.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Authorization .

ind:captureId rdf:type rdf:Property ;
    rdfs:label 'Capture Id' ;
    rdfs:comment 'Foreign key linking to transaction.capture. Business justification: Capture information supports accurate calculation of disputed amounts and fee reversals in case settlements.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capture .

ind:crossBorderPaymentId rdf:type rdf:Property ;
    rdfs:label 'Cross Border Payment Id' ;
    rdfs:comment 'Foreign key linking to fx.cross_border_payment. Business justification: Dispute cases originating from cross-border payments need the payment reference for compliance and routing analysis.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrossBorderPayment .

ind:paymentTxnId rdf:type rdf:Property ;
    rdfs:label 'Payment Txn Id' ;
    rdfs:comment 'Foreign key linking to transaction.payment_txn. Business justification: Dispute case reports reference the original payment transaction to provide a complete audit trail and regulatory evidence.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTxn .

ind:arbitrationFilingDate rdf:type rdf:Property ;
    rdfs:label 'Arbitration Filing Date' ;
    rdfs:comment 'Date on which the dispute was escalated to card scheme arbitration after pre-arbitration failed to reach resolution. Null if the case did not reach arbitration. Arbitration decisions are binding and final per card scheme rules.' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargebackFilingDate rdf:type rdf:Property ;
    rdfs:label 'Chargeback Filing Date' ;
    rdfs:comment 'Date on which the formal chargeback was filed with the card scheme by the issuing bank. Marks the start of the chargeback lifecycle stage and triggers merchant response deadlines. Null if the case has not yet reached chargeback stage.' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargebackReasonCode rdf:type rdf:Property ;
    rdfs:label 'Chargeback Reason Code' ;
    rdfs:comment 'Card scheme-specific reason code assigned to the chargeback, identifying the precise basis for the dispute (e.g., Visa reason code 10.4 for Other Fraud — Card Absent, Mastercard reason code 4853 for Cardholder Dispute). Null for retrieval requests that have not yet escalated to chargeback. [ENUM-REF-CANDIDATE: promote to reference product — codes vary by card scheme and are subject to periodic updates by Visa, Mastercard, Amex, and Discover]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Timestamp' ;
    rdfs:comment 'Date and time when the dispute case was formally closed and all activities concluded. Null if the case is still open. Used to calculate total case duration and measure resolution cycle time against SLA targets.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disputeChannel rdf:type rdf:Property ;
    rdfs:label 'Dispute Channel' ;
    rdfs:comment 'Channel through which the cardholder or issuing bank initiated the dispute. Values: online (web portal), phone (call center), branch (in-person), mobile_app (mobile banking app), scheme_portal (direct card scheme submission). Used for channel analytics and process optimization.' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'High-level classification of the dispute category as defined by card scheme rules. Values: fraud (unauthorized transaction), authorization (authorization-related issue), processing_error (duplicate, incorrect amount, etc.), consumer_dispute (goods/services not received or not as described), compliance (regulatory or scheme compliance violation).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Evidence Submitted Flag' ;
    rdfs:comment 'Indicates whether the merchant has submitted an evidence package (e.g., transaction receipts, delivery confirmation, signed authorization) in response to the chargeback. True = evidence package received. Used to track representment completeness and SLA compliance.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interchangeFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Interchange Fee Amount' ;
    rdfs:comment 'Interchange Reimbursement Fee amount associated with the disputed transaction, which may be reversed or adjusted as part of the chargeback process. Relevant for financial reconciliation between the acquiring bank and issuing bank.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:is3dsAuthenticated rdf:type rdf:Property ;
    rdfs:label 'Is 3ds Authenticated' ;
    rdfs:comment 'Indicates whether the original transaction was authenticated using 3-D Secure (3DS) protocol at the time of authorization. True = 3DS authentication was performed. Relevant for liability shift determination — 3DS-authenticated transactions shift chargeback liability to the issuer.' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFraudConfirmed rdf:type rdf:Property ;
    rdfs:label 'Is Fraud Confirmed' ;
    rdfs:comment 'Indicates whether the dispute has been confirmed as a fraudulent transaction by the fraud investigation team or card scheme ruling. True = confirmed fraud; False = not confirmed as fraud. Used for fraud analytics, SAR filing decisions, and AML reporting.' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingBankBin rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank Bin' ;
    rdfs:comment 'Bank Identification Number (BIN) / Issuer Identification Number (IIN) of the issuing bank that initiated the dispute on behalf of the cardholder. First 6-8 digits of the PAN identifying the card issuer. Used for dispute routing and interchange settlement.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityParty rdf:type rdf:Property ;
    rdfs:label 'Liability Party' ;
    rdfs:comment 'The party determined to bear financial liability for the disputed transaction based on card scheme rules, authentication status, and dispute outcome. Drives financial adjustment routing between issuing bank, acquiring bank, and merchant.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current stage in the dispute lifecycle workflow as governed by card scheme rules. Progresses from retrieval_request through chargeback, representment, pre_arbitration, arbitration, to closed. Drives SLA deadlines and permissible actions at each stage.' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openTimestamp rdf:type rdf:Property ;
    rdfs:label 'Open Timestamp' ;
    rdfs:comment 'Date and time when the dispute case was formally opened in the Dispute and Chargeback Management System. Serves as the principal business event timestamp and the anchor for all SLA deadline calculations per card scheme rules.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Amount' ;
    rdfs:comment 'The full monetary amount of the original payment transaction that is the subject of this dispute, in the original transaction currency. Provides context for partial dispute scenarios where dispute_amount is less than the full transaction value.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalTransactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the original payment transaction. May differ from dispute_currency_code in Dynamic Currency Conversion (DCC) scenarios or cross-border transactions.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representmentDate rdf:type rdf:Property ;
    rdfs:label 'Representment Date' ;
    rdfs:comment 'Date on which the merchant submitted a representment (rebuttal) package challenging the chargeback. Null if no representment has been filed. Used to track merchant response timeliness and advance the lifecycle stage.' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retrievalRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Retrieval Request Number' ;
    rdfs:comment 'Unique identifier assigned to the pre-chargeback retrieval request (also known as a copy request) issued by the issuing bank to obtain transaction documentation from the acquirer. Null if the case was filed directly as a chargeback without a prior retrieval request.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Sar Filed Flag' ;
    rdfs:comment 'Indicates whether a Suspicious Activity Report (SAR) was filed with FinCEN in connection with this dispute case due to suspected money laundering, fraud patterns, or other financial crimes identified during the dispute investigation.' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:schemeCaseReference rdf:type rdf:Property ;
    rdfs:label 'Scheme Case Reference' ;
    rdfs:comment 'Reference number assigned by the card scheme (Visa, Mastercard, etc.) to track the dispute within their own dispute management system (e.g., Visa Resolve Online - VROL, Mastercard Connect). Used for cross-referencing internal records with scheme-side tracking.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Adjustment Amount' ;
    rdfs:comment 'Net financial adjustment amount applied to the settlement account as a result of the dispute resolution. May differ from dispute_amount due to partial recoveries, fees, or write-offs. Negative value indicates a debit to the merchant; positive indicates a credit to the cardholder.' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackReasonCodeId rdf:type rdf:Property ;
    rdfs:label 'Chargeback Reason Code Id' ;
    rdfs:comment 'Reference to the card scheme reason code record in the reference domain that classifies the basis for the chargeback (e.g., fraud, not as described, duplicate processing, credit not processed). Each card scheme (Visa, Mastercard, Amex, Discover) maintains its own reason code taxonomy.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChargebackReasonCode .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Reference to the General Ledger entry in Oracle Financials (ERP) recording the financial adjustment associated with this chargeback. Enables reconciliation between the dispute management system and the financial accounting system for SOX compliance and revenue recognition.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:rateId rdf:type rdf:Property ;
    rdfs:label 'Rate Id' ;
    rdfs:comment 'Foreign key linking to fx.fx_rate. Business justification: Chargeback settlement report requires original FX rate for currency conversion of the chargeback amount.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rate .

ind:responseId rdf:type rdf:Property ;
    rdfs:label 'Response Id' ;
    rdfs:comment 'Foreign key linking to gateway.gateway_response. Business justification: Chargeback reconciliation needs the original acquirer response to verify decline reason, authorization code, and fraud flags.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Response .

ind:settlementId rdf:type rdf:Property ;
    rdfs:label 'Settlement Id' ;
    rdfs:comment 'Foreign key linking to settlement.settlement. Business justification: Chargeback settlement reports must link to the settlement record that includes the chargeback amount for traceability.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Settlement .

ind:walletTransactionId rdf:type rdf:Property ;
    rdfs:label 'Wallet Transaction Id' ;
    rdfs:comment 'Foreign key linking to wallet.wallet_transaction. Business justification: Chargeback processing for wallet transactions requires linking each chargeback to the specific wallet transaction that was disputed, enabling accurate reconciliation and reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WalletTransaction .

ind:acquirerReference rdf:type rdf:Property ;
    rdfs:label 'Acquirer Reference' ;
    rdfs:comment 'Acquiring bank\'s internal reference number for this chargeback case. Used by the acquiring bank\'s operations team to track the chargeback in their internal systems and correlate with the card scheme case identifier.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Net financial adjustment amount posted to the merchant\'s account as a result of this chargeback. Includes the chargeback amount plus any applicable scheme fees, processing fees, or interchange adjustments. Negative value indicates a debit to the merchant; positive value indicates a credit (e.g., upon successful representment).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Gross amount of the chargeback as filed by the issuing bank in the transaction currency. Represents the disputed amount that will be debited from the merchant\'s account if the chargeback is upheld. May differ from the original transaction amount in cases of partial chargebacks.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arbitrationDeadline rdf:type rdf:Property ;
    rdfs:label 'Arbitration Deadline' ;
    rdfs:comment 'Scheme-mandated deadline for filing an arbitration case with the card scheme after a failed pre-arbitration or second chargeback cycle. Arbitration is the final escalation path where the card scheme adjudicates the dispute and assigns liability. Missing this deadline forfeits the right to arbitration.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:arbitrationFilingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Arbitration Filing Timestamp' ;
    rdfs:comment 'Actual timestamp when the arbitration case was filed with the card scheme. Populated only when the chargeback has been escalated to the arbitration stage (cycle_stage = ARBITRATION).' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cardholderDisputeReason rdf:type rdf:Property ;
    rdfs:label 'Cardholder Dispute Reason' ;
    rdfs:comment 'Free-text description of the cardholder\'s stated reason for disputing the transaction as captured by the issuing bank. Provides the narrative context behind the formal reason code classification. Used by the merchant in preparing the representment package.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackStatus rdf:type rdf:Property ;
    rdfs:label 'Chargeback Status' ;
    rdfs:comment 'Current disposition and lifecycle status of the chargeback record. Tracks the chargeback from initial receipt through final resolution. RECEIVED: chargeback filed by issuer; UNDER_REVIEW: internal review in progress; AWAITING_RESPONSE: merchant response pending; REPRESENTED: merchant submitted representment; ACCEPTED: merchant accepted liability; WON: merchant successfully defended; LOST: chargeback upheld; ARBITRATION: escalated to scheme arbitration; CLOSED: final resolution reached. [ENUM-REF-CANDIDATE: RECEIVED|UNDER_REVIEW|AWAITING_RESPONSE|REPRESENTED|ACCEPTED|WON|LOST|ARBITRATION|CLOSED — promote to reference product]' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the currency in which the chargeback amount is denominated. May differ from the original transaction currency in cross-border disputes where Dynamic Currency Conversion (DCC) was applied.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleStage rdf:type rdf:Property ;
    rdfs:label 'Cycle Stage' ;
    rdfs:comment 'Current stage in the chargeback lifecycle cycle as defined by card scheme rules. FIRST_CHARGEBACK is the initial filing by the issuer; SECOND_CHARGEBACK (also called pre-arbitration chargeback under Mastercard rules) occurs after a failed representment; PRE_ARBITRATION is the Visa pre-arbitration stage; ARBITRATION is the final scheme-level adjudication; COMPLIANCE is a scheme compliance filing.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineMet rdf:type rdf:Property ;
    rdfs:label 'Deadline Met' ;
    rdfs:comment 'Indicates whether the chargeback response was submitted on or before the scheme-mandated response deadline. True if response_timestamp is on or before response_deadline; False if the deadline was missed, resulting in automatic acceptance of the chargeback liability.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidencePackageRef rdf:type rdf:Property ;
    rdfs:label 'Evidence Package Ref' ;
    rdfs:comment 'Reference identifier for the evidence package (representment documentation) submitted by the merchant to contest the chargeback. Points to the document management system location containing delivery confirmations, signed receipts, authorization records, and other supporting evidence.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudIndicator rdf:type rdf:Property ;
    rdfs:label 'Fraud Indicator' ;
    rdfs:comment 'Indicates whether this chargeback is classified as fraud-related based on the reason code category (True) or non-fraud (False). Fraud chargebacks (e.g., Visa reason code 10.x, Mastercard reason code 4837/4863) are tracked separately for fraud reporting, chargeback ratio monitoring, and Fraud Detection and Prevention Platform feedback loops.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartialChargeback rdf:type rdf:Property ;
    rdfs:label 'Is Partial Chargeback' ;
    rdfs:comment 'Indicates whether this chargeback is for a partial amount of the original transaction (True) or for the full transaction amount (False). Partial chargebacks occur when only a portion of the goods or services are disputed.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the currency in which the original payment transaction was denominated. Enables currency reconciliation in cross-border dispute scenarios involving Foreign Exchange (FX) or Dynamic Currency Conversion (DCC).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratioFlag rdf:type rdf:Property ;
    rdfs:label 'Ratio Flag' ;
    rdfs:comment 'Indicates whether this chargeback has been flagged as contributing to the merchant\'s chargeback ratio threshold breach under card scheme monitoring programs (e.g., Visa Chargeback Monitoring Program - VCMP, Mastercard Excessive Chargeback Program - ECP). Merchants exceeding scheme thresholds face fines and potential termination.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:representmentDeadline rdf:type rdf:Property ;
    rdfs:label 'Representment Deadline' ;
    rdfs:comment 'Scheme-mandated deadline by which the merchant must submit a representment (rebuttal) package to challenge the chargeback. Distinct from response_deadline in that it specifically governs the representment submission window after the merchant elects to contest the chargeback.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:representmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Representment Timestamp' ;
    rdfs:comment 'Actual timestamp when the merchant submitted the representment package to contest the chargeback. A representment is the merchant\'s formal response disputing the chargeback, including evidence such as delivery confirmation, signed receipts, or fraud documentation.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'Actual timestamp when the merchant or acquiring bank submitted their response (representment package or acceptance) to the chargeback. Compared against response_deadline to determine deadline compliance status.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:schemeFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Scheme Fee Amount' ;
    rdfs:comment 'Fee charged by the card scheme (Visa, Mastercard, Amex, Discover) for processing the chargeback. Scheme fees are assessed per chargeback filing and may vary by scheme, reason code, and merchant chargeback ratio tier. Debited from the acquiring bank and typically passed through to the merchant.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaBreach rdf:type rdf:Property ;
    rdfs:label 'Sla Breach' ;
    rdfs:comment 'Indicates whether the internal SLA for chargeback processing was breached (True) for this case. Internal SLAs govern the time from chargeback receipt to merchant notification, evidence collection, and representment submission, distinct from the scheme-mandated response deadlines.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimId rdf:type rdf:Property ;
    rdfs:label 'Claim Id' ;
    rdfs:comment 'Primary key for claim' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedAgentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Agent Employee Id' ;
    rdfs:comment 'Reference to the customer service or dispute resolution agent assigned to handle this claim.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:chargebackCaseChargebackId rdf:type rdf:Property ;
    rdfs:label 'Chargeback Case Chargeback Id' ;
    rdfs:comment 'Reference to the formal chargeback case record if this claim was escalated to the chargeback process.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Chargeback .

ind:actualResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Date' ;
    rdfs:comment 'The actual date on which the claim was resolved (approved, denied, or withdrawn).' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cardholderStatement rdf:type rdf:Property ;
    rdfs:label 'Cardholder Statement' ;
    rdfs:comment 'Free-text narrative provided by the cardholder describing the reason for the dispute and supporting details.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Externally-visible unique claim identifier provided to the cardholder for tracking and reference purposes.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle status of the dispute claim: submitted, under review, pending documentation, approved, denied, withdrawn, or escalated to chargeback. [ENUM-REF-CANDIDATE: submitted|under_review|pending_documentation|approved|denied|withdrawn|escalated_to_chargeback — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Classification of the dispute claim based on the nature of the cardholders assertion: unauthorized transaction, item not received, item not as described, duplicate charge, credit not processed, or service not rendered.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactAttemptCount rdf:type rdf:Property ;
    rdfs:label 'Contact Attempt Count' ;
    rdfs:comment 'The number of times the dispute resolution team attempted to contact the cardholder for additional information or clarification.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputedTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Transaction Amount' ;
    rdfs:comment 'The monetary amount of the original transaction that is being disputed by the cardholder.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputedTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Disputed Transaction Date' ;
    rdfs:comment 'The original transaction date of the payment being disputed by the cardholder.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentationReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Documentation Reference Code' ;
    rdfs:comment 'Reference identifier linking to the document management system where supporting evidence files are stored.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedToChargebackFlag rdf:type rdf:Property ;
    rdfs:label 'Escalated To Chargeback Flag' ;
    rdfs:comment 'Boolean indicator of whether this claim was escalated to a formal chargeback filing with the card network.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Resolution Date' ;
    rdfs:comment 'The target date by which the claim investigation and resolution is expected to be completed, based on regulatory timelines and internal SLAs.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fraudIndicatorFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Indicator Flag' ;
    rdfs:comment 'Boolean indicator of whether the claim was flagged as potentially fraudulent and routed to the fraud investigation team.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initialTriageOutcome rdf:type rdf:Property ;
    rdfs:label 'Initial Triage Outcome' ;
    rdfs:comment 'The outcome of the initial automated or manual triage assessment: accepted for review, rejected due to insufficient information, rejected as out of timeframe, escalated to fraud investigation, or provisional credit issued.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Contact Timestamp' ;
    rdfs:comment 'The date and time of the most recent contact attempt or successful communication with the cardholder regarding this claim.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'The date and time when this claim record was last updated in the dispute management system.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:merchantCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Merchant Category Code' ;
    rdfs:comment 'Four-digit code classifying the type of goods or services provided by the merchant involved in the disputed transaction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Provisional Credit Amount' ;
    rdfs:comment 'The monetary amount of provisional credit issued to the cardholder, if applicable.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisionalCreditDate rdf:type rdf:Property ;
    rdfs:label 'Provisional Credit Date' ;
    rdfs:comment 'The date on which provisional credit was posted to the cardholder account.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:provisionalCreditIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Provisional Credit Issued Flag' ;
    rdfs:comment 'Boolean indicator of whether a provisional credit was issued to the cardholder account while the claim is under investigation, as required by Regulation E for certain dispute types.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Internal notes documenting the investigation findings, decision rationale, and resolution details.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for the claim resolution outcome, aligned with card scheme reason code taxonomies.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'The channel through which the cardholder submitted the dispute claim: mobile app, call center, online portal, branch, email, or chat.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentationProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Provided Flag' ;
    rdfs:comment 'Boolean indicator of whether the cardholder provided supporting documentation (receipts, correspondence, delivery confirmations) with the claim submission.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:triageTimestamp rdf:type rdf:Property ;
    rdfs:label 'Triage Timestamp' ;
    rdfs:comment 'The date and time when the initial triage assessment was completed.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disputeComplianceCaseId rdf:type rdf:Property ;
    rdfs:label 'Dispute Compliance Case Id' ;
    rdfs:comment 'Primary key for compliance_case' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acquirerBin rdf:type rdf:Property ;
    rdfs:label 'Acquirer Bin' ;
    rdfs:comment 'Bank Identification Number of the acquiring bank responsible for the merchant under compliance review.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquirerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Acquirer Reference Number' ;
    rdfs:comment 'Unique 23-character reference number assigned by the acquiring bank to track the transaction lifecycle, used for linking compliance cases to specific transaction disputes.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessedFineAmount rdf:type rdf:Property ;
    rdfs:label 'Assessed Fine Amount' ;
    rdfs:comment 'Monetary fine amount assessed by the card scheme for the compliance violation.' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caseClosureDate rdf:type rdf:Property ;
    rdfs:label 'Case Closure Date' ;
    rdfs:comment 'Date when the compliance case was officially closed by the card scheme after all requirements were met.' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseClosureReason rdf:type rdf:Property ;
    rdfs:label 'Case Closure Reason' ;
    rdfs:comment 'Reason code indicating why the compliance case was closed (e.g., remediation completed, fine paid, violation resolved, case withdrawn, escalated to arbitration).' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseOpenedDate rdf:type rdf:Property ;
    rdfs:label 'Case Opened Date' ;
    rdfs:comment 'Date when the compliance case was officially opened by the card scheme or internal compliance team.' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargebackCount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Count' ;
    rdfs:comment 'Total number of chargebacks associated with the merchant during the violation period that contributed to the compliance case.' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargebackRatio rdf:type rdf:Property ;
    rdfs:label 'Chargeback Ratio' ;
    rdfs:comment 'Ratio of chargebacks to total transactions for the merchant during the violation period, expressed as a decimal (e.g., 0.0125 for 1.25%).' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Current escalation level of the compliance case within the internal compliance management hierarchy (e.g., level 1, level 2, level 3, executive escalation).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fineCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fine Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the assessed fine amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fineDueDate rdf:type rdf:Property ;
    rdfs:label 'Fine Due Date' ;
    rdfs:comment 'Date by which the assessed fine must be paid to the card scheme to avoid further penalties.' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finePaidDate rdf:type rdf:Property ;
    rdfs:label 'Fine Paid Date' ;
    rdfs:comment 'Date when the assessed fine was fully paid to the card scheme.' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finePaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Fine Payment Status' ;
    rdfs:comment 'Current payment status of the assessed fine (e.g., unpaid, partially paid, paid, waived, disputed).' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Internal notes and comments regarding the compliance case, remediation efforts, and communications with the card scheme.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciDssViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Violation Flag' ;
    rdfs:comment 'Boolean flag indicating whether the compliance case involves a PCI DSS data security violation (True) or not (False).' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether the compliance case requires regulatory reporting to authorities such as FinCEN, CFPB, or FCA (True) or not (False).' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completed Date' ;
    rdfs:comment 'Date when all required remediation actions were completed and accepted by the card scheme.' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationRequirement rdf:type rdf:Property ;
    rdfs:label 'Remediation Requirement' ;
    rdfs:comment 'Detailed description of corrective actions and remediation steps required by the card scheme to resolve the compliance violation and prevent recurrence.' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeCaseReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Scheme Case Reference Number' ;
    rdfs:comment 'External case reference number assigned by the card scheme (Visa, Mastercard) for tracking the compliance violation case.' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeContactEmail rdf:type rdf:Property ;
    rdfs:label 'Scheme Contact Email' ;
    rdfs:comment 'Email address of the card scheme representative managing the compliance case.' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeContactName rdf:type rdf:Property ;
    rdfs:label 'Scheme Contact Name' ;
    rdfs:comment 'Name of the card scheme representative or contact person managing the compliance case on behalf of the scheme.' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeThresholdBreached rdf:type rdf:Property ;
    rdfs:label 'Scheme Threshold Breached' ;
    rdfs:comment 'Description of the specific card scheme threshold or program requirement that was breached (e.g., Visa Fraud Monitoring Program threshold, Mastercard Excessive Chargeback Merchant threshold).' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationDescription rdf:type rdf:Property ;
    rdfs:label 'Violation Description' ;
    rdfs:comment 'Detailed narrative description of the specific scheme rule violation, including context and circumstances that led to the compliance case.' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Violation Period End Date' ;
    rdfs:comment 'End date of the period during which the scheme rule violations occurred.' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:violationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Violation Period Start Date' ;
    rdfs:comment 'Start date of the period during which the scheme rule violations occurred.' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:violationType rdf:type rdf:Property ;
    rdfs:label 'Violation Type' ;
    rdfs:comment 'Category of scheme rule violation that triggered the compliance case (e.g., excessive chargebacks, non-compliance with representment procedures, scheme program requirement failures).' ;
    rdfs:domain ind:DisputeComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidencePackageId rdf:type rdf:Property ;
    rdfs:label 'Evidence Package Id' ;
    rdfs:comment 'Unique surrogate identifier for the evidence package record in the dispute and chargeback management system. Primary key for this entity.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EvidencePackage .

ind:representmentId rdf:type rdf:Property ;
    rdfs:label 'Representment Id' ;
    rdfs:comment 'Reference to the representment filing associated with this evidence package. A representment is the merchant\'s formal rebuttal to a chargeback, supported by this evidence package.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Representment .

ind:assemblyTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assembly Timestamp' ;
    rdfs:comment 'Date and time when the evidence package was fully assembled and marked ready for submission. Represents the principal business event time for this entity — the moment the package became a complete evidentiary artifact.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disputedTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Disputed Transaction Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the disputed transaction amount (e.g., USD, EUR, GBP). Required for cross-border dispute processing and FX-related chargeback reason codes.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCount rdf:type rdf:Property ;
    rdfs:label 'Document Count' ;
    rdfs:comment 'Total number of individual evidence documents included in this package. Used for completeness validation and scheme submission compliance checks.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidenceTypesIncluded rdf:type rdf:Property ;
    rdfs:label 'Evidence Types Included' ;
    rdfs:comment 'Pipe-delimited list of evidence type codes included in this package (e.g., \'AUTH_RECORD|DELIVERY_CONF|3DS_PROOF\'). Provides a consolidated summary of all evidence categories present without requiring a join to the document-level detail table.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:has3dsAuthenticationProof rdf:type rdf:Property ;
    rdfs:label 'Has 3ds Authentication Proof' ;
    rdfs:comment 'Indicates whether the evidence package includes 3-D Secure (3DS) authentication proof (e.g., authentication value, ECI indicator, CAVV) demonstrating the transaction was authenticated under PSD2 Strong Customer Authentication (SCA) requirements.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasAuthorizationRecord rdf:type rdf:Property ;
    rdfs:label 'Has Authorization Record' ;
    rdfs:comment 'Indicates whether the evidence package includes an authorization record (approval code, authorization timestamp, and response code) as evidence that the transaction was properly authorized at the time of the original payment.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasAvsCvvMatch rdf:type rdf:Property ;
    rdfs:label 'Has Avs Cvv Match' ;
    rdfs:comment 'Indicates whether the evidence package includes the Address Verification System (AVS) and/or Card Verification Value (CVV) match result from the original authorization, demonstrating the cardholder\'s identity was verified at point of sale.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasCardholderCommunication rdf:type rdf:Property ;
    rdfs:label 'Has Cardholder Communication' ;
    rdfs:comment 'Indicates whether the evidence package includes documented communication with the cardholder (e.g., email correspondence, chat logs, signed agreements) relevant to the disputed transaction.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasDeliveryConfirmation rdf:type rdf:Property ;
    rdfs:label 'Has Delivery Confirmation' ;
    rdfs:comment 'Indicates whether the evidence package includes a delivery confirmation document (e.g., signed proof of delivery, carrier tracking confirmation) to rebut non-receipt chargebacks.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasShippingRecord rdf:type rdf:Property ;
    rdfs:label 'Has Shipping Record' ;
    rdfs:comment 'Indicates whether the evidence package includes a shipping record (e.g., carrier waybill, tracking number, shipment manifest) as evidence of goods dispatch for merchandise-related disputes.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasSignedReceipt rdf:type rdf:Property ;
    rdfs:label 'Has Signed Receipt' ;
    rdfs:comment 'Indicates whether the evidence package includes a signed transaction receipt (physical or electronic) bearing the cardholder\'s signature or PIN-verified acknowledgment at the point of sale.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAutoAssembled rdf:type rdf:Property ;
    rdfs:label 'Is Auto Assembled' ;
    rdfs:comment 'Indicates whether the evidence package was assembled automatically by the dispute management system\'s Straight-Through Processing (STP) engine, or manually by a dispute analyst. Supports STP rate reporting and automation analytics.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuerReference rdf:type rdf:Property ;
    rdfs:label 'Issuer Reference' ;
    rdfs:comment 'The issuing bank\'s case or reference number for the chargeback, as communicated in the chargeback notification. Used to correlate the evidence package with the issuer\'s dispute record.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeDate rdf:type rdf:Property ;
    rdfs:label 'Outcome Date' ;
    rdfs:comment 'The date on which the final resolution outcome was received from the card scheme, issuing bank, or arbitration body. Used for financial adjustment processing and dispute analytics.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcomeReason rdf:type rdf:Property ;
    rdfs:label 'Outcome Reason' ;
    rdfs:comment 'Textual explanation or scheme-provided reason code description for the dispute outcome decision. Captures why the evidence package was accepted or rejected to support root cause analysis and process improvement.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageNotes rdf:type rdf:Property ;
    rdfs:label 'Package Notes' ;
    rdfs:comment 'Free-text notes entered by the dispute analyst regarding the evidence package, including special circumstances, escalation context, or instructions for the reviewing party. Not transmitted to the card scheme.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageOutcome rdf:type rdf:Property ;
    rdfs:label 'Package Outcome' ;
    rdfs:comment 'Final resolution outcome of the evidence package submission: won (dispute resolved in merchant\'s favor), lost (chargeback upheld), partial_win (partial amount recovered), withdrawn (package retracted), or pending (awaiting decision).' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Package Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to the evidence package, used in scheme submissions and merchant communications. Follows the EVP- prefix convention.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle status of the evidence package: draft (being assembled), assembled (complete but not yet submitted), submitted (sent to card scheme or issuer), accepted (acknowledged by receiving party), rejected (refused by receiving party), or withdrawn (retracted before decision).' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Classification of the evidence package by the dispute stage it supports: representment (first chargeback rebuttal), pre_arbitration (pre-arb response), arbitration (scheme arbitration filing), retrieval_response (response to retrieval request), or good_faith (voluntary compliance submission). [ENUM-REF-CANDIDATE: representment|pre_arbitration|arbitration|retrieval_response|good_faith — promote to reference product]' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveredAmount rdf:type rdf:Property ;
    rdfs:label 'Recovered Amount' ;
    rdfs:comment 'The monetary amount recovered in the merchant\'s favor as a result of the evidence package submission. May be equal to the full disputed amount (full win), a partial amount (partial win), or zero (loss). Denominated in the disputed transaction currency.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Card scheme or issuer-provided code indicating why the evidence package was rejected (e.g., late submission, insufficient evidence, incorrect format). Populated only when package_status is \'rejected\'. Used for defect analysis and process improvement.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Date' ;
    rdfs:comment 'The card scheme-mandated deadline by which the evidence package must be submitted to avoid forfeiture of the dispute. Derived from chargeback receipt date plus scheme-specific response windows (e.g., Visa 30 days, Mastercard 45 days).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:schemeSubmissionConfirmation rdf:type rdf:Property ;
    rdfs:label 'Scheme Submission Confirmation' ;
    rdfs:comment 'Confirmation or acknowledgment number returned by the card scheme portal (e.g., Visa Resolve Online, Mastercard Connect) upon successful receipt of the evidence package submission. Used for reconciliation and proof of timely submission.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDeadlineMet rdf:type rdf:Property ;
    rdfs:label 'Sla Deadline Met' ;
    rdfs:comment 'Indicates whether the evidence package was submitted before the card scheme response deadline. False indicates a missed SLA, which results in automatic forfeiture of the dispute. Critical for operational performance monitoring.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submittedByUser rdf:type rdf:Property ;
    rdfs:label 'Submitted By User' ;
    rdfs:comment 'Username or employee identifier of the individual or automated process that submitted the evidence package to the card scheme or issuer. Supports audit trail requirements under SOX and PCI DSS.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Total File Size Bytes' ;
    rdfs:comment 'Aggregate file size in bytes of all documents included in the evidence package. Used to validate compliance with card scheme maximum submission size limits (e.g., Visa 5MB per package).' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeId rdf:type rdf:Property ;
    rdfs:label 'Fee Id' ;
    rdfs:comment 'Primary key for fee' ;
    rdfs:domain ind:Fee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:schemeFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Scheme Fee Schedule Id' ;
    rdfs:comment 'Reference to the fee schedule or pricing configuration that determined the assessed fee amount. Links to the applicable scheme fee table or internal pricing rule used to calculate this charge.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SchemeFeeSchedule .

ind:amountUsd rdf:type rdf:Property ;
    rdfs:label 'Amount Usd' ;
    rdfs:comment 'Fee amount converted to US Dollars (USD) using the FX rate applied at assessment date. Enables normalized cross-currency reporting and analytics across all dispute fee records.' ;
    rdfs:domain ind:Fee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessingEntityName rdf:type rdf:Property ;
    rdfs:label 'Assessing Entity Name' ;
    rdfs:comment 'Human-readable name of the specific entity that assessed the fee (e.g., \'Visa Inc.\', \'Mastercard International\', \'Chase Merchant Services\'). Complements assessed_by for reporting and reconciliation.' ;
    rdfs:domain ind:Fee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriod rdf:type rdf:Property ;
    rdfs:label 'Billing Period' ;
    rdfs:comment 'The billing cycle period (YYYY-MM format) to which this fee is attributed for invoicing and financial reporting. Aligns with monthly scheme billing cycles and ERP accounts payable periods.' ;
    rdfs:domain ind:Fee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'Internal cost center code to which this dispute fee expense is allocated. Supports departmental P&L reporting and internal cost attribution for dispute operations.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeFeeNotes rdf:type rdf:Property ;
    rdfs:label 'Dispute Fee Notes' ;
    rdfs:comment 'Free-text notes or comments entered by dispute operations staff regarding this fee record. May include waiver justification details, scheme correspondence references, or escalation context.' ;
    rdfs:domain ind:Fee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStage rdf:type rdf:Property ;
    rdfs:label 'Dispute Stage' ;
    rdfs:comment 'Stage of the dispute lifecycle at which this fee was assessed. Identifies whether the fee relates to a retrieval request, first chargeback, second chargeback, pre-arbitration, arbitration, or compliance filing.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Contractual or scheme-mandated deadline by which the fee must be paid. Drives overdue detection, collections escalation, and SLA compliance monitoring.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Status' ;
    rdfs:comment 'Current lifecycle status of the fee record. Tracks progression from initial assessment through invoicing, payment, waiver, or secondary dispute of the fee itself.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeType rdf:type rdf:Property ;
    rdfs:label 'Fee Type' ;
    rdfs:comment 'Classification of the fee assessed in connection with the dispute. Distinguishes scheme chargeback fees, arbitration filing fees, compliance assessment fines, retrieval request fees, pre-arbitration fees, and internal processing fees. [ENUM-REF-CANDIDATE: chargeback_fee|arbitration_fee|compliance_assessment|retrieval_request_fee|internal_processing_fee|pre_arbitration_fee|scheme_penalty|network_fine — promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxRateApplied rdf:type rdf:Property ;
    rdfs:label 'Fx Rate Applied' ;
    rdfs:comment 'The FX exchange rate used to convert the fee amount from the fee currency to USD at the time of assessment. Supports audit trail for currency conversion and DCC-related fee reconciliation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReference rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference' ;
    rdfs:comment 'Reference number of the invoice or billing statement on which this fee appears. Links the fee record to the ERP accounts payable or accounts receivable invoice for payment tracking and reconciliation.' ;
    rdfs:domain ind:Fee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Net Fee Amount' ;
    rdfs:comment 'Final collectible fee amount after applying any waivers or adjustments (fee_amount minus waiver_amount). Represents the actual amount due for billing and GL posting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Date on which the fee was settled or paid. Populated when payment_status transitions to \'paid\' or \'partially_paid\'. Used for cash flow reporting and aging analysis.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current payment collection status of the net fee amount. Tracks whether the fee has been paid, remains outstanding, is overdue, or has been written off. Distinct from fee_status which tracks the assessment lifecycle.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for this fee record as assigned by the assessing entity (card scheme, acquirer, or internal billing system). Used for reconciliation and invoice matching.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Scheme Reason Code' ;
    rdfs:comment 'Card scheme-specific reason code associated with the chargeback or dispute event that triggered this fee (e.g., Visa reason code 10.4, Mastercard reason code 4853). Aligns with ISO 8583 and scheme rule classifications.' ;
    rdfs:domain ind:Fee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverAmount rdf:type rdf:Property ;
    rdfs:label 'Waiver Amount' ;
    rdfs:comment 'Monetary amount waived from the original fee_amount. Supports partial waivers where only a portion of the assessed fee is forgiven. Zero if no waiver applied.' ;
    rdfs:domain ind:Fee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Flag' ;
    rdfs:comment 'Indicates whether this fee has been fully waived by the assessing entity. When True, the fee amount is not expected to be collected. Distinct from partial adjustments tracked in fee_waiver_amount.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Reason code explaining why the fee was waived. Applicable only when waiver_flag is True. Supports audit and compliance reporting for fee waiver decisions.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Financial Adjustment Id' ;
    rdfs:comment 'Primary key for financial_adjustment' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialAdjustment .

ind:originalTransactionId rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Id' ;
    rdfs:comment 'Reference to the original payment transaction record that is the subject of the dispute. Enables traceability from the financial adjustment back to the source authorization and capture event.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:reversalReferenceFinancialAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Reversal Reference Financial Adjustment Id' ;
    rdfs:comment 'Reference to the original financial adjustment record that this entry reverses. Populated only when reversal_flag is True, enabling full audit trail of reversal chains.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialAdjustment .

ind:adjustmentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the adjustment amount. Identifies the currency in which the financial adjustment is denominated.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Event Timestamp' ;
    rdfs:comment 'Precise date and time when the financial adjustment event was triggered in the Dispute and Chargeback Management System. Represents the real-world business event time, distinct from the GL posting date.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adjustmentNotes rdf:type rdf:Property ;
    rdfs:label 'Adjustment Notes' ;
    rdfs:comment 'Free-text operational notes or comments recorded by dispute analysts regarding the financial adjustment, such as manual override justifications, scheme correspondence references, or exception handling details.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this financial adjustment, used in reconciliation, GL posting, and scheme communications. Assigned by the Dispute and Chargeback Management System or card scheme.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle state of the financial adjustment record within the dispute processing workflow. Drives GL posting eligibility and settlement batch inclusion.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Classification of the financial adjustment event within the dispute lifecycle. Determines the direction of fund flow and the applicable card scheme rules. [ENUM-REF-CANDIDATE: chargeback_debit|representment_credit|arbitration_fee|compliance_assessment|final_settlement|pre_arbitration_debit|pre_compliance_fee|good_faith_collection — promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Posted Flag' ;
    rdfs:comment 'Indicates whether this financial adjustment was automatically posted to the GL via Straight-Through Processing (STP) (True) or required manual intervention before posting (False). Supports operational efficiency reporting and STP rate analytics.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether this financial adjustment represents a debit (funds withdrawn from the merchant or acquirer) or a credit (funds returned). Critical for GL double-entry accounting and settlement reconciliation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Outcome' ;
    rdfs:comment 'Final outcome of the dispute case associated with this financial adjustment. Determines whether the adjustment represents a permanent financial liability or will be reversed upon successful representment or arbitration.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialPeriod rdf:type rdf:Property ;
    rdfs:label 'Financial Period' ;
    rdfs:comment 'Accounting period (YYYY-MM) to which this financial adjustment is attributed for revenue recognition, period-end close, and regulatory financial reporting. Aligned with Oracle Financials GL calendar.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxConversionRate rdf:type rdf:Property ;
    rdfs:label 'Fx Conversion Rate' ;
    rdfs:comment 'Exchange rate applied when converting the adjustment amount from the transaction currency to the settlement currency. Applicable for cross-border disputes involving Dynamic Currency Conversion (DCC) or multi-currency settlement.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Gl Cost Center Code' ;
    rdfs:comment 'Oracle Financials cost center dimension code associated with this adjustment for internal financial reporting and P&L attribution within the dispute operations function.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeAmount rdf:type rdf:Property ;
    rdfs:label 'Interchange Amount' ;
    rdfs:comment 'Interchange Reimbursement Fee (IRF) component of the financial adjustment, representing the fee paid between the acquiring bank and issuing bank as part of the dispute resolution. Relevant for chargeback debits and representment credits.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuerCode rdf:type rdf:Property ;
    rdfs:label 'Issuer Code' ;
    rdfs:comment 'Reference to the issuing bank (cardholder\'s bank) that initiated the chargeback or dispute. Used for issuer-level financial reporting and scheme compliance tracking.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'Calendar date on which the financial adjustment was posted to the General Ledger (GL) and included in the settlement batch. Drives financial period recognition and regulatory reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'Net amount posted to the settlement batch after applying any scheme fees, interchange adjustments, or currency conversion. May differ from adjustment_amount when FX conversion or fee netting applies.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementBatchReference rdf:type rdf:Property ;
    rdfs:label 'Settlement Batch Reference' ;
    rdfs:comment 'Identifier of the settlement batch in which this financial adjustment was included for clearing and fund transfer. Links to the Transaction Processing Platform batch processing records.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the settlement amount. May differ from adjustment_currency_code when Dynamic Currency Conversion (DCC) or cross-border settlement applies.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifies the operational system of record that originated this financial adjustment record (e.g., Dispute and Chargeback Management System, ERP Oracle Financials, card scheme network feed, or manual entry). Supports data lineage and reconciliation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Dispute Lifecycle Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each immutable event record in the dispute lifecycle event log. Primary key for this append-only audit table. Role: EVENT_LOG.' ;
    rdfs:domain ind:DisputeLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acquirerMid rdf:type rdf:Property ;
    rdfs:label 'Acquirer Mid' ;
    rdfs:comment 'The Merchant Identification Number assigned by the acquiring bank to the merchant involved in this dispute event. Used for merchant-level dispute tracking, chargeback ratio monitoring, and acquirer reporting.' ;
    rdfs:domain ind:DisputeLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actorType rdf:type rdf:Property ;
    rdfs:label 'Actor Type' ;
    rdfs:comment 'Category of the party that triggered or performed this lifecycle event. Identifies whether the action was taken by the issuing bank, acquiring bank, card scheme, merchant, or an internal analyst. Critical for accountability and regulatory audit trails.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arbitrationOutcome rdf:type rdf:Property ;
    rdfs:label 'Arbitration Outcome' ;
    rdfs:comment 'The final decision rendered by the card scheme in arbitration proceedings. Populated only when event_type is arbitration_decided. Determines final financial liability allocation between issuer and acquirer.' ;
    rdfs:domain ind:DisputeLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackCycle rdf:type rdf:Property ;
    rdfs:label 'Chargeback Cycle' ;
    rdfs:comment 'Identifies the current cycle stage of the chargeback process at the time of this event. Distinguishes first chargeback from second chargeback (re-presentment response), pre-arbitration, and formal arbitration stages per card scheme rules.' ;
    rdfs:domain ind:DisputeLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventNotes rdf:type rdf:Property ;
    rdfs:label 'Event Notes' ;
    rdfs:comment 'Free-text narrative describing the context, rationale, or outcome of this lifecycle event. Captures analyst commentary, scheme decision rationale, or system-generated explanations. EVENT_PAYLOAD_OR_VALUE per EVENT_LOG role.' ;
    rdfs:domain ind:DisputeLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Sequence Number' ;
    rdfs:comment 'Monotonically increasing sequence number of this event within the parent dispute case, starting at 1 for the first event. Enables ordered reconstruction of the complete dispute lifecycle timeline and detection of out-of-order event ingestion.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Discriminator classifying the kind of lifecycle event that occurred in the dispute workflow. Drives downstream routing, SLA monitoring, and regulatory reporting. EVENT_TYPE_OR_CHANNEL per EVENT_LOG role. [ENUM-REF-CANDIDATE: case_opened|retrieval_sent|chargeback_filed|representment_submitted|pre_arbitration_filed|arbitration_decided|case_closed|deadline_breached — promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Adjustment Amount' ;
    rdfs:comment 'The monetary value of the financial adjustment (debit, credit, fee, or reversal) associated with this lifecycle event. Used for settlement reconciliation, GL posting, and dispute financial reporting. Expressed in dispute_currency_code.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialAdjustmentType rdf:type rdf:Property ;
    rdfs:label 'Financial Adjustment Type' ;
    rdfs:comment 'Classifies the type of financial adjustment triggered by this lifecycle event (e.g., debit to acquirer for chargeback, credit to issuer, reversal for representment win, scheme fee). Drives GL posting and settlement reconciliation in ERP - Oracle Financials.' ;
    rdfs:domain ind:DisputeLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeadlineBreached rdf:type rdf:Property ;
    rdfs:label 'Is Deadline Breached' ;
    rdfs:comment 'Indicates whether the response deadline for this lifecycle event stage was breached (True) or met on time (False). Drives automatic escalation workflows, scheme penalty assessments, and SLA reporting.' ;
    rdfs:domain ind:DisputeLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFraudRelated rdf:type rdf:Property ;
    rdfs:label 'Is Fraud Related' ;
    rdfs:comment 'Indicates whether this dispute event is classified as fraud-related (True) based on the chargeback reason code or fraud detection platform signals. Drives SAR/STR filing obligations, fraud analytics, and scheme fraud reporting thresholds.' ;
    rdfs:domain ind:DisputeLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newState rdf:type rdf:Property ;
    rdfs:label 'New State' ;
    rdfs:comment 'The dispute case state immediately after this event was applied. Represents the current state of the dispute case as of this event. Used for SLA tracking, workflow routing, and regulatory reporting. [ENUM-REF-CANDIDATE: new|retrieval_pending|chargeback_pending|representment_pending|pre_arbitration_pending|arbitration_pending|resolved|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panLastFour rdf:type rdf:Property ;
    rdfs:label 'Pan Last Four' ;
    rdfs:comment 'The last four digits of the cardholder\'s Primary Account Number (PAN) associated with the disputed transaction. Retained for dispute identification and cardholder communication while complying with PCI DSS data minimization requirements.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousState rdf:type rdf:Property ;
    rdfs:label 'Previous State' ;
    rdfs:comment 'The dispute case state immediately before this event was applied. Together with new_state, provides a complete state-transition record for audit and analytics. Enables reconstruction of the full dispute lifecycle history. [ENUM-REF-CANDIDATE: new|retrieval_pending|chargeback_pending|representment_pending|pre_arbitration_pending|arbitration_pending|resolved|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingRegion rdf:type rdf:Property ;
    rdfs:label 'Processing Region' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the region where this dispute event was processed. Determines applicable regulatory framework (e.g., PSD2 in EU, Regulation E in US), jurisdiction for compliance reporting, and cross-border dispute rules.' ;
    rdfs:domain ind:DisputeLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Timestamp' ;
    rdfs:comment 'The actual date and time at which the required response or evidence package was submitted for this event stage. Compared against response_deadline to determine SLA compliance and deadline breach status.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'The number of hours within which the required action for this event type must be completed per card scheme rules and internal SLA commitments. Used to compute response_deadline and monitor SLA compliance.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:threeDsAuthenticationResult rdf:type rdf:Property ;
    rdfs:label 'Three Ds Authentication Result' ;
    rdfs:comment 'The outcome of 3-D Secure (3DS) authentication for the original disputed transaction. Determines liability shift applicability under card scheme rules — authenticated transactions shift liability to the issuer, affecting dispute outcome and representment strategy.' ;
    rdfs:domain ind:DisputeLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantResponseId rdf:type rdf:Property ;
    rdfs:label 'Merchant Response Id' ;
    rdfs:comment 'Primary key for merchant_response' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system process that last modified this merchant response record. Supports audit trail and accountability requirements.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acquirerFeedbackNotes rdf:type rdf:Property ;
    rdfs:label 'Acquirer Feedback Notes' ;
    rdfs:comment 'Internal notes or feedback provided by the acquirer reviewer regarding the quality, completeness, or deficiencies of the merchant response.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquirerReviewCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acquirer Review Completed Timestamp' ;
    rdfs:comment 'Date and time when the acquirer completed their review of the merchant response and made a decision on whether to proceed with representment.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:acquirerReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Acquirer Review Status' ;
    rdfs:comment 'Status of the acquirers internal review of the merchant response. Indicates whether the response meets quality standards for formal representment to the issuer.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedResponseFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Response Flag' ;
    rdfs:comment 'Indicates whether this response was generated automatically by the merchants dispute management system or submitted manually by a merchant representative. True if automated.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cardholderName rdf:type rdf:Property ;
    rdfs:label 'Cardholder Name' ;
    rdfs:comment 'Name of the cardholder who initiated the dispute. Included for merchant reference and evidence matching purposes.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Notification Date' ;
    rdfs:comment 'Date when the merchant was first notified of the dispute or retrieval request. Used to calculate response deadline and track merchant response time.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evidenceDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Count' ;
    rdfs:comment 'Total number of supporting documents or evidence files submitted by the merchant as part of this response package.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidenceTypeList rdf:type rdf:Property ;
    rdfs:label 'Evidence Type List' ;
    rdfs:comment 'Comma-separated list of evidence types included in the response package (e.g., receipt, delivery_confirmation, customer_signature, terms_and_conditions, communication_log).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityAcceptanceAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Acceptance Amount' ;
    rdfs:comment 'Monetary amount that the merchant accepts liability for in cases of partial acceptance. Null if merchant contests the full dispute amount.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityAcceptanceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Liability Acceptance Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the liability acceptance amount. Typically matches the original transaction currency.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantContactEmail rdf:type rdf:Property ;
    rdfs:label 'Merchant Contact Email' ;
    rdfs:comment 'Email address of the merchant representative for follow-up communication regarding this response.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantContactName rdf:type rdf:Property ;
    rdfs:label 'Merchant Contact Name' ;
    rdfs:comment 'Name of the merchant representative or contact person who prepared and submitted this response.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantContactPhone rdf:type rdf:Property ;
    rdfs:label 'Merchant Contact Phone' ;
    rdfs:comment 'Phone number of the merchant representative for urgent communication regarding this response.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantRebuttalNarrative rdf:type rdf:Property ;
    rdfs:label 'Merchant Rebuttal Narrative' ;
    rdfs:comment 'Free-text explanation provided by the merchant describing their position, justification, and defense against the dispute claim. May include transaction details, customer interaction history, and policy references.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representmentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Representment Eligible Flag' ;
    rdfs:comment 'Indicates whether this merchant response qualifies for formal representment to the issuer based on acquirer review, evidence quality, and card scheme rules. True if eligible.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseChannel rdf:type rdf:Property ;
    rdfs:label 'Response Channel' ;
    rdfs:comment 'Channel or interface through which the merchant submitted their response to the acquirer (e.g., dispute management portal, API integration, email submission).' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Response Confidence Score' ;
    rdfs:comment 'Automated confidence score (0-100) indicating the predicted likelihood of winning the dispute based on evidence quality, reason code, and historical outcomes. Used for prioritization and strategy.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Response Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the language in which the merchant rebuttal narrative and evidence were submitted.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Response Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this merchant response for tracking and correspondence purposes.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTurnaroundDays rdf:type rdf:Property ;
    rdfs:label 'Response Turnaround Days' ;
    rdfs:comment 'Number of calendar days between dispute notification and merchant response submission. Used for performance tracking and SLA monitoring.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseType rdf:type rdf:Property ;
    rdfs:label 'Response Type' ;
    rdfs:comment 'Classification of the merchants position in response to the dispute notification. Indicates whether merchant accepts, contests, or partially accepts the chargeback claim.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Response Version Number' ;
    rdfs:comment 'Version number tracking revisions to the merchant response. Incremented each time the merchant updates their response before final submission.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether the merchant response was submitted after the deadline, resulting in automatic forfeiture of representment rights. True if deadline missed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:withdrawalRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Requested Flag' ;
    rdfs:comment 'Indicates whether the merchant has requested to withdraw this response and accept the chargeback liability. True if withdrawal requested.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeNotificationId rdf:type rdf:Property ;
    rdfs:label 'Dispute Notification Id' ;
    rdfs:comment 'Unique identifier for the dispute notification record. Primary key.' ;
    rdfs:domain ind:DisputeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:templateId rdf:type rdf:Property ;
    rdfs:label 'Template Id' ;
    rdfs:comment 'Reference to the message template used to generate this notification, enabling template performance tracking and version control.' ;
    rdfs:domain ind:DisputeNotification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NotificationTemplate .

ind:acknowledgmentMethod rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Method' ;
    rdfs:comment 'The method by which the recipient acknowledged the notification: email open tracking, link click, webhook callback, portal view, API response, or manual confirmation.' ;
    rdfs:domain ind:DisputeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:body rdf:type rdf:Property ;
    rdfs:label 'Body' ;
    rdfs:comment 'The full text content of the notification message, including event details, action items, deadlines, and instructions.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:comment 'The card scheme reason code for the dispute that triggered this notification (e.g., Visa reason code 10.4, Mastercard reason code 4853). Enables recipient to understand the dispute type.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRetryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Retry Timestamp' ;
    rdfs:comment 'The date and time of the most recent retry attempt. Null if no retries occurred. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:DisputeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Status' ;
    rdfs:comment 'Overall lifecycle status of the notification: draft (being prepared), scheduled (queued for send), sent (transmitted), delivered (confirmed receipt), acknowledged (recipient confirmed), failed (delivery unsuccessful), cancelled (notification voided before send). [ENUM-REF-CANDIDATE: draft|scheduled|sent|delivered|acknowledged|failed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientEmail rdf:type rdf:Property ;
    rdfs:label 'Recipient Email' ;
    rdfs:comment 'Primary email address where the notification was sent. Used for email channel notifications.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'The legal or business name of the notification recipient (merchant name, bank name, cardholder name, partner name).' ;
    rdfs:domain ind:DisputeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Recipient Reference Code' ;
    rdfs:comment 'The identifier of the recipient entity (MID for merchant, institution ID for acquirer/issuer, customer ID for cardholder, partner ID for partner). Format varies by recipient type.' ;
    rdfs:domain ind:DisputeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientType rdf:type rdf:Property ;
    rdfs:label 'Recipient Type' ;
    rdfs:comment 'Classification of the notification recipient: merchant (the business being notified), acquirer (acquiring bank), cardholder (end consumer), issuer (issuing bank), partner (third-party service provider), or internal (internal operations team).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'The number of times the system attempted to resend this notification after initial delivery failure. Zero indicates successful first-attempt delivery.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledSendTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Send Timestamp' ;
    rdfs:comment 'The date and time when the notification was originally scheduled to be sent. May differ from actual send_timestamp if delays occurred. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:DisputeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sendTimestamp rdf:type rdf:Property ;
    rdfs:label 'Send Timestamp' ;
    rdfs:comment 'The date and time when the notification was sent from the system to the recipient channel. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:DisputeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sftpFileName rdf:type rdf:Property ;
    rdfs:label 'Sftp File Name' ;
    rdfs:comment 'The name of the notification file deposited on the SFTP server. Populated only for sftp_file channel notifications.' ;
    rdfs:domain ind:DisputeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sftpFilePath rdf:type rdf:Property ;
    rdfs:label 'Sftp File Path' ;
    rdfs:comment 'The full file path on the SFTP server where the notification file was deposited. Populated only for sftp_file channel notifications.' ;
    rdfs:domain ind:DisputeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDeadlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Deadline Timestamp' ;
    rdfs:comment 'The contractual or regulatory deadline by which this notification must be delivered to meet Service Level Agreement (SLA) obligations. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Boolean indicator of whether the notification was delivered within the SLA deadline. True if delivered on time, False if SLA was breached.' ;
    rdfs:domain ind:DisputeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'The subject line or title of the notification message, summarizing the event and action required.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:webhookResponseBody rdf:type rdf:Property ;
    rdfs:label 'Webhook Response Body' ;
    rdfs:comment 'The response payload returned by the recipient webhook endpoint, used for troubleshooting and confirmation tracking. Null for non-webhook channels.' ;
    rdfs:domain ind:DisputeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:webhookResponseCode rdf:type rdf:Property ;
    rdfs:label 'Webhook Response Code' ;
    rdfs:comment 'The HTTP response status code returned by the recipient webhook endpoint (e.g., 200 for success, 4xx for client error, 5xx for server error). Null for non-webhook channels.' ;
    rdfs:domain ind:DisputeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:webhookUrl rdf:type rdf:Property ;
    rdfs:label 'Webhook Url' ;
    rdfs:comment 'The HTTPS endpoint URL where the API webhook notification was posted. Populated only for api_webhook channel notifications.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preArbitrationId rdf:type rdf:Property ;
    rdfs:label 'Pre Arbitration Id' ;
    rdfs:comment 'Unique identifier for the pre-arbitration case record. Primary key for the pre-arbitration entity.' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acquirerBankCode rdf:type rdf:Property ;
    rdfs:label 'Acquirer Bank Code' ;
    rdfs:comment 'Bank Identification Number (BIN) of the merchant\'s acquiring bank that processed the original transaction.' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNotes rdf:type rdf:Property ;
    rdfs:label 'Case Notes' ;
    rdfs:comment 'Internal notes and commentary regarding the pre-arbitration case, including strategy considerations, evidence assessment, and communication history.' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Deadline Compliance Status' ;
    rdfs:comment 'Indicates whether the responding party met the scheme-mandated response deadline: compliant (on time), late (submitted after deadline but accepted), or missed (no response submitted).' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceSubmissionCount rdf:type rdf:Property ;
    rdfs:label 'Evidence Submission Count' ;
    rdfs:comment 'Number of evidence documents or packages submitted by the filing party to support their pre-arbitration claim.' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Fee charged by the card scheme for filing a pre-arbitration case. This fee is typically assessed to the losing party upon case resolution.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this pre-arbitration record was last updated, tracking any changes to status, outcome, or case details.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preArbitrationStatus rdf:type rdf:Property ;
    rdfs:label 'Pre Arbitration Status' ;
    rdfs:comment 'Current lifecycle status of the pre-arbitration case: filed (submitted to scheme), pending_response (awaiting counterparty response), under_review (scheme reviewing submissions), accepted (pre-arb claim accepted), rejected (pre-arb claim denied), escalated_to_arbitration (proceeding to formal arbitration), withdrawn (filing party withdrew), or expired (deadline passed without resolution). [ENUM-REF-CANDIDATE: filed|pending_response|under_review|accepted|rejected|escalated_to_arbitration|withdrawn|expired — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date when the pre-arbitration case reached final resolution (accepted, rejected, or escalated to arbitration). Null if case is still pending.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDate rdf:type rdf:Property ;
    rdfs:label 'Response Date' ;
    rdfs:comment 'Actual date when the responding party submitted their response to the pre-arbitration case. Null if no response has been received.' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Response Received Flag' ;
    rdfs:comment 'Boolean indicator of whether a response has been received from the responding party. True if response submitted, False if pending or no response.' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:schemeDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Scheme Decision Date' ;
    rdfs:comment 'Date when the card scheme issued their official decision on the pre-arbitration case, determining liability assignment.' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'Date when the filing party voluntarily withdrew the pre-arbitration case. Null if case was not withdrawn.' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratioMonitorId rdf:type rdf:Property ;
    rdfs:label 'Ratio Monitor Id' ;
    rdfs:comment 'Primary key for ratio_monitor' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acquirerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Acquirer Notification Date' ;
    rdfs:comment 'The date the acquiring bank notified the merchant of the chargeback ratio threshold breach and required remediation actions.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Assessment Fee Amount' ;
    rdfs:comment 'The monetary penalty or assessment fee imposed by the card scheme for the chargeback ratio threshold breach during this monitoring period. Fees escalate with severity and duration of non-compliance.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Assessment Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the assessment fee amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackRatioPercentage rdf:type rdf:Property ;
    rdfs:label 'Chargeback Ratio Percentage' ;
    rdfs:comment 'The calculated chargeback ratio expressed as a percentage: (total_chargeback_count / total_transaction_count) * 100. Core metric for determining scheme program threshold breaches.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consecutiveMonthsInProgram rdf:type rdf:Property ;
    rdfs:label 'Consecutive Months In Program' ;
    rdfs:comment 'The number of consecutive months the merchant has been enrolled in the chargeback monitoring program as of this monitoring period. Used to track escalation and potential termination risk.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:excessiveThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Excessive Threshold Percentage' ;
    rdfs:comment 'The excessive chargeback ratio threshold percentage defined by the card scheme program for this monitoring period. Typically 1.8% for Visa VDMP excessive threshold.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudChargebackCount rdf:type rdf:Property ;
    rdfs:label 'Fraud Chargeback Count' ;
    rdfs:comment 'The subset of total chargebacks that were classified as fraud-related (reason codes 10.4, 4837, etc.) during the monitoring period. Used for Visa Fraud Monitoring Program (VFM) tracking.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fraudRatioPercentage rdf:type rdf:Property ;
    rdfs:label 'Fraud Ratio Percentage' ;
    rdfs:comment 'The calculated fraud chargeback ratio expressed as a percentage: (fraud_chargeback_count / total_transaction_count) * 100. Used for Visa Fraud Monitoring Program (VFM) compliance.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:highRiskIndicator rdf:type rdf:Property ;
    rdfs:label 'High Risk Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the merchant is classified as high-risk by the acquirer or card scheme, which may result in stricter chargeback ratio thresholds or enhanced monitoring.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mcc rdf:type rdf:Property ;
    rdfs:label 'Mcc' ;
    rdfs:comment 'Four-digit code classifying the merchants business type. Certain MCCs have different chargeback ratio thresholds or heightened monitoring requirements.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumChargebackThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Chargeback Threshold' ;
    rdfs:comment 'The minimum number of chargebacks required during the monitoring period for the merchant to be subject to the chargeback monitoring program. Typically 100 chargebacks for Visa VDMP standard threshold.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumTransactionThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Transaction Threshold' ;
    rdfs:comment 'The minimum number of transactions required during the monitoring period for the merchant to be subject to the chargeback monitoring program. Typically 1,000 transactions for Visa VDMP.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monitoringPeriodMonth rdf:type rdf:Property ;
    rdfs:label 'Monitoring Period Month' ;
    rdfs:comment 'The calendar month for which this chargeback ratio is calculated and monitored. Typically the first day of the month (YYYY-MM-01 format).' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringProgramType rdf:type rdf:Property ;
    rdfs:label 'Monitoring Program Type' ;
    rdfs:comment 'The specific card scheme chargeback monitoring program under which this merchant is being tracked. Examples: VDMP (Visa Dispute Monitoring Program), VFM (Visa Fraud Monitoring), MCP (Mastercard Chargeback Program), ECMP (Excessive Chargeback Merchant Program).' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Monitoring Record Status' ;
    rdfs:comment 'Current lifecycle status of this monitoring record. Active indicates ongoing monitoring; Closed indicates the monitoring period has concluded; Under Review indicates pending scheme or acquirer review.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Program Enrollment Date' ;
    rdfs:comment 'The date the merchant was enrolled into the card scheme chargeback monitoring program due to threshold breach. Null if merchant is not currently enrolled.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programExitDate rdf:type rdf:Property ;
    rdfs:label 'Program Exit Date' ;
    rdfs:comment 'The date the merchant successfully exited the card scheme chargeback monitoring program by achieving compliance. Null if merchant is still enrolled or was never enrolled.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country or region code where the merchant operates. Card scheme monitoring programs may have regional variations in thresholds and rules.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationPlanReference rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan Reference' ;
    rdfs:comment 'Reference identifier or document number for the merchants chargeback remediation plan submitted to address the threshold breach. Required for merchants enrolled in monitoring programs.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'The end date of the rolling review period used to calculate the chargeback ratio.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'The start date of the rolling review period used to calculate the chargeback ratio. Card schemes typically use a rolling 12-month or 6-month window.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:schemeNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Scheme Notification Date' ;
    rdfs:comment 'The date the card scheme officially notified the acquirer and merchant of the chargeback ratio threshold breach and program enrollment.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standardThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Standard Threshold Percentage' ;
    rdfs:comment 'The standard chargeback ratio threshold percentage defined by the card scheme program for this monitoring period. Typically 0.9% for Visa VDMP standard threshold.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdLevelBreached rdf:type rdf:Property ;
    rdfs:label 'Threshold Level Breached' ;
    rdfs:comment 'The severity level of the chargeback ratio threshold breach, if any. Indicates which tier of the card scheme monitoring program the merchant has entered. None indicates compliance; other values indicate escalating severity.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalChargebackCount rdf:type rdf:Property ;
    rdfs:label 'Total Chargeback Count' ;
    rdfs:comment 'The total number of chargebacks received against the merchant during the monitoring period month. Numerator for chargeback ratio calculation.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Total Transaction Count' ;
    rdfs:comment 'The total number of transactions processed by the merchant during the monitoring period month. Denominator for chargeback ratio calculation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedAnalyst rdf:type rdf:Property ;
    rdfs:label 'Assigned Analyst' ;
    rdfs:comment 'Name or identifier of the dispute analyst or team responsible for preparing and managing this representment case. Supports workload management and accountability tracking within the Dispute and Chargeback Management System.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackAmount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Amount' ;
    rdfs:comment 'The original chargeback amount as filed by the issuing bank. Retained on the representment record for direct comparison against the representment amount to identify partial representments.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysToDeadline rdf:type rdf:Property ;
    rdfs:label 'Days To Deadline' ;
    rdfs:comment 'Number of calendar days between the representment creation date and the scheme-mandated response deadline. Positive values indicate days remaining; negative values indicate overdue status. Supports operational prioritization and SLA alerting.' ;
    rdfs:domain ind:Representment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deadlineCompliant rdf:type rdf:Property ;
    rdfs:label 'Deadline Compliant' ;
    rdfs:comment 'Indicates whether the representment was submitted on or before the scheme-mandated response deadline. True if submission_date is on or before response_deadline; False if submitted late. Late submissions are typically rejected by card schemes.' ;
    rdfs:domain ind:Representment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidencePackageReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Package Reference' ;
    rdfs:comment 'Reference identifier for the evidence package submitted with the representment (e.g., document store ID, S3 path, or case management reference). Links to the collection of supporting documents such as transaction receipts, delivery confirmations, and cardholder communications.' ;
    rdfs:domain ind:Representment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeDecision rdf:type rdf:Property ;
    rdfs:label 'Outcome Decision' ;
    rdfs:comment 'The final or current decision rendered by the card scheme or issuing bank on the representment. Accepted means the chargeback is reversed in the merchant\'s favor; rejected means the chargeback stands; pre_arbitration and arbitration indicate escalation paths.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preArbitrationDeadline rdf:type rdf:Property ;
    rdfs:label 'Pre Arbitration Deadline' ;
    rdfs:comment 'The scheme-mandated deadline by which the acquirer must file for pre-arbitration if the representment is rejected and escalation is desired. Null if pre-arbitration is not applicable or not yet triggered.' ;
    rdfs:domain ind:Representment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preArbitrationEligible rdf:type rdf:Property ;
    rdfs:label 'Pre Arbitration Eligible' ;
    rdfs:comment 'Indicates whether this representment is eligible for escalation to the pre-arbitration stage if the outcome decision is rejected. Eligibility is determined by card scheme rules based on reason code, dispute amount, and prior cycle history.' ;
    rdfs:domain ind:Representment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preArbitrationFiled rdf:type rdf:Property ;
    rdfs:label 'Pre Arbitration Filed' ;
    rdfs:comment 'Indicates whether a pre-arbitration case has been formally filed following rejection of this representment. True if pre-arbitration has been initiated; False otherwise.' ;
    rdfs:domain ind:Representment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rebuttalNarrative rdf:type rdf:Property ;
    rdfs:label 'Rebuttal Narrative' ;
    rdfs:comment 'Free-text narrative written by the merchant or acquirer explaining the basis for the representment rebuttal. Describes why the chargeback is invalid, referencing supporting evidence. Key input for scheme adjudication.' ;
    rdfs:domain ind:Representment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Amount' ;
    rdfs:comment 'The actual monetary amount recovered by the merchant/acquirer following a successful representment outcome. May differ from representment_amount in cases of partial acceptance by the issuer.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Externally-known business identifier for the representment package, typically assigned by the acquiring bank or payment scheme upon submission. Used for cross-system tracking and scheme correspondence.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representmentType rdf:type rdf:Property ;
    rdfs:label 'Representment Type' ;
    rdfs:comment 'Classifies the representment by its position in the dispute cycle. First chargeback representment is the initial rebuttal; second chargeback representment follows a re-presentment rejection; pre-arbitration and arbitration are escalation stages.' ;
    rdfs:domain ind:Representment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'The calendar date on which the representment package was actually submitted. Used in conjunction with response_deadline to calculate deadline compliance status.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retrievalRequestId rdf:type rdf:Property ;
    rdfs:label 'Retrieval Request Id' ;
    rdfs:comment 'Unique surrogate identifier for the retrieval request record in the Dispute and Chargeback Management System. Primary key for this entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acquirerCode rdf:type rdf:Property ;
    rdfs:label 'Acquirer Code' ;
    rdfs:comment 'Identifier of the acquiring bank responsible for fulfilling the retrieval request by providing the requested transaction documentation to the issuing bank.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Authorization approval code issued by the issuing bank for the original transaction. Included in the retrieval request to help locate the original transaction record and validate the authorization record as part of the evidence package.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAmount rdf:type rdf:Property ;
    rdfs:label 'Billing Amount' ;
    rdfs:comment 'Amount billed to the cardholder in their billing currency, which may differ from the transaction amount when Dynamic Currency Conversion (DCC) or foreign exchange conversion was applied. Used in cross-border dispute resolution.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCurrency rdf:type rdf:Property ;
    rdfs:label 'Billing Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the cardholder\'s billing currency. Relevant when DCC was applied and the billing currency differs from the transaction currency.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderDisputeCategory rdf:type rdf:Property ;
    rdfs:label 'Cardholder Dispute Category' ;
    rdfs:comment 'High-level category of the cardholder\'s dispute underlying the retrieval request. Aligns with card scheme dispute category frameworks (Visa Dispute Resolution; Mastercard Dispute Resolution Management). Used for dispute analytics and trend reporting.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysToFulfill rdf:type rdf:Property ;
    rdfs:label 'Days To Fulfill' ;
    rdfs:comment 'Number of calendar days elapsed between the request_date and the fulfillment_date. Populated upon fulfillment. Used for SLA performance analytics and scheme compliance benchmarking.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Document Delivery Method' ;
    rdfs:comment 'Method used to deliver the requested transaction documentation (sales draft, receipt, authorization record) to the issuing bank. Electronic delivery via scheme portal is the preferred method per PCI DSS and scheme rules.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTypesRequested rdf:type rdf:Property ;
    rdfs:label 'Document Types Requested' ;
    rdfs:comment 'Comma-separated list or description of the specific document types requested by the issuing bank (e.g., sales draft, transaction receipt, authorization record, imprinted voucher, signed cardholder receipt). Drives the fulfillment workflow and evidence package assembly.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedToChargeback rdf:type rdf:Property ;
    rdfs:label 'Escalated To Chargeback' ;
    rdfs:comment 'Boolean flag indicating whether this retrieval request was escalated to a formal chargeback due to non-fulfillment within the scheme-mandated deadline. True indicates a chargeback has been filed; False indicates the request was resolved without chargeback escalation.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date on which the retrieval request was escalated to a formal chargeback. Populated only when escalated_to_chargeback is True. Used for SLA tracking and scheme compliance reporting.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fraudSuspected rdf:type rdf:Property ;
    rdfs:label 'Fraud Suspected' ;
    rdfs:comment 'Boolean flag indicating whether the retrieval request is associated with a suspected fraudulent transaction, as flagged by the issuing bank or the fraud detection platform. When True, the case may be escalated to the Fraud Detection and Prevention Platform for additional investigation.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Date' ;
    rdfs:comment 'Actual date on which the acquiring bank fulfilled the retrieval request by delivering the requested documentation to the issuing bank. Null if not yet fulfilled. Used to calculate response time and SLA compliance.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentDeadline rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Deadline' ;
    rdfs:comment 'Scheme-mandated deadline by which the acquiring bank must fulfill the retrieval request by delivering the requested documentation. Failure to meet this deadline typically results in automatic escalation to a chargeback. Calculated from request_date per applicable card scheme rules (Visa: typically 30 days; Mastercard: varies by reason code).' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:merchantCountry rdf:type rdf:Property ;
    rdfs:label 'Merchant Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the merchant\'s country of operation where the original transaction occurred. Used for cross-border dispute routing and applicable scheme rule determination.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantName rdf:type rdf:Property ;
    rdfs:label 'Merchant Name' ;
    rdfs:comment 'Doing-business-as name of the merchant as it appears on the cardholder\'s statement for the original transaction. Used to identify the merchant in the retrieval request workflow and for cardholder communication.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posEntryMode rdf:type rdf:Property ;
    rdfs:label 'Pos Entry Mode' ;
    rdfs:comment 'Method by which the cardholder\'s payment credentials were captured at the point of sale for the original transaction (e.g., EMV chip, magnetic stripe swipe, NFC contactless, manual key entry, e-commerce). Relevant to determining liability and document requirements in the retrieval request.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseNotes rdf:type rdf:Property ;
    rdfs:label 'Response Notes' ;
    rdfs:comment 'Free-text notes entered by the acquiring bank or merchant operations team describing the fulfillment response, any issues encountered in locating documentation, or reasons for non-fulfillment. Supports case management and audit trail.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tid rdf:type rdf:Property ;
    rdfs:label 'Tid' ;
    rdfs:comment 'Terminal Identification Number identifying the specific POS or mPOS terminal at which the original transaction was processed. Supports evidence collection and sales draft retrieval from the correct terminal.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleConfigId rdf:type rdf:Property ;
    rdfs:label 'Rule Config Id' ;
    rdfs:comment 'Primary key for rule_config' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionParameters rdf:type rdf:Property ;
    rdfs:label 'Action Parameters' ;
    rdfs:comment 'Configuration parameters or metadata required to execute the auto action, stored as JSON or key-value pairs.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Approval workflow status indicating whether the rule configuration has been reviewed and authorized for production use.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Identifier or name of the user or role who approved this rule configuration for production deployment.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when this rule configuration was approved, recorded in ISO 8601 format.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:autoActionType rdf:type rdf:Property ;
    rdfs:label 'Auto Action Type' ;
    rdfs:comment 'Automated action to be taken when the rule conditions are met during dispute processing.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text field capturing compliance considerations, regulatory alignment, or audit notes related to this rule configuration.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionExpression rdf:type rdf:Property ;
    rdfs:label 'Condition Expression' ;
    rdfs:comment 'Structured or semi-structured expression defining the logical conditions under which this rule is triggered. May be JSON, XML, or domain-specific language.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeAgeThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Dispute Age Threshold Days' ;
    rdfs:comment 'Maximum age of the dispute in days for this rule to apply, enabling time-sensitive rule logic.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidenceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Evidence Required Flag' ;
    rdfs:comment 'Indicates whether supporting evidence must be present for the rule action to be executed.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executionCount rdf:type rdf:Property ;
    rdfs:label 'Execution Count' ;
    rdfs:comment 'Cumulative count of how many times this rule has been executed since activation, used for monitoring and analytics.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failureCount rdf:type rdf:Property ;
    rdfs:label 'Failure Count' ;
    rdfs:comment 'Cumulative count of failed rule executions where the rule action could not be completed due to errors or exceptions.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastExecutedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Executed Timestamp' ;
    rdfs:comment 'Date and time when this rule was last executed in a dispute processing workflow, recorded in ISO 8601 format.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxDisputeCount rdf:type rdf:Property ;
    rdfs:label 'Max Dispute Count' ;
    rdfs:comment 'Maximum number of disputes this rule can process within a defined time window, used for rate limiting or risk control.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:merchantSegment rdf:type rdf:Property ;
    rdfs:label 'Merchant Segment' ;
    rdfs:comment 'Merchant classification or segment to which this rule applies, enabling segment-specific dispute handling strategies. May reference MCC (Merchant Category Code) ranges or internal merchant tiers.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Identifier or name of the user or system process that last modified this rule configuration record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRecipientList rdf:type rdf:Property ;
    rdfs:label 'Notification Recipient List' ;
    rdfs:comment 'Comma-separated list of email addresses or user identifiers to be notified when this rule is triggered.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Required Flag' ;
    rdfs:comment 'Indicates whether a notification must be sent to stakeholders when this rule is triggered.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric priority ranking for rule evaluation order when multiple rules may apply to the same dispute. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Unique business identifier code for the dispute rule configuration, used for external reference and system integration.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name of the dispute rule configuration describing its purpose and scope.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleOwner rdf:type rdf:Property ;
    rdfs:label 'Rule Owner' ;
    rdfs:comment 'Business owner or team responsible for maintaining and governing this dispute rule configuration.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the dispute rule configuration indicating whether it is actively applied in dispute processing.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classification of the dispute rule configuration indicating the type of automated action or decision logic it governs.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successCount rdf:type rdf:Property ;
    rdfs:label 'Success Count' ;
    rdfs:comment 'Cumulative count of successful rule executions where the rule conditions were met and the action was successfully applied.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeWindowHours rdf:type rdf:Property ;
    rdfs:label 'Time Window Hours' ;
    rdfs:comment 'Time window in hours for evaluating max dispute count or other time-bound rule conditions.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionAgeThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Transaction Age Threshold Days' ;
    rdfs:comment 'Maximum age of the original transaction in days for this rule to apply, used for representment eligibility assessment.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:winRateThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Win Rate Threshold Pct' ;
    rdfs:comment 'Minimum historical win rate percentage for similar disputes required for auto-representment eligibility under this rule.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auth3dsResultId rdf:type rdf:Property ;
    rdfs:label 'Auth 3ds Result Id' ;
    rdfs:comment 'Unique surrogate key for each 3-D Secure authentication outcome record.' ;
    rdfs:domain ind:Auth3dsResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAuthTransactionId rdf:type rdf:Property ;
    rdfs:label 'Primary Auth Transaction Id' ;
    rdfs:comment 'Identifier of the payment transaction to which this 3DS result belongs.' ;
    rdfs:domain ind:Auth3dsResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:tertiaryAuthAcsTransactionId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Auth Acs Transaction Id' ;
    rdfs:comment 'Identifier assigned by the Access Control Server (ACS) for this authentication flow.' ;
    rdfs:domain ind:Auth3dsResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:authenticationAttempts rdf:type rdf:Property ;
    rdfs:label 'Authentication Attempts' ;
    rdfs:comment 'Count of how many authentication attempts were made for this transaction.' ;
    rdfs:domain ind:Auth3dsResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authenticationErrorCode rdf:type rdf:Property ;
    rdfs:label 'Authentication Error Code' ;
    rdfs:comment 'Standardized error code returned when authentication fails.' ;
    rdfs:domain ind:Auth3dsResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Authentication Error Message' ;
    rdfs:comment 'Human-readable error message describing the authentication failure.' ;
    rdfs:domain ind:Auth3dsResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationStatus rdf:type rdf:Property ;
    rdfs:label 'Authentication Status' ;
    rdfs:comment 'Outcome of the 3-D Secure authentication attempt.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authentication Timestamp' ;
    rdfs:comment 'Exact timestamp when the 3-D Secure authentication event occurred.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cardholderIpAddress rdf:type rdf:Property ;
    rdfs:label 'Cardholder Ip Address' ;
    rdfs:comment 'IP address of the cardholder at the time of authentication.' ;
    rdfs:domain ind:Auth3dsResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeIndicator rdf:type rdf:Property ;
    rdfs:label 'Challenge Indicator' ;
    rdfs:comment 'Indicates whether a challenge was required, requested, or not needed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Processing Latency Ms' ;
    rdfs:comment 'Time elapsed between authentication request and final response, measured in milliseconds.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskDecision rdf:type rdf:Property ;
    rdfs:label 'Risk Decision' ;
    rdfs:comment 'Final decision based on fraud score and business rules.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaExemptionType rdf:type rdf:Property ;
    rdfs:label 'Sca Exemption Type' ;
    rdfs:comment 'Type of SCA exemption applied to the transaction, if any.' ;
    rdfs:domain ind:Auth3dsResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blocklistAuditId rdf:type rdf:Property ;
    rdfs:label 'Blocklist Audit Id' ;
    rdfs:comment 'Unique surrogate key for each audit log entry of a blocklist record.' ;
    rdfs:domain ind:BlocklistAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blocklistEntryId rdf:type rdf:Property ;
    rdfs:label 'Blocklist Entry Id' ;
    rdfs:comment 'Identifier of the blocklist entry whose lifecycle event is being recorded.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BlocklistEntry .

ind:relatedCaseFraudCaseId rdf:type rdf:Property ;
    rdfs:label 'Related Case Fraud Case Id' ;
    rdfs:comment 'Identifier of the fraud case linked to this blocklist event, if any.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudCase .

ind:relatedFraudCaseId rdf:type rdf:Property ;
    rdfs:label 'Related Fraud Case Id' ;
    rdfs:comment 'Identifier of the fraud case linked to this blocklist event, if any.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudCase .

ind:blocklistType rdf:type rdf:Property ;
    rdfs:label 'Blocklist Type' ;
    rdfs:comment 'Category of the value being blocked (e.g., IP address, PAN, device identifier, token, email, phone).' ;
    rdfs:domain ind:BlocklistAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blocklistValue rdf:type rdf:Property ;
    rdfs:label 'Blocklist Value' ;
    rdfs:comment 'The actual value placed on the blocklist (e.g., PAN, IP address, token).' ;
    rdfs:domain ind:BlocklistAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:comment rdf:type rdf:Property ;
    rdfs:label 'Comment' ;
    rdfs:comment 'Free-form notes or comments added by the performer.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirement rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement' ;
    rdfs:comment 'Regulatory or standards driver for the blocklist action.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'System error code returned if the blocklist action failed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Human-readable error description for a failed blocklist operation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:justification rdf:type rdf:Property ;
    rdfs:label 'Justification' ;
    rdfs:comment 'Narrative explanation for why the blocklist action was taken, required for regulatory audit.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'Status of the blocklist entry after the event.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performedBy rdf:type rdf:Property ;
    rdfs:label 'Performed By' ;
    rdfs:comment 'Name or identifier of the analyst, system, or automated process that executed the action.' ;
    rdfs:domain ind:BlocklistAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performedByRole rdf:type rdf:Property ;
    rdfs:label 'Performed By Role' ;
    rdfs:comment 'Role of the actor that performed the blocklist action.' ;
    rdfs:domain ind:BlocklistAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'Status of the blocklist entry before the event.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockReasonCode rdf:type rdf:Property ;
    rdfs:label 'Block Reason Code' ;
    rdfs:comment 'Standardized code indicating why the entity was placed on the blocklist.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingScope rdf:type rdf:Property ;
    rdfs:label 'Blocking Scope' ;
    rdfs:comment 'Scope of the block action (e.g., decline transaction, flag for review, step-up authentication, monitor only).' ;
    rdfs:domain ind:BlocklistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blocklistEntryStatus rdf:type rdf:Property ;
    rdfs:label 'Blocklist Entry Status' ;
    rdfs:comment 'Current lifecycle status of the blocklist record.' ;
    rdfs:domain ind:BlocklistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blocklistVersion rdf:type rdf:Property ;
    rdfs:label 'Blocklist Version' ;
    rdfs:comment 'Version number for the blocklist record to support change tracking.' ;
    rdfs:domain ind:BlocklistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Entity Identifier' ;
    rdfs:comment 'Tokenized or hashed value that uniquely identifies the blocked entity within the system.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGlobal rdf:type rdf:Property ;
    rdfs:label 'Is Global' ;
    rdfs:comment 'True if the block applies across all jurisdictions; false if limited to a specific jurisdiction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceOfAddition rdf:type rdf:Property ;
    rdfs:label 'Source Of Addition' ;
    rdfs:comment 'Origin of the blocklist entry (e.g., manual entry, automated fraud rule, network advisory).' ;
    rdfs:domain ind:BlocklistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compromisedCredentialId rdf:type rdf:Property ;
    rdfs:label 'Compromised Credential Id' ;
    rdfs:comment 'System-generated unique identifier for the compromised credential record.' ;
    rdfs:domain ind:CompromisedCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'Applicable regulatory or compliance obligations (e.g., PCI DSS, GDPR) triggered by the compromise.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compromiseDate rdf:type rdf:Property ;
    rdfs:label 'Compromise Date' ;
    rdfs:comment 'Calendar date on which the credential was determined to be compromised.' ;
    rdfs:domain ind:CompromisedCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compromiseSource rdf:type rdf:Property ;
    rdfs:label 'Compromise Source' ;
    rdfs:comment 'Origin of the compromise information indicating how the credential breach was discovered.' ;
    rdfs:domain ind:CompromisedCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compromisedCredentialStatus rdf:type rdf:Property ;
    rdfs:label 'Compromised Credential Status' ;
    rdfs:comment 'Overall lifecycle status of the compromised credential record.' ;
    rdfs:domain ind:CompromisedCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialIdentifierHash rdf:type rdf:Property ;
    rdfs:label 'Credential Identifier Hash' ;
    rdfs:comment 'Hashed representation of the compromised credential value to protect sensitive data while enabling lookup.' ;
    rdfs:domain ind:CompromisedCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Methodology used to detect the compromise (real-time scoring, batch analysis, or manual review).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Exact timestamp when the compromise was detected by the system.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:issuerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Issuer Notified Flag' ;
    rdfs:comment 'Indicates whether the issuing institution has been notified of the compromise.' ;
    rdfs:domain ind:CompromisedCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completion Date' ;
    rdfs:comment 'Date on which remediation was successfully completed.' ;
    rdfs:domain ind:CompromisedCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Remediation Timestamp' ;
    rdfs:comment 'Timestamp of the most recent remediation activity.' ;
    rdfs:domain ind:CompromisedCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:riskScoreAtCompromise rdf:type rdf:Property ;
    rdfs:label 'Risk Score At Compromise' ;
    rdfs:comment 'Fraud risk score assigned to the credential at the time of compromise detection.' ;
    rdfs:domain ind:CompromisedCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appVersion rdf:type rdf:Property ;
    rdfs:label 'App Version' ;
    rdfs:comment 'Version of the mobile or desktop application used.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blocklistFlag rdf:type rdf:Property ;
    rdfs:label 'Blocklist Flag' ;
    rdfs:comment 'Indicates whether the device is present on an internal or external blocklist.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blocklistSource rdf:type rdf:Property ;
    rdfs:label 'Blocklist Source' ;
    rdfs:comment 'Identifier of the source list that flagged the device (e.g., internal, external vendor).' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browserName rdf:type rdf:Property ;
    rdfs:label 'Browser Name' ;
    rdfs:comment 'Name of the web browser or embedded web view.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browserVersion rdf:type rdf:Property ;
    rdfs:label 'Browser Version' ;
    rdfs:comment 'Version of the browser.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceFingerprintStatus rdf:type rdf:Property ;
    rdfs:label 'Device Fingerprint Status' ;
    rdfs:comment 'Current lifecycle status of the device fingerprint record.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceLabel rdf:type rdf:Property ;
    rdfs:label 'Device Label' ;
    rdfs:comment 'Human-readable label or nickname assigned to the device for operational reference.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstSeenTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Seen Timestamp' ;
    rdfs:comment 'Timestamp when the device fingerprint was first observed in the system.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:geoCity rdf:type rdf:Property ;
    rdfs:label 'Geo City' ;
    rdfs:comment 'City name derived from geolocation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hceFlag rdf:type rdf:Property ;
