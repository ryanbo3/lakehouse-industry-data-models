    rdfs:range xsd:string .

ind:requestAmount rdf:type rdf:Property ;
    rdfs:label 'Request Amount' ;
    rdfs:comment 'Monetary amount of the transaction that triggered the routing decision.' ;
    rdfs:domain ind:RoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestProtocol rdf:type rdf:Property ;
    rdfs:label 'Request Protocol' ;
    rdfs:comment 'Protocol used by the originating request (e.g., ISO8583, REST, SOAP, JSON).' ;
    rdfs:domain ind:RoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSource rdf:type rdf:Property ;
    rdfs:label 'Request Source' ;
    rdfs:comment 'Channel through which the payment request arrived (e.g., web, mobile app, POS terminal).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingDecisionStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Decision Status' ;
    rdfs:comment 'Current lifecycle status of the routing decision.' ;
    rdfs:domain ind:RoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Routing Latency Ms' ;
    rdfs:comment 'Measured time in milliseconds from request receipt to routing decision output.' ;
