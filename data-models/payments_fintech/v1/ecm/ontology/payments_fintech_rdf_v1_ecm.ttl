ind:connectionType rdf:type rdf:Property ;
    rdfs:label 'Connection Type' ;
    rdfs:comment 'Indicates whether connections are persistent or stateless.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCenterLocation rdf:type rdf:Property ;
    rdfs:label 'Data Center Location' ;
    rdfs:comment 'Physical data-center location (city, facility) hosting the endpoint.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointDescription rdf:type rdf:Property ;
    rdfs:label 'Endpoint Description' ;
    rdfs:comment 'Free-form description of the endpoint purpose and characteristics.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointStatus rdf:type rdf:Property ;
    rdfs:label 'Endpoint Status' ;
    rdfs:comment 'Current operational status of the endpoint.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthCheckIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Health Check Interval Seconds' ;
    rdfs:comment 'Interval between successive health checks, in seconds.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:healthCheckTimeoutSeconds rdf:type rdf:Property ;
    rdfs:label 'Health Check Timeout Seconds' ;
    rdfs:comment 'Maximum time to wait for a health-check response before marking it failed.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:healthStatus rdf:type rdf:Property ;
    rdfs:label 'Health Status' ;
    rdfs:comment 'Current health assessment of the endpoint.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddressRange rdf:type rdf:Property ;
    rdfs:label 'Ip Address Range' ;
    rdfs:comment 'CIDR notation representing the IP range allocated to the endpoint.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTlsMutual rdf:type rdf:Property ;
    rdfs:label 'Is Tls Mutual' ;
    rdfs:comment 'True if mutual TLS authentication is required.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceWindow rdf:type rdf:Property ;
    rdfs:label 'Maintenance Window' ;
    rdfs:comment 'Planned maintenance period (e.g., "Sat 02:00-04:00 UTC").' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxConnections rdf:type rdf:Property ;
    rdfs:label 'Max Connections' ;
    rdfs:comment 'Maximum number of simultaneous connections the endpoint can sustain.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxMessageSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Max Message Size Bytes' ;
    rdfs:comment 'Maximum size of a single message the endpoint will accept, in bytes.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkInterface rdf:type rdf:Property ;
    rdfs:label 'Network Interface' ;
    rdfs:comment 'Type of network interface (e.g., Ethernet, Fiber).' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingPriority rdf:type rdf:Property ;
    rdfs:label 'Routing Priority' ;
    rdfs:comment 'Numeric priority used when selecting among multiple eligible endpoints.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportedMessageFormat rdf:type rdf:Property ;
    rdfs:label 'Supported Message Format' ;
    rdfs:comment 'Message format(s) the endpoint can process.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputTps rdf:type rdf:Property ;
    rdfs:label 'Throughput Tps' ;
    rdfs:comment 'Average number of transactions the endpoint processes per second.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:messageLogId rdf:type rdf:Property ;
    rdfs:label 'Message Log Id' ;
    rdfs:comment 'Unique surrogate identifier for each network message log record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MessageLog .

ind:networkCertificationRecordId rdf:type rdf:Property ;
    rdfs:label 'Network Certification Network Certification Record Id' ;
    rdfs:comment 'Identifier of the certification record that validates the network endpoint\'s compliance.' ;
    rdfs:domain ind:MessageLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkCertificationRecord .

ind:networkRoutingRuleId rdf:type rdf:Property ;
    rdfs:label 'Network Routing Rule Id' ;
    rdfs:comment 'Reference to the routing rule applied to route this message.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkRoutingRule .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Result of the authorization attempt as reported by the network.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReasonCode rdf:type rdf:Property ;
    rdfs:label 'Decline Reason Code' ;
    rdfs:comment 'Code indicating the specific reason for a decline, if applicable.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoMessageVersion rdf:type rdf:Property ;
    rdfs:label 'Iso Message Version' ;
    rdfs:comment 'Specifies whether the message follows ISO 8583 or ISO 20022 formatting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageDirection rdf:type rdf:Property ;
    rdfs:label 'Message Direction' ;
    rdfs:comment 'Indicates whether the record is a request, response, advice, or reversal message.' ;
    rdfs:domain ind:MessageLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageHash rdf:type rdf:Property ;
    rdfs:label 'Message Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the raw message for integrity verification.' ;
    rdfs:domain ind:MessageLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Message Sequence Number' ;
    rdfs:comment 'Sequential number of the message within its batch or session.' ;
    rdfs:domain ind:MessageLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:messageTypeIndicator rdf:type rdf:Property ;
    rdfs:label 'Message Type Indicator' ;
    rdfs:comment 'Four-digit code that identifies the message class, function, and origin according to ISO 8583 or ISO 20022. [ENUM-REF-CANDIDATE: 0100|0110|0200|0210|0400|0410|0420|0430|0500|0510|0800|0810 — promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkScheme rdf:type rdf:Property ;
    rdfs:label 'Network Scheme' ;
    rdfs:comment 'Payment scheme or network that processed the message (e.g., Visa, Mastercard).' ;
    rdfs:domain ind:MessageLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkStatus rdf:type rdf:Property ;
    rdfs:label 'Network Status' ;
    rdfs:comment 'Overall status of the network interaction for this message.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingCode rdf:type rdf:Property ;
    rdfs:label 'Processing Code' ;
    rdfs:comment 'Six-digit code that defines the transaction type and processing rules (e.g., purchase, refund, cash advance).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rawMessage rdf:type rdf:Property ;
    rdfs:label 'Raw Message' ;
    rdfs:comment 'Full raw message content as received from the network (e.g., ISO 8583 bitmap).' ;
    rdfs:domain ind:MessageLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundTripLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Round Trip Latency Ms' ;
    rdfs:comment 'Measured latency in milliseconds between transmission and receipt of the corresponding response.' ;
    rdfs:domain ind:MessageLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmission Timestamp' ;
    rdfs:comment 'Timestamp when the message was sent from the originating system to the network.' ;
    rdfs:domain ind:MessageLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:networkProtocolConfigId rdf:type rdf:Property ;
    rdfs:label 'Network Protocol Config Id' ;
    rdfs:comment 'System-generated unique identifier for each network protocol configuration record.' ;
    rdfs:domain ind:NetworkProtocolConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bitmapFormat rdf:type rdf:Property ;
    rdfs:label 'Bitmap Format' ;
    rdfs:comment 'Representation format of the ISO 8583 bitmap (binary or hexadecimal).' ;
    rdfs:domain ind:NetworkProtocolConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Checksum Algorithm' ;
    rdfs:comment 'Algorithm used to compute message integrity checksums.' ;
    rdfs:domain ind:NetworkProtocolConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delimiter rdf:type rdf:Property ;
    rdfs:label 'Delimiter' ;
    rdfs:comment 'Character or byte sequence used to separate messages when framing rule is \'delimiter\'.' ;
    rdfs:domain ind:NetworkProtocolConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encoding rdf:type rdf:Property ;
    rdfs:label 'Encoding' ;
    rdfs:comment 'Character encoding used for the message payload.' ;
    rdfs:domain ind:NetworkProtocolConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldMappingDefinition rdf:type rdf:Property ;
    rdfs:label 'Field Mapping Definition' ;
    rdfs:comment 'JSON string that maps internal field names to network message fields.' ;
    rdfs:domain ind:NetworkProtocolConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso20022MessageSet rdf:type rdf:Property ;
    rdfs:label 'Iso 20022 Message Set' ;
    rdfs:comment 'Identifier of the ISO 20022 message set (e.g., pain.001, pacs.008) employed by the configuration.' ;
    rdfs:domain ind:NetworkProtocolConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso8583Version rdf:type rdf:Property ;
    rdfs:label 'Iso 8583 Version' ;
    rdfs:comment 'Version of the ISO 8583 standard used (e.g., 1987, 1993, 2003).' ;
    rdfs:domain ind:NetworkProtocolConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxMessageLength rdf:type rdf:Property ;
    rdfs:label 'Max Message Length' ;
    rdfs:comment 'Maximum allowed size of a single protocol message in bytes.' ;
    rdfs:domain ind:NetworkProtocolConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:messageFramingRule rdf:type rdf:Property ;
    rdfs:label 'Message Framing Rule' ;
    rdfs:comment 'Rule that defines how messages are delimited or length-prefixed on the wire.' ;
    rdfs:domain ind:NetworkProtocolConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minMessageLength rdf:type rdf:Property ;
    rdfs:label 'Min Message Length' ;
    rdfs:comment 'Minimum expected size of a protocol message in bytes.' ;
    rdfs:domain ind:NetworkProtocolConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkProtocolConfigCode rdf:type rdf:Property ;
    rdfs:label 'Network Protocol Config Code' ;
    rdfs:comment 'Business identifier or code used to reference the configuration in downstream systems.' ;
    rdfs:domain ind:NetworkProtocolConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkProtocolConfigDescription rdf:type rdf:Property ;
    rdfs:label 'Network Protocol Config Description' ;
    rdfs:comment 'Free-form description of the protocol configuration and its purpose.' ;
    rdfs:domain ind:NetworkProtocolConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkProtocolConfigName rdf:type rdf:Property ;
    rdfs:label 'Network Protocol Config Name' ;
    rdfs:comment 'Human-readable name identifying the protocol configuration.' ;
    rdfs:domain ind:NetworkProtocolConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkProtocolConfigStatus rdf:type rdf:Property ;
    rdfs:label 'Network Protocol Config Status' ;
    rdfs:comment 'Current lifecycle state of the protocol configuration.' ;
    rdfs:domain ind:NetworkProtocolConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolType rdf:type rdf:Property ;
    rdfs:label 'Protocol Type' ;
    rdfs:comment 'Type of messaging protocol implemented by this configuration.' ;
    rdfs:domain ind:NetworkProtocolConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedMessageTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Message Types' ;
    rdfs:comment 'Comma-separated list of message type identifiers (e.g., 0100, 0200) supported.' ;
    rdfs:domain ind:NetworkProtocolConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkResponseCodeId rdf:type rdf:Property ;
    rdfs:label 'Network Response Code Id' ;
    rdfs:comment 'Unique surrogate identifier for each network response code. _canonical_skip_reason: Entity is a reference lookup, no minimum attribute categories required.' ;
    rdfs:domain ind:NetworkResponseCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isRetryable rdf:type rdf:Property ;
    rdfs:label 'Is Retryable' ;
    rdfs:comment 'Indicates whether the transaction may be safely retried after this response.' ;
    rdfs:domain ind:NetworkResponseCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkResponseCodeDescription rdf:type rdf:Property ;
    rdfs:label 'Network Response Code Description' ;
    rdfs:comment 'Human-readable explanation of what the response code means.' ;
    rdfs:domain ind:NetworkResponseCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkResponseCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Network Response Code Status' ;
    rdfs:comment 'Lifecycle status of the response code within the scheme.' ;
    rdfs:domain ind:NetworkResponseCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedMerchantAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Merchant Action' ;
    rdfs:comment 'Suggested action for the merchant when this response code is returned (e.g., retry, contact cardholder, decline).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseCategory rdf:type rdf:Property ;
    rdfs:label 'Response Category' ;
    rdfs:comment 'High-level classification of the response code.' ;
    rdfs:domain ind:NetworkResponseCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseSource rdf:type rdf:Property ;
    rdfs:label 'Response Source' ;
    rdfs:comment 'Origin of the response code (network-generated, issuer-generated, or processor-generated).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingTableId rdf:type rdf:Property ;
    rdfs:label 'Routing Table Id' ;
    rdfs:comment 'Foreign key linking to network.routing_table. Business justification: Routing rules belong to a routing table; adding routing_table_id FK establishes hierarchy.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoutingTable .

ind:targetEndpointId rdf:type rdf:Property ;
    rdfs:label 'Target Endpoint Id' ;
    rdfs:comment 'Foreign key linking to network.endpoint. Business justification: Routing rule must reference the actual endpoint entity; replace the free-text column with a proper foreign key to enforce data integrity and enable joins.' ;
    rdfs:domain ind:NetworkRoutingRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Endpoint .

ind:binEnd rdf:type rdf:Property ;
    rdfs:label 'Bin End' ;
    rdfs:comment 'Last BIN in the inclusive range that the rule applies to.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binStart rdf:type rdf:Property ;
    rdfs:label 'Bin Start' ;
    rdfs:comment 'First BIN (Bank Identification Number) in the inclusive range that the rule applies to.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOverride rdf:type rdf:Property ;
    rdfs:label 'Is Override' ;
    rdfs:comment 'Indicates whether this rule can supersede lower-priority rules for the same criteria.' ;
    rdfs:domain ind:NetworkRoutingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkRoutingRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Network Routing Rule Status' ;
    rdfs:comment 'Current lifecycle status of the rule.' ;
    rdfs:domain ind:NetworkRoutingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaId rdf:type rdf:Property ;
    rdfs:label 'Sla Id' ;
    rdfs:comment 'System-generated unique identifier for the SLA record.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Associates SLA escalation contact with an employee, enabling automated alert routing and compliance reporting.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualAuthorizationResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Actual Authorization Response Time Ms' ;
    rdfs:comment 'Measured average authorization response time during the reporting period.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualBatchSettlementWindowHours rdf:type rdf:Property ;
    rdfs:label 'Actual Batch Settlement Window Hours' ;
    rdfs:comment 'Observed average time taken to settle batches.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Actual Latency Ms' ;
    rdfs:comment 'Observed average latency during the reporting period.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualUptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Actual Uptime Percentage' ;
    rdfs:comment 'Measured network availability percentage for the reporting period.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSettlementWindowHours rdf:type rdf:Property ;
    rdfs:label 'Batch Settlement Window Hours' ;
    rdfs:comment 'Maximum time allowed to complete batch settlement after transaction capture.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endpointIdentifier rdf:type rdf:Property ;
    rdfs:label 'Endpoint Identifier' ;
    rdfs:comment 'Unique identifier of the network connection endpoint used for routing.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Max Latency Ms' ;
    rdfs:comment 'Maximum allowed network latency for transaction messages, in milliseconds.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'How often SLA performance metrics are measured and reported.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyClause rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause' ;
    rdfs:comment 'Text describing the financial penalty applied for SLA breaches.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCategory rdf:type rdf:Property ;
    rdfs:label 'Sla Category' ;
    rdfs:comment 'Classification of the SLA metric type (authorization response time, uptime, latency, settlement window).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaName rdf:type rdf:Property ;
    rdfs:label 'Sla Name' ;
    rdfs:comment 'Human-readable name of the service-level agreement.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Status' ;
    rdfs:comment 'Current lifecycle status of the SLA record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAuthorizationResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Target Authorization Response Time Ms' ;
    rdfs:comment 'Promised maximum time for a real-time authorization response, expressed in milliseconds.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetUptimePercentage rdf:type rdf:Property ;
    rdfs:label 'Target Uptime Percentage' ;
    rdfs:comment 'Contracted network availability expressed as a percentage.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeLimitId rdf:type rdf:Property ;
    rdfs:label 'Volume Limit Id' ;
    rdfs:comment 'Surrogate primary key for the network volume limit record.' ;
    rdfs:domain ind:VolumeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Percentage' ;
    rdfs:comment 'Percentage of limit at which an alert is generated.' ;
    rdfs:domain ind:VolumeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyLimitCount rdf:type rdf:Property ;
    rdfs:label 'Daily Limit Count' ;
    rdfs:comment 'Maximum number of transactions allowed per day.' ;
    rdfs:domain ind:VolumeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dailyLimitValue rdf:type rdf:Property ;
    rdfs:label 'Daily Limit Value' ;
    rdfs:comment 'Maximum total transaction amount allowed per day.' ;
    rdfs:domain ind:VolumeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limitScope rdf:type rdf:Property ;
    rdfs:label 'Limit Scope' ;
    rdfs:comment 'Scope level at which the limit applies.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitUnit rdf:type rdf:Property ;
    rdfs:label 'Limit Unit' ;
    rdfs:comment 'Unit of measurement for limit_value.' ;
    rdfs:domain ind:VolumeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitValue rdf:type rdf:Property ;
    rdfs:label 'Limit Value' ;
    rdfs:comment 'Numeric threshold for the limit (e.g., max amount or max count).' ;
    rdfs:domain ind:VolumeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyLimitCount rdf:type rdf:Property ;
    rdfs:label 'Monthly Limit Count' ;
    rdfs:comment 'Maximum number of transactions allowed per month.' ;
    rdfs:domain ind:VolumeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monthlyLimitValue rdf:type rdf:Property ;
    rdfs:label 'Monthly Limit Value' ;
    rdfs:comment 'Maximum total transaction amount allowed per month.' ;
    rdfs:domain ind:VolumeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageAmount rdf:type rdf:Property ;
    rdfs:label 'Usage Amount' ;
    rdfs:comment 'Current accumulated transaction amount within the active window.' ;
    rdfs:domain ind:VolumeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageCounter rdf:type rdf:Property ;
    rdfs:label 'Usage Counter' ;
    rdfs:comment 'Current count of transactions counted towards the limit within the active window.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageResetTimestamp rdf:type rdf:Property ;
    rdfs:label 'Usage Reset Timestamp' ;
    rdfs:comment 'Timestamp when the usage counters reset.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:volumeLimitDescription rdf:type rdf:Property ;
    rdfs:label 'Volume Limit Description' ;
    rdfs:comment 'Free-text description of the limit purpose and any special notes.' ;
    rdfs:domain ind:VolumeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeLimitName rdf:type rdf:Property ;
    rdfs:label 'Volume Limit Name' ;
    rdfs:comment 'Human readable name for the volume limit configuration.' ;
    rdfs:domain ind:VolumeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeLimitStatus rdf:type rdf:Property ;
    rdfs:label 'Volume Limit Status' ;
    rdfs:comment 'Current lifecycle status of the limit configuration.' ;
    rdfs:domain ind:VolumeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackSequence rdf:type rdf:Property ;
    rdfs:label 'Fallback Sequence' ;
    rdfs:comment 'Order number for fallback routing attempts.' ;
    rdfs:domain ind:RoutingTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isFallbackEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Fallback Enabled' ;
    rdfs:comment 'Indicates whether fallback routing is permitted if primary routing fails.' ;
    rdfs:domain ind:RoutingTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingRail rdf:type rdf:Property ;
    rdfs:label 'Processing Rail' ;
    rdfs:comment 'Processing mode used for the routed transaction.' ;
    rdfs:domain ind:RoutingTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingTableDescription rdf:type rdf:Property ;
    rdfs:label 'Routing Table Description' ;
    rdfs:comment 'Free-form description of the routing rule purpose and logic.' ;
    rdfs:domain ind:RoutingTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingTableStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Table Status' ;
    rdfs:comment 'Current lifecycle status of the routing rule.' ;
    rdfs:domain ind:RoutingTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Surcharge Amount' ;
    rdfs:comment 'Fixed surcharge amount added to the transaction fee for this routing path.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetNetwork rdf:type rdf:Property ;
    rdfs:label 'Target Network' ;
    rdfs:comment 'Payment network to which the transaction should be routed.' ;
    rdfs:domain ind:RoutingTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencySupported rdf:type rdf:Property ;
    rdfs:label 'Currency Supported' ;
    rdfs:comment 'Currencies in which the scheme can settle transactions.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeFeeRate rdf:type rdf:Property ;
    rdfs:label 'Interchange Fee Rate' ;
    rdfs:comment 'Numeric fee rate applied to transactions (e.g., 0.0150 for 1.5%).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interchangeFeeType rdf:type rdf:Property ;
    rdfs:label 'Interchange Fee Type' ;
    rdfs:comment 'Indicates whether the interchange fee is calculated as a percentage or a fixed amount.' ;
    rdfs:domain ind:Scheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Network Certification Date' ;
    rdfs:comment 'Date when the scheme achieved its most recent network certification.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:networkCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Network Certification Status' ;
    rdfs:comment 'Current certification status of the scheme within the network.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskProfile rdf:type rdf:Property ;
    rdfs:label 'Risk Profile' ;
    rdfs:comment 'Risk classification of the scheme based on fraud and chargeback history.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeCode rdf:type rdf:Property ;
    rdfs:label 'Scheme Code' ;
    rdfs:comment 'Canonical short code used to identify the scheme in messages and reports (e.g., VISA, MC).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeDescription rdf:type rdf:Property ;
    rdfs:label 'Scheme Description' ;
    rdfs:comment 'Free-form description of the scheme, its purpose and key characteristics.' ;
    rdfs:domain ind:Scheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeStatus rdf:type rdf:Property ;
    rdfs:label 'Scheme Status' ;
    rdfs:comment 'Current operational status of the scheme within the platform.' ;
    rdfs:domain ind:Scheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeType rdf:type rdf:Property ;
    rdfs:label 'Scheme Type' ;
    rdfs:comment 'Category of the scheme based on the primary instrument or service it supports.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedTransactionTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Transaction Types' ;
    rdfs:comment 'Comma-separated list of transaction types the scheme supports (e.g., purchase, refund, cash-advance).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeDsSupported rdf:type rdf:Property ;
    rdfs:label 'Three Ds Supported' ;
    rdfs:comment 'Indicates whether the scheme supports 3-Domain Secure authentication.' ;
    rdfs:domain ind:Scheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:schemeBulletinId rdf:type rdf:Property ;
    rdfs:label 'Scheme Bulletin Id' ;
    rdfs:comment 'Unique system-generated identifier for the scheme bulletin record.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SchemeBulletin .

ind:applicableRegions rdf:type rdf:Property ;
    rdfs:label 'Applicable Regions' ;
    rdfs:comment 'Comma-separated list of ISO-3166-1 alpha-3 country codes where the bulletin applies.' ;
    rdfs:domain ind:SchemeBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulletinNumber rdf:type rdf:Property ;
    rdfs:label 'Bulletin Number' ;
    rdfs:comment 'Official bulletin number or code assigned by the card scheme.' ;
    rdfs:domain ind:SchemeBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulletinType rdf:type rdf:Property ;
    rdfs:label 'Bulletin Type' ;
    rdfs:comment 'Category of the bulletin (e.g., mandate, update, advisory).' ;
    rdfs:domain ind:SchemeBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'Date by which merchants/issuers must comply with the bulletin.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impactedParameterCategory rdf:type rdf:Property ;
    rdfs:label 'Impacted Parameter Category' ;
    rdfs:comment 'Primary functional area(s) affected by the bulletin.' ;
    rdfs:domain ind:SchemeBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Progress of internal implementation of the bulletin requirements.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatory rdf:type rdf:Property ;
    rdfs:label 'Mandatory' ;
    rdfs:comment 'Indicates whether the bulletin is mandatory (true) or advisory (false).' ;
    rdfs:domain ind:SchemeBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:schemeBulletinDescription rdf:type rdf:Property ;
    rdfs:label 'Scheme Bulletin Description' ;
    rdfs:comment 'Full textual description of the bulletin content and purpose.' ;
    rdfs:domain ind:SchemeBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeBulletinStatus rdf:type rdf:Property ;
    rdfs:label 'Scheme Bulletin Status' ;
    rdfs:comment 'Current lifecycle status of the bulletin.' ;
    rdfs:domain ind:SchemeBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Source Document Url' ;
    rdfs:comment 'Link to the original bulletin document hosted by the scheme.' ;
    rdfs:domain ind:SchemeBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeComplianceRecordId rdf:type rdf:Property ;
    rdfs:label 'Scheme Compliance Record Id' ;
    rdfs:comment 'System-generated unique identifier for the scheme compliance record.' ;
    rdfs:domain ind:SchemeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attestationDocumentId rdf:type rdf:Property ;
    rdfs:label 'Attestation Document Id' ;
    rdfs:comment 'Reference identifier for the uploaded attestation or certification document.' ;
    rdfs:domain ind:SchemeComplianceRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:attestationReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Attestation Received Date' ;
    rdfs:comment 'Date the scheme acknowledged receipt of the compliance attestation.' ;
    rdfs:domain ind:SchemeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Score' ;
    rdfs:comment 'Numeric score (e.g., 0-100) representing overall compliance health for the record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonComplianceNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Notice Date' ;
    rdfs:comment 'Date a formal notice of non-compliance was received from the scheme.' ;
