ind:currencyId rdf:type rdf:Property ;
    rdfs:label 'Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Account statements are issued in a specific currency; linking to reference.currency ensures consistent reporting and fee calculation.' ;
    rdfs:domain ind:PaymentsFintech ;
