    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeComplianceRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Scheme Compliance Record Status' ;
    rdfs:comment 'Current overall status of the compliance record against the scheme requirements.' ;
    rdfs:domain ind:SchemeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeEventId rdf:type rdf:Property ;
    rdfs:label 'Scheme Event Id' ;
    rdfs:comment 'System-generated unique identifier for each scheme-level operational event.' ;
    rdfs:domain ind:SchemeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedMccCodes rdf:type rdf:Property ;
    rdfs:label 'Affected Mcc Codes' ;
    rdfs:comment 'Comma-separated list of MCC values whose merchants are impacted.' ;
    rdfs:domain ind:SchemeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedRegions rdf:type rdf:Property ;
    rdfs:label 'Affected Regions' ;
    rdfs:comment 'Comma-separated list of ISO-3166-1 alpha-3 country codes impacted by the event.' ;
    rdfs:domain ind:SchemeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactScope rdf:type rdf:Property ;
    rdfs:label 'Impact Scope' ;
    rdfs:comment 'Geographic or functional scope of the event (e.g., global, regional, specific merchant category).' ;
    rdfs:domain ind:SchemeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmergency rdf:type rdf:Property ;
    rdfs:label 'Is Emergency' ;
    rdfs:comment 'True if the event required emergency handling or unscheduled routing changes.' ;
    rdfs:domain ind:SchemeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parameterName rdf:type rdf:Property ;
    rdfs:label 'Parameter Name' ;
    rdfs:comment 'Name of the scheme configuration parameter that was changed (relevant for parameter_push events).' ;
    rdfs:domain ind:Network ;
