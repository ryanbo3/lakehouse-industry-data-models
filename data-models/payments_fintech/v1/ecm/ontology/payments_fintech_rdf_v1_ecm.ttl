ind:verificationResult rdf:type rdf:Property ;
    rdfs:label 'Verification Result' ;
    rdfs:comment 'Outcome of the verification: pass, fail, or partial (e.g., address matched but CVV did not).' ;
    rdfs:domain ind:InstrumentVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationType rdf:type rdf:Property ;
    rdfs:label 'Verification Type' ;
    rdfs:comment 'Category of verification performed (e.g., Address Verification System, Card Verification Value, 3-DS, Biometric, Micro-Deposit, Tokenization).' ;
    rdfs:domain ind:InstrumentVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuerWalletConfigId rdf:type rdf:Property ;
    rdfs:label 'Issuer Wallet Config Id' ;
    rdfs:comment 'Unique surrogate key for each issuer wallet configuration record.' ;
    rdfs:domain ind:IssuerWalletConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allowedCardSchemes rdf:type rdf:Property ;
    rdfs:label 'Allowed Card Schemes' ;
    rdfs:comment 'Comma-separated list of card scheme codes (e.g., VISA, MASTERCARD) that may be tokenized.' ;
    rdfs:domain ind:IssuerWalletConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configStatus rdf:type rdf:Property ;
    rdfs:label 'Config Status' ;
    rdfs:comment 'Current lifecycle status of the configuration.' ;
    rdfs:domain ind:IssuerWalletConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:greenPathThreshold rdf:type rdf:Property ;
    rdfs:label 'Green Path Threshold' ;
    rdfs:comment 'Risk score percentage below which transactions follow the green (low-risk) path.' ;
    rdfs:domain ind:IssuerWalletConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDynamicCurrencyConversionSupported rdf:type rdf:Property ;
    rdfs:label 'Is Dynamic Currency Conversion Supported' ;
    rdfs:comment 'Indicates support for DCC in tokenized transactions.' ;
    rdfs:domain ind:IssuerWalletConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuerWalletConfigDescription rdf:type rdf:Property ;
    rdfs:label 'Issuer Wallet Config Description' ;
    rdfs:comment 'Free-form description of the configuration purpose and scope.' ;
    rdfs:domain ind:IssuerWalletConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxTokensPerFpan rdf:type rdf:Property ;
    rdfs:label 'Max Tokens Per Fpan' ;
    rdfs:comment 'Maximum number of active tokens that may be issued for a single primary account number.' ;
    rdfs:domain ind:IssuerWalletConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otpDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Otp Delivery Method' ;
    rdfs:comment 'Channel used to deliver the OTP for step-up authentication.' ;
    rdfs:domain ind:IssuerWalletConfig ;
