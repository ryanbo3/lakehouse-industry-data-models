    rdfs:comment 'Policy governing how points expire – rolling (based on activity), fixed date, or none.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsPending rdf:type rdf:Property ;
