ind:primaryBaseCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Primary Base Currency Id' ;
    rdfs:comment 'FK to reference.currency' ;
    rdfs:domain ind:CurrencyPair ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:crossBorderEligible rdf:type rdf:Property ;
