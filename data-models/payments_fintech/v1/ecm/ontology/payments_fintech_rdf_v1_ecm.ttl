    rdfs:comment 'Comma-separated list of transaction types the terminal can process.' ;
    rdfs:domain ind:EmvParameterSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:velocityCheckLimit rdf:type rdf:Property ;
    rdfs:label 'Velocity Check Limit' ;
    rdfs:comment 'Maximum number of offline transactions allowed before a mandatory online check.' ;
    rdfs:domain ind:EmvParameterSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:velocityCheckTimeWindow rdf:type rdf:Property ;
