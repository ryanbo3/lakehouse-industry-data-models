    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCategory rdf:type rdf:Property ;
    rdfs:label 'Training Category' ;
    rdfs:comment 'Broad category of the training content.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionStatus rdf:type rdf:Property ;
