ind:tokenizationSupported rdf:type rdf:Property ;
    rdfs:label 'Tokenization Supported' ;
    rdfs:comment 'Indicates whether tokenization services are available in the region.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientApplicationId rdf:type rdf:Property ;
