    rdfs:comment 'Position or tag identifier of the field within the message standard.' ;
    rdfs:domain ind:IsoMessageField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoMessageFieldStatus rdf:type rdf:Property ;
    rdfs:label 'Iso Message Field Status' ;
    rdfs:comment 'Current lifecycle status of the field definition.' ;
    rdfs:domain ind:IsoMessageField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:length rdf:type rdf:Property ;
    rdfs:label 'Length' ;
    rdfs:comment 'Allowed length or length range of the field value.' ;
    rdfs:domain ind:IsoMessageField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryIndicator rdf:type rdf:Property ;
