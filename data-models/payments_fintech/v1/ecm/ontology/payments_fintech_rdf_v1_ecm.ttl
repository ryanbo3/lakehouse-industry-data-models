    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Internal Owner Department' ;
    rdfs:comment 'Business unit that owns the reporting requirement configuration.' ;
    rdfs:domain ind:RegulatoryReportingReq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationName rdf:type rdf:Property ;
