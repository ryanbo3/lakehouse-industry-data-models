    rdfs:range xsd:string .

ind:decisionOutcome rdf:type rdf:Property ;
    rdfs:label 'Decision Outcome' ;
    rdfs:comment 'Result of the routing decision as applied to the transaction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionReason rdf:type rdf:Property ;
    rdfs:label 'Decision Reason' ;
    rdfs:comment 'Human-readable explanation or code describing why the particular endpoint was selected.' ;
