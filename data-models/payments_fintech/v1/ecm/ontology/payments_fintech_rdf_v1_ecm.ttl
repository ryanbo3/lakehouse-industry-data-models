ind:nfcEnabled rdf:type rdf:Property ;
    rdfs:label 'Nfc Enabled' ;
    rdfs:comment 'Indicates if NFC (Near Field Communication) is enabled on the terminal.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profileType rdf:type rdf:Property ;
    rdfs:label 'Profile Type' ;
    rdfs:comment 'Classification of the profile (e.g., default, custom, partner specific).' ;
    rdfs:domain ind:ContactlessProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qrPaymentEnabled rdf:type rdf:Property ;
    rdfs:label 'Qr Payment Enabled' ;
    rdfs:comment 'Flag indicating if QR code payments are enabled for the terminal.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qrPaymentType rdf:type rdf:Property ;
    rdfs:label 'Qr Payment Type' ;
    rdfs:comment 'Specifies whether static or dynamic QR codes are used.' ;
    rdfs:domain ind:ContactlessProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityCertificationLevel rdf:type rdf:Property ;
    rdfs:label 'Security Certification Level' ;
    rdfs:comment 'Security certification level of the terminal (e.g., PCI PTS, PCI PTS A, PCI PTS B).' ;
    rdfs:domain ind:ContactlessProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedKernels rdf:type rdf:Property ;
    rdfs:label 'Supported Kernels' ;
    rdfs:comment 'Comma-separated list of contactless kernel identifiers supported (e.g., Visa payWave, Mastercard PayPass, Amex ExpressPay, Discover D-PAS). [ENUM-REF-CANDIDATE: Visa payWave|Mastercard PayPass|Amex ExpressPay|Discover D-PAS|UnionPay QuickPass|JCB J/Speedy — promote to reference product]' ;
    rdfs:domain ind:ContactlessProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalSoftwareVersion rdf:type rdf:Property ;
    rdfs:label 'Terminal Software Version' ;
    rdfs:comment 'Version of the terminal software that implements this profile.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emvParameterSetId rdf:type rdf:Property ;
    rdfs:label 'Emv Parameter Set Id' ;
    rdfs:comment 'Unique surrogate key for each EMV parameter set record.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmvParameterSet .

ind:applicationTransactionCounter rdf:type rdf:Property ;
    rdfs:label 'Application Transaction Counter' ;
    rdfs:comment 'Initial value of the transaction counter for the application.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cvmList rdf:type rdf:Property ;
    rdfs:label 'Cvm List' ;
    rdfs:comment 'Comma-separated list of supported CVMs for the terminal.' ;
    rdfs:domain ind:EmvParameterSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emvParameterSetDescription rdf:type rdf:Property ;
    rdfs:label 'Emv Parameter Set Description' ;
    rdfs:comment 'Human-readable description or notes about the parameter set.' ;
    rdfs:domain ind:EmvParameterSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emvParameterSetStatus rdf:type rdf:Property ;
    rdfs:label 'Emv Parameter Set Status' ;
    rdfs:comment 'Current lifecycle status of the EMV parameter set.' ;
    rdfs:domain ind:EmvParameterSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorLimit rdf:type rdf:Property ;
    rdfs:label 'Floor Limit' ;
    rdfs:comment 'Maximum transaction amount that can be approved offline without online authorization.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offlinePinSupported rdf:type rdf:Property ;
    rdfs:label 'Offline Pin Supported' ;
    rdfs:comment 'Indicates if the terminal can perform offline PIN verification.' ;
