    rdfs:range xsd:dateTime .

ind:reissuanceLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Reissuance Lead Time Days' ;
    rdfs:comment 'Configured lead time used for scheduling renewal batches.' ;
