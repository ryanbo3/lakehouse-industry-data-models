ind:watchlistEntryId rdf:type rdf:Property ;
    rdfs:label 'Watchlist Entry Id' ;
    rdfs:comment 'Foreign key linking to compliance.watchlist_entry. Business justification: Sanctions checks reference entries in the watchlist master; linking provides source of the hit.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WatchlistEntry .

ind:blockActionTaken rdf:type rdf:Property ;
    rdfs:label 'Block Action Taken' ;
    rdfs:comment 'Action taken as a result of the hit (e.g., blocked transaction, allowed, sent for review).' ;
