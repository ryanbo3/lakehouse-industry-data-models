ind:currencyPairStatus rdf:type rdf:Property ;
    rdfs:label 'Currency Pair Status' ;
    rdfs:comment 'Current lifecycle status of the currency pair.' ;
    rdfs:domain ind:CurrencyPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dccEligible rdf:type rdf:Property ;
    rdfs:label 'Dcc Eligible' ;
    rdfs:comment 'True if the pair is eligible for DCC transactions.' ;
