    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradingEndTime rdf:type rdf:Property ;
    rdfs:label 'Trading End Time' ;
    rdfs:comment 'UTC time when the pair stops being tradable each business day.' ;
