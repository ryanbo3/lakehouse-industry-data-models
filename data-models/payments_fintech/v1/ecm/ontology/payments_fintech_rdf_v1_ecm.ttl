    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventLogDescription rdf:type rdf:Property ;
    rdfs:label 'Event Log Description' ;
    rdfs:comment 'Human-readable description summarizing the event.' ;
    rdfs:domain ind:EventLog ;
