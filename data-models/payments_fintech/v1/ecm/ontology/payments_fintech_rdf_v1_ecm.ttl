    rdfs:comment 'Timestamp when processing of the message began.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiverBic rdf:type rdf:Property ;
    rdfs:label 'Receiver Bic' ;
    rdfs:comment 'BIC of the receiving financial institution.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySanctionsStatus rdf:type rdf:Property ;
