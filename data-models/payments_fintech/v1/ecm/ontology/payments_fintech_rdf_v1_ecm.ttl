    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tradingStartTime rdf:type rdf:Property ;
    rdfs:label 'Trading Start Time' ;
    rdfs:comment 'UTC time when the pair becomes tradable each business day.' ;
    rdfs:domain ind:CurrencyPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dccConfigId rdf:type rdf:Property ;
    rdfs:label 'Dcc Config Id' ;
    rdfs:comment 'Surrogate primary key for the DCC configuration record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DccConfig .

ind:cardholderDisclosureTextRef rdf:type rdf:Property ;
    rdfs:label 'Cardholder Disclosure Text Ref' ;
    rdfs:comment 'Reference identifier to the legal disclosure text shown to cardholders for DCC offers.' ;
    rdfs:domain ind:DccConfig ;
    rdf:type owl:DatatypeProperty ;
