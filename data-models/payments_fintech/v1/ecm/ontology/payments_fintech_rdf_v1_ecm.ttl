    rdfs:range xsd:string .

ind:dccTransactionStatus rdf:type rdf:Property ;
    rdfs:label 'Dcc Transaction Status' ;
    rdfs:comment 'Current lifecycle state of the DCC transaction.' ;
    rdfs:domain ind:DccTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
