ind:originalIssuanceInstrumentIssuanceId rdf:type rdf:Property ;
    rdfs:label 'Original Issuance Instrument Issuance Id' ;
    rdfs:comment 'Identifier of the original issuance record when this is a re-issue.' ;
    rdfs:domain ind:InstrumentIssuance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InstrumentIssuance .

ind:activationDeadline rdf:type rdf:Property ;
    rdfs:label 'Activation Deadline' ;
    rdfs:comment 'Date by which the instrument must be activated before it expires or is de-provisioned.' ;
    rdfs:domain ind:InstrumentIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:instrumentIssuanceStatus rdf:type rdf:Property ;
    rdfs:label 'Instrument Issuance Status' ;
    rdfs:comment 'Current lifecycle state of the issuance record.' ;
    rdfs:domain ind:InstrumentIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReissued rdf:type rdf:Property ;
    rdfs:label 'Is Reissued' ;
    rdfs:comment 'True if this issuance replaces a previously issued instrument.' ;
    rdfs:domain ind:InstrumentIssuance ;
