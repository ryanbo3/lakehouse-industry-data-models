ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Human-readable name of the program offering.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programTier rdf:type rdf:Property ;
    rdfs:label 'Program Tier' ;
    rdfs:comment 'Tier or level of the program assigned to the cardholder (e.g., Silver, Gold, Platinum).' ;
    rdfs:domain ind:ProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
