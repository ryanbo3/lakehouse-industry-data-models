    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minAmount rdf:type rdf:Property ;
    rdfs:label 'Min Amount' ;
    rdfs:comment 'Lower bound amount for which the rule applies (optional).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parameters rdf:type rdf:Property ;
    rdfs:label 'Parameters' ;
    rdfs:comment 'JSON-encoded parameter set used by the rule logic.' ;
    rdfs:domain ind:RiskRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Rule Description' ;
    rdfs:comment 'Detailed free-text description of the rule logic and purpose.' ;
