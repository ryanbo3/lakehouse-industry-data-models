ind:parameterCode rdf:type rdf:Property ;
    rdfs:label 'Parameter Code' ;
    rdfs:comment 'Unique code assigned by the card network to identify the parameter.' ;
    rdfs:domain ind:SchemeParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeParameterDescription rdf:type rdf:Property ;
    rdfs:label 'Scheme Parameter Description' ;
    rdfs:comment 'Detailed free-text description of the parameter purpose and usage.' ;
