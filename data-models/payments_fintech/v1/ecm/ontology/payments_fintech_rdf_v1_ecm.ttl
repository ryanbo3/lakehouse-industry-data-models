ind:availabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Availability Percentage' ;
    rdfs:comment 'Calculated availability of the gateway service expressed as a percentage of the measurement window.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachSeverity rdf:type rdf:Property ;
    rdfs:label 'Breach Severity' ;
    rdfs:comment 'Categorical severity of the SLA breach, where higher levels indicate greater impact.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorRatePercent rdf:type rdf:Property ;
    rdfs:label 'Error Rate Percent' ;
    rdfs:comment 'Proportion of total requests that failed, expressed as a percentage of the measurement window.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
