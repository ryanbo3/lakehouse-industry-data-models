    rdfs:comment 'Classification of the relationship (e.g., household_member, corporate_subsidiary, guarantor, beneficial_owner, joint_account_holder, power_of_attorney). [ENUM-REF-CANDIDATE: household_member|corporate_subsidiary|guarantor|beneficial_owner|joint_account_holder|power_of_attorney|other — promote to reference product]' ;
    rdfs:domain ind:Relationship ;
