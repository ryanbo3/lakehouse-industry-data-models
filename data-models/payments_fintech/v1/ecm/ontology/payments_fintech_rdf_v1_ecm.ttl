    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAttemptsAllowed rdf:type rdf:Property ;
    rdfs:label 'Max Attempts Allowed' ;
    rdfs:comment 'Configured maximum number of verification attempts before lockout.' ;
    rdfs:domain ind:InstrumentVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:microDepositStatus rdf:type rdf:Property ;
    rdfs:label 'Micro Deposit Status' ;
    rdfs:comment 'Current status of the micro-deposit verification process.' ;
