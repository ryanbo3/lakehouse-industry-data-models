    rdfs:range xsd:integer .

ind:errorRateThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Error Rate Threshold Pct' ;
    rdfs:comment 'Maximum allowed error/decline rate expressed as a percentage.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationContactEmail rdf:type rdf:Property ;
