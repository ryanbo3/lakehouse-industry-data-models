ind:messageCategory rdf:type rdf:Property ;
    rdfs:label 'Message Category' ;
    rdfs:comment 'Broad category of the message (e.g., financial, status, reporting). [ENUM-REF-CANDIDATE: financial|status|reporting|reconciliation|settlement|risk|compliance — promote to reference product]' ;
