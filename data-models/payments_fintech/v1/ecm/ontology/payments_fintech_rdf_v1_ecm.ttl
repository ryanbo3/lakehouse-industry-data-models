ind:applicableToInternational rdf:type rdf:Property ;
    rdfs:label 'Applicable To International' ;
    rdfs:comment 'True if the fee applies to international (cross-border) transactions.' ;
    rdfs:domain ind:SchemeFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeCapIndicator rdf:type rdf:Property ;
    rdfs:label 'Fee Cap Indicator' ;
    rdfs:comment 'True if a fee cap is enforced for this schedule.' ;
    rdfs:domain ind:SchemeFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Code' ;
    rdfs:comment 'Business-facing code that uniquely identifies the fee schedule within the organization.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeFeeScheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Scheme Fee Schedule Description' ;
    rdfs:comment 'Free-form text describing the purpose, scope, or special conditions of the fee schedule.' ;
    rdfs:domain ind:SchemeFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeFeeScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Scheme Fee Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the fee schedule.' ;
    rdfs:domain ind:SchemeFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeIndicator rdf:type rdf:Property ;
    rdfs:label 'Surcharge Indicator' ;
    rdfs:comment 'True if the fee is a surcharge passed to the merchant or cardholder.' ;
    rdfs:domain ind:SchemeFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionCategory rdf:type rdf:Property ;
    rdfs:label 'Transaction Category' ;
    rdfs:comment 'Business classification of the transaction (e.g., purchase, refund, cash-advance) to which the fee applies.' ;
    rdfs:domain ind:PaymentsFintech ;
