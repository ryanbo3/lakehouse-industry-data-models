    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethodDetail rdf:type rdf:Property ;
    rdfs:label 'Verification Method Detail' ;
    rdfs:comment 'Free-text description of the method or technology used for verification (e.g., HCE, NFC, OTP).' ;
