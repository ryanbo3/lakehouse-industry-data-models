    rdfs:comment 'Current lifecycle status of the policy.' ;
    rdfs:domain ind:PolicyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Category of regulatory or internal policy.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psd2IncidentReportId rdf:type rdf:Property ;
    rdfs:label 'Psd2 Incident Report Id' ;
    rdfs:comment 'Unique surrogate key for the PSD2 incident report.' ;
    rdfs:domain ind:Psd2IncidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedServices rdf:type rdf:Property ;
    rdfs:label 'Affected Services' ;
    rdfs:comment 'Comma-separated list of payment services or APIs impacted by the incident.' ;
