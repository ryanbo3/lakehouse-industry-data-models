ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'Unit of measurement for the risk score threshold (points or percent).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudScaChallengeId rdf:type rdf:Property ;
    rdfs:label 'Fraud Sca Challenge Id' ;
    rdfs:comment 'Unique identifier for the SCA challenge record.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateway3dsAuthenticationId rdf:type rdf:Property ;
    rdfs:label 'Gateway3ds Authentication Id' ;
    rdfs:comment 'Foreign key linking to gateway.gateway3ds_authentication. Business justification: SCA challenge records must be tied to the corresponding 3-DS authentication session for full compliance audit.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gateway3dsAuthentication .

ind:authCode rdf:type rdf:Property ;
    rdfs:label 'Auth Code' ;
    rdfs:comment 'Authorization code returned by the issuer after successful challenge.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeAttemptNumber rdf:type rdf:Property ;
    rdfs:label 'Challenge Attempt Number' ;
    rdfs:comment 'Sequential number of the attempt for the same transaction.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:challengeOutcome rdf:type rdf:Property ;
    rdfs:label 'Challenge Outcome' ;
    rdfs:comment 'Result of the SCA challenge: passed, failed, or abandoned by the cardholder.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Challenge Response Time Ms' ;
    rdfs:comment 'Elapsed time in milliseconds between initiation and completion of the challenge.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:idempotencyKey rdf:type rdf:Property ;
    rdfs:label 'Idempotency Key' ;
    rdfs:comment 'Unique key to ensure the challenge request is processed exactly once.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiation Timestamp' ;
    rdfs:comment 'Timestamp when the SCA challenge was presented to the cardholder.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isChallengeAbandoned rdf:type rdf:Property ;
    rdfs:label 'Is Challenge Abandoned' ;
    rdfs:comment 'True when the cardholder abandoned the challenge.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isChallengeBlocked rdf:type rdf:Property ;
    rdfs:label 'Is Challenge Blocked' ;
    rdfs:comment 'True when the challenge was blocked by policy or system error.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isChallengeExempted rdf:type rdf:Property ;
    rdfs:label 'Is Challenge Exempted' ;
    rdfs:comment 'True when an SCA exemption was applied and no challenge was required.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isChallengeSuccessful rdf:type rdf:Property ;
    rdfs:label 'Is Challenge Successful' ;
    rdfs:comment 'True when the challenge outcome is passed.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryContext rdf:type rdf:Property ;
    rdfs:label 'Regulatory Context' ;
    rdfs:comment 'Regulatory framework governing the challenge, e.g., PSD2.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaMethod rdf:type rdf:Property ;
    rdfs:label 'Sca Method' ;
    rdfs:comment 'Method used to perform the SCA challenge (One-Time Password, biometric, push notification, knowledge-based).' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoreEventId rdf:type rdf:Property ;
    rdfs:label 'Score Event Id' ;
    rdfs:comment 'Globally unique identifier for the fraud scoring event record.' ;
    rdfs:domain ind:ScoreEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskModelId rdf:type rdf:Property ;
    rdfs:label 'Risk Model Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_model. Business justification: Fraud scoring uses a specific risk model; linking enables audit of model version per score event for compliance.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskModel .

ind:decision rdf:type rdf:Property ;
    rdfs:label 'Decision' ;
    rdfs:comment 'Actual decision taken by downstream systems after applying the recommended action.' ;
    rdfs:domain ind:ScoreEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSource rdf:type rdf:Property ;
    rdfs:label 'Event Source' ;
    rdfs:comment 'Subsystem that generated the fraud scoring event.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureSetHash rdf:type rdf:Property ;
    rdfs:label 'Feature Set Hash' ;
    rdfs:comment 'Hash of the input feature set used for the scoring run, enabling reproducibility.' ;
    rdfs:domain ind:ScoreEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geo Country Code' ;
    rdfs:comment 'Three-letter ISO country code derived from the IP address.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Version string of the fraud scoring model.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Suggested operational action based on the fraud evaluation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when the fraud score event record was first persisted.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the fraud score event record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ruleSetVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Set Version' ;
    rdfs:comment 'Version of the rule set used for the evaluation.' ;
    rdfs:domain ind:ScoreEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoreBand rdf:type rdf:Property ;
    rdfs:label 'Score Band' ;
    rdfs:comment 'Categorical band derived from the fraud score for operational handling.' ;
    rdfs:domain ind:ScoreEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentFraudTypeId rdf:type rdf:Property ;
    rdfs:label 'Parent Fraud Type Id' ;
    rdfs:comment 'Identifier of the parent fraud type for hierarchical classification.' ;
    rdfs:domain ind:FraudType ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudType .

ind:fraudTypeCode rdf:type rdf:Property ;
    rdfs:label 'Fraud Type Code' ;
    rdfs:comment 'Short alphanumeric code representing the fraud type (e.g., CNP for Card-Not-Present).' ;
    rdfs:domain ind:FraudType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Fraud Type Description' ;
    rdfs:comment 'Detailed description of the fraud scenario and typical characteristics.' ;
    rdfs:domain ind:FraudType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudTypeName rdf:type rdf:Property ;
    rdfs:label 'Fraud Type Name' ;
    rdfs:comment 'Human-readable name of the fraud type.' ;
    rdfs:domain ind:FraudType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Fraud Type Status' ;
    rdfs:comment 'Lifecycle status of the fraud type definition.' ;
    rdfs:domain ind:FraudType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationAction rdf:type rdf:Property ;
    rdfs:label 'Mitigation Action' ;
    rdfs:comment 'Standard remediation action taken when this fraud type is detected.' ;
    rdfs:domain ind:FraudType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'Primary channel where the fraud type is observed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Code' ;
    rdfs:comment 'Code used in regulatory reports (e.g., Visa reason code, Mastercard reason code).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresManualReview rdf:type rdf:Property ;
    rdfs:label 'Requires Manual Review' ;
    rdfs:comment 'Indicates if cases of this fraud type automatically trigger manual investigation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:typicalLossAmount rdf:type rdf:Property ;
    rdfs:label 'Typical Loss Amount' ;
    rdfs:comment 'Average monetary loss historically associated with this fraud type.' ;
    rdfs:domain ind:FraudType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalLossCurrency rdf:type rdf:Property ;
    rdfs:label 'Typical Loss Currency' ;
    rdfs:comment 'ISO 4217 currency code for the typical loss amount.' ;
    rdfs:domain ind:FraudType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudVelocityControlId rdf:type rdf:Property ;
    rdfs:label 'Fraud Velocity Control Id' ;
    rdfs:comment 'System-generated unique identifier for the velocity control configuration.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudVelocityControl .

ind:notificationTemplateId rdf:type rdf:Property ;
    rdfs:label 'Notification Template Id' ;
    rdfs:comment 'Reference to the template used for alerts generated by this control.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NotificationTemplate .

ind:applicableChannels rdf:type rdf:Property ;
    rdfs:label 'Applicable Channels' ;
    rdfs:comment 'Payment channels to which the control applies.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicablePaymentMethods rdf:type rdf:Property ;
    rdfs:label 'Applicable Payment Methods' ;
    rdfs:comment 'Payment instrument types covered by the control.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachAction rdf:type rdf:Property ;
    rdfs:label 'Breach Action' ;
    rdfs:comment 'Action taken when the threshold is exceeded: block transaction, flag for review, invoke step-up authentication, or generate an alert.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachCount rdf:type rdf:Property ;
    rdfs:label 'Breach Count' ;
    rdfs:comment 'Cumulative number of times the control has been breached since activation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective End Timestamp' ;
    rdfs:comment 'Date-time when the control expires; null for indefinite.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Start Timestamp' ;
    rdfs:comment 'Date-time when the control becomes effective.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fraudVelocityControlDescription rdf:type rdf:Property ;
    rdfs:label 'Fraud Velocity Control Description' ;
    rdfs:comment 'Free-form description of the control\'s purpose and business rationale.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudVelocityControlStatus rdf:type rdf:Property ;
    rdfs:label 'Fraud Velocity Control Status' ;
    rdfs:comment 'Current lifecycle status of the velocity control.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Code' ;
    rdfs:comment 'Three-letter ISO country code indicating the regulatory jurisdiction for the control.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastBreachTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Breach Timestamp' ;
    rdfs:comment 'Timestamp of the most recent occurrence where the control was breached.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ruleVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Version' ;
    rdfs:comment 'Version identifier for the control definition (e.g., v1.0, v2.1).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeEntity rdf:type rdf:Property ;
    rdfs:label 'Scope Entity' ;
    rdfs:comment 'Entity to which the velocity limit applies (e.g., individual cardholder, merchant, BIN, device, IP address, or channel).' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'Numeric limit that triggers the breach action; interpreted according to threshold_unit.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windowDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Window Duration Seconds' ;
    rdfs:comment 'Length of the rolling time window over which the control is evaluated, expressed in seconds.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactMethod rdf:type rdf:Property ;
    rdfs:label 'Contact Method' ;
    rdfs:comment 'Preferred contact channel for the watchlist entity used for notifications or escalations.' ;
    rdfs:domain ind:Watchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringLevel rdf:type rdf:Property ;
    rdfs:label 'Monitoring Level' ;
    rdfs:comment 'Intensity of monitoring applied to the entity (passive = observation only, active = heightened scrutiny, step_up = requires step-up authentication).' ;
    rdfs:domain ind:Watchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Business justification for placing the entity on the watchlist (e.g., high velocity, suspicious geography, known fraud pattern).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Planned date for the next manual review of the watchlist entry.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:watchlistSource rdf:type rdf:Property ;
    rdfs:label 'Watchlist Source' ;
    rdfs:comment 'Origin of the watchlist entry (internal risk team, external network advisory, law-enforcement notification).' ;
    rdfs:domain ind:Watchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistStatus rdf:type rdf:Property ;
    rdfs:label 'Watchlist Status' ;
    rdfs:comment 'Current lifecycle status of the watchlist entry.' ;
    rdfs:domain ind:Watchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:muleAccountId rdf:type rdf:Property ;
    rdfs:label 'Mule Account Id' ;
    rdfs:comment 'System-generated unique identifier for the mule account record.' ;
    rdfs:domain ind:MuleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionTaken rdf:type rdf:Property ;
    rdfs:label 'Action Taken' ;
    rdfs:comment 'Operational response applied to the mule account after detection.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address linked to the mule account for communication and investigation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number associated with the mule account, used for verification and outreach.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayName rdf:type rdf:Property ;
    rdfs:label 'Display Name' ;
    rdfs:comment 'Human-readable name associated with the mule account, as provided during onboarding or investigation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:muleAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Mule Account Status' ;
    rdfs:comment 'Current lifecycle state of the mule account within the fraud management process.' ;
    rdfs:domain ind:MuleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:muleCategory rdf:type rdf:Property ;
    rdfs:label 'Mule Category' ;
    rdfs:comment 'Indicates whether the mule is knowingly participating (witting), unaware (unwitting), or a repeat offender (established).' ;
    rdfs:domain ind:MuleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingStatus rdf:type rdf:Property ;
    rdfs:label 'Reporting Status' ;
    rdfs:comment 'Indicates whether a SAR has been filed, law-enforcement referral made, or no reporting required.' ;
    rdfs:domain ind:MuleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreBand rdf:type rdf:Property ;
    rdfs:label 'Risk Score Band' ;
    rdfs:comment 'Categorical bucket derived from the numeric risk score.' ;
    rdfs:domain ind:MuleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenizedAccountReference rdf:type rdf:Property ;
    rdfs:label 'Tokenized Account Reference' ;
    rdfs:comment 'Tokenized representation of the account number used by the mule, stored to protect the underlying PAN.' ;
    rdfs:domain ind:MuleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkFraudAdvisoryId rdf:type rdf:Property ;
    rdfs:label 'Network Fraud Advisory Id' ;
    rdfs:comment 'Unique surrogate identifier for the network fraud advisory record.' ;
    rdfs:domain ind:NetworkFraudAdvisory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advisoryDescription rdf:type rdf:Property ;
    rdfs:label 'Advisory Description' ;
    rdfs:comment 'Free-text details describing the nature of the fraud advisory.' ;
    rdfs:domain ind:NetworkFraudAdvisory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advisorySeverity rdf:type rdf:Property ;
    rdfs:label 'Advisory Severity' ;
    rdfs:comment 'Severity level assigned to the advisory indicating potential impact.' ;
    rdfs:domain ind:NetworkFraudAdvisory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advisorySeverityScore rdf:type rdf:Property ;
    rdfs:label 'Advisory Severity Score' ;
    rdfs:comment 'Numeric score representing the advisory\'s risk magnitude, used for internal prioritization.' ;
    rdfs:domain ind:NetworkFraudAdvisory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advisoryStatus rdf:type rdf:Property ;
    rdfs:label 'Advisory Status' ;
    rdfs:comment 'Current processing status of the advisory within the fraud system.' ;
    rdfs:domain ind:NetworkFraudAdvisory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advisoryType rdf:type rdf:Property ;
    rdfs:label 'Advisory Type' ;
    rdfs:comment 'Category of fraud advisory received from a card network or industry body.' ;
    rdfs:domain ind:NetworkFraudAdvisory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedEntityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Identifier' ;
    rdfs:comment 'Identifier of the affected entity (e.g., compromised BIN number, PAN range, merchant ID).' ;
    rdfs:domain ind:NetworkFraudAdvisory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedEntityType rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Type' ;
    rdfs:comment 'Type of entity impacted by the advisory (e.g., BIN, PAN, merchant, account).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'External Reference Number' ;
    rdfs:comment 'Reference number provided by the issuing network for traceability.' ;
    rdfs:domain ind:NetworkFraudAdvisory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalActionTaken rdf:type rdf:Property ;
    rdfs:label 'Internal Action Taken' ;
    rdfs:comment 'Action performed internally in response to the advisory.' ;
    rdfs:domain ind:NetworkFraudAdvisory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkName rdf:type rdf:Property ;
    rdfs:label 'Network Name' ;
    rdfs:comment 'Card network or industry body that issued the advisory.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'Date and time when the advisory was received by the fraud platform.' ;
    rdfs:domain ind:NetworkFraudAdvisory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:velocityBreachId rdf:type rdf:Property ;
    rdfs:label 'Velocity Breach Id' ;
    rdfs:comment 'System-generated unique identifier for the velocity control breach event.' ;
    rdfs:domain ind:VelocityBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:binNumber rdf:type rdf:Property ;
    rdfs:label 'Bin Number' ;
    rdfs:comment 'First six digits of the card number identifying the issuing bank.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breach Timestamp' ;
    rdfs:comment 'Date and time when the velocity breach was detected.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detectionEngine rdf:type rdf:Property ;
    rdfs:label 'Detection Engine' ;
    rdfs:comment 'Engine that evaluated the transaction – real-time rule engine, batch processor, or ML model.' ;
    rdfs:domain ind:VelocityBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityReference rdf:type rdf:Property ;
    rdfs:label 'Entity Reference' ;
    rdfs:comment 'System identifier of the entity (e.g., cardholder_id, merchant_id) that caused the breach.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:observedValue rdf:type rdf:Property ;
    rdfs:label 'Observed Value' ;
    rdfs:comment 'The actual count or monetary amount observed that exceeded the threshold.' ;
    rdfs:domain ind:VelocityBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:velocityBreachDescription rdf:type rdf:Property ;
    rdfs:label 'Velocity Breach Description' ;
    rdfs:comment 'Free-form notes describing the context or rationale of the breach.' ;
    rdfs:domain ind:VelocityBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Id' ;
    rdfs:comment 'Unique surrogate key for each beneficiary record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Beneficiary .

ind:accountCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Account Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Beneficiary account currency must be tied to the currency master for compliance and conversion accuracy.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:bankBicSwift rdf:type rdf:Property ;
    rdfs:label 'Bank Bic Swift' ;
    rdfs:comment 'SWIFT/BIC identifier of the beneficiary\'s bank.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Name' ;
    rdfs:comment 'Legal name of the beneficiary (individual or corporate).' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryStatus rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Status' ;
    rdfs:comment 'Overall status indicating whether the beneficiary is active, inactive, suspended, or closed.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryType rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Type' ;
    rdfs:comment 'Indicates whether the beneficiary is an individual, corporate, government, or nonprofit entity.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalBeneficiaryCode rdf:type rdf:Property ;
    rdfs:label 'External Beneficiary Code' ;
    rdfs:comment 'Identifier assigned to the beneficiary by external correspondent banks or partners.' ;
    rdfs:domain ind:Beneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPreferred rdf:type rdf:Property ;
    rdfs:label 'Is Preferred' ;
    rdfs:comment 'True if the beneficiary is marked as preferred for recurring cross-border payments.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPaymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Payment Timestamp' ;
    rdfs:comment 'Date and time of the most recent successful payment to this beneficiary.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conversionAuditId rdf:type rdf:Property ;
    rdfs:label 'Conversion Audit Id' ;
    rdfs:comment 'Unique identifier for the conversion audit record.' ;
    rdfs:domain ind:ConversionAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inputCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Input Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Audit of conversion inputs requires a foreign key to the currency master for validation and regulatory reporting.' ;
    rdfs:domain ind:ConversionAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:settlementInstructionId rdf:type rdf:Property ;
    rdfs:label 'Settlement Instruction Id' ;
    rdfs:comment 'Identifier of the settlement batch or instruction related to this conversion.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instruction .

ind:auditUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this audit record (e.g., after reprocessing).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:calculatedAmount rdf:type rdf:Property ;
    rdfs:label 'Calculated Amount' ;
    rdfs:comment 'Resulting amount after applying conversion rate and rounding.' ;
    rdfs:domain ind:ConversionAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationStatus rdf:type rdf:Property ;
    rdfs:label 'Calculation Status' ;
    rdfs:comment 'Outcome status of the conversion calculation.' ;
    rdfs:domain ind:ConversionAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientIp rdf:type rdf:Property ;
    rdfs:label 'Client Ip' ;
    rdfs:comment 'IP address of the client initiating the transaction (if captured).' ;
    rdfs:domain ind:ConversionAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionPnl rdf:type rdf:Property ;
    rdfs:label 'Conversion Pnl' ;
    rdfs:comment 'Profit or loss impact of the conversion on the company\'s FX P&L.' ;
    rdfs:domain ind:ConversionAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionRate rdf:type rdf:Property ;
    rdfs:label 'Conversion Rate' ;
    rdfs:comment 'FX rate applied for the conversion (target per unit of source).' ;
    rdfs:domain ind:ConversionAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Conversion Timestamp' ;
    rdfs:comment 'Timestamp when the currency conversion was performed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conversionType rdf:type rdf:Property ;
    rdfs:label 'Conversion Type' ;
    rdfs:comment 'Category of conversion operation.' ;
    rdfs:domain ind:ConversionAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineVersion rdf:type rdf:Property ;
    rdfs:label 'Engine Version' ;
    rdfs:comment 'Version of the conversion calculation engine or service.' ;
    rdfs:domain ind:ConversionAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputAmount rdf:type rdf:Property ;
    rdfs:label 'Input Amount' ;
    rdfs:comment 'Original monetary amount before conversion.' ;
    rdfs:domain ind:ConversionAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRateValidated rdf:type rdf:Property ;
    rdfs:label 'Is Rate Validated' ;
    rdfs:comment 'Indicates whether the applied FX rate passed compliance validation checks.' ;
    rdfs:domain ind:ConversionAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTestConversion rdf:type rdf:Property ;
    rdfs:label 'Is Test Conversion' ;
    rdfs:comment 'Indicates whether the conversion was performed in a test or sandbox environment.' ;
    rdfs:domain ind:ConversionAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateSource rdf:type rdf:Property ;
    rdfs:label 'Rate Source' ;
    rdfs:comment 'Identifier of the rate source (e.g., Bloomberg, internal feed, central bank).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rate Timestamp' ;
    rdfs:comment 'Timestamp when the FX rate was retrieved or published.' ;
    rdfs:domain ind:Fx ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rateValidationRule rdf:type rdf:Property ;
    rdfs:label 'Rate Validation Rule' ;
    rdfs:comment 'Name of the compliance rule applied for rate validation.' ;
    rdfs:domain ind:ConversionAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingMethod rdf:type rdf:Property ;
    rdfs:label 'Rounding Method' ;
    rdfs:comment 'Rounding algorithm applied to the converted amount.' ;
    rdfs:domain ind:Fx ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCurrency rdf:type rdf:Property ;
    rdfs:label 'Target Currency' ;
    rdfs:comment 'ISO 4217 currency code of the resulting amount.' ;
    rdfs:domain ind:ConversionAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondentBankId rdf:type rdf:Property ;
    rdfs:label 'Correspondent Bank Id' ;
    rdfs:comment 'Unique system-generated identifier for the correspondent bank record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrespondentBank .

ind:swiftBicId rdf:type rdf:Property ;
    rdfs:label 'Swift Bic Id' ;
    rdfs:comment 'Foreign key linking to reference.swift_bic. Business justification: BIC codes are centrally managed; linking enables validation and sanctions screening of correspondent banks.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SwiftBic .

ind:amlKycStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Kyc Status' ;
    rdfs:comment 'Current anti-money-laundering and know-your-customer compliance status of the bank.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDocumentation rdf:type rdf:Property ;
    rdfs:label 'Compliance Documentation' ;
    rdfs:comment 'Reference identifier or URL to the stored compliance documents (e.g., AML policies, contracts).' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactAddress rdf:type rdf:Property ;
    rdfs:label 'Contact Address' ;
    rdfs:comment 'Mailing address of the bank\'s primary office for correspondence.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondentBankName rdf:type rdf:Property ;
    rdfs:label 'Correspondent Bank Name' ;
    rdfs:comment 'Legal name of the correspondent bank.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondentFeeFixed rdf:type rdf:Property ;
    rdfs:label 'Correspondent Fee Fixed' ;
    rdfs:comment 'Flat fee charged per transaction, in the bank\'s settlement currency.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correspondentFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Correspondent Fee Percentage' ;
    rdfs:comment 'Variable fee expressed as a percentage of the transaction amount.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitUsd rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Usd' ;
    rdfs:comment 'Maximum credit exposure the fintech is permitted to have with the correspondent bank, expressed in US dollars.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ibanFormatSupported rdf:type rdf:Property ;
    rdfs:label 'Iban Format Supported' ;
    rdfs:comment 'Pattern or description of IBAN structures the bank can process (e.g., country-specific length).' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIbanSupported rdf:type rdf:Property ;
    rdfs:label 'Is Iban Supported' ;
    rdfs:comment 'Indicates whether the bank can receive or send payments using IBAN format.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSwiftEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Swift Enabled' ;
    rdfs:comment 'Indicates whether SWIFT messaging is supported for this bank.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTokenizationSupported rdf:type rdf:Property ;
    rdfs:label 'Is Tokenization Supported' ;
    rdfs:comment 'Indicates whether the bank participates in tokenization services for digital wallets.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nostroAccountCurrency rdf:type rdf:Property ;
    rdfs:label 'Nostro Account Currency' ;
    rdfs:comment 'Currency code of the nostro account (e.g., USD, EUR).' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nostroAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Nostro Account Number' ;
    rdfs:comment 'Bank account number held by the fintech in the correspondent bank for settlement purposes.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentCorridors rdf:type rdf:Property ;
    rdfs:label 'Payment Corridors' ;
    rdfs:comment 'Geographic or network corridors (e.g., US-EU, APAC-LATAM) the bank supports for cross-border payments.' ;
    rdfs:domain ind:CorrespondentBank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'Country or region whose financial regulations govern the correspondent relationship.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Settlement Cutoff Time' ;
    rdfs:comment 'Daily cut-off time (local bank time) after which transactions are processed in the next business day.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementMethod rdf:type rdf:Property ;
    rdfs:label 'Settlement Method' ;
    rdfs:comment 'Primary mechanism used for settling transactions with the correspondent bank.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedCurrencies rdf:type rdf:Property ;
    rdfs:label 'Supported Currencies' ;
    rdfs:comment 'Comma-separated list of ISO 4217 currency codes the bank can settle for.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Public website URL of the correspondent bank.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderFeeId rdf:type rdf:Property ;
    rdfs:label 'Cross Border Fee Id' ;
    rdfs:comment 'System-generated unique identifier for the cross-border fee record.' ;
    rdfs:domain ind:CrossBorderFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'Mechanism by which the fee is collected from the payer.' ;
    rdfs:domain ind:CrossBorderFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRegulation rdf:type rdf:Property ;
    rdfs:label 'Compliance Regulation' ;
    rdfs:comment 'Regulatory framework(s) applicable to this fee.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCurrency rdf:type rdf:Property ;
    rdfs:label 'Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 code of the currency in which the fee amount is expressed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCurrencyConversionRate rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Conversion Rate' ;
    rdfs:comment 'Rate used to convert fee_original_amount to fee_amount.' ;
    rdfs:domain ind:CrossBorderFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeDescription rdf:type rdf:Property ;
    rdfs:label 'Fee Description' ;
    rdfs:comment 'Free-form description of the fee purpose or context.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeEffectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fee Effective Timestamp' ;
    rdfs:comment 'Date-time when the fee became effective (e.g., when applied to the transaction).' ;
    rdfs:domain ind:CrossBorderFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:feeOriginalAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Original Amount' ;
    rdfs:comment 'Fee amount expressed in the transaction’s settlement currency before conversion.' ;
    rdfs:domain ind:CrossBorderFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeOriginalCurrency rdf:type rdf:Property ;
    rdfs:label 'Fee Original Currency' ;
    rdfs:comment 'Currency of the fee as originally charged before any conversion.' ;
    rdfs:domain ind:CrossBorderFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feePayer rdf:type rdf:Property ;
    rdfs:label 'Fee Payer' ;
    rdfs:comment 'Party responsible for paying the fee.' ;
    rdfs:domain ind:CrossBorderFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeQuantity rdf:type rdf:Property ;
    rdfs:label 'Fee Quantity' ;
    rdfs:comment 'Number of fee units applied; typically 1.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Fee Reference Code' ;
    rdfs:comment 'External reference code for the fee (e.g., ARN, SWIFT code).' ;
    rdfs:domain ind:CrossBorderFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeSettlementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fee Settlement Timestamp' ;
    rdfs:comment 'Date-time when the fee was settled with the correspondent bank or internal ledger.' ;
    rdfs:domain ind:CrossBorderFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Indicates whether the fee is subject to tax.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineSequence rdf:type rdf:Property ;
    rdfs:label 'Line Sequence' ;
    rdfs:comment 'Sequential order of the fee line within the transaction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'Timestamp when the fee reversal was processed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Current settlement state of the fee.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Tax amount applied to the fee, if taxable.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCurrency rdf:type rdf:Property ;
    rdfs:label 'Tax Currency' ;
    rdfs:comment 'Currency of the tax amount.' ;
    rdfs:domain ind:CrossBorderFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryPartyId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Party Id' ;
    rdfs:comment 'Identifier of the party receiving the funds.' ;
    rdfs:domain ind:CrossBorderPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:originCountryId rdf:type rdf:Property ;
    rdfs:label 'Origin Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Origin country is required for AML, sanctions, and reporting; linking to country master provides authoritative data.' ;
    rdfs:domain ind:CrossBorderPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:originCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Origin Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: Origin currency must be validated against the currency master for conversion and reporting.' ;
    rdfs:domain ind:CrossBorderPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:senderPartyId rdf:type rdf:Property ;
    rdfs:label 'Sender Party Id' ;
    rdfs:comment 'Identifier of the party (individual or organization) sending the funds.' ;
    rdfs:domain ind:CrossBorderPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:beneficiaryBankBic rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Bank Bic' ;
    rdfs:comment 'Bank Identifier Code of the beneficiary\'s financial institution.' ;
    rdfs:domain ind:Fx ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryIban rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Iban' ;
    rdfs:comment 'International Bank Account Number of the beneficiary\'s account.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackIndicator rdf:type rdf:Property ;
    rdfs:label 'Chargeback Indicator' ;
    rdfs:comment 'True if the payment resulted in a chargeback.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:convertedAmount rdf:type rdf:Property ;
    rdfs:label 'Converted Amount' ;
    rdfs:comment 'Monetary amount in the destination currency after applying the FX rate.' ;
    rdfs:domain ind:Fx ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossBorderPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Cross Border Payment Status' ;
    rdfs:comment 'Current lifecycle status of the cross-border payment.' ;
    rdfs:domain ind:CrossBorderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 code of the beneficiary\'s country.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Destination Currency Code' ;
    rdfs:comment 'ISO 4217 currency code of the amount received by the beneficiary.' ;
    rdfs:domain ind:CrossBorderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'Classification of the FX rate (e.g., spot, forward).' ;
    rdfs:domain ind:CrossBorderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateValidityEnd rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Validity End' ;
    rdfs:comment 'End of the time window during which the FX rate is valid.' ;
    rdfs:domain ind:CrossBorderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeRateValidityStart rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Validity Start' ;
    rdfs:comment 'Start of the time window during which the FX rate is valid.' ;
    rdfs:domain ind:CrossBorderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'ISO 4217 currency code of the fee amount.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxRate rdf:type rdf:Property ;
    rdfs:label 'Fx Rate' ;
    rdfs:comment 'Exchange rate applied to convert the original amount to the destination currency.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fxRateSource rdf:type rdf:Property ;
    rdfs:label 'Fx Rate Source' ;
    rdfs:comment 'Name or identifier of the rate feed provider (e.g., Bloomberg, Reuters).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxRateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fx Rate Timestamp' ;
    rdfs:comment 'Timestamp when the FX rate was sourced or locked for the transaction.' ;
