ind:schemeEventStatus rdf:type rdf:Property ;
    rdfs:label 'Scheme Event Status' ;
    rdfs:comment 'Lifecycle status of the event from creation to closure.' ;
    rdfs:domain ind:SchemeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableToDomestic rdf:type rdf:Property ;
    rdfs:label 'Applicable To Domestic' ;
    rdfs:comment 'True if the fee applies to domestic (same-country) transactions.' ;
