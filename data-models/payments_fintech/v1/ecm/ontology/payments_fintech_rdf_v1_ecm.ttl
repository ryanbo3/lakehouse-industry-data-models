ind:paymentRail rdf:type rdf:Property ;
    rdfs:label 'Payment Rail' ;
    rdfs:comment 'Network or scheme used to route the cross-border payment.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
