    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowEventReference rdf:type rdf:Property ;
    rdfs:label 'Workflow Event Reference' ;
    rdfs:comment 'Identifier of the workflow event that triggered the creation of the note.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantRiskProfileId rdf:type rdf:Property ;
    rdfs:label 'Merchant Risk Profile Id' ;
    rdfs:comment 'Unique surrogate key for each merchant risk profile record.' ;
