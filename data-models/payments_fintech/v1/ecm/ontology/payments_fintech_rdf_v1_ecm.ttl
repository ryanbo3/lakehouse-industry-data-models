    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:replenishmentCount rdf:type rdf:Property ;
    rdfs:label 'Replenishment Count' ;
    rdfs:comment 'Total number of times the key has been replenished.' ;
    rdfs:domain ind:HceCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replenishmentThreshold rdf:type rdf:Property ;
    rdfs:label 'Replenishment Threshold' ;
    rdfs:comment 'Number of remaining uses that triggers automatic key replenishment.' ;
    rdfs:domain ind:HceCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:instrumentBlockId rdf:type rdf:Property ;
    rdfs:label 'Instrument Block Id' ;
    rdfs:comment 'Unique surrogate identifier for each instrument block record.' ;
    rdfs:domain ind:InstrumentBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedTransactionTypes rdf:type rdf:Property ;
    rdfs:label 'Affected Transaction Types' ;
    rdfs:comment 'Comma-separated list of transaction types that the block restricts.' ;
    rdfs:domain ind:InstrumentBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockAmountLimit rdf:type rdf:Property ;
    rdfs:label 'Block Amount Limit' ;
    rdfs:comment 'Monetary ceiling that may still be processed under the block (e.g., limit for low-value transactions).' ;
    rdfs:domain ind:InstrumentBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockCategory rdf:type rdf:Property ;
    rdfs:label 'Block Category' ;
    rdfs:comment 'High-level grouping of the block used for reporting and analytics.' ;
