    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Token Lifecycle Event Id' ;
    rdfs:comment 'Surrogate primary key for the token lifecycle event record.' ;
