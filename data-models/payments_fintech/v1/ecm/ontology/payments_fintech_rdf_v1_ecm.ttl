    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalAccountCode rdf:type rdf:Property ;
    rdfs:label 'External Account Code' ;
    rdfs:comment 'Original identifier of the account in the external financial institution\'s system.' ;
    rdfs:domain ind:LinkedAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingMethod rdf:type rdf:Property ;
    rdfs:label 'Funding Method' ;
    rdfs:comment 'Method used to verify and link the external account for funding.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'Standardized international bank account identifier for cross-border linked accounts.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryFunding rdf:type rdf:Property ;
    rdfs:label 'Is Primary Funding' ;
    rdfs:comment 'Indicates whether this linked account is the default source for funding transactions.' ;
    rdfs:domain ind:LinkedAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTokenized rdf:type rdf:Property ;
    rdfs:label 'Is Tokenized' ;
    rdfs:comment 'Indicates whether the linked account details are stored as a tokenized value.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkedSince rdf:type rdf:Property ;
    rdfs:label 'Linked Since' ;
    rdfs:comment 'Date when the external account was first linked to the cardholder.' ;
    rdfs:domain ind:LinkedAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkedStatus rdf:type rdf:Property ;
    rdfs:label 'Linked Status' ;
    rdfs:comment 'Operational status of the linked account within the platform.' ;
    rdfs:domain ind:LinkedAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedUntil rdf:type rdf:Property ;
    rdfs:label 'Linked Until' ;
    rdfs:comment 'Date when the linked account was de-linked or became inactive (null if still active).' ;
    rdfs:domain ind:LinkedAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:routingNumberMasked rdf:type rdf:Property ;
    rdfs:label 'Routing Number Masked' ;
    rdfs:comment 'Masked routing number of the external account, showing only the last 4 digits.' ;
    rdfs:domain ind:LinkedAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenServiceProvider rdf:type rdf:Property ;
    rdfs:label 'Token Service Provider' ;
    rdfs:comment 'Name of the token service provider (TSP) that issued the token for this account.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCount rdf:type rdf:Property ;
    rdfs:label 'Transaction Count' ;
    rdfs:comment 'Total number of funding transactions executed against this linked account.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:panRecordId rdf:type rdf:Property ;
    rdfs:label 'Pan Record Id' ;
    rdfs:comment 'Surrogate primary key for the PAN record.' ;
    rdfs:domain ind:PanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:schemeId rdf:type rdf:Property ;
    rdfs:label 'Scheme Id' ;
    rdfs:comment 'Foreign key linking to network.scheme. Business justification: Required for card issuance and settlement: each PAN must be associated with its payment scheme (Visa, Mastercard) to route transactions and calculate interchange fees.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Scheme .

ind:amlScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Status' ;
    rdfs:comment 'Result of Anti-Money-Laundering screening for the PAN.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bin rdf:type rdf:Property ;
    rdfs:label 'Bin' ;
    rdfs:comment 'First six digits of the PAN identifying the issuing bank and card brand.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardScheme rdf:type rdf:Property ;
    rdfs:label 'Card Scheme' ;
    rdfs:comment 'Payment network brand associated with the PAN.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for transactions using this PAN. [ENUM-REF-CANDIDATE: USD|EUR|GBP|JPY|AUD|CAD|CHF|CNY|INR|BRL|... — promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Flag' ;
    rdfs:comment 'True if the PAN has been flagged for suspected fraudulent activity.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iin rdf:type rdf:Property ;
    rdfs:label 'Iin' ;
    rdfs:comment 'First eight digits of the PAN used for routing and issuer identification.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBankCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank Code' ;
    rdfs:comment 'Surrogate key linking to the bank that issued the PAN.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastFour rdf:type rdf:Property ;
    rdfs:label 'Last Four' ;
    rdfs:comment 'Last four digits of the PAN, commonly used for verification and customer service.' ;
    rdfs:domain ind:PanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maskedPan rdf:type rdf:Property ;
    rdfs:label 'Masked Pan' ;
    rdfs:comment 'Masked representation of the PAN (e.g., XXXX-XXXX-XXXX-1234) for human-readable displays.' ;
    rdfs:domain ind:PanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panFormat rdf:type rdf:Property ;
    rdfs:label 'Pan Format' ;
    rdfs:comment 'Indicates whether the PAN consists of only numeric characters or includes alphanumeric characters.' ;
    rdfs:domain ind:PanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panLength rdf:type rdf:Property ;
    rdfs:label 'Pan Length' ;
    rdfs:comment 'Number of digits in the PAN (typically 16, 15, or 19).' ;
    rdfs:domain ind:PanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:panStatus rdf:type rdf:Property ;
    rdfs:label 'Pan Status' ;
    rdfs:comment 'Operational status of the PAN within its lifecycle.' ;
    rdfs:domain ind:PanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panToken rdf:type rdf:Property ;
    rdfs:label 'Pan Token' ;
    rdfs:comment 'PCI-DSS compliant token that represents the PAN; never stores the clear PAN.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panType rdf:type rdf:Property ;
    rdfs:label 'Pan Type' ;
    rdfs:comment 'Indicates whether the PAN is a physical PAN (FPAN) or a device-generated token (DPAN).' ;
    rdfs:domain ind:PanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Token Expiry Date' ;
    rdfs:comment 'Date when the PAN token becomes invalid.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tokenizationMethod rdf:type rdf:Property ;
    rdfs:label 'Tokenization Method' ;
    rdfs:comment 'Technique used to derive the token from the clear PAN.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Total number of successful transactions processed for this PAN.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentCredentialId rdf:type rdf:Property ;
    rdfs:label 'Payment Credential Id' ;
    rdfs:comment 'Unique system-generated identifier for the payment credential record.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Payment Instrument Id' ;
    rdfs:comment 'Identifier of the payment instrument (e.g., PAN record) linked to this credential.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentInstrument .

ind:biometricEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Biometric Enabled Flag' ;
    rdfs:comment 'Indicates whether biometric authentication is enabled for this credential.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biometricType rdf:type rdf:Property ;
    rdfs:label 'Biometric Type' ;
    rdfs:comment 'Specific biometric modality used (if enabled).' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactlessNfcEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Contactless Nfc Enabled Flag' ;
    rdfs:comment 'True when NFC/contactless payments are permitted for this credential.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:credentialLabel rdf:type rdf:Property ;
    rdfs:label 'Credential Label' ;
    rdfs:comment 'Human-readable name or label assigned to the credential (e.g., "Primary Card Credential").' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Credential Source System' ;
    rdfs:comment 'Name of the operational system that originated the credential record (e.g., Digital Wallet Platform).' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialStatus rdf:type rdf:Property ;
    rdfs:label 'Credential Status' ;
    rdfs:comment 'Current operational state of the credential.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialType rdf:type rdf:Property ;
    rdfs:label 'Credential Type' ;
    rdfs:comment 'Category of the credential indicating the underlying payment instrument.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialVersion rdf:type rdf:Property ;
    rdfs:label 'Credential Version' ;
    rdfs:comment 'Monotonically increasing version number for the credential record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cvv2ValidationFlag rdf:type rdf:Property ;
    rdfs:label 'Cvv2 Validation Flag' ;
    rdfs:comment 'Indicates whether CVV2 validation is required for this credential.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cvvHashRef rdf:type rdf:Property ;
    rdfs:label 'Cvv Hash Ref' ;
    rdfs:comment 'Reference to the hashed CVV/CVC stored securely in the HSM.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpanReference rdf:type rdf:Property ;
    rdfs:label 'Dpan Reference' ;
    rdfs:comment 'Device Primary Account Number linked to this credential.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emvChipEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Emv Chip Enabled Flag' ;
    rdfs:comment 'Indicates whether EMV chip authentication is supported.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalCredentialCode rdf:type rdf:Property ;
    rdfs:label 'External Credential Code' ;
    rdfs:comment 'Identifier used by external systems (e.g., token service provider) to reference this credential.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsmKeyReference rdf:type rdf:Property ;
    rdfs:label 'Hsm Key Reference' ;
    rdfs:comment 'Identifier of the HSM key used to encrypt credential secrets.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceDate rdf:type rdf:Property ;
    rdfs:label 'Issuance Date' ;
    rdfs:comment 'Date when the credential was originally issued.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRotationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Rotation Timestamp' ;
    rdfs:comment 'Date-time when the credential secrets were last rotated.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:otpEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Otp Enabled Flag' ;
    rdfs:comment 'Indicates whether one-time-password (OTP) authentication is active.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otpLastSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Otp Last Sent Timestamp' ;
    rdfs:comment 'Date-time when the most recent OTP was generated/sent.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:panLinkageStatus rdf:type rdf:Property ;
    rdfs:label 'Pan Linkage Status' ;
    rdfs:comment 'Current relationship status between the credential and its PAN/DPAN.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinLastChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pin Last Change Timestamp' ;
    rdfs:comment 'Date-time when the PIN offset was last updated.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pinOffset rdf:type rdf:Property ;
    rdfs:label 'Pin Offset' ;
    rdfs:comment 'Encrypted PIN offset used for offline PIN verification (PCI-DSS).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaComplianceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sca Compliance Timestamp' ;
    rdfs:comment 'Date-time when SCA compliance was last verified.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:threeDsEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Three Ds Enrollment Status' ;
    rdfs:comment 'State of Strong Customer Authentication enrollment for this credential.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeDsMethod rdf:type rdf:Property ;
    rdfs:label 'Three Ds Method' ;
    rdfs:comment 'Method used for 3-DS challenge-response (e.g., OTP, biometric).' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderScaChallengeId rdf:type rdf:Property ;
    rdfs:label 'Cardholder Sca Challenge Id' ;
    rdfs:comment 'Globally unique identifier for the SCA challenge event.' ;
    rdfs:domain ind:CardholderScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionId rdf:type rdf:Property ;
    rdfs:label 'Transaction Id' ;
    rdfs:comment 'Identifier of the payment transaction associated with the SCA challenge.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:acsReference rdf:type rdf:Property ;
    rdfs:label 'Acs Reference' ;
    rdfs:comment 'Identifier of the ACS that generated the challenge.' ;
    rdfs:domain ind:CardholderScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationValue rdf:type rdf:Property ;
    rdfs:label 'Authentication Value' ;
    rdfs:comment 'Cryptographic authentication value returned by the ACS.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:challengeStatus rdf:type rdf:Property ;
    rdfs:label 'Challenge Status' ;
    rdfs:comment 'Current lifecycle state of the challenge.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Challenge Timestamp' ;
    rdfs:comment 'Exact time the challenge was issued to the cardholder.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:challengeType rdf:type rdf:Property ;
    rdfs:label 'Challenge Type' ;
    rdfs:comment 'Method used to deliver the SCA challenge to the cardholder.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eciIndicator rdf:type rdf:Property ;
    rdfs:label 'Eci Indicator' ;
    rdfs:comment 'Indicator of the authentication outcome used for liability shift.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'Reason why SCA was bypassed, if applicable.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSuccessful rdf:type rdf:Property ;
    rdfs:label 'Is Successful' ;
    rdfs:comment 'Indicates whether the challenge was successfully completed (true) or not (false).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:threeDsVersion rdf:type rdf:Property ;
    rdfs:label 'Three Ds Version' ;
    rdfs:comment 'Version of the 3-Domain Secure protocol applied.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderVelocityControlId rdf:type rdf:Property ;
    rdfs:label 'Cardholder Velocity Control Id' ;
    rdfs:comment 'Unique surrogate key for the velocity control record.' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mccId rdf:type rdf:Property ;
    rdfs:label 'Mcc Id' ;
    rdfs:comment 'Foreign key linking to reference.mcc. Business justification: Velocity controls are often MCC-based; a foreign key to reference.mcc enables rule management and risk scoring.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Mcc .

ind:cardholderVelocityControlStatus rdf:type rdf:Property ;
    rdfs:label 'Cardholder Velocity Control Status' ;
    rdfs:comment 'Current lifecycle status of the control.' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Payment channel to which the control applies (e.g., Card-Not-Present, Card-Present).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlSource rdf:type rdf:Property ;
    rdfs:label 'Control Source' ;
    rdfs:comment 'Origin of the control definition: issuer-set, cardholder self-service, or regulatory mandate.' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Category of the velocity control (e.g., spending limit, transaction count, MCC restriction).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlVersion rdf:type rdf:Property ;
    rdfs:label 'Control Version' ;
    rdfs:comment 'Version number of the control for change tracking.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailySpentAmount rdf:type rdf:Property ;
    rdfs:label 'Daily Spent Amount' ;
    rdfs:comment 'Total amount spent by the cardholder today under this control.' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Daily Transaction Count' ;
    rdfs:comment 'Number of transactions performed today under this control.' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enforcementPriority rdf:type rdf:Property ;
    rdfs:label 'Enforcement Priority' ;
    rdfs:comment 'Numeric priority for rule evaluation when multiple controls apply; lower numbers have higher priority.' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isExempted rdf:type rdf:Property ;
    rdfs:label 'Is Exempted' ;
    rdfs:comment 'Indicates if the cardholder is exempted from this control (e.g., corporate card).' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastEvaluatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Evaluated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent transaction evaluation against this control.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:limitAmount rdf:type rdf:Property ;
    rdfs:label 'Limit Amount' ;
    rdfs:comment 'Monetary amount limit for the control (e.g., daily spend cap).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limitCurrency rdf:type rdf:Property ;
    rdfs:label 'Limit Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the limit amount.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitPeriod rdf:type rdf:Property ;
    rdfs:label 'Limit Period' ;
    rdfs:comment 'Time window for the monetary limit.' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCountLimit rdf:type rdf:Property ;
    rdfs:label 'Transaction Count Limit' ;
    rdfs:comment 'Maximum number of transactions allowed in the defined period.' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:violationCount rdf:type rdf:Property ;
    rdfs:label 'Violation Count' ;
    rdfs:comment 'Cumulative count of times the control was violated.' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachNotificationId rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Id' ;
    rdfs:comment 'System-generated unique identifier for the breach notification record.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Breach notification handled by compliance officer employee; needed for breach response accountability.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:posTerminalId rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Id' ;
    rdfs:comment 'Foreign key linking to terminal.pos_terminal. Business justification: Data breach notifications must identify the terminal where the breach occurred for incident response and regulator reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosTerminal .

ind:affectedDataCategories rdf:type rdf:Property ;
    rdfs:label 'Affected Data Categories' ;
    rdfs:comment 'Comma-separated list of data categories compromised (e.g., PAN, personal email, authentication credentials).' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSystems rdf:type rdf:Property ;
    rdfs:label 'Affected Systems' ;
    rdfs:comment 'List of internal systems, applications, or services impacted by the breach.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardReportDate rdf:type rdf:Property ;
    rdfs:label 'Board Report Date' ;
    rdfs:comment 'Date the breach was formally reported to the board.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:breachSource rdf:type rdf:Property ;
    rdfs:label 'Breach Source' ;
    rdfs:comment 'Origin of the breach (e.g., internal employee, external attacker, third-party vendor).' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachStatus rdf:type rdf:Property ;
    rdfs:label 'Breach Status' ;
    rdfs:comment 'Current lifecycle status of the breach investigation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataLossIndicator rdf:type rdf:Property ;
    rdfs:label 'Data Loss Indicator' ;
    rdfs:comment 'True if data was confirmed to be exfiltrated or accessed without authorization.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discovery Timestamp' ;
    rdfs:comment 'Exact date and time when the security incident was first discovered.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:encryptionStatusAtTime rdf:type rdf:Property ;
    rdfs:label 'Encryption Status At Time' ;
    rdfs:comment 'Encryption state of the affected data at the moment of breach.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedCardholderCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Cardholder Count' ;
    rdfs:comment 'Estimated number of individual cardholders whose data was impacted.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedMerchantCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Merchant Count' ;
    rdfs:comment 'Estimated number of merchants affected by the breach.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isReportedToBoard rdf:type rdf:Property ;
    rdfs:label 'Is Reported To Board' ;
    rdfs:comment 'Indicates whether the breach has been escalated to the board of directors.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date on which the regulator (or required authority) was formally notified.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'Channel used to notify affected individuals or regulators.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationTrigger rdf:type rdf:Property ;
    rdfs:label 'Notification Trigger' ;
    rdfs:comment 'Regulatory or policy trigger that initiates the breach notification (e.g., GDPR 72-hour rule, state breach law, PCI DSS Requirement 12.10).' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorNotified rdf:type rdf:Property ;
    rdfs:label 'Regulator Notified' ;
    rdfs:comment 'Regulatory authority that was notified about the breach.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationActionSummary rdf:type rdf:Property ;
    rdfs:label 'Remediation Action Summary' ;
    rdfs:comment 'High-level description of actions taken to contain and remediate the breach.' ;
    rdfs:domain ind:BreachNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceAmlScreeningResultId rdf:type rdf:Property ;
    rdfs:label 'Compliance Aml Screening Result Id' ;
    rdfs:comment 'System-generated unique identifier for each AML screening result record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceAmlScreeningResult .

ind:digitalWalletId rdf:type rdf:Property ;
    rdfs:label 'Digital Wallet Id' ;
    rdfs:comment 'Foreign key linking to wallet.digital_wallet. Business justification: Regulatory AML screening reports are generated per wallet account; linking enables reporting and audit of wallet-specific AML outcomes.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalWallet .

ind:regulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_obligation. Business justification: AML screening results are governed by a regulatory obligation; linking enables obligation-centric reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:requestId rdf:type rdf:Property ;
    rdfs:label 'Request Id' ;
    rdfs:comment 'Foreign key linking to gateway.gateway_request. Business justification: AML screening result must be traceable to the originating gateway request for audit and regulatory reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Request .

ind:analystOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Analyst Override Flag' ;
    rdfs:comment 'Indicates whether an analyst manually overrode the automated disposition.' ;
    rdfs:domain ind:ComplianceAmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:analystOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Analyst Override Reason' ;
    rdfs:comment 'Free-text explanation provided by the analyst for the override.' ;
    rdfs:domain ind:ComplianceAmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceAmlScreeningResultStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Aml Screening Result Status' ;
    rdfs:comment 'Current lifecycle status of the screening result record.' ;
    rdfs:domain ind:ComplianceAmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerName rdf:type rdf:Property ;
    rdfs:label 'Customer Name' ;
    rdfs:comment 'Legal full name of the individual associated with the screened entity.' ;
    rdfs:domain ind:ComplianceAmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Type of business entity that was screened.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSarRequired rdf:type rdf:Property ;
    rdfs:label 'Is Sar Required' ;
    rdfs:comment 'Indicates whether a Suspicious Activity Report (SAR) must be filed.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStrRequired rdf:type rdf:Property ;
    rdfs:label 'Is Str Required' ;
    rdfs:comment 'Indicates whether a Suspicious Transaction Report (STR) must be filed.' ;
    rdfs:domain ind:ComplianceAmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchType rdf:type rdf:Property ;
    rdfs:label 'Match Type' ;
    rdfs:comment 'Category of data element that triggered a match during screening.' ;
    rdfs:domain ind:ComplianceAmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarFilingStatus rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Status' ;
    rdfs:comment 'Current status of the SAR filing process.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarFilingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Timestamp' ;
    rdfs:comment 'Date and time when the SAR was filed, if applicable.' ;
    rdfs:domain ind:ComplianceAmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:screeningEngine rdf:type rdf:Property ;
    rdfs:label 'Screening Engine' ;
    rdfs:comment 'Name of the AML screening engine or vendor used (e.g., World-Check, LexisNexis).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningRuleVersion rdf:type rdf:Property ;
    rdfs:label 'Screening Rule Version' ;
    rdfs:comment 'Version identifier of the rule set applied during the screening.' ;
    rdfs:domain ind:ComplianceAmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceModule rdf:type rdf:Property ;
    rdfs:label 'Source Module' ;
    rdfs:comment 'Specific module or component within the source system that executed the screening.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strFilingStatus rdf:type rdf:Property ;
    rdfs:label 'Str Filing Status' ;
    rdfs:comment 'Current status of the STR filing process.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strFilingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Str Filing Timestamp' ;
    rdfs:comment 'Date and time when the STR was filed, if applicable.' ;
    rdfs:domain ind:ComplianceAmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:typology rdf:type rdf:Property ;
    rdfs:label 'Typology' ;
    rdfs:comment 'AML typology or pattern identified (e.g., structuring, smurfing, terrorist financing).' ;
    rdfs:domain ind:ComplianceAmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestationId rdf:type rdf:Property ;
    rdfs:label 'Attestation Id' ;
    rdfs:comment 'Unique system-generated identifier for the compliance attestation record.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gatewayApiCredentialId rdf:type rdf:Property ;
    rdfs:label 'Gateway Api Credential Id' ;
    rdfs:comment 'Foreign key linking to gateway.api_credential. Business justification: Regulatory attestation requires certifying each API credential used for gateway integration meets PCI-DSS and security standards.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GatewayApiCredential .

ind:attachedDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Attached Document Url' ;
    rdfs:comment 'Link to the PDF or supporting documentation for the attestation.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestationNumber rdf:type rdf:Property ;
    rdfs:label 'Attestation Number' ;
    rdfs:comment 'Business-friendly reference number for the attestation, used in reporting and audit trails.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestationStatus rdf:type rdf:Property ;
    rdfs:label 'Attestation Status' ;
    rdfs:comment 'Current lifecycle state of the attestation.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestationType rdf:type rdf:Property ;
    rdfs:label 'Attestation Type' ;
    rdfs:comment 'Category of regulatory or internal compliance attestation (e.g., PCI DSS Attestation of Compliance, SOX Section 302).' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestingPartyName rdf:type rdf:Property ;
    rdfs:label 'Attesting Party Name' ;
    rdfs:comment 'Full legal name of the individual or entity signing the attestation.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestingPartyRole rdf:type rdf:Property ;
    rdfs:label 'Attesting Party Role' ;
    rdfs:comment 'Role of the attesting party within the organization.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlOwner rdf:type rdf:Property ;
    rdfs:label 'Control Owner' ;
    rdfs:comment 'Name of the individual or team that owns the compliance control covered by the attestation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureReference rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Reference' ;
    rdfs:comment 'Pointer (e.g., URL or hash) to the stored digital signature for the attestation.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementPenaltyEstimate rdf:type rdf:Property ;
    rdfs:label 'Enforcement Penalty Estimate' ;
    rdfs:comment 'Monetary estimate of potential penalties if the attestation were found non-compliant.' ;
    rdfs:domain ind:Attestation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date when the attestation was last reviewed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewDecision rdf:type rdf:Property ;
    rdfs:label 'Review Decision' ;
    rdfs:comment 'Outcome of the review process.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Risk level associated with the attestation based on compliance exposure.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCaseId rdf:type rdf:Property ;
    rdfs:label 'Compliance Case Id' ;
    rdfs:comment 'Unique identifier for the compliance_compliance_case data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceCase .

ind:assignedOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Officer Employee Id' ;
    rdfs:comment 'Identifier of the compliance officer responsible for the case.' ;
    rdfs:domain ind:ComplianceCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryComplianceMerchantId rdf:type rdf:Property ;
    rdfs:label 'Primary Compliance Merchant Id' ;
    rdfs:comment 'Identifier of the merchant associated with the case, if applicable.' ;
    rdfs:domain ind:ComplianceCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Merchant .

ind:primaryComplianceTransactionId rdf:type rdf:Property ;
    rdfs:label 'Primary Compliance Transaction Id' ;
    rdfs:comment 'Identifier of the transaction that prompted the case, if applicable.' ;
    rdfs:domain ind:ComplianceCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:riskCaseId rdf:type rdf:Property ;
    rdfs:label 'Risk Case Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_case. Business justification: Compliance investigations often originate from a risk case; linking preserves the provenance of the compliance case.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskCase .

ind:actionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Action Timestamp' ;
    rdfs:comment 'Timestamp when the compliance action was executed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:caseCategory rdf:type rdf:Property ;
    rdfs:label 'Case Category' ;
    rdfs:comment 'High-level grouping of the case (e.g., regulatory, operational, conduct).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Business identifier assigned to the case for tracking and reference.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseSeverity rdf:type rdf:Property ;
    rdfs:label 'Case Severity' ;
    rdfs:comment 'Severity rating reflecting potential impact.' ;
    rdfs:domain ind:ComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle status of the case.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseSubtype rdf:type rdf:Property ;
    rdfs:label 'Case Subtype' ;
    rdfs:comment 'More granular classification within the main category.' ;
    rdfs:domain ind:ComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseTags rdf:type rdf:Property ;
    rdfs:label 'Case Tags' ;
    rdfs:comment 'Comma-separated list of user-defined tags for search and categorisation.' ;
    rdfs:domain ind:ComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Category of the case such as AML, sanctions, PCI, GDPR, conduct, fraud, risk, or other. [ENUM-REF-CANDIDATE: AML|sanctions|PCI|GDPR|conduct|fraud|risk|other — promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceActionTaken rdf:type rdf:Property ;
    rdfs:label 'Compliance Action Taken' ;
    rdfs:comment 'Description of the remedial or enforcement action performed.' ;
    rdfs:domain ind:ComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCaseDescription rdf:type rdf:Property ;
    rdfs:label 'Compliance Case Description' ;
    rdfs:comment 'Free-form narrative describing the issue, findings, and context.' ;
    rdfs:domain ind:ComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOfficerNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Notes' ;
    rdfs:comment 'Notes entered by the compliance officer during investigation.' ;
    rdfs:domain ind:ComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'Enterprise data classification applied to the case record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceLogReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Log Reference' ;
    rdfs:comment 'Reference to the evidence log or repository containing supporting documents.' ;
    rdfs:domain ind:ComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'Identifier assigned by an external regulator or reporting body.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConfidential rdf:type rdf:Property ;
    rdfs:label 'Is Confidential' ;
    rdfs:comment 'Flag indicating whether the case contains confidential information requiring restricted handling.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEscalated rdf:type rdf:Property ;
    rdfs:label 'Is Escalated' ;
    rdfs:comment 'Flag indicating the case was escalated to higher authority.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFalsePositive rdf:type rdf:Property ;
    rdfs:label 'Is False Positive' ;
    rdfs:comment 'Flag indicating the case was determined to be a false positive.' ;
    rdfs:domain ind:ComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opened Timestamp' ;
    rdfs:comment 'Timestamp when the case was initially opened.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Regulation or standard governing the case.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportFiled rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Filed' ;
    rdfs:comment 'Indicates whether a required regulatory report has been filed.' ;
    rdfs:domain ind:ComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportFilingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Report Filing Timestamp' ;
    rdfs:comment 'Timestamp when the regulatory report was filed.' ;
    rdfs:domain ind:ComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Result of the case after investigation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Timestamp when the case resolution was recorded.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceTrigger rdf:type rdf:Property ;
    rdfs:label 'Source Trigger' ;
    rdfs:comment 'Origin that triggered the creation of the case.' ;
    rdfs:domain ind:ComplianceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlId rdf:type rdf:Property ;
    rdfs:label 'Control Id' ;
    rdfs:comment 'Unique system-generated identifier for the compliance control.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Control .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Control ownership assigned to a specific employee; needed for control accountability reports.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ownerOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Owner Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Control ownership tied to org unit; needed for departmental responsibility reporting.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:auditTrail rdf:type rdf:Property ;
    rdfs:label 'Audit Trail' ;
    rdfs:comment 'Reference to audit log entries related to the control.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlCode rdf:type rdf:Property ;
    rdfs:label 'Control Code' ;
    rdfs:comment 'Unique business code used to reference the control across systems.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlDescription rdf:type rdf:Property ;
    rdfs:label 'Control Description' ;
    rdfs:comment 'Detailed description of the control\'s purpose and scope.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlName rdf:type rdf:Property ;
    rdfs:label 'Control Name' ;
    rdfs:comment 'Human-readable name of the compliance control.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlScope rdf:type rdf:Property ;
    rdfs:label 'Control Scope' ;
    rdfs:comment 'Business area or process that the control applies to.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlStatus rdf:type rdf:Property ;
    rdfs:label 'Control Status' ;
    rdfs:comment 'Current lifecycle status of the control.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticality rdf:type rdf:Property ;
    rdfs:label 'Criticality' ;
    rdfs:comment 'Criticality level of the control for business continuity.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceCollected rdf:type rdf:Property ;
    rdfs:label 'Evidence Collected' ;
    rdfs:comment 'True if required evidence has been collected for the latest assessment.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceRequired rdf:type rdf:Property ;
    rdfs:label 'Evidence Required' ;
    rdfs:comment 'Description of the evidence needed to demonstrate control execution.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceUrl rdf:type rdf:Property ;
    rdfs:label 'Evidence Url' ;
    rdfs:comment 'Link to the stored evidence artifact.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'How often the control is performed or reviewed.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAutomated rdf:type rdf:Property ;
    rdfs:label 'Is Automated' ;
    rdfs:comment 'True if the control is performed automatically by systems.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKeyControl rdf:type rdf:Property ;
    rdfs:label 'Is Key Control' ;
    rdfs:comment 'Indicates whether the control is considered a key control for regulatory reporting.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isManual rdf:type rdf:Property ;
    rdfs:label 'Is Manual' ;
    rdfs:comment 'True if the control requires manual execution.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Date' ;
    rdfs:comment 'Date of the most recent assessment of the control.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAssessmentResult rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Result' ;
    rdfs:comment 'Outcome of the most recent control assessment.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAssessmentDue rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due' ;
    rdfs:comment 'Planned date for the next control assessment.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryRequirementCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Code' ;
    rdfs:comment 'Identifier of the specific regulatory requirement mapped to this control.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationAction rdf:type rdf:Property ;
    rdfs:label 'Remediation Action' ;
    rdfs:comment 'Planned action to address control deficiencies.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of the remediation effort.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Comma-separated tags for categorizing the control (e.g., finance, security, privacy).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingMethodology rdf:type rdf:Property ;
    rdfs:label 'Testing Methodology' ;
    rdfs:comment 'Method used to test the effectiveness of the control.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceKycVerificationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Kyc Verification Id' ;
    rdfs:comment 'Unique identifier for the KYC verification record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceKycVerification .

ind:kycDocumentTypeId rdf:type rdf:Property ;
    rdfs:label 'Kyc Document Type Id' ;
    rdfs:comment 'Foreign key linking to reference.kyc_document_type. Business justification: Connects KYC verification document type to reference catalog for validation and audit trails.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KycDocumentType .

ind:merchantIntegrationId rdf:type rdf:Property ;
    rdfs:label 'Merchant Integration Id' ;
    rdfs:comment 'Foreign key linking to gateway.merchant_integration. Business justification: KYC verification outcome is tied to the specific merchant integration configuration used during onboarding.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchantIntegration .

ind:sanctionsCheckId rdf:type rdf:Property ;
    rdfs:label 'Sanctions Check Id' ;
    rdfs:comment 'Foreign key linking to compliance.sanctions_check. Business justification: KYC verification references the sanctions check performed for the same entity; linking provides audit trail.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SanctionsCheck .

ind:settlementParticipantId rdf:type rdf:Property ;
    rdfs:label 'Settlement Participant Id' ;
    rdfs:comment 'Foreign key linking to settlement.participant. Business justification: KYC verification records must be linked to the settlement participant (bank) they pertain to for AML compliance reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Participant .

ind:amlScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Result' ;
    rdfs:comment 'Result of AML screening for the party.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cddClassification rdf:type rdf:Property ;
    rdfs:label 'Cdd Classification' ;
    rdfs:comment 'Indicates whether standard (CDD) or enhanced (EDD) due diligence was applied.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Document Expiry Date' ;
    rdfs:comment 'Expiration date of the identity document.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentIssueDate rdf:type rdf:Property ;
    rdfs:label 'Document Issue Date' ;
    rdfs:comment 'Date the identity document was issued.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentIssuingCountry rdf:type rdf:Property ;
    rdfs:label 'Document Issuing Country' ;
    rdfs:comment 'Three-letter ISO country code of the issuing authority.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether the verification record is currently active.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycEntityType rdf:type rdf:Property ;
    rdfs:label 'Kyc Entity Type' ;
    rdfs:comment 'Classification of the party being verified.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactType rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Type' ;
    rdfs:comment 'Method of primary contact used for KYC communication.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Provider Reference Code' ;
    rdfs:comment 'Reference identifier assigned by the verification provider.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reVerificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Re Verification Due Date' ;
    rdfs:comment 'Date by which the KYC must be refreshed or re-verified.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsCheckResult rdf:type rdf:Property ;
    rdfs:label 'Sanctions Check Result' ;
    rdfs:comment 'Result of OFAC/SDN sanctions screening.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Verification Outcome' ;
    rdfs:comment 'Result of the verification after processing.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentRecordId rdf:type rdf:Property ;
    rdfs:label 'Consent Record Id' ;
    rdfs:comment 'System-generated unique identifier for each consent record.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Consent record creation logged by employee; needed for data governance audit.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:partyId rdf:type rdf:Property ;
    rdfs:label 'Party Id' ;
    rdfs:comment 'Unique identifier of the data subject (cardholder or merchant) who gave the consent.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:consentTextHash rdf:type rdf:Property ;
    rdfs:label 'Consent Text Hash' ;
    rdfs:comment 'Cryptographic hash of the consent text version to ensure integrity and support audit.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'Version string of the consent text to support change management and re-consent tracking.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProcessingPurpose rdf:type rdf:Property ;
    rdfs:label 'Data Processing Purpose' ;
    rdfs:comment 'Narrative description of why the data is being processed under this consent.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Days' ;
    rdfs:comment 'Number of days the data may be retained after consent, as defined by policy.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geoRegion rdf:type rdf:Property ;
    rdfs:label 'Geo Region' ;
    rdfs:comment 'Higher-level region or jurisdiction (e.g., EU, APAC) associated with the consent capture.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'ISO 639-1 language code of the consent text presented to the data subject.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawfulBasis rdf:type rdf:Property ;
    rdfs:label 'Lawful Basis' ;
    rdfs:comment 'Legal justification for processing under GDPR/CCPA (e.g., consent, contract, legal obligation, legitimate interest).' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyType rdf:type rdf:Property ;
    rdfs:label 'Party Type' ;
    rdfs:comment 'Indicates whether the consent was provided by a cardholder (consumer) or a merchant (business).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconsentDueDate rdf:type rdf:Property ;
    rdfs:label 'Reconsent Due Date' ;
    rdfs:comment 'Date by which the data subject must provide renewed consent, if required.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconsentRequired rdf:type rdf:Property ;
    rdfs:label 'Reconsent Required' ;
    rdfs:comment 'Indicates whether a new consent must be obtained due to regulatory or policy changes.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scope rdf:type rdf:Property ;
    rdfs:label 'Scope' ;
    rdfs:comment 'Describes the data processing activities covered by the consent (e.g., marketing, analytics, third-party sharing, risk assessment).' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Free-text reason provided by the data subject for withdrawing consent.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Control Assessment Id' ;
    rdfs:comment 'System-generated unique identifier for each control assessment record.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assessor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Assessment performed by an employee; required for audit of control testing.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentCycle rdf:type rdf:Property ;
    rdfs:label 'Assessment Cycle' ;
    rdfs:comment 'Frequency with which the control is assessed.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'Calendar date on which the assessment was performed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Assessment Outcome' ;
    rdfs:comment 'Overall pass/fail result of the control assessment.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Assessment Period' ;
    rdfs:comment 'Fiscal or calendar period the assessment covers (e.g., Q1-2023).' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assessment Timestamp' ;
    rdfs:comment 'Exact date-time (with timezone) when the assessment activity occurred.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assessorRole rdf:type rdf:Property ;
    rdfs:label 'Assessor Role' ;
    rdfs:comment 'Role or function of the assessor within the assessment process.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference to the detailed audit log for this assessment.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Control Assessment Status' ;
    rdfs:comment 'Current operational status of the assessment record.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlCategory rdf:type rdf:Property ;
    rdfs:label 'Control Category' ;
    rdfs:comment 'Regulatory or framework category to which the control belongs.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlEffectivenessScore rdf:type rdf:Property ;
    rdfs:label 'Control Effectiveness Score' ;
    rdfs:comment 'Numeric score (0-100) representing the assessed effectiveness of the control.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Indicates whether an exception to the control was granted.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionReason rdf:type rdf:Property ;
    rdfs:label 'Exception Reason' ;
    rdfs:comment 'Explanation for why an exception was allowed.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingSeverity rdf:type rdf:Property ;
    rdfs:label 'Finding Severity' ;
    rdfs:comment 'Severity rating assigned to any deficiency identified during the assessment.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Status' ;
    rdfs:comment 'Current lifecycle status of the assessment record.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Target date by which remediation must be completed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationRequired rdf:type rdf:Property ;
    rdfs:label 'Remediation Required' ;
    rdfs:comment 'Indicates whether corrective action is required to address a finding.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testingApproach rdf:type rdf:Property ;
    rdfs:label 'Testing Approach' ;
    rdfs:comment 'Methodology used to test the control (e.g., walkthrough, sampling, automated scan).' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctfControlId rdf:type rdf:Property ;
    rdfs:label 'Ctf Control Id' ;
    rdfs:comment 'System-generated unique identifier for the Counter-Terrorism Financing control record.' ;
    rdfs:domain ind:CtfControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliesToChannel rdf:type rdf:Property ;
    rdfs:label 'Applies To Channel' ;
    rdfs:comment 'Payment channels (e.g., online, POS) where the control is enforced.' ;
    rdfs:domain ind:CtfControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToTransactionType rdf:type rdf:Property ;
    rdfs:label 'Applies To Transaction Type' ;
    rdfs:comment 'Transaction types to which the control is applied.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Notes' ;
    rdfs:comment 'Free-form notes capturing audit observations or change rationale.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'Regulatory framework(s) that mandate the control.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Control Owner Department' ;
    rdfs:comment 'Organizational department that owns the control.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctfControlDescription rdf:type rdf:Property ;
    rdfs:label 'Ctf Control Description' ;
    rdfs:comment 'Detailed narrative describing the purpose, scope, and mechanics of the CTF control.' ;
    rdfs:domain ind:CtfControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctfControlStatus rdf:type rdf:Property ;
    rdfs:label 'Ctf Control Status' ;
    rdfs:comment 'Current lifecycle status of the control.' ;
    rdfs:domain ind:CtfControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Rating' ;
    rdfs:comment 'Quantitative rating (0-1) of how effective the control is, based on internal assessments.' ;
    rdfs:domain ind:CtfControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fatfRecommendation rdf:type rdf:Property ;
    rdfs:label 'Fatf Recommendation' ;
    rdfs:comment 'Specific FATF recommendation number (e.g., Recommendation 10) that the control implements.' ;
    rdfs:domain ind:CtfControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether the control is mandatory under regulatory requirements.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportingRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Requirement' ;
    rdfs:comment 'Specific reporting obligation (e.g., SAR, STR) linked to the control.' ;
    rdfs:domain ind:CtfControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Days' ;
    rdfs:comment 'Number of days between scheduled reviews of the control.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Technical description of the rule logic (e.g., pseudocode or reference to model version).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationRequestId rdf:type rdf:Property ;
    rdfs:label 'Examination Request Id' ;
    rdfs:comment 'Unique system-generated identifier for the regulatory examination request.' ;
    rdfs:domain ind:ExaminationRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Internal Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Examination request owned by internal employee; needed for case management.' ;
    rdfs:domain ind:ExaminationRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complianceArea rdf:type rdf:Property ;
    rdfs:label 'Compliance Area' ;
    rdfs:comment 'Regulatory domain to which the examination pertains.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentsProvided rdf:type rdf:Property ;
    rdfs:label 'Documents Provided' ;
    rdfs:comment 'List or description of the documents submitted in response to the request.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Reason for escalation, if applicable.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
