ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason provided for terminating the membership agreement.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeParameterId rdf:type rdf:Property ;
    rdfs:label 'Scheme Parameter Id' ;
    rdfs:comment 'Unique surrogate identifier for each scheme parameter record.' ;
    rdfs:domain ind:SchemeParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliesToCardType rdf:type rdf:Property ;
    rdfs:label 'Applies To Card Type' ;
    rdfs:comment 'Card product types to which the parameter is applicable.' ;
    rdfs:domain ind:SchemeParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToMcc rdf:type rdf:Property ;
    rdfs:label 'Applies To Mcc' ;
    rdfs:comment 'Four-digit MCC to which the parameter is limited; null if not MCC-specific.' ;
