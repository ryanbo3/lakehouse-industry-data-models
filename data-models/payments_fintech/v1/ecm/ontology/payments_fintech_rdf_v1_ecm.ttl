    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Tracks the employee account manager responsible for each cardholder account; essential for oversight, risk monitoring, and regulatory audit.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:paymentProductId rdf:type rdf:Property ;
