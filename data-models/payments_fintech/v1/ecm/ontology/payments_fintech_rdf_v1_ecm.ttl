ind:isoMessageTypeId rdf:type rdf:Property ;
    rdfs:label 'Iso Message Type Id' ;
    rdfs:comment 'Foreign key linking to reference.iso_message_type. Business justification: iso_message_field belongs to a single iso_message_type; adding iso_message_type_id normalises the relationship and removes the redundant string list.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IsoMessageType .

ind:dataType rdf:type rdf:Property ;
    rdfs:label 'Data Type' ;
    rdfs:comment 'Technical data type of the field value.' ;
    rdfs:domain ind:IsoMessageField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldCategory rdf:type rdf:Property ;
    rdfs:label 'Field Category' ;
    rdfs:comment 'High-level category of the field\'s business purpose.' ;
    rdfs:domain ind:IsoMessageField ;
    rdf:type owl:DatatypeProperty ;
