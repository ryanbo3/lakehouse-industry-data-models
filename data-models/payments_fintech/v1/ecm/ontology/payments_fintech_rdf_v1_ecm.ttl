ind:rtpStatus rdf:type rdf:Property ;
    rdfs:label 'Rtp Status' ;
    rdfs:comment 'Current processing status of the RTP payment.' ;
    rdfs:domain ind:RtpPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stpIndicator rdf:type rdf:Property ;
    rdfs:label 'Stp Indicator' ;
    rdfs:comment 'True if the payment was processed end-to-end without manual intervention.' ;
