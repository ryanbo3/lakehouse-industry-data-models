    rdfs:comment 'JSON or structured text describing the step-by-step provisioning flow for tokens.' ;
    rdfs:domain ind:IssuerWalletConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redPathThreshold rdf:type rdf:Property ;
    rdfs:label 'Red Path Threshold' ;
    rdfs:comment 'Risk score percentage above which transactions follow the red (high-risk) path.' ;
    rdfs:domain ind:IssuerWalletConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepUpAuthRequired rdf:type rdf:Property ;
