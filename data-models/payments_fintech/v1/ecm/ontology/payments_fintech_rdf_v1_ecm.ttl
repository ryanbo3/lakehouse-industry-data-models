ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Category of the program (e.g., rewards, Buy-Now-Pay-Later, premium tier, co-brand, loyalty).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Reward Points Balance' ;
    rdfs:comment 'Current accumulated reward points for the cardholder within this program.' ;
    rdfs:domain ind:ProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sanctionsScreenedFlag rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screened Flag' ;
    rdfs:comment 'True if the cardholder was screened against sanctions lists (OFAC, UN) at enrollment.' ;
    rdfs:domain ind:ProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statusChangeReason rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason' ;
    rdfs:comment 'Free-text explanation for the most recent status transition.' ;
    rdfs:domain ind:ProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'Identifier of the internal user or service that created the enrollment.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipId rdf:type rdf:Property ;
