    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isComplianceRule rdf:type rdf:Property ;
    rdfs:label 'Is Compliance Rule' ;
    rdfs:comment 'Indicates whether the rule enforces regulatory compliance.' ;
