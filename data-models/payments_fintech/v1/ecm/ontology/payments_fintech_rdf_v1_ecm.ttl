ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date when the address ceased to be effective (null if still active).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodeLatitude rdf:type rdf:Property ;
    rdfs:label 'Geocode Latitude' ;
    rdfs:comment 'Latitude coordinate from geocoding the address.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geocodeLongitude rdf:type rdf:Property ;
    rdfs:label 'Geocode Longitude' ;
    rdfs:comment 'Longitude coordinate from geocoding the address.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this address is the primary address for the cardholder.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:label rdf:type rdf:Property ;
    rdfs:label 'Label' ;
    rdfs:comment 'Human-readable label for the address (e.g., Home, Office).' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line1' ;
    rdfs:comment 'First line of the street address.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line2' ;
    rdfs:comment 'Second line of the street address (optional).' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line3 rdf:type rdf:Property ;
    rdfs:label 'Line3' ;
    rdfs:comment 'Third line of the street address (optional).' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationAttempts rdf:type rdf:Property ;
    rdfs:label 'Verification Attempts' ;
    rdfs:comment 'Number of verification attempts performed for this address.' ;
    rdfs:domain ind:Cardholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verificationSource rdf:type rdf:Property ;
    rdfs:label 'Verification Source' ;
    rdfs:comment 'Source of address verification.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Current verification status of the address.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentId rdf:type rdf:Property ;
    rdfs:label 'Consent Id' ;
    rdfs:comment 'Surrogate primary key uniquely identifying each consent record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Consent .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Identifier of the internal user or system process that created the consent record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatoryJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to reference.regulatory_jurisdiction. Business justification: Consent management is jurisdiction-specific (GDPR, CCPA) and needs a reference to the applicable regulatory jurisdiction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryJurisdiction .

ind:collectionChannel rdf:type rdf:Property ;
    rdfs:label 'Collection Channel' ;
    rdfs:comment 'Channel through which the consent was obtained.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current lifecycle state of the consent record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'Exact date and time when the consent was granted.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'Category of consent captured, indicating the purpose such as GDPR data processing, CCPA sale opt-out, marketing communications, data sharing, or biometric usage.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCategory rdf:type rdf:Property ;
    rdfs:label 'Data Category' ;
    rdfs:comment 'High-level classification of the data types covered by the consent.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Timestamp' ;
    rdfs:comment 'Optional expiry date/time after which the consent is no longer valid.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'Legal justification for processing under GDPR, such as consent or legitimate interest.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Free-text description of the data processing activities covered by the consent.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version identifier of the consent text or policy that the cardholder agreed to.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalChannel rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Channel' ;
    rdfs:comment 'Channel through which the consent was withdrawn.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalIpAddress rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Ip Address' ;
    rdfs:comment 'IP address of the device used when consent was withdrawn.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Timestamp' ;
    rdfs:comment 'Date and time when the cardholder withdrew the consent, if applicable.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactEventId rdf:type rdf:Property ;
    rdfs:label 'Contact Event Id' ;
    rdfs:comment 'System-generated unique identifier for each contact event record.' ;
    rdfs:domain ind:ContactEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Agent Employee Id' ;
    rdfs:comment 'Identifier of the support agent who handled the outbound contact (if applicable).' ;
    rdfs:domain ind:ContactEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:disputeCaseId rdf:type rdf:Property ;
    rdfs:label 'Dispute Case Id' ;
    rdfs:comment 'Identifier of the dispute associated with the contact (if applicable).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DisputeCase .

ind:disputeCaseId rdf:type rdf:Property ;
    rdfs:label 'Dispute Dispute Case Id' ;
    rdfs:comment 'Identifier of the dispute associated with the contact (if applicable).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DisputeCase .

ind:notificationPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Notification Preference Id' ;
    rdfs:comment 'Reference to the cardholder\'s communication preference record governing channel consent.' ;
    rdfs:domain ind:Cardholder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NotificationPreference .

ind:attachmentCount rdf:type rdf:Property ;
    rdfs:label 'Attachment Count' ;
    rdfs:comment 'Number of attachments included with the communication.' ;
    rdfs:domain ind:ContactEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attachmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Attachment Indicator' ;
    rdfs:comment 'True if the message included one or more attachments.' ;
    rdfs:domain ind:ContactEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Timestamp' ;
    rdfs:comment 'Timestamp when the compliance validation was performed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactChannel rdf:type rdf:Property ;
    rdfs:label 'Contact Channel' ;
    rdfs:comment 'Medium used for the communication with the cardholder.' ;
    rdfs:domain ind:ContactEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactDirection rdf:type rdf:Property ;
    rdfs:label 'Contact Direction' ;
    rdfs:comment 'Indicates whether the communication was initiated by the cardholder (inbound) or by the platform/agent (outbound).' ;
    rdfs:domain ind:ContactEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactReason rdf:type rdf:Property ;
    rdfs:label 'Contact Reason' ;
    rdfs:comment 'Business purpose of the contact (e.g., fraud alert, statement ready, payment due, dispute update, KYC request, promotional). [ENUM-REF-CANDIDATE: fraud_alert|statement_ready|payment_due|dispute_update|kyc_request|promotional|other] ' ;
    rdfs:domain ind:ContactEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current status of the outbound message delivery.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Timestamp when the delivery status was recorded.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fraudAlertFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Alert Flag' ;
    rdfs:comment 'True if the contact pertains to a fraud alert or investigation.' ;
    rdfs:domain ind:ContactEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Compliant' ;
    rdfs:comment 'Indicates whether the contact complies with the cardholder\'s opt-in/opt-out preferences and regulatory rules.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHighPriority rdf:type rdf:Property ;
    rdfs:label 'Is High Priority' ;
    rdfs:comment 'Indicates whether the contact was marked as high priority (e.g., fraud or regulatory urgency).' ;
    rdfs:domain ind:ContactEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOptOut rdf:type rdf:Property ;
    rdfs:label 'Is Opt Out' ;
    rdfs:comment 'True if the cardholder has opted out of the specified contact channel.' ;
    rdfs:domain ind:ContactEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Kyc Request Flag' ;
    rdfs:comment 'True if the contact is a request for KYC documentation or verification.' ;
    rdfs:domain ind:ContactEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 language code of the communication content.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Marketing Campaign Code' ;
    rdfs:comment 'Reference to the marketing campaign that generated the promotional contact.' ;
    rdfs:domain ind:ContactEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:messageContent rdf:type rdf:Property ;
    rdfs:label 'Message Content' ;
    rdfs:comment 'Full body of the communication sent to or received from the cardholder.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageReference rdf:type rdf:Property ;
    rdfs:label 'Message Reference' ;
    rdfs:comment 'External identifier of the message (e.g., email Message-ID, SMS transaction ID).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageSubject rdf:type rdf:Property ;
    rdfs:label 'Message Subject' ;
    rdfs:comment 'Subject line or title of the communication (relevant for email, push, in-app messages).' ;
    rdfs:domain ind:ContactEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opt Out Timestamp' ;
    rdfs:comment 'Timestamp when the cardholder opted out of the channel.' ;
    rdfs:domain ind:ContactEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Categorized priority of the contact event.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Flag' ;
    rdfs:comment 'True if the communication is part of a marketing or promotional campaign.' ;
    rdfs:domain ind:ContactEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseDeadline rdf:type rdf:Property ;
    rdfs:label 'Response Deadline' ;
    rdfs:comment 'Latest timestamp by which the cardholder should respond.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Received Timestamp' ;
    rdfs:comment 'Timestamp when the inbound response from the cardholder was recorded.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseRequired rdf:type rdf:Property ;
    rdfs:label 'Response Required' ;
    rdfs:comment 'Indicates whether a reply from the cardholder is expected.' ;
    rdfs:domain ind:ContactEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Current status of the expected response.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'Date after which the contact event record must be purged in accordance with data retention policies.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaActualSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Seconds' ;
    rdfs:comment 'Actual elapsed time in seconds from contact initiation to required action completion.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTargetSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Target Seconds' ;
    rdfs:comment 'Target response time in seconds defined by service-level agreements for this contact type.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:systemReference rdf:type rdf:Property ;
    rdfs:label 'System Reference' ;
    rdfs:comment 'Identifier of the internal system that generated the contact event (e.g., CRM, Fraud Platform).' ;
    rdfs:domain ind:ContactEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceFingerprintId rdf:type rdf:Property ;
    rdfs:label 'Device Fingerprint Id' ;
    rdfs:comment 'Foreign key linking to fraud.device_fingerprint. Business justification: Unified device profiling links registered cardholder device to its fraud fingerprint record for accurate risk scoring.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceFingerprint .

ind:deviceName rdf:type rdf:Property ;
    rdfs:label 'Device Name' ;
    rdfs:comment 'Human-readable name assigned by the cardholder to the device (e.g., \'John’s iPhone\').' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpanProvisioned rdf:type rdf:Property ;
    rdfs:label 'Dpan Provisioned' ;
    rdfs:comment 'True if a Device Primary Account Number has been provisioned to the device.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fingerprintHash rdf:type rdf:Property ;
    rdfs:label 'Fingerprint Hash' ;
    rdfs:comment 'Cryptographic hash representing the device fingerprint used for risk scoring.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Firmware Version' ;
    rdfs:comment 'Version of the device firmware, if applicable.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hceCapable rdf:type rdf:Property ;
    rdfs:label 'Hce Capable' ;
    rdfs:comment 'Indicates whether the device can perform Host Card Emulation for tokenized payments.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imei rdf:type rdf:Property ;
    rdfs:label 'Imei' ;
    rdfs:comment 'Unique hardware identifier for mobile devices, used for device tracking and fraud detection.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Active Timestamp' ;
    rdfs:comment 'Most recent timestamp when the device was used for a transaction or authentication.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Latitude coordinate of the device’s last known location (if available).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Longitude coordinate of the device’s last known location (if available).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Company that manufactured the device (e.g., Apple, Samsung).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Model identifier of the device (e.g., iPhone 13, Galaxy S22).' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nfcCapable rdf:type rdf:Property ;
    rdfs:label 'Nfc Capable' ;
    rdfs:comment 'Indicates whether the device supports Near Field Communication for contactless payments.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:osName rdf:type rdf:Property ;
    rdfs:label 'Os Name' ;
    rdfs:comment 'Name of the operating system running on the device (e.g., iOS, Android).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osVersion rdf:type rdf:Property ;
    rdfs:label 'Os Version' ;
    rdfs:comment 'Version string of the operating system (e.g., 16.4).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pushNotificationToken rdf:type rdf:Property ;
    rdfs:label 'Push Notification Token' ;
    rdfs:comment 'Token used to send push notifications to the device.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of the device registration.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Registration Timestamp' ;
    rdfs:comment 'Date and time when the device was first registered to the cardholder.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:uuid rdf:type rdf:Property ;
    rdfs:label 'Uuid' ;
    rdfs:comment 'Universally unique identifier assigned to the device within the platform.' ;
    rdfs:domain ind:Device ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertType rdf:type rdf:Property ;
    rdfs:label 'Alert Type' ;
    rdfs:comment 'Category of transaction event that triggers a notification.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Delivery channel selected by the cardholder for this alert type.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceToken rdf:type rdf:Property ;
    rdfs:label 'Device Token' ;
    rdfs:comment 'Push notification device token used when the channel is push.' ;
    rdfs:domain ind:NotificationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isScaCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Sca Compliant' ;
    rdfs:comment 'Indicates whether the notification preference complies with Strong Customer Authentication requirements.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastNotifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Notified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent notification sent under this preference.' ;
    rdfs:domain ind:NotificationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationFrequency rdf:type rdf:Property ;
    rdfs:label 'Notification Frequency' ;
    rdfs:comment 'How often the cardholder wishes to receive notifications of this type.' ;
    rdfs:domain ind:NotificationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationPreferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Preference Status' ;
    rdfs:comment 'Current lifecycle status of the notification preference.' ;
    rdfs:domain ind:NotificationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceName rdf:type rdf:Property ;
    rdfs:label 'Preference Name' ;
    rdfs:comment 'Human-readable name for the notification preference configuration.' ;
    rdfs:domain ind:NotificationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Threshold Amount' ;
    rdfs:comment 'Monetary amount that must be exceeded to trigger the alert (if applicable).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdCurrency rdf:type rdf:Property ;
    rdfs:label 'Threshold Currency' ;
    rdfs:comment 'ISO 4217 currency code for the threshold amount.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Optimistic-lock version counter for concurrency control.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to ledger.cost_center. Business justification: Links employee cardholder profiles to cost centers for expense allocation and internal reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:fxFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Fx Fee Schedule Id' ;
    rdfs:comment 'Foreign key linking to fx.fx_fee_schedule. Business justification: FX fee schedule applied per cardholder for fee calculation reports; treasury uses this to charge correct FX fees based on customer segment.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FxFeeSchedule .

ind:issuingMerchantId rdf:type rdf:Property ;
    rdfs:label 'Issuing Merchant Id' ;
    rdfs:comment 'Foreign key linking to merchant.merchant. Business justification: Needed for co-branded card programs: link each cardholder to the merchant that issued the card for revenue sharing, program eligibility, and regulatory reporting.' ;
    rdfs:domain ind:CardholderProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Merchant .

ind:issuingParticipantId rdf:type rdf:Property ;
    rdfs:label 'Issuing Participant Id' ;
    rdfs:comment 'Foreign key linking to settlement.participant. Business justification: Regulatory AML/KYC reporting requires linking each cardholder to their issuing bank’s settlement participant to trace funds and satisfy cross-border settlement netting.' ;
    rdfs:domain ind:CardholderProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Participant .

ind:preferredPaymentProductId rdf:type rdf:Property ;
    rdfs:label 'Preferred Payment Product Id' ;
    rdfs:comment 'Foreign key linking to product.payment_product. Business justification: Personalized offers and risk scoring use the cardholder\'s preferred payment_product, necessitating a direct FK to payment_product.' ;
    rdfs:domain ind:CardholderProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentProduct .

ind:preferredSchemeId rdf:type rdf:Property ;
    rdfs:label 'Preferred Scheme Id' ;
    rdfs:comment 'Foreign key linking to network.scheme. Business justification: Needed for offering cardholder-specific scheme preferences during new card issuance and for compliance reporting on scheme-wise cardholder demographics.' ;
    rdfs:domain ind:CardholderProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Scheme .

ind:rateMarginConfigId rdf:type rdf:Property ;
    rdfs:label 'Rate Margin Config Id' ;
    rdfs:comment 'Foreign key linking to fx.rate_margin_config. Business justification: Custom margin config per cardholder determines FX rate margins; used in pricing engine and compliance reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateMarginConfig .

ind:watchlistId rdf:type rdf:Property ;
    rdfs:label 'Watchlist Id' ;
    rdfs:comment 'Foreign key linking to fraud.fraud_watchlist. Business justification: Compliance monitoring links each cardholder profile to its watchlist entry to satisfy AML and sanctions screening regulations.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Watchlist .

ind:accountLockFlag rdf:type rdf:Property ;
    rdfs:label 'Account Lock Flag' ;
    rdfs:comment 'Indicates whether the cardholder\'s account is currently locked due to security policies.' ;
    rdfs:domain ind:CardholderProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'First line of the cardholder\'s street address.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Second line of the street address (optional).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressVerified rdf:type rdf:Property ;
    rdfs:label 'Address Verified' ;
    rdfs:comment 'Indicates whether the cardholder\'s address has been validated through KYC processes.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cardholderType rdf:type rdf:Property ;
    rdfs:label 'Cardholder Type' ;
    rdfs:comment 'Segment indicating whether the cardholder is an individual consumer, business entity, merchant, or partner.' ;
    rdfs:domain ind:CardholderProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completenessScore rdf:type rdf:Property ;
    rdfs:label 'Completeness Score' ;
    rdfs:comment 'Calculated percentage (0-100) reflecting how many optional profile fields are populated.' ;
    rdfs:domain ind:CardholderProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdBySystem rdf:type rdf:Property ;
    rdfs:label 'Created By System' ;
    rdfs:comment 'Name of the system or service that initially created the profile record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionOptOut rdf:type rdf:Property ;
    rdfs:label 'Data Retention Opt Out' ;
    rdfs:comment 'Indicates if the cardholder has opted out of data retention beyond statutory periods.' ;
    rdfs:domain ind:CardholderProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailVerified rdf:type rdf:Property ;
    rdfs:label 'Email Verified' ;
    rdfs:comment 'True when the primary email address has been confirmed via verification workflow.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalCustomerCode rdf:type rdf:Property ;
    rdfs:label 'External Customer Code' ;
    rdfs:comment 'Identifier used by external partner systems to reference this cardholder.' ;
    rdfs:domain ind:CardholderProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudRiskScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Risk Score' ;
    rdfs:comment 'Numerical risk score generated by the fraud detection platform for this cardholder.' ;
    rdfs:domain ind:Cardholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Self-declared gender of the cardholder for demographic reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTestAccount rdf:type rdf:Property ;
    rdfs:label 'Is Test Account' ;
    rdfs:comment 'True if the profile is used for internal testing or sandbox environments.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Status' ;
    rdfs:comment 'Result of the Know-Your-Customer verification process for the cardholder.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBySystem rdf:type rdf:Property ;
    rdfs:label 'Last Modified By System' ;
    rdfs:comment 'Name of the system that performed the most recent update.' ;
    rdfs:domain ind:CardholderProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current lifecycle state of the cardholder profile.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingConsentEmail rdf:type rdf:Property ;
    rdfs:label 'Marketing Consent Email' ;
    rdfs:comment 'Indicates whether the cardholder has opted in to receive marketing emails.' ;
    rdfs:domain ind:CardholderProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingConsentSms rdf:type rdf:Property ;
    rdfs:label 'Marketing Consent Sms' ;
    rdfs:comment 'Indicates whether the cardholder has opted in to receive marketing SMS messages.' ;
