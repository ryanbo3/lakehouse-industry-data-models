ind:authenticationOutcome rdf:type rdf:Property ;
    rdfs:label 'Authentication Outcome' ;
    rdfs:comment 'Result of the authentication attempt.' ;
    rdfs:domain ind:AuthenticationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
