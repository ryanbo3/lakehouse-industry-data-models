    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for additional location details (building, floor, department).' ;
    rdfs:domain ind:MerchantLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date when this location was deactivated or closed, ceasing transaction processing.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudMonitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Fraud Monitoring Enabled' ;
    rdfs:comment 'Indicates whether real-time fraud detection and prevention monitoring is enabled for transactions at this location.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Business name or identifier for this specific merchant location (e.g., \'Downtown Store\', \'Airport Terminal 3\').' ;
    rdfs:domain ind:MerchantLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational status of the merchant location in its lifecycle: active (processing transactions), inactive (temporarily not processing), suspended (compliance hold), pending (onboarding), or closed (permanently offboarded).' ;
    rdfs:domain ind:MerchantLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the merchant location type: physical storefront, kiosk, online, mobile Point of Sale (mPOS), virtual, or pop-up.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours for the location (e.g., \'Mon-Fri 9AM-5PM, Sat 10AM-2PM\') used for customer service and transaction pattern analysis.' ;
    rdfs:domain ind:MerchantLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciAttestationDate rdf:type rdf:Property ;
    rdfs:label 'Pci Attestation Date' ;
    rdfs:comment 'Date of the most recent PCI DSS compliance attestation or Self-Assessment Questionnaire (SAQ) completion for this location.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noteId rdf:type rdf:Property ;
    rdfs:label 'Note Id' ;
    rdfs:comment 'System-generated unique identifier for each merchant note record.' ;
