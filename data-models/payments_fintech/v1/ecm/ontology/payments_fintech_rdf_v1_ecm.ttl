    rdfs:comment 'Timestamp when the current status was recorded.' ;
    rdfs:domain ind:SwiftGpiTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:swiftGpiTrackerStatus rdf:type rdf:Property ;
