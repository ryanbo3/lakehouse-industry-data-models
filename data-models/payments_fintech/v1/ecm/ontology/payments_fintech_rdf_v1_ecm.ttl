ind:eligibilityRule rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rule' ;
    rdfs:comment 'Business rule that defines which merchants or cardholders may use this product.' ;
    rdfs:domain ind:SchemeProductMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeBillingIndicator rdf:type rdf:Property ;
    rdfs:label 'Fee Billing Indicator' ;
    rdfs:comment 'Method used to bill scheme fees for this product.' ;
    rdfs:domain ind:SchemeProductMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeRate rdf:type rdf:Property ;
    rdfs:label 'Interchange Rate' ;
    rdfs:comment 'Base interchange rate expressed as a percentage.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDefaultMapping rdf:type rdf:Property ;
    rdfs:label 'Is Default Mapping' ;
    rdfs:comment 'True if this mapping is the default for the associated product.' ;
    rdfs:domain ind:SchemeProductMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mappingName rdf:type rdf:Property ;
    rdfs:label 'Mapping Name' ;
    rdfs:comment 'Human-readable name for the mapping configuration.' ;
    rdfs:domain ind:SchemeProductMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkFeeIndicator rdf:type rdf:Property ;
    rdfs:label 'Network Fee Indicator' ;
    rdfs:comment 'True if a network-level fee applies to this product.' ;
    rdfs:domain ind:SchemeProductMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productTier rdf:type rdf:Property ;
    rdfs:label 'Product Tier' ;
    rdfs:comment 'Tier level of the product as defined by the scheme.' ;
    rdfs:domain ind:SchemeProductMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeProductCode rdf:type rdf:Property ;
    rdfs:label 'Scheme Product Code' ;
    rdfs:comment 'Unique code assigned by the scheme to the product tier.' ;
    rdfs:domain ind:SchemeProductMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeProductMappingStatus rdf:type rdf:Property ;
    rdfs:label 'Scheme Product Mapping Status' ;
    rdfs:comment 'Current lifecycle status of the mapping.' ;
    rdfs:domain ind:SchemeProductMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeProductName rdf:type rdf:Property ;
    rdfs:label 'Scheme Product Name' ;
    rdfs:comment 'Descriptive name of the product as defined by the scheme.' ;
    rdfs:domain ind:SchemeProductMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualAccountProductId rdf:type rdf:Property ;
    rdfs:label 'Virtual Account Product Id' ;
    rdfs:comment 'Unique system-generated identifier for the virtual account product.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VirtualAccountProduct .

ind:allowedMccCodes rdf:type rdf:Property ;
    rdfs:label 'Allowed Mcc Codes' ;
    rdfs:comment 'Comma-separated list of Merchant Category Codes permitted for transactions on this virtual account.' ;
    rdfs:domain ind:VirtualAccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Issuance Fee Amount' ;
    rdfs:comment 'One-time fee charged when the virtual account is created.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Maintenance Fee Amount' ;
    rdfs:comment 'Recurring fee for maintaining the virtual account product.' ;
    rdfs:domain ind:VirtualAccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Max Balance Amount' ;
    rdfs:comment 'Upper bound on the cumulative balance that can be held in the virtual account.' ;
    rdfs:domain ind:VirtualAccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promoEligible rdf:type rdf:Property ;
    rdfs:label 'Promo Eligible' ;
    rdfs:comment 'Indicates whether the product can be included in promotional offers.' ;
    rdfs:domain ind:VirtualAccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spendControlRules rdf:type rdf:Property ;
    rdfs:label 'Spend Control Rules' ;
    rdfs:comment 'JSON-encoded rules that define merchant category restrictions, geographic limits, and velocity controls.' ;
    rdfs:domain ind:VirtualAccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualAccountProductDescription rdf:type rdf:Property ;
    rdfs:label 'Virtual Account Product Description' ;
    rdfs:comment 'Free-form description of the virtual account product, including marketing and functional details.' ;
    rdfs:domain ind:VirtualAccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualAccountProductName rdf:type rdf:Property ;
    rdfs:label 'Virtual Account Product Name' ;
    rdfs:comment 'Human-readable name of the virtual account product.' ;
    rdfs:domain ind:VirtualAccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualAccountProductStatus rdf:type rdf:Property ;
    rdfs:label 'Virtual Account Product Status' ;
    rdfs:comment 'Current lifecycle status of the product.' ;
    rdfs:domain ind:VirtualAccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlRiskCountryId rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Country Id' ;
    rdfs:comment 'Unique surrogate key for each AML risk country record.' ;
    rdfs:domain ind:AmlRiskCountry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amlRiskCountryStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Country Status' ;
    rdfs:comment 'Lifecycle status indicating whether the record is currently used in risk decisions.' ;
    rdfs:domain ind:AmlRiskCountry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enhancedDdRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Enhanced Dd Required Flag' ;
    rdfs:comment 'True when enhanced due-diligence procedures must be applied for customers from this jurisdiction.' ;
    rdfs:domain ind:AmlRiskCountry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:euHighRiskThirdCountryFlag rdf:type rdf:Property ;
    rdfs:label 'Eu High Risk Third Country Flag' ;
    rdfs:comment 'True if the country is considered a high-risk third country under EU regulations.' ;
    rdfs:domain ind:AmlRiskCountry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fatfStatus rdf:type rdf:Property ;
    rdfs:label 'Fatf Status' ;
    rdfs:comment 'FATF classification of the jurisdiction (blacklist, greylist, compliant).' ;
    rdfs:domain ind:AmlRiskCountry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fincenAdvisoryFlag rdf:type rdf:Property ;
    rdfs:label 'Fincen Advisory Flag' ;
    rdfs:comment 'Indicates whether FinCEN has issued a specific advisory for the country.' ;
    rdfs:domain ind:AmlRiskCountry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizationResponseCodeId rdf:type rdf:Property ;
    rdfs:label 'Authorization Response Code Id' ;
    rdfs:comment 'Unique surrogate identifier for each authorization response code record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuthorizationResponseCode .

ind:authorizationResponseCodeCategory rdf:type rdf:Property ;
    rdfs:label 'Authorization Response Code Category' ;
    rdfs:comment 'High-level classification of the response: approved, declined, referral (e.g., need for additional authentication), or error.' ;
    rdfs:domain ind:AuthorizationResponseCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationResponseCodeCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Response Code Code' ;
    rdfs:comment 'Standardized two- to four-character code returned by the issuing bank or scheme (e.g., "00", "05", "51").' ;
    rdfs:domain ind:AuthorizationResponseCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationResponseCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Response Code Status' ;
    rdfs:comment 'Current lifecycle status of the code record.' ;
    rdfs:domain ind:AuthorizationResponseCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRetriable rdf:type rdf:Property ;
    rdfs:label 'Is Retriable' ;
    rdfs:comment 'Indicates whether the transaction may be automatically retried (true) or must be halted (false).' ;
    rdfs:domain ind:AuthorizationResponseCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSoftDecline rdf:type rdf:Property ;
    rdfs:label 'Is Soft Decline' ;
    rdfs:comment 'True when the decline is considered soft (e.g., insufficient funds) and may be resolved without cardholder action.' ;
    rdfs:domain ind:AuthorizationResponseCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:schemeOverrideMessage rdf:type rdf:Property ;
    rdfs:label 'Scheme Override Message' ;
    rdfs:comment 'Optional scheme-specific description that overrides the generic message for this code.' ;
    rdfs:domain ind:AuthorizationResponseCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackReasonCodeCode rdf:type rdf:Property ;
    rdfs:label 'Chargeback Reason Code Code' ;
    rdfs:comment 'Alphanumeric identifier assigned by the card scheme (e.g., 4837, R01).' ;
    rdfs:domain ind:ChargebackReasonCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackReasonCodeDescription rdf:type rdf:Property ;
    rdfs:label 'Chargeback Reason Code Description' ;
    rdfs:comment 'Full textual explanation of the chargeback reason as defined by the scheme.' ;
    rdfs:domain ind:ChargebackReasonCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackReasonCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Chargeback Reason Code Status' ;
    rdfs:comment 'Operational status indicating whether the code is currently usable.' ;
    rdfs:domain ind:ChargebackReasonCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationRequirements rdf:type rdf:Property ;
    rdfs:label 'Documentation Requirements' ;
    rdfs:comment 'List of required supporting documents (e.g., receipt, proof of delivery) for this reason code.' ;
    rdfs:domain ind:ChargebackReasonCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedBy rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed By' ;
    rdfs:comment 'Identifier of the data steward responsible for the most recent review.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Calendar date when the reason code was last validated by data governance.' ;
    rdfs:domain ind:ChargebackReasonCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legacyCode rdf:type rdf:Property ;
    rdfs:label 'Legacy Code' ;
    rdfs:comment 'Previous code value retained for backward compatibility.' ;
    rdfs:domain ind:ChargebackReasonCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCodeType rdf:type rdf:Property ;
    rdfs:label 'Reason Code Type' ;
    rdfs:comment 'Specifies whether the entry is a chargeback, retrieval request, or representment reason.' ;
    rdfs:domain ind:ChargebackReasonCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimeLimitDays rdf:type rdf:Property ;
    rdfs:label 'Response Time Limit Days' ;
    rdfs:comment 'Allowed response window in calendar days for the merchant to address the chargeback.' ;
    rdfs:domain ind:ChargebackReasonCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Secondary classification providing finer detail (e.g., duplicate_processing, counterfeit_card).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayCalendarId rdf:type rdf:Property ;
    rdfs:label 'Holiday Calendar Id' ;
    rdfs:comment 'Surrogate key linking to the country-specific holiday calendar.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HolidayCalendar .

ind:capitalCity rdf:type rdf:Property ;
    rdfs:label 'Capital City' ;
    rdfs:comment 'Official capital city of the country.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryName rdf:type rdf:Property ;
    rdfs:label 'Country Name' ;
    rdfs:comment 'Official short name of the sovereign nation or territory.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dialingCode rdf:type rdf:Property ;
    rdfs:label 'Dialing Code' ;
    rdfs:comment 'Country calling code used for telephone numbers.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatfHighRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Fatf High Risk Flag' ;
    rdfs:comment 'True if the country is identified by FATF as high-risk for money-laundering or terrorism financing.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAmexSupported rdf:type rdf:Property ;
    rdfs:label 'Is Amex Supported' ;
    rdfs:comment 'Indicates whether American Express transactions are supported in the country.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEuMember rdf:type rdf:Property ;
    rdfs:label 'Is Eu Member' ;
    rdfs:comment 'True if the country is a member of the European Union.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isG20Member rdf:type rdf:Property ;
    rdfs:label 'Is G20 Member' ;
    rdfs:comment 'True if the country participates in the Group of Twenty.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isG7Member rdf:type rdf:Property ;
    rdfs:label 'Is G7 Member' ;
    rdfs:comment 'True if the country is part of the Group of Seven economies.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMastercardSupported rdf:type rdf:Property ;
    rdfs:label 'Is Mastercard Supported' ;
    rdfs:comment 'Indicates whether Mastercard transactions are supported in the country.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRtpSupported rdf:type rdf:Property ;
    rdfs:label 'Is Rtp Supported' ;
    rdfs:comment 'True if real-time payment infrastructure is available in the country.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSwiftSupported rdf:type rdf:Property ;
    rdfs:label 'Is Swift Supported' ;
    rdfs:comment 'True if the country participates in the SWIFT global payments network.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnMember rdf:type rdf:Property ;
    rdfs:label 'Is Un Member' ;
    rdfs:comment 'True if the country is a member of the United Nations.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnionpaySupported rdf:type rdf:Property ;
    rdfs:label 'Is Unionpay Supported' ;
    rdfs:comment 'Indicates whether UnionPay transactions are supported in the country.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVisaSupported rdf:type rdf:Property ;
    rdfs:label 'Is Visa Supported' ;
    rdfs:comment 'Indicates whether Visa card transactions are supported in the country.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoAlpha2Code rdf:type rdf:Property ;
    rdfs:label 'Iso Alpha2 Code' ;
    rdfs:comment 'Two-letter country code defined by ISO 3166-1.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoAlpha3Code rdf:type rdf:Property ;
    rdfs:label 'Iso Alpha3 Code' ;
    rdfs:comment 'Three-letter country code defined by ISO 3166-1.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Iso Currency Code' ;
    rdfs:comment 'Primary ISO 4217 currency code used for transactions in the country.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoNumericCode rdf:type rdf:Property ;
    rdfs:label 'Iso Numeric Code' ;
    rdfs:comment 'Three-digit numeric country code defined by ISO 3166-1.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCodes rdf:type rdf:Property ;
    rdfs:label 'Language Codes' ;
    rdfs:comment 'Comma-separated list of ISO 639-1 language codes spoken officially in the country.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ofacSanctionsFlag rdf:type rdf:Property ;
    rdfs:label 'Ofac Sanctions Flag' ;
    rdfs:comment 'Indicates whether the country appears on the OFAC sanctions list.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:psd2Applicability rdf:type rdf:Property ;
    rdfs:label 'Psd2 Applicability' ;
    rdfs:comment 'True if the country falls under the EU PSD2 regulatory regime.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subRegion rdf:type rdf:Property ;
    rdfs:label 'Sub Region' ;
    rdfs:comment 'More granular sub-region classification (e.g., Western Europe, Southern Asia).' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyDescription rdf:type rdf:Property ;
    rdfs:label 'Currency Description' ;
    rdfs:comment 'Additional free-text description or notes about the currency.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyName rdf:type rdf:Property ;
    rdfs:label 'Currency Name' ;
    rdfs:comment 'Full official name of the currency.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyType rdf:type rdf:Property ;
    rdfs:label 'Currency Type' ;
    rdfs:comment 'Classification of the currency as fiat, digital (e.g., cryptocurrency), or commodity-backed.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCrypto rdf:type rdf:Property ;
    rdfs:label 'Is Crypto' ;
    rdfs:comment 'True if the currency is a cryptocurrency.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFiat rdf:type rdf:Property ;
    rdfs:label 'Is Fiat' ;
    rdfs:comment 'True if the currency is a traditional fiat currency.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHistoric rdf:type rdf:Property ;
    rdfs:label 'Is Historic' ;
    rdfs:comment 'True if the currency is no longer in active circulation.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso3166NumericCountryCode rdf:type rdf:Property ;
    rdfs:label 'Iso 3166 Numeric Country Code' ;
    rdfs:comment 'Numeric country code associated with the currency\'s primary country.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorUnit rdf:type rdf:Property ;
    rdfs:label 'Minor Unit' ;
    rdfs:comment 'Number of decimal places used by the currency (e.g., 2 for USD).' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numericCode rdf:type rdf:Property ;
    rdfs:label 'Numeric Code' ;
    rdfs:comment 'Three-digit numeric code for the currency per ISO 4217.' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingRule rdf:type rdf:Property ;
    rdfs:label 'Rounding Rule' ;
    rdfs:comment 'Rounding rule applied for the currency (e.g., round half up).' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:symbol rdf:type rdf:Property ;
    rdfs:label 'Symbol' ;
    rdfs:comment 'Common symbol used to represent the currency (e.g., $).' ;
    rdfs:domain ind:Currency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineCodeId rdf:type rdf:Property ;
    rdfs:label 'Decline Code Id' ;
    rdfs:comment 'Unique surrogate identifier for each decline code record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeclineCode .

ind:cardholderMessage rdf:type rdf:Property ;
    rdfs:label 'Cardholder Message' ;
    rdfs:comment 'Message displayed to the cardholder when decline occurs.' ;
    rdfs:domain ind:DeclineCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineCodeCategory rdf:type rdf:Property ;
    rdfs:label 'Decline Code Category' ;
    rdfs:comment 'High-level classification of decline reason (e.g., do-not-honor, insufficient-funds, fraud-suspected). [ENUM-REF-CANDIDATE: do_not_honor|insufficient_funds|lost_card|stolen_card|fraud_suspected|expired_card|invalid_cvv|invalid_pin|restricted_card|generic_decline — promote to reference product]' ;
    rdfs:domain ind:DeclineCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineCodeCode rdf:type rdf:Property ;
    rdfs:label 'Decline Code Code' ;
    rdfs:comment 'Standardized decline code used in transaction processing.' ;
    rdfs:domain ind:DeclineCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineCodeDescription rdf:type rdf:Property ;
    rdfs:label 'Decline Code Description' ;
    rdfs:comment 'Human readable description of the decline reason.' ;
    rdfs:domain ind:DeclineCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Decline Code Status' ;
    rdfs:comment 'Current lifecycle status of the decline code.' ;
    rdfs:domain ind:DeclineCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantMessage rdf:type rdf:Property ;
    rdfs:label 'Merchant Message' ;
    rdfs:comment 'Message provided to the merchant for the decline reason.' ;
    rdfs:domain ind:DeclineCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retryEligible rdf:type rdf:Property ;
    rdfs:label 'Retry Eligible' ;
    rdfs:comment 'Indicates whether the transaction can be retried after this decline.' ;
    rdfs:domain ind:DeclineCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emvTagId rdf:type rdf:Property ;
    rdfs:label 'Emv Tag Id' ;
    rdfs:comment 'Unique surrogate key for each EMV tag record. _canonical_skip_reason: Entity is a reference lookup catalog of EMV data elements, thus no minimum role categories required.' ;
    rdfs:domain ind:EmvTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emvTagStatus rdf:type rdf:Property ;
    rdfs:label 'Emv Tag Status' ;
    rdfs:comment 'Current lifecycle status of the tag definition.' ;
    rdfs:domain ind:EmvTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso7816Reference rdf:type rdf:Property ;
    rdfs:label 'Iso 7816 Reference' ;
    rdfs:comment 'Reference to the ISO 7816 standard clause that defines the tag.' ;
