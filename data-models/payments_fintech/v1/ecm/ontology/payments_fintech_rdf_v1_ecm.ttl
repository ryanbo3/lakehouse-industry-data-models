ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether the review outcome complies with internal fraud policy and regulatory requirements.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerImpact rdf:type rdf:Property ;
    rdfs:label 'Customer Impact' ;
    rdfs:comment 'Effect of the false positive on the customer, such as a declined legitimate transaction or account freeze.' ;
    rdfs:domain ind:FalsePositiveReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falsePositiveReasonCategory rdf:type rdf:Property ;
    rdfs:label 'False Positive Reason Category' ;
    rdfs:comment 'High-level category describing why the alert was deemed a false positive.' ;
    rdfs:domain ind:FalsePositiveReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falsePositiveReasonDetail rdf:type rdf:Property ;
    rdfs:label 'False Positive Reason Detail' ;
    rdfs:comment 'Free-text explanation providing additional context for the false positive classification.' ;
    rdfs:domain ind:FalsePositiveReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackActionDetail rdf:type rdf:Property ;
    rdfs:label 'Feedback Action Detail' ;
    rdfs:comment 'Additional details about the corrective action applied.' ;
    rdfs:domain ind:FalsePositiveReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackActionTaken rdf:type rdf:Property ;
    rdfs:label 'Feedback Action Taken' ;
    rdfs:comment 'Action performed as a result of the false positive review to improve fraud detection (e.g., model tuning).' ;
    rdfs:domain ind:FalsePositiveReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactDetail rdf:type rdf:Property ;
    rdfs:label 'Impact Detail' ;
    rdfs:comment 'Narrative description of the specific customer impact experienced.' ;
    rdfs:domain ind:FalsePositiveReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Three-letter ISO country code of the jurisdiction governing the transaction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalAlertScore rdf:type rdf:Property ;
    rdfs:label 'Original Alert Score' ;
    rdfs:comment 'Fraud score value that originally triggered the alert.' ;
    rdfs:domain ind:FalsePositiveReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalAlertSeverity rdf:type rdf:Property ;
    rdfs:label 'Original Alert Severity' ;
    rdfs:comment 'Severity level assigned to the original fraud alert.' ;
    rdfs:domain ind:FalsePositiveReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalAlertTimestamp rdf:type rdf:Property ;
    rdfs:label 'Original Alert Timestamp' ;
    rdfs:comment 'Date and time when the original fraud alert was generated.' ;
    rdfs:domain ind:FalsePositiveReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryReportFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Flag' ;
    rdfs:comment 'True if the false positive review required regulatory reporting (e.g., SAR filing).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Analyst notes captured during the false positive review.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Full name of the analyst who cleared the alert as a false positive.' ;
    rdfs:domain ind:FalsePositiveReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned User Employee Id' ;
    rdfs:comment 'Identifier of the analyst or user currently handling the alert.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:endpointId rdf:type rdf:Property ;
    rdfs:label 'Endpoint Id' ;
    rdfs:comment 'Foreign key linking to network.network_endpoint. Business justification: Forensic analysis of alerts needs the exact network endpoint that processed the transaction, supporting root-cause investigations.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Endpoint .

ind:fraudRuleId rdf:type rdf:Property ;
    rdfs:label 'Fraud Rule Id' ;
    rdfs:comment 'Identifier of the rule that triggered the alert, if rule-based.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudRule .

ind:modelId rdf:type rdf:Property ;
    rdfs:label 'Model Id' ;
    rdfs:comment 'Identifier of the ML model that produced the fraud score, if applicable.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskModel .

ind:authResponseCode rdf:type rdf:Property ;
    rdfs:label 'Auth Response Code' ;
    rdfs:comment 'ISO-8583 response code returned by the issuer. [ENUM-REF-CANDIDATE: 00|05|12|13|14|15|30|41|43|51|54|55|57|58|62|63|65|75|76|77|78|79|80|81|82|83|84|85|86|87|88|89|90|91|92|93|94|95|96|97|98|99 — 42 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReason rdf:type rdf:Property ;
    rdfs:label 'Decline Reason' ;
    rdfs:comment 'Reason provided by the issuer for a declined transaction, if applicable.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudAlertStatus rdf:type rdf:Property ;
    rdfs:label 'Fraud Alert Status' ;
    rdfs:comment 'Current lifecycle state of the alert within the case management workflow.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCountry rdf:type rdf:Property ;
    rdfs:label 'Geo Country' ;
    rdfs:comment 'Three-letter ISO country code of the transaction source.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFraudulent rdf:type rdf:Property ;
    rdfs:label 'Is Fraudulent' ;
    rdfs:comment 'Flag indicating whether the transaction is confirmed as fraudulent after review.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Descriptive name of the ML model used for scoring.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNetwork rdf:type rdf:Property ;
    rdfs:label 'Payment Network' ;
    rdfs:comment 'Card scheme or network that processed the transaction.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Score Threshold' ;
    rdfs:comment 'Configured threshold that the triggered_score must exceed to raise an alert.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Business-defined severity indicating potential impact of the alert.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeredScore rdf:type rdf:Property ;
    rdfs:label 'Triggered Score' ;
    rdfs:comment 'Numeric risk score generated by the detection engine.' ;
    rdfs:domain ind:FraudAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedInvestigatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Investigator Employee Id' ;
    rdfs:comment 'Identifier of the analyst or investigator assigned to the case.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:billingId rdf:type rdf:Property ;
    rdfs:label 'Billing Id' ;
    rdfs:comment 'Foreign key linking to interchange.interchange_billing. Business justification: Billing adjustments for chargebacks require linking each fraud case to the billing period record that captured the transaction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Billing .

ind:fraudTypeId rdf:type rdf:Property ;
    rdfs:label 'Fraud Type Id' ;
    rdfs:comment 'Foreign key linking to fraud.fraud_type. Business justification: fraud_case needs a classification of the case type; linking to fraud_type provides hierarchy and risk weighting.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudType .

ind:qualificationId rdf:type rdf:Property ;
    rdfs:label 'Qualification Id' ;
    rdfs:comment 'Foreign key linking to interchange.interchange_qualification. Business justification: Fraud loss reporting needs the original IRF rate applied to the fraudulent transaction to calculate lost interchange revenue.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Qualification .

ind:regulatoryReportRegulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Regulatory Filing Id' ;
    rdfs:comment 'Identifier of the regulatory report associated with the case.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:riskProfileId rdf:type rdf:Property ;
    rdfs:label 'Risk Profile Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_profile. Business justification: Risk assessment reports require linking each fraud case to the party\'s risk profile to correlate fraud outcomes with risk scores.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskProfile .

ind:routingDecisionId rdf:type rdf:Property ;
    rdfs:label 'Routing Decision Id' ;
    rdfs:comment 'Foreign key linking to gateway.routing_decision. Business justification: Case reviews often examine the routing decision that selected the acquirer to understand risk exposure.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoutingDecision .

ind:watchlistFraudWatchlistId rdf:type rdf:Property ;
    rdfs:label 'Watchlist Fraud Watchlist Id' ;
    rdfs:comment 'Foreign key linking to fraud.fraud_watchlist. Business justification: fraud_case may reference a watchlist entry that triggered the case; linking to fraud_watchlist enables traceability.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Watchlist .

ind:amlAlert rdf:type rdf:Property ;
    rdfs:label 'Aml Alert' ;
    rdfs:comment 'Indicates whether the case triggered an AML screening alert.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blocklistHit rdf:type rdf:Property ;
    rdfs:label 'Blocklist Hit' ;
    rdfs:comment 'True if the entity matched an internal or external blocklist.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blocklistName rdf:type rdf:Property ;
    rdfs:label 'Blocklist Name' ;
    rdfs:comment 'Name of the blocklist that produced the hit.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackCurrency rdf:type rdf:Property ;
    rdfs:label 'Chargeback Currency' ;
    rdfs:comment 'Currency of the chargeback amount.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionSource rdf:type rdf:Property ;
    rdfs:label 'Detection Source' ;
    rdfs:comment 'System or channel that initially flagged the suspicious activity.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureAmount rdf:type rdf:Property ;
    rdfs:label 'Exposure Amount' ;
    rdfs:comment 'Estimated monetary loss if fraud is successful.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudCategory rdf:type rdf:Property ;
    rdfs:label 'Fraud Category' ;
    rdfs:comment 'High-level fraud taxonomy for the case.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigation End Timestamp' ;
    rdfs:comment 'When the investigation was concluded.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:investigationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Timestamp' ;
    rdfs:comment 'When the formal investigation of the case began.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isBlocked rdf:type rdf:Property ;
    rdfs:label 'Is Blocked' ;
    rdfs:comment 'Indicates whether the associated account or card was blocked pending investigation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isChargebackFlagged rdf:type rdf:Property ;
    rdfs:label 'Is Chargeback Flagged' ;
    rdfs:comment 'Indicates whether a chargeback was filed related to the case.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentInstrumentToken rdf:type rdf:Property ;
    rdfs:label 'Payment Instrument Token' ;
    rdfs:comment 'Token representing the payment credential used in the transaction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarFiled rdf:type rdf:Property ;
    rdfs:label 'Sar Filed' ;
    rdfs:comment 'True if a Suspicious Activity Report was filed for this case.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Case Status History Id' ;
    rdfs:comment 'System-generated unique identifier for each status transition record in the fraud case lifecycle.' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actor rdf:type rdf:Property ;
    rdfs:label 'Actor' ;
    rdfs:comment 'Name or system identifier of the entity (analyst, automated system, or external partner) that performed the status change.' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casePriority rdf:type rdf:Property ;
    rdfs:label 'Case Priority' ;
    rdfs:comment 'Business-defined priority level of the fraud case at the time of the transition.' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatusHistoryStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status History Status' ;
    rdfs:comment 'The status of the fraud case after the transition. [ENUM-REF-CANDIDATE: new|under_investigation|escalated|pending_recovery|closed_fraud|closed_no_fraud|referred_to_law_enforcement — promote to reference product]' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudRuleTriggered rdf:type rdf:Property ;
    rdfs:label 'Fraud Rule Triggered' ;
    rdfs:comment 'Identifier of the fraud rule or model that influenced the status change, if applicable.' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationOutcome rdf:type rdf:Property ;
    rdfs:label 'Investigation Outcome' ;
    rdfs:comment 'Result of the investigation at the time of this transition.' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreAtTransition rdf:type rdf:Property ;
    rdfs:label 'Risk Score At Transition' ;
    rdfs:comment 'Fraud risk score associated with the case when the status change was recorded.' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaMet rdf:type rdf:Property ;
    rdfs:label 'Sla Met' ;
    rdfs:comment 'Indicates whether the transition occurred within the SLA deadline (true) or missed it (false).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Timestamp' ;
    rdfs:comment 'Exact date and time when the status change was recorded.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fraudChannelId rdf:type rdf:Property ;
    rdfs:label 'Fraud Channel Id' ;
    rdfs:comment 'Unique surrogate key for each payment channel used in fraud monitoring.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudChannel .

ind:applicableRuleCategories rdf:type rdf:Property ;
    rdfs:label 'Applicable Rule Categories' ;
    rdfs:comment 'Comma-separated list of fraud rule categories that apply to this channel (e.g., "velocity|device_fingerprint|geolocation").' ;
    rdfs:domain ind:FraudChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageFraudRate rdf:type rdf:Property ;
    rdfs:label 'Average Fraud Rate' ;
    rdfs:comment 'Historical average fraud rate for the channel expressed as a proportion (e.g., 0.0125 = 1.25%).' ;
    rdfs:domain ind:FraudChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Short, unique alphanumeric code that identifies the payment channel.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelDescription rdf:type rdf:Property ;
    rdfs:label 'Channel Description' ;
    rdfs:comment 'Detailed description of the channel\'s characteristics and typical use cases.' ;
    rdfs:domain ind:FraudChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelGroup rdf:type rdf:Property ;
    rdfs:label 'Channel Group' ;
    rdfs:comment 'Higher-level category used to aggregate channels (e.g., "Card", "Bank Transfer", "Digital").' ;
    rdfs:domain ind:FraudChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Human-readable name of the payment channel (e.g., "Card-Present POS").' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudChannelStatus rdf:type rdf:Property ;
    rdfs:label 'Fraud Channel Status' ;
    rdfs:comment 'Current lifecycle status of the channel definition.' ;
    rdfs:domain ind:FraudChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:is3dsApplicable rdf:type rdf:Property ;
    rdfs:label 'Is 3ds Applicable' ;
    rdfs:comment 'Indicates whether 3-Domain Secure authentication is supported for the channel.' ;
    rdfs:domain ind:FraudChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isScaRequired rdf:type rdf:Property ;
    rdfs:label 'Is Sca Required' ;
    rdfs:comment 'True if Strong Customer Authentication is mandatory for transactions on this channel.' ;
    rdfs:domain ind:FraudChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskScoreWeight rdf:type rdf:Property ;
    rdfs:label 'Risk Score Weight' ;
    rdfs:comment 'Multiplier applied to the channel’s base fraud score to reflect relative risk.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceId rdf:type rdf:Property ;
    rdfs:label 'Evidence Id' ;
    rdfs:comment 'Unique surrogate key for each fraud evidence record.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidenceFraudCaseId rdf:type rdf:Property ;
    rdfs:label 'Evidence Fraud Case Id' ;
    rdfs:comment 'Identifier of the fraud case to which this evidence belongs.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudCase .

ind:evidenceRelatedFraudCaseId rdf:type rdf:Property ;
    rdfs:label 'Evidence Related Fraud Case Id' ;
    rdfs:comment 'Identifier of the fraud case to which this evidence belongs.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudCase .

ind:evidenceRelatedTransactionId rdf:type rdf:Property ;
    rdfs:label 'Evidence Related Transaction Id' ;
    rdfs:comment 'Identifier of the transaction that is the subject of this evidence.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:evidenceTransactionId rdf:type rdf:Property ;
    rdfs:label 'Evidence Transaction Id' ;
    rdfs:comment 'Identifier of the transaction that is the subject of this evidence.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:relatedCardholderCardholderProfileId rdf:type rdf:Property ;
    rdfs:label 'Related Cardholder Cardholder Profile Id' ;
    rdfs:comment 'Identifier of the cardholder associated with the evidence.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CardholderProfile .

ind:relatedCardholderProfileId rdf:type rdf:Property ;
    rdfs:label 'Related Cardholder Profile Id' ;
    rdfs:comment 'Identifier of the cardholder associated with the evidence.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CardholderProfile .

ind:accessControlLevel rdf:type rdf:Property ;
    rdfs:label 'Access Control Level' ;
    rdfs:comment 'Data classification level governing who may view or retrieve the evidence.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admissibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Admissibility Flag' ;
    rdfs:comment 'Indicates whether the evidence meets regulatory and legal standards for use in dispute or law-enforcement proceedings.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chainOfCustodyStatus rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Status' ;
    rdfs:comment 'Current integrity status of the evidence for legal admissibility.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'Exact date-time when the evidence was captured.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:encryptionStatus rdf:type rdf:Property ;
    rdfs:label 'Encryption Status' ;
    rdfs:comment 'Indicates whether the evidence is stored encrypted and the encryption state.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceDescription rdf:type rdf:Property ;
    rdfs:label 'Evidence Description' ;
    rdfs:comment 'Free-text narrative describing the content and relevance of the evidence.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceSource rdf:type rdf:Property ;
    rdfs:label 'Evidence Source' ;
    rdfs:comment 'Originating system or component that produced the evidence.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceStatus rdf:type rdf:Property ;
    rdfs:label 'Evidence Status' ;
    rdfs:comment 'Current lifecycle state of the evidence within the fraud investigation process.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceType rdf:type rdf:Property ;
    rdfs:label 'Evidence Type' ;
    rdfs:comment 'Category of the evidence artifact captured for a fraud investigation.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileHash rdf:type rdf:Property ;
    rdfs:label 'File Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the stored evidence file for integrity verification.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'File format or serialization of the stored evidence.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSensitive rdf:type rdf:Property ;
    rdfs:label 'Is Sensitive' ;
    rdfs:comment 'True if the evidence contains personally identifiable or regulated data.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageUri rdf:type rdf:Property ;
    rdfs:label 'Storage Uri' ;
    rdfs:comment 'Reference (e.g., S3 URI, file path) to the physical location of the stored evidence.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationId rdf:type rdf:Property ;
    rdfs:label 'Investigation Id' ;
    rdfs:comment 'Unique identifier for the fraud investigation record.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditTrailId rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Id' ;
    rdfs:comment 'Reference to audit trail record for this investigation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditTrail .

ind:investigationAssignedInvestigatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Investigation Assigned Investigator Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:investigationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Investigation Employee Id' ;
    rdfs:comment 'Identifier of the investigator assigned to the case.' ;
    rdfs:domain ind:Investigation ;
