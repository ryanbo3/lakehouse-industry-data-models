    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractualAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Contractual Agreement Reference' ;
    rdfs:comment 'Reference identifier for the legal agreement governing token requestor activities.' ;
    rdfs:domain ind:TokenRequestor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyTokenRequestCount rdf:type rdf:Property ;
    rdfs:label 'Daily Token Request Count' ;
    rdfs:comment 'Running count of token requests submitted by the requestor for the current day.' ;
