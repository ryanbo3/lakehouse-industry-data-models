ind:isSystemDefault rdf:type rdf:Property ;
    rdfs:label 'Is System Default' ;
    rdfs:comment 'Indicates whether this threshold is a built-in default provided by the platform.' ;
    rdfs:domain ind:Threshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationChannel rdf:type rdf:Property ;
