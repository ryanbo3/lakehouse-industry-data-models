    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latencyP95Ms rdf:type rdf:Property ;
    rdfs:label 'Latency P95 Ms' ;
    rdfs:comment '95th percentile request latency observed during the measurement window, expressed in milliseconds.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latencyP99Ms rdf:type rdf:Property ;
    rdfs:label 'Latency P99 Ms' ;
    rdfs:comment '99th percentile request latency observed during the measurement window, expressed in milliseconds.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementSource rdf:type rdf:Property ;
    rdfs:label 'Measurement Source' ;
    rdfs:comment 'Origin of the measurement data, e.g., real-time gateway, batch processing, external monitoring service.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'Exact time the SLA measurement observation occurred.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Measurement Window End' ;
    rdfs:comment 'Timestamp marking the end of the period over which the SLA metrics were aggregated.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementWindowStart rdf:type rdf:Property ;
    rdfs:label 'Measurement Window Start' ;
    rdfs:comment 'Timestamp marking the beginning of the period over which the SLA metrics were aggregated.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tps rdf:type rdf:Property ;
    rdfs:label 'Tps' ;
    rdfs:comment 'Average number of successful transactions processed per second during the measurement window.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachNotificationTimeHours rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Time Hours' ;
    rdfs:comment 'Maximum time to notify the merchant after an SLA breach.' ;
