    rdfs:range xsd:string .

ind:rateMarginConfigDescription rdf:type rdf:Property ;
    rdfs:label 'Rate Margin Config Description' ;
    rdfs:comment 'Free-text description providing context and business rationale.' ;
    rdfs:domain ind:RateMarginConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateMarginConfigName rdf:type rdf:Property ;
    rdfs:label 'Rate Margin Config Name' ;
    rdfs:comment 'Human-readable name identifying the margin configuration.' ;
    rdfs:domain ind:RateMarginConfig ;
