    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:noteTransactionId rdf:type rdf:Property ;
    rdfs:label 'Note Transaction Id' ;
    rdfs:comment 'Identifier of a transaction that is contextually linked to the note, if applicable.' ;
