    rdfs:comment 'True if the configuration satisfies PSD2 transparency requirements.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportingReqId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Req Id' ;
    rdfs:comment 'Unique identifier for the regulatory reporting requirement record.' ;
