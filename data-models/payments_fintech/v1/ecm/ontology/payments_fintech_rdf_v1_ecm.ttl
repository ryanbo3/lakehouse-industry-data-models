    rdfs:domain ind:AcceptanceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Acceptance Type Description' ;
    rdfs:comment 'Detailed free-text description of the acceptance type and its typical use cases.' ;
