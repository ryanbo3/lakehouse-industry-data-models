    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentLimitId rdf:type rdf:Property ;
    rdfs:label 'Instrument Limit Id' ;
    rdfs:comment 'Unique surrogate key for each instrument limit configuration record.' ;
    rdfs:domain ind:InstrumentLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atmWithdrawalLimit rdf:type rdf:Property ;
