ind:exposureStatus rdf:type rdf:Property ;
    rdfs:label 'Exposure Status' ;
    rdfs:comment 'Current lifecycle status of the exposure record.' ;
    rdfs:domain ind:Exposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossNotionalExposure rdf:type rdf:Property ;
