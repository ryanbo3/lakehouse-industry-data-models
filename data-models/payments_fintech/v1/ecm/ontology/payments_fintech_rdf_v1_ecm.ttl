ind:regulatoryReportingReqStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Req Status' ;
    rdfs:comment 'Current lifecycle state of the reporting requirement.' ;
    rdfs:domain ind:RegulatoryReportingReq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingChannel rdf:type rdf:Property ;
