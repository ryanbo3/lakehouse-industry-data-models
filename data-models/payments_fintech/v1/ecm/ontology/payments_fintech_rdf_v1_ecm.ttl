ind:forwardContractId rdf:type rdf:Property ;
    rdfs:label 'Forward Contract Id' ;
    rdfs:comment 'System-generated unique identifier for the FX forward contract record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ForwardContract .

ind:counterpartyId rdf:type rdf:Property ;
