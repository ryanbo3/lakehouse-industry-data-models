ind:isoMessageFieldId rdf:type rdf:Property ;
    rdfs:label 'Iso Message Field Id' ;
    rdfs:comment 'Unique surrogate identifier for each ISO message field record.' ;
    rdfs:domain ind:IsoMessageField ;
    rdf:type owl:DatatypeProperty ;
