    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationCountry rdf:type rdf:Property ;
    rdfs:label 'Location Country' ;
    rdfs:comment 'Three-letter country code of the request origin.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestReason rdf:type rdf:Property ;
    rdfs:label 'Request Reason' ;
    rdfs:comment 'Business reason for the detokenization request.' ;
    rdfs:domain ind:DetokenizationRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorType rdf:type rdf:Property ;
    rdfs:label 'Requestor Type' ;
    rdfs:comment 'Classification of the requesting party.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Balance Eligibility Flag' ;
    rdfs:comment 'Indicates whether the wallet is eligible to hold a stored-value balance.' ;
    rdfs:domain ind:DigitalWallet ;
    rdf:type owl:DatatypeProperty ;
