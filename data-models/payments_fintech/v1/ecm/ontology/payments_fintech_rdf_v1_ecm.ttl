    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dualInterfaceEnabled rdf:type rdf:Property ;
    rdfs:label 'Dual Interface Enabled' ;
    rdfs:comment 'Indicates whether the terminal supports both contactless and chip interfaces.' ;
    rdfs:domain ind:ContactlessProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dualInterfaceRoutingRule rdf:type rdf:Property ;
