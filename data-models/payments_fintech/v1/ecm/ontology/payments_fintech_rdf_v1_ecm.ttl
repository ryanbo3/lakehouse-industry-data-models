    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minTradeableUnit rdf:type rdf:Property ;
    rdfs:label 'Min Tradeable Unit' ;
    rdfs:comment 'Smallest amount of the base currency that can be traded or converted.' ;
