    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportingReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Reference' ;
    rdfs:comment 'Identifier of the related case, dispute, compliance event, or other artifact that justified the status change.' ;
    rdfs:domain ind:InstrumentStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentVerificationId rdf:type rdf:Property ;
    rdfs:label 'Instrument Verification Id' ;
    rdfs:comment 'Unique surrogate key for each instrument verification event record.' ;
