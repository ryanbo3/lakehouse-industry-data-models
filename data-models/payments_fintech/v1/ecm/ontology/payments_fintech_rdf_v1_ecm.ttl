    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationResult rdf:type rdf:Property ;
    rdfs:label 'Authentication Result' ;
    rdfs:comment 'Outcome of the 3-DS authentication: Y=success, N=failed, A=attempted, U=unavailable, R=retry, C=challenge.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardBrand rdf:type rdf:Property ;
    rdfs:label 'Card Brand' ;
    rdfs:comment 'Brand of the payment card used in the transaction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cavv rdf:type rdf:Property ;
    rdfs:label 'Cavv' ;
    rdfs:comment 'Cryptographic value generated by the cardholder\'s device for authentication.' ;
