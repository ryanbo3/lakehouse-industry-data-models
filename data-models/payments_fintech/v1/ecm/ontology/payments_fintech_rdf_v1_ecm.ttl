ind:lastEnforcedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Enforced Timestamp' ;
    rdfs:comment 'Timestamp of the most recent transaction where this limit was evaluated.' ;
    rdfs:domain ind:InstrumentLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:limitGroupCode rdf:type rdf:Property ;
    rdfs:label 'Limit Group Code' ;
    rdfs:comment 'Logical grouping identifier for related limit records (e.g., program-wide, regional).' ;
    rdfs:domain ind:InstrumentLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitVersion rdf:type rdf:Property ;
    rdfs:label 'Limit Version' ;
    rdfs:comment 'Monotonically increasing version number for change-control and audit.' ;
