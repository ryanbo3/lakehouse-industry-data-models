    rdfs:domain ind:SwiftGpiTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionInitiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Initiated Timestamp' ;
    rdfs:comment 'Timestamp when the payment was initially submitted to the gpi network.' ;
    rdfs:domain ind:SwiftGpiTracker ;
    rdf:type owl:DatatypeProperty ;
