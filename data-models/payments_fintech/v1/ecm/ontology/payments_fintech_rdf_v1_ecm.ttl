ind:configType rdf:type rdf:Property ;
    rdfs:label 'Config Type' ;
    rdfs:comment 'Classification of the DCC configuration (e.g., standard, premium, custom).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dccConfigStatus rdf:type rdf:Property ;
    rdfs:label 'Dcc Config Status' ;
    rdfs:comment 'Current lifecycle status of the DCC configuration.' ;
