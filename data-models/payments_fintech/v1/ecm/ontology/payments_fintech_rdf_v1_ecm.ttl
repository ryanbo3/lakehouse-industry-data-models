ind:linkedAccountId rdf:type rdf:Property ;
    rdfs:label 'Linked Linked Account Id' ;
    rdfs:comment 'Reference to the bank account that funds are drawn from or credited to for this VPA.' ;
    rdfs:domain ind:Upi ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LinkedAccount .

ind:failedAuthAttempts rdf:type rdf:Property ;
    rdfs:label 'Failed Auth Attempts' ;
    rdfs:comment 'Count of consecutive failed authentication attempts since the last successful login.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastSuccessfulAuthTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Successful Auth Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful authentication (e.g., PIN entry, biometric) for the VPA.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxFailedAttempts rdf:type rdf:Property ;
    rdfs:label 'Max Failed Attempts' ;
    rdfs:comment 'Configured threshold after which the VPA is locked pending reset.' ;
