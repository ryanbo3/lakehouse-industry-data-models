    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onlinePinSupported rdf:type rdf:Property ;
    rdfs:label 'Online Pin Supported' ;
    rdfs:comment 'Indicates if the terminal can perform online PIN verification.' ;
    rdfs:domain ind:EmvParameterSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:randomSelectionPercentage rdf:type rdf:Property ;
    rdfs:label 'Random Selection Percentage' ;
    rdfs:comment 'Percentage of transactions randomly selected for online processing to mitigate risk.' ;
    rdfs:domain ind:EmvParameterSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tacDefault rdf:type rdf:Property ;
    rdfs:label 'Tac Default' ;
    rdfs:comment 'Default Terminal Action Code applied when no other TAC matches.' ;
    rdfs:domain ind:EmvParameterSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tacDenial rdf:type rdf:Property ;
    rdfs:label 'Tac Denial' ;
    rdfs:comment 'Terminal Action Code used when a transaction is denied offline.' ;
    rdfs:domain ind:EmvParameterSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tacOnline rdf:type rdf:Property ;
    rdfs:label 'Tac Online' ;
    rdfs:comment 'Terminal Action Code used when a transaction requires online authorization.' ;
    rdfs:domain ind:EmvParameterSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTypeSupport rdf:type rdf:Property ;
