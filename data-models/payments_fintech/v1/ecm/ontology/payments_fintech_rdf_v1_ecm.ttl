    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRestrictedToken rdf:type rdf:Property ;
    rdfs:label 'Is Restricted Token' ;
    rdfs:comment 'Flag indicating whether the token is subject to additional restrictions (e.g., high-value transactions).' ;
