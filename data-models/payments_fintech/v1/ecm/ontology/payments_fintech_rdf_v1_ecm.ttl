ind:submissionFormat rdf:type rdf:Property ;
    rdfs:label 'Submission Format' ;
    rdfs:comment 'File or message format required for the regulatory filing.' ;
    rdfs:domain ind:RegulatoryReportingReq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningResultId rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Result Id' ;
    rdfs:comment 'System-generated unique identifier for each sanctions screening result record.' ;
    rdfs:domain ind:SanctionsScreeningResult ;
    rdf:type owl:DatatypeProperty ;
