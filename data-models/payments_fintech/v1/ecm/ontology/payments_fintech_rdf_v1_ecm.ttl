    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquirerEndpointId rdf:type rdf:Property ;
    rdfs:label 'Acquirer Endpoint Id' ;
    rdfs:comment 'Unique system-generated identifier for the acquirer endpoint configuration.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AcquirerEndpoint .

ind:failoverEndpointId rdf:type rdf:Property ;
