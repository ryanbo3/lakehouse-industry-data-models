    rdfs:range xsd:date .

ind:checksumSha256 rdf:type rdf:Property ;
    rdfs:label 'Checksum Sha256' ;
    rdfs:comment 'SHA-256 hash of the SDK package for integrity verification.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumType rdf:type rdf:Property ;
    rdfs:label 'Checksum Type' ;
    rdfs:comment 'Algorithm used to generate the checksum.' ;
    rdfs:domain ind:SdkVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downloadUrl rdf:type rdf:Property ;
    rdfs:label 'Download Url' ;
    rdfs:comment 'Secure URL from which the SDK package can be downloaded.' ;
    rdfs:domain ind:SdkVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endOfLifeDate rdf:type rdf:Property ;
    rdfs:label 'End Of Life Date' ;
    rdfs:comment 'Final date after which the SDK version will be retired and unsupported.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:languageSupport rdf:type rdf:Property ;
    rdfs:label 'Language Support' ;
    rdfs:comment 'Comma-separated list of programming languages or locales supported by the SDK.' ;
    rdfs:domain ind:SdkVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciDssComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Compliance Status' ;
    rdfs:comment 'Current PCI DSS compliance certification status of the SDK.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseNotes rdf:type rdf:Property ;
