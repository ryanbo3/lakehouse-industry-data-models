    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeBytes rdf:type rdf:Property ;
    rdfs:label 'Size Bytes' ;
    rdfs:comment 'Size of the raw request payload in bytes.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceIp rdf:type rdf:Property ;
    rdfs:label 'Source Ip' ;
    rdfs:comment 'IP address of the client that initiated the request.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcePort rdf:type rdf:Property ;
