    rdfs:range xsd:string .

ind:kernelVersion rdf:type rdf:Property ;
    rdfs:label 'Kernel Version' ;
    rdfs:comment 'Version identifier of the contactless kernel software.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxTransactionAttempts rdf:type rdf:Property ;
    rdfs:label 'Max Transaction Attempts' ;
    rdfs:comment 'Maximum number of contactless attempts before fallback to chip.' ;
