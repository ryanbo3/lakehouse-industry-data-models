ind:pointsRedeemedLast12Months rdf:type rdf:Property ;
    rdfs:label 'Points Redeemed Last 12 Months' ;
    rdfs:comment 'Cumulative points redeemed over the past 12 calendar months.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsRedeemedLast30Days rdf:type rdf:Property ;
    rdfs:label 'Points Redeemed Last 30 Days' ;
    rdfs:comment 'Total points redeemed in the most recent 30-day window.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsRedeemedTotal rdf:type rdf:Property ;
    rdfs:label 'Points Redeemed Total' ;
    rdfs:comment 'Cumulative total of points that have been redeemed from the account.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programSponsor rdf:type rdf:Property ;
    rdfs:label 'Program Sponsor' ;
    rdfs:comment 'Entity (e.g., bank, merchant, brand) that sponsors the loyalty program.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardRedemptionEligibility rdf:type rdf:Property ;
    rdfs:label 'Reward Redemption Eligibility' ;
    rdfs:comment 'Indicates whether the account currently meets all criteria to redeem rewards.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rewardRedemptionEligibilityReason rdf:type rdf:Property ;
    rdfs:label 'Reward Redemption Eligibility Reason' ;
    rdfs:comment 'Human-readable explanation why the account is or is not eligible for redemption.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Tier Expiry Date' ;
    rdfs:comment 'Date when the current tier status expires if not renewed.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierPointsThreshold rdf:type rdf:Property ;
    rdfs:label 'Tier Points Threshold' ;
    rdfs:comment 'Number of points required to attain or maintain the current tier.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Date' ;
    rdfs:comment 'Date on which the account qualified for its current tier.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierQualificationMethod rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Method' ;
    rdfs:comment 'Mechanism by which the account qualified for its current tier.' ;
    rdfs:domain ind:LoyaltyAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Transaction Id' ;
    rdfs:comment 'Unique identifier for the loyalty transaction record.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:locationCity rdf:type rdf:Property ;
    rdfs:label 'Location City' ;
    rdfs:comment 'City name of the transaction\'s geographic origin.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monetaryEquivalent rdf:type rdf:Property ;
    rdfs:label 'Monetary Equivalent' ;
    rdfs:comment 'Monetary value of the points transacted, expressed in the transaction currency.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsAmount rdf:type rdf:Property ;
    rdfs:label 'Points Amount' ;
    rdfs:comment 'Number of loyalty points earned (positive) or redeemed/adjusted (negative) in this transaction.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Points Balance After' ;
    rdfs:comment 'Loyalty points balance of the account after this transaction is applied.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Points Balance Before' ;
    rdfs:comment 'Loyalty points balance of the account prior to this transaction.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programRuleName rdf:type rdf:Property ;
    rdfs:label 'Program Rule Name' ;
    rdfs:comment 'Descriptive name of the rule that governed point accrual or redemption.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Fee Currency' ;
    rdfs:comment 'Currency of the transaction fee, expressed as ISO 4217 code.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nfcTapEventId rdf:type rdf:Property ;
    rdfs:label 'Nfc Tap Event Id' ;
    rdfs:comment 'Unique identifier for each NFC tap interaction record.' ;
    rdfs:domain ind:NfcTapEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cryptogramValue rdf:type rdf:Property ;
    rdfs:label 'Cryptogram Value' ;
    rdfs:comment 'Masked representation of the cryptogram generated for the transaction, stored for audit and fraud analysis.' ;
    rdfs:domain ind:NfcTapEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tapResult rdf:type rdf:Property ;
    rdfs:label 'Tap Result' ;
    rdfs:comment 'Outcome of the tap attempt as reported by the terminal.' ;
    rdfs:domain ind:NfcTapEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tap Timestamp' ;
    rdfs:comment 'Exact date and time when the NFC tap was captured.' ;
    rdfs:domain ind:NfcTapEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:p2pTransferId rdf:type rdf:Property ;
    rdfs:label 'P2p Transfer Id' ;
    rdfs:comment 'System-generated unique identifier for the P2P transfer record.' ;
    rdfs:domain ind:P2pTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryP2pDigitalWalletId rdf:type rdf:Property ;
    rdfs:label 'Primary P2p Digital Wallet Id' ;
    rdfs:comment 'Unique identifier of the wallet from which funds are debited.' ;
    rdfs:domain ind:P2pTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalWallet .

ind:externalTransferReference rdf:type rdf:Property ;
    rdfs:label 'External Transfer Reference' ;
    rdfs:comment 'External or partner-provided reference number for the transfer, if any.' ;
    rdfs:domain ind:P2pTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientIdentifier rdf:type rdf:Property ;
    rdfs:label 'Recipient Identifier' ;
    rdfs:comment 'Value of the recipient identifier (e.g., phone number, email address, UPI VPA, or wallet ID).' ;
    rdfs:domain ind:P2pTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientIdentifierType rdf:type rdf:Property ;
    rdfs:label 'Recipient Identifier Type' ;
    rdfs:comment 'Method used to identify the recipient (phone number, email address, UPI VPA, or internal wallet ID).' ;
    rdfs:domain ind:P2pTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrencePattern rdf:type rdf:Property ;
    rdfs:label 'Recurrence Pattern' ;
    rdfs:comment 'Pattern defining how a recurring transfer repeats.' ;
    rdfs:domain ind:P2pTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Timestamp' ;
    rdfs:comment 'Planned execution time for a scheduled transfer; null for instant transfers.' ;
    rdfs:domain ind:P2pTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transferAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Amount' ;
    rdfs:comment 'Principal amount transferred between wallets, before fees.' ;
    rdfs:domain ind:P2pTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle state of the transfer.' ;
    rdfs:domain ind:P2pTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Indicates whether the transfer is immediate, scheduled for a future date, or part of a recurring series.' ;
    rdfs:domain ind:P2pTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panAliasId rdf:type rdf:Property ;
    rdfs:label 'Pan Alias Id' ;
    rdfs:comment 'Unique surrogate identifier for the PAN alias record.' ;
    rdfs:domain ind:PanAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aliasDescription rdf:type rdf:Property ;
    rdfs:label 'Alias Description' ;
    rdfs:comment 'Human-readable description or notes about the alias purpose or usage.' ;
    rdfs:domain ind:PanAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aliasPurpose rdf:type rdf:Property ;
    rdfs:label 'Alias Purpose' ;
    rdfs:comment 'Intended business use of the alias, such as customer-facing display, statement line, receipt line, or internal processing.' ;
    rdfs:domain ind:PanAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aliasType rdf:type rdf:Property ;
    rdfs:label 'Alias Type' ;
    rdfs:comment 'Category of the alias representation, e.g., masked PAN, last four digits, display token, or reference number.' ;
    rdfs:domain ind:PanAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aliasValue rdf:type rdf:Property ;
    rdfs:label 'Alias Value' ;
    rdfs:comment 'The actual alias string presented to downstream systems; may be a masked PAN, last-four digits, token, or reference number.' ;
    rdfs:domain ind:PanAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPciCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Pci Compliant' ;
    rdfs:comment 'True if the alias complies with PCI DSS requirements for storage and display.' ;
    rdfs:domain ind:PanAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRestrictedAlias rdf:type rdf:Property ;
    rdfs:label 'Is Restricted Alias' ;
    rdfs:comment 'True if the alias is subject to additional access controls or usage limits.' ;
    rdfs:domain ind:PanAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTestAlias rdf:type rdf:Property ;
    rdfs:label 'Is Test Alias' ;
    rdfs:comment 'Indicates whether the alias is used for testing or sandbox environments.' ;
    rdfs:domain ind:PanAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:panAliasStatus rdf:type rdf:Property ;
    rdfs:label 'Pan Alias Status' ;
    rdfs:comment 'Current lifecycle state of the alias.' ;
    rdfs:domain ind:PanAlias ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkBrand rdf:type rdf:Property ;
    rdfs:label 'Network Brand' ;
    rdfs:comment 'Underlying interchange network used for transaction routing.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentInstrumentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Instrument Status' ;
    rdfs:comment 'Current lifecycle state of the instrument.' ;
    rdfs:domain ind:PaymentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinManagementId rdf:type rdf:Property ;
    rdfs:label 'Pin Management Id' ;
    rdfs:comment 'Unique surrogate key for each PIN lifecycle record.' ;
    rdfs:domain ind:PinManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pinBlockFormat rdf:type rdf:Property ;
    rdfs:label 'Pin Block Format' ;
    rdfs:comment 'Format used to encrypt the PIN as defined by ISO 9564.' ;
    rdfs:domain ind:PinManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinBlockedFlag rdf:type rdf:Property ;
    rdfs:label 'Pin Blocked Flag' ;
    rdfs:comment 'Indicates whether the PIN is currently blocked due to exceeded attempts.' ;
    rdfs:domain ind:PinManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pinBlockedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pin Blocked Timestamp' ;
    rdfs:comment 'Date and time when the PIN became blocked.' ;
    rdfs:domain ind:PinManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pinChangeCount rdf:type rdf:Property ;
    rdfs:label 'Pin Change Count' ;
    rdfs:comment 'Total number of times the PIN has been changed since creation.' ;
    rdfs:domain ind:PinManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pinComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Pin Compliance Status' ;
    rdfs:comment 'Compliance assessment of the PIN against PCI and regulatory rules.' ;
    rdfs:domain ind:PinManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinEncryptionAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Pin Encryption Algorithm' ;
    rdfs:comment 'Cryptographic algorithm used to protect the PIN block.' ;
    rdfs:domain ind:PinManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinFailedAttempts rdf:type rdf:Property ;
    rdfs:label 'Pin Failed Attempts' ;
    rdfs:comment 'Count of consecutive failed PIN entry attempts since last successful entry.' ;
    rdfs:domain ind:PinManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pinLabel rdf:type rdf:Property ;
    rdfs:label 'Pin Label' ;
    rdfs:comment 'Human-readable label for the PIN (e.g., "Primary PIN").' ;
    rdfs:domain ind:PinManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinLastChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pin Last Changed Timestamp' ;
    rdfs:comment 'Date and time of the most recent successful PIN change.' ;
    rdfs:domain ind:PinManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pinLastFailedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pin Last Failed Timestamp' ;
    rdfs:comment 'Date and time of the most recent failed PIN entry.' ;
    rdfs:domain ind:PinManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pinLastSuccessfulTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pin Last Successful Timestamp' ;
    rdfs:comment 'Date and time of the most recent successful PIN entry.' ;
    rdfs:domain ind:PinManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pinResetMethod rdf:type rdf:Property ;
    rdfs:label 'Pin Reset Method' ;
    rdfs:comment 'Channel used to reset the PIN.' ;
    rdfs:domain ind:PinManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinResetTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pin Reset Timestamp' ;
    rdfs:comment 'Date and time when the PIN was last reset.' ;
    rdfs:domain ind:PinManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pinSetTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pin Set Timestamp' ;
    rdfs:comment 'Date and time when the PIN was initially set for the instrument.' ;
    rdfs:domain ind:PinManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pinStatus rdf:type rdf:Property ;
    rdfs:label 'Pin Status' ;
    rdfs:comment 'Current lifecycle state of the PIN.' ;
    rdfs:domain ind:PinManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinTriesRemaining rdf:type rdf:Property ;
    rdfs:label 'Pin Tries Remaining' ;
    rdfs:comment 'Number of remaining allowed PIN entry attempts before the PIN is blocked.' ;
    rdfs:domain ind:PinManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pinType rdf:type rdf:Property ;
    rdfs:label 'Pin Type' ;
    rdfs:comment 'Classification of the PIN based on its usage scenario.' ;
    rdfs:domain ind:PinManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinVersion rdf:type rdf:Property ;
    rdfs:label 'Pin Version' ;
    rdfs:comment 'Version number of the PIN record for optimistic concurrency control.' ;
    rdfs:domain ind:PinManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:provisioningRequestId rdf:type rdf:Property ;
    rdfs:label 'Provisioning Request Id' ;
    rdfs:comment 'System-generated unique identifier for the provisioning request event.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalRequestReference rdf:type rdf:Property ;
    rdfs:label 'External Request Reference' ;
    rdfs:comment 'Identifier supplied by the originating system or partner for cross-system traceability.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTestRequest rdf:type rdf:Property ;
    rdfs:label 'Is Test Request' ;
    rdfs:comment 'True if the provisioning request was generated in a test or sandbox environment.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuerDecision rdf:type rdf:Property ;
    rdfs:label 'Issuer Decision' ;
    rdfs:comment 'Final decision returned by the issuing bank: approved, declined, or step-up required.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisioningMethod rdf:type rdf:Property ;
    rdfs:label 'Provisioning Method' ;
    rdfs:comment 'Operational path used for provisioning: green (standard), yellow (conditional), or red (exception) flow.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisioningRequestStatus rdf:type rdf:Property ;
    rdfs:label 'Provisioning Request Status' ;
    rdfs:comment 'Current lifecycle status of the provisioning request.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaOutcome rdf:type rdf:Property ;
    rdfs:label 'Sca Outcome' ;
    rdfs:comment 'Result of the SCA check required for the provisioning request.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepUpMethod rdf:type rdf:Property ;
    rdfs:label 'Step Up Method' ;
    rdfs:comment 'Method used to satisfy a step-up requirement: one-time password, biometric, or call-center verification.' ;
    rdfs:domain ind:ProvisioningRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qrCodeId rdf:type rdf:Property ;
    rdfs:label 'Qr Code Id' ;
    rdfs:comment 'System-generated unique identifier for each QR code record.' ;
    rdfs:domain ind:QrCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isTestCode rdf:type rdf:Property ;
    rdfs:label 'Is Test Code' ;
    rdfs:comment 'Indicates whether the QR code is generated for testing purposes.' ;
    rdfs:domain ind:QrCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastScannedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Scanned Timestamp' ;
    rdfs:comment 'Date-time of the most recent scan of the QR code.' ;
    rdfs:domain ind:QrCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qrCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Qr Code Status' ;
    rdfs:comment 'Current lifecycle status of the QR code.' ;
    rdfs:domain ind:QrCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qrCodeType rdf:type rdf:Property ;
    rdfs:label 'Qr Code Type' ;
    rdfs:comment 'Indicates whether the QR code is static (merchant), dynamic (transaction), or peer-to-peer.' ;
    rdfs:domain ind:QrCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qrVersion rdf:type rdf:Property ;
    rdfs:label 'Qr Version' ;
    rdfs:comment 'Version identifier of the QR code format or specification used.' ;
    rdfs:domain ind:QrCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanCount rdf:type rdf:Property ;
    rdfs:label 'Scan Count' ;
    rdfs:comment 'Number of times the QR code has been scanned.' ;
    rdfs:domain ind:QrCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageLimit rdf:type rdf:Property ;
    rdfs:label 'Usage Limit' ;
    rdfs:comment 'Maximum number of allowed scans before the QR code is automatically deactivated.' ;
    rdfs:domain ind:QrCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:schemeMessageId rdf:type rdf:Property ;
    rdfs:label 'Scheme Message Id' ;
    rdfs:comment 'Unique identifier for the scheme message record.' ;
    rdfs:domain ind:SchemeMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rawMessageUri rdf:type rdf:Property ;
    rdfs:label 'Raw Message Uri' ;
    rdfs:comment 'Pointer (URI) to the encrypted raw message payload stored in secure storage.' ;
    rdfs:domain ind:SchemeMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusCode rdf:type rdf:Property ;
    rdfs:label 'Status Code' ;
    rdfs:comment 'Standardized code representing the outcome or state of the message processing.' ;
    rdfs:domain ind:SchemeMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secureElementId rdf:type rdf:Property ;
    rdfs:label 'Secure Element Id' ;
    rdfs:comment 'Unique system-generated identifier for each secure element record.' ;
    rdfs:domain ind:SecureElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceEmvco rdf:type rdf:Property ;
    rdfs:label 'Compliance Emvco' ;
    rdfs:comment 'True if the secure element complies with EMVCo standards.' ;
    rdfs:domain ind:SecureElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cryptographicKeySetReference rdf:type rdf:Property ;
    rdfs:label 'Cryptographic Key Set Reference' ;
    rdfs:comment 'Reference identifier for the set of cryptographic keys associated with the secure element.' ;
    rdfs:domain ind:SecureElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decommission Timestamp' ;
    rdfs:comment 'Date-time when the secure element was retired or decommissioned.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Device Identifier' ;
    rdfs:comment 'Unique identifier of the mobile device hosting the secure element (e.g., IMEI).' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTestSe rdf:type rdf:Property ;
    rdfs:label 'Is Test Se' ;
    rdfs:comment 'True if the record represents a test or sandbox secure element.' ;
    rdfs:domain ind:SecureElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keySetExpiry rdf:type rdf:Property ;
    rdfs:label 'Key Set Expiry' ;
    rdfs:comment 'Date on which the current key set expires and must be rotated.' ;
    rdfs:domain ind:SecureElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:keySetVersion rdf:type rdf:Property ;
    rdfs:label 'Key Set Version' ;
    rdfs:comment 'Version label of the cryptographic key set.' ;
    rdfs:domain ind:SecureElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastProvisionedBy rdf:type rdf:Property ;
    rdfs:label 'Last Provisioned By' ;
    rdfs:comment 'Identifier of the user or system that performed the last provisioning action.' ;
    rdfs:domain ind:SecureElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastProvisionedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Provisioned Timestamp' ;
    rdfs:comment 'Date-time of the most recent provisioning event.' ;
    rdfs:domain ind:SecureElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:provisioningStatus rdf:type rdf:Property ;
    rdfs:label 'Provisioning Status' ;
    rdfs:comment 'Current status of the secure element provisioning workflow.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisioningTimestamp rdf:type rdf:Property ;
