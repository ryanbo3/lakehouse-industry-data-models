    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pendingCredits rdf:type rdf:Property ;
    rdfs:label 'Pending Credits' ;
    rdfs:comment 'Sum of credit amounts that are authorized but not yet finalised.' ;
    rdfs:domain ind:NostroBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pendingDebits rdf:type rdf:Property ;
    rdfs:label 'Pending Debits' ;
    rdfs:comment 'Sum of debit amounts that are authorized but not yet finalised.' ;
    rdfs:domain ind:NostroBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCorridorId rdf:type rdf:Property ;
    rdfs:label 'Payment Corridor Id' ;
    rdfs:comment 'Unique system-generated identifier for the payment corridor record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentCorridor .

ind:sourceCountryId rdf:type rdf:Property ;
    rdfs:label 'Source Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Payment corridor reporting requires the source country to be a foreign key to the country master for regulatory stats.' ;
    rdfs:domain ind:PaymentCorridor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:currencyConversionAllowed rdf:type rdf:Property ;
    rdfs:label 'Currency Conversion Allowed' ;
    rdfs:comment 'Flag indicating whether automatic currency conversion is permitted for this corridor.' ;
    rdfs:domain ind:PaymentCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dccSupported rdf:type rdf:Property ;
    rdfs:label 'Dcc Supported' ;
    rdfs:comment 'Indicates if DCC (Dynamic Currency Conversion) is offered for transactions in this corridor.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationBankCodes rdf:type rdf:Property ;
    rdfs:label 'Destination Bank Codes' ;
    rdfs:comment 'Comma-separated list of BIC codes of banks in the destination country that can receive payments.' ;
    rdfs:domain ind:PaymentCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryIso rdf:type rdf:Property ;
    rdfs:label 'Destination Country Iso' ;
    rdfs:comment 'Three-letter ISO code of the destination country for the corridor.' ;
    rdfs:domain ind:PaymentCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCurrencyCodes rdf:type rdf:Property ;
    rdfs:label 'Destination Currency Codes' ;
    rdfs:comment 'Comma-separated list of ISO 4217 currency codes that can be received in this corridor.' ;
    rdfs:domain ind:PaymentCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedSettlementTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Settlement Time Minutes' ;
    rdfs:comment 'Typical time in minutes from transaction initiation to settlement for this corridor.' ;
    rdfs:domain ind:PaymentCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ofacScreeningRequired rdf:type rdf:Property ;
    rdfs:label 'Ofac Screening Required' ;
    rdfs:comment 'Indicates whether OFAC or other sanctions screening must be performed for transactions in this corridor.' ;
    rdfs:domain ind:PaymentCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentCorridorDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Corridor Description' ;
    rdfs:comment 'Human-readable description of the corridor, including any special handling notes.' ;
    rdfs:domain ind:PaymentCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentCorridorStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Corridor Status' ;
    rdfs:comment 'Current lifecycle status of the corridor.' ;
    rdfs:domain ind:PaymentCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentCorridorType rdf:type rdf:Property ;
    rdfs:label 'Payment Corridor Type' ;
    rdfs:comment 'Business classification of the corridor based on usage or risk profile.' ;
    rdfs:domain ind:PaymentCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRestrictions rdf:type rdf:Property ;
    rdfs:label 'Regulatory Restrictions' ;
    rdfs:comment 'Textual description of any regulatory or compliance constraints that apply to the corridor (e.g., AML limits, country sanctions).' ;
    rdfs:domain ind:PaymentCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceBankCodes rdf:type rdf:Property ;
    rdfs:label 'Source Bank Codes' ;
    rdfs:comment 'Comma-separated list of BIC codes of banks in the source country that can originate payments.' ;
    rdfs:domain ind:PaymentCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceCurrencyCodes rdf:type rdf:Property ;
    rdfs:label 'Source Currency Codes' ;
    rdfs:comment 'Comma-separated list of ISO 4217 currency codes that can be originated in this corridor.' ;
    rdfs:domain ind:PaymentCorridor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedPaymentRails rdf:type rdf:Property ;
    rdfs:label 'Supported Payment Rails' ;
    rdfs:comment 'Payment rail(s) available for routing transactions through this corridor.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psd2FxDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Psd2 Fx Disclosure Id' ;
    rdfs:comment 'System-generated unique identifier for each PSD2 FX disclosure record.' ;
    rdfs:domain ind:Psd2FxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardholderAcknowledgementStatus rdf:type rdf:Property ;
    rdfs:label 'Cardholder Acknowledgement Status' ;
    rdfs:comment 'Result of the cardholder\'s interaction with the disclosure (acknowledged, declined, or not shown).' ;
    rdfs:domain ind:Psd2FxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureChannel rdf:type rdf:Property ;
    rdfs:label 'Disclosure Channel' ;
    rdfs:comment 'Medium through which the FX disclosure was presented (online, mobile app, or POS terminal).' ;
    rdfs:domain ind:Psd2FxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureReference rdf:type rdf:Property ;
    rdfs:label 'Disclosure Reference' ;
    rdfs:comment 'Business-visible reference code for the FX disclosure presented to the payer.' ;
    rdfs:domain ind:Psd2FxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disclosure Timestamp' ;
    rdfs:comment 'Exact date-time when the FX rate and fee disclosure was presented to the payer.' ;
    rdfs:domain ind:Psd2FxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disclosureVersion rdf:type rdf:Property ;
    rdfs:label 'Disclosure Version' ;
    rdfs:comment 'Version identifier of the disclosure template or rule set used.' ;
    rdfs:domain ind:Psd2FxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRecipientAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Recipient Amount' ;
    rdfs:comment 'Projected amount the payee will receive after conversion, expressed in the recipient\'s currency.' ;
    rdfs:domain ind:Psd2FxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Timestamp' ;
    rdfs:comment 'Date-time when the FX rate was retrieved from the source.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:feeAmountDisclosed rdf:type rdf:Property ;
    rdfs:label 'Fee Amount Disclosed' ;
    rdfs:comment 'Total fee amount disclosed alongside the FX rate, expressed in payer currency.' ;
    rdfs:domain ind:Psd2FxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:midMarketRateShown rdf:type rdf:Property ;
    rdfs:label 'Mid Market Rate Shown' ;
    rdfs:comment 'Mid-market exchange rate displayed to the payer before the transaction.' ;
    rdfs:domain ind:Psd2FxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:psd2FxDisclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Psd2 Fx Disclosure Status' ;
    rdfs:comment 'Current processing state of the disclosure record.' ;
    rdfs:domain ind:Psd2FxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalChargesDisclosed rdf:type rdf:Property ;
    rdfs:label 'Total Charges Disclosed' ;
    rdfs:comment 'Aggregate amount (in payer currency) of all fees and margins disclosed alongside the FX rate.' ;
    rdfs:domain ind:Psd2FxDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataFormat rdf:type rdf:Property ;
    rdfs:label 'Data Format' ;
    rdfs:comment 'File or message format in which rates are delivered.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionProtocol rdf:type rdf:Property ;
    rdfs:label 'Encryption Protocol' ;
    rdfs:comment 'Specific encryption protocol negotiated for the feed connection.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failoverPriority rdf:type rdf:Property ;
    rdfs:label 'Failover Priority' ;
    rdfs:comment 'Rank used to select an alternate feed when the primary feed is unavailable (lower = higher priority).' ;
    rdfs:domain ind:RateFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feedEndpoint rdf:type rdf:Property ;
    rdfs:label 'Feed Endpoint' ;
    rdfs:comment 'Network address (URL, host:port, or file path) where the rate feed is accessed.' ;
    rdfs:domain ind:RateFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedProtocol rdf:type rdf:Property ;
    rdfs:label 'Feed Protocol' ;
    rdfs:comment 'Technical protocol through which the FX rates are delivered to the platform.' ;
    rdfs:domain ind:RateFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEncrypted rdf:type rdf:Property ;
    rdfs:label 'Is Encrypted' ;
    rdfs:comment 'True if the feed connection uses encryption (TLS/SSH).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastErrorCode rdf:type rdf:Property ;
    rdfs:label 'Last Error Code' ;
    rdfs:comment 'Standardized code identifying the reason for the most recent feed failure.' ;
    rdfs:domain ind:RateFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Last Error Message' ;
    rdfs:comment 'Detailed message describing the most recent feed retrieval error.' ;
    rdfs:domain ind:RateFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFailureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Failure Timestamp' ;
    rdfs:comment 'Date-time of the most recent poll that resulted in an error.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastSuccessTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Success Timestamp' ;
    rdfs:comment 'Date-time of the last successful poll of the external rate feed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pollingFrequencySeconds rdf:type rdf:Property ;
    rdfs:label 'Polling Frequency Seconds' ;
    rdfs:comment 'How often the platform requests new rates from the provider.' ;
    rdfs:domain ind:RateFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:providerCode rdf:type rdf:Property ;
    rdfs:label 'Provider Code' ;
    rdfs:comment 'Unique business code assigned to the provider for contract and reporting purposes.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerName rdf:type rdf:Property ;
    rdfs:label 'Provider Name' ;
    rdfs:comment 'Human-readable name of the external FX rate feed provider (e.g., Reuters Refinitiv, Bloomberg FX).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateFeedDescription rdf:type rdf:Property ;
    rdfs:label 'Rate Feed Description' ;
    rdfs:comment 'Narrative description providing context, notes, or special handling instructions for the feed.' ;
    rdfs:domain ind:RateFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateFeedStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Feed Status' ;
    rdfs:comment 'Lifecycle state of the rate feed configuration.' ;
    rdfs:domain ind:RateFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Ms' ;
    rdfs:comment 'Target maximum latency for a successful feed retrieval as defined in the provider SLA.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaUptimePercent rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Percent' ;
    rdfs:comment 'Minimum acceptable availability of the feed over a month, expressed as a percent.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportedCurrencyPairs rdf:type rdf:Property ;
    rdfs:label 'Supported Currency Pairs' ;
    rdfs:comment 'List of currency pairs (e.g., EUR/USD, GBP/JPY) that the feed supplies.' ;
    rdfs:domain ind:RateFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier (e.g., UTC, Europe/London) used for timestamps supplied by the provider.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRateEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Rate Employee Id' ;
    rdfs:comment 'Identifier of the internal user who approved the configuration.' ;
    rdfs:domain ind:RateMarginConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableRegionCode rdf:type rdf:Property ;
    rdfs:label 'Applicable Region Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 code of the region where the margin applies. [ENUM-REF-CANDIDATE: USA|GBR|FRA|DEU|JPN|CHN|IND|BRA|CAN|AUS|... — promote to reference product]' ;
    rdfs:domain ind:RateMarginConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditComment rdf:type rdf:Property ;
    rdfs:label 'Audit Comment' ;
    rdfs:comment 'Free-text field for audit notes or change justification.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseRateSourceCode rdf:type rdf:Property ;
    rdfs:label 'Base Rate Source Code' ;
    rdfs:comment 'Identifier of the source providing the underlying interbank rate.' ;
    rdfs:domain ind:RateMarginConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerTierCode rdf:type rdf:Property ;
    rdfs:label 'Customer Tier Code' ;
    rdfs:comment 'Segment of customers (e.g., platinum, gold) for which the margin is defined.' ;
