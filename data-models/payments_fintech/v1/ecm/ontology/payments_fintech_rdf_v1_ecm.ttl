    rdfs:range ind:RateFeed .

ind:collateralAmount rdf:type rdf:Property ;
    rdfs:label 'Collateral Amount' ;
    rdfs:comment 'Amount of collateral posted for the contract.' ;
    rdfs:domain ind:ForwardContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Collateral Currency Code' ;
    rdfs:comment 'Currency of the posted collateral.' ;
    rdfs:domain ind:ForwardContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralRequired rdf:type rdf:Property ;
    rdfs:label 'Collateral Required' ;
    rdfs:comment 'Indicates if collateral is required for the contract.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Unique external reference code for the FX forward contract.' ;
    rdfs:domain ind:ForwardContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle status of the FX forward contract.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractVersion rdf:type rdf:Property ;
    rdfs:label 'Contract Version' ;
    rdfs:comment 'Version number of the contract record for amendment tracking.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forwardPoints rdf:type rdf:Property ;
    rdfs:label 'Forward Points' ;
    rdfs:comment 'Difference between forward and spot rates expressed in points.' ;
    rdfs:domain ind:ForwardContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forwardRate rdf:type rdf:Property ;
    rdfs:label 'Forward Rate' ;
    rdfs:comment 'Agreed exchange rate for settlement on the value date.' ;
    rdfs:domain ind:ForwardContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedgeDesignation rdf:type rdf:Property ;
    rdfs:label 'Hedge Designation' ;
    rdfs:comment 'Accounting hedge classification per IFRS 9/ASC 815.' ;
    rdfs:domain ind:ForwardContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalAccountingCode rdf:type rdf:Property ;
    rdfs:label 'Internal Accounting Code' ;
    rdfs:comment 'Internal accounting code used for GL posting.' ;
    rdfs:domain ind:ForwardContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCrossBorder rdf:type rdf:Property ;
    rdfs:label 'Is Cross Border' ;
    rdfs:comment 'True if the contract involves cross-border currency exchange.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maturityDate rdf:type rdf:Property ;
    rdfs:label 'Maturity Date' ;
    rdfs:comment 'Date when the contract expires if not settled earlier.' ;
    rdfs:domain ind:ForwardContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notionalAmount rdf:type rdf:Property ;
    rdfs:label 'Notional Amount' ;
    rdfs:comment 'Principal amount of the base currency to be exchanged.' ;
    rdfs:domain ind:ForwardContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementInstructions rdf:type rdf:Property ;
    rdfs:label 'Settlement Instructions' ;
    rdfs:comment 'Textual instructions for settlement (e.g., bank account, SWIFT details).' ;
    rdfs:domain ind:Fx ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotRateAtInception rdf:type rdf:Property ;
    rdfs:label 'Spot Rate At Inception' ;
    rdfs:comment 'Spot exchange rate observed at contract initiation.' ;
    rdfs:domain ind:ForwardContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateFeedId rdf:type rdf:Property ;
    rdfs:label 'Rate Feed Id' ;
    rdfs:comment 'Foreign key linking to fx.rate_feed. Business justification: fx_rate records are produced by a specific rate feed and belong to a currency pair; linking removes duplicated source fields and enables traceability to the feed and pair.' ;
    rdfs:domain ind:Fx ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateFeed .

ind:askPrice rdf:type rdf:Property ;
    rdfs:label 'Ask Price' ;
    rdfs:comment 'Price at which the market maker is willing to sell the base currency.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseCurrency rdf:type rdf:Property ;
    rdfs:label 'Base Currency' ;
    rdfs:comment 'Currency being quoted (the numerator in the pair).' ;
    rdfs:domain ind:Fx ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidPrice rdf:type rdf:Property ;
    rdfs:label 'Bid Price' ;
    rdfs:comment 'Price at which the market maker is willing to buy the base currency.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'Provider-assigned confidence level (0-100) indicating reliability of the rate.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossBorderIndicator rdf:type rdf:Property ;
    rdfs:label 'Cross Border Indicator' ;
    rdfs:comment 'True if the rate is used for a cross-border transaction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalRateCode rdf:type rdf:Property ;
    rdfs:label 'External Rate Code' ;
    rdfs:comment 'Reference code used by the external provider to identify this specific rate.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketRegion rdf:type rdf:Property ;
    rdfs:label 'Market Region' ;
    rdfs:comment 'Geographic region of the market where the rate is sourced or applied.' ;
    rdfs:domain ind:Fx ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:midPrice rdf:type rdf:Property ;
    rdfs:label 'Mid Price' ;
    rdfs:comment 'Average of bid and ask prices; often used as the reference rate.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precision rdf:type rdf:Property ;
    rdfs:label 'Precision' ;
    rdfs:comment 'Number of decimal places provided for the rate value.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quoteCurrency rdf:type rdf:Property ;
    rdfs:label 'Quote Currency' ;
    rdfs:comment 'Currency used to express the rate (the denominator in the pair).' ;
    rdfs:domain ind:Fx ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the FX rate indicating its purpose and calculation method.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateValue rdf:type rdf:Property ;
    rdfs:label 'Rate Value' ;
    rdfs:comment 'Primary exchange rate value expressed as the amount of quote currency per one unit of base currency.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spread rdf:type rdf:Property ;
    rdfs:label 'Spread' ;
    rdfs:comment 'Difference between ask and bid prices, expressed in quote currency units.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isEstimated rdf:type rdf:Property ;
    rdfs:label 'Is Estimated' ;
    rdfs:comment 'True if the rates are derived estimates rather than directly observed market rates.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateFeedVersion rdf:type rdf:Property ;
    rdfs:label 'Rate Feed Version' ;
    rdfs:comment 'Version string of the rate feed used for this snapshot.' ;
    rdfs:domain ind:RateSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePrecision rdf:type rdf:Property ;
    rdfs:label 'Rate Precision' ;
    rdfs:comment 'Number of decimal places used to represent the rates for this currency pair.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:settlementCurrency rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency' ;
    rdfs:comment 'Currency in which the transaction settlement will be performed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapshotType rdf:type rdf:Property ;
    rdfs:label 'Snapshot Type' ;
    rdfs:comment 'Classification of the snapshot: end-of-day (EOD), intraday, or regulatory reporting.' ;
    rdfs:domain ind:RateSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceFeedSessionReference rdf:type rdf:Property ;
    rdfs:label 'Source Feed Session Reference' ;
    rdfs:comment 'Identifier of the feed session that produced this snapshot.' ;
    rdfs:domain ind:RateSnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fxReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Fx Reconciliation Id' ;
    rdfs:comment 'System-generated unique identifier for each FX reconciliation record.' ;
    rdfs:domain ind:FxReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reconcilerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reconciler Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Reconciliation tasks are assigned to a treasury analyst; audit trail requires analyst identifier.' ;
    rdfs:domain ind:FxReconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Audit Created By' ;
    rdfs:comment 'User or system account that created the reconciliation record.' ;
    rdfs:domain ind:FxReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Audit Updated By' ;
    rdfs:comment 'User or system account that last updated the reconciliation record.' ;
    rdfs:domain ind:FxReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedAmount rdf:type rdf:Property ;
    rdfs:label 'Confirmed Amount' ;
    rdfs:comment 'FX amount confirmed by external counterparties (e.g., correspondent bank) in quote currency.' ;
    rdfs:domain ind:FxReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyPair rdf:type rdf:Property ;
    rdfs:label 'Currency Pair' ;
    rdfs:comment 'Currency pair in ISO format (e.g., USD/EUR) for the conversion being reconciled.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateUsed rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Used' ;
    rdfs:comment 'FX rate applied to convert the base amount to the quote amount for this reconciliation.' ;
    rdfs:domain ind:FxReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedAmount rdf:type rdf:Property ;
    rdfs:label 'Expected Amount' ;
    rdfs:comment 'FX amount that the internal system expects after conversion, expressed in quote currency.' ;
    rdfs:domain ind:FxReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fxReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Fx Reconciliation Status' ;
    rdfs:comment 'Current status of the reconciliation record.' ;
    rdfs:domain ind:FxReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTest rdf:type rdf:Property ;
    rdfs:label 'Is Test' ;
    rdfs:comment 'Flag indicating whether the record originates from a test or production environment.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingTimeMs rdf:type rdf:Property ;
    rdfs:label 'Processing Time Ms' ;
    rdfs:comment 'Elapsed time in milliseconds for the reconciliation process to complete.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date on which the FX reconciliation was performed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportIndicator rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Indicator' ;
    rdfs:comment 'True if this reconciliation must be included in regulatory reporting (e.g., AML, SAR).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Action taken to resolve a variance or discrepancy.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runReference rdf:type rdf:Property ;
    rdfs:label 'Run Reference' ;
    rdfs:comment 'External reference code for the reconciliation run, used for audit and reporting.' ;
    rdfs:domain ind:FxReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Total Transaction Amount' ;
    rdfs:comment 'Aggregate amount of all original transaction amounts before conversion, expressed in base currency.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Difference between expected and confirmed amounts (expected – confirmed).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Variance expressed as a percentage of the expected amount.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Code indicating why a variance occurred.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ibanRoutingId rdf:type rdf:Property ;
    rdfs:label 'Iban Routing Id' ;
    rdfs:comment 'System-generated unique identifier for each IBAN routing rule record.' ;
    rdfs:domain ind:IbanRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountNumberEndPosition rdf:type rdf:Property ;
    rdfs:label 'Account Number End Position' ;
    rdfs:comment 'Zero-based end index (inclusive) of the account number segment within the BBAN.' ;
    rdfs:domain ind:IbanRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountNumberStartPosition rdf:type rdf:Property ;
    rdfs:label 'Account Number Start Position' ;
    rdfs:comment 'Zero-based start index of the account number segment within the BBAN.' ;
    rdfs:domain ind:IbanRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankIdEndPosition rdf:type rdf:Property ;
    rdfs:label 'Bank Id End Position' ;
    rdfs:comment 'Zero-based end index (inclusive) of the national bank identifier within the BBAN.' ;
    rdfs:domain ind:IbanRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankIdStartPosition rdf:type rdf:Property ;
    rdfs:label 'Bank Id Start Position' ;
    rdfs:comment 'Zero-based start index of the national bank identifier within the BBAN.' ;
    rdfs:domain ind:IbanRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bbanPattern rdf:type rdf:Property ;
    rdfs:label 'Bban Pattern' ;
    rdfs:comment 'Regular-expression pattern describing the BBAN structure (excluding country code and check digits).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchCodeEndPosition rdf:type rdf:Property ;
    rdfs:label 'Branch Code End Position' ;
    rdfs:comment 'Zero-based end index (inclusive) of the branch code segment within the BBAN.' ;
    rdfs:domain ind:IbanRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:branchCodeStartPosition rdf:type rdf:Property ;
    rdfs:label 'Branch Code Start Position' ;
    rdfs:comment 'Zero-based start index of the branch code segment within the BBAN, if applicable.' ;
    rdfs:domain ind:IbanRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkDigitAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Check Digit Algorithm' ;
    rdfs:comment 'Algorithm used to calculate and validate the IBAN check digits.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ibanExample rdf:type rdf:Property ;
    rdfs:label 'Iban Example' ;
    rdfs:comment 'A valid example IBAN for the country, useful for testing and documentation.' ;
    rdfs:domain ind:IbanRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ibanLength rdf:type rdf:Property ;
    rdfs:label 'Iban Length' ;
    rdfs:comment 'Total number of characters in a valid IBAN for the country.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ibanRoutingStatus rdf:type rdf:Property ;
    rdfs:label 'Iban Routing Status' ;
    rdfs:comment 'Current lifecycle status of the routing rule (active, inactive, or deprecated).' ;
    rdfs:domain ind:IbanRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingBic rdf:type rdf:Property ;
    rdfs:label 'Routing Bic' ;
    rdfs:comment 'SWIFT BIC of the primary correspondent bank used for routing payments to this country.' ;
    rdfs:domain ind:IbanRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sepaMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Sepa Member Flag' ;
    rdfs:comment 'Indicates whether the country participates in the Single Euro Payments Area (true = member).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liquidityPositionId rdf:type rdf:Property ;
    rdfs:label 'Liquidity Position Id' ;
    rdfs:comment 'Unique identifier for the liquidity position record.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Flag' ;
    rdfs:comment 'Indicates whether net liquidity fell below the minimum threshold.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:committedOutflows rdf:type rdf:Property ;
    rdfs:label 'Committed Outflows' ;
    rdfs:comment 'Total amount of pending outbound cross-border payments.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedInflows rdf:type rdf:Property ;
    rdfs:label 'Expected Inflows' ;
    rdfs:comment 'Total amount of incoming settlements expected.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumLiquidityThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Liquidity Threshold' ;
    rdfs:comment 'Configured minimum liquidity threshold for the currency.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netAvailableLiquidity rdf:type rdf:Property ;
    rdfs:label 'Net Available Liquidity' ;
    rdfs:comment 'Net liquidity after accounting for outflows and inflows.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Position Timestamp' ;
    rdfs:comment 'Timestamp when the liquidity position snapshot was recorded.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current lifecycle status of the liquidity position record.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAvailableBalance rdf:type rdf:Property ;
    rdfs:label 'Total Available Balance' ;
    rdfs:comment 'Aggregate available balance across all nostro accounts for the currency.' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treasuryActionTaken rdf:type rdf:Property ;
    rdfs:label 'Treasury Action Taken' ;
    rdfs:comment 'Action taken by treasury in response to liquidity breach or status (e.g., pre-funding, hold).' ;
    rdfs:domain ind:LiquidityPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multicurrencySettlementId rdf:type rdf:Property ;
    rdfs:label 'Multicurrency Settlement Id' ;
    rdfs:comment 'System-generated unique identifier for the multicurrency settlement record.' ;
    rdfs:domain ind:MulticurrencySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchCreationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Batch Creation Timestamp' ;
    rdfs:comment 'Timestamp when the settlement batch record was initially created in the processing system.' ;
    rdfs:domain ind:MulticurrencySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchProcessingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Batch Processing Timestamp' ;
    rdfs:comment 'Timestamp when the batch was sent to the settlement rail for execution.' ;
    rdfs:domain ind:MulticurrencySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:correspondentBankSwiftCode rdf:type rdf:Property ;
    rdfs:label 'Correspondent Bank Swift Code' ;
    rdfs:comment 'SWIFT/BIC identifier of the correspondent bank used for the settlement.' ;
    rdfs:domain ind:MulticurrencySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRatePrecision rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Precision' ;
    rdfs:comment 'Number of decimal places used for the FX rate.' ;
    rdfs:domain ind:MulticurrencySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exchangeRateSource rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Source' ;
    rdfs:comment 'Source system or provider that supplied the FX rate.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Settlement Amount' ;
    rdfs:comment 'Total amount of the batch before FX conversion and fees, expressed in origination currency.' ;
    rdfs:domain ind:MulticurrencySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Settlement Amount' ;
    rdfs:comment 'Amount after FX conversion and deduction of fees, expressed in settlement currency.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nostroAccountDebited rdf:type rdf:Property ;
    rdfs:label 'Nostro Account Debited' ;
    rdfs:comment 'Account number of the fintech\'s Nostro account from which funds are debited.' ;
    rdfs:domain ind:MulticurrencySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originationCurrency rdf:type rdf:Property ;
    rdfs:label 'Origination Currency' ;
    rdfs:comment 'Currency of the original cross-border transaction(s) before conversion.' ;
    rdfs:domain ind:MulticurrencySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationReference rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Reference' ;
    rdfs:comment 'Reference to the external reconciliation file or message confirming settlement.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCurrencyMinorUnits rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Minor Units' ;
    rdfs:comment 'Number of minor units (e.g., cents) for the settlement currency.' ;
    rdfs:domain ind:MulticurrencySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:settlementEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Settlement Event Timestamp' ;
    rdfs:comment 'Timestamp when the settlement batch was executed in the payment rail.' ;
    rdfs:domain ind:MulticurrencySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementRail rdf:type rdf:Property ;
    rdfs:label 'Settlement Rail' ;
    rdfs:comment 'Payment rail used to move the settled funds.' ;
    rdfs:domain ind:MulticurrencySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementStatusReason rdf:type rdf:Property ;
    rdfs:label 'Settlement Status Reason' ;
    rdfs:comment 'Free-text explanation for the current settlement status, especially when failed or pending.' ;
    rdfs:domain ind:MulticurrencySettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nostroAccountId rdf:type rdf:Property ;
    rdfs:label 'Nostro Account Id' ;
    rdfs:comment 'Unique system-generated identifier for the nostro account record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NostroAccount .

ind:accountLabel rdf:type rdf:Property ;
    rdfs:label 'Account Label' ;
    rdfs:comment 'Human-friendly label or nickname for the account used in treasury dashboards.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountPurpose rdf:type rdf:Property ;
    rdfs:label 'Account Purpose' ;
    rdfs:comment 'Primary business purpose of the nostro account.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlWatchlistStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Watchlist Status' ;
    rdfs:comment 'Result of AML watchlist screening for the account.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableBalance rdf:type rdf:Property ;
    rdfs:label 'Available Balance' ;
    rdfs:comment 'Balance available for new transactions after holds and overdraft considerations.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date on which the nostro account was closed, if applicable.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cumulativeDailyAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Daily Amount' ;
    rdfs:comment 'Total value of transactions processed on the current day.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyTransactionLimit rdf:type rdf:Property ;
    rdfs:label 'Daily Transaction Limit' ;
    rdfs:comment 'Maximum aggregate transaction amount permitted per calendar day.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyUsagePercentage rdf:type rdf:Property ;
    rdfs:label 'Daily Usage Percentage' ;
    rdfs:comment 'Percentage of the daily transaction limit that has been used.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeSchedule rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule' ;
    rdfs:comment 'Description of fees applicable to the account.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPreFunded rdf:type rdf:Property ;
    rdfs:label 'Is Pre Funded' ;
    rdfs:comment 'Indicates whether the account is pre-funded for anticipated transactions.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Audit Timestamp' ;
    rdfs:comment 'Timestamp of the most recent audit performed on the account.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastReconciliationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Timestamp' ;
    rdfs:comment 'Timestamp of the most recent reconciliation with the correspondent bank statement.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastStatementDate rdf:type rdf:Property ;
    rdfs:label 'Last Statement Date' ;
    rdfs:comment 'Date of the most recent bank statement received for the account.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liquidityLimit rdf:type rdf:Property ;
    rdfs:label 'Liquidity Limit' ;
    rdfs:comment 'Maximum liquidity allocation permitted for the account.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBalanceThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Threshold' ;
    rdfs:comment 'Minimum balance that must be maintained to avoid fees or penalties.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nostroAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Nostro Account Status' ;
    rdfs:comment 'Operational status of the nostro account.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date on which the nostro account was opened with the correspondent bank.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openingBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Balance' ;
    rdfs:comment 'Balance of the account at the moment it was opened.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdraftLimit rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit' ;
    rdfs:comment 'Authorized overdraft amount for the account.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treasuryDesk rdf:type rdf:Property ;
    rdfs:label 'Treasury Desk' ;
    rdfs:comment 'Internal treasury desk responsible for managing the account.' ;
    rdfs:domain ind:NostroAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nostroBalanceId rdf:type rdf:Property ;
    rdfs:label 'Nostro Balance Id' ;
    rdfs:comment 'Unique identifier for each nostro balance snapshot record.' ;
    rdfs:domain ind:NostroBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:balanceStatus rdf:type rdf:Property ;
    rdfs:label 'Balance Status' ;
    rdfs:comment 'Indicates whether the snapshot has been reconciled against correspondent bank statements.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingBalance rdf:type rdf:Property ;
    rdfs:label 'Closing Balance' ;
    rdfs:comment 'Balance amount at the end of the value date, after all posted movements.' ;
