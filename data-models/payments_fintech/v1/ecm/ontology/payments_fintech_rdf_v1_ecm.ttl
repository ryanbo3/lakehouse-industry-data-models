    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:keyUsageLimit rdf:type rdf:Property ;
    rdfs:label 'Key Usage Limit' ;
    rdfs:comment 'Maximum allowed uses for the key before it must be replenished or rotated.' ;
    rdfs:domain ind:HceCredential ;
    rdf:type owl:DatatypeProperty ;
