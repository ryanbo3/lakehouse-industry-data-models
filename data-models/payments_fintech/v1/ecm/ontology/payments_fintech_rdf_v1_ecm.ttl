ind:reversalStatus rdf:type rdf:Property ;
    rdfs:label 'Reversal Status' ;
    rdfs:comment 'Current processing status of the reversal.' ;
    rdfs:domain ind:Reversal ;
    rdf:type owl:DatatypeProperty ;
