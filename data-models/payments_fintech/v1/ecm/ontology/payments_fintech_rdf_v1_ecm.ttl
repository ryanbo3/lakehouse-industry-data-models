    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalAttemptCount rdf:type rdf:Property ;
    rdfs:label 'Renewal Attempt Count' ;
    rdfs:comment 'Number of times renewal has been tried for this schedule.' ;
