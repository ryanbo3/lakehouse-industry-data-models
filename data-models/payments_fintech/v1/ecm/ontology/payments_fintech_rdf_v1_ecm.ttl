    rdfs:comment 'Average number of transactions per month for merchants in this category (historical baseline).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cardSchemeApplicability rdf:type rdf:Property ;
