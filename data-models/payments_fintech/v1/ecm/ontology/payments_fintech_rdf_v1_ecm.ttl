    rdfs:comment 'Comma-separated list of ISO-3166-1 alpha-2 country codes where the document type is accepted. [ENUM-REF-CANDIDATE: US|CA|GB|AU|DE|FR|JP|CN|IN|BR|... — promote to reference product]' ;
    rdfs:domain ind:KycDocumentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableProcesses rdf:type rdf:Property ;
    rdfs:label 'Applicable Processes' ;
    rdfs:comment 'Comma-separated list of business processes where this document type is used.' ;
    rdfs:domain ind:KycDocumentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPolicy rdf:type rdf:Property ;
