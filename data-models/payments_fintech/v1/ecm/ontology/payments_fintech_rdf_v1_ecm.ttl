ind:walletType rdf:type rdf:Property ;
    rdfs:label 'Wallet Type' ;
    rdfs:comment 'Category of wallet based on the provider or technology (e.g., Apple Pay, Google Pay, proprietary).' ;
    rdfs:domain ind:DigitalWallet ;
    rdf:type owl:DatatypeProperty ;
