ind:deviceProvisioningStatus rdf:type rdf:Property ;
    rdfs:label 'Device Provisioning Status' ;
    rdfs:comment 'Status of the device provisioning process for the wallet.' ;
    rdfs:domain ind:DigitalWallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudReasonCode rdf:type rdf:Property ;
    rdfs:label 'Fraud Reason Code' ;
    rdfs:comment 'Code describing the reason for a fraud flag (e.g., suspicious_activity, stolen_device).' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:is3dsEnrolled rdf:type rdf:Property ;
    rdfs:label 'Is 3ds Enrolled' ;
    rdfs:comment 'Indicates whether the wallet is enrolled in 3-Domain Secure authentication.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHceEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Hce Enabled' ;
    rdfs:comment 'Indicates whether the wallet uses Host Card Emulation for tokenized payments.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastActivityTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Activity Timestamp' ;
    rdfs:comment 'Date-time of the most recent successful transaction or interaction with the wallet.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastTokenizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Tokenization Timestamp' ;
    rdfs:comment 'Date-time when the wallet was most recently tokenized or re-tokenized.' ;
    rdfs:domain ind:DigitalWallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pciDssCompliant rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Compliant' ;
    rdfs:comment 'Indicates whether the wallet meets PCI DSS security standards.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:provisioningChannel rdf:type rdf:Property ;
    rdfs:label 'Provisioning Channel' ;
    rdfs:comment 'Channel through which the wallet was provisioned (e.g., mobile app, web portal, partner integration, API).' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psd2Compliant rdf:type rdf:Property ;
    rdfs:label 'Psd2 Compliant' ;
    rdfs:comment 'Indicates whether the wallet complies with EU PSD2 regulatory requirements.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storedValueBalance rdf:type rdf:Property ;
    rdfs:label 'Stored Value Balance' ;
    rdfs:comment 'Current monetary balance held in the wallet for stored-value transactions.' ;
    rdfs:domain ind:DigitalWallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:walletDescription rdf:type rdf:Property ;
    rdfs:label 'Wallet Description' ;
    rdfs:comment 'Free-form description or notes about the wallet instance.' ;
    rdfs:domain ind:DigitalWallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walletName rdf:type rdf:Property ;
    rdfs:label 'Wallet Name' ;
    rdfs:comment 'Human-readable name or label for the wallet, often shown to the cardholder in UI.' ;
