    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenizationKeyVersion rdf:type rdf:Property ;
    rdfs:label 'Tokenization Key Version' ;
    rdfs:comment 'Version label of the tokenization key.' ;
