    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characterSet rdf:type rdf:Property ;
    rdfs:label 'Character Set' ;
    rdfs:comment 'Specific character set applied to the message (e.g., ISO-8859-1).' ;
    rdfs:domain ind:GatewayProtocolConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStandard rdf:type rdf:Property ;
