ind:challengePreference rdf:type rdf:Property ;
    rdfs:label 'Challenge Preference' ;
    rdfs:comment 'Merchant-specified preference for challenge flow during authentication.' ;
    rdfs:domain ind:ThreedsConfig ;
    rdf:type owl:DatatypeProperty ;
