    rdfs:comment 'Total count of data elements defined for this message type.' ;
    rdfs:domain ind:IsoMessageType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBatch rdf:type rdf:Property ;
    rdfs:label 'Is Batch' ;
    rdfs:comment 'True if the message type is typically transmitted in batch files rather than real-time.' ;
