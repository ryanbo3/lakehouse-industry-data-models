    rdfs:domain ind:Mcc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryGroup rdf:type rdf:Property ;
    rdfs:label 'Category Group' ;
    rdfs:comment 'Higher-level grouping of MCCs (e.g., Retail, Services, Travel).' ;
    rdfs:domain ind:Mcc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highRiskFlag rdf:type rdf:Property ;
    rdfs:label 'High Risk Flag' ;
    rdfs:comment 'True if the merchant category is considered high risk for fraud or compliance monitoring.' ;
    rdfs:domain ind:Mcc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industrySector rdf:type rdf:Property ;
    rdfs:label 'Industry Sector' ;
    rdfs:comment 'Broad industry sector associated with the merchant category (e.g., Food & Beverage, Transportation).' ;
    rdfs:domain ind:Mcc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeEligibility rdf:type rdf:Property ;
