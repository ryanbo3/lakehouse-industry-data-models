    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtpPaymentId rdf:type rdf:Property ;
    rdfs:label 'Rtp Payment Id' ;
    rdfs:comment 'Primary key uniquely identifying the RTP payment record.' ;
