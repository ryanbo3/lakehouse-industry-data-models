    rdfs:range xsd:string .

ind:settlementType rdf:type rdf:Property ;
    rdfs:label 'Settlement Type' ;
    rdfs:comment 'Settlement speed category for the pair.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceFeed rdf:type rdf:Property ;
    rdfs:label 'Source Feed' ;
    rdfs:comment 'Origin of the FX rate feed for the pair.' ;
