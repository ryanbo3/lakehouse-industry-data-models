ind:clearingReference rdf:type rdf:Property ;
    rdfs:label 'Clearing Reference' ;
    rdfs:comment 'External reference number assigned to the clearing record by the clearing system.' ;
    rdfs:domain ind:ClearingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingStatus rdf:type rdf:Property ;
    rdfs:label 'Clearing Status' ;
    rdfs:comment 'Current processing status of the clearing record.' ;
