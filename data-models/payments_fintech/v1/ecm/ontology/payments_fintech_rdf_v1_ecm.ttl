    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compliancePsd2Version rdf:type rdf:Property ;
    rdfs:label 'Compliance Psd2 Version' ;
    rdfs:comment 'Version of the PSD2 regulatory framework applicable.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderSupported rdf:type rdf:Property ;
    rdfs:label 'Cross Border Supported' ;
    rdfs:comment 'Indicates if the credential can be used for cross-border payments.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
