    rdfs:label 'Vpa' ;
    rdfs:comment 'The UPI ID in the format address@bank, used for peer-to-peer and peer-to-merchant payments.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vpaType rdf:type rdf:Property ;
    rdfs:label 'Vpa Type' ;
    rdfs:comment 'Indicates whether the VPA is for a personal or business entity.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upiRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Upi Registration Id' ;
    rdfs:comment 'Unique identifier for the UPI registration record.' ;
    rdfs:domain ind:UpiRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deregistrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deregistration Timestamp' ;
    rdfs:comment 'Timestamp when the VPA was deregistered or deactivated.' ;
    rdfs:domain ind:UpiRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linkedBankAccountMasked rdf:type rdf:Property ;
    rdfs:label 'Linked Bank Account Masked' ;
    rdfs:comment 'Masked representation of the bank account linked to the VPA.' ;
    rdfs:domain ind:UpiRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationSource rdf:type rdf:Property ;
    rdfs:label 'Registration Source' ;
    rdfs:comment 'Origin of the registration request, such as self-service or customer support.' ;
    rdfs:domain ind:UpiRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upiHandle rdf:type rdf:Property ;
    rdfs:label 'Upi Handle' ;
    rdfs:comment 'PSP-specific suffix appended to the VPA (e.g., @bank).' ;
    rdfs:domain ind:UpiRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upiPinSet rdf:type rdf:Property ;
    rdfs:label 'Upi Pin Set' ;
    rdfs:comment 'Indicates whether a PIN has been configured for the VPA.' ;
    rdfs:domain ind:UpiRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balanceCategory rdf:type rdf:Property ;
    rdfs:label 'Balance Category' ;
    rdfs:comment 'Business segment to which the balance applies.' ;
    rdfs:domain ind:WalletBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceCeilingLimit rdf:type rdf:Property ;
    rdfs:label 'Balance Ceiling Limit' ;
    rdfs:comment 'Maximum allowable balance for the wallet as defined by product rules or regulatory caps.' ;
    rdfs:domain ind:WalletBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eMoneyClassification rdf:type rdf:Property ;
    rdfs:label 'E Money Classification' ;
    rdfs:comment 'Regulatory classification of the e-money balance.' ;
    rdfs:domain ind:WalletBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalBalanceReference rdf:type rdf:Property ;
    rdfs:label 'External Balance Reference' ;
    rdfs:comment 'External reference number used by partner systems for this balance.' ;
    rdfs:domain ind:WalletBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFrozen rdf:type rdf:Property ;
    rdfs:label 'Is Frozen' ;
    rdfs:comment 'True when the balance is temporarily frozen due to compliance or risk actions.' ;
    rdfs:domain ind:WalletBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverdraftAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Overdraft Allowed' ;
    rdfs:comment 'Indicates whether the wallet permits overdraft usage.' ;
    rdfs:domain ind:WalletBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCreditTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Credit Timestamp' ;
    rdfs:comment 'Timestamp of the most recent credit transaction applied to the balance.' ;
    rdfs:domain ind:WalletBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastDebitTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Debit Timestamp' ;
    rdfs:comment 'Timestamp of the most recent debit transaction applied to the balance.' ;
    rdfs:domain ind:WalletBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservedBalance rdf:type rdf:Property ;
    rdfs:label 'Reserved Balance' ;
    rdfs:comment 'Amount held for pending authorizations or holds.' ;
    rdfs:domain ind:WalletBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBalance rdf:type rdf:Property ;
    rdfs:label 'Total Balance' ;
    rdfs:comment 'Sum of available and reserved balances representing the full stored value.' ;
    rdfs:domain ind:WalletBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:walletBinRangeId rdf:type rdf:Property ;
    rdfs:label 'Wallet Bin Range Id' ;
    rdfs:comment 'Surrogate primary key for the BIN range record.' ;
    rdfs:domain ind:WalletBinRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuingCountryId rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Bin range issuing country compliance requires reference.country for sanctions and regulatory checks.' ;
    rdfs:domain ind:WalletBinRange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:binPrefix rdf:type rdf:Property ;
    rdfs:label 'Bin Prefix' ;
    rdfs:comment 'Numeric prefix (6-11 digits) identifying the issuing institution.' ;
    rdfs:domain ind:WalletBinRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpanSupported rdf:type rdf:Property ;
    rdfs:label 'Dpan Supported' ;
    rdfs:comment 'Indicates if Device PAN (DPAN) is issued for this BIN.' ;
    rdfs:domain ind:WalletBinRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fundingType rdf:type rdf:Property ;
    rdfs:label 'Funding Type' ;
    rdfs:comment 'Whether the card is funded directly from an account or prepaid.' ;
    rdfs:domain ind:WalletBinRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeEligible rdf:type rdf:Property ;
    rdfs:label 'Interchange Eligible' ;
