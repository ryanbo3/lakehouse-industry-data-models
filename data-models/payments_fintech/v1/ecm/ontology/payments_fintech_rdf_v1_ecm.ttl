    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'True when the renewal reminder has been communicated.' ;
    rdfs:domain ind:InstrumentExpirySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'Date-time the renewal reminder was dispatched.' ;
    rdfs:domain ind:InstrumentExpirySchedule ;
