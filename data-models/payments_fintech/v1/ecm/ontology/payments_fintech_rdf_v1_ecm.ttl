ind:tokenizationAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Tokenization Algorithm' ;
    rdfs:comment 'Name of the cryptographic algorithm applied during token generation.' ;
    rdfs:domain ind:TokenPanMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenizationCompliance rdf:type rdf:Property ;
    rdfs:label 'Tokenization Compliance' ;
    rdfs:comment 'Regulatory compliance standards satisfied by the tokenization process.' ;
    rdfs:domain ind:TokenPanMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenizationKeyReference rdf:type rdf:Property ;
    rdfs:label 'Tokenization Key Reference' ;
    rdfs:comment 'Identifier of the cryptographic key used for token creation.' ;
