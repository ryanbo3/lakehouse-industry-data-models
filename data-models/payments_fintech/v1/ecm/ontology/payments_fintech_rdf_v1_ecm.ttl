    rdfs:comment 'Number of days after issuance that a token automatically expires if not used.' ;
    rdfs:domain ind:IssuerWalletConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tokenExpiryPolicy rdf:type rdf:Property ;
    rdfs:label 'Token Expiry Policy' ;
    rdfs:comment 'Policy governing token lifetime: rolling (renew on use), fixed (static date), or session-based.' ;
    rdfs:domain ind:IssuerWalletConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yellowPathThreshold rdf:type rdf:Property ;
    rdfs:label 'Yellow Path Threshold' ;
    rdfs:comment 'Risk score percentage range for the yellow (moderate-risk) path.' ;
    rdfs:domain ind:IssuerWalletConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyAccountId rdf:type rdf:Property ;
