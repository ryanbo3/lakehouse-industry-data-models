    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Acceptance Type Status' ;
    rdfs:comment 'Current lifecycle status of the acceptance type.' ;
    rdfs:domain ind:AcceptanceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associatedFeeRate rdf:type rdf:Property ;
    rdfs:label 'Associated Fee Rate' ;
    rdfs:comment 'Base interchange or service fee rate (as a decimal) associated with this acceptance type.' ;
    rdfs:domain ind:AcceptanceType ;
    rdf:type owl:DatatypeProperty ;
