ind:trainingModuleName rdf:type rdf:Property ;
    rdfs:label 'Training Module Name' ;
    rdfs:comment 'Descriptive name of the training module.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingProvider rdf:type rdf:Property ;
