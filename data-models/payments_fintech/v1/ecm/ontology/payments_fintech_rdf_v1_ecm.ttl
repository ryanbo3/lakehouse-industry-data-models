    rdfs:range xsd:integer .

ind:caseId rdf:type rdf:Property ;
    rdfs:label 'Case Id' ;
    rdfs:comment 'Identifier of the fraud case associated with the alert.' ;
    rdfs:domain ind:FalsePositiveReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudCase .

ind:reviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Employee Id' ;
    rdfs:comment 'System identifier of the analyst who performed the review.' ;
    rdfs:domain ind:PaymentsFintech ;
