ind:membershipNumber rdf:type rdf:Property ;
    rdfs:label 'Membership Number' ;
    rdfs:comment 'External business identifier assigned to the membership agreement by the platform.' ;
    rdfs:domain ind:SchemeMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle state of the membership agreement.' ;
    rdfs:domain ind:SchemeMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipType rdf:type rdf:Property ;
    rdfs:label 'Membership Type' ;
    rdfs:comment 'Classification of the membership relationship with the scheme.' ;
    rdfs:domain ind:SchemeMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFeeAmount rdf:type rdf:Property ;
