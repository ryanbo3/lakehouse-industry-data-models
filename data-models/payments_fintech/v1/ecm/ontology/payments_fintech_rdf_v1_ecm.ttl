ind:uetr rdf:type rdf:Property ;
    rdfs:label 'Uetr' ;
    rdfs:comment 'Globally unique identifier assigned to each gpi transaction per SWIFT standards.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
