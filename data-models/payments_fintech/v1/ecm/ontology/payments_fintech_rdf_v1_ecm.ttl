    rdfs:range xsd:integer .

ind:instrumentStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Instrument Status History Id' ;
    rdfs:comment 'Unique surrogate identifier for each status change event of a payment instrument.' ;
    rdfs:domain ind:InstrumentStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Change Timestamp' ;
    rdfs:comment 'Exact date-time when the status transition occurred in the source system.' ;
