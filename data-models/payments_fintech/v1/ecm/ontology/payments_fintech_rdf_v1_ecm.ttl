    rdfs:comment 'True if the MCC is included in the industry MATCH list for heightened monitoring.' ;
    rdfs:domain ind:Mcc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedCategoryFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Category Flag' ;
    rdfs:comment 'True if the MCC falls under a regulatory restricted category (e.g., gambling, adult services).' ;
    rdfs:domain ind:Mcc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nachaReturnCodeId rdf:type rdf:Property ;
