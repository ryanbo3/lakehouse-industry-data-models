    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionAmountLimitOverride rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount Limit Override' ;
    rdfs:comment 'Override for the maximum transaction amount under the exception.' ;
    rdfs:domain ind:RiskException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionVolumeLimitOverride rdf:type rdf:Property ;
    rdfs:label 'Transaction Volume Limit Override' ;
    rdfs:comment 'Override for the maximum number of transactions allowed under the exception.' ;
    rdfs:domain ind:RiskException ;
    rdf:type owl:DatatypeProperty ;
