    rdfs:range xsd:string .

ind:usageQuota rdf:type rdf:Property ;
    rdfs:label 'Usage Quota' ;
    rdfs:comment 'Total number of allowed invocations or monetary value before the credential is throttled or blocked.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceLastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Last Review Date' ;
    rdfs:comment 'Date of the most recent compliance audit or review for this integration.' ;
