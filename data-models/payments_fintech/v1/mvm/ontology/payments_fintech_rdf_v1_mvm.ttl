    rdfs:range xsd:string .

ind:gatewayRoutingRuleId rdf:type rdf:Property ;
    rdfs:label 'Gateway Routing Rule Id' ;
    rdfs:comment 'Unique identifier for the routing rule.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GatewayRoutingRule .

ind:networkParticipationId rdf:type rdf:Property ;
    rdfs:label 'Network Participation Id' ;
    rdfs:comment 'Foreign key linking to partner.network_participation. Business justification: Routing decisions depend on which payment networks the partner participates in and their participation roles. Gateway must route transactions only through networks where the partner has active partici' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkParticipation .

ind:primaryGatewayAcquirerEndpointId rdf:type rdf:Property ;
    rdfs:label 'Primary Gateway Acquirer Endpoint Id' ;
    rdfs:comment 'Primary acquirer endpoint to which matching transactions are routed.' ;
    rdfs:domain ind:GatewayRoutingRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AcquirerEndpoint .

ind:targetAcquirerAcquirerEndpointId rdf:type rdf:Property ;
    rdfs:label 'Target Acquirer Acquirer Endpoint Id' ;
    rdfs:comment 'Primary acquirer endpoint to which matching transactions are routed.' ;
    rdfs:domain ind:GatewayRoutingRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AcquirerEndpoint .

ind:complianceRuleSet rdf:type rdf:Property ;
    rdfs:label 'Compliance Rule Set' ;
    rdfs:comment 'Identifier of the compliance rule set applied to transactions routed by this rule.' ;
    rdfs:domain ind:GatewayRoutingRule ;
    rdf:type owl:DatatypeProperty ;
