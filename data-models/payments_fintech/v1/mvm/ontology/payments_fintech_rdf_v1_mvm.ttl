    rdfs:range xsd:string .

ind:adjustmentId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Id' ;
    rdfs:comment 'Primary key for adjustment' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalSettlementId rdf:type rdf:Property ;
    rdfs:label 'Original Settlement Id' ;
    rdfs:comment 'Identifier of the settlement record that is being adjusted.' ;
    rdfs:domain ind:Settlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Settlement .

ind:adjustedAmount rdf:type rdf:Property ;
    rdfs:label 'Adjusted Amount' ;
    rdfs:comment 'Monetary amount applied by the adjustment (positive for credit, negative for debit).' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
