    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:networkParticipationFlags rdf:type rdf:Property ;
    rdfs:label 'Network Participation Flags' ;
    rdfs:comment 'Comma-separated flags indicating participation in specific payment networks or schemes.' ;
    rdfs:domain ind:EcosystemPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingStage rdf:type rdf:Property ;
    rdfs:label 'Onboarding Stage' ;
    rdfs:comment 'Lifecycle stage of the partner onboarding process.' ;
