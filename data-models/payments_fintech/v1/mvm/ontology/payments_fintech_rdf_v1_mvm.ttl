ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Primary jurisdiction where the product is offered. [ENUM-REF-CANDIDATE: USA|GBR|CAN|AUS|DEU|FRA|JPN|SGP — 8 candidates stripped; promote to reference product]' ;
