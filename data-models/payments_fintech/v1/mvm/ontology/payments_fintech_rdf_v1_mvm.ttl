    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:a2aProductStatus rdf:type rdf:Property ;
    rdfs:label 'A2a Product Status' ;
    rdfs:comment 'Current lifecycle state of the product.' ;
    rdfs:domain ind:A2aProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso20022Version rdf:type rdf:Property ;
    rdfs:label 'Iso 20022 Version' ;
    rdfs:comment 'Version of the ISO 20022 message schema used for this product.' ;
