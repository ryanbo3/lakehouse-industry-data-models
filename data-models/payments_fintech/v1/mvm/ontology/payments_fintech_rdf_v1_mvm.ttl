ind:crossBorderAllowed rdf:type rdf:Property ;
    rdfs:label 'Cross Border Allowed' ;
    rdfs:comment 'Indicates if cross-border transfers are permitted.' ;
    rdfs:domain ind:P2pProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dailyLimit rdf:type rdf:Property ;
    rdfs:label 'Daily Limit' ;
    rdfs:comment 'Maximum cumulative amount allowed per day.' ;
    rdfs:domain ind:P2pProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingSources rdf:type rdf:Property ;
    rdfs:label 'Funding Sources' ;
    rdfs:comment 'Supported funding source types for the P2P product.' ;
    rdfs:domain ind:P2pProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxEligibility rdf:type rdf:Property ;
