ind:requestorEntity rdf:type rdf:Property ;
    rdfs:label 'Requestor Entity' ;
    rdfs:comment 'Entity that requested the exception.' ;
    rdfs:domain ind:RiskException ;
    rdf:type owl:DatatypeProperty ;
