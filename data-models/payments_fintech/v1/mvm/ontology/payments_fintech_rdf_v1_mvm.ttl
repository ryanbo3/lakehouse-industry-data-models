    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headers rdf:type rdf:Property ;
    rdfs:label 'Headers' ;
    rdfs:comment 'Serialized HTTP headers of the inbound request.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:httpMethod rdf:type rdf:Property ;
    rdfs:label 'Http Method' ;
    rdfs:comment 'HTTP verb used for the request.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
