ind:authenticationEventId rdf:type rdf:Property ;
    rdfs:label 'Authentication Event Id' ;
    rdfs:comment 'System-generated unique identifier for each authentication event record.' ;
    rdfs:domain ind:AuthenticationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAuthenticationCardholderCardholderProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Authentication Cardholder Cardholder Profile Id' ;
    rdfs:comment 'Unique identifier of the cardholder whose authentication was attempted.' ;
    rdfs:domain ind:AuthenticationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CardholderProfile .

ind:scoreEventId rdf:type rdf:Property ;
    rdfs:label 'Score Event Id' ;
    rdfs:comment 'Foreign key linking to fraud.score_event. Business justification: Fraud step-up authentication decisions and false-positive analysis require linking each authentication event to the fraud score event that evaluated it. Fraud operations teams use this link to tune mo' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScoreEvent .

ind:authenticationChannel rdf:type rdf:Property ;
    rdfs:label 'Authentication Channel' ;
    rdfs:comment 'Channel through which the authentication request was made.' ;
    rdfs:domain ind:AuthenticationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationFactor rdf:type rdf:Property ;
    rdfs:label 'Authentication Factor' ;
    rdfs:comment 'Specific factor used in the authentication (e.g., password, OTP, biometric).' ;
    rdfs:domain ind:AuthenticationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationOutcome rdf:type rdf:Property ;
    rdfs:label 'Authentication Outcome' ;
    rdfs:comment 'Result of the authentication attempt.' ;
    rdfs:domain ind:AuthenticationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geolocationCity rdf:type rdf:Property ;
    rdfs:label 'Geolocation City' ;
    rdfs:comment 'City inferred from the IP address or device location.' ;
    rdfs:domain ind:AuthenticationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockoutFlag rdf:type rdf:Property ;
    rdfs:label 'Lockout Flag' ;
    rdfs:comment 'Indicates whether the cardholder account was locked as a result of this attempt.' ;
    rdfs:domain ind:AuthenticationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskFlags rdf:type rdf:Property ;
    rdfs:label 'Risk Flags' ;
    rdfs:comment 'Pipe-separated list of risk indicators (e.g., high_velocity|blacklist|suspicious_location).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderVelocityControlId rdf:type rdf:Property ;
    rdfs:label 'Cardholder Velocity Control Id' ;
    rdfs:comment 'Unique surrogate key for the velocity control record.' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:limitId rdf:type rdf:Property ;
    rdfs:label 'Limit Id' ;
    rdfs:comment 'Foreign key linking to product.limit. Business justification: Cardholder velocity controls implement product-level limit definitions. Compliance and fraud teams reconcile cardholder-level controls against the product.limit records they enforce (daily, weekly, mo' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Limit .

ind:cardholderVelocityControlStatus rdf:type rdf:Property ;
    rdfs:label 'Cardholder Velocity Control Status' ;
    rdfs:comment 'Current lifecycle status of the control.' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Payment channel to which the control applies (e.g., Card-Not-Present, Card-Present).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlSource rdf:type rdf:Property ;
    rdfs:label 'Control Source' ;
    rdfs:comment 'Origin of the control definition: issuer-set, cardholder self-service, or regulatory mandate.' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Category of the velocity control (e.g., spending limit, transaction count, MCC restriction).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlVersion rdf:type rdf:Property ;
    rdfs:label 'Control Version' ;
    rdfs:comment 'Version number of the control for change tracking.' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dailySpentAmount rdf:type rdf:Property ;
    rdfs:label 'Daily Spent Amount' ;
    rdfs:comment 'Total amount spent by the cardholder today under this control.' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Daily Transaction Count' ;
    rdfs:comment 'Number of transactions performed today under this control.' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enforcementPriority rdf:type rdf:Property ;
    rdfs:label 'Enforcement Priority' ;
    rdfs:comment 'Numeric priority for rule evaluation when multiple controls apply; lower numbers have higher priority.' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isExempted rdf:type rdf:Property ;
    rdfs:label 'Is Exempted' ;
    rdfs:comment 'Indicates if the cardholder is exempted from this control (e.g., corporate card).' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastEvaluatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Evaluated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent transaction evaluation against this control.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:limitAmount rdf:type rdf:Property ;
    rdfs:label 'Limit Amount' ;
    rdfs:comment 'Monetary amount limit for the control (e.g., daily spend cap).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limitCurrency rdf:type rdf:Property ;
    rdfs:label 'Limit Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the limit amount.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitPeriod rdf:type rdf:Property ;
    rdfs:label 'Limit Period' ;
    rdfs:comment 'Time window for the monetary limit.' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCountLimit rdf:type rdf:Property ;
    rdfs:label 'Transaction Count Limit' ;
    rdfs:comment 'Maximum number of transactions allowed in the defined period.' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:violationCount rdf:type rdf:Property ;
    rdfs:label 'Violation Count' ;
    rdfs:comment 'Cumulative count of times the control was violated.' ;
    rdfs:domain ind:CardholderVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseId rdf:type rdf:Property ;
    rdfs:label 'Response Id' ;
    rdfs:comment 'Foreign key linking to gateway.gateway_response. Business justification: Reconciliation and settlement reports need the exact gateway response that settled the payment transaction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Response .

ind:txnTypeId rdf:type rdf:Property ;
    rdfs:label 'Txn Type Id' ;
    rdfs:comment 'Foreign key linking to transaction.txn_type. Business justification: payment_txn has a denormalized transaction_type STRING column. txn_type is the authoritative reference classification table for transaction types. Normalizing via txn_type_id FK eliminates the free-te' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TxnType .

ind:authCode rdf:type rdf:Property ;
    rdfs:label 'Auth Code' ;
    rdfs:comment 'Alphanumeric code generated by the issuer confirming approval of the transaction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avsResult rdf:type rdf:Property ;
    rdfs:label 'Avs Result' ;
    rdfs:comment 'Result code from AVS indicating match level between billing address and card issuer records.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Identifier of the batch in which the transaction was processed for settlement.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvvResult rdf:type rdf:Property ;
    rdfs:label 'Cvv Result' ;
    rdfs:comment 'Result code indicating whether the CVV supplied matched the issuer\'s record.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReason rdf:type rdf:Property ;
    rdfs:label 'Decline Reason' ;
    rdfs:comment 'Human-readable reason provided when a transaction is declined (e.g., insufficient funds, suspected fraud).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Conversion rate applied when the transaction involves a foreign currency.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCrossBorder rdf:type rdf:Property ;
    rdfs:label 'Is Cross Border' ;
    rdfs:comment 'True if the transaction involved currency conversion or parties in different countries.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStp rdf:type rdf:Property ;
    rdfs:label 'Is Stp' ;
    rdfs:comment 'True when the transaction was processed end-to-end without manual intervention.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoMessageType rdf:type rdf:Property ;
    rdfs:label 'Iso Message Type' ;
    rdfs:comment 'Four-digit code identifying the message class (e.g., 0100 for authorization request).' ;
    rdfs:domain ind:PaymentTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoMessageVersion rdf:type rdf:Property ;
    rdfs:label 'Iso Message Version' ;
    rdfs:comment 'Year of the ISO 8583 version used for the message (e.g., 2003).' ;
    rdfs:domain ind:PaymentTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Final amount settled to the merchant after fees, expressed in transaction currency.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:network rdf:type rdf:Property ;
    rdfs:label 'Network' ;
    rdfs:comment 'Card scheme or payment network that processed the transaction (Visa, Mastercard, Amex, Discover, UnionPay, Other).' ;
    rdfs:domain ind:PaymentTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalAmount rdf:type rdf:Property ;
    rdfs:label 'Original Amount' ;
    rdfs:comment 'Transaction amount in the original currency prior to conversion.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Original Currency Code' ;
    rdfs:comment 'Currency code of the amount before conversion (if different from transaction_currency).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTxnStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Txn Status' ;
    rdfs:comment 'Current processing state of the transaction (e.g., authorized, captured, settled, declined, reversed, chargeback).' ;
    rdfs:domain ind:PaymentTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingCode rdf:type rdf:Property ;
    rdfs:label 'Processing Code' ;
    rdfs:comment 'Four-digit ISO 8583 processing code indicating transaction type and account handling.' ;
    rdfs:domain ind:PaymentTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Current status of the settlement process (pending, settled, failed).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenizationFlag rdf:type rdf:Property ;
    rdfs:label 'Tokenization Flag' ;
    rdfs:comment 'True if the transaction used a tokenized payment credential instead of a clear PAN.' ;
    rdfs:domain ind:PaymentTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Exact date-time when the transaction was initiated or authorized in the payment network.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalAuthAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Original Auth Authorization Id' ;
    rdfs:comment 'Reference to the first authorization attempt when this record is a retry.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Authorization .

ind:partnerApiCredentialId rdf:type rdf:Property ;
    rdfs:label 'Partner Api Credential Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_api_credential. Business justification: PCI-DSS compliance requires audit trails of which partner API credential processed each authorization. Security incident response and credential rotation impact analysis depend on this link. gateway_a' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerApiCredential .

ind:routingDecisionId rdf:type rdf:Property ;
    rdfs:label 'Routing Decision Id' ;
    rdfs:comment 'Foreign key linking to gateway.routing_decision. Business justification: Authorization approval-rate-by-acquirer reporting and SLA analysis require linking each authorization to the gateway routing decision that selected the acquirer. Payments domain experts expect this fo' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoutingDecision .

ind:amountAuthorized rdf:type rdf:Property ;
    rdfs:label 'Amount Authorized' ;
    rdfs:comment 'The monetary amount that was approved by the issuer.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountRequested rdf:type rdf:Property ;
    rdfs:label 'Amount Requested' ;
    rdfs:comment 'The monetary amount requested for authorization.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Auth Reference Number' ;
    rdfs:comment 'External reference number for the authorization attempt, used for reconciliation and reporting.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authRetryCount rdf:type rdf:Property ;
    rdfs:label 'Auth Retry Count' ;
    rdfs:comment 'Number of authorization attempts made for this transaction.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authSource rdf:type rdf:Property ;
    rdfs:label 'Auth Source' ;
    rdfs:comment 'Origin of the authorization request – real-time or batch processing.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authStatus rdf:type rdf:Property ;
    rdfs:label 'Auth Status' ;
    rdfs:comment 'Current lifecycle status of the authorization attempt.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Code returned by the issuer indicating approval.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCheckPassed rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Passed' ;
    rdfs:comment 'Indicates whether the transaction passed mandatory compliance checks (e.g., AML, sanctions).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceFingerprint rdf:type rdf:Property ;
    rdfs:label 'Device Fingerprint' ;
    rdfs:comment 'Unique identifier derived from device characteristics for fraud detection.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceIpAddress rdf:type rdf:Property ;
    rdfs:label 'Device Ip Address' ;
    rdfs:comment 'IP address of the device that originated the authorization request.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCardPresent rdf:type rdf:Property ;
    rdfs:label 'Is Card Present' ;
    rdfs:comment 'True if the card was physically present at the point of sale.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isContactless rdf:type rdf:Property ;
    rdfs:label 'Is Contactless' ;
    rdfs:comment 'True if the transaction used contactless technology.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTestTransaction rdf:type rdf:Property ;
    rdfs:label 'Is Test Transaction' ;
    rdfs:comment 'True if the transaction is a test or sandbox transaction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuerResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Issuer Response Time Ms' ;
    rdfs:comment 'Time in milliseconds taken by the issuer to respond.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Network Latency Ms' ;
    rdfs:comment 'Measured network latency between gateway and issuer.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'Channel through which the payment was initiated.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingTimeMs rdf:type rdf:Property ;
    rdfs:label 'Processing Time Ms' ;
    rdfs:comment 'Overall time taken to process the authorization request end-to-end.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Timestamp when the authorization request was sent to the issuer.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scaStatus rdf:type rdf:Property ;
    rdfs:label 'Sca Status' ;
    rdfs:comment 'Result of the SCA evaluation for the transaction.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeDsResult rdf:type rdf:Property ;
    rdfs:label 'Three Ds Result' ;
    rdfs:comment 'Outcome of the 3-D Secure authentication flow.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenUsed rdf:type rdf:Property ;
    rdfs:label 'Token Used' ;
    rdfs:comment 'True if a tokenized PAN was used for the transaction.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Original Authorization Id' ;
    rdfs:comment 'Identifier of the original authorization transaction that this capture fulfills.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Authorization .

ind:acquirerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Acquirer Reference Number' ;
    rdfs:comment 'Unique reference assigned by the acquiring bank for tracking the transaction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captureMethod rdf:type rdf:Property ;
    rdfs:label 'Capture Method' ;
    rdfs:comment 'Method by which the capture was performed (immediate, delayed, incremental, or partial).' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captureNumber rdf:type rdf:Property ;
    rdfs:label 'Capture Number' ;
    rdfs:comment 'Business-facing identifier for the capture event, often used in reporting and reconciliation.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captureStatus rdf:type rdf:Property ;
    rdfs:label 'Capture Status' ;
    rdfs:comment 'Current lifecycle status of the capture (e.g., pending, completed, failed, reversed, partial).' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeFee rdf:type rdf:Property ;
    rdfs:label 'Interchange Fee' ;
    rdfs:comment 'Fee paid between acquiring and issuing banks for this capture.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isIncremental rdf:type rdf:Property ;
    rdfs:label 'Is Incremental' ;
    rdfs:comment 'True when the capture adds to a previously captured amount (multiple captures).' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartialCapture rdf:type rdf:Property ;
    rdfs:label 'Is Partial Capture' ;
    rdfs:comment 'Indicates whether the capture represents a partial amount of the original authorization.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSettled rdf:type rdf:Property ;
    rdfs:label 'Is Settled' ;
    rdfs:comment 'True when the capture amount has been successfully settled.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingFee rdf:type rdf:Property ;
    rdfs:label 'Processing Fee' ;
    rdfs:comment 'Fee charged by the payment processor for handling the capture.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalAmount rdf:type rdf:Property ;
    rdfs:label 'Reversal Amount' ;
    rdfs:comment 'Amount reversed from the capture, if a reversal occurred.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'Timestamp when the capture was reversed.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordinal number of this capture within a series of incremental captures.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:settlementCurrency rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency' ;
    rdfs:comment 'Currency in which the settlement amount is paid to the merchant.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Surcharge Amount' ;
    rdfs:comment 'Any surcharge (e.g., service fee) applied at capture time.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tipAmount rdf:type rdf:Property ;
    rdfs:label 'Tip Amount' ;
    rdfs:comment 'Additional tip amount added to the capture, if applicable.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearingSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Clearing Submission Id' ;
    rdfs:comment 'Unique identifier for the clearing submission record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClearingSubmission .

ind:interchangeQualificationId rdf:type rdf:Property ;
    rdfs:label 'Interchange Qualification Id' ;
    rdfs:comment 'Foreign key linking to product.interchange_qualification. Business justification: Clearing submissions are qualified to interchange tiers at clearing time — this is the definitive interchange qualification event. clearing_submission has denormalized interchange_category and irf_rat' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InterchangeQualification .

ind:acquiringInstitutionCode rdf:type rdf:Property ;
    rdfs:label 'Acquiring Institution Code' ;
    rdfs:comment 'Identifier of the acquiring financial institution.' ;
    rdfs:domain ind:ClearingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountFee rdf:type rdf:Property ;
    rdfs:label 'Amount Fee' ;
    rdfs:comment 'Sum of all fees applied to the transaction.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountGross rdf:type rdf:Property ;
    rdfs:label 'Amount Gross' ;
    rdfs:comment 'Total transaction amount before fees and adjustments.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountNet rdf:type rdf:Property ;
    rdfs:label 'Amount Net' ;
    rdfs:comment 'Transaction amount after fees are deducted.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:binNumber rdf:type rdf:Property ;
    rdfs:label 'Bin Number' ;
    rdfs:comment 'First six digits of the card number identifying the issuing bank.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'Calendar date on which the transaction cleared.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingSubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Clearing Submission Status' ;
    rdfs:comment 'Current processing state of the clearing submission.' ;
    rdfs:domain ind:ClearingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iinNumber rdf:type rdf:Property ;
    rdfs:label 'Iin Number' ;
    rdfs:comment 'Six-digit identifier of the card issuer.' ;
    rdfs:domain ind:ClearingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irfAmount rdf:type rdf:Property ;
    rdfs:label 'Irf Amount' ;
    rdfs:comment 'Fee amount calculated based on IRF rate category.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuingInstitutionCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Institution Code' ;
    rdfs:comment 'Identifier of the issuing financial institution.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pciCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Pci Compliant Flag' ;
    rdfs:comment 'True if the transaction data meets PCI compliance requirements.' ;
    rdfs:domain ind:ClearingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseCode rdf:type rdf:Property ;
    rdfs:label 'Response Code' ;
    rdfs:comment 'Two-digit response indicating approval or decline reason.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionReference rdf:type rdf:Property ;
    rdfs:label 'Submission Reference' ;
    rdfs:comment 'Reference assigned by the card scheme or ACH network for this clearing submission.' ;
    rdfs:domain ind:ClearingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:txnLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Txn Lifecycle Event Id' ;
    rdfs:comment 'Unique surrogate key for each immutable transaction lifecycle event record.' ;
    rdfs:domain ind:TxnLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventId rdf:type rdf:Property ;
    rdfs:label 'Event Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_event. Business justification: Lifecycle events with dispute_flag, reversal_flag, or fraud_flag generate risk events. Linking txn_lifecycle_event to risk_event enables operational risk monitoring, regulatory audit trails, and real-' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Event .

ind:refundId rdf:type rdf:Property ;
    rdfs:label 'Refund Id' ;
    rdfs:comment 'Foreign key linking to transaction.refund. Business justification: txn_lifecycle_event has a refund_flag BOOLEAN indicating refund events. Adding refund_id FK enables direct traceability from lifecycle events to the refund record. Nullable — only populated for refund' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Refund .

ind:reversalId rdf:type rdf:Property ;
    rdfs:label 'Reversal Id' ;
    rdfs:comment 'Foreign key linking to transaction.reversal. Business justification: txn_lifecycle_event has a reversal_flag BOOLEAN indicating reversal events. Adding reversal_id FK enables direct traceability from lifecycle events to the reversal record. Nullable — only populated fo' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Reversal .

ind:transactionBatchId rdf:type rdf:Property ;
    rdfs:label 'Transaction Batch Id' ;
    rdfs:comment 'Identifier of the processing batch (if the event is part of a batch).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransactionBatch .

ind:chargebackFlag rdf:type rdf:Property ;
    rdfs:label 'Chargeback Flag' ;
    rdfs:comment 'True if a chargeback has been filed for the transaction.' ;
    rdfs:domain ind:TxnLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'True if the transaction is currently under dispute.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Free-form text providing additional context for the event.' ;
    rdfs:domain ind:TxnLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Event Source System' ;
    rdfs:comment 'Originating system that generated the event record.' ;
    rdfs:domain ind:TxnLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoMessageTypeCode rdf:type rdf:Property ;
    rdfs:label 'Iso Message Type Code' ;
    rdfs:comment 'ISO 8583 or ISO 20022 message type identifier associated with the event (e.g., 0100, 0200, 0300).' ;
    rdfs:domain ind:TxnLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorState rdf:type rdf:Property ;
    rdfs:label 'Prior State' ;
    rdfs:comment 'State of the transaction before this event occurred. [ENUM-REF-CANDIDATE: authorized|captured|cleared|settled|reversed|voided|refunded|chargeback|disputed|pending — promote to reference product]' ;
    rdfs:domain ind:TxnLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Processing Latency Ms' ;
    rdfs:comment 'Time in milliseconds taken to process the event from receipt to completion.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refundFlag rdf:type rdf:Property ;
    rdfs:label 'Refund Flag' ;
    rdfs:comment 'True if the event represents a refund.' ;
    rdfs:domain ind:TxnLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceIpAddress rdf:type rdf:Property ;
    rdfs:label 'Source Ip Address' ;
    rdfs:comment 'IP address of the system that originated the event.' ;
    rdfs:domain ind:TxnLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stpIndicator rdf:type rdf:Property ;
    rdfs:label 'Stp Indicator' ;
    rdfs:comment 'True if the transaction was processed without manual intervention.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tps rdf:type rdf:Property ;
    rdfs:label 'Tps' ;
    rdfs:comment 'Observed TPS rate at the time of the event.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voidFlag rdf:type rdf:Property ;
    rdfs:label 'Void Flag' ;
    rdfs:comment 'True if the transaction was voided before capture.' ;
    rdfs:domain ind:TxnLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatingPartyRole rdf:type rdf:Property ;
    rdfs:label 'Initiating Party Role' ;
    rdfs:comment 'Role of the entity that initiated the reversal.' ;
    rdfs:domain ind:Reversal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netReversalAmount rdf:type rdf:Property ;
    rdfs:label 'Net Reversal Amount' ;
    rdfs:comment 'Net amount after deducting reversal fees.' ;
    rdfs:domain ind:Reversal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partialReversalFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Reversal Flag' ;
    rdfs:comment 'True if the reversal is for a portion of the original amount.' ;
    rdfs:domain ind:Reversal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalStatus rdf:type rdf:Property ;
    rdfs:label 'Reversal Status' ;
    rdfs:comment 'Current processing status of the reversal.' ;
    rdfs:domain ind:Reversal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalType rdf:type rdf:Property ;
    rdfs:label 'Reversal Type' ;
    rdfs:comment 'Category of reversal: void, partial, timeout, or duplicate.' ;
    rdfs:domain ind:Reversal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentId rdf:type rdf:Property ;
    rdfs:label 'Assessment Id' ;
    rdfs:comment 'Foreign key linking to risk.assessment. Business justification: Large or chargeback-related refunds trigger a risk assessment for AML re-screening and fraud re-evaluation. The assessment_id links the refund to the risk assessment that evaluated it. Refund fraud mo' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assessment .

ind:fraudCaseId rdf:type rdf:Property ;
    rdfs:label 'Fraud Case Id' ;
    rdfs:comment 'Foreign key linking to fraud.fraud_case. Business justification: Refund fraud is a major payments fraud vector — fraudulent refund schemes, refund abuse, and first-party fraud require linking refunds to fraud cases. Fraud investigation teams open fraud cases on sus' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudCase .

ind:cardholderEmail rdf:type rdf:Property ;
    rdfs:label 'Cardholder Email' ;
    rdfs:comment 'Primary email address of the cardholder for communication and receipt delivery.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFlagFraud rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag Fraud' ;
    rdfs:comment 'True if the refund was flagged by the fraud detection engine.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiated Timestamp' ;
    rdfs:comment 'Date-time when the merchant initiated the refund request.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isChargebackRelated rdf:type rdf:Property ;
    rdfs:label 'Is Chargeback Related' ;
    rdfs:comment 'True if the refund is linked to an ongoing chargeback case.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartialRefund rdf:type rdf:Property ;
    rdfs:label 'Is Partial Refund' ;
    rdfs:comment 'True if the refund amount is less than the original transaction amount.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partialRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Partial Refund Amount' ;
    rdfs:comment 'Amount refunded when the refund is partial.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'Date-time when the refund was successfully posted to the cardholder\'s account.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processorReference rdf:type rdf:Property ;
    rdfs:label 'Processor Reference' ;
    rdfs:comment 'Reference identifier returned by the payment processor for the refund transaction.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundMethod rdf:type rdf:Property ;
    rdfs:label 'Refund Method' ;
    rdfs:comment 'Method used to return funds: original payment instrument, alternative instrument, or store credit.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundStatus rdf:type rdf:Property ;
    rdfs:label 'Refund Status' ;
    rdfs:comment 'Current processing status of the refund.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDecision rdf:type rdf:Property ;
    rdfs:label 'Risk Decision' ;
    rdfs:comment 'Decision outcome based on the risk score.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeRefundReference rdf:type rdf:Property ;
    rdfs:label 'Scheme Refund Reference' ;
    rdfs:comment 'Identifier assigned by the card scheme (e.g., Visa, Mastercard) for the refund.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaId rdf:type rdf:Property ;
    rdfs:label 'Sla Id' ;
    rdfs:comment 'Foreign key linking to network.sla. Business justification: Batch settlement is governed by scheme SLAs defining batch_settlement_window_hours and uptime targets. Linking transaction_batch to the applicable SLA record enables automated SLA breach detection, pe' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sla .

ind:batchType rdf:type rdf:Property ;
    rdfs:label 'Batch Type' ;
    rdfs:comment 'Categorization of the batch purpose.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCount rdf:type rdf:Property ;
    rdfs:label 'Error Count' ;
    rdfs:comment 'Number of error records detected during batch validation.' ;
    rdfs:domain ind:TransactionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exchangeRateToUsd rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate To Usd' ;
    rdfs:comment 'FX rate used to convert batch amounts to USD for reporting.' ;
    rdfs:domain ind:TransactionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'Name of the file generated for settlement transmission.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingRateTps rdf:type rdf:Property ;
    rdfs:label 'Processing Rate Tps' ;
    rdfs:comment 'Average number of transactions processed per second during batch execution.' ;
    rdfs:domain ind:TransactionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Processing Time Seconds' ;
    rdfs:comment 'Total elapsed time in seconds to process the batch from open to close.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:schemeBatchReference rdf:type rdf:Property ;
    rdfs:label 'Scheme Batch Reference' ;
    rdfs:comment 'Identifier assigned by the payment scheme (e.g., Visa, Mastercard) for this batch.' ;
    rdfs:domain ind:TransactionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementReference rdf:type rdf:Property ;
    rdfs:label 'Settlement Reference' ;
    rdfs:comment 'Reference identifier returned by the settlement system.' ;
    rdfs:domain ind:TransactionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stpRate rdf:type rdf:Property ;
    rdfs:label 'Stp Rate' ;
    rdfs:comment 'Percentage of transactions in the batch processed without manual intervention.' ;
    rdfs:domain ind:TransactionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Sum of the gross amounts of all transactions in the batch, before fees and adjustments.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmountLocal rdf:type rdf:Property ;
    rdfs:label 'Total Amount Local' ;
    rdfs:comment 'Batch total amount expressed in the batch\'s native currency.' ;
    rdfs:domain ind:TransactionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Total Amount Usd' ;
    rdfs:comment 'Batch total amount expressed in US dollars.' ;
    rdfs:domain ind:TransactionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Fee Amount' ;
    rdfs:comment 'Aggregate of all fees (interchange, MDR, IRF, etc.) applied to the batch.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFeeAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Total Fee Amount Usd' ;
    rdfs:comment 'Aggregate fee amount converted to USD.' ;
    rdfs:domain ind:TransactionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Net Amount' ;
    rdfs:comment 'Net amount after subtracting fees and adjustments from the total amount.' ;
    rdfs:domain ind:TransactionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Total Net Amount Usd' ;
    rdfs:comment 'Net batch amount after fees, expressed in USD.' ;
    rdfs:domain ind:TransactionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionBatchStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Batch Status' ;
    rdfs:comment 'Current lifecycle state of the batch as defined by the processing workflow.' ;
    rdfs:domain ind:TransactionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warningCount rdf:type rdf:Property ;
    rdfs:label 'Warning Count' ;
    rdfs:comment 'Number of warning records detected during batch validation.' ;
    rdfs:domain ind:TransactionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reconciliationId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Id' ;
    rdfs:comment 'System-generated unique identifier for each reconciliation record.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acquiringBankCode rdf:type rdf:Property ;
    rdfs:label 'Acquiring Bank Code' ;
    rdfs:comment 'Identifier of the acquiring bank involved in the transaction flow.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Status' ;
    rdfs:comment 'Result of automated compliance checks performed on the reconciliation data.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Indicates whether the reconciliation resulted in any exceptions (true) or not (false).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingBankCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank Code' ;
    rdfs:comment 'Identifier of the issuing bank that supplied the payment instrument.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchedTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Matched Transaction Count' ;
    rdfs:comment 'Number of transactions that successfully matched between internal records and scheme files.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Net Total Amount' ;
    rdfs:comment 'Net amount after applying variance adjustments (total_matched_amount minus total_variance_amount).' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationNumber rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Number' ;
    rdfs:comment 'Business identifier assigned to the reconciliation run, used for external reporting and audit.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Timestamp' ;
    rdfs:comment 'Timestamp when the reconciliation process was executed.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reconciliationType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Type' ;
    rdfs:comment 'Indicates whether the reconciliation is performed intraday, at end of day, or as a T+1 settlement.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportIndicator rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Indicator' ;
    rdfs:comment 'Flag indicating whether this reconciliation record is included in regulatory reporting submissions.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreAverage rdf:type rdf:Property ;
    rdfs:label 'Risk Score Average' ;
    rdfs:comment 'Average fraud risk score of the transactions included in this reconciliation batch.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceFileInternal rdf:type rdf:Property ;
    rdfs:label 'Source File Internal' ;
    rdfs:comment 'File name or path of the internal transaction file used in the reconciliation.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceFileScheme rdf:type rdf:Property ;
    rdfs:label 'Source File Scheme' ;
    rdfs:comment 'File name or path of the scheme-provided clearing/settlement file used for comparison.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMatchedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Matched Amount' ;
    rdfs:comment 'Aggregate monetary value of all matched transactions, expressed in settlement currency.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'Total tax component captured in the transaction batch, if applicable.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Total Transaction Amount' ;
    rdfs:comment 'Aggregate amount of all transactions (matched and unmatched) before any adjustments.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Total Variance Amount' ;
    rdfs:comment 'Sum of monetary differences between internal and scheme amounts for unmatched or partially matched transactions.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency' ;
    rdfs:comment 'ISO 4217 currency code of the original transaction amounts before conversion.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unmatchedTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Unmatched Transaction Count' ;
    rdfs:comment 'Number of transactions that did not find a counterpart in the scheme file.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Code describing the primary cause of the variance (e.g., amount mismatch, missing transaction).' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:txnRoutingDecisionId rdf:type rdf:Property ;
    rdfs:label 'Txn Routing Decision Id' ;
    rdfs:comment 'System-generated unique identifier for each routing decision record.' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibilityRuleId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rule Id' ;
    rdfs:comment 'Foreign key linking to product.eligibility_rule. Business justification: Routing engines evaluate product eligibility rules before selecting a network/route. Linking txn_routing_decision to the eligibility_rule applied enables routing audit trails, compliance reporting on ' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EligibilityRule .

ind:endpointId rdf:type rdf:Property ;
    rdfs:label 'Endpoint Id' ;
    rdfs:comment 'Foreign key linking to network.network_endpoint. Business justification: Routing decision records the specific network endpoint used for processing, needed for audit trails and latency monitoring.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Endpoint .

ind:networkRoutingRuleId rdf:type rdf:Property ;
    rdfs:label 'Network Routing Rule Id' ;
    rdfs:comment 'Foreign key linking to network.network_routing_rule. Business justification: The specific network_routing_rule matched and executed for each routing decision must be traceable for compliance audit, override tracking, and rule performance monitoring. This FK enables direct attr' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkRoutingRule .

ind:primaryTxnNetworkSchemeId rdf:type rdf:Property ;
    rdfs:label 'Primary Txn Network Scheme Id' ;
    rdfs:comment 'Identifier of the payment network (e.g., Visa, Mastercard).' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Scheme .

ind:routingTableId rdf:type rdf:Property ;
    rdfs:label 'Routing Table Id' ;
    rdfs:comment 'Foreign key linking to network.routing_table. Business justification: Each routing decision consults a specific routing_table entry (BIN range, MCC, currency rules). Linking the decision to the routing_table row applied enables routing rule effectiveness analysis, least' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoutingTable .

ind:candidateNetworks rdf:type rdf:Property ;
    rdfs:label 'Candidate Networks' ;
    rdfs:comment 'Comma-separated list of networks evaluated during routing decision.' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardPresent rdf:type rdf:Property ;
    rdfs:label 'Card Present' ;
    rdfs:comment 'True if the transaction was card-present (vs. card-not-present).' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossBorderFee rdf:type rdf:Property ;
    rdfs:label 'Cross Border Fee' ;
    rdfs:comment 'Additional fee applied for cross-border processing, if any.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decisionReference rdf:type rdf:Property ;
    rdfs:label 'Decision Reference' ;
    rdfs:comment 'Human-readable reference code for the routing decision (e.g., RD-20231101-0001).' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Timestamp when the routing decision was recorded.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:durbinComplianceApplied rdf:type rdf:Property ;
    rdfs:label 'Durbin Compliance Applied' ;
    rdfs:comment 'Flag indicating whether Durbin Amendment routing rules were enforced.' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lcrApplied rdf:type rdf:Property ;
    rdfs:label 'Lcr Applied' ;
    rdfs:comment 'Flag indicating whether least-cost routing logic was applied.' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Routing Latency Ms' ;
    rdfs:comment 'Time in milliseconds from receipt of the transaction to routing decision.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routingPath rdf:type rdf:Property ;
    rdfs:label 'Routing Path' ;
    rdfs:comment 'Serialized representation of the processing path taken (e.g., gateway → network → acquirer).' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingReason rdf:type rdf:Property ;
    rdfs:label 'Routing Reason' ;
    rdfs:comment 'Business reason why the selected network was chosen.' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingRuleVersion rdf:type rdf:Property ;
    rdfs:label 'Routing Rule Version' ;
    rdfs:comment 'Version identifier of the routing rule set applied to this transaction.' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionFee rdf:type rdf:Property ;
    rdfs:label 'Transaction Fee' ;
    rdfs:comment 'Total fees applied to the transaction (e.g., interchange, network, processing).' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:txnRoutingDecisionStatus rdf:type rdf:Property ;
    rdfs:label 'Txn Routing Decision Status' ;
    rdfs:comment 'Current processing status of the routing decision record.' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:txnFeeId rdf:type rdf:Property ;
    rdfs:label 'Txn Fee Id' ;
    rdfs:comment 'Unique identifier for the fee record associated with a payment transaction.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:merchantPayoutId rdf:type rdf:Property ;
    rdfs:label 'Merchant Payout Id' ;
    rdfs:comment 'Foreign key linking to settlement.merchant_payout. Business justification: MDR, interchange, and scheme fees are deducted in merchant payouts. Linking txn_fee to merchant_payout enables fee-level payout reconciliation, merchant dispute resolution, and transparent fee disclos' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchantPayout .

ind:feeAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Fee Amount Usd' ;
    rdfs:comment 'Fee amount converted to US Dollars for standardized reporting.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Approval Status' ;
    rdfs:comment 'Approval state of the fee after compliance review.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fee Approval Timestamp' ;
    rdfs:comment 'Timestamp when the fee was approved or rejected.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:feeAuditTrail rdf:type rdf:Property ;
    rdfs:label 'Fee Audit Trail' ;
    rdfs:comment 'JSON-encoded audit log capturing changes to the fee record.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCalculationBasis rdf:type rdf:Property ;
    rdfs:label 'Fee Calculation Basis' ;
    rdfs:comment 'Method used to calculate the fee.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fee Created Timestamp' ;
    rdfs:comment 'Timestamp when the fee record was created.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:feeCurrency rdf:type rdf:Property ;
    rdfs:label 'Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the fee amount.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Fee Effective Date' ;
    rdfs:comment 'Date when the fee becomes effective.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeExchangeRate rdf:type rdf:Property ;
    rdfs:label 'Fee Exchange Rate' ;
    rdfs:comment 'Exchange rate used to convert the fee amount to the reporting currency.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Fee Expiration Date' ;
    rdfs:comment 'Date when the fee ceases to be applicable (null if indefinite).' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeFlatAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Flat Amount' ;
    rdfs:comment 'Fixed amount applied when the calculation basis is flat.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Fee Jurisdiction Code' ;
    rdfs:comment 'Three-letter ISO country code indicating the jurisdiction governing the fee.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeQuantity rdf:type rdf:Property ;
    rdfs:label 'Fee Quantity' ;
    rdfs:comment 'Number of units used in tiered or volume-based fee calculations.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeRate rdf:type rdf:Property ;
    rdfs:label 'Fee Rate' ;
    rdfs:comment 'Percentage rate applied when the calculation basis is percentage.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeRegulatoryReportingCode rdf:type rdf:Property ;
    rdfs:label 'Fee Regulatory Reporting Code' ;
    rdfs:comment 'Code used for regulatory reporting of the fee (e.g., PCI, PSD2).' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeResponsibleParty rdf:type rdf:Property ;
    rdfs:label 'Fee Responsible Party' ;
    rdfs:comment 'Entity responsible for paying the fee.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeReversalFlag rdf:type rdf:Property ;
    rdfs:label 'Fee Reversal Flag' ;
    rdfs:comment 'Indicates whether this fee record represents a reversal.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeRuleVersion rdf:type rdf:Property ;
    rdfs:label 'Fee Rule Version' ;
    rdfs:comment 'Version of the fee calculation rule applied.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeSequence rdf:type rdf:Property ;
    rdfs:label 'Fee Sequence' ;
    rdfs:comment 'Sequential order of the fee line within the transaction fee set.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Fee Settlement Date' ;
    rdfs:comment 'Date on which the fee was settled.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeSettlementStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Settlement Status' ;
    rdfs:comment 'Settlement state of the fee with respect to the financial ledger.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Fee Source System' ;
    rdfs:comment 'System of record that originated the fee (e.g., gateway, settlement platform).' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Tax Amount' ;
    rdfs:comment 'Tax amount applied to the fee, if taxable.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeTierDescription rdf:type rdf:Property ;
    rdfs:label 'Fee Tier Description' ;
    rdfs:comment 'Textual description of the tier applied for tiered fee calculations.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fee Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the fee record.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fxConversionId rdf:type rdf:Property ;
    rdfs:label 'Fx Conversion Id' ;
    rdfs:comment 'Unique surrogate key for each foreign exchange conversion record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FxConversion .

ind:conversionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Conversion Fee Amount' ;
    rdfs:comment 'Fee charged for performing the foreign exchange conversion, expressed in the target currency.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Conversion Fee Currency Code' ;
    rdfs:comment 'Currency in which the conversion fee is denominated.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionMethod rdf:type rdf:Property ;
    rdfs:label 'Conversion Method' ;
    rdfs:comment 'How the conversion rate was applied: automatically, manually, or overridden by an operator.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionNote rdf:type rdf:Property ;
    rdfs:label 'Conversion Note' ;
    rdfs:comment 'Free-form text field for any additional remarks about the conversion.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionReference rdf:type rdf:Property ;
    rdfs:label 'Conversion Reference' ;
    rdfs:comment 'Business reference code assigned to the conversion event for external tracking.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionStatus rdf:type rdf:Property ;
    rdfs:label 'Conversion Status' ;
    rdfs:comment 'Current lifecycle state of the conversion record.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Conversion Timestamp' ;
    rdfs:comment 'Exact date-time when the foreign exchange conversion was executed.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dccOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Dcc Opt In Flag' ;
    rdfs:comment 'True if the cardholder opted in to Dynamic Currency Conversion; otherwise False.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exchangeRateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Timestamp' ;
    rdfs:comment 'Timestamp when the FX rate was sourced, which may differ from conversion_timestamp.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rateValidityEnd rdf:type rdf:Property ;
    rdfs:label 'Rate Validity End' ;
    rdfs:comment 'Date after which the quoted FX rate is no longer valid (nullable).' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateValidityStart rdf:type rdf:Property ;
    rdfs:label 'Rate Validity Start' ;
    rdfs:comment 'Date from which the quoted FX rate is considered valid.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceAmount rdf:type rdf:Property ;
    rdfs:label 'Source Amount' ;
    rdfs:comment 'Transaction amount expressed in the source currency before conversion.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAmount rdf:type rdf:Property ;
    rdfs:label 'Target Amount' ;
    rdfs:comment 'Transaction amount expressed in the target currency after conversion.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceStandard rdf:type rdf:Property ;
    rdfs:label 'Compliance Standard' ;
    rdfs:comment 'Enumerated list of regulatory or industry standards applicable to the transaction type.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCrossBorderAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Cross Border Allowed' ;
    rdfs:comment 'True when the transaction type may be processed for payments involving different currency jurisdictions.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFraudSensitive rdf:type rdf:Property ;
    rdfs:label 'Is Fraud Sensitive' ;
    rdfs:comment 'True when transactions of this type trigger enhanced fraud monitoring.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecurringAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Recurring Allowed' ;
    rdfs:comment 'True when the transaction type can be used for scheduled or subscription payments.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoProcessingCode rdf:type rdf:Property ;
    rdfs:label 'Iso Processing Code' ;
    rdfs:comment 'Standardized processing code defined by ISO 8583 / ISO 20022 that identifies the transaction function.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAmount rdf:type rdf:Property ;
    rdfs:label 'Max Amount' ;
    rdfs:comment 'Upper limit on the monetary value that can be processed under this transaction type.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minAmount rdf:type rdf:Property ;
    rdfs:label 'Min Amount' ;
    rdfs:comment 'Lower bound on the monetary value for this transaction type.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkRuleSet rdf:type rdf:Property ;
    rdfs:label 'Network Rule Set' ;
    rdfs:comment 'Identifier of the rule set that governs routing, fees, and interchange for the transaction type.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingFeeFixed rdf:type rdf:Property ;
    rdfs:label 'Processing Fee Fixed' ;
    rdfs:comment 'Flat fee amount applied to each transaction of this type.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingFeePercent rdf:type rdf:Property ;
    rdfs:label 'Processing Fee Percent' ;
    rdfs:comment 'Variable component of the fee expressed as a percent of the transaction amount.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requires3ds rdf:type rdf:Property ;
    rdfs:label 'Requires 3ds' ;
    rdfs:comment 'True when 3-D Secure authentication is required for this transaction type.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresAmlCheck rdf:type rdf:Property ;
    rdfs:label 'Requires Aml Check' ;
    rdfs:comment 'True when anti-money-laundering screening must be performed for this transaction type.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresAuthentication rdf:type rdf:Property ;
    rdfs:label 'Requires Authentication' ;
    rdfs:comment 'True if the transaction must pass an authentication step before authorization.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresKyc rdf:type rdf:Property ;
    rdfs:label 'Requires Kyc' ;
    rdfs:comment 'True when the transaction type mandates Know-Your-Customer checks.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskScoreCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Score Category' ;
    rdfs:comment 'Categorization used by risk models to apply appropriate scoring thresholds.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Settlement Eligibility Flag' ;
    rdfs:comment 'True when transactions of this type can be settled to a financial institution.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionCategory rdf:type rdf:Property ;
    rdfs:label 'Transaction Category' ;
    rdfs:comment 'Broad category indicating the channel or medium of the transaction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:txnTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Txn Type Description' ;
    rdfs:comment 'Detailed business description of the transaction type, including typical use-cases.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:txnTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Txn Type Status' ;
    rdfs:comment 'Operational state indicating whether the type is in active use, retired, or awaiting approval.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeCode rdf:type rdf:Property ;
    rdfs:label 'Type Code' ;
    rdfs:comment 'Compact alphanumeric code representing the transaction type (e.g., PUR for Purchase).' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeName rdf:type rdf:Property ;
    rdfs:label 'Type Name' ;
    rdfs:comment 'Descriptive name of the transaction type as used in UI and reports.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:txnLimitRuleId rdf:type rdf:Property ;
    rdfs:label 'Txn Limit Rule Id' ;
    rdfs:comment 'System-generated unique identifier for the transaction limit rule.' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactlessLimit rdf:type rdf:Property ;
    rdfs:label 'Contactless Limit' ;
    rdfs:comment 'Maximum amount allowed for contactless (tap-and-go) transactions under this rule.' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossBorderLimit rdf:type rdf:Property ;
    rdfs:label 'Cross Border Limit' ;
    rdfs:comment 'Maximum amount permitted for cross-border transactions governed by this rule.' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentType rdf:type rdf:Property ;
    rdfs:label 'Instrument Type' ;
    rdfs:comment 'Type of payment instrument to which the rule applies.' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitCategory rdf:type rdf:Property ;
    rdfs:label 'Limit Category' ;
    rdfs:comment 'Classification of the rule type indicating which limit dimension it governs.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAmountPerDay rdf:type rdf:Property ;
    rdfs:label 'Max Amount Per Day' ;
    rdfs:comment 'Aggregate monetary limit for the total value of transactions in a single day.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxAmountPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Max Amount Per Transaction' ;
    rdfs:comment 'Upper bound on the monetary value of an individual transaction.' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTransactionsPerDay rdf:type rdf:Property ;
    rdfs:label 'Max Transactions Per Day' ;
    rdfs:comment 'Velocity limit specifying the maximum number of transactions allowed in a calendar day.' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxTransactionsPerHour rdf:type rdf:Property ;
    rdfs:label 'Max Transactions Per Hour' ;
    rdfs:comment 'Velocity limit specifying the maximum number of transactions allowed in any rolling hour.' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'Reference to the regulatory requirement (e.g., PSD2, PCI DSS) that drives the rule.' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapLimit rdf:type rdf:Property ;
    rdfs:label 'Tap Limit' ;
    rdfs:comment 'Maximum amount for NFC tap transactions (often lower than standard contactless limit).' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:txnLimitRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Txn Limit Rule Description' ;
    rdfs:comment 'Free-form description of the business purpose and logic of the rule.' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:txnLimitRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Txn Limit Rule Status' ;
    rdfs:comment 'Current lifecycle status of the rule.' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDocumentId rdf:type rdf:Property ;
    rdfs:label 'Policy Document Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy_document. Business justification: Payment schemes publish operating regulations and rulebooks that are formal policy documents. Compliance teams track which policy document (scheme rulebook version) governs each scheme. Scheme ruleboo' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PolicyDocument .

ind:rateFeedId rdf:type rdf:Property ;
    rdfs:label 'Rate Feed Id' ;
    rdfs:comment 'Foreign key linking to fx.rate_feed. Business justification: Payment schemes designate specific FX rate feeds for DCC and cross-border rate sourcing — Visa uses specific rate providers, Mastercard uses others. Scheme-specific rate feed configuration for DCC com' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateFeed .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'Regulatory and industry standards the scheme must adhere to.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencySupported rdf:type rdf:Property ;
    rdfs:label 'Currency Supported' ;
    rdfs:comment 'Currencies in which the scheme can settle transactions.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'List of ISO-3166-1 alpha-3 country codes where the scheme is accepted.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
