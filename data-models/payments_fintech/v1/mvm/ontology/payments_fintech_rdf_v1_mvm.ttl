    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeImpactType rdf:type rdf:Property ;
    rdfs:label 'Fee Impact Type' ;
    rdfs:comment 'How the feature influences pricing (no impact, fixed fee, percentage fee, or tiered fee).' ;
    rdfs:domain ind:Feature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEnabledByDefault rdf:type rdf:Property ;
    rdfs:label 'Is Enabled By Default' ;
    rdfs:comment 'Indicates whether the feature is enabled by default on new product instances.' ;
    rdfs:domain ind:Feature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryDependency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Dependency' ;
    rdfs:comment 'Regulations or standards that govern the use of this feature.' ;
    rdfs:domain ind:Feature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresAml rdf:type rdf:Property ;
    rdfs:label 'Requires Aml' ;
    rdfs:comment 'Indicates whether Anti-Money-Laundering screening is required for the feature.' ;
    rdfs:domain ind:Feature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresContactless rdf:type rdf:Property ;
    rdfs:label 'Requires Contactless' ;
    rdfs:comment 'Indicates whether contactless (NFC) capability is required for the feature.' ;
    rdfs:domain ind:Feature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresDcc rdf:type rdf:Property ;
    rdfs:label 'Requires Dcc' ;
    rdfs:comment 'Indicates whether Dynamic Currency Conversion is required for the feature.' ;
    rdfs:domain ind:Feature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresInternational rdf:type rdf:Property ;
    rdfs:label 'Requires International' ;
    rdfs:comment 'Indicates whether the feature can be used for cross-border or international payments.' ;
    rdfs:domain ind:Feature ;
    rdf:type owl:DatatypeProperty ;
