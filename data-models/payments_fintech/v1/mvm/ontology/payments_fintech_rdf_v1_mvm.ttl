    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackRateCurrent rdf:type rdf:Property ;
    rdfs:label 'Chargeback Rate Current' ;
    rdfs:comment 'Percentage of total transactions that have resulted in chargebacks in the most recent reporting period.' ;
