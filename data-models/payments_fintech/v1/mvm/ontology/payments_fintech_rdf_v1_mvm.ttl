    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subledgerMethod rdf:type rdf:Property ;
    rdfs:label 'Subledger Method' ;
    rdfs:comment 'Method used for subledger accounting.' ;
    rdfs:domain ind:Config ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Flag' ;
    rdfs:comment 'Indicates if the ledger is used for tax reporting purposes.' ;
    rdfs:domain ind:Config ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:translationMethod rdf:type rdf:Property ;
    rdfs:label 'Translation Method' ;
    rdfs:comment 'Method applied to translate foreign currency balances.' ;
    rdfs:domain ind:Config ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subledgerEntryId rdf:type rdf:Property ;
    rdfs:label 'Subledger Entry Id' ;
    rdfs:comment 'Unique surrogate key for the subledger entry record.' ;
    rdfs:domain ind:SubledgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:counterpartyPartyId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Party Id' ;
    rdfs:comment 'Foreign key linking to compliance.party. Business justification: Subledger entries track transactional counterparties for AML screening, sanctions checks, audit trail requirements, and party-level risk aggregation in payments fintech transaction processing and comp' ;
    rdfs:domain ind:SubledgerEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:primarySubledgerCardholderCardholderProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Subledger Cardholder Cardholder Profile Id' ;
    rdfs:comment 'Identifier of the cardholder involved in the transaction.' ;
    rdfs:domain ind:SubledgerEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CardholderProfile .

ind:glDerivationRule rdf:type rdf:Property ;
    rdfs:label 'Gl Derivation Rule' ;
    rdfs:comment 'Rule applied to derive the GL account from transaction attributes.' ;
    rdfs:domain ind:SubledgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReconciled rdf:type rdf:Property ;
    rdfs:label 'Is Reconciled' ;
    rdfs:comment 'Indicates whether the entry has been reconciled with the GL.' ;
    rdfs:domain ind:SubledgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentInstrumentToken rdf:type rdf:Property ;
    rdfs:label 'Payment Instrument Token' ;
    rdfs:comment 'Token representing the payment instrument used, per tokenization standards.' ;
    rdfs:domain ind:SubledgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current status of posting this entry to the General Ledger.' ;
    rdfs:domain ind:SubledgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Numeric quantity associated with the entry, e.g., number of units or amount of service.' ;
    rdfs:domain ind:SubledgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date when the entry was reconciled.' ;
    rdfs:domain ind:SubledgerEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Schedule Id' ;
    rdfs:comment 'Unique surrogate key for the revenue recognition schedule record.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognitionSchedule .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'Portion of total price allocated to this schedule.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:classificationOrType rdf:type rdf:Property ;
    rdfs:label 'Classification Or Type' ;
    rdfs:comment 'Category of revenue type for the schedule.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyInterval rdf:type rdf:Property ;
    rdfs:label 'Frequency Interval' ;
    rdfs:comment 'Numeric interval for the frequency (e.g., every 2 months).' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isPartialRecognitionAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Partial Recognition Allowed' ;
    rdfs:comment 'Flag indicating if partial recognition is permitted before full amount.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProrated rdf:type rdf:Property ;
    rdfs:label 'Is Prorated' ;
    rdfs:comment 'Indicates if the schedule uses prorated amounts.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recognitionEndDate rdf:type rdf:Property ;
    rdfs:label 'Recognition End Date' ;
    rdfs:comment 'Scheduled end date for the final recognition event.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionFrequency rdf:type rdf:Property ;
    rdfs:label 'Recognition Frequency' ;
    rdfs:comment 'Frequency at which revenue is recognized.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'Method used to recognize revenue.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Start Date' ;
    rdfs:comment 'Scheduled start date for the first recognition event.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognizedToDateAmount rdf:type rdf:Property ;
    rdfs:label 'Recognized To Date Amount' ;
    rdfs:comment 'Cumulative amount recognized to date.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTransactionPrice rdf:type rdf:Property ;
    rdfs:label 'Total Transaction Price' ;
    rdfs:comment 'Total contract transaction price allocated to this performance obligation.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionEventId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Event Id' ;
    rdfs:comment 'Unique identifier for the revenue recognition event.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Gl Journal Entry Id' ;
    rdfs:comment 'Identifier of the GL journal entry created for this revenue recognition.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:reversalEventRevenueRecognitionEventId rdf:type rdf:Property ;
    rdfs:label 'Reversal Event Revenue Recognition Event Id' ;
    rdfs:comment 'If this event reverses a prior recognition, reference to that event.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognitionEvent .

ind:auditComment rdf:type rdf:Property ;
    rdfs:label 'Audit Comment' ;
    rdfs:comment 'Free-form comment for audit or review purposes.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeRecognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Recognized Amount' ;
    rdfs:comment 'Total amount recognized to date for the schedule, including this event.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isForeignCurrency rdf:type rdf:Property ;
    rdfs:label 'Is Foreign Currency' ;
    rdfs:comment 'True if the recognized amount was originally in a foreign currency.' ;
