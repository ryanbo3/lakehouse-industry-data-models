    rdfs:comment 'ISO 4217 currency code for the typical loss amount.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistId rdf:type rdf:Property ;
    rdfs:label 'Watchlist Id' ;
    rdfs:comment 'System-generated unique identifier for each watchlist entry.' ;
    rdfs:domain ind:Watchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactMethod rdf:type rdf:Property ;
    rdfs:label 'Contact Method' ;
    rdfs:comment 'Preferred contact channel for the watchlist entity used for notifications or escalations.' ;
    rdfs:domain ind:Watchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringLevel rdf:type rdf:Property ;
    rdfs:label 'Monitoring Level' ;
    rdfs:comment 'Intensity of monitoring applied to the entity (passive = observation only, active = heightened scrutiny, step_up = requires step-up authentication).' ;
    rdfs:domain ind:Watchlist ;
    rdf:type owl:DatatypeProperty ;
