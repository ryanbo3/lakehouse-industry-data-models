ind:balanceStatus rdf:type rdf:Property ;
    rdfs:label 'Balance Status' ;
    rdfs:comment 'Lifecycle state of the balance (e.g., posted after close, provisional during interim).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceType rdf:type rdf:Property ;
    rdfs:label 'Balance Type' ;
    rdfs:comment 'Indicates whether the balance is in functional currency or reporting currency.' ;
