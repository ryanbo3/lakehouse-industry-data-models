ind:watchlistSource rdf:type rdf:Property ;
    rdfs:label 'Watchlist Source' ;
    rdfs:comment 'Origin of the watchlist entry (internal risk team, external network advisory, law-enforcement notification).' ;
    rdfs:domain ind:Watchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistStatus rdf:type rdf:Property ;
    rdfs:label 'Watchlist Status' ;
    rdfs:comment 'Current lifecycle status of the watchlist entry.' ;
    rdfs:domain ind:Watchlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenedAccountHolderId rdf:type rdf:Property ;
    rdfs:label 'Screened Account Holder Id' ;
    rdfs:comment 'Foreign key linking to cardholder.account_holder. Business justification: AML screening is performed on account holders during onboarding and ongoing monitoring per FATF/BSA requirements. Compliance operations teams must trace each AML screening result to the specific accou' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountHolder .

ind:analystOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Analyst Override Flag' ;
    rdfs:comment 'Indicates whether an analyst manually overrode the automated disposition.' ;
