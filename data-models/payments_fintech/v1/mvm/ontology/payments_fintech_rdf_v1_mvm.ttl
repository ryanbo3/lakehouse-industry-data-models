    rdfs:comment 'Foreign key linking to cardholder.cardholder_account. Business justification: Compliance cases trigger account-level actions (suspension, credit limit freeze, account closure). Compliance and operations teams need to link a case directly to the affected cardholder_account to ex' ;
    rdfs:domain ind:ComplianceCase ;
