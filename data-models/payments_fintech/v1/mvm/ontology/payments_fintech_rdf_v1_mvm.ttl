ind:issuingParticipantId rdf:type rdf:Property ;
    rdfs:label 'Issuing Participant Id' ;
    rdfs:comment 'Foreign key linking to settlement.participant. Business justification: Regulatory AML/KYC reporting requires linking each cardholder to their issuing bank’s settlement participant to trace funds and satisfy cross-border settlement netting.' ;
    rdfs:domain ind:Cardholder ;
