    rdfs:comment 'Unique identifier of the cardholder to whom the consent applies.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CardholderProfile .

ind:collectionChannel rdf:type rdf:Property ;
