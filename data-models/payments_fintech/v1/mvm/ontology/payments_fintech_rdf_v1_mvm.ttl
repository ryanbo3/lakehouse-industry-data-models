ind:regulatoryStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status' ;
    rdfs:comment 'Regulatory compliance status of the acquirer.' ;
    rdfs:domain ind:Acquirer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Commonly used short name or brand for the acquirer.' ;
    rdfs:domain ind:Acquirer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportContactName rdf:type rdf:Property ;
    rdfs:label 'Support Contact Name' ;
    rdfs:comment 'Name of the primary support contact person for the acquirer.' ;
    rdfs:domain ind:Acquirer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corridorBankAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Corridor Bank Assignment Id' ;
    rdfs:comment 'Unique system-generated identifier for this corridor-bank assignment record' ;
    rdfs:domain ind:CorridorBankAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Assigned By User Code' ;
    rdfs:comment 'Reference to the treasury or operations user who created or last approved this corridor-bank assignment' ;
    rdfs:domain ind:CorridorBankAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeOverride rdf:type rdf:Property ;
    rdfs:label 'Fee Override' ;
    rdfs:comment 'Negotiated fee amount specific to this corridor-bank combination, overriding the correspondent bank\'s standard fee schedule when populated' ;
    rdfs:domain ind:CorridorBankAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxDailyVolumeUsd rdf:type rdf:Property ;
    rdfs:label 'Max Daily Volume Usd' ;
    rdfs:comment 'Maximum daily transaction volume in USD that can be routed through this correspondent bank for this specific corridor, used for liquidity and risk management' ;
    rdfs:domain ind:CorridorBankAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCorridors rdf:type rdf:Property ;
    rdfs:label 'Payment Corridors' ;
    rdfs:comment 'Geographic or network corridors (e.g., US-EU, APAC-LATAM) the bank supports for cross-border payments. [Moved from correspondent_bank: This STRING attribute in correspondent_bank lists corridors the bank supports, but the actual operational assignment with priority, dates, and fees belongs in the association. The attribute should be removed as it creates denormalization and will be replaced by querying the corridor_bank_assignment association.]' ;
    rdfs:domain ind:CorridorBankAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedCoverageId rdf:type rdf:Property ;
    rdfs:label 'Feed Coverage Id' ;
    rdfs:comment 'Surrogate primary key uniquely identifying each feed-pair coverage configuration record' ;
    rdfs:domain ind:FeedCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confidenceWeight rdf:type rdf:Property ;
    rdfs:label 'Confidence Weight' ;
    rdfs:comment 'Weighting factor (0.0000 to 1.0000) representing the confidence/quality of rates from this feed for this specific pair. Used in weighted rate aggregation algorithms when multiple feeds provide rates for the same pair.' ;
    rdfs:domain ind:FeedCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Status' ;
    rdfs:comment 'Lifecycle status of this feed-pair coverage configuration (active, suspended, deprecated, testing)' ;
    rdfs:domain ind:FeedCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimarySource rdf:type rdf:Property ;
    rdfs:label 'Is Primary Source' ;
    rdfs:comment 'True if this feed is designated as the primary/preferred source for this currency pair. Used in rate aggregation and failover logic when multiple feeds cover the same pair.' ;
    rdfs:domain ind:FeedCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRateReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Rate Received Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful rate retrieval for this specific feed-pair combination. Used for monitoring feed health at the pair level.' ;
    rdfs:domain ind:FeedCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:precisionOverride rdf:type rdf:Property ;
    rdfs:label 'Precision Override' ;
    rdfs:comment 'Decimal precision override specific to this feed-pair combination, overriding the currency_pair default when this feed is the source. Allows feed-specific precision handling.' ;
    rdfs:domain ind:FeedCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportedCurrencyPairs rdf:type rdf:Property ;
    rdfs:label 'Supported Currency Pairs' ;
    rdfs:comment 'List of currency pairs (e.g., EUR/USD, GBP/JPY) that the feed supplies. [Moved from rate_feed: This STRING field in rate_feed is a denormalized list representation of the M:N relationship. The proper normalized model captures each feed-pair coverage as a separate record in the association, eliminating the need for this comma-separated list. The association provides granular control over which pairs each feed covers with pair-specific configuration.]' ;
    rdfs:domain ind:FeedCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casePartyInvolvementId rdf:type rdf:Property ;
    rdfs:label 'Case Party Involvement Id' ;
    rdfs:comment 'Unique identifier for this case-party involvement record' ;
    rdfs:domain ind:CasePartyInvolvement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewDate rdf:type rdf:Property ;
    rdfs:label 'Interview Date' ;
    rdfs:comment 'Date when this party was interviewed regarding this case (nullable)' ;
    rdfs:domain ind:CasePartyInvolvement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:involvementDate rdf:type rdf:Property ;
    rdfs:label 'Involvement Date' ;
    rdfs:comment 'Date when this party was identified as involved in the case' ;
    rdfs:domain ind:CasePartyInvolvement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:involvementNotes rdf:type rdf:Property ;
    rdfs:label 'Involvement Notes' ;
    rdfs:comment 'Free-form notes about this specific party\'s involvement in this specific case' ;
    rdfs:domain ind:CasePartyInvolvement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:involvementRole rdf:type rdf:Property ;
    rdfs:label 'Involvement Role' ;
    rdfs:comment 'The role this party plays in the compliance case investigation (e.g., primary subject, witness, associated entity, beneficial owner)' ;
    rdfs:domain ind:CasePartyInvolvement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:involvementStatus rdf:type rdf:Property ;
    rdfs:label 'Involvement Status' ;
    rdfs:comment 'Current status of this party\'s involvement in the investigation (e.g., identified, under review, interviewed, cleared, implicated)' ;
    rdfs:domain ind:CasePartyInvolvement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimarySubject rdf:type rdf:Property ;
    rdfs:label 'Is Primary Subject' ;
    rdfs:comment 'Flag indicating whether this party is the primary subject of the compliance investigation' ;
    rdfs:domain ind:CasePartyInvolvement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskContributionLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Contribution Level' ;
    rdfs:comment 'Assessment of how much this party contributed to the compliance risk in this case' ;
    rdfs:domain ind:CasePartyInvolvement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
