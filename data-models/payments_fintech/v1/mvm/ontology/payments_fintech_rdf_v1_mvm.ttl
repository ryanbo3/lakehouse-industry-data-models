ind:grossLossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Loss Amount' ;
    rdfs:comment 'Total monetary value of the fraudulent transaction before any recovery.' ;
    rdfs:domain ind:Loss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lossCategory rdf:type rdf:Property ;
    rdfs:label 'Loss Category' ;
    rdfs:comment 'Category describing how the fraud occurred (e.g., card-present, CNP, account takeover).' ;
    rdfs:domain ind:Loss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossDescription rdf:type rdf:Property ;
    rdfs:label 'Loss Description' ;
    rdfs:comment 'Free-form text describing the circumstances of the fraud loss.' ;
    rdfs:domain ind:Loss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossStatus rdf:type rdf:Property ;
    rdfs:label 'Loss Status' ;
    rdfs:comment 'Current processing state of the loss record.' ;
    rdfs:domain ind:Loss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netLossAmount rdf:type rdf:Property ;
    rdfs:label 'Net Loss Amount' ;
    rdfs:comment 'Final loss after subtracting recovered amount from gross loss.' ;
