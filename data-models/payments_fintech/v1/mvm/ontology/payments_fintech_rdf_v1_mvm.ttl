    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresTokenization rdf:type rdf:Property ;
    rdfs:label 'Requires Tokenization' ;
    rdfs:comment 'Indicates whether tokenization of payment credentials is mandatory for the feature.' ;
    rdfs:domain ind:Feature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:featureAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Feature Assignment Id' ;
    rdfs:comment 'System-generated unique identifier for each product-feature assignment record.' ;
    rdfs:domain ind:FeatureAssignment ;
