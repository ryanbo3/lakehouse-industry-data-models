    rdfs:comment 'Timestamp of the most recent compliance review for the batch.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crossBorderCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cross Border Currency Code' ;
    rdfs:comment 'Currency code of the foreign currency involved in cross-border settlement. [ENUM-REF-CANDIDATE: USD|EUR|GBP|JPY|CHF|... — promote to reference product]' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Credit Amount' ;
    rdfs:comment 'Total credit (incoming) amount of all transactions in the batch before netting.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Debit Amount' ;
    rdfs:comment 'Total debit (outgoing) amount of all transactions in the batch before netting.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPositionAmount rdf:type rdf:Property ;
    rdfs:label 'Net Position Amount' ;
    rdfs:comment 'Net position (balance) of the settlement participant after this batch is applied.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPositionCurrency rdf:type rdf:Property ;
    rdfs:label 'Net Position Currency' ;
    rdfs:comment 'Currency of the net position amount. [ENUM-REF-CANDIDATE: USD|EUR|GBP|JPY|CHF|CAD|... — promote to reference product]' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingCenterCode rdf:type rdf:Property ;
    rdfs:label 'Processing Center Code' ;
    rdfs:comment 'Internal code of the processing center handling the batch.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Fee Amount' ;
    rdfs:comment 'Fee charged by the scheme or clearing house for processing the batch.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Settlement Fee Currency' ;
    rdfs:comment 'Currency of the settlement fee amount. [ENUM-REF-CANDIDATE: USD|EUR|GBP|JPY|CHF|... — promote to reference product]' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementInstructionsReference rdf:type rdf:Property ;
    rdfs:label 'Settlement Instructions Reference' ;
    rdfs:comment 'Reference identifier for the settlement instruction file associated with the batch.' ;
    rdfs:domain ind:SettlementBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Settlement Timestamp' ;
    rdfs:comment 'Timestamp when the net settlement was executed (nullable).' ;
    rdfs:domain ind:Settlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:instructionId rdf:type rdf:Property ;
    rdfs:label 'Instruction Id' ;
    rdfs:comment 'Primary key for instruction' ;
    rdfs:domain ind:Settlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instruction .

ind:instructionSettlementParticipantId rdf:type rdf:Property ;
    rdfs:label 'Instruction Settlement Participant Id' ;
    rdfs:comment 'Internal identifier of the party that funds the instruction (e.g., acquiring bank or merchant).' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Participant .

ind:netPositionId rdf:type rdf:Property ;
    rdfs:label 'Net Position Id' ;
    rdfs:comment 'Link to the net settlement position that aggregates multiple instructions.' ;
    rdfs:domain ind:Settlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetPosition .

ind:receivingPartySettlementParticipantId rdf:type rdf:Property ;
    rdfs:label 'Receiving Party Settlement Participant Id' ;
    rdfs:comment 'Internal identifier of the party that receives the funds (e.g., issuing bank or settlement participant).' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Participant .

ind:reversalOfInstructionId rdf:type rdf:Property ;
    rdfs:label 'Reversal Of Instruction Id' ;
    rdfs:comment 'If this is a reversal, points to the original instruction being reversed.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instruction .

ind:currencyConversionIndicator rdf:type rdf:Property ;
    rdfs:label 'Currency Conversion Indicator' ;
    rdfs:comment 'True if the instruction required currency conversion.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instructionNumber rdf:type rdf:Property ;
    rdfs:label 'Instruction Number' ;
    rdfs:comment 'Business-visible identifier assigned to the instruction, used for tracking and reconciliation.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionStatus rdf:type rdf:Property ;
    rdfs:label 'Instruction Status' ;
    rdfs:comment 'Current lifecycle state of the instruction.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Instruction Timestamp' ;
    rdfs:comment 'Timestamp of the real-world event that triggered the instruction (e.g., value date time).' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:instructionType rdf:type rdf:Property ;
    rdfs:label 'Instruction Type' ;
    rdfs:comment 'Indicates whether the instruction adds (credit) or subtracts (debit) funds.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalCurrency rdf:type rdf:Property ;
    rdfs:label 'Original Currency' ;
    rdfs:comment 'Currency of the original transaction amount.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this instruction is a reversal of a prior instruction.' ;
