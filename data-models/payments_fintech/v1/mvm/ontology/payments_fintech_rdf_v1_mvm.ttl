ind:cycleId rdf:type rdf:Property ;
    rdfs:label 'Cycle Id' ;
    rdfs:comment 'Primary key for cycle' ;
    rdfs:domain ind:Settlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cycle .

ind:cutOffTime rdf:type rdf:Property ;
    rdfs:label 'Cut Off Time' ;
    rdfs:comment 'Timestamp representing the cut-off deadline for transaction inclusion in this cycle.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Business-visible code identifying the settlement cycle, used in operational reporting.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleStatus rdf:type rdf:Property ;
    rdfs:label 'Cycle Status' ;
    rdfs:comment 'Current lifecycle status of the settlement cycle.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Timestamp when the settlement cycle ends; nullable for open-ended cycles.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:netPosition rdf:type rdf:Property ;
    rdfs:label 'Net Position' ;
    rdfs:comment 'Net position of the settlement participant after this cycle.' ;
