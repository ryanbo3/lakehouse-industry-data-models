ind:nostroAccountId rdf:type rdf:Property ;
    rdfs:label 'Nostro Account Id' ;
    rdfs:comment 'Foreign key linking to fx.nostro_account. Business justification: Scheme membership fees (annual fees, renewal fees) are paid from designated nostro accounts. The plain fee_payment_account attribute is a denormalized reference to the nostro account. Membership fee p' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
