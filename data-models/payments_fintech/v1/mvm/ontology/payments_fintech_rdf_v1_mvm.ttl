    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limitChangeReason rdf:type rdf:Property ;
    rdfs:label 'Limit Change Reason' ;
    rdfs:comment 'Free-text description explaining why the limit was created or modified.' ;
    rdfs:domain ind:ProcessingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitCode rdf:type rdf:Property ;
    rdfs:label 'Limit Code' ;
    rdfs:comment 'Business code that uniquely identifies the type of limit configuration.' ;
    rdfs:domain ind:PaymentsFintech ;
