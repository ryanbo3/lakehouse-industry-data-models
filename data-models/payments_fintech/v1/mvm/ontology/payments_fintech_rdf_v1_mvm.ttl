    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingLimitStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Limit Status' ;
    rdfs:comment 'Current lifecycle status of the limit configuration.' ;
    rdfs:domain ind:ProcessingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Limit Amount' ;
    rdfs:comment 'Maximum total amount that can be refunded within the limit period.' ;
    rdfs:domain ind:ProcessingLimit ;
    rdf:type owl:DatatypeProperty ;
