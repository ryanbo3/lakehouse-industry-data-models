    rdfs:comment 'Channel through which the verification request originated.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationScore rdf:type rdf:Property ;
    rdfs:label 'Verification Score' ;
    rdfs:comment 'Numerical confidence score (0-100) produced by the KYC engine.' ;
    rdfs:domain ind:CardholderKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kycDocumentId rdf:type rdf:Property ;
    rdfs:label 'Kyc Document Id' ;
    rdfs:comment 'Unique surrogate identifier for the KYC document record.' ;
    rdfs:domain ind:KycDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checksum rdf:type rdf:Property ;
    rdfs:label 'Checksum' ;
    rdfs:comment 'SHA-256 checksum of the document file for integrity verification.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Timestamp' ;
    rdfs:comment 'Timestamp when the compliance evaluation was performed.' ;
    rdfs:domain ind:Cardholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'Business classification of the document purpose for KYC.' ;
    rdfs:domain ind:KycDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentImageUri rdf:type rdf:Property ;
    rdfs:label 'Document Image Uri' ;
    rdfs:comment 'Secure vault URI pointing to the stored image or PDF of the document.' ;
    rdfs:domain ind:KycDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentIssuePlace rdf:type rdf:Property ;
    rdfs:label 'Document Issue Place' ;
    rdfs:comment 'City or locality where the document was issued.' ;
    rdfs:domain ind:KycDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLanguage rdf:type rdf:Property ;
    rdfs:label 'Document Language' ;
    rdfs:comment 'Two-letter language code of the document content.' ;
    rdfs:domain ind:KycDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Masked or tokenized identifier of the document (e.g., passport number).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'File format of the stored document image.' ;
    rdfs:domain ind:KycDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the stored document file in bytes.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date on which the document was originally issued by the authority.' ;
    rdfs:domain ind:KycDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingCountry rdf:type rdf:Property ;
    rdfs:label 'Issuing Country' ;
    rdfs:comment 'Three-letter ISO country code of the authority that issued the document.' ;
    rdfs:domain ind:KycDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycDocumentStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Document Status' ;
    rdfs:comment 'Current lifecycle status of the document record.' ;
    rdfs:domain ind:KycDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manualReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Manual Review Outcome' ;
    rdfs:comment 'Result of the manual review after completion.' ;
    rdfs:domain ind:KycDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manualReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Manual Review Status' ;
    rdfs:comment 'Current status of the human review process for the document.' ;
    rdfs:domain ind:KycDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ocrConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Ocr Confidence Score' ;
    rdfs:comment 'Confidence percentage (0-100) of the OCR extraction accuracy.' ;
    rdfs:domain ind:KycDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ocrStatus rdf:type rdf:Property ;
    rdfs:label 'Ocr Status' ;
    rdfs:comment 'Current status of optical character recognition processing for the document.' ;
    rdfs:domain ind:KycDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'Date after which the document must be deleted to satisfy regulatory retention rules.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Date-time when the manual review was finalized.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tamperDetected rdf:type rdf:Property ;
    rdfs:label 'Tamper Detected' ;
    rdfs:comment 'Indicates whether the document image shows signs of tampering.' ;
    rdfs:domain ind:KycDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:panRecordId rdf:type rdf:Property ;
    rdfs:label 'Pan Record Id' ;
    rdfs:comment 'Surrogate primary key for the PAN record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PanRecord .

ind:binSponsorshipId rdf:type rdf:Property ;
    rdfs:label 'Bin Sponsorship Id' ;
    rdfs:comment 'Foreign key linking to partner.bin_sponsorship. Business justification: Each PAN falls within a specific BIN sponsorship range. BIN sponsorship governs the PAN\'s card scheme rules, issuing bank compliance, and revenue share. Domain experts expect pan_record to reference b' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BinSponsorship .

ind:primaryPanCardholderCardholderProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Pan Cardholder Cardholder Profile Id' ;
    rdfs:comment 'Surrogate key linking the PAN to its owning cardholder profile.' ;
    rdfs:domain ind:PanRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CardholderProfile .

ind:amlScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Status' ;
    rdfs:comment 'Result of Anti-Money-Laundering screening for the PAN.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Flag' ;
    rdfs:comment 'True if the PAN has been flagged for suspected fraudulent activity.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iin rdf:type rdf:Property ;
    rdfs:label 'Iin' ;
    rdfs:comment 'First eight digits of the PAN used for routing and issuer identification.' ;
    rdfs:domain ind:PanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFour rdf:type rdf:Property ;
    rdfs:label 'Last Four' ;
    rdfs:comment 'Last four digits of the PAN, commonly used for verification and customer service.' ;
    rdfs:domain ind:PanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Used Timestamp' ;
    rdfs:comment 'Date-time of the most recent successful authorization involving this PAN.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maskedPan rdf:type rdf:Property ;
    rdfs:label 'Masked Pan' ;
    rdfs:comment 'Masked representation of the PAN (e.g., XXXX-XXXX-XXXX-1234) for human-readable displays.' ;
    rdfs:domain ind:PanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panFormat rdf:type rdf:Property ;
    rdfs:label 'Pan Format' ;
    rdfs:comment 'Indicates whether the PAN consists of only numeric characters or includes alphanumeric characters.' ;
    rdfs:domain ind:PanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panLength rdf:type rdf:Property ;
    rdfs:label 'Pan Length' ;
    rdfs:comment 'Number of digits in the PAN (typically 16, 15, or 19).' ;
    rdfs:domain ind:PanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:panStatus rdf:type rdf:Property ;
    rdfs:label 'Pan Status' ;
    rdfs:comment 'Operational status of the PAN within its lifecycle.' ;
    rdfs:domain ind:PanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panToken rdf:type rdf:Property ;
    rdfs:label 'Pan Token' ;
    rdfs:comment 'PCI-DSS compliant token that represents the PAN; never stores the clear PAN.' ;
    rdfs:domain ind:PanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panType rdf:type rdf:Property ;
    rdfs:label 'Pan Type' ;
    rdfs:comment 'Indicates whether the PAN is a physical PAN (FPAN) or a device-generated token (DPAN).' ;
    rdfs:domain ind:PanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Token Expiry Date' ;
    rdfs:comment 'Date when the PAN token becomes invalid.' ;
    rdfs:domain ind:PanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tokenServiceProvider rdf:type rdf:Property ;
    rdfs:label 'Token Service Provider' ;
    rdfs:comment 'Entity responsible for generating and managing the PAN token.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenizationMethod rdf:type rdf:Property ;
    rdfs:label 'Tokenization Method' ;
    rdfs:comment 'Technique used to derive the token from the clear PAN.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Total number of successful transactions processed for this PAN.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentCredentialId rdf:type rdf:Property ;
    rdfs:label 'Payment Credential Id' ;
    rdfs:comment 'Unique system-generated identifier for the payment credential record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentCredential .

ind:primaryPaymentCardholderCardholderProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Cardholder Cardholder Profile Id' ;
    rdfs:comment 'Identifier of the cardholder who owns this credential.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CardholderProfile .

ind:authenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Authentication Method' ;
    rdfs:comment 'Primary method used to authenticate the credential during a transaction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biometricEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Biometric Enabled Flag' ;
    rdfs:comment 'Indicates whether biometric authentication is enabled for this credential.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biometricType rdf:type rdf:Property ;
    rdfs:label 'Biometric Type' ;
    rdfs:comment 'Specific biometric modality used (if enabled).' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactlessNfcEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Contactless Nfc Enabled Flag' ;
    rdfs:comment 'True when NFC/contactless payments are permitted for this credential.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:credentialLabel rdf:type rdf:Property ;
    rdfs:label 'Credential Label' ;
    rdfs:comment 'Human-readable name or label assigned to the credential (e.g., "Primary Card Credential").' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Credential Source System' ;
    rdfs:comment 'Name of the operational system that originated the credential record (e.g., Digital Wallet Platform).' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialStatus rdf:type rdf:Property ;
    rdfs:label 'Credential Status' ;
    rdfs:comment 'Current operational state of the credential.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialType rdf:type rdf:Property ;
    rdfs:label 'Credential Type' ;
    rdfs:comment 'Category of the credential indicating the underlying payment instrument.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialVersion rdf:type rdf:Property ;
    rdfs:label 'Credential Version' ;
    rdfs:comment 'Monotonically increasing version number for the credential record.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cvv2ValidationFlag rdf:type rdf:Property ;
    rdfs:label 'Cvv2 Validation Flag' ;
    rdfs:comment 'Indicates whether CVV2 validation is required for this credential.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cvvHashRef rdf:type rdf:Property ;
    rdfs:label 'Cvv Hash Ref' ;
    rdfs:comment 'Reference to the hashed CVV/CVC stored securely in the HSM.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emvChipEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Emv Chip Enabled Flag' ;
    rdfs:comment 'Indicates whether EMV chip authentication is supported.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalCredentialCode rdf:type rdf:Property ;
    rdfs:label 'External Credential Code' ;
    rdfs:comment 'Identifier used by external systems (e.g., token service provider) to reference this credential.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsmKeyReference rdf:type rdf:Property ;
    rdfs:label 'Hsm Key Reference' ;
    rdfs:comment 'Identifier of the HSM key used to encrypt credential secrets.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceDate rdf:type rdf:Property ;
    rdfs:label 'Issuance Date' ;
    rdfs:comment 'Date when the credential was originally issued.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRotationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Rotation Timestamp' ;
    rdfs:comment 'Date-time when the credential secrets were last rotated.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:otpEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Otp Enabled Flag' ;
    rdfs:comment 'Indicates whether one-time-password (OTP) authentication is active.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otpLastSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Otp Last Sent Timestamp' ;
    rdfs:comment 'Date-time when the most recent OTP was generated/sent.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:panLinkageStatus rdf:type rdf:Property ;
    rdfs:label 'Pan Linkage Status' ;
    rdfs:comment 'Current relationship status between the credential and its PAN/DPAN.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinLastChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pin Last Change Timestamp' ;
    rdfs:comment 'Date-time when the PIN offset was last updated.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pinOffset rdf:type rdf:Property ;
    rdfs:label 'Pin Offset' ;
    rdfs:comment 'Encrypted PIN offset used for offline PIN verification (PCI-DSS).' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sca Compliance Flag' ;
    rdfs:comment 'True when the credential meets PSD2 Strong Customer Authentication requirements.' ;
    rdfs:domain ind:Cardholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scaComplianceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sca Compliance Timestamp' ;
    rdfs:comment 'Date-time when SCA compliance was last verified.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:threeDsEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Three Ds Enrollment Status' ;
    rdfs:comment 'State of Strong Customer Authentication enrollment for this credential.' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeDsMethod rdf:type rdf:Property ;
    rdfs:label 'Three Ds Method' ;
    rdfs:comment 'Method used for 3-DS challenge-response (e.g., OTP, biometric).' ;
    rdfs:domain ind:PaymentCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderScaChallengeId rdf:type rdf:Property ;
    rdfs:label 'Cardholder Sca Challenge Id' ;
    rdfs:comment 'Globally unique identifier for the SCA challenge event.' ;
    rdfs:domain ind:CardholderScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auth3dsResultId rdf:type rdf:Property ;
    rdfs:label 'Auth 3ds Result Id' ;
    rdfs:comment 'Foreign key linking to fraud.auth_3ds_result. Business justification: 3DS authentication outcome reporting requires linking the cardholder-side SCA challenge to the ACS/fraud-side auth_3ds_result for liability shift determination and PSD2 SCA compliance reporting. Domai' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Auth3dsResult .

ind:deviceId rdf:type rdf:Property ;
    rdfs:label 'Device Id' ;
    rdfs:comment 'Unique identifier of the device used for the challenge (e.g., mobile device ID).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Device .

ind:requestId rdf:type rdf:Property ;
    rdfs:label 'Request Id' ;
    rdfs:comment 'Foreign key linking to gateway.request. Business justification: An SCA challenge is triggered by a specific gateway request. PSD2 and 3DS audit requirements mandate end-to-end traceability from the originating payment request through the SCA challenge outcome. The' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Request .

ind:acsReference rdf:type rdf:Property ;
    rdfs:label 'Acs Reference' ;
    rdfs:comment 'Identifier of the ACS that generated the challenge.' ;
    rdfs:domain ind:CardholderScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attemptNumber rdf:type rdf:Property ;
    rdfs:label 'Attempt Number' ;
    rdfs:comment 'Sequential number of the challenge attempt for the same transaction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authenticationValue rdf:type rdf:Property ;
    rdfs:label 'Authentication Value' ;
    rdfs:comment 'Cryptographic authentication value returned by the ACS.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:challengeStatus rdf:type rdf:Property ;
    rdfs:label 'Challenge Status' ;
    rdfs:comment 'Current lifecycle state of the challenge.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Challenge Timestamp' ;
    rdfs:comment 'Exact time the challenge was issued to the cardholder.' ;
    rdfs:domain ind:CardholderScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:challengeType rdf:type rdf:Property ;
    rdfs:label 'Challenge Type' ;
    rdfs:comment 'Method used to deliver the SCA challenge to the cardholder.' ;
    rdfs:domain ind:CardholderScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eciIndicator rdf:type rdf:Property ;
    rdfs:label 'Eci Indicator' ;
    rdfs:comment 'Indicator of the authentication outcome used for liability shift.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'Reason why SCA was bypassed, if applicable.' ;
    rdfs:domain ind:CardholderScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Textual description of why the challenge failed, if applicable.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address of the device that initiated the challenge.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSuccessful rdf:type rdf:Property ;
    rdfs:label 'Is Successful' ;
    rdfs:comment 'Indicates whether the challenge was successfully completed (true) or not (false).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latencyMs rdf:type rdf:Property ;
    rdfs:label 'Latency Ms' ;
    rdfs:comment 'Time in milliseconds between challenge issuance and final response.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:threeDsVersion rdf:type rdf:Property ;
    rdfs:label 'Three Ds Version' ;
    rdfs:comment 'Version of the 3-Domain Secure protocol applied.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'Browser or application user-agent string presented during the challenge.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:a2aProductId rdf:type rdf:Property ;
    rdfs:label 'A2a Product Id' ;
    rdfs:comment 'Foreign key linking to product.a2a_product. Business justification: A cardholder account enabled for A2A bank transfers is governed by an a2a_product defining settlement windows, ISO 20022 version, supported rails, and regulatory reporting requirements. Operations and' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:A2aProduct .

ind:creditLimitId rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Id' ;
    rdfs:comment 'Foreign key linking to risk.credit_limit. Business justification: Cardholder account servicing, credit decisioning, and regulatory capital reporting require direct linkage to the governing credit_limit record. credit_limit and available_credit on cardholder_account ' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditLimit .

ind:fundingScheduleId rdf:type rdf:Property ;
    rdfs:label 'Funding Schedule Id' ;
    rdfs:comment 'Foreign key linking to settlement.funding_schedule. Business justification: Prepaid and digital wallet cardholder_accounts are governed by a funding_schedule (direct deposit, top-up cadence). Account management operations and funding operations teams require this link to dete' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FundingSchedule .

ind:p2pProductId rdf:type rdf:Property ;
    rdfs:label 'P2p Product Id' ;
    rdfs:comment 'Foreign key linking to product.p2p_product. Business justification: A cardholder account enabled for P2P transfers is governed by a p2p_product defining transfer limits, KYC requirements, AML screening, and FX eligibility. Product and compliance teams need this link t' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:P2pProduct .

ind:productPricingPlanId rdf:type rdf:Property ;
    rdfs:label 'Product Pricing Plan Id' ;
    rdfs:comment 'Foreign key linking to product.product_pricing_plan. Business justification: Each cardholder account is assigned a pricing plan determining fees, discount rates, and transaction charges. Billing and revenue teams use this to calculate account-level charges and produce fee reve' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductPricingPlan .

ind:virtualAccountProductId rdf:type rdf:Property ;
    rdfs:label 'Virtual Account Product Id' ;
    rdfs:comment 'Foreign key linking to product.virtual_account_product. Business justification: A cardholder account may be a virtual account issued under a virtual_account_product definition governing BIN range, spend limits, tokenization, and issuance fees. Issuance and product management team' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VirtualAccountProduct .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Tier level of the account based on eligibility and benefits.' ;
    rdfs:domain ind:CardholderAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycleDay rdf:type rdf:Property ;
