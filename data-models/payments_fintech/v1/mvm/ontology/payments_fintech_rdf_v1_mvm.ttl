    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDuplicate rdf:type rdf:Property ;
    rdfs:label 'Is Duplicate' ;
    rdfs:comment 'True if this record is identified as a duplicate of another reconciliation record.' ;
    rdfs:domain ind:ReconciliationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isException rdf:type rdf:Property ;
    rdfs:label 'Is Exception' ;
    rdfs:comment 'Indicates whether the reconciliation record required exception handling.' ;
    rdfs:domain ind:ReconciliationRecord ;
