    rdfs:comment 'Indicates if participant holds a reserve account for settlement.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAmlReviewTimestamp rdf:type rdf:Property ;
