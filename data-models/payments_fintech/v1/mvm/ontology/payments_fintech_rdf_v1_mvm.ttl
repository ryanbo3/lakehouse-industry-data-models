    rdfs:comment 'Current lifecycle status of the product.' ;
    rdfs:domain ind:P2pProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perTransactionLimit rdf:type rdf:Property ;
