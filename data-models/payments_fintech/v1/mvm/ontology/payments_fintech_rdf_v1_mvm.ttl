ind:healthCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Health Check Status' ;
    rdfs:comment 'Result of the most recent automated health check.' ;
    rdfs:domain ind:AcquirerEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxConcurrentConnections rdf:type rdf:Property ;
    rdfs:label 'Max Concurrent Connections' ;
    rdfs:comment 'Hard limit on concurrent active sessions allowed for this endpoint.' ;
