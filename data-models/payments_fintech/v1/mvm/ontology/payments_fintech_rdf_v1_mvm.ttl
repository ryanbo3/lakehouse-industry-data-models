    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recoveryMethod rdf:type rdf:Property ;
    rdfs:label 'Recovery Method' ;
    rdfs:comment 'Mechanism used to recover funds from the fraudulent loss.' ;
    rdfs:domain ind:Loss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'Date the loss was formally written off in the accounting system.' ;
    rdfs:domain ind:Loss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentFraudTypeId rdf:type rdf:Property ;
    rdfs:label 'Parent Fraud Type Id' ;
    rdfs:comment 'Identifier of the parent fraud type for hierarchical classification.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Type .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Primary detection technique used for this fraud type.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudTypeCode rdf:type rdf:Property ;
    rdfs:label 'Fraud Type Code' ;
    rdfs:comment 'Short alphanumeric code representing the fraud type (e.g., CNP for Card-Not-Present).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Fraud Type Description' ;
    rdfs:comment 'Detailed description of the fraud scenario and typical characteristics.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudTypeName rdf:type rdf:Property ;
    rdfs:label 'Fraud Type Name' ;
    rdfs:comment 'Human-readable name of the fraud type.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Fraud Type Status' ;
    rdfs:comment 'Lifecycle status of the fraud type definition.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationAction rdf:type rdf:Property ;
    rdfs:label 'Mitigation Action' ;
    rdfs:comment 'Standard remediation action taken when this fraud type is detected.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Code' ;
    rdfs:comment 'Code used in regulatory reports (e.g., Visa reason code, Mastercard reason code).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresManualReview rdf:type rdf:Property ;
    rdfs:label 'Requires Manual Review' ;
    rdfs:comment 'Indicates if cases of this fraud type automatically trigger manual investigation.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
