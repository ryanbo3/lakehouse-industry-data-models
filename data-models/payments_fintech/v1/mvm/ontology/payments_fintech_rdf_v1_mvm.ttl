ind:isGlobalPartner rdf:type rdf:Property ;
    rdfs:label 'Is Global Partner' ;
    rdfs:comment 'True if the partner operates in multiple jurisdictions globally.' ;
    rdfs:domain ind:EcosystemPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Audit Timestamp' ;
    rdfs:comment 'Timestamp of the most recent compliance audit for the partner.' ;
