ind:preferredSchemeId rdf:type rdf:Property ;
    rdfs:label 'Preferred Scheme Id' ;
    rdfs:comment 'Foreign key linking to network.scheme. Business justification: Needed for offering cardholder-specific scheme preferences during new card issuance and for compliance reporting on scheme-wise cardholder demographics.' ;
    rdfs:domain ind:CardholderProfile ;
