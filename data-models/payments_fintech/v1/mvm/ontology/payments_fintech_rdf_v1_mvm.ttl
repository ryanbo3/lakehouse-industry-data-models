ind:isConsolidationLedger rdf:type rdf:Property ;
    rdfs:label 'Is Consolidation Ledger' ;
    rdfs:comment 'Indicates whether this ledger is used for consolidation reporting.' ;
    rdfs:domain ind:Config ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMultiCurrency rdf:type rdf:Property ;
    rdfs:label 'Is Multi Currency' ;
    rdfs:comment 'Indicates if the ledger supports multiple functional currencies.' ;
    rdfs:domain ind:Config ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerCode rdf:type rdf:Property ;
    rdfs:label 'Ledger Code' ;
    rdfs:comment 'Business identifier or code assigned to the ledger.' ;
    rdfs:domain ind:Config ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerConfigDescription rdf:type rdf:Property ;
    rdfs:label 'Ledger Config Description' ;
    rdfs:comment 'Free-form description of the ledger purpose and scope.' ;
    rdfs:domain ind:Config ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerConfigStatus rdf:type rdf:Property ;
    rdfs:label 'Ledger Config Status' ;
    rdfs:comment 'Current lifecycle status of the ledger.' ;
    rdfs:domain ind:Config ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerName rdf:type rdf:Property ;
    rdfs:label 'Ledger Name' ;
    rdfs:comment 'Human-readable name of the ledger.' ;
    rdfs:domain ind:Config ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerOwner rdf:type rdf:Property ;
