ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Business justification for placing the entity on the watchlist (e.g., high velocity, suspicious geography, known fraud pattern).' ;
    rdfs:domain ind:Watchlist ;
    rdf:type owl:DatatypeProperty ;
