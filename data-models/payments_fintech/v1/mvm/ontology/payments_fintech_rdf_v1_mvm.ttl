    rdfs:comment 'Preferred channel used to reach the counterparty for risk communications.' ;
    rdfs:domain ind:RiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactValue rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Value' ;
    rdfs:comment 'Contact detail corresponding to the selected primary_contact_method (e.g., email address or phone number).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
