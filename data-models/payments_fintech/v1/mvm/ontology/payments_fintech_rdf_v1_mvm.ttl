    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterValue rdf:type rdf:Property ;
    rdfs:label 'Parameter Value' ;
    rdfs:comment 'Raw value of the parameter as provided by the scheme; stored as string to accommodate numeric, boolean, or textual formats.' ;
    rdfs:domain ind:SchemeParameter ;
    rdf:type owl:DatatypeProperty ;
