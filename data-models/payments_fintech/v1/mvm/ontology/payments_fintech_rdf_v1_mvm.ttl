    rdfs:range xsd:string .

ind:geographicFootprint rdf:type rdf:Property ;
    rdfs:label 'Geographic Footprint' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where the partner operates. [ENUM-REF-CANDIDATE: list of many countries — promote to reference product]' ;
    rdfs:domain ind:PartnerProfile ;
