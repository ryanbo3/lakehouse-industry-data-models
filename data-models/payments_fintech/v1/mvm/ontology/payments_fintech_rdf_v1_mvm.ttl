    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPositionStatus rdf:type rdf:Property ;
    rdfs:label 'Net Position Status' ;
    rdfs:comment 'Current lifecycle status of the net position.' ;
    rdfs:domain ind:NetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingMethod rdf:type rdf:Property ;
    rdfs:label 'Netting Method' ;
    rdfs:comment 'Method used to net the positions.' ;
    rdfs:domain ind:NetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:note rdf:type rdf:Property ;
    rdfs:label 'Note' ;
    rdfs:comment 'Free-text note or comment regarding the net position.' ;
    rdfs:domain ind:NetPosition ;
