ind:riskScoreAtSet rdf:type rdf:Property ;
    rdfs:label 'Risk Score At Set' ;
    rdfs:comment 'Risk model score associated with the merchant at the time the limit was established.' ;
    rdfs:domain ind:ProcessingLimit ;
