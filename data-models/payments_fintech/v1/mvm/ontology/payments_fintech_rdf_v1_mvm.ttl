    rdfs:range xsd:string .

ind:exceptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exception Timestamp' ;
    rdfs:comment 'Date and time when the exception was first detected in the settlement process.' ;
    rdfs:domain ind:SettlementException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isManualOverride rdf:type rdf:Property ;
    rdfs:label 'Is Manual Override' ;
    rdfs:comment 'Indicates whether a human manually intervened to resolve the exception.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Flag' ;
    rdfs:comment 'True if the exception has regulatory reporting or compliance implications.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Outcome of the resolution attempt.' ;
    rdfs:domain ind:SettlementException ;
