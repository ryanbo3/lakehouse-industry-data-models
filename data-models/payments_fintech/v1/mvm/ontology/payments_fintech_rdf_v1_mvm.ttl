ind:indicatorId rdf:type rdf:Property ;
    rdfs:label 'Indicator Id' ;
    rdfs:comment 'Unique surrogate key for each risk indicator record.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachCount rdf:type rdf:Property ;
    rdfs:label 'Breach Count' ;
    rdfs:comment 'Number of times the indicator has breached thresholds within the current reporting window.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Flag' ;
    rdfs:comment 'Indicates whether the measured value currently violates any threshold.' ;
    rdfs:domain ind:Indicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachSeverity rdf:type rdf:Property ;
    rdfs:label 'Breach Severity' ;
    rdfs:comment 'Severity level of the current breach, if any.' ;
