    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataPrivacyAgreementSigned rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Agreement Signed' ;
    rdfs:comment 'Indicates whether the partner has signed the required data privacy agreement.' ;
    rdfs:domain ind:EcosystemPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isApprovedForCrossBorder rdf:type rdf:Property ;
    rdfs:label 'Is Approved For Cross Border' ;
    rdfs:comment 'True if the partner is authorized to process cross-border transactions.' ;
    rdfs:domain ind:EcosystemPartner ;
    rdf:type owl:DatatypeProperty ;
