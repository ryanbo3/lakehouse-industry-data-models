    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Business operation the request is attempting (authorization, capture, void, refund, inquiry).' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemaVersion rdf:type rdf:Property ;
    rdfs:label 'Schema Version' ;
    rdfs:comment 'Version of the API request schema used by the client.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeBytes rdf:type rdf:Property ;
    rdfs:label 'Size Bytes' ;
    rdfs:comment 'Size of the raw request payload in bytes.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceIp rdf:type rdf:Property ;
    rdfs:label 'Source Ip' ;
    rdfs:comment 'IP address of the client that initiated the request.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcePort rdf:type rdf:Property ;
    rdfs:label 'Source Port' ;
    rdfs:comment 'Network port on the client side used for the request.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tlsVersion rdf:type rdf:Property ;
    rdfs:label 'Tls Version' ;
    rdfs:comment 'TLS protocol version negotiated for the request.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationErrorCode rdf:type rdf:Property ;
    rdfs:label 'Validation Error Code' ;
    rdfs:comment 'Error code returned when validation_outcome is \'rejected\' or \'error\'.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationOutcome rdf:type rdf:Property ;
    rdfs:label 'Validation Outcome' ;
    rdfs:comment 'Result of the gateway\'s initial syntactic/semantic validation.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquirerResponseCode rdf:type rdf:Property ;
    rdfs:label 'Acquirer Response Code' ;
    rdfs:comment 'Response code returned by the acquiring bank or processor.' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountCents rdf:type rdf:Property ;
    rdfs:label 'Amount Cents' ;
    rdfs:comment 'Transaction amount expressed in the smallest currency unit (e.g., cents).' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceCheckDetails rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Details' ;
    rdfs:comment 'Free-text details of any compliance issues detected.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationIp rdf:type rdf:Property ;
    rdfs:label 'Destination Ip' ;
    rdfs:comment 'IP address of the merchant endpoint that received the response.' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPort rdf:type rdf:Property ;
    rdfs:label 'Destination Port' ;
    rdfs:comment 'Network port on the merchant side used for the response.' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorDescription rdf:type rdf:Property ;
    rdfs:label 'Error Description' ;
    rdfs:comment 'Detailed description of the internal error.' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalDisposition rdf:type rdf:Property ;
    rdfs:label 'Final Disposition' ;
    rdfs:comment 'Overall outcome of the response after retries (e.g., success, failed, partial).' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:message rdf:type rdf:Property ;
    rdfs:label 'Message' ;
    rdfs:comment 'Optional free-text message included in the response.' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'Number of retry attempts performed before delivering the final response.' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaMet rdf:type rdf:Property ;
    rdfs:label 'Sla Met' ;
    rdfs:comment 'Indicates whether the response met the defined SLA latency threshold.' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alternativeAcquirerEndpoints rdf:type rdf:Property ;
    rdfs:label 'Alternative Acquirer Endpoints' ;
    rdfs:comment 'Comma-separated list of other eligible acquirer endpoints evaluated during routing.' ;
    rdfs:domain ind:RoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionErrorCode rdf:type rdf:Property ;
    rdfs:label 'Decision Error Code' ;
    rdfs:comment 'Standardized error code if the routing decision failed.' ;
    rdfs:domain ind:RoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Decision Error Message' ;
    rdfs:comment 'Human-readable error message associated with a failed routing decision.' ;
    rdfs:domain ind:RoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failoverTriggered rdf:type rdf:Property ;
    rdfs:label 'Failover Triggered' ;
    rdfs:comment 'Indicates whether a failover path was taken due to primary endpoint failure.' ;
    rdfs:domain ind:RoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadBalancingOutcome rdf:type rdf:Property ;
    rdfs:label 'Load Balancing Outcome' ;
    rdfs:comment 'Algorithmic outcome used to select the acquirer endpoint.' ;
    rdfs:domain ind:RoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestAmount rdf:type rdf:Property ;
    rdfs:label 'Request Amount' ;
    rdfs:comment 'Monetary amount of the transaction that triggered the routing decision.' ;
    rdfs:domain ind:RoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestProtocol rdf:type rdf:Property ;
    rdfs:label 'Request Protocol' ;
    rdfs:comment 'Protocol used by the originating request (e.g., ISO8583, REST, SOAP, JSON).' ;
    rdfs:domain ind:RoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSource rdf:type rdf:Property ;
    rdfs:label 'Request Source' ;
    rdfs:comment 'Channel through which the payment request arrived (e.g., web, mobile app, POS terminal).' ;
    rdfs:domain ind:RoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingDecisionStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Decision Status' ;
    rdfs:comment 'Current lifecycle status of the routing decision.' ;
    rdfs:domain ind:RoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectedAcquirerEndpoint rdf:type rdf:Property ;
    rdfs:label 'Selected Acquirer Endpoint' ;
    rdfs:comment 'Endpoint (e.g., URL, host:port) of the acquirer that was chosen to receive the transaction.' ;
    rdfs:domain ind:RoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaAchieved rdf:type rdf:Property ;
    rdfs:label 'Sla Achieved' ;
    rdfs:comment 'Indicates whether the actual routing latency met the SLA target.' ;
    rdfs:domain ind:RoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetMs rdf:type rdf:Property ;
    rdfs:label 'Sla Target Ms' ;
    rdfs:comment 'Configured service-level-agreement target latency for routing decisions.' ;
    rdfs:domain ind:RoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failoverEventId rdf:type rdf:Property ;
    rdfs:label 'Failover Event Id' ;
    rdfs:comment 'Unique identifier for each failover event record.' ;
    rdfs:domain ind:FailoverEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkSlaId rdf:type rdf:Property ;
    rdfs:label 'Network Sla Id' ;
    rdfs:comment 'Foreign key linking to network.sla. Business justification: Failover events are triggered by SLA threshold breaches. The failover_event.sla_breach_flag is a denormalization signal — the specific network SLA record being breached must be traceable for penalty c' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sla .

ind:primaryFailoverAcquirerEndpointId rdf:type rdf:Property ;
    rdfs:label 'Primary Failover Acquirer Endpoint Id' ;
    rdfs:comment 'Identifier of the primary (failed) acquirer endpoint.' ;
    rdfs:domain ind:FailoverEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AcquirerEndpoint .

ind:primaryFailoverNetworkSchemeId rdf:type rdf:Property ;
    rdfs:label 'Primary Failover Network Scheme Id' ;
    rdfs:comment 'Identifier of the payment network (e.g., Visa, Mastercard) involved.' ;
    rdfs:domain ind:FailoverEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Scheme .

ind:targetEndpointAcquirerEndpointId rdf:type rdf:Property ;
    rdfs:label 'Target Endpoint Acquirer Endpoint Id' ;
    rdfs:comment 'Identifier of the secondary (fallback) acquirer endpoint.' ;
    rdfs:domain ind:FailoverEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AcquirerEndpoint .

ind:affectedTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Affected Transaction Amount' ;
    rdfs:comment 'Aggregate monetary value of the affected transactions (currency assumed USD).' ;
    rdfs:domain ind:FailoverEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedTransactionVolume rdf:type rdf:Property ;
    rdfs:label 'Affected Transaction Volume' ;
    rdfs:comment 'Count of individual transactions impacted by the failover.' ;
    rdfs:domain ind:FailoverEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failoverDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Failover Duration Seconds' ;
    rdfs:comment 'Elapsed time from failover start to successful recovery, measured in seconds.' ;
    rdfs:domain ind:FailoverEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failoverEventStatus rdf:type rdf:Property ;
    rdfs:label 'Failover Event Status' ;
    rdfs:comment 'Current lifecycle status of the failover event.' ;
    rdfs:domain ind:FailoverEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkName rdf:type rdf:Property ;
    rdfs:label 'Network Name' ;
    rdfs:comment 'Human-readable name of the payment network.' ;
    rdfs:domain ind:FailoverEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recovery Timestamp' ;
    rdfs:comment 'Timestamp when traffic was successfully restored to the target endpoint.' ;
    rdfs:domain ind:FailoverEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceEndpointName rdf:type rdf:Property ;
    rdfs:label 'Source Endpoint Name' ;
    rdfs:comment 'Human-readable name of the failed primary endpoint.' ;
    rdfs:domain ind:FailoverEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEndpointName rdf:type rdf:Property ;
    rdfs:label 'Target Endpoint Name' ;
    rdfs:comment 'Human-readable name of the fallback endpoint.' ;
    rdfs:domain ind:FailoverEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerReason rdf:type rdf:Property ;
    rdfs:label 'Trigger Reason' ;
    rdfs:comment 'Reason why the primary endpoint was considered unavailable.' ;
    rdfs:domain ind:FailoverEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:webhookSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Webhook Subscription Id' ;
    rdfs:comment 'System-generated unique identifier for the webhook subscription record.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WebhookSubscription .

ind:authenticationSecret rdf:type rdf:Property ;
    rdfs:label 'Authentication Secret' ;
    rdfs:comment 'Secret key or token used with the selected authentication method (e.g., HMAC secret, OAuth bearer token).' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backoffStrategy rdf:type rdf:Property ;
    rdfs:label 'Backoff Strategy' ;
    rdfs:comment 'Algorithm used to calculate delay between successive retries.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionEnabled rdf:type rdf:Property ;
    rdfs:label 'Encryption Enabled' ;
    rdfs:comment 'Indicates whether the payload is encrypted at rest or in transit.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encryptionKeyReference rdf:type rdf:Property ;
    rdfs:label 'Encryption Key Reference' ;
    rdfs:comment 'Identifier of the encryption key used to protect the payload.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTypes rdf:type rdf:Property ;
    rdfs:label 'Event Types' ;
    rdfs:comment 'Comma-separated list of event identifiers (e.g., authorization.approved,capture.completed) the subscriber wishes to receive.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAllowlist rdf:type rdf:Property ;
    rdfs:label 'Ip Allowlist' ;
    rdfs:comment 'Comma-separated list of IP address ranges permitted to receive webhook calls.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTest rdf:type rdf:Property ;
    rdfs:label 'Is Test' ;
    rdfs:comment 'Indicates whether the subscription is for testing purposes only.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastFailureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Failure Timestamp' ;
    rdfs:comment 'Timestamp of the most recent delivery failure.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxPayloadSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Max Payload Size Bytes' ;
    rdfs:comment 'Maximum allowed size of the webhook payload in bytes.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxRetryAttempts rdf:type rdf:Property ;
    rdfs:label 'Max Retry Attempts' ;
    rdfs:comment 'Maximum number of retry attempts before the subscription is marked failed.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationEndpointType rdf:type rdf:Property ;
    rdfs:label 'Notification Endpoint Type' ;
    rdfs:comment 'Transport mechanism for the webhook (e.g., HTTP, HTTPS, message queue).' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oauthClientIdentifier rdf:type rdf:Property ;
    rdfs:label 'Oauth Client Identifier' ;
    rdfs:comment 'Client identifier when OAuth Bearer authentication is used.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oauthScopes rdf:type rdf:Property ;
    rdfs:label 'Oauth Scopes' ;
    rdfs:comment 'Space-separated list of OAuth scopes granted to the webhook client.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payloadFormat rdf:type rdf:Property ;
    rdfs:label 'Payload Format' ;
    rdfs:comment 'Format of the webhook payload delivered to the target URL.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateLimitPerMinute rdf:type rdf:Property ;
    rdfs:label 'Rate Limit Per Minute' ;
    rdfs:comment 'Maximum number of webhook calls allowed per minute for this subscription.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retryBackoffSeconds rdf:type rdf:Property ;
    rdfs:label 'Retry Backoff Seconds' ;
    rdfs:comment 'Base number of seconds used in backoff calculations between retries.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retryPolicy rdf:type rdf:Property ;
    rdfs:label 'Retry Policy' ;
    rdfs:comment 'Policy governing how failed webhook deliveries are retried.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Seconds' ;
    rdfs:comment 'Target maximum time (in seconds) for the webhook endpoint to acknowledge a delivery.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subscriptionCode rdf:type rdf:Property ;
    rdfs:label 'Subscription Code' ;
    rdfs:comment 'Business-facing code used to reference the subscription in external systems and documentation.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionName rdf:type rdf:Property ;
    rdfs:label 'Subscription Name' ;
    rdfs:comment 'Human-readable name for the webhook subscription.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionType rdf:type rdf:Property ;
    rdfs:label 'Subscription Type' ;
    rdfs:comment 'Broad classification of the subscription purpose.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetUrl rdf:type rdf:Property ;
    rdfs:label 'Target Url' ;
    rdfs:comment 'Fully qualified HTTPS endpoint where event notifications are delivered.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:webhookSecretHash rdf:type rdf:Property ;
    rdfs:label 'Webhook Secret Hash' ;
    rdfs:comment 'Hash of the secret used for HMAC verification of incoming webhook calls.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:webhookSubscriptionDescription rdf:type rdf:Property ;
    rdfs:label 'Webhook Subscription Description' ;
    rdfs:comment 'Optional free-form description providing context about the subscription purpose.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current status of the webhook delivery attempt.' ;
    rdfs:domain ind:WebhookDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Exact time the webhook delivery attempt was initiated.' ;
    rdfs:domain ind:WebhookDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:httpStatusCode rdf:type rdf:Property ;
    rdfs:label 'Http Status Code' ;
    rdfs:comment 'HTTP response status code returned by the merchant endpoint.' ;
    rdfs:domain ind:WebhookDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isFinalAttempt rdf:type rdf:Property ;
    rdfs:label 'Is Final Attempt' ;
    rdfs:comment 'True if this attempt is the last allowed retry.' ;
    rdfs:domain ind:WebhookDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxAttempts rdf:type rdf:Property ;
    rdfs:label 'Max Attempts' ;
    rdfs:comment 'Configured maximum number of retry attempts allowed for the webhook.' ;
    rdfs:domain ind:WebhookDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextRetryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Retry Timestamp' ;
    rdfs:comment 'Scheduled timestamp for the next retry attempt when the previous delivery failed.' ;
    rdfs:domain ind:WebhookDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:payloadHash rdf:type rdf:Property ;
    rdfs:label 'Payload Hash' ;
    rdfs:comment 'SHA-256 hash of the webhook payload to verify integrity.' ;
    rdfs:domain ind:WebhookDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseBodySnippet rdf:type rdf:Property ;
    rdfs:label 'Response Body Snippet' ;
    rdfs:comment 'Truncated portion of the HTTP response body for diagnostic purposes.' ;
    rdfs:domain ind:WebhookDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Response Latency Ms' ;
    rdfs:comment 'Round-trip time in milliseconds between sending the webhook and receiving the HTTP response.' ;
    rdfs:domain ind:WebhookDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:successFlag rdf:type rdf:Property ;
    rdfs:label 'Success Flag' ;
    rdfs:comment 'Indicates whether the webhook delivery was successful (true) or not (false).' ;
    rdfs:domain ind:WebhookDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:throttlingFlag rdf:type rdf:Property ;
    rdfs:label 'Throttling Flag' ;
    rdfs:comment 'Indicates whether delivery was delayed due to rate-limiting.' ;
    rdfs:domain ind:WebhookDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:burstLimit rdf:type rdf:Property ;
    rdfs:label 'Burst Limit' ;
    rdfs:comment 'Number of requests allowed in a short burst exceeding the steady-state quota.' ;
    rdfs:domain ind:RateLimitPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumerIdentifier rdf:type rdf:Property ;
    rdfs:label 'Consumer Identifier' ;
    rdfs:comment 'Identifier of the consumer subject to the policy (e.g., API key, MID, or IP range).' ;
    rdfs:domain ind:RateLimitPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyCap rdf:type rdf:Property ;
    rdfs:label 'Daily Cap' ;
    rdfs:comment 'Maximum total requests allowed in a calendar day.' ;
    rdfs:domain ind:RateLimitPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enforcementAction rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action' ;
    rdfs:comment 'Action taken when limits are breached: throttle (delay) or block (reject).' ;
    rdfs:domain ind:RateLimitPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Human-readable name of the rate limit policy.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateLimitPolicyDescription rdf:type rdf:Property ;
    rdfs:label 'Rate Limit Policy Description' ;
    rdfs:comment 'Free-form text describing the purpose and scope of the policy.' ;
    rdfs:domain ind:RateLimitPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateLimitPolicyStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Limit Policy Status' ;
    rdfs:comment 'Current lifecycle status of the policy.' ;
    rdfs:domain ind:RateLimitPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestQuotaRpm rdf:type rdf:Property ;
    rdfs:label 'Request Quota Rpm' ;
    rdfs:comment 'Maximum allowed requests per minute for the consumer.' ;
    rdfs:domain ind:RateLimitPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestQuotaTps rdf:type rdf:Property ;
    rdfs:label 'Request Quota Tps' ;
    rdfs:comment 'Maximum allowed requests per second for the consumer.' ;
    rdfs:domain ind:RateLimitPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:throttleResponseCode rdf:type rdf:Property ;
    rdfs:label 'Throttle Response Code' ;
    rdfs:comment 'HTTP status code returned when the consumer exceeds the quota.' ;
    rdfs:domain ind:RateLimitPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Penalty Gl Account Id' ;
    rdfs:comment 'Foreign key linking to ledger.gl_account. Business justification: SLA breaches trigger penalty obligations (payables to merchants) or penalty income (receivables from acquirers). Direct GL account linkage enables automated accrual of SLA-related financial obligation' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:breachNotificationTimeHours rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Time Hours' ;
    rdfs:comment 'Maximum time to notify the merchant after an SLA breach.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorRateThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Error Rate Threshold Pct' ;
    rdfs:comment 'Maximum allowed error/decline rate expressed as a percentage.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMeasuredAvailabilityPct rdf:type rdf:Property ;
    rdfs:label 'Last Measured Availability Pct' ;
    rdfs:comment 'Observed availability percentage during the last measurement window.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMeasuredErrorRatePct rdf:type rdf:Property ;
    rdfs:label 'Last Measured Error Rate Pct' ;
    rdfs:comment 'Observed error/decline rate in the last measurement window.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMeasuredLatencyP95Ms rdf:type rdf:Property ;
    rdfs:label 'Last Measured Latency P95 Ms' ;
    rdfs:comment 'Observed 95th percentile latency in the last measurement window.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastMeasuredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Measured Timestamp' ;
    rdfs:comment 'Timestamp of the most recent SLA performance measurement.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:latencyP50Ms rdf:type rdf:Property ;
    rdfs:label 'Latency P50 Ms' ;
    rdfs:comment '50th percentile (median) authorization response time in milliseconds.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:latencyP95Ms rdf:type rdf:Property ;
    rdfs:label 'Latency P95 Ms' ;
    rdfs:comment '95th percentile authorization response time in milliseconds.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:latencyP99Ms rdf:type rdf:Property ;
    rdfs:label 'Latency P99 Ms' ;
    rdfs:comment '99th percentile authorization response time in milliseconds.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementMetric rdf:type rdf:Property ;
    rdfs:label 'Measurement Metric' ;
    rdfs:comment 'Primary metric used for SLA measurement.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementWindowMinutes rdf:type rdf:Property ;
    rdfs:label 'Measurement Window Minutes' ;
    rdfs:comment 'Time window over which SLA metrics are aggregated.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remediationObligation rdf:type rdf:Property ;
    rdfs:label 'Remediation Obligation' ;
    rdfs:comment 'Description of remediation steps or penalties applied when SLA is breached.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCode rdf:type rdf:Property ;
    rdfs:label 'Sla Code' ;
    rdfs:comment 'Business identifier for the SLA agreement, used in contracts and reporting.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaProfileStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Profile Status' ;
    rdfs:comment 'Current lifecycle status of the SLA.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaRevisionNumber rdf:type rdf:Property ;
    rdfs:label 'Sla Revision Number' ;
    rdfs:comment 'Sequential revision number for tracking changes to the SLA.' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Classification of the SLA (e.g., merchant integration, acquirer endpoint, API service, partner).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaVersion rdf:type rdf:Property ;
    rdfs:label 'Sla Version' ;
    rdfs:comment 'Version label of the SLA contract (e.g., v1.0, v2.1).' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAvailabilityPct rdf:type rdf:Property ;
    rdfs:label 'Target Availability Pct' ;
    rdfs:comment 'Committed service availability expressed as a percentage (e.g., 99.95).' ;
    rdfs:domain ind:SlaProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquirerBin rdf:type rdf:Property ;
    rdfs:label 'Acquirer Bin' ;
    rdfs:comment 'Six-digit BIN of the acquiring bank used for routing the 3-DS flow.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationFlow rdf:type rdf:Property ;
    rdfs:label 'Authentication Flow' ;
    rdfs:comment 'Method used to present the 3-DS challenge to the cardholder.' ;
    rdfs:domain ind:ThreedsConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengePreference rdf:type rdf:Property ;
    rdfs:label 'Challenge Preference' ;
    rdfs:comment 'Merchant-specified preference for challenge flow during authentication.' ;
    rdfs:domain ind:ThreedsConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeTimeoutSeconds rdf:type rdf:Property ;
    rdfs:label 'Challenge Timeout Seconds' ;
    rdfs:comment 'Time limit in seconds for the challenge response.' ;
    rdfs:domain ind:ThreedsConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:configCode rdf:type rdf:Property ;
    rdfs:label 'Config Code' ;
    rdfs:comment 'Business code used to reference the configuration in external systems.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configName rdf:type rdf:Property ;
    rdfs:label 'Config Name' ;
    rdfs:comment 'Human-readable name identifying the 3-DS configuration.' ;
    rdfs:domain ind:ThreedsConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configType rdf:type rdf:Property ;
    rdfs:label 'Config Type' ;
    rdfs:comment 'Indicates whether the configuration follows a standard template or is custom-built for a merchant.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionRules rdf:type rdf:Property ;
    rdfs:label 'Exemption Rules' ;
    rdfs:comment 'Comma-separated list of exemption criteria applied to the configuration.' ;
    rdfs:domain ind:ThreedsConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frictionlessFlowEligible rdf:type rdf:Property ;
    rdfs:label 'Frictionless Flow Eligible' ;
    rdfs:comment 'Indicates whether transactions can be processed without a challenge under this configuration.' ;
    rdfs:domain ind:ThreedsConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxChallengeAttempts rdf:type rdf:Property ;
    rdfs:label 'Max Challenge Attempts' ;
    rdfs:comment 'Maximum number of challenge attempts allowed before transaction decline.' ;
    rdfs:domain ind:ThreedsConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestorIdentifier rdf:type rdf:Property ;
    rdfs:label 'Requestor Identifier' ;
    rdfs:comment 'Identifier of the entity (typically the merchant) that initiates the 3-DS authentication request.' ;
    rdfs:domain ind:ThreedsConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threedsConfigDescription rdf:type rdf:Property ;
    rdfs:label 'Threeds Config Description' ;
    rdfs:comment 'Free-form text describing the purpose and scope of the configuration.' ;
    rdfs:domain ind:ThreedsConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threedsConfigStatus rdf:type rdf:Property ;
    rdfs:label 'Threeds Config Status' ;
    rdfs:comment 'Current lifecycle state of the 3-DS configuration.' ;
    rdfs:domain ind:ThreedsConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudRuleId rdf:type rdf:Property ;
    rdfs:label 'Fraud Rule Id' ;
    rdfs:comment 'Identifier of the rule or model that generated the alert.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudRule .

ind:typeId rdf:type rdf:Property ;
    rdfs:label 'Type Id' ;
    rdfs:comment 'Foreign key linking to fraud.fraud_type. Business justification: fraud_case needs a classification of the case type; linking to fraud_type provides hierarchy and risk weighting.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Type .

ind:watchlistFraudWatchlistId rdf:type rdf:Property ;
    rdfs:label 'Watchlist Fraud Watchlist Id' ;
    rdfs:comment 'Foreign key linking to fraud.fraud_watchlist. Business justification: fraud_case may reference a watchlist entry that triggered the case; linking to fraud_watchlist enables traceability.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Watchlist .

ind:amlAlert rdf:type rdf:Property ;
    rdfs:label 'Aml Alert' ;
    rdfs:comment 'Indicates whether the case triggered an AML screening alert.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blocklistHit rdf:type rdf:Property ;
    rdfs:label 'Blocklist Hit' ;
    rdfs:comment 'True if the entity matched an internal or external blocklist.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargebackCurrency rdf:type rdf:Property ;
    rdfs:label 'Chargeback Currency' ;
    rdfs:comment 'Currency of the chargeback amount.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionSource rdf:type rdf:Property ;
    rdfs:label 'Detection Source' ;
    rdfs:comment 'System or channel that initially flagged the suspicious activity.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureAmount rdf:type rdf:Property ;
    rdfs:label 'Exposure Amount' ;
    rdfs:comment 'Estimated monetary loss if fraud is successful.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudCategory rdf:type rdf:Property ;
    rdfs:label 'Fraud Category' ;
    rdfs:comment 'High-level fraud taxonomy for the case.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigation End Timestamp' ;
    rdfs:comment 'When the investigation was concluded.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:investigationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Timestamp' ;
    rdfs:comment 'When the formal investigation of the case began.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isBlocked rdf:type rdf:Property ;
    rdfs:label 'Is Blocked' ;
    rdfs:comment 'Indicates whether the associated account or card was blocked pending investigation.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isChargebackFlagged rdf:type rdf:Property ;
    rdfs:label 'Is Chargeback Flagged' ;
    rdfs:comment 'Indicates whether a chargeback was filed related to the case.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEscalated rdf:type rdf:Property ;
    rdfs:label 'Is Escalated' ;
    rdfs:comment 'True when the case has been escalated to senior investigators or external teams.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFraudulent rdf:type rdf:Property ;
    rdfs:label 'Is Fraudulent' ;
    rdfs:comment 'True if the case was concluded as confirmed fraud.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sarFiled rdf:type rdf:Property ;
    rdfs:label 'Sar Filed' ;
    rdfs:comment 'True if a Suspicious Activity Report was filed for this case.' ;
    rdfs:domain ind:FraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertId rdf:type rdf:Property ;
    rdfs:label 'Alert Id' ;
    rdfs:comment 'System-generated unique identifier for the fraud alert record.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Alert .

ind:alertType rdf:type rdf:Property ;
    rdfs:label 'Alert Type' ;
    rdfs:comment 'Category of the alert indicating the source logic (rule, machine-learning score, velocity control, etc.).' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authResponseCode rdf:type rdf:Property ;
    rdfs:label 'Auth Response Code' ;
    rdfs:comment 'ISO-8583 response code returned by the issuer. [ENUM-REF-CANDIDATE: 00|05|12|13|14|15|30|41|43|51|54|55|57|58|62|63|65|75|76|77|78|79|80|81|82|83|84|85|86|87|88|89|90|91|92|93|94|95|96|97|98|99 — 42 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudAlertStatus rdf:type rdf:Property ;
    rdfs:label 'Fraud Alert Status' ;
    rdfs:comment 'Current lifecycle state of the alert within the case management workflow.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCity rdf:type rdf:Property ;
    rdfs:label 'Geo City' ;
    rdfs:comment 'City name of the transaction source location, if available.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCountry rdf:type rdf:Property ;
    rdfs:label 'Geo Country' ;
    rdfs:comment 'Three-letter ISO country code of the transaction source.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Fraud Rule Status' ;
    rdfs:comment 'Current lifecycle status of the rule.' ;
    rdfs:domain ind:FraudRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTestRule rdf:type rdf:Property ;
    rdfs:label 'Is Test Rule' ;
    rdfs:comment 'Indicates whether the rule is deployed in a test environment only.' ;
    rdfs:domain ind:FraudRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxDeclineAmount rdf:type rdf:Property ;
    rdfs:label 'Max Decline Amount' ;
    rdfs:comment 'Upper monetary limit for automatic decline actions.' ;
    rdfs:domain ind:FraudRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxDeclineCurrency rdf:type rdf:Property ;
    rdfs:label 'Max Decline Currency' ;
    rdfs:comment 'ISO 4217 currency code for the max decline amount.' ;
    rdfs:domain ind:FraudRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:velocityLimit rdf:type rdf:Property ;
    rdfs:label 'Velocity Limit' ;
    rdfs:comment 'Maximum number of transactions allowed within the velocity window.' ;
    rdfs:domain ind:FraudRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleVersionId rdf:type rdf:Property ;
    rdfs:label 'Rule Version Id' ;
    rdfs:comment 'System-generated unique identifier for each version of a fraud rule configuration.' ;
    rdfs:domain ind:RuleVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliesToPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Applies To Payment Method' ;
    rdfs:comment 'Payment instrument categories that the rule evaluates.' ;
    rdfs:domain ind:RuleVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToRegion rdf:type rdf:Property ;
    rdfs:label 'Applies To Region' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating the geographic region where the rule is active.' ;
    rdfs:domain ind:RuleVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionLogic rdf:type rdf:Property ;
    rdfs:label 'Condition Logic' ;
    rdfs:comment 'Serialized representation (e.g., JSON or DSL) of the rule\'s conditional expressions.' ;
    rdfs:domain ind:RuleVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFallbackRule rdf:type rdf:Property ;
    rdfs:label 'Is Fallback Rule' ;
    rdfs:comment 'Flag indicating whether this rule serves as a fallback when no other rule matches.' ;
    rdfs:domain ind:RuleVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxTransactionsPerMinute rdf:type rdf:Property ;
    rdfs:label 'Max Transactions Per Minute' ;
    rdfs:comment 'Velocity control limit for the number of transactions allowed per minute before the rule triggers.' ;
    rdfs:domain ind:RuleVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleVersionDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Version Description' ;
    rdfs:comment 'Detailed free-text description of the rule purpose and scope.' ;
    rdfs:domain ind:RuleVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleVersionStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Version Status' ;
    rdfs:comment 'Current lifecycle state of the rule version.' ;
    rdfs:domain ind:RuleVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'Unit of measurement for the risk score threshold (points or percent).' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableChannels rdf:type rdf:Property ;
    rdfs:label 'Applicable Channels' ;
    rdfs:comment 'Payment channels to which the control applies.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicablePaymentMethods rdf:type rdf:Property ;
    rdfs:label 'Applicable Payment Methods' ;
    rdfs:comment 'Payment instrument types covered by the control.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachAction rdf:type rdf:Property ;
    rdfs:label 'Breach Action' ;
    rdfs:comment 'Action taken when the threshold is exceeded: block transaction, flag for review, invoke step-up authentication, or generate an alert.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlCode rdf:type rdf:Property ;
    rdfs:label 'Control Code' ;
    rdfs:comment 'Human-readable unique code used to reference the control in operational interfaces.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlName rdf:type rdf:Property ;
    rdfs:label 'Control Name' ;
    rdfs:comment 'Descriptive name of the velocity control rule.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective End Timestamp' ;
    rdfs:comment 'Date-time when the control expires; null for indefinite.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Start Timestamp' ;
    rdfs:comment 'Date-time when the control becomes effective.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fraudVelocityControlDescription rdf:type rdf:Property ;
    rdfs:label 'Fraud Velocity Control Description' ;
    rdfs:comment 'Free-form description of the control\'s purpose and business rationale.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudVelocityControlStatus rdf:type rdf:Property ;
    rdfs:label 'Fraud Velocity Control Status' ;
    rdfs:comment 'Current lifecycle status of the velocity control.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Code' ;
    rdfs:comment 'Three-letter ISO country code indicating the regulatory jurisdiction for the control.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastBreachTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Breach Timestamp' ;
    rdfs:comment 'Timestamp of the most recent occurrence where the control was breached.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scopeEntity rdf:type rdf:Property ;
    rdfs:label 'Scope Entity' ;
    rdfs:comment 'Entity to which the velocity limit applies (e.g., individual cardholder, merchant, BIN, device, IP address, or channel).' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Window Duration Seconds' ;
    rdfs:comment 'Length of the rolling time window over which the control is evaluated, expressed in seconds.' ;
    rdfs:domain ind:FraudVelocityControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:velocityBreachId rdf:type rdf:Property ;
    rdfs:label 'Velocity Breach Id' ;
    rdfs:comment 'System-generated unique identifier for the velocity control breach event.' ;
    rdfs:domain ind:VelocityBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gatewayRequestId rdf:type rdf:Property ;
    rdfs:label 'Gateway Request Id' ;
    rdfs:comment 'Foreign key linking to gateway.request. Business justification: Velocity breaches are detected during real-time request processing. Linking to the originating gateway request is essential for breach remediation, merchant notification of blocked transactions, regul' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Request .

ind:actionTaken rdf:type rdf:Property ;
    rdfs:label 'Action Taken' ;
    rdfs:comment 'Automated or manual response applied after the breach (e.g., block, flag, challenge).' ;
    rdfs:domain ind:VelocityBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Action Timestamp' ;
    rdfs:comment 'Date and time when the response action was executed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detectionEngine rdf:type rdf:Property ;
    rdfs:label 'Detection Engine' ;
    rdfs:comment 'Engine that evaluated the transaction – real-time rule engine, batch processor, or ML model.' ;
    rdfs:domain ind:VelocityBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Entity Identifier' ;
    rdfs:comment 'Business identifier of the entity such as masked PAN (last 4), MID, or device token.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityReference rdf:type rdf:Property ;
    rdfs:label 'Entity Reference' ;
    rdfs:comment 'System identifier of the entity (e.g., cardholder_id, merchant_id) that caused the breach.' ;
    rdfs:domain ind:VelocityBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Type of entity that triggered the breach (cardholder, merchant, device, BIN, or account).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observedValue rdf:type rdf:Property ;
    rdfs:label 'Observed Value' ;
    rdfs:comment 'The actual count or monetary amount observed that exceeded the threshold.' ;
    rdfs:domain ind:VelocityBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:velocityBreachDescription rdf:type rdf:Property ;
    rdfs:label 'Velocity Breach Description' ;
    rdfs:comment 'Free-form notes describing the context or rationale of the breach.' ;
    rdfs:domain ind:VelocityBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appVersion rdf:type rdf:Property ;
    rdfs:label 'App Version' ;
    rdfs:comment 'Version of the mobile or desktop application used.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blocklistFlag rdf:type rdf:Property ;
    rdfs:label 'Blocklist Flag' ;
    rdfs:comment 'Indicates whether the device is present on an internal or external blocklist.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blocklistSource rdf:type rdf:Property ;
    rdfs:label 'Blocklist Source' ;
    rdfs:comment 'Identifier of the source list that flagged the device (e.g., internal, external vendor).' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browserName rdf:type rdf:Property ;
    rdfs:label 'Browser Name' ;
    rdfs:comment 'Name of the web browser or embedded web view.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browserVersion rdf:type rdf:Property ;
    rdfs:label 'Browser Version' ;
    rdfs:comment 'Version of the browser.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceFingerprintStatus rdf:type rdf:Property ;
    rdfs:label 'Device Fingerprint Status' ;
    rdfs:comment 'Current lifecycle status of the device fingerprint record.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceLabel rdf:type rdf:Property ;
    rdfs:label 'Device Label' ;
    rdfs:comment 'Human-readable label or nickname assigned to the device for operational reference.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstSeenTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Seen Timestamp' ;
    rdfs:comment 'Timestamp when the device fingerprint was first observed in the system.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hceFlag rdf:type rdf:Property ;
    rdfs:label 'Hce Flag' ;
    rdfs:comment 'Indicates whether the device supports Host Card Emulation.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSeenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Seen Timestamp' ;
    rdfs:comment 'Timestamp of the most recent observation of the device fingerprint.' ;
    rdfs:domain ind:DeviceFingerprint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fraudScaChallengeId rdf:type rdf:Property ;
    rdfs:label 'Fraud Sca Challenge Id' ;
    rdfs:comment 'Foreign key linking to fraud.fraud_sca_challenge. Business justification: A 3DS authentication result is the outcome of an SCA challenge process. The fraud_sca_challenge record captures the challenge initiation and method, while auth_3ds_result captures the authentication o' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudScaChallenge .

ind:authenticationAttempts rdf:type rdf:Property ;
    rdfs:label 'Authentication Attempts' ;
    rdfs:comment 'Count of how many authentication attempts were made for this transaction.' ;
    rdfs:domain ind:Auth3dsResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authenticationErrorCode rdf:type rdf:Property ;
    rdfs:label 'Authentication Error Code' ;
    rdfs:comment 'Standardized error code returned when authentication fails.' ;
    rdfs:domain ind:Auth3dsResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Authentication Error Message' ;
    rdfs:comment 'Human-readable error message describing the authentication failure.' ;
    rdfs:domain ind:Auth3dsResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationStatus rdf:type rdf:Property ;
    rdfs:label 'Authentication Status' ;
    rdfs:comment 'Outcome of the 3-D Secure authentication attempt.' ;
    rdfs:domain ind:Auth3dsResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authentication Timestamp' ;
    rdfs:comment 'Exact timestamp when the 3-D Secure authentication event occurred.' ;
    rdfs:domain ind:Auth3dsResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cardholderIpAddress rdf:type rdf:Property ;
    rdfs:label 'Cardholder Ip Address' ;
    rdfs:comment 'IP address of the cardholder at the time of authentication.' ;
    rdfs:domain ind:Auth3dsResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeIndicator rdf:type rdf:Property ;
    rdfs:label 'Challenge Indicator' ;
    rdfs:comment 'Indicates whether a challenge was required, requested, or not needed.' ;
    rdfs:domain ind:Auth3dsResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityShift rdf:type rdf:Property ;
    rdfs:label 'Liability Shift' ;
    rdfs:comment 'True if liability for the transaction shifted to the issuer per 3DS outcome.' ;
    rdfs:domain ind:Auth3dsResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scaExemptionType rdf:type rdf:Property ;
    rdfs:label 'Sca Exemption Type' ;
    rdfs:comment 'Type of SCA exemption applied to the transaction, if any.' ;
    rdfs:domain ind:Auth3dsResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryFraudCardholderCardholderProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Fraud Cardholder Cardholder Profile Id' ;
    rdfs:comment 'Identifier of the cardholder (customer) subject to the SCA challenge.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CardholderProfile .

ind:challengeAttemptNumber rdf:type rdf:Property ;
    rdfs:label 'Challenge Attempt Number' ;
    rdfs:comment 'Sequential number of the attempt for the same transaction.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:challengeOutcome rdf:type rdf:Property ;
    rdfs:label 'Challenge Outcome' ;
    rdfs:comment 'Result of the SCA challenge: passed, failed, or abandoned by the cardholder.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeResponseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Challenge Response Time Ms' ;
    rdfs:comment 'Elapsed time in milliseconds between initiation and completion of the challenge.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Timestamp when the SCA challenge was completed (success, failure, or abandonment).' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exemptionType rdf:type rdf:Property ;
    rdfs:label 'Exemption Type' ;
    rdfs:comment 'PSD2 exemption applied to the transaction, if any.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiation Timestamp' ;
    rdfs:comment 'Timestamp when the SCA challenge was presented to the cardholder.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isChallengeAbandoned rdf:type rdf:Property ;
    rdfs:label 'Is Challenge Abandoned' ;
    rdfs:comment 'True when the cardholder abandoned the challenge.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isChallengeBlocked rdf:type rdf:Property ;
    rdfs:label 'Is Challenge Blocked' ;
    rdfs:comment 'True when the challenge was blocked by policy or system error.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isChallengeExempted rdf:type rdf:Property ;
    rdfs:label 'Is Challenge Exempted' ;
    rdfs:comment 'True when an SCA exemption was applied and no challenge was required.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isChallengeSuccessful rdf:type rdf:Property ;
    rdfs:label 'Is Challenge Successful' ;
    rdfs:comment 'True when the challenge outcome is passed.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentInstrumentType rdf:type rdf:Property ;
    rdfs:label 'Payment Instrument Type' ;
    rdfs:comment 'Type of payment instrument used for the transaction.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryContext rdf:type rdf:Property ;
    rdfs:label 'Regulatory Context' ;
    rdfs:comment 'Regulatory framework governing the challenge, e.g., PSD2.' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaMethod rdf:type rdf:Property ;
    rdfs:label 'Sca Method' ;
    rdfs:comment 'Method used to perform the SCA challenge (One-Time Password, biometric, push notification, knowledge-based).' ;
    rdfs:domain ind:FraudScaChallenge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blocklistEntryId rdf:type rdf:Property ;
    rdfs:label 'Blocklist Entry Id' ;
    rdfs:comment 'System-generated unique identifier for each blocklist record.' ;
    rdfs:domain ind:BlocklistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockReasonCode rdf:type rdf:Property ;
    rdfs:label 'Block Reason Code' ;
    rdfs:comment 'Standardized code indicating why the entity was placed on the blocklist.' ;
    rdfs:domain ind:BlocklistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingScope rdf:type rdf:Property ;
    rdfs:label 'Blocking Scope' ;
    rdfs:comment 'Scope of the block action (e.g., decline transaction, flag for review, step-up authentication, monitor only).' ;
    rdfs:domain ind:BlocklistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blocklistEntryStatus rdf:type rdf:Property ;
    rdfs:label 'Blocklist Entry Status' ;
    rdfs:comment 'Current lifecycle status of the blocklist record.' ;
    rdfs:domain ind:BlocklistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blocklistVersion rdf:type rdf:Property ;
    rdfs:label 'Blocklist Version' ;
    rdfs:comment 'Version number for the blocklist record to support change tracking.' ;
    rdfs:domain ind:BlocklistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Result of the latest review (e.g., reviewed, not reviewed, escalated).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOfAddition rdf:type rdf:Property ;
    rdfs:label 'Source Of Addition' ;
    rdfs:comment 'Origin of the blocklist entry (e.g., manual entry, automated fraud rule, network advisory).' ;
    rdfs:domain ind:BlocklistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decision rdf:type rdf:Property ;
    rdfs:label 'Decision' ;
    rdfs:comment 'Actual decision taken by downstream systems after applying the recommended action.' ;
    rdfs:domain ind:ScoreEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureSetHash rdf:type rdf:Property ;
    rdfs:label 'Feature Set Hash' ;
    rdfs:comment 'Hash of the input feature set used for the scoring run, enabling reproducibility.' ;
    rdfs:domain ind:ScoreEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geo Country Code' ;
    rdfs:comment 'Three-letter ISO country code derived from the IP address.' ;
    rdfs:domain ind:ScoreEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Flag' ;
    rdfs:comment 'True if the event must be included in regulatory reporting feeds.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scoreBand rdf:type rdf:Property ;
    rdfs:label 'Score Band' ;
    rdfs:comment 'Categorical band derived from the fraud score for operational handling.' ;
    rdfs:domain ind:ScoreEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationId rdf:type rdf:Property ;
    rdfs:label 'Investigation Id' ;
    rdfs:comment 'Unique identifier for the fraud investigation record.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigation .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'Date and time when the investigator was assigned.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Days' ;
    rdfs:comment 'Number of days the investigation data must be retained per policy.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the investigation was escalated, if applicable.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:evidenceDetails rdf:type rdf:Property ;
    rdfs:label 'Evidence Details' ;
    rdfs:comment 'Detailed evidence data (e.g., transaction logs, device data) stored as JSON string.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceSummary rdf:type rdf:Property ;
    rdfs:label 'Evidence Summary' ;
    rdfs:comment 'Summary of evidence collected during investigation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current lifecycle status of the investigation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationType rdf:type rdf:Property ;
    rdfs:label 'Investigation Type' ;
    rdfs:comment 'Category of investigation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigatorName rdf:type rdf:Property ;
    rdfs:label 'Investigator Name' ;
    rdfs:comment 'Full name of the assigned investigator.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrivileged rdf:type rdf:Property ;
    rdfs:label 'Is Privileged' ;
    rdfs:comment 'Indicates if the investigation involves privileged accounts.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcomeRecommendation rdf:type rdf:Property ;
