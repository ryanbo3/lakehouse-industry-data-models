ind:settlementCycleDescription rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle Description' ;
    rdfs:comment 'Free-text description of the settlement cycle purpose or characteristics.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCycleType rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle Type' ;
    rdfs:comment 'Frequency classification of the settlement cycle.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementWindow rdf:type rdf:Property ;
    rdfs:label 'Settlement Window' ;
    rdfs:comment 'Human-readable representation of the time window for the cycle (e.g., \'09:00-17:00 UTC\').' ;
