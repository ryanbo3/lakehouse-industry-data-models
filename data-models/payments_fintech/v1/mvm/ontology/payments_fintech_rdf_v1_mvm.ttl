    rdfs:range xsd:boolean .

ind:lastReconciledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reconciled Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful reconciliation for this record.' ;
