    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAdjustment rdf:type rdf:Property ;
    rdfs:label 'Is Adjustment' ;
    rdfs:comment 'True if the entry represents an accounting adjustment.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:journalEntryDescription rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Description' ;
    rdfs:comment 'Free-form text describing the purpose or nature of the journal entry.' ;
