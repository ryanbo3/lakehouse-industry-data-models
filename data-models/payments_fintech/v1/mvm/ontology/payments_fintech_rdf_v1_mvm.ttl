    rdfs:range xsd:decimal .

ind:isCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Compliant' ;
    rdfs:comment 'True when the limit configuration satisfies all applicable regulatory and internal compliance rules.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isManualReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Is Manual Review Required' ;
    rdfs:comment 'Indicates if transactions breaching the limit trigger a manual review workflow.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Override Allowed' ;
    rdfs:comment 'Indicates whether authorized personnel may temporarily override the limit.' ;
