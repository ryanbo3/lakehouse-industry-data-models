    rdfs:comment 'Indicates if participant allows netting of settlement positions.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:participantName rdf:type rdf:Property ;
    rdfs:label 'Participant Name' ;
    rdfs:comment 'Full legal name of the participant (e.g., acquiring bank, issuing bank, PSP).' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantStatus rdf:type rdf:Property ;
    rdfs:label 'Participant Status' ;
    rdfs:comment 'Current operational status of the participant.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantType rdf:type rdf:Property ;
    rdfs:label 'Participant Type' ;
    rdfs:comment 'Category of participant in the settlement network.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceCode rdf:type rdf:Property ;
    rdfs:label 'Reference Code' ;
    rdfs:comment 'Identifier used by external systems (e.g., partner system).' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionState rdf:type rdf:Property ;
    rdfs:label 'Region State' ;
    rdfs:comment 'State or region of participant\'s address.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAccountIban rdf:type rdf:Property ;
    rdfs:label 'Settlement Account Iban' ;
    rdfs:comment 'International Bank Account Number for settlement.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCyclePreference rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle Preference' ;
    rdfs:comment 'Preferred frequency of settlement cycles.' ;
