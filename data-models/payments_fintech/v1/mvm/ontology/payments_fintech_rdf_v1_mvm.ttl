    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Fraud Score Threshold' ;
    rdfs:comment 'Minimum fraud risk score required for the rule to be applied.' ;
    rdfs:domain ind:GatewayRoutingRule ;
