ind:parameterCategory rdf:type rdf:Property ;
    rdfs:label 'Parameter Category' ;
    rdfs:comment 'Broad classification of the parameter (e.g., floor_limit, velocity_threshold, cvv_requirement, avs_requirement, 3ds_mandate, sca_exemption, chargeback_time_limit, emv_fallback). [ENUM-REF-CANDIDATE: floor_limit|velocity_threshold|cvv_requirement|avs_requirement|3ds_mandate|sca_exemption|chargeback_time_limit|emv_fallback|other — promote to reference product]' ;
    rdfs:domain ind:SchemeParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterCode rdf:type rdf:Property ;
    rdfs:label 'Parameter Code' ;
