    rdfs:comment 'Version string of the risk model used for scoring.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskPolicyVersion rdf:type rdf:Property ;
    rdfs:label 'Risk Policy Version' ;
    rdfs:comment 'Version of the risk policy applied to this profile.' ;
