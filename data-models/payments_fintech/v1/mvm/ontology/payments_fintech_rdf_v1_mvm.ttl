ind:identifier rdf:type rdf:Property ;
    rdfs:label 'Identifier' ;
    rdfs:comment 'Human-readable unique code assigned to the adjustment (e.g., ADJ-20230915-001).' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
