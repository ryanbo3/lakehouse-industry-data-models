    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureLimitId rdf:type rdf:Property ;
    rdfs:label 'Exposure Limit Id' ;
    rdfs:comment 'Foreign key linking to risk.exposure_limit. Business justification: Net positions represent actual participant credit/debit exposure in a settlement cycle. Monitoring net_amount against exposure_limit.limit_amount is a core intraday risk management process — breach de' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExposureLimit .

ind:primaryNetSettlementParticipantId rdf:type rdf:Property ;
    rdfs:label 'Primary Net Settlement Participant Id' ;
    rdfs:comment 'Identifier of the first participant (e.g., acquiring bank) in the settlement pair.' ;
    rdfs:domain ind:NetPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Participant .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Reason for any adjustment applied to the net position.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationFlag rdf:type rdf:Property ;
