    rdfs:comment 'Specifies the compliance framework, fixed to PCI DSS for this product.' ;
    rdfs:domain ind:PciCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isWaiverApproved rdf:type rdf:Property ;
    rdfs:label 'Is Waiver Approved' ;
    rdfs:comment 'True if a waiver for non-compliance fees has been formally approved.' ;
    rdfs:domain ind:PciCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAssessmentDate rdf:type rdf:Property ;
