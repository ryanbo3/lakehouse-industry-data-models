    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquiringAgreementId rdf:type rdf:Property ;
    rdfs:label 'Acquiring Agreement Id' ;
    rdfs:comment 'Unique system-generated identifier for the acquiring agreement record.' ;
    rdfs:domain ind:AcquiringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaProfileId rdf:type rdf:Property ;
    rdfs:label 'Sla Profile Id' ;
    rdfs:comment 'Foreign key linking to gateway.sla_profile. Business justification: Acquiring agreements embed SLA commitments (uptime, latency, error rate thresholds). The sla_profile captures these operational targets. Contract management, SLA breach reporting, and penalty calculat' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaProfile .

ind:acquiringAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Acquiring Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the agreement.' ;
    rdfs:domain ind:AcquiringAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementCategory rdf:type rdf:Property ;
    rdfs:label 'Agreement Category' ;
    rdfs:comment 'High-level business category of the agreement.' ;
    rdfs:domain ind:AcquiringAgreement ;
    rdf:type owl:DatatypeProperty ;
