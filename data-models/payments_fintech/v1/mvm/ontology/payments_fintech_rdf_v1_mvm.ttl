    rdfs:comment 'Indicates whether the net position has been confirmed for fund movement.' ;
    rdfs:domain ind:NetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossCreditTotal rdf:type rdf:Property ;
    rdfs:label 'Gross Credit Total' ;
    rdfs:comment 'Total gross credit amount for the participant pair before netting.' ;
    rdfs:domain ind:NetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossDebitTotal rdf:type rdf:Property ;
    rdfs:label 'Gross Debit Total' ;
    rdfs:comment 'Total gross debit amount for the participant pair before netting.' ;
    rdfs:domain ind:NetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAdjusted rdf:type rdf:Property ;
    rdfs:label 'Is Adjusted' ;
    rdfs:comment 'Indicates if the net position has been adjusted post initial calculation.' ;
    rdfs:domain ind:NetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPositionNumber rdf:type rdf:Property ;
    rdfs:label 'Net Position Number' ;
    rdfs:comment 'Human-readable reference number for the net position.' ;
    rdfs:domain ind:NetPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPositionSource rdf:type rdf:Property ;
    rdfs:label 'Net Position Source' ;
    rdfs:comment 'Source system or process that generated the net position (e.g., Transaction Processing Platform).' ;
