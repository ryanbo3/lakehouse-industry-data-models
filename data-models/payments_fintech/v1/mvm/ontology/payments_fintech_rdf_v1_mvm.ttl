    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:port rdf:type rdf:Property ;
    rdfs:label 'Port' ;
    rdfs:comment 'TCP/UDP port number on which the endpoint listens.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
