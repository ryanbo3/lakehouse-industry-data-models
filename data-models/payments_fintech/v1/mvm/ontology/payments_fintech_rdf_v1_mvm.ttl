    rdfs:comment 'Recommended action based on investigation outcome.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Reporting Jurisdiction' ;
    rdfs:comment 'Jurisdiction for regulatory reporting (ISO 3166-1 alpha-3).' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCompliance rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance' ;
    rdfs:comment 'Indicates whether the investigation met SLA requirements.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaDueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Due Timestamp' ;
    rdfs:comment 'Target date/time for SLA compliance.' ;
    rdfs:domain ind:Investigation ;
