    rdfs:range xsd:integer .

ind:fraudIndicatorCodes rdf:type rdf:Property ;
    rdfs:label 'Fraud Indicator Codes' ;
    rdfs:comment 'Pipe-separated list of fraud indicator codes associated with the case.' ;
    rdfs:domain ind:RiskCase ;
    rdf:type owl:DatatypeProperty ;
