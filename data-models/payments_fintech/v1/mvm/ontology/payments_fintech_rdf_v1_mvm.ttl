    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGlobal rdf:type rdf:Property ;
    rdfs:label 'Is Global' ;
    rdfs:comment 'True if the parameter applies to all merchants and terminals; false if scoped to specific groups.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
