ind:thresholdName rdf:type rdf:Property ;
    rdfs:label 'Threshold Name' ;
    rdfs:comment 'Human-readable name of the risk threshold.' ;
    rdfs:domain ind:Threshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdStatus rdf:type rdf:Property ;
    rdfs:label 'Threshold Status' ;
    rdfs:comment 'Current lifecycle status of the threshold configuration.' ;
    rdfs:domain ind:Threshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'Numeric value that defines the limit for the selected risk dimension.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Indicates whether the decision was made by an automated engine or a human underwriter.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailRef rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Ref' ;
    rdfs:comment 'Link to the detailed audit log entry capturing the decision workflow.' ;
    rdfs:domain ind:UnderwritingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceRequirementsMet rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements Met' ;
    rdfs:comment 'List of regulatory or internal compliance checks satisfied by this decision.' ;
    rdfs:domain ind:UnderwritingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsApplied rdf:type rdf:Property ;
    rdfs:label 'Conditions Applied' ;
    rdfs:comment 'Free-text description of any special conditions (e.g., reserve rate, TPV cap) imposed by the decision.' ;
    rdfs:domain ind:UnderwritingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionCategory rdf:type rdf:Property ;
    rdfs:label 'Decision Category' ;
    rdfs:comment 'High-level classification of the decision (e.g., "new_merchant", "risk_adjustment").' ;
    rdfs:domain ind:UnderwritingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionConfidence rdf:type rdf:Property ;
    rdfs:label 'Decision Confidence' ;
    rdfs:comment 'Confidence level (0-1) associated with the automated decision engine\'s output.' ;
    rdfs:domain ind:UnderwritingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decisionExpirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Expiration Timestamp' ;
    rdfs:comment 'If the decision is conditional, the time after which it expires and must be re-evaluated.' ;
    rdfs:domain ind:UnderwritingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:decisionOutcome rdf:type rdf:Property ;
    rdfs:label 'Decision Outcome' ;
    rdfs:comment 'Result of the underwriting evaluation: approved, declined, conditional, or referred.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionOverrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Decision Override Allowed' ;
    rdfs:comment 'Flag indicating whether a human can override the automated decision.' ;
    rdfs:domain ind:UnderwritingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Decision Override Reason' ;
    rdfs:comment 'Reason provided when a decision is manually overridden.' ;
    rdfs:domain ind:UnderwritingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionReason rdf:type rdf:Property ;
    rdfs:label 'Decision Reason' ;
    rdfs:comment 'Narrative explanation for the decision outcome.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionReviewDate rdf:type rdf:Property ;
    rdfs:label 'Decision Review Date' ;
    rdfs:comment 'Scheduled date for periodic review of the underwriting decision.' ;
    rdfs:domain ind:UnderwritingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionScoreComponents rdf:type rdf:Property ;
    rdfs:label 'Decision Score Components' ;
    rdfs:comment 'Serialized representation of individual score components used in the final risk score.' ;
    rdfs:domain ind:UnderwritingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionSource rdf:type rdf:Property ;
    rdfs:label 'Decision Source' ;
    rdfs:comment 'Origin of the decision request: real-time engine, batch process, or manual entry.' ;
    rdfs:domain ind:UnderwritingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionStatus rdf:type rdf:Property ;
    rdfs:label 'Decision Status' ;
    rdfs:comment 'Current lifecycle state of the underwriting decision.' ;
    rdfs:domain ind:UnderwritingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionTags rdf:type rdf:Property ;
    rdfs:label 'Decision Tags' ;
    rdfs:comment 'Comma-separated tags for categorizing the decision (e.g., "new_merchant,high_volume").' ;
    rdfs:domain ind:UnderwritingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionType rdf:type rdf:Property ;
    rdfs:label 'Decision Type' ;
    rdfs:comment 'Indicates whether this is the initial underwriting, a reassessment, or a post-settlement review.' ;
    rdfs:domain ind:UnderwritingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFraudFlag rdf:type rdf:Property ;
    rdfs:label 'Is Fraud Flag' ;
    rdfs:comment 'Indicates whether the decision was influenced by a fraud detection signal.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHighRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Is High Risk Flag' ;
    rdfs:comment 'True when the decision falls into a high-risk category requiring extra monitoring.' ;
    rdfs:domain ind:UnderwritingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyVersion rdf:type rdf:Property ;
    rdfs:label 'Policy Version' ;
    rdfs:comment 'Version string of the underwriting policy in effect.' ;
    rdfs:domain ind:UnderwritingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveAmount rdf:type rdf:Property ;
    rdfs:label 'Reserve Amount' ;
    rdfs:comment 'Monetary amount placed in reserve for the merchant based on the decision.' ;
    rdfs:domain ind:UnderwritingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tpvCap rdf:type rdf:Property ;
    rdfs:label 'Tpv Cap' ;
    rdfs:comment 'Maximum cumulative payment volume allowed for the merchant within the policy period.' ;
    rdfs:domain ind:UnderwritingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerEcosystemPartnerId rdf:type rdf:Property ;
    rdfs:label 'Partner Ecosystem Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.ecosystem_partner. Business justification: Enables the Partner Risk Assessment dashboard, associating partner IDs with risk assessment outcomes for regulatory reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EcosystemPartner .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Human-readable reference number assigned to the assessment, used in reporting and audit trails.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Tracks the workflow state of the assessment from creation through completion or rejection.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Indicates whether the assessment is an initial onboarding review, a scheduled periodic review, or a review triggered by a specific event.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageTransactionValue rdf:type rdf:Property ;
    rdfs:label 'Average Transaction Value' ;
    rdfs:comment 'Mean monetary value per transaction for the party in the last 30 days.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceFlagAml rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag Aml' ;
    rdfs:comment 'True if the assessment included an Anti-Money-Laundering screening.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceFlagSanctions rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag Sanctions' ;
    rdfs:comment 'True if the assessment incorporated sanctions list checks.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditRiskScore rdf:type rdf:Property ;
    rdfs:label 'Credit Risk Score' ;
    rdfs:comment 'Quantitative score reflecting creditworthiness of the assessed party.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHighRisk rdf:type rdf:Property ;
    rdfs:label 'Is High Risk' ;
    rdfs:comment 'Boolean flag set when the overall risk tier meets or exceeds the high-risk threshold.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isManualReview rdf:type rdf:Property ;
    rdfs:label 'Is Manual Review' ;
    rdfs:comment 'True when a human analyst intervened in the assessment process.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mccCategory rdf:type rdf:Property ;
    rdfs:label 'Mcc Category' ;
    rdfs:comment 'Four-digit code classifying the merchant\'s primary business activity.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalRiskScore rdf:type rdf:Property ;
    rdfs:label 'Operational Risk Score' ;
    rdfs:comment 'Score measuring operational risk factors such as process failures or system outages.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRiskScore rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Score' ;
    rdfs:comment 'Composite risk score derived from individual risk dimension scores.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Prescribed next steps for the assessed party (e.g., increase limits, impose controls, terminate relationship).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRiskScore rdf:type rdf:Property ;
    rdfs:label 'Regulatory Risk Score' ;
    rdfs:comment 'Score reflecting compliance and regulatory exposure of the party.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reputationalRiskScore rdf:type rdf:Property ;
    rdfs:label 'Reputational Risk Score' ;
    rdfs:comment 'Score assessing potential damage to brand or public perception.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Risk Exposure Amount' ;
    rdfs:comment 'Estimated financial exposure associated with the assessed risk, expressed in the reporting currency.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionAmountLast30d rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount Last 30d' ;
    rdfs:comment 'Sum of transaction monetary values for the party over the preceding 30-day window.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
