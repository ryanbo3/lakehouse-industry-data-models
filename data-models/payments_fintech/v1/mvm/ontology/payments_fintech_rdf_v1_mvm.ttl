    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scopes rdf:type rdf:Property ;
    rdfs:label 'Scopes' ;
    rdfs:comment 'Comma-separated list of permission scopes granted to the credential (e.g., transactions:read, settlements:write).' ;
    rdfs:domain ind:GatewayApiCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenEndpoint rdf:type rdf:Property ;
