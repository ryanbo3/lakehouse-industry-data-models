    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseSource rdf:type rdf:Property ;
    rdfs:label 'Case Source' ;
    rdfs:comment 'Origin of the case creation.' ;
    rdfs:domain ind:RiskCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Category of the risk case indicating the originating risk domain.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Timestamp when the triggering rule fired.' ;
