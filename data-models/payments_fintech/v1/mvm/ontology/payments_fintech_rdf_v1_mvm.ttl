    rdfs:range xsd:string .

ind:ledgerType rdf:type rdf:Property ;
    rdfs:label 'Ledger Type' ;
    rdfs:comment 'Classification of the ledger (e.g., primary, secondary, reporting).' ;
    rdfs:domain ind:Config ;
    rdf:type owl:DatatypeProperty ;
