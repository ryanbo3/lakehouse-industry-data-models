    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyLimit rdf:type rdf:Property ;
    rdfs:label 'Monthly Limit' ;
    rdfs:comment 'Maximum cumulative amount allowed per month.' ;
    rdfs:domain ind:P2pProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:p2pProductCode rdf:type rdf:Property ;
    rdfs:label 'P2p Product Code' ;
    rdfs:comment 'Unique business code for the P2P product.' ;
    rdfs:domain ind:P2pProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:p2pProductDescription rdf:type rdf:Property ;
    rdfs:label 'P2p Product Description' ;
    rdfs:comment 'Detailed description of the P2P product offering.' ;
