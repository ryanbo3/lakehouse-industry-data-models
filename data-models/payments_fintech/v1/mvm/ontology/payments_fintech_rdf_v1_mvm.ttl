    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:analystOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Analyst Override Reason' ;
    rdfs:comment 'Free-text explanation provided by the analyst for the override.' ;
    rdfs:domain ind:AmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceAmlScreeningResultStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Aml Screening Result Status' ;
    rdfs:comment 'Current lifecycle status of the screening result record.' ;
    rdfs:domain ind:AmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Outcome of the screening: pass, requires manual review, or block.' ;
    rdfs:domain ind:AmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSarRequired rdf:type rdf:Property ;
    rdfs:label 'Is Sar Required' ;
    rdfs:comment 'Indicates whether a Suspicious Activity Report (SAR) must be filed.' ;
    rdfs:domain ind:AmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStrRequired rdf:type rdf:Property ;
    rdfs:label 'Is Str Required' ;
    rdfs:comment 'Indicates whether a Suspicious Transaction Report (STR) must be filed.' ;
    rdfs:domain ind:AmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchType rdf:type rdf:Property ;
    rdfs:label 'Match Type' ;
    rdfs:comment 'Category of data element that triggered a match during screening.' ;
    rdfs:domain ind:AmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarFilingStatus rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Status' ;
    rdfs:comment 'Current status of the SAR filing process.' ;
    rdfs:domain ind:AmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarFilingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Timestamp' ;
    rdfs:comment 'Date and time when the SAR was filed, if applicable.' ;
    rdfs:domain ind:AmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:screeningEngine rdf:type rdf:Property ;
    rdfs:label 'Screening Engine' ;
    rdfs:comment 'Name of the AML screening engine or vendor used (e.g., World-Check, LexisNexis).' ;
    rdfs:domain ind:AmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningRuleVersion rdf:type rdf:Property ;
    rdfs:label 'Screening Rule Version' ;
    rdfs:comment 'Version identifier of the rule set applied during the screening.' ;
    rdfs:domain ind:AmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Screening Timestamp' ;
    rdfs:comment 'Date and time when the AML screening was performed.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceModule rdf:type rdf:Property ;
    rdfs:label 'Source Module' ;
    rdfs:comment 'Specific module or component within the source system that executed the screening.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strFilingStatus rdf:type rdf:Property ;
    rdfs:label 'Str Filing Status' ;
    rdfs:comment 'Current status of the STR filing process.' ;
    rdfs:domain ind:AmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strFilingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Str Filing Timestamp' ;
    rdfs:comment 'Date and time when the STR was filed, if applicable.' ;
    rdfs:domain ind:AmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:typology rdf:type rdf:Property ;
    rdfs:label 'Typology' ;
    rdfs:comment 'AML typology or pattern identified (e.g., structuring, smurfing, terrorist financing).' ;
    rdfs:domain ind:AmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySanctionsMerchantId rdf:type rdf:Property ;
    rdfs:label 'Primary Sanctions Merchant Id' ;
    rdfs:comment 'Identifier of the merchant associated with this screening, if applicable.' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Merchant .

ind:blockActionTaken rdf:type rdf:Property ;
    rdfs:label 'Block Action Taken' ;
    rdfs:comment 'Action taken as a result of the hit (e.g., blocked transaction, allowed, sent for review).' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:falsePositiveFlag rdf:type rdf:Property ;
    rdfs:label 'False Positive Flag' ;
    rdfs:comment 'Indicates whether the hit was later determined to be a false positive.' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hitDetails rdf:type rdf:Property ;
    rdfs:label 'Hit Details' ;
    rdfs:comment 'Details of the matched sanctioned entity (e.g., name, address).' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hitIndicator rdf:type rdf:Property ;
    rdfs:label 'Hit Indicator' ;
    rdfs:comment 'True if the screening produced a potential match against the sanctions list.' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCritical rdf:type rdf:Property ;
    rdfs:label 'Is Critical' ;
    rdfs:comment 'True if the screening result is considered high-risk and requires immediate attention.' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listName rdf:type rdf:Property ;
    rdfs:label 'List Name' ;
    rdfs:comment 'Name of the sanctions list used for the screening (e.g., OFAC SDN, EU Consolidated, UN).' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listVersion rdf:type rdf:Property ;
    rdfs:label 'List Version' ;
    rdfs:comment 'Version identifier of the sanctions list at the time of screening.' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchScore rdf:type rdf:Property ;
    rdfs:label 'Match Score' ;
    rdfs:comment 'Numerical confidence score (0-100) indicating the strength of the match.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingObligation rdf:type rdf:Property ;
    rdfs:label 'Reporting Obligation' ;
    rdfs:comment 'Regulatory filing triggered by the hit (Suspicious Activity Report, Suspicious Transaction Report, or None).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingObligationFiled rdf:type rdf:Property ;
    rdfs:label 'Reporting Obligation Filed' ;
    rdfs:comment 'True if the required regulatory report was filed.' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewDecision rdf:type rdf:Property ;
    rdfs:label 'Review Decision' ;
    rdfs:comment 'Outcome of the compliance review.' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningMethod rdf:type rdf:Property ;
    rdfs:label 'Screening Method' ;
    rdfs:comment 'Algorithmic method used for the screening.' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningSource rdf:type rdf:Property ;
    rdfs:label 'Screening Source' ;
    rdfs:comment 'System or module that executed the screening (e.g., Risk and Compliance Management System).' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningStatus rdf:type rdf:Property ;
    rdfs:label 'Screening Status' ;
    rdfs:comment 'Current processing status of the screening.' ;
    rdfs:domain ind:SanctionsCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sarFilingId rdf:type rdf:Property ;
    rdfs:label 'Sar Filing Id' ;
    rdfs:comment 'Unique identifier for the SAR filing record.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:filingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Filing Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to ledger.legal_entity. Business justification: SARs must identify the filing legal entity for regulatory submission to FinCEN/FIU, audit trail requirements, and entity-level suspicious activity reporting obligations in payments fintech.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_filing. Business justification: A SAR filing is a specific type of regulatory filing submitted to FinCEN. The regulatory_filing table is the master record of all regulatory submissions. Linking sar_filing to its corresponding regula' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:subjectAccountHolderId rdf:type rdf:Property ;
    rdfs:label 'Subject Account Holder Id' ;
    rdfs:comment 'Foreign key linking to cardholder.account_holder. Business justification: SAR filings are made about specific account holders per FinCEN/BSA requirements. subject_party_id references compliance.party; a direct FK to account_holder enables compliance officers to pull all SAR' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountHolder .

ind:subjectPartyId rdf:type rdf:Property ;
    rdfs:label 'Subject Party Id' ;
    rdfs:comment 'Foreign key linking to compliance.party. Business justification: The SAR filing subject (subject_entity_name, subject_identifier, subject_address) corresponds to a party in the compliance party master. Adding subject_party_id links the SAR to the authoritative part' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:activityEndDate rdf:type rdf:Property ;
    rdfs:label 'Activity End Date' ;
    rdfs:comment 'Date when the suspicious activity ended.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activityStartDate rdf:type rdf:Property ;
    rdfs:label 'Activity Start Date' ;
    rdfs:comment 'Date when the suspicious activity began.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Categorization of the suspicious activity.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential number of the amendment for this SAR.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountInvolved rdf:type rdf:Property ;
    rdfs:label 'Amount Involved' ;
    rdfs:comment 'Total monetary value associated with the suspicious activity.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attachmentReference rdf:type rdf:Property ;
    rdfs:label 'Attachment Reference' ;
    rdfs:comment 'Reference to supporting documents attached to the filing.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Classification level indicating data sensitivity.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionExpiry rdf:type rdf:Property ;
    rdfs:label 'Data Retention Expiry' ;
    rdfs:comment 'Date after which the SAR record must be purged per retention policy.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Number' ;
    rdfs:comment 'External tracking number assigned by BSA for the filing.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingOfficerName rdf:type rdf:Property ;
    rdfs:label 'Filing Officer Name' ;
    rdfs:comment 'Full name of the officer responsible for the filing.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current processing status of the SAR with the regulator.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAmended rdf:type rdf:Property ;
    rdfs:label 'Is Amended' ;
    rdfs:comment 'True if this filing is an amendment to a prior SAR.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:narrativeSummary rdf:type rdf:Property ;
    rdfs:label 'Narrative Summary' ;
    rdfs:comment 'Free-text narrative describing the suspicious activity.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'Regulatory authority to which the SAR was submitted.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectAddress rdf:type rdf:Property ;
    rdfs:label 'Subject Address' ;
    rdfs:comment 'Physical address of the subject entity.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectCountryCode rdf:type rdf:Property ;
    rdfs:label 'Subject Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the subject\'s residence.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectEntityType rdf:type rdf:Property ;
    rdfs:label 'Subject Entity Type' ;
    rdfs:comment 'Classification of the subject entity.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Id' ;
    rdfs:comment 'Foreign key linking to fx.beneficiary. Business justification: Cross-border payment beneficiaries require KYC verification under AML/CTF regulations. Payment processors must verify beneficiary identity, sanctions status, and risk tier before authorizing payments.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Beneficiary .

ind:cddClassification rdf:type rdf:Property ;
    rdfs:label 'Cdd Classification' ;
    rdfs:comment 'Indicates whether standard (CDD) or enhanced (EDD) due diligence was applied.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Document Expiry Date' ;
    rdfs:comment 'Expiration date of the identity document.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentIssueDate rdf:type rdf:Property ;
    rdfs:label 'Document Issue Date' ;
    rdfs:comment 'Date the identity document was issued.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentIssuingCountry rdf:type rdf:Property ;
    rdfs:label 'Document Issuing Country' ;
    rdfs:comment 'Three-letter ISO country code of the issuing authority.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycEntityType rdf:type rdf:Property ;
    rdfs:label 'Kyc Entity Type' ;
    rdfs:comment 'Classification of the party being verified.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactType rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Type' ;
    rdfs:comment 'Method of primary contact used for KYC communication.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Provider Reference Code' ;
    rdfs:comment 'Reference identifier assigned by the verification provider.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reVerificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Re Verification Due Date' ;
    rdfs:comment 'Date by which the KYC must be refreshed or re-verified.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsCheckResult rdf:type rdf:Property ;
    rdfs:label 'Sanctions Check Result' ;
    rdfs:comment 'Result of OFAC/SDN sanctions screening.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Verification Outcome' ;
    rdfs:comment 'Result of the verification after processing.' ;
    rdfs:domain ind:ComplianceKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Amendment Indicator' ;
    rdfs:comment 'True if the obligation has been amended since its original issuance.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlOwner rdf:type rdf:Property ;
    rdfs:label 'Control Owner' ;
    rdfs:comment 'Business unit, department, or role responsible for ensuring compliance with the obligation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'Link to the official regulatory document or guidance.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementPenalty rdf:type rdf:Property ;
    rdfs:label 'Enforcement Penalty' ;
    rdfs:comment 'Description of penalties, fines, or sanctions associated with non-compliance.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Short alphanumeric code used internally to reference the obligation.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationName rdf:type rdf:Property ;
    rdfs:label 'Obligation Name' ;
    rdfs:comment 'Human-readable name of the regulatory obligation as defined by the governing body.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationType rdf:type rdf:Property ;
    rdfs:label 'Regulation Type' ;
    rdfs:comment 'Category of the regulatory instrument (law, directive, standard, or guideline).' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryObligationDescription rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Description' ;
    rdfs:comment 'Full textual description of the regulatory requirement, including scope and key provisions.' ;
    rdfs:domain ind:RegulatoryObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCadence rdf:type rdf:Property ;
    rdfs:label 'Review Cadence' ;
    rdfs:comment 'Frequency at which the obligation is reviewed for relevance and compliance.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlDescription rdf:type rdf:Property ;
    rdfs:label 'Control Description' ;
    rdfs:comment 'Detailed description of the control\'s purpose and scope.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlScope rdf:type rdf:Property ;
    rdfs:label 'Control Scope' ;
    rdfs:comment 'Business area or process that the control applies to.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlStatus rdf:type rdf:Property ;
    rdfs:label 'Control Status' ;
    rdfs:comment 'Current lifecycle status of the control.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticality rdf:type rdf:Property ;
    rdfs:label 'Criticality' ;
    rdfs:comment 'Criticality level of the control for business continuity.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceCollected rdf:type rdf:Property ;
    rdfs:label 'Evidence Collected' ;
    rdfs:comment 'True if required evidence has been collected for the latest assessment.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceRequired rdf:type rdf:Property ;
    rdfs:label 'Evidence Required' ;
    rdfs:comment 'Description of the evidence needed to demonstrate control execution.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceUrl rdf:type rdf:Property ;
    rdfs:label 'Evidence Url' ;
    rdfs:comment 'Link to the stored evidence artifact.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'How often the control is performed or reviewed.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isKeyControl rdf:type rdf:Property ;
    rdfs:label 'Is Key Control' ;
    rdfs:comment 'Indicates whether the control is considered a key control for regulatory reporting.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAssessmentResult rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Result' ;
    rdfs:comment 'Outcome of the most recent control assessment.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAssessmentDue rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due' ;
    rdfs:comment 'Planned date for the next control assessment.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryRequirementCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Code' ;
    rdfs:comment 'Identifier of the specific regulatory requirement mapped to this control.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of the remediation effort.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingMethodology rdf:type rdf:Property ;
    rdfs:label 'Testing Methodology' ;
    rdfs:comment 'Method used to test the effectiveness of the control.' ;
    rdfs:domain ind:Control ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Control Assessment Id' ;
    rdfs:comment 'System-generated unique identifier for each control assessment record.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentCycle rdf:type rdf:Property ;
    rdfs:label 'Assessment Cycle' ;
    rdfs:comment 'Frequency with which the control is assessed.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Assessment Outcome' ;
    rdfs:comment 'Overall pass/fail result of the control assessment.' ;
    rdfs:domain ind:ControlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Assessment Period' ;
    rdfs:comment 'Fiscal or calendar period the assessment covers (e.g., Q1-2023).' ;
