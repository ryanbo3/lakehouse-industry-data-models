ind:reconciliationMethod rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Method' ;
    rdfs:comment 'Method used to perform the reconciliation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Record Status' ;
    rdfs:comment 'Current processing status of the reconciliation record.' ;
    rdfs:domain ind:ReconciliationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordVersion rdf:type rdf:Property ;
    rdfs:label 'Record Version' ;
    rdfs:comment 'Version number for optimistic concurrency control.' ;
    rdfs:domain ind:ReconciliationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceFileName rdf:type rdf:Property ;
    rdfs:label 'Source File Name' ;
    rdfs:comment 'Name of the external file (e.g., MT940, camt.053) used for reconciliation.' ;
