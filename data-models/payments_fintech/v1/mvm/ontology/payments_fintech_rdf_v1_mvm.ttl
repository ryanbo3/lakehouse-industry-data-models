ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Ordinal position of the line within the journal entry.' ;
    rdfs:domain ind:JournalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Lifecycle status indicating whether the line is posted, pending, reversed, or encountered an error.' ;
    rdfs:domain ind:JournalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Code of the project or initiative associated with the line for cost allocation.' ;
    rdfs:domain ind:JournalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Code representing the tax rule or jurisdiction applicable to this line.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glBalanceId rdf:type rdf:Property ;
    rdfs:label 'Gl Balance Id' ;
    rdfs:comment 'Unique surrogate identifier for each GL balance snapshot.' ;
    rdfs:domain ind:GlBalance ;
    rdf:type owl:DatatypeProperty ;
