    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryStatus rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Status' ;
    rdfs:comment 'Current lifecycle status of the journal entry.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'Timestamp when the entry was posted to the general ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:soxControlReference rdf:type rdf:Property ;
    rdfs:label 'Sox Control Reference' ;
    rdfs:comment 'Reference to the specific SOX control that governs this entry.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount' ;
    rdfs:comment 'Aggregate credit amount for the journal entry, expressed in the entry currency.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Total Debit Amount' ;
    rdfs:comment 'Aggregate debit amount for the journal entry, expressed in the entry currency.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:journalLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Line Id' ;
    rdfs:comment 'Unique surrogate key for each line item within a general ledger journal entry.' ;
    rdfs:domain ind:JournalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal Entry Id' ;
    rdfs:comment 'Identifier of the parent journal entry to which this line belongs.' ;
    rdfs:domain ind:JournalLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'Identifier of the business unit owning the transaction for internal reporting.' ;
    rdfs:domain ind:JournalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Monetary amount credited on this line, expressed in the functional currency of the entity.' ;
