    rdfs:comment 'Current lifecycle state of the routing profile.' ;
    rdfs:domain ind:MultiNetworkRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileUpdatedBy rdf:type rdf:Property ;
