ind:complianceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Compliance Document Reference' ;
    rdfs:comment 'Identifier or URI of supporting documentation (e.g., scan reports, policies).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Compliance Fee Amount' ;
    rdfs:comment 'Monetary amount of any fee associated with compliance monitoring or certification.' ;
    rdfs:domain ind:PciCompliance ;
