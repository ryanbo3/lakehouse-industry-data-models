    rdfs:comment 'Classification level of participant data.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReserveAccountFlag rdf:type rdf:Property ;
