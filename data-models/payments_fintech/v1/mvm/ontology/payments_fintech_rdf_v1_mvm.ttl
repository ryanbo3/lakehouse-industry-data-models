ind:openedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opened Timestamp' ;
    rdfs:comment 'Timestamp when the case was officially opened for investigation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:riskScoreAtCreation rdf:type rdf:Property ;
    rdfs:label 'Risk Score At Creation' ;
    rdfs:comment 'Risk score calculated at the moment the case was created.' ;
    rdfs:domain ind:RiskCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskScoreCurrent rdf:type rdf:Property ;
    rdfs:label 'Risk Score Current' ;
    rdfs:comment 'Most recent risk score reflecting ongoing assessment.' ;
    rdfs:domain ind:RiskCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sanctionCheckResult rdf:type rdf:Property ;
    rdfs:label 'Sanction Check Result' ;
    rdfs:comment 'Result of sanctions screening at case creation.' ;
    rdfs:domain ind:RiskCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'More detailed classification within the main category.' ;
    rdfs:domain ind:RiskCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Free-form tags for ad-hoc categorisation and search.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskExceptionId rdf:type rdf:Property ;
    rdfs:label 'Risk Exception Id' ;
    rdfs:comment 'Unique identifier for the risk exception record.' ;
    rdfs:domain ind:RiskException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionsAttached rdf:type rdf:Property ;
    rdfs:label 'Conditions Attached' ;
    rdfs:comment 'Specific conditions or constraints attached to the exception.' ;
    rdfs:domain ind:RiskException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rationale rdf:type rdf:Property ;
    rdfs:label 'Rationale' ;
    rdfs:comment 'Business justification for granting the exception.' ;
    rdfs:domain ind:RiskException ;
    rdf:type owl:DatatypeProperty ;
