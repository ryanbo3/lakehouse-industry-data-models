ind:accountingCalendar rdf:type rdf:Property ;
    rdfs:label 'Accounting Calendar' ;
    rdfs:comment 'Accounting calendar associated with the ledger.' ;
    rdfs:domain ind:Config ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Result of the most recent audit of the ledger configuration (e.g., passed, failed, pending).' ;
