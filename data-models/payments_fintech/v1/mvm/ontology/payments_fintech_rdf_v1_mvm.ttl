ind:complianceScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Score' ;
    rdfs:comment 'Overall compliance rating derived from regulatory checks, KYC, AML, and sanctions results.' ;
    rdfs:domain ind:RiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryContactMethod rdf:type rdf:Property ;
