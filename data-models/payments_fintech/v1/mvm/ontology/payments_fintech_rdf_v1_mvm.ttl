    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementFeeRate rdf:type rdf:Property ;
    rdfs:label 'Settlement Fee Rate' ;
    rdfs:comment 'Fee rate applied to settlement transactions (percentage).' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementRailCapability rdf:type rdf:Property ;
    rdfs:label 'Settlement Rail Capability' ;
    rdfs:comment 'Rail(s) the participant can use for settlement.' ;
