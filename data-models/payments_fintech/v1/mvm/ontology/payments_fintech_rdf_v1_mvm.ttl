    rdfs:range xsd:string .

ind:virtualAccountProductName rdf:type rdf:Property ;
    rdfs:label 'Virtual Account Product Name' ;
    rdfs:comment 'Human-readable name of the virtual account product.' ;
    rdfs:domain ind:VirtualAccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualAccountProductStatus rdf:type rdf:Property ;
    rdfs:label 'Virtual Account Product Status' ;
    rdfs:comment 'Current lifecycle status of the product.' ;
    rdfs:domain ind:VirtualAccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureId rdf:type rdf:Property ;
    rdfs:label 'Feature Id' ;
