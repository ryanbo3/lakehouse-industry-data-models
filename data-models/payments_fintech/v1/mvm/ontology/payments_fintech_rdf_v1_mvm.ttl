ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardized code representing the underlying cause of the exception. [ENUM-REF-CANDIDATE: data_mismatch|validation_error|network_failure|partner_error|regulatory_hold — promote to reference product]' ;
    rdfs:domain ind:SettlementException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementExceptionStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Exception Status' ;
    rdfs:comment 'Current lifecycle status of the exception.' ;
    rdfs:domain ind:SettlementException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Business-assigned severity level reflecting impact on settlement operations.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bicCode rdf:type rdf:Property ;
