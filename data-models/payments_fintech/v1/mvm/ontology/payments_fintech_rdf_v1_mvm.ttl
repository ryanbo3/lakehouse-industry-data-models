    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endpointUrl rdf:type rdf:Property ;
    rdfs:label 'Endpoint Url' ;
    rdfs:comment 'Fully qualified URL of the merchant\'s API endpoint or callback address.' ;
    rdfs:domain ind:PaymentsFintech ;
