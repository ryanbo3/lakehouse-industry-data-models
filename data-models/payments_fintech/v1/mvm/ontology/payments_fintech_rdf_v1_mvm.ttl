    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationParameters rdf:type rdf:Property ;
    rdfs:label 'Configuration Parameters' ;
    rdfs:comment 'JSON-encoded key-value pairs for feature-specific settings (e.g., 3DS version, DCC markup rate).' ;
    rdfs:domain ind:FeatureAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deactivation Timestamp' ;
    rdfs:comment 'Exact date-time when the feature was de-activated or expired; null if still active.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:featureAssignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Feature Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the feature assignment.' ;
    rdfs:domain ind:FeatureAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atmWithdrawalCapAmount rdf:type rdf:Property ;
    rdfs:label 'Atm Withdrawal Cap Amount' ;
    rdfs:comment 'Maximum cash withdrawal amount per ATM transaction.' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bnplCreditExposureLimit rdf:type rdf:Property ;
    rdfs:label 'Bnpl Credit Exposure Limit' ;
    rdfs:comment 'Total credit exposure allowed for a BNPL product.' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyCumulativeLimit rdf:type rdf:Property ;
    rdfs:label 'Daily Cumulative Limit' ;
    rdfs:comment 'Aggregate monetary limit for all transactions within a calendar day.' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enforcementMode rdf:type rdf:Property ;
    rdfs:label 'Enforcement Mode' ;
    rdfs:comment 'Indicates whether the limit is a hard block (transaction declined) or a soft alert.' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitDescription rdf:type rdf:Property ;
    rdfs:label 'Limit Description' ;
    rdfs:comment 'Free-form description providing additional context for the limit.' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxInstallments rdf:type rdf:Property ;
    rdfs:label 'Max Installments' ;
    rdfs:comment 'Maximum number of installments allowed for BNPL plans.' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monthlyCumulativeLimit rdf:type rdf:Property ;
    rdfs:label 'Monthly Cumulative Limit' ;
    rdfs:comment 'Aggregate monetary limit for all transactions within a month.' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:period rdf:type rdf:Property ;
    rdfs:label 'Period' ;
    rdfs:comment 'Time window to which a cumulative limit applies.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRationale rdf:type rdf:Property ;
    rdfs:label 'Regulatory Rationale' ;
    rdfs:comment 'Explanation of the regulatory requirement that drives this limit (e.g., AML, PSD2).' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRationale rdf:type rdf:Property ;
    rdfs:label 'Risk Rationale' ;
    rdfs:comment 'Business or risk-based justification for the limit (e.g., fraud exposure).' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weeklyCumulativeLimit rdf:type rdf:Property ;
    rdfs:label 'Weekly Cumulative Limit' ;
    rdfs:comment 'Aggregate monetary limit for all transactions within a week.' ;
    rdfs:domain ind:Limit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateLimitPolicyId rdf:type rdf:Property ;
    rdfs:label 'Rate Limit Policy Id' ;
    rdfs:comment 'Foreign key linking to gateway.rate_limit_policy. Business justification: gateway_api_credential has rate_limit_per_minute (raw integer) — a denormalized rate limiting value that should reference the authoritative rate_limit_policy master record. API credentials are subject' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateLimitPolicy .

ind:allowedIpRanges rdf:type rdf:Property ;
    rdfs:label 'Allowed Ip Ranges' ;
    rdfs:comment 'Network CIDR blocks from which the credential may be used; empty means unrestricted.' ;
    rdfs:domain ind:GatewayApiCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditLogReference rdf:type rdf:Property ;
    rdfs:label 'Audit Log Reference' ;
    rdfs:comment 'External identifier linking to a detailed audit trail stored in the compliance system.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateThumbprint rdf:type rdf:Property ;
    rdfs:label 'Certificate Thumbprint' ;
    rdfs:comment 'SHA-1/256 hash of the public certificate associated with the credential.' ;
    rdfs:domain ind:GatewayApiCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientIdentifier rdf:type rdf:Property ;
    rdfs:label 'Client Identifier' ;
    rdfs:comment 'Public identifier for an OAuth client used during token acquisition.' ;
    rdfs:domain ind:GatewayApiCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSecret rdf:type rdf:Property ;
    rdfs:label 'Client Secret' ;
    rdfs:comment 'Confidential secret associated with an OAuth client credential.' ;
    rdfs:domain ind:GatewayApiCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialKey rdf:type rdf:Property ;
    rdfs:label 'Credential Key' ;
    rdfs:comment 'Public API key or client identifier presented by the merchant/partner when invoking gateway APIs.' ;
    rdfs:domain ind:GatewayApiCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialName rdf:type rdf:Property ;
    rdfs:label 'Credential Name' ;
    rdfs:comment 'Descriptive name assigned to the credential for easy identification by operations and security teams.' ;
    rdfs:domain ind:GatewayApiCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Encryption Algorithm' ;
    rdfs:comment 'Cryptographic algorithm employed to protect the credential material.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environment rdf:type rdf:Property ;
    rdfs:label 'Environment' ;
    rdfs:comment 'Indicates whether the credential is intended for live production traffic or testing/sandbox environments.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayApiCredentialStatus rdf:type rdf:Property ;
    rdfs:label 'Gateway Api Credential Status' ;
    rdfs:comment 'Indicates whether the credential is usable, disabled, revoked, or awaiting activation.' ;
    rdfs:domain ind:GatewayApiCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hashAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Hash Algorithm' ;
    rdfs:comment 'Digest algorithm used for HMAC or signature verification.' ;
    rdfs:domain ind:GatewayApiCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hmacSecret rdf:type rdf:Property ;
    rdfs:label 'Hmac Secret' ;
    rdfs:comment 'Shared secret used to compute HMAC signatures for request authentication.' ;
    rdfs:domain ind:GatewayApiCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuer rdf:type rdf:Property ;
    rdfs:label 'Issuer' ;
    rdfs:comment 'Name of the authority or system that issued the credential.' ;
    rdfs:domain ind:GatewayApiCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyIdentifier rdf:type rdf:Property ;
    rdfs:label 'Key Identifier' ;
    rdfs:comment 'Unique identifier for the cryptographic key, used in token headers.' ;
    rdfs:domain ind:GatewayApiCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRotatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Rotated Timestamp' ;
    rdfs:comment 'Date and time when the credential was most recently rotated.' ;
    rdfs:domain ind:GatewayApiCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxConcurrentSessions rdf:type rdf:Property ;
    rdfs:label 'Max Concurrent Sessions' ;
    rdfs:comment 'Upper limit on simultaneous active sessions or tokens for this credential.' ;
    rdfs:domain ind:GatewayApiCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextRotationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Rotation Timestamp' ;
    rdfs:comment 'Scheduled date and time for the next required rotation of the credential.' ;
    rdfs:domain ind:GatewayApiCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryReviewDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Review Date' ;
    rdfs:comment 'Date when the credential was last examined for regulatory compliance.' ;
    rdfs:domain ind:GatewayApiCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Human-readable explanation for why the credential was revoked.' ;
    rdfs:domain ind:GatewayApiCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revokedFlag rdf:type rdf:Property ;
    rdfs:label 'Revoked Flag' ;
    rdfs:comment 'True if the credential has been revoked and must no longer be accepted.' ;
    rdfs:domain ind:GatewayApiCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revokedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Revoked Timestamp' ;
    rdfs:comment 'Date and time the revocation became effective.' ;
    rdfs:domain ind:GatewayApiCredential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rotationIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Rotation Interval Days' ;
    rdfs:comment 'Policy-driven interval after which the credential must be regenerated.' ;
