    rdfs:range xsd:string .

ind:gatewayRegion rdf:type rdf:Property ;
    rdfs:label 'Gateway Region' ;
    rdfs:comment 'Geographic region or data-center where the integration is hosted (e.g., us-east-1).' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationCategory rdf:type rdf:Property ;
    rdfs:label 'Integration Category' ;
    rdfs:comment 'High-level business category of the integration (e.g., payment, refund).' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationName rdf:type rdf:Property ;
    rdfs:label 'Integration Name' ;
    rdfs:comment 'Human-readable name given to this integration profile by the merchant or operations team.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationType rdf:type rdf:Property ;
    rdfs:label 'Integration Type' ;
    rdfs:comment 'Technical style of the integration (e.g., REST API, SOAP web service, ISO 8583 message, native SDK).' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRateLimited rdf:type rdf:Property ;
    rdfs:label 'Is Rate Limited' ;
    rdfs:comment 'Flag indicating whether rate limiting is enforced for this integration.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:merchantIntegrationDescription rdf:type rdf:Property ;
    rdfs:label 'Merchant Integration Description' ;
    rdfs:comment 'Free-form description of the integration purpose, scope, or special notes.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Merchant Integration Status' ;
    rdfs:comment 'Operational status of the integration profile.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingStatus rdf:type rdf:Property ;
