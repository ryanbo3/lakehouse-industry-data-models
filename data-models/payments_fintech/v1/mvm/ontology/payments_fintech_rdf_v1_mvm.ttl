# RDFS Schema for Business: Payments Fintech

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/payments_fintech#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Payments Fintech ---
ind:PaymentsFintech rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Payments Fintech' ;
    rdfs:comment 'Payments and Fintech is a transformative industry connecting consumers, merchants, and financial institutions through fast, secure electronic payment networks, digital wallets, and innovative financial technology solutions spanning over 200 countries.' .

# --- Domain Classes ---
ind:Transaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:PaymentsFintech ;
    rdfs:label 'Transaction' ;
    rdfs:comment 'Core payment transaction processing owning the full lifecycle from authorization, capture, clearing, settlement instruction, and reconciliation. SSOT for all payment events processed through ISO 8583 and ISO 20022 message flows, real-time authorization decisions, batch processing records, TPS metrics, STP rates, and multi-currency transaction data across card-present, card-not-present, and digital payment channels.' .

ind:Merchant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:PaymentsFintech ;
    rdfs:label 'Merchant' ;
    rdfs:comment 'SSOT for merchant identity, onboarding, and relationship management. Owns MID provisioning, MCC classification, merchant KYC/KYB verification, PayFac and ISO sub-merchant hierarchies, terminal registration, pricing configuration, settlement accounts, processing limits, and merchant lifecycle from application through offboarding.' .

ind:Cardholder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:PaymentsFintech ;
    rdfs:label 'Cardholder' ;
    rdfs:comment 'SSOT for all consumer and business cardholder identities served by the platform. Owns cardholder profiles, account credentials, KYC verification status, PAN/DPAN linkages, authentication attributes (CVV, AVS), SCA compliance data, and customer lifecycle supporting B2C and B2B payment relationships across all channels.' .

ind:Settlement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:PaymentsFintech ;
    rdfs:label 'Settlement' ;
    rdfs:comment 'Manages the end-to-end clearing and settlement lifecycle including batch file generation, net settlement positions, RTGS and RTP rail instructions, fund movements, reconciliation records, and funding confirmations between acquiring banks, issuing banks, and card schemes. SSOT for settlement obligations, funding schedules, reserve accounts, and settlement cycles.' .

ind:Network rdf:type rdfs:Class ;
    rdfs:subClassOf ind:PaymentsFintech ;
    rdfs:label 'Network' ;
    rdfs:comment 'Defines payment network connectivity, routing rules, and messaging metadata for each payment scheme (Visa, Mastercard, Amex, Discover). Owns network endpoints, routing tables, scheme parameter configurations, network certification records, and multi-network transaction routing logic.' .

ind:Interchange rdf:type rdfs:Class ;
    rdfs:subClassOf ind:PaymentsFintech ;
    rdfs:label 'Interchange' ;
    rdfs:comment 'SSOT for network and interchange economics — IRF tables, MDR configurations, MSF schedules, scheme fee structures, BIN-level interchange qualification rules, and Durbin Amendment compliance tiers. Supports revenue recognition and cost-of-acceptance calculations for acquiring and issuing portfolios.' .

ind:Fraud rdf:type rdfs:Class ;
    rdfs:subClassOf ind:PaymentsFintech ;
    rdfs:label 'Fraud' ;
    rdfs:comment 'Operational domain for real-time fraud detection, case management, and prevention. Owns fraud scoring rule configurations, velocity controls, device fingerprint records, 3DS authentication outcomes, SCA challenge results, blocklists, and fraud case lifecycle tracking from detection through remediation.' .

ind:Risk rdf:type rdfs:Class ;
    rdfs:subClassOf ind:PaymentsFintech ;
    rdfs:label 'Risk' ;
    rdfs:comment 'Aggregates enterprise risk scores, underwriting rules, exposure limits, and risk appetite frameworks used for transaction approval decisions and merchant risk profiling. SSOT for risk thresholds, risk models, and risk-based decisioning across the payment lifecycle.' .

ind:Dispute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:PaymentsFintech ;
    rdfs:label 'Dispute' ;
    rdfs:comment 'Manages the full dispute and chargeback lifecycle — retrieval requests, chargeback filings, reason code classification, representment packages, arbitration tracking, evidence collection, response deadlines, and final resolution outcomes. SSOT for ARN-linked dispute records and financial adjustments per card scheme rules.' .

ind:Compliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:PaymentsFintech ;
    rdfs:label 'Compliance' ;
    rdfs:comment 'Enterprise regulatory compliance domain owning AML screening results, OFAC/SDN sanctions checks, SAR and STR filings, CTF controls, BSA compliance records, PSD2 regulatory reporting, PCI DSS audit trails, GDPR data subject rights, and regulatory examination support. SSOT for regulatory obligations, FinCEN reporting, and compliance attestations.' .

ind:Product rdf:type rdfs:Class ;
    rdfs:subClassOf ind:PaymentsFintech ;
    rdfs:label 'Product' ;
    rdfs:comment 'SSOT for the payment product and pricing catalog — card programs, BNPL offerings, P2P transfer products, A2A rails, virtual account products, fee schedule configurations, pricing plans, promotional offers, bundled services, and product eligibility rules used across merchant and cardholder agreements.' .

ind:Partner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:PaymentsFintech ;
    rdfs:label 'Partner' ;
    rdfs:comment 'Master data for ecosystem partners — acquiring banks, issuing banks, card schemes, PSPs, ISOs, PayFacs, aggregators, TSPs, and technology partners. Owns partner onboarding, agreements, API integration credentials, revenue sharing, SLA commitments, referral tracking, and network participation records.' .

ind:Gateway rdf:type rdfs:Class ;
    rdfs:subClassOf ind:PaymentsFintech ;
    rdfs:label 'Gateway' ;
    rdfs:comment 'Owns the payment gateway and API routing infrastructure — merchant API/SDK integration configurations, transaction routing rules, protocol translation (ISO 8583, REST, SOAP), acquirer endpoint registrations, webhook delivery, rate limiting, API authentication, failover logic, and gateway SLA performance records.' .

ind:Fx rdf:type rdfs:Class ;
    rdfs:subClassOf ind:PaymentsFintech ;
    rdfs:label 'Fx' ;
    rdfs:comment 'Owns cross-border payment and foreign exchange operations — FX rate feeds, DCC transaction records, currency conversion audit trails, SWIFT/IBAN routing configurations, correspondent banking relationships, and multi-currency settlement instructions across 200+ countries.' .

ind:Ledger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:PaymentsFintech ;
    rdfs:label 'Ledger' ;
    rdfs:comment 'General ledger and financial accounting including GL account management, journal entries, revenue recognition, expense allocation, intercompany settlements, financial period close, and SOX-compliant financial controls. Manages chart of accounts, cost centers, and financial reporting structures.' .

# --- Data Product Classes (Tables) ---
ind:Chargeback rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dispute ;
    rdfs:label 'Chargeback' ;
    rdfs:comment 'Core master record for a chargeback filing initiated by an issuing bank on behalf of a cardholder. Captures the full chargeback lifecycle from initial filing through final resolution, including ARN, originating transaction reference, card scheme reason code (FK to reference domain), financial adjustment amounts, cycle stage (first chargeback, second chargeback/pre-arbitration chargeback), filing timestamps, scheme-mandated response deadlines, actual response dates, deadline compliance status, and current disposition. SSOT for all chargeback records in the dispute domain per card scheme rules (Visa, Mastercard, Amex, Discover).' .

ind:RetrievalRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dispute ;
    rdfs:label 'Retrieval Request' ;
    rdfs:comment 'Pre-chargeback inquiry record issued by an issuing bank requesting transaction documentation (sales draft, receipt, authorization record) from the acquiring bank before a formal chargeback is filed. Tracks retrieval request ID, ARN, MID, TID, request date, fulfillment deadline, fulfillment status, and document delivery method. Failure to fulfill a retrieval request within scheme deadlines typically escalates to a chargeback.' .

ind:Representment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dispute ;
    rdfs:label 'Representment' ;
    rdfs:comment 'Merchant or acquirer response package submitted to rebut a chargeback filing. Captures representment ID, linked chargeback ID, ARN, submission timestamp, representment amount, evidence package reference, rebuttal narrative, scheme-specific representment reason code (FK to reference domain), submission channel, scheme-mandated response deadline, actual submission date, deadline compliance status, and outcome decision (accepted, rejected, escalated to pre-arbitration). Tracks the full representment lifecycle including pre-arbitration escalation eligibility.' .

ind:ArbitrationCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dispute ;
    rdfs:label 'Arbitration Case' ;
    rdfs:comment 'Formal arbitration proceeding filed with a card scheme (Visa, Mastercard) when a dispute cannot be resolved through standard chargeback, representment, and pre-arbitration cycles. Captures arbitration case number, linked chargeback ID, filing party (issuer or acquirer), scheme arbitration fee amount, filing date, scheme-mandated response deadline, hearing date, arbitration decision, financial liability assignment, compliance case flag, and case closure date. Tracks the highest-escalation tier of the dispute lifecycle.' .

ind:DisputeCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dispute ;
    rdfs:label 'Dispute Case' ;
    rdfs:comment 'Unified dispute case record that serves as the top-level container aggregating all dispute activities — retrieval requests, chargebacks, representments, arbitration proceedings, and financial adjustments — for a single disputed transaction. Captures case number, originating transaction ARN, dispute type (fraud, authorization, processing error, consumer dispute, compliance), case open date, case close date, current lifecycle stage, assigned analyst, and final resolution outcome. SSOT for end-to-end dispute tracking.' .

ind:EvidencePackage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dispute ;
    rdfs:label 'Evidence Package' ;
    rdfs:comment 'Collection of evidentiary documents and artifacts assembled to support a representment, pre-arbitration, or arbitration response. Each package contains one or more individual evidence documents tracked at the document level (type, file reference, upload timestamp, validity status). Captures package ID, linked dispute case ID, representment ID, evidence types included (authorization record, delivery confirmation, cardholder communication, AVS/CVV match result, 3DS authentication proof, signed receipt, shipping record), document count, total file size, package assembly date, submission timestamp, submission channel, and package status. Manages the full evidence lifecycle from document collection through scheme submission and supports granular per-document tracking within the package.' .

ind:FinancialAdjustment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dispute ;
    rdfs:label 'Financial Adjustment' ;
    rdfs:comment 'Financial adjustment record generated as a result of a dispute event — chargeback debit, representment credit, arbitration fee, scheme compliance assessment, or final settlement adjustment. Captures adjustment ID, dispute case ID, adjustment type, adjustment amount, currency, debit/credit indicator, settlement batch reference, GL account code, posting date, reversal flag, and scheme-assigned financial liability party. SSOT for all monetary movements originating from the dispute lifecycle.' .

ind:LifecycleEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dispute ;
    rdfs:label 'Lifecycle Event' ;
    rdfs:comment 'Immutable event log capturing every state transition and significant activity in a dispute case lifecycle. Captures event ID, dispute case ID, event type (case opened, retrieval sent, chargeback filed, representment submitted, pre-arbitration filed, arbitration decided, case closed, deadline breached), event timestamp, actor type (issuer, acquirer, scheme, merchant, analyst), actor ID, previous state, new state, and event notes. Provides full audit trail for regulatory compliance and dispute analytics.' .

ind:PreArbitration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dispute ;
    rdfs:label 'Pre Arbitration' ;
    rdfs:comment 'Pre-arbitration filing record representing the escalation step between representment rejection and formal arbitration. Captures pre-arbitration ID, linked chargeback ID, linked representment ID, filing party (issuer or acquirer), filing date, scheme pre-arbitration case number, scheme-mandated response deadline, actual response date, deadline compliance status, response received flag, outcome (accepted, rejected, escalated to arbitration), and financial liability amount. Tracks the intermediate escalation tier before formal scheme arbitration.' .

ind:RuleConfig rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dispute ;
    rdfs:label 'Rule Config' ;
    rdfs:comment 'Business rule configuration governing automated dispute handling decisions — auto-accept thresholds, auto-representment eligibility criteria, reason-code-specific response strategies, merchant-level dispute handling overrides, and scheme-specific processing rules. Captures rule ID, rule name, rule type, applicable reason code scope, merchant segment scope, threshold amount, currency, auto-action type, effective date, expiry date, and approval status. Enables configurable dispute automation without code changes.' .

ind:RatioMonitor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dispute ;
    rdfs:label 'Ratio Monitor' ;
    rdfs:comment 'Operational monitoring record tracking a merchant\'s chargeback ratio against card scheme program thresholds (Visa VDMP, Mastercard MCP) on a monthly basis. Captures monitor record ID, MID, monitoring period month, total transaction count, total chargeback count, chargeback ratio percentage, scheme program threshold breached (standard, excessive), program enrollment date, remediation plan reference, and scheme notification date. Distinct from analytics — this is the operational compliance record used to manage merchant scheme program status.' .

ind:Claim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dispute ;
    rdfs:label 'Claim' ;
    rdfs:comment 'Cardholder-initiated dispute claim record capturing the consumer\'s assertion of a transaction problem before or during the formal chargeback process. Captures claim ID, cardholder account reference, disputed transaction ARN, claim type (unauthorized transaction, item not received, item not as described, duplicate charge, credit not processed), claim submission channel (mobile app, call center, online portal), claim date, claim amount, supporting statement, and initial triage outcome. Represents the consumer-facing entry point into the dispute lifecycle.' .

ind:MerchantResponse rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dispute ;
    rdfs:label 'Merchant Response' ;
    rdfs:comment 'Merchant-submitted response record to a dispute notification or retrieval request, capturing the merchant\'s position and supporting documentation prior to formal representment. Captures response ID, dispute case ID, MID, merchant response date, response type (accept liability, contest dispute, partial acceptance), merchant rebuttal narrative, evidence submitted flag, response channel, and acquirer review status. Distinct from representment — this is the merchant\'s raw input before the acquirer packages the formal representment.' .

ind:Fee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dispute ;
    rdfs:label 'Fee' ;
    rdfs:comment 'Fee record for all charges assessed in connection with dispute processing — scheme chargeback fees, arbitration filing fees, compliance assessment fines, retrieval request fees, and internal processing fees. Captures fee ID, dispute case ID, fee type, fee amount, currency, fee assessed by (scheme, acquirer, internal), fee assessment date, billing period, invoice reference, payment status, and waiver flag. Distinct from dispute_financial_adjustment which tracks transaction-level debits/credits; this tracks fee-based charges.' .

ind:IrfTable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interchange ;
    rdfs:label 'Irf Table' ;
    rdfs:comment 'Master reference table for Interchange Reimbursement Fee (IRF) schedules published by card schemes (Visa, Mastercard, Amex, Discover). Stores interchange rate categories, rate percentages, per-transaction fees, effective dates, card type applicability, transaction type qualifiers, and scheme-specific program identifiers. This is the authoritative SSOT for all interchange rate definitions used in cost-of-acceptance calculations.' .

ind:IrfRateCategory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interchange ;
    rdfs:label 'Irf Rate Category' ;
    rdfs:comment 'Defines the interchange rate category taxonomy used by each card scheme — e.g., Visa CPS/Retail, Mastercard Merit III, Amex OptBlue tiers. Captures category code, category name, qualifying criteria (card-present/card-not-present, EMV, AVS, MCC range), downgrade rules, and the parent scheme. Enables BIN-level and MCC-level interchange qualification logic.' .

ind:MdrConfig rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interchange ;
    rdfs:label 'Mdr Config' ;
    rdfs:comment 'Merchant Discount Rate (MDR) configuration master — stores the contractual MDR applied to each merchant or merchant segment. Captures blended rate, interchange-plus margin, tiered pricing bands, effective date range, currency, acquiring bank identifier, and pricing model type (flat, tiered, IC-plus, subscription). SSOT for merchant-facing pricing in the acquiring portfolio.' .

ind:MsfSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interchange ;
    rdfs:label 'Msf Schedule' ;
    rdfs:comment 'Merchant Service Fee (MSF) schedule defining the fee structures billed to merchants for payment acceptance services. Stores monthly/annual fee amounts, per-transaction service fees, minimum monthly fees, statement fees, PCI compliance fees, chargeback fees, and the applicable merchant tier or program. Supports revenue recognition for the acquiring portfolio.' .

ind:SchemeFeeTable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interchange ;
    rdfs:label 'Scheme Fee Table' ;
    rdfs:comment 'Card scheme assessment and network fee table capturing all fees levied by Visa, Mastercard, Amex, Discover, and other schemes on acquirers and issuers. Includes assessment rates, network access fees, cross-border fees, digital enablement fees, misuse-of-authorization fees, and scheme-specific surcharges. Effective date ranges and volume tier thresholds are tracked for accurate cost modeling.' .

ind:BinInterchangeRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interchange ;
    rdfs:label 'Bin Interchange Rule' ;
    rdfs:comment 'BIN (Bank Identification Number) level interchange qualification rules mapping BIN ranges to applicable interchange rate categories. Captures BIN range start/end, issuing bank identifier, card product type (debit, credit, prepaid, commercial), regulated/unregulated flag under Durbin Amendment, applicable IRF category codes, and scheme identifier. Core to real-time interchange qualification during transaction processing.' .

ind:Qualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interchange ;
    rdfs:label 'Qualification' ;
    rdfs:comment 'Transactional record of the interchange rate qualification outcome for each cleared transaction. Captures the transaction reference, qualified IRF category, rate applied, interchange amount calculated, downgrade reason (if applicable), qualifying criteria met (EMV, AVS, MCC, card-present flag), scheme identifier, and settlement currency. Feeds cost-of-acceptance reporting and revenue recognition.' .

ind:Billing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interchange ;
    rdfs:label 'Billing' ;
    rdfs:comment 'Periodic interchange billing record representing the net interchange amount billed or credited between acquirer and issuer for a settlement period. Captures billing period, scheme identifier, acquiring bank, issuing bank, total transaction count, gross interchange amount, scheme fee deductions, net settlement amount, currency, and billing status. Supports reconciliation against scheme invoices.' .

ind:CostOfAcceptance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interchange ;
    rdfs:label 'Cost Of Acceptance' ;
    rdfs:comment 'Calculated cost-of-acceptance record per merchant per settlement period, aggregating interchange fees, scheme assessment fees, and MSF components to derive the total payment acceptance cost. Stores gross transaction volume (TPV), total interchange cost, total scheme fees, total MSF revenue, net margin, effective rate (basis points), and period identifiers. Supports acquiring portfolio profitability analysis.' .

ind:Downgrade rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interchange ;
    rdfs:label 'Downgrade' ;
    rdfs:comment 'Records instances where a transaction failed to qualify for the optimal interchange rate category and was downgraded to a higher-cost tier. Captures original qualified category, downgraded-to category, downgrade reason code, rate differential (basis points), incremental cost, merchant identifier, transaction reference, and scheme. Enables downgrade root-cause analysis and merchant coaching.' .

ind:SchemeInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interchange ;
    rdfs:label 'Scheme Invoice' ;
    rdfs:comment 'Card scheme invoice record representing the periodic billing statement received from Visa, Mastercard, Amex, or Discover for network participation fees, assessment fees, and scheme services. Captures invoice number, scheme identifier, billing period, invoice date, due date, line-item fee categories, total amount due, currency, payment status, and reconciliation reference. SSOT for scheme payables.' .

ind:Program rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interchange ;
    rdfs:label 'Program' ;
    rdfs:comment 'Card scheme interchange program master defining special interchange programs (e.g., Visa Utility, Mastercard Merit, Amex OptBlue, Visa Purchasing) with their eligibility criteria, qualifying transaction attributes, rate structures, and enrollment requirements. Captures program code, program name, scheme, card type eligibility, MCC eligibility, transaction size thresholds, and program tier levels.' .

ind:CrossBorderFeeRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interchange ;
    rdfs:label 'Cross Border Fee Rule' ;
    rdfs:comment 'Cross-border and international transaction fee rules defining the additional fees applied when the issuing country differs from the acquiring country. Captures originating country, destination country, card scheme, cross-border assessment rate, currency conversion fee rate, DCC (Dynamic Currency Conversion) fee, SWIFT/correspondent banking fee component, and effective date range. Supports FX cost modeling in cross-border payment flows.' .

ind:PricingException rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interchange ;
    rdfs:label 'Pricing Exception' ;
    rdfs:comment 'Records negotiated pricing exceptions and custom interchange arrangements granted to specific merchants, portfolios, or partners that deviate from standard MDR or MSF schedules. Captures exception type, merchant or portfolio identifier, standard rate, exception rate, basis point discount, approval authority, effective date, expiry date, and business justification. Supports audit and contract compliance tracking.' .

ind:VolumeTierThreshold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Interchange ;
    rdfs:label 'Volume Tier Threshold' ;
    rdfs:comment 'Volume tier threshold configuration defining the transaction volume or TPV (Total Payment Volume) bands that trigger tiered interchange rates, MDR discounts, or scheme fee rebates. Captures tier level, lower volume bound, upper volume bound, applicable rate or discount, fee type, scheme or acquirer identifier, and effective date. Enables dynamic pricing adjustments based on merchant volume performance.' .

ind:Merchant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchant ;
    rdfs:label 'Merchant' ;
    rdfs:comment 'Core master entity representing a merchant business entity onboarded to the payments platform. Owns the authoritative merchant identity record including legal business name, DBA name, MID (Merchant Identification Number), business registration details, tax identification, business type, incorporation country, operational status, and lifecycle stage from application through offboarding. SSOT for all merchant identity data.' .

ind:Application rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchant ;
    rdfs:label 'Application' ;
    rdfs:comment 'Captures the full merchant onboarding application lifecycle — from initial submission through underwriting review, KYC/KYB verification, and final approval or rejection. Tracks application type (new, change, reinstatement), submission channel, assigned underwriter, decision rationale, required documentation checklist, and timestamps for each stage. Source of record for the Merchant Management System onboarding workflow.' .

ind:Location rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchant ;
    rdfs:label 'Location' ;
    rdfs:comment 'Represents a physical or virtual merchant outlet location associated with a merchant entity. Stores location name, address (street, city, state, postal code, country), location type (physical storefront, kiosk, online, mPOS), operating hours, geo-coordinates, timezone, and location-level MCC override. A single merchant may operate multiple locations each with independent settlement and terminal configurations.' .

ind:MerchantContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchant ;
    rdfs:label 'Merchant Contact' ;
    rdfs:comment 'Stores named contacts associated with a merchant entity — including primary business contact, billing contact, technical integration contact, and dispute contact. Captures full name, title, role type, email, phone, preferred communication channel, and contact status. Supports multi-contact management per merchant for relationship and operational communications.' .

ind:KybVerification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchant ;
    rdfs:label 'Kyb Verification' ;
    rdfs:comment 'Records the Know Your Business (KYB) verification outcome for a merchant entity. Captures verification provider, verification date, business identity check result, UBO (Ultimate Beneficial Owner) screening result, sanctions/OFAC screening result, adverse media check, document verification status, risk tier assigned, and overall KYB pass/fail decision. Supports AML and regulatory compliance requirements for merchant onboarding.' .

ind:BeneficialOwner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchant ;
    rdfs:label 'Beneficial Owner' ;
    rdfs:comment 'Captures the Ultimate Beneficial Owner (UBO) records for a merchant entity as required by BSA/AML regulations. Stores owner full name, date of birth, nationality, government ID type and number, ownership percentage, control role (director, officer, shareholder), PEP (Politically Exposed Person) flag, sanctions screening status, and identity verification outcome. Regulatory requirement for FinCEN CDD Rule compliance.' .

ind:MerchantAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchant ;
    rdfs:label 'Merchant Account' ;
    rdfs:comment 'Represents the processing account configuration for a merchant — the operational account that governs transaction processing parameters. Stores account status, processing currency, accepted card schemes (Visa, Mastercard, Amex, Discover), enabled payment methods, 3DS configuration, SCA requirements, AVS/CVV policy settings, transaction velocity limits, and account-level risk controls. Distinct from the merchant settlement bank account.' .

ind:MccAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchant ;
    rdfs:label 'Mcc Assignment' ;
    rdfs:comment 'Records the Merchant Category Code (MCC) assignment for a merchant or merchant location, including the assigned MCC value, assignment date, assigning authority (card scheme or acquirer), assignment rationale, previous MCC if changed, effective date, and expiry date. Tracks MCC history for interchange qualification, fraud risk profiling, and regulatory reporting. MCC drives interchange rate eligibility and spending category analytics.' .

ind:MerchantPricingPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchant ;
    rdfs:label 'Merchant Pricing Plan' ;
    rdfs:comment 'Defines the commercial pricing plan assigned to a merchant — the fee structure governing MDR (Merchant Discount Rate), interchange pass-through model, flat-rate or tiered pricing, monthly minimums, setup fees, PCI compliance fees, and chargeback fees. Stores plan name, pricing model type (flat-rate, interchange-plus, tiered, blended), effective date, expiry date, and negotiated rate overrides. SSOT for merchant commercial pricing configuration.' .

ind:MerchantFeeSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchant ;
    rdfs:label 'Merchant Fee Schedule' ;
    rdfs:comment 'Granular fee line-item schedule associated with a merchant pricing plan. Captures individual fee types (authorization fee, capture fee, refund fee, chargeback fee, monthly service fee, PCI non-compliance fee, early termination fee), fee amount or rate, fee basis (per-transaction, percentage, flat monthly), applicable card scheme, applicable transaction type, and effective date range. Enables detailed merchant billing and revenue recognition.' .

ind:MerchantSettlementAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchant ;
    rdfs:label 'Merchant Settlement Account' ;
    rdfs:comment 'Stores the merchant\'s designated bank account(s) for settlement fund disbursement. Captures bank name, account holder name, account type (checking, savings), IBAN, account number (tokenized/masked), routing number, BIC/SWIFT code, currency, settlement frequency (daily, weekly, monthly), settlement delay days, and account verification status. Supports multi-currency and multi-bank settlement configurations per merchant.' .

ind:ProcessingLimit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchant ;
    rdfs:label 'Processing Limit' ;
    rdfs:comment 'Defines the transaction processing limits and velocity controls configured for a merchant account. Stores single transaction maximum amount, daily transaction volume cap, monthly TPV (Total Payment Volume) limit, maximum transaction count per day, card-not-present limit, cross-border transaction limit, refund limit, and limit review date. Limits are set during underwriting and adjusted based on risk profile changes.' .

ind:Hierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchant ;
    rdfs:label 'Hierarchy' ;
    rdfs:comment 'Models the organizational hierarchy relationships between merchant entities — including PayFac (Payment Facilitator) to sub-merchant relationships, ISO (Independent Sales Organization) portfolios, corporate parent-to-subsidiary chains, and aggregator-to-merchant structures. Captures parent merchant ID, child merchant ID, hierarchy type (PayFac, ISO, corporate, aggregator), effective date, and hierarchy level. Enables consolidated reporting and risk exposure aggregation across merchant groups.' .

ind:SubMerchant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchant ;
    rdfs:label 'Sub Merchant' ;
    rdfs:comment 'Represents a sub-merchant entity operating under a PayFac or aggregator umbrella. Stores sub-merchant name, sub-MID, parent PayFac or aggregator reference, business type, onboarding date, processing status, assigned MCC, transaction volume tier, and sub-merchant-level risk classification. Sub-merchants are distinct from direct merchants in that they are sponsored and managed by a PayFac rather than directly contracted with the acquirer.' .

ind:AcquiringAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchant ;
    rdfs:label 'Acquiring Agreement' ;
    rdfs:comment 'Stores the formal acquiring agreement (merchant services agreement) between the acquirer and the merchant. Captures agreement type, contract start date, contract end date, auto-renewal flag, early termination fee terms, governing law jurisdiction, signatory name and date, agreement version, and amendment history reference. Distinct from pricing plan — this is the legal contract record, not the fee configuration.' .

ind:PciCompliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchant ;
    rdfs:label 'Pci Compliance' ;
    rdfs:comment 'Tracks PCI DSS (Payment Card Industry Data Security Standard) compliance status for each merchant. Stores compliance level (SAQ A, SAQ B, SAQ D, ROC), current compliance status, last assessment date, next assessment due date, AOC (Attestation of Compliance) reference, ASV scan status, penetration test date, non-compliance fee waiver status, and assigned QSA (Qualified Security Assessor). Mandatory for all card-accepting merchants per card scheme rules.' .

ind:RiskProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchant ;
    rdfs:label 'Risk Profile' ;
    rdfs:comment 'Stores the underwriting and ongoing risk assessment profile for a merchant. Captures risk tier (low, medium, high, prohibited), business model risk classification, chargeback rate (current and rolling 3-month), refund rate, fraud rate, reserve requirement type (none, rolling, capped), reserve percentage, reserve balance, last risk review date, and risk review trigger. Owned by the merchant domain as the operational risk configuration record; distinct from the enterprise risk domain\'s scoring models.' .

ind:AccountHolder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cardholder ;
    rdfs:label 'Account Holder' ;
    rdfs:comment 'SSOT master record for every consumer and business cardholder identity served by the platform. Captures full legal identity (name, DOB, nationality, tax ID), account holder type (individual B2C vs. corporate B2B), onboarding channel, lifecycle status (active, suspended, closed, dormant), preferred language, and platform-assigned cardholder reference number. This is the root anchor entity for all cardholder sub-entities and the authoritative golden record for cardholder identity across all payment channels.' .

ind:CardholderProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cardholder ;
    rdfs:label 'Cardholder Profile' ;
    rdfs:comment 'Extended personal and contact profile for an account holder. Stores PII attributes including full legal name, date of birth, gender, primary email, primary phone, preferred communication channel, marketing consent flags, and profile completeness score. Distinct from account_holder (which owns identity and lifecycle) — this entity owns the mutable contact and preference layer that changes independently of identity status. Supports GDPR/CCPA data subject rights management including right-to-erasure flags.' .

ind:Address rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cardholder ;
    rdfs:label 'Address' ;
    rdfs:comment 'Physical and mailing address records associated with a cardholder. Stores structured address components (street, city, state/province, postal code, country ISO code), address type (billing, shipping, residential, registered business), AVS-verified flag, AVS verification timestamp, geocoding coordinates, and address lifecycle (primary, secondary, historical). Supports AVS (Address Verification System) checks during card-not-present authorization and KYC address validation workflows.' .

ind:CardholderKycVerification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cardholder ;
    rdfs:label 'Cardholder Kyc Verification' ;
    rdfs:comment 'KYC (Know Your Customer) verification record capturing the full identity verification lifecycle for a cardholder. Stores verification method (document scan, biometric, database check, eIDV), verification provider, verification status (pending, passed, failed, expired, manual_review), risk tier assigned post-KYC, document types submitted, verification score, expiry date of verification, and regulatory jurisdiction. Supports AML/CTF compliance obligations and onboarding gating logic. Each re-verification creates a new record preserving the full audit trail.' .

ind:KycDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cardholder ;
    rdfs:label 'Kyc Document' ;
    rdfs:comment 'Individual identity document submitted as part of a KYC verification. Captures document type (passport, national ID, driver\'s license, utility bill, bank statement), issuing country, document number (tokenized/masked), issue date, expiry date, document image reference (vault URI), OCR extraction status, tamper detection flag, and manual review outcome. Linked to a parent kyc_verification record. Supports regulatory document retention requirements under BSA, PSD2, and FATF standards.' .

ind:PanRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cardholder ;
    rdfs:label 'Pan Record' ;
    rdfs:comment 'Authoritative PAN (Primary Account Number) registry for cardholders. Stores the tokenized PAN reference (never the raw PAN in clear text per PCI DSS), BIN (Bank Identification Number), IIN (Issuer Identification Number), card scheme (Visa, Mastercard, Amex, Discover), PAN type (FPAN physical, DPAN device token), PAN status (active, blocked, expired, replaced), expiry date, and the issuing bank reference. This is the SSOT for PAN-to-cardholder linkage and supports BIN-level routing and interchange qualification.' .

ind:PaymentCredential rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cardholder ;
    rdfs:label 'Payment Credential' ;
    rdfs:comment 'Authentication credential set associated with a cardholder\'s payment instrument. Stores CVV/CVC hash reference, CVV2 validation flag, PIN offset (for debit/ATM), 3DS enrollment status, 3DS authentication method (OTP, biometric, out-of-band), SCA compliance flag per PSD2, credential version, last rotation timestamp, and HSM key reference identifier. Distinct from pan_record (which owns the PAN identity) — this entity owns the authentication secrets and SCA compliance state. Supports EMV chip credential management and NFC contactless authentication.' .

ind:CardholderScaChallenge rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cardholder ;
    rdfs:label 'Cardholder Sca Challenge' ;
    rdfs:comment 'Record of each Strong Customer Authentication (SCA) challenge event issued to a cardholder under PSD2/3DS protocols. Captures challenge type (OTP SMS, OTP email, biometric, push notification, out-of-band), challenge status (issued, passed, failed, expired, bypassed), 3DS version, ACS (Access Control Server) reference, authentication value (CAVV/AAV), ECI indicator, challenge timestamp, and exemption reason if SCA was bypassed (low-value, TRA, merchant-initiated). Provides the full SCA audit trail required by PSD2 RTS.' .

ind:CardholderAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cardholder ;
    rdfs:label 'Cardholder Account' ;
    rdfs:comment 'Financial account record owned by a cardholder on the platform. Represents the account-level construct (credit card account, prepaid account, debit account, BNPL account) that aggregates one or more payment instruments. Stores account type, credit limit, available credit, current balance, billing cycle day, statement currency, account open date, account status (active, delinquent, charged-off, closed), and product program reference. This is the financial account layer sitting between the cardholder identity and individual payment instruments.' .

ind:AccountStatusHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cardholder ;
    rdfs:label 'Account Status History' ;
    rdfs:comment 'Immutable audit log of all status transitions for a cardholder account. Records each status change event (e.g., active→suspended, suspended→closed), the reason code, initiating actor (system, agent, cardholder self-service), effective timestamp, and reversal flag. Supports regulatory audit trail requirements under SOX, PCI DSS, and CFPB complaint handling. Enables lifecycle analytics and delinquency workflow tracking without mutating the parent cardholder_account record.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cardholder ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Segmentation classification assigned to a cardholder for product targeting, risk tiering, and pricing differentiation. Stores segment code, segment name, segment tier (mass market, premium, ultra-premium, SMB, corporate), assignment method (rule-based, ML-assigned, manual), effective date, expiry date, and the segment criteria version used. Supports product eligibility gating, MDR/MSF pricing tiers, and personalized offer targeting. A cardholder may have one active segment per segment dimension (spend tier, risk tier, loyalty tier).' .

ind:Consent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cardholder ;
    rdfs:label 'Consent' ;
    rdfs:comment 'Explicit consent and preference record for a cardholder covering data privacy, marketing, and regulatory consent obligations. Captures consent type (GDPR data processing, CCPA sale opt-out, marketing email, marketing SMS, data sharing with partners, biometric data), consent status (granted, withdrawn, pending), consent version, collection channel, IP address at consent time, and withdrawal timestamp. Provides the SSOT for all consent decisions required under GDPR, CCPA, and PSD2 open banking data sharing rules.' .

ind:LinkedAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cardholder ;
    rdfs:label 'Linked Account' ;
    rdfs:comment 'External bank account or financial account linked to a cardholder for funding, ACH pull, A2A transfer, or BNPL repayment purposes. Stores account type (checking, savings, brokerage), routing number (masked), account number token, bank name, account holder name, linking method (micro-deposit, instant verification via Plaid/Finicity, manual), verification status, and primary funding flag. Supports ACH debit authorization, IBAN/BIC for cross-border linked accounts, and open banking account aggregation.' .

ind:Device rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cardholder ;
    rdfs:label 'Device' ;
    rdfs:comment 'Mobile device or hardware token registered by a cardholder for digital wallet provisioning, HCE (Host Card Emulation), NFC payments, or 3DS out-of-band authentication. Stores device type (iOS, Android, wearable, browser), device fingerprint hash, device name, OS version, NFC capability flag, HCE capability flag, device registration status (active, deactivated, suspended), DPAN provisioning status, and last active timestamp. Distinct from wallet domain device records — this entity owns the cardholder-device relationship and authentication eligibility.' .

ind:AuthenticationEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cardholder ;
    rdfs:label 'Authentication Event' ;
    rdfs:comment 'Record of each cardholder authentication attempt across all channels — online banking login, mobile app login, IVR PIN entry, card activation, and password reset. Captures authentication method (password, OTP, biometric fingerprint, biometric face, FIDO2 passkey, knowledge-based), authentication outcome (success, failure, lockout), failure reason, IP address, geolocation, device reference, session ID, and risk signal flags. Supports fraud detection correlation, account takeover (ATO) detection, and PCI DSS access control audit requirements.' .

ind:CardholderVelocityControl rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cardholder ;
    rdfs:label 'Cardholder Velocity Control' ;
    rdfs:comment 'Cardholder-level velocity and spending control configuration. Defines per-cardholder or per-account spending limits (daily, weekly, monthly), transaction count limits, single-transaction amount caps, MCC-level restrictions, geographic restrictions (allowed/blocked countries), channel restrictions (CNP, CP, ATM, online), and control source (issuer-set, cardholder self-service, regulatory mandate). Supports real-time authorization decisioning and parental/corporate card control programs. Each active control record represents a currently enforced rule.' .

ind:PaymentTxn rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Payment Txn' ;
    rdfs:comment 'Core SSOT for every payment transaction processed through the platform — card-present, card-not-present, and digital payment channels. Captures the full ISO 8583 / ISO 20022 message lifecycle from authorization request through capture, including transaction amount, currency, MCC, channel type (POS, mPOS, eCommerce, QR, NFC, HCE), entry mode (EMV, swipe, contactless, manual), transaction timestamp, acquirer reference number (ARN), network transaction ID, processing code, response code, and STP flag. Single authoritative record per payment event.' .

ind:Authorization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Authorization' ;
    rdfs:comment 'Real-time authorization decision record produced by the Payment Gateway and Authorization Engine for each payment transaction. Stores the authorization request and response pair including authorization code, response code, decline reason, AVS result, CVV result, 3DS authentication result, SCA outcome, issuer response time, network latency, and the final approve/decline/referral decision. One authorization record per authorization attempt; a single payment may have multiple authorization attempts (retries).' .

ind:Capture rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Capture' ;
    rdfs:comment 'Capture record finalizing an authorized transaction for downstream clearing and settlement. Tracks the capture amount (which may differ from authorized amount for tip-adjusted or partial captures), capture timestamp, capture method (immediate, delayed, incremental), batch ID reference, and capture status. Represents the business event that moves a transaction from authorized to billable state in the Transaction Processing Platform.' .

ind:ClearingSubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Clearing Submission' ;
    rdfs:comment 'Clearing file record generated by the Transaction Processing Platform representing a captured transaction submitted to the card scheme or ACH network for interbank settlement. Contains clearing amount, clearing currency, interchange qualification category, MCC, BIN, IIN, scheme-assigned clearing reference, clearing file batch ID, clearing date, and scheme-specific data elements required for IRF calculation. SSOT for the clearing lifecycle stage of each transaction.' .

ind:TxnLifecycleEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Txn Lifecycle Event' ;
    rdfs:comment 'Immutable audit log of every state transition in a payment transaction\'s lifecycle — authorization, capture, clearing submission, settlement, reversal, void, refund initiation, chargeback flag. Each row records the prior state, new state, event timestamp, triggering actor (system, user, network), and ISO message type code. Enables full end-to-end transaction traceability required for PCI DSS audit trails and regulatory reporting.' .

ind:Reversal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Reversal' ;
    rdfs:comment 'Transaction reversal record capturing full and partial reversals, voids, and cancellations processed against an original payment transaction. Stores reversal type (void, partial reversal, timeout reversal), reversal amount, original transaction reference, reversal reason code, initiating party (merchant, acquirer, issuer, network), and reversal processing timestamp. Distinct from refunds (which are new debit transactions) and chargebacks (which are dispute-driven).' .

ind:Refund rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Refund' ;
    rdfs:comment 'Refund transaction record representing a merchant-initiated credit back to a cardholder\'s payment instrument following a completed sale. Captures refund amount, refund reason, original transaction reference, refund method (original payment instrument, alternative instrument), refund status, merchant-initiated timestamp, and scheme refund reference. Operationally distinct from reversals (pre-settlement) and chargebacks (dispute-driven). SSOT for merchant-initiated credit events.' .

ind:TransactionBatch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Transaction Batch' ;
    rdfs:comment 'Batch processing record representing a grouped set of captured transactions submitted together for clearing and settlement by the Transaction Processing Platform. Stores batch open timestamp, batch close timestamp, batch total transaction count, batch total amount, batch currency, batch status (open, closed, submitted, accepted, rejected), scheme batch reference, and STP rate for the batch. Enables reconciliation between individual transaction records and settlement file totals.' .

ind:Reconciliation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Reconciliation' ;
    rdfs:comment 'Reconciliation record produced by the Transaction Processing Platform comparing internal transaction records against scheme-reported clearing and settlement files. Captures reconciliation date, reconciliation type (intraday, end-of-day, T+1 settlement), matched transaction count, unmatched transaction count, total matched amount, total variance amount, reconciliation status (balanced, exception, pending), and the source file references for both sides of the comparison. SSOT for transaction-level reconciliation outcomes.' .

ind:TxnRoutingDecision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Txn Routing Decision' ;
    rdfs:comment 'Record of the real-time routing decision made by the Payment Gateway and Authorization Engine for each transaction, capturing which network rail, acquirer, and processing path was selected. Stores routing rule version applied, candidate networks evaluated, selected network, routing reason (least cost, preferred network, fallback, regulatory), routing latency in milliseconds, and whether least-cost routing (LCR) or Durbin Amendment routing rules were applied. Enables routing optimization analytics and regulatory compliance evidence.' .

ind:TxnFee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Txn Fee' ;
    rdfs:comment 'Fee record associated with a payment transaction, capturing all fee types assessed at the transaction level — interchange fees (IRF), scheme fees, processing fees, gateway fees, and cross-border surcharges. Stores fee type, fee amount, fee currency, fee calculation basis (percentage, flat, tiered), applicable rate, and the party responsible for the fee (merchant, acquirer, issuer). Enables MDR decomposition, fee revenue recognition, and interchange cost reporting.' .

ind:FxConversion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Fx Conversion' ;
    rdfs:comment 'Foreign exchange conversion record for cross-border and multi-currency transactions, capturing the source currency, target currency, FX rate applied, rate type (mid-market, DCC, scheme rate), conversion amount, conversion timestamp, rate source (scheme, internal FX engine, third-party provider), and DCC opt-in/opt-out flag. SSOT for currency conversion events at the transaction level, supporting cross-border payment reporting and DCC revenue tracking.' .

ind:TxnType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Txn Type' ;
    rdfs:comment 'Reference classification of payment transaction types supported across the platform — purchase, cash advance, balance inquiry, refund, reversal, pre-authorization, incremental authorization, account verification, P2P transfer, A2A transfer, BNPL installment, ACH debit, ACH credit, RTGS, RTP. Each type record stores the ISO processing code, transaction type code, debit/credit indicator, settlement eligibility, and applicable network rules. Provides standardized classification for transaction reporting and routing logic.' .

ind:TxnLimitRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Txn Limit Rule' ;
    rdfs:comment 'Business rule configuration defining transaction-level limits enforced during authorization — single transaction amount limits, daily cumulative limits, velocity limits (count per hour/day), card-present vs card-not-present limits, cross-border transaction limits, and contactless tap limits. Each rule stores the limit type, limit value, limit currency, applicable instrument type, applicable channel, effective date range, and the regulatory or risk basis for the limit (e.g., PSD2 contactless limit, scheme velocity rule). Owned by the transaction domain as these rules are enforced at authorization time.' .

ind:Scheme rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Scheme' ;
    rdfs:comment 'Master record for each payment card scheme (Visa, Mastercard, Amex, Discover, UnionPay, etc.). Defines the scheme brand identity, governing body, supported transaction types, geographic reach, and scheme-level operational parameters. SSOT for payment scheme identity across the platform.' .

ind:Endpoint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Endpoint' ;
    rdfs:comment 'Defines physical and logical connectivity endpoints for each payment network — host URLs, IP ranges, port configurations, protocol versions (ISO 8583, ISO 20022), TLS certificate references, and connection health thresholds. Represents the network infrastructure layer for scheme connectivity.' .

ind:RoutingTable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Routing Table' ;
    rdfs:comment 'Defines transaction routing rules mapping BIN ranges, MCC codes, transaction types, and currency combinations to target network endpoints and processing rails. Supports multi-network routing logic, least-cost routing, and failover sequencing. Core operational artifact for the Payment Gateway and Authorization Engine.' .

ind:NetworkRoutingRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Network Routing Rule' ;
    rdfs:comment 'Individual routing rule entry within a routing table. Specifies the condition set (BIN range, card type, transaction type, amount threshold, currency, region) and the target network endpoint or rail. Supports priority ordering, effective date ranges, and override flags for dynamic routing decisions.' .

ind:SchemeParameter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Scheme Parameter' ;
    rdfs:comment 'Stores scheme-specific configuration parameters published by card networks — authorization floor limits, velocity thresholds, CVV/AVS requirement flags, 3DS mandate settings, SCA exemption rules, chargeback time limits, and EMV fallback policies. Updated per scheme bulletin cycles.' .

ind:Sla rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Sla' ;
    rdfs:comment 'Defines SLA commitments for each payment network connection — target authorization response time (TPS), uptime percentage, maximum latency thresholds, batch settlement window, and penalty clauses. Tracks contracted vs. actual performance metrics per scheme and endpoint.' .

ind:SchemeMembership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Scheme Membership' ;
    rdfs:comment 'Records the formal membership and participation agreements between the platform (as acquirer, issuer, or processor) and each card scheme. Stores membership type (principal, associate, affiliate), membership ID, effective date, annual fees, and compliance obligations. SSOT for scheme participation status.' .

ind:SchemeFeeSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Scheme Fee Schedule' ;
    rdfs:comment 'Defines the fee structures charged by card schemes for network access, authorization, clearing, and value-added services. Stores fee type (network access fee, scheme processing fee, cross-border assessment), rate, effective date range, and applicable transaction categories. Distinct from interchange (owned by interchange domain).' .

ind:MultiNetworkRouting rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Multi Network Routing' ;
    rdfs:comment 'Manages multi-network routing configurations for transactions eligible to be processed across multiple networks (e.g., Visa vs. Interlink for debit, Mastercard vs. Maestro). Stores network preference order, merchant override rules, cardholder preference flags, Durbin Amendment compliance settings, and least-cost routing logic.' .

ind:Cycle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Settlement ;
    rdfs:label 'Cycle' ;
    rdfs:comment 'Master definition of a settlement cycle — the scheduled window during which transactions are batched, cleared, and settled between acquiring banks, issuing banks, and card schemes. Owns cycle identifiers, cut-off times, settlement rail (RTGS, RTP, ACH, SWIFT), value date, cycle status, and participating network scheme. SSOT for settlement timing and cycle configuration.' .

ind:SettlementBatch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Settlement ;
    rdfs:label 'Settlement Batch' ;
    rdfs:comment 'Represents a discrete batch of transactions submitted for clearing and settlement within a given settlement cycle. Captures batch sequence number, batch file reference, originating acquirer, card scheme, total transaction count, gross debit amount, gross credit amount, net settlement amount, currency, batch status (open, submitted, accepted, rejected, settled), and submission timestamp. Sourced from the Transaction Processing Platform batch processing module.' .

ind:Instruction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Settlement ;
    rdfs:label 'Instruction' ;
    rdfs:comment 'Individual fund movement instruction generated for a settlement obligation — specifying the paying party, receiving party, amount, currency, value date, payment rail (RTGS, RTP, ACH, SWIFT), IBAN/BIC routing details, and instruction status. Each instruction maps to a net settlement position and drives the actual fund transfer. Sourced from the Transaction Processing Platform settlement module.' .

ind:NetPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Settlement ;
    rdfs:label 'Net Position' ;
    rdfs:comment 'Computed net settlement position for each participant pair (acquirer–issuer, acquirer–scheme, or scheme–acquirer) within a settlement cycle. Stores gross debit total, gross credit total, net amount, currency, netting method (bilateral, multilateral), position type (transaction netting, interchange, scheme fee), position status, and confirmation flags. After merging interchange and scheme fee settlement records, this product is the unified SSOT for all settlement obligations before fund movement instructions are generated.' .

ind:FundingConfirmation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Settlement ;
    rdfs:label 'Funding Confirmation' ;
    rdfs:comment 'Record of confirmed fund receipt or payment acknowledgment for a settlement instruction. Captures confirmation reference, confirming bank, confirmation timestamp, confirmed amount, currency, RTGS/RTP transaction reference, and reconciliation status. Provides the authoritative proof-of-payment for each settlement obligation. Sourced from the Transaction Processing Platform reconciliation module.' .

ind:ClearingRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Settlement ;
    rdfs:label 'Clearing Record' ;
    rdfs:comment 'Individual cleared transaction record produced during the clearing phase — the post-authorization, pre-settlement representation of a payment transaction. Stores ARN (Acquirer Reference Number), original authorization code, MID, card scheme, interchange category, cleared amount, currency, clearing date, and clearing status. Bridges the transaction domain and the settlement domain. Sourced from the Transaction Processing Platform clearing module.' .

ind:ReconciliationRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Settlement ;
    rdfs:label 'Reconciliation Record' ;
    rdfs:comment 'Reconciliation entry matching internal settlement records against external counterparts — including bank statements, scheme clearing files, RTGS confirmations, and nostro/vostro account statements (SWIFT MT940/MT950, camt.053). Captures reconciliation run reference, reconciliation type (batch, instruction, nostro, scheme file), matched/unmatched status, variance amount, source record reference, counterpart record reference, opening and closing balances (for statement-level reconciliation), reconciliation method, and resolution notes. SSOT for all settlement reconciliation including nostro statement matching and break management.' .

ind:SettlementAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Settlement ;
    rdfs:label 'Settlement Account' ;
    rdfs:comment 'Master record of a settlement bank account used to fund or receive settlement obligations. Stores account holder (acquirer, issuer, or scheme), bank name, BIC, IBAN, account currency, account type (nostro, vostro, settlement), account status, credit limit, and current balance. SSOT for settlement account registry distinct from the general ledger account in the ledger domain.' .

ind:ReserveAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Settlement ;
    rdfs:label 'Reserve Account' ;
    rdfs:comment 'Rolling reserve or security deposit account held against a merchant or acquirer to cover potential chargebacks, fraud losses, or settlement shortfalls. Captures reserve type (rolling, capped, fixed), reserve percentage, held amount, currency, release schedule, release conditions, and current balance. SSOT for reserve obligations and release tracking.' .

ind:FundingSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Settlement ;
    rdfs:label 'Funding Schedule' ;
    rdfs:comment 'Master schedule defining when and how merchants, sub-acquirers, or PayFacs are funded from settled proceeds. Stores funding frequency (daily, weekly, T+1, T+2, T+n), funding method (ACH, wire, RTP, SEPA), funding bank account reference, minimum funding threshold, hold period, deduction sequence (MDR, interchange, scheme fees, chargebacks, reserves), and schedule status. SSOT for merchant funding timing, payout configuration, and settlement-to-payout waterfall rules.' .

ind:MerchantPayout rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Settlement ;
    rdfs:label 'Merchant Payout' ;
    rdfs:comment 'Individual payout disbursement record representing the net funds transferred to a merchant or sub-merchant after applying the funding schedule waterfall — deducting MDR, MSF, interchange fees, scheme fees, chargebacks, refunds, and reserve holds from settled transaction proceeds. Captures payout reference, merchant MID, payout amount, currency, line-item deduction breakdown, funding account, payout status (pending, released, on-hold, paid, failed), value date, and remittance advice reference. SSOT for merchant settlement payouts and funding audit trail.' .

ind:SettlementException rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Settlement ;
    rdfs:label 'Settlement Exception' ;
    rdfs:comment 'Operational record of any exception, break, or failure arising during the settlement lifecycle — including unmatched clearing records, funding shortfalls, rejected instructions, and reconciliation variances. Captures exception type, severity, affected batch or instruction reference, exception amount, assigned resolver, resolution status, and SLA breach flag. SSOT for settlement break management.' .

ind:Participant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Settlement ;
    rdfs:label 'Participant' ;
    rdfs:comment 'Master registry of all entities participating in the settlement network for this platform — acquiring banks, issuing banks, card schemes, PSPs, and PayFacs. Captures participant type, BIC/routing number, settlement account references, participation status, scheme membership IDs, and settlement rail capabilities. Distinct from the partner domain master — this is the settlement-specific participation record.' .

ind:Adjustment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Settlement ;
    rdfs:label 'Adjustment' ;
    rdfs:comment 'Record of post-settlement adjustments applied to correct errors, process late presentments, apply fee credits, or handle scheme-mandated corrections. Captures adjustment type (debit, credit), adjustment reason code, original settlement reference, adjusted amount, currency, approval reference, and effective date. Provides full audit trail for settlement corrections.' .

ind:RiskProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Risk Risk Profile' ;
    rdfs:comment 'Master record for each counterparty (merchant, cardholder, partner) capturing aggregated risk scores, risk tier classification, risk appetite alignment, and overall risk posture. SSOT for entity-level risk assessment used in underwriting, authorization decisioning, and ongoing portfolio monitoring.' .

ind:UnderwritingPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Underwriting Policy' ;
    rdfs:comment 'Defines underwriting rules, eligibility criteria, and approval conditions for merchant onboarding, credit extension, and payment product access. Captures MCC-based restrictions, TPV thresholds, reserve requirements, rolling reserve rates, and risk-based pricing parameters. Used by the Merchant Management System and Risk and Compliance Management System to automate underwriting decisions.' .

ind:RiskRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Risk Rule' ;
    rdfs:comment 'Risk decisioning rule definitions including rule type (velocity, exposure, concentration, behavioral, threshold-based), evaluation logic, parameterized threshold values, action triggers (approve, decline, review, hold), and rule versioning. Supports real-time transaction rules and batch portfolio rules. Includes threshold configurations that drive automated risk actions.' .

ind:Model rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Model' ;
    rdfs:comment 'Registry of risk scoring models deployed in the risk engine — including model type (credit, behavioral, velocity, concentration), model version, champion/challenger status, training dataset reference, feature set, performance metrics (Gini, KS, AUC), and deployment lifecycle state. Distinct from fraud domain ML models — these are risk underwriting and exposure models.' .

ind:ExposureLimit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Exposure Limit' ;
    rdfs:comment 'Maximum exposure and credit limit assignments by counterparty, counterparty type (merchant, cardholder, institutional partner), limit scope (TPV, settlement, credit line, intraday, FX), geography, and product type. Captures limit amount, currency, utilization, breach status, and review cycle. Enforced during real-time authorization and batch settlement.' .

ind:Threshold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Threshold' ;
    rdfs:comment 'Granular risk threshold configurations for specific risk dimensions — chargeback ratio thresholds, fraud rate thresholds, decline rate bands, reserve trigger levels, and concentration risk limits. Linked to risk rules and underwriting policies. Provides the parameterized values that drive automated risk actions and escalation workflows.' .

ind:UnderwritingDecision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Underwriting Decision' ;
    rdfs:comment 'Transactional record of each underwriting decision made for a merchant, cardholder, or partner — capturing decision outcome (approved, declined, conditional, referred), applied policy version, risk score at decision time, conditions imposed (reserve rate, TPV cap, restricted MCCs), decision timestamp, and approving authority (automated engine or human underwriter). SSOT for underwriting audit trail.' .

ind:Assessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Assessment' ;
    rdfs:comment 'Periodic or event-triggered risk assessment records for merchants, cardholders, and partners — capturing assessment type (initial onboarding, periodic review, triggered review), risk dimensions evaluated (credit, operational, reputational, regulatory), assessment outcome, risk tier assigned, and recommended actions. Distinct from real-time scoring — these are structured review records with human or model-driven conclusions.' .

ind:Event rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Event' ;
    rdfs:comment 'Captures discrete risk events that trigger risk management actions — including chargeback ratio breaches, fraud rate spikes, exposure limit violations, sanctions hits, and behavioral anomalies. Each event records the triggering condition, severity level, affected entity, risk dimension, and escalation status. Feeds the risk case management workflow.' .

ind:RiskCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Risk Case' ;
    rdfs:comment 'Operational case management for risk investigations — capturing case type, status lifecycle (open, under review, escalated, resolved, closed), assigned analyst, investigation evidence, mitigation actions taken, resolution outcome, and effectiveness review. SSOT for risk case workflow and intervention tracking.' .

ind:RiskException rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Risk Exception' ;
    rdfs:comment 'Records approved exceptions to standard risk policies and underwriting rules — capturing exception type, requesting entity, exception rationale, approving authority, exception validity period, conditions attached, and exception outcome. Enables governance oversight of risk policy deviations and supports regulatory audit of exception management.' .

ind:Indicator rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Indicator' ;
    rdfs:comment 'Key Risk Indicator (KRI) definitions and their time-series measurement readings. Captures indicator name, measurement formula, data source, frequency, threshold bands (green/amber/red), measured values, trend direction, and breach history. Provides operational data for KRI dashboards and risk committee reporting.' .

ind:CreditLimit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Credit limit assignments for merchants and cardholders — capturing approved credit line amount, currency, credit limit type (revolving, installment, BNPL), utilization amount, available credit, limit review date, and limit change history trigger. Owned by risk domain as the underwriting output that governs payment authorization credit decisions. Distinct from exposure_limit which governs TPV and settlement exposure.' .

ind:MitigationAction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Mitigation Action' ;
    rdfs:comment 'Records risk mitigation actions taken in response to risk events, assessment findings, or KRI breaches — capturing action type (reserve increase, TPV cap reduction, MCC restriction, account suspension, enhanced monitoring), action status, triggering risk event or case, implementation date, and effectiveness review date. Provides the operational record of risk management interventions.' .

ind:PaymentProduct rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Payment Product' ;
    rdfs:comment 'Master catalog of all payment products offered by the platform — card programs (credit, debit, prepaid), BNPL offerings, P2P transfer products, A2A rail products, virtual account products, and digital wallet products. Each record defines a distinct product type with its commercial identity, lifecycle status, supported rails, and regulatory classification. SSOT for product identity across merchant and cardholder agreements.' .

ind:CardProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Card Program' ;
    rdfs:comment 'Defines a card program as a distinct business entity — a branded card product issued under a specific BIN range, card scheme (Visa, Mastercard, Amex), and issuing bank arrangement. Captures program type (credit, debit, prepaid, commercial), co-brand partnerships, EMV configuration, contactless enablement, and program-level spending controls. Links to BIN registry and interchange qualification rules.' .

ind:BnplPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Bnpl Plan' ;
    rdfs:comment 'Master definition of Buy Now Pay Later installment plan structures offered to cardholders and merchants. Captures installment count, interest rate, promotional APR windows, minimum purchase threshold, maximum credit limit, merchant eligibility criteria, and repayment schedule logic. Distinct from a cardholder\'s active BNPL enrollment — this is the plan template in the product catalog.' .

ind:ProductFeeSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Fee Schedule' ;
    rdfs:comment 'Master fee schedule defining all fee types, rates, and calculation methods applicable to a payment product or pricing plan. Covers MDR tiers, MSF rates, interchange pass-through configurations, monthly maintenance fees, transaction fees, chargeback fees, FX markup fees, and BNPL origination fees. Each schedule is versioned and effective-dated to support regulatory and commercial changes.' .

ind:FeeScheduleLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Fee Schedule Line' ;
    rdfs:comment 'Individual line-item entries within a fee schedule, each representing a single fee component with its own rate type (flat, percentage, tiered, blended), applicable transaction type, currency, minimum/maximum cap, and effective date range. Enables granular fee modeling for complex MDR structures, interchange-plus pricing, and tiered volume discounts.' .

ind:ProductPricingPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Pricing Plan' ;
    rdfs:comment 'Commercial pricing plan assigned to merchants or cardholders, bundling a fee schedule with interchange model (flat-rate, interchange-plus, tiered, blended), volume discount thresholds, and promotional pricing windows. Tracks plan version, effective dates, approval status, and the sales channel through which the plan was offered. SSOT for the commercial pricing agreement at the plan level.' .

ind:EligibilityRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Eligibility Rule' ;
    rdfs:comment 'Business rules governing which merchants, cardholders, or segments are eligible for a given payment product, pricing plan, or promotional offer. Captures rule type (MCC restriction, BIN range filter, geography, TPV threshold, KYC tier, risk score band), rule logic (include/exclude), effective dates, and override authority. Used by onboarding and agreement workflows to validate product assignment.' .

ind:Version rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Version' ;
    rdfs:comment 'Tracks the versioned lifecycle of a payment product definition — capturing each material change to product terms, fee structures, regulatory classifications, or feature sets. Stores version number, change reason, approval authority, effective date, and the delta from the prior version. Supports regulatory audit trails and backward-compatible product agreement references.' .

ind:RateTier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Rate Tier' ;
    rdfs:comment 'Volume-based rate tier definitions used within pricing plans and fee schedules — specifying TPV bands (e.g., $0–$10K, $10K–$100K, $100K+) and the corresponding MDR or MSF rate applicable at each tier. Supports both merchant-level and portfolio-level tiered pricing models. Effective-dated to support periodic rate reviews.' .

ind:InterchangeQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Interchange Qualification' ;
    rdfs:comment 'Product-level interchange qualification configuration mapping card program and transaction attributes (card type, entry mode, MCC, authorization method, SCA compliance) to the expected interchange rate category (e.g., Visa CPS Retail, MC Merit III). Distinct from the interchange rate table owned by the interchange domain — this entity defines the qualification logic for a product\'s expected interchange outcome.' .

ind:P2pProduct rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'P2p Product' ;
    rdfs:comment 'Master definition of Peer-to-Peer transfer products offered on the platform — including instant P2P, scheduled P2P, and cross-border P2P variants. Captures supported funding sources (debit card, bank account, wallet balance), transfer limits, FX eligibility, SLA for fund availability, and regulatory classification per jurisdiction. Distinct from A2A rail products which are bank-to-bank.' .

ind:A2aProduct rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'A2a Product' ;
    rdfs:comment 'Master definition of Account-to-Account transfer rail products — ACH (standard and same-day), RTP, RTGS, SWIFT, and open banking A2A variants. Captures supported rails, settlement windows, transaction limits, STP eligibility, ISO 20022 message schema version, and regulatory reporting obligations (Reg E, PSD2). Distinct from P2P products which are consumer-wallet-funded.' .

ind:VirtualAccountProduct rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Virtual Account Product' ;
    rdfs:comment 'Master definition of virtual account products — single-use virtual card numbers, multi-use virtual accounts, and virtual IBANs issued for B2B payables, expense management, or marketplace disbursements. Captures account type, BIN assignment, spending controls, expiry logic, tokenization method (TSP/HCE), and the issuing program it belongs to.' .

ind:Feature rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Feature' ;
    rdfs:comment 'Catalog of discrete features and capabilities that can be enabled or disabled on a payment product — e.g., contactless NFC, 3DS authentication, DCC, instalment conversion, rewards accrual, spend controls, real-time notifications, and open banking data sharing. Each feature has its own activation rules, regulatory dependencies, and fee implications. Supports modular product configuration.' .

ind:FeatureAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Feature Assignment' ;
    rdfs:comment 'Association entity recording which features are enabled on a specific payment product or card program, including activation date, configuration parameters (e.g., 3DS version, DCC markup rate), approval status, and the channel or agreement that triggered the feature activation. Enables per-product feature matrix management.' .

ind:Limit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Limit' ;
    rdfs:comment 'Defines transaction and velocity limits configured at the product level — single transaction maximum, daily/weekly/monthly cumulative limits, cross-border limits, ATM withdrawal caps, and BNPL credit exposure limits. Captures limit type, currency, enforcement mode (hard block vs. soft alert), and the regulatory or risk rationale for each limit. Distinct from cardholder-level spending controls.' .

ind:GatewayApiCredential rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gateway ;
    rdfs:label 'Gateway Api Credential' ;
    rdfs:comment 'Master record for merchant and partner API authentication credentials used to access the payment gateway. Stores API keys, OAuth client IDs/secrets, HMAC signing keys, certificate thumbprints, credential rotation schedules, permission scopes, and revocation status. SSOT for gateway authentication identity — every inbound API call is authenticated against this record.' .

ind:MerchantIntegration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gateway ;
    rdfs:label 'Merchant Integration' ;
    rdfs:comment 'Master configuration record for each merchant\'s API or SDK integration with the payment gateway. Captures integration type (REST, SOAP, ISO 8583, SDK), protocol version, endpoint URLs, MID linkage, integration environment (sandbox/production), onboarding status, PCI DSS compliance tier, and assigned gateway region. One merchant may have multiple integration profiles across channels.' .

ind:GatewayRoutingRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gateway ;
    rdfs:label 'Gateway Routing Rule' ;
    rdfs:comment 'Business-managed transaction routing rule defining how inbound payment requests are directed to acquirer endpoints. Captures rule priority, matching criteria (BIN range, MCC, currency, amount threshold, card scheme, region), target acquirer endpoint, failover sequence, load-balancing weight, effective date range, and rule status. Supports least-cost routing, scheme-preference routing, and geographic routing strategies.' .

ind:AcquirerEndpoint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gateway ;
    rdfs:label 'Acquirer Endpoint' ;
    rdfs:comment 'Master record for each registered acquirer connection endpoint available to the gateway. Stores acquirer BIC/BIN, connection protocol (ISO 8583, REST, SWIFT), host URL, port, TLS certificate details, connection pool size, timeout thresholds, supported card schemes, settlement currency, geographic coverage, and operational status. SSOT for acquirer connectivity configuration within the gateway domain.' .

ind:Request rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gateway ;
    rdfs:label 'Request' ;
    rdfs:comment 'Transactional record capturing every inbound API request received by the payment gateway before authorization processing. Stores request timestamp, originating MID, TID, API credential reference, request type (authorization, capture, void, refund, inquiry), raw message hash, protocol used, source IP, request size, TLS version, and initial validation outcome. Serves as the immutable entry-point audit record for every gateway interaction.' .

ind:Response rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gateway ;
    rdfs:label 'Response' ;
    rdfs:comment 'Transactional record capturing the gateway\'s outbound response for each processed request. Stores response timestamp, linked gateway_request_id, response code, authorization code, decline reason, acquirer response code, processing latency (ms), response protocol, retry count, and final disposition. Enables SLA measurement, decline analysis, and end-to-end latency tracking.' .

ind:RoutingDecision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gateway ;
    rdfs:label 'Routing Decision' ;
    rdfs:comment 'Transactional record capturing the real-time routing decision made for each payment request. Records which routing rule was applied, the selected acquirer endpoint, evaluated alternative endpoints, routing latency, load-balancing outcome, failover triggered flag, and the reason for endpoint selection. Provides full auditability of routing logic for dispute resolution, performance tuning, and regulatory review.' .

ind:FailoverEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gateway ;
    rdfs:label 'Failover Event' ;
    rdfs:comment 'Transactional record of each gateway failover occurrence — when a primary acquirer endpoint becomes unavailable and traffic is rerouted to a secondary. Captures failover trigger timestamp, failed endpoint, failover target endpoint, trigger reason (timeout, connection refused, error threshold breach), affected transaction volume, failover duration, and recovery timestamp. Critical for SLA breach analysis and infrastructure resilience reporting.' .

ind:WebhookSubscription rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gateway ;
    rdfs:label 'Webhook Subscription' ;
    rdfs:comment 'Master record for each merchant or partner webhook subscription registered with the gateway. Stores target URL, subscribed event types (authorization.approved, capture.completed, dispute.opened, etc.), authentication method (HMAC-SHA256, OAuth bearer), retry policy, maximum retry attempts, backoff strategy, active status, and subscription creation/expiry dates. SSOT for outbound event notification configuration.' .

ind:WebhookDelivery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gateway ;
    rdfs:label 'Webhook Delivery' ;
    rdfs:comment 'Transactional record for each webhook notification delivery attempt made by the gateway. Captures delivery timestamp, linked webhook_subscription_id, event type, payload hash, HTTP response code, response latency, delivery attempt number, retry sequence, success/failure status, and next retry scheduled time. Enables merchant support teams to diagnose missed notifications and replay failed deliveries.' .

ind:RateLimitPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gateway ;
    rdfs:label 'Rate Limit Policy' ;
    rdfs:comment 'Business-managed rate limiting policy applied to API consumers accessing the gateway. Defines the consumer scope (per API credential, per MID, per IP range), request quota (TPS, RPM, daily cap), burst allowance, throttle response code, policy effective period, and enforcement action (throttle vs. block). Supports tiered service levels and abuse prevention without impacting legitimate high-volume merchants.' .

ind:SlaProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gateway ;
    rdfs:label 'Sla Profile' ;
    rdfs:comment 'Master record defining the gateway SLA commitments for a merchant integration or acquirer endpoint. Specifies target availability percentage, maximum authorization latency (p50/p95/p99 in ms), maximum error rate threshold, measurement window, breach notification SLA, and remediation obligations. Linked to merchant agreements and used as the baseline for SLA performance measurement.' .

ind:ThreedsConfig rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gateway ;
    rdfs:label 'Threeds Config' ;
    rdfs:comment 'Master configuration record for 3-D Secure (3DS v1 and v2) authentication settings applied per merchant integration. Stores 3DS protocol version, requestor ID, acquirer BIN, merchant category code override, challenge preference (no-preference, no-challenge, challenge-requested), exemption rules (TRA, low-value, trusted-beneficiary), frictionless flow eligibility, and SCA compliance status under PSD2. Governs how the gateway invokes 3DS for each merchant.' .

ind:FraudCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Fraud Case' ;
    rdfs:comment 'Core operational record representing a fraud investigation lifecycle from initial detection through remediation. Tracks case type (card-not-present, account takeover, synthetic identity, first-party fraud, etc.), case status, assigned investigator, detection source, financial exposure, recovery amount, and resolution outcome. SSOT for fraud case management in the Fraud Detection and Prevention Platform.' .

ind:Alert rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Alert' ;
    rdfs:comment 'Real-time fraud alert generated by the fraud detection engine when a transaction or account activity breaches a scoring threshold or rule condition. Captures alert type, severity level, triggering rule or model identifier, alert status (open, reviewed, escalated, closed), and the associated transaction or account reference. Feeds the case management workflow.' .

ind:FraudRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Fraud Rule' ;
    rdfs:comment 'Configuration record for a fraud detection rule deployed in the rule engine. Defines rule name, rule type (velocity, threshold, pattern, blocklist), condition logic expression, action (decline, flag, challenge, review), effective date range, channel applicability (POS, CNP, ATM, digital wallet), and rule owner. Supports versioned rule lifecycle management.' .

ind:RuleVersion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Rule Version' ;
    rdfs:comment 'Versioned history of fraud rule configurations, capturing each published version of a fraud rule with its full condition logic, action parameters, activation timestamp, deactivation timestamp, and the analyst who approved the version. Enables audit trail and rollback capability for rule changes.' .

ind:FraudVelocityControl rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Fraud Velocity Control' ;
    rdfs:comment 'Velocity control configuration defining transaction frequency and volume limits applied per cardholder, merchant, BIN, or device within a rolling time window. Captures control type (count, amount, unique merchant), window duration, threshold value, breach action (block, flag, step-up auth), and applicability scope. Core fraud prevention mechanism for CNP and POS channels.' .

ind:VelocityBreach rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Velocity Breach' ;
    rdfs:comment 'Transactional record of a velocity control breach event, capturing which velocity control was breached, the entity (cardholder, merchant, device, BIN) that triggered the breach, the observed count or amount versus the configured threshold, the breach timestamp, and the resulting action taken (block, flag, challenge). Feeds fraud alert generation.' .

ind:DeviceFingerprint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Device Fingerprint' ;
    rdfs:comment 'Device fingerprint record capturing the unique digital identity of a device used in a payment or authentication event. Stores device fingerprint hash, device type (mobile, desktop, POS terminal, mPOS), OS, browser or app version, IP address, geolocation, HCE flag, NFC capability, first-seen and last-seen timestamps, and risk classification. Used for device-based fraud detection and account takeover prevention.' .

ind:Auth3dsResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Auth 3ds Result' ;
    rdfs:comment '3-D Secure authentication outcome record for a payment transaction. Captures 3DS version (1.0, 2.1, 2.2), authentication status (authenticated, attempted, failed, not enrolled), ECI indicator, authentication value (CAVV/AAV), DS transaction ID, ACS transaction ID, challenge indicator, SCA exemption type applied, and authentication timestamp. SSOT for 3DS outcomes in the fraud domain.' .

ind:FraudScaChallenge rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Fraud Sca Challenge' ;
    rdfs:comment 'Strong Customer Authentication challenge record capturing the SCA method used (OTP, biometric, push notification, knowledge-based), challenge outcome (passed, failed, abandoned), SCA exemption applied (low-value, TRA, trusted beneficiary, recurring), PSD2 regulatory context, challenge initiation timestamp, and completion timestamp. Supports PSD2 SCA compliance reporting.' .

ind:BlocklistEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Blocklist Entry' ;
    rdfs:comment 'Blocklist record for an entity (PAN, BIN, device fingerprint, IP address, email, phone, merchant MID, IBAN) that has been flagged for blocking or enhanced scrutiny. Captures entity type, entity identifier (tokenized/hashed), blocklist reason code, source of addition (manual, automated rule, network advisory), effective date, expiry date, and blocking scope (decline, flag, step-up). SSOT for fraud blocklist management.' .

ind:ScoreEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Score Event' ;
    rdfs:comment 'Operational record of a fraud scoring evaluation performed on a transaction or account event. Captures the scoring model identifier, model version, input feature set hash, composite fraud score, score band (low, medium, high, critical), scoring latency in milliseconds, and the recommended action output. This is an OPERATIONAL event record — not an analytics aggregate — representing each real-time scoring invocation.' .

ind:Investigation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Investigation' ;
    rdfs:comment 'Detailed investigation record linked to a fraud case, tracking the investigator assigned, investigation steps taken, evidence collected (transaction logs, device data, cardholder statements), escalation history, SLA compliance status, and investigation outcome recommendation. Supports the full case investigation workflow within the FDPP case management module.' .

ind:Evidence rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Evidence' ;
    rdfs:comment 'Evidence artifact record associated with a fraud investigation, capturing evidence type (transaction record, device log, cardholder statement, network advisory, 3DS result, SCA log), evidence source, collection timestamp, storage reference, chain-of-custody status, and admissibility flag. Supports structured evidence management for dispute representment and law enforcement referrals.' .

ind:Loss rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Loss' ;
    rdfs:comment 'Financial loss record associated with a confirmed fraud case, capturing gross fraud loss amount, recovered amount, net loss, loss currency, loss category (card-present, CNP, account takeover, synthetic identity), write-off date, recovery method (chargeback, insurance, law enforcement), and accounting period. SSOT for fraud financial impact tracking and regulatory loss reporting.' .

ind:Type rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Type' ;
    rdfs:comment 'Reference classification of fraud types recognized by the platform, including type code, type name (card-not-present, card-present counterfeit, lost-and-stolen, account takeover, synthetic identity, first-party, merchant fraud, money mule, phishing), parent category, applicable payment channel, and regulatory reporting code mapping (e.g., Visa reason code, Mastercard reason code). Used for consistent fraud categorization across cases and reporting.' .

ind:Watchlist rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fraud ;
    rdfs:label 'Watchlist' ;
    rdfs:comment 'Watchlist of entities (cardholders, merchants, devices, IP ranges, email domains) under enhanced fraud monitoring without full blocking. Captures entity type, entity identifier, watchlist reason, monitoring level (passive, active, step-up auth required), watchlist source (internal, network advisory, law enforcement), effective date, review date, and assigned analyst. Distinct from blocklist — watchlist entities are monitored but not blocked.' .

ind:AmlScreeningResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Aml Screening Result' ;
    rdfs:comment 'SSOT for Anti-Money Laundering screening outcomes. Records each AML screening event against a transaction, cardholder, or merchant entity — including the screening engine used, risk score assigned, matched typology, disposition (pass/review/block), analyst override, and regulatory obligation reference. Sourced from the Risk and Compliance Management System AML module.' .

ind:SanctionsCheck rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Sanctions Check' ;
    rdfs:comment 'Records each OFAC/SDN and global sanctions screening event performed against a party (cardholder, merchant, partner, beneficiary). Captures the list version screened (SDN, EU Consolidated, UN), match score, hit details, false-positive determination, blocking action taken, and OFAC reporting obligation triggered. SSOT for sanctions screening history.' .

ind:SarFiling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Sar Filing' ;
    rdfs:comment 'Suspicious Activity Report filing record — the authoritative record of each SAR submitted to FinCEN or equivalent regulator. Captures the subject entity, suspicious activity type, activity date range, filing date, BSA tracking number, narrative summary, filing officer, and acknowledgement receipt. Supports regulatory examination and audit trail requirements under BSA.' .

ind:ComplianceKycVerification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Compliance Kyc Verification' ;
    rdfs:comment 'Know Your Customer identity verification record for cardholders, merchants, and business entities. Captures verification method (document check, biometric, database lookup), identity document type and number, verification provider, outcome (pass/fail/pending), risk tier assigned, re-verification due date, and CDD/EDD classification. SSOT for KYC status across the platform.' .

ind:RegulatoryObligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Obligation' ;
    rdfs:comment 'Master registry of all regulatory obligations applicable to the business — laws, directives, rules, and standards (PCI DSS, PSD2, BSA, GDPR, CCPA, Reg E, Reg II, OFAC, SOX). Each record defines the obligation name, governing body, jurisdiction, effective date, applicability scope, control owner, and review cadence. Serves as the compliance obligation inventory for control mapping.' .

ind:Control rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Control' ;
    rdfs:comment 'Defines each internal compliance control implemented to satisfy one or more regulatory obligations. Captures control ID, control name, control type (preventive/detective/corrective), frequency, owner, mapped obligation references, testing methodology, and last assessment outcome. Forms the control library used in PCI DSS, SOX, and regulatory examination responses.' .

ind:ControlAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Control Assessment' ;
    rdfs:comment 'Records each periodic testing or assessment of a compliance control — including assessment date, assessor (internal audit, QSA, external auditor), testing approach, evidence collected, finding severity, remediation required flag, and pass/fail outcome. Provides the audit trail for control effectiveness over time and supports PCI DSS QSA assessments and SOX testing cycles.' .

ind:PciDssAudit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Pci Dss Audit' ;
    rdfs:comment 'PCI DSS compliance audit record capturing each annual or interim assessment cycle — QSA firm, assessment scope (SAQ type or full ROC), cardholder data environment (CDE) boundaries assessed, requirements tested, findings, compensating controls, and Report on Compliance (ROC) or Self-Assessment Questionnaire (SAQ) submission details. SSOT for PCI DSS compliance posture.' .

ind:ConsentRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Consent Record' ;
    rdfs:comment 'Authoritative record of data processing consent obtained from cardholders and merchants under GDPR, PSD2, and CCPA. Captures consent type (marketing, data sharing, open banking, SCA), consent version, collection channel, timestamp, IP address, withdrawal status, and re-consent triggers. Supports lawful basis documentation and data subject rights fulfillment.' .

ind:RegulatoryFiling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Filing' ;
    rdfs:comment 'Master record of all regulatory filings submitted to governing bodies — FinCEN CTR (Currency Transaction Reports), PSD2 incident reports to ECB/NCAs, Reg E error resolution notices, CFPB complaint responses, and SWIFT gpi compliance reports. Captures filing type, regulator, submission date, filing reference number, status, and acknowledgement. Distinct from SAR/STR which have dedicated entities.' .

ind:ExaminationRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Examination Request' ;
    rdfs:comment 'Tracks regulatory examination and supervisory requests received from regulators (OCC, CFPB, FCA, ECB, FinCEN). Captures the regulator, examination type (routine, targeted, enforcement), request date, information requested, response due date, documents provided, examiner contacts, and examination outcome. SSOT for regulatory examination support and response management.' .

ind:ComplianceCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Compliance Case' ;
    rdfs:comment 'Compliance investigation case record — opened when a potential violation, breach, or regulatory concern is identified. Captures case type (AML, sanctions, PCI, GDPR, conduct), case status, assigned compliance officer, source trigger (SAR, audit finding, regulator inquiry, internal alert), investigation timeline, evidence log references, and resolution outcome. Distinct from fraud_case in the fraud domain.' .

ind:WatchlistEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Watchlist Entry' ;
    rdfs:comment 'Reference master of watchlist entries used in AML, sanctions, and CTF screening — sourced from OFAC SDN, EU Consolidated List, UN Consolidated List, HM Treasury, PEP databases, and adverse media feeds. Captures entity name, aliases, entity type (individual/organization/vessel), list source, list version date, risk category, and active status. Feeds the sanctions_check and aml_screening_result processes.' .

ind:PolicyDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Policy Document' ;
    rdfs:comment 'Master record of compliance policies and procedures — AML program policy, PCI DSS information security policy, GDPR data protection policy, sanctions policy, acceptable use policy, and BSA compliance program. Captures policy name, version, effective date, expiry date, owner, approval authority, applicable regulatory obligation references, and distribution scope.' .

ind:JurisdictionProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Jurisdiction Profile' ;
    rdfs:comment 'Reference master of regulatory jurisdictions in which the business operates — country, regulatory zone (EU, EEA, APAC), applicable payment regulations (PSD2, Reg E, APRA CPS 234), AML/CTF regime classification, FATF mutual evaluation rating, data residency requirements, and sanctions regime membership. Used to determine applicable obligations per transaction corridor and entity domicile.' .

ind:EcosystemPartner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Ecosystem Partner' ;
    rdfs:comment 'Master record for all ecosystem partners in the payments network — acquiring banks, issuing banks, card schemes, PSPs, ISOs, PayFacs, aggregators, TSPs, and technology partners. Owns the authoritative partner identity including legal entity name, partner type classification, registration jurisdiction, regulatory license numbers, PCI DSS compliance status, network participation flags, operational status, and onboarding lifecycle stage. SSOT for partner identity across the enterprise.' .

ind:PartnerProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Partner Profile' ;
    rdfs:comment 'Extended business profile for each ecosystem partner capturing operational details beyond identity — headquarters address, primary contact information, website, business description, annual TPV tier, supported payment rails (ACH, SWIFT, RTP, card), geographic footprint (countries served), supported currencies, API capability flags, and partner tier classification (Gold, Silver, Bronze). Complements ecosystem_partner with rich operational metadata.' .

ind:Agreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Agreement' ;
    rdfs:comment 'Contractual agreement records between Payments Fintech and ecosystem partners — covering acquiring agreements, ISO/PayFac sponsorship agreements, network participation agreements, TSP licensing agreements, and technology partner contracts. Captures agreement type, effective date, expiration date, auto-renewal flag, governing law jurisdiction, signatory details, MDR/IRF revenue share terms reference, SLA tier reference, termination clauses, and agreement status lifecycle (draft, active, suspended, terminated).' .

ind:OnboardingApplication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Onboarding Application' ;
    rdfs:comment 'Partner onboarding application record tracking the full lifecycle of a new partner joining the ecosystem — from initial application submission through KYC/KYB verification, due diligence, compliance screening (OFAC/AML), technical integration assessment, and final approval or rejection. Captures application date, applicant legal entity, partner type requested, assigned onboarding analyst, KYC status, AML screening result, PCI DSS attestation status, approval decision, rejection reason codes, and go-live date.' .

ind:PartnerApiCredential rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Partner Api Credential' ;
    rdfs:comment 'API integration credentials issued to partners for accessing Payments Fintech platform services — gateway APIs, tokenization APIs, reporting APIs, and webhook endpoints. Captures credential type (API key, OAuth2 client, mTLS certificate), environment (sandbox, production), issued date, expiration date, last rotation date, permission scopes, rate limit tier, IP allowlist, revocation status, and associated SDK version. Critical for partner integration security and access governance.' .

ind:RevenueShareSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Revenue Share Schedule' ;
    rdfs:comment 'Revenue sharing schedule defining the economic terms between Payments Fintech and a partner — IRF pass-through rates, MDR split percentages, MSF sharing tiers, volume-based incentive thresholds, residual income rates for ISO/PayFac referrals, and bonus structures. Captures effective date, expiration date, tiering logic (volume bands), currency, payment frequency (monthly, quarterly), and the associated partner agreement. SSOT for partner economics.' .

ind:RevenueShareStatement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Revenue Share Statement' ;
    rdfs:comment 'Periodic revenue share statement generated for each partner — capturing the calculation period, total TPV processed through the partner, gross interchange earned, MDR collected, IRF paid to networks, net revenue, partner share amount, adjustments (chargebacks, refunds, penalties), and final payable amount. Supports partner billing reconciliation and Oracle Financials AP integration for partner payouts.' .

ind:SlaCommitment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Sla Commitment' ;
    rdfs:comment 'SLA commitments defined for each partner relationship — covering uptime guarantees, authorization response time targets (TPS thresholds), settlement cutoff SLAs, dispute resolution turnaround times, API availability SLAs, and support response tiers. Captures SLA type, metric name, target value, measurement unit, measurement window, breach penalty terms, and effective period. Distinct from generic product SLAs — these are partner-specific negotiated commitments.' .

ind:NetworkParticipation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Network Participation' ;
    rdfs:comment 'Network participation records defining which payment card schemes and rails a partner is certified and active on — Visa, Mastercard, Amex, Discover, ACH, RTP, SWIFT, UPI. Captures network name, participation role (acquirer, issuer, processor, sponsor), BIN range assignments, IIN registrations, certification date, certification expiry, network-assigned member ID, and participation status. Critical for routing decisions and interchange qualification.' .

ind:BinSponsorship rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Bin Sponsorship' ;
    rdfs:comment 'BIN/IIN sponsorship records where an acquiring or issuing bank partner sponsors BIN ranges on behalf of PayFacs, ISOs, or sub-processors. Captures sponsored BIN range start/end, sponsoring bank partner, sponsored entity, card scheme, sponsorship effective date, expiration date, sponsorship agreement reference, and compliance attestation status. Essential for PayFac and ISO program management.' .

ind:PartnerContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Partner Contact' ;
    rdfs:comment 'Contact persons associated with partner organizations — primary business contacts, technical integration contacts, compliance officers, finance/billing contacts, and executive sponsors. Captures full name, job title, department, email, phone, contact role type, preferred communication channel, and active status. Supports CRM (Salesforce) synchronization for partner relationship management.' .

ind:IntegrationEndpoint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Integration Endpoint' ;
    rdfs:comment 'Technical integration endpoint configurations for partner API and messaging connections — REST API endpoints, ISO 8583 socket connections, ISO 20022 messaging endpoints, SFTP batch file exchange endpoints, and webhook delivery URLs. Captures endpoint URL, protocol type, message format standard (ISO 8583, ISO 20022, JSON REST), environment (sandbox/production), TLS version, authentication method, timeout settings, retry policy, and health check URL.' .

ind:PartnerSettlementAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Partner ;
    rdfs:label 'Partner Settlement Account' ;
    rdfs:comment 'Bank account and settlement account details registered for partner payouts — revenue share disbursements, referral commissions, and incentive payments. Captures account holder name, bank name, account type, IBAN, BIC/SWIFT code, routing number (ACH), account currency, account verification status, verification date, and designated use (revenue share, penalty, refund). Distinct from merchant settlement accounts — these are partner-level financial accounts.' .

ind:GlAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'Chart of accounts master record defining every general ledger account used across the enterprise. Captures account number, account type (asset, liability, equity, revenue, expense), normal balance direction, account hierarchy level, parent account reference, financial statement mapping (P&L vs balance sheet), currency, consolidation flag, intercompany flag, and SOX control classification. This is the SSOT for all GL account definitions in Oracle Financials and the authoritative reference for all journal entry postings.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Organizational cost center master record representing a financial responsibility unit within the payments fintech enterprise. Captures cost center code, name, owning business unit, division, department, manager, active status, budget period, currency, and allocation basis. Used for expense allocation, P&L reporting by business unit, and management accounting. Aligns with Oracle Financials cost center segment in the accounting flexfield.' .

ind:LegalEntity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Legal Entity' ;
    rdfs:comment 'Legal entity master record representing each incorporated company, subsidiary, or branch within the payments fintech corporate group. Captures legal entity name, registration number, jurisdiction of incorporation, tax identification number, functional currency, consolidation group, SWIFT BIC, regulatory license references, and OFAC/sanctions screening status. Serves as the top-level organizational anchor for all financial reporting and intercompany accounting.' .

ind:AccountingPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'Financial accounting period master defining the fiscal calendar used for GL posting, period-end close, and financial reporting. Captures period name, fiscal year, period number, period type (month, quarter, year), open/closed status, period open date, period close date, adjustment period flag, and the ledger it belongs to. Controls which periods accept journal entry postings and drives the financial period close workflow.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'General ledger journal entry header record representing a balanced accounting transaction posted to the GL. Captures journal entry number, journal source (payment processing, settlement, manual, intercompany, recurring), journal category, accounting date, currency, total debit amount, total credit amount, posting status, reversal flag, reversal period, preparer, approver, SOX control reference, and description. The primary transactional record for all financial activity in Oracle Financials GL module.' .

ind:JournalLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Journal Line' ;
    rdfs:comment 'Individual debit or credit line within a GL journal entry. Captures line number, GL account, cost center, legal entity, project, intercompany entity, debit amount, credit amount, functional currency amount, transaction currency amount, FX rate, line description, tax code, and reconciliation reference. Each journal entry must have balanced lines (total debits = total credits). Supports drill-through from financial statements to source transactions.' .

ind:GlBalance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Gl Balance' ;
    rdfs:comment 'Period-end GL account balance record capturing the opening balance, period activity (debits and credits), and closing balance for each GL account per accounting period per ledger. Supports financial statement generation, variance analysis, and period-over-period comparisons. Captures account, period, ledger, currency type (functional/reporting), beginning balance, period debit, period credit, ending balance, and translated balance for multi-currency reporting.' .

ind:Config rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Config' ;
    rdfs:comment 'Ledger configuration master defining each accounting ledger (primary, secondary, reporting) within Oracle Financials. Captures ledger name, ledger type, chart of accounts, accounting calendar, functional currency, subledger accounting method, consolidation ledger flag, reporting currency, translation method, and retained earnings account. A payments fintech enterprise typically maintains multiple ledgers for different legal entities and regulatory reporting jurisdictions.' .

ind:SubledgerEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Subledger Entry' ;
    rdfs:comment 'Subledger accounting entry record generated by operational subsystems (payment gateway, settlement engine, merchant billing, dispute management) before posting to the GL. Captures subledger application (AP, AR, FA, payment processing), event type, event date, accounting date, transaction reference, GL account derivation rule applied, debit/credit amounts, currency, and transfer-to-GL status. Provides the audit trail linking operational transactions to GL postings per SOX requirements.' .

ind:RevenueRecognitionSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Revenue Recognition Schedule' ;
    rdfs:comment 'Revenue recognition schedule master defining the rules and timeline for recognizing deferred revenue in compliance with ASC 606 / IFRS 15. Captures contract reference, performance obligation description, total transaction price, allocated amount, recognition method (point-in-time vs over-time), recognition start date, recognition end date, recognition frequency, and recognized-to-date amount. Critical for payments fintech revenue streams including MDR, SaaS platform fees, and BNPL origination fees.' .

ind:RevenueRecognitionEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Revenue Recognition Event' ;
    rdfs:comment 'Individual revenue recognition event record capturing each instance of revenue being recognized against a schedule. Captures schedule reference, recognition date, accounting period, recognized amount, cumulative recognized amount, remaining deferred amount, GL journal entry reference, recognition trigger (time-based, milestone, usage), and recognition status. Provides the transactional audit trail for ASC 606 compliance and SOX revenue controls.' .

ind:AccountReconciliation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Account Reconciliation' ;
    rdfs:comment 'GL account reconciliation record capturing the formal balance reconciliation performed for each GL account at period end. Captures account, accounting period, GL balance per books, reconciling items, adjusted balance, supporting documentation reference, preparer, reviewer, approval status, and sign-off date. Mandatory SOX control for all balance sheet accounts. Tracks open reconciling items and aging of unresolved differences.' .

ind:Payable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Payable' ;
    rdfs:comment 'Accounts payable invoice record representing amounts owed by the payments fintech enterprise to vendors, card schemes, and service providers. Captures supplier reference, invoice number, invoice date, due date, payment terms, invoice amount, currency, tax amount, GL account distribution, cost center, approval status, payment status, and scheme invoice reference (for Visa/Mastercard scheme fee invoices). Managed in Oracle Financials AP module.' .

ind:Receivable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Receivable' ;
    rdfs:comment 'Accounts receivable invoice record representing amounts owed to the payments fintech enterprise by merchants, partners, and customers. Captures customer/merchant reference, invoice number, invoice date, due date, payment terms, invoice amount, currency, tax amount, GL account distribution, collection status, aging bucket, and dispute flag. Includes MDR billing, platform fee invoices, and interchange income receivables. Managed in Oracle Financials AR module.' .

ind:FinancialStatement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ledger ;
    rdfs:label 'Financial Statement' ;
    rdfs:comment 'Published financial statement record representing a formal financial report (income statement, balance sheet, cash flow statement, statement of equity) for a legal entity or consolidated group for a reporting period. Captures statement type, reporting entity, reporting period, reporting standard (GAAP/IFRS), currency, preparation status, review status, external audit sign-off, filing reference (SEC, regulatory), and restatement flag. The authoritative record of financial reporting outputs.' .

ind:Rate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fx ;
    rdfs:label 'Rate' ;
    rdfs:comment 'Master record for foreign exchange rates published and consumed by the payments platform. Captures spot rates, mid-market rates, bid/ask spreads, and indicative rates for every currency pair supported across 200+ countries. Sourced from primary rate feed providers (Reuters, Bloomberg, ECB) and internal treasury desks. Serves as the authoritative rate reference for DCC pricing, cross-border transaction conversion, and settlement FX calculations. Includes rate type classification (spot, forward, indicative, guaranteed), effective timestamp, expiry timestamp, rate source, and confidence band.' .

ind:RateFeed rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fx ;
    rdfs:label 'Rate Feed' ;
    rdfs:comment 'Master configuration record for each external FX rate feed provider integrated into the platform. Defines the provider identity (Reuters Refinitiv, Bloomberg FX, ECB reference rates, internal treasury), feed protocol (REST, FIX, SFTP), polling frequency, supported currency pairs, rate type delivered, SLA thresholds, failover priority, and connectivity credentials metadata. Governs how the platform ingests, validates, and routes rate data from each upstream source. Critical for rate feed health monitoring and provider SLA management.' .

ind:CurrencyPair rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fx ;
    rdfs:label 'Currency Pair' ;
    rdfs:comment 'Reference master for all supported currency pairs traded or converted on the platform. Defines the base currency, quote currency, ISO 4217 currency codes, standard pip size, minimum tradeable unit, decimal precision, market convention (direct/indirect quote), trading hours, and active status. Serves as the canonical reference for FX rate lookups, DCC eligibility checks, and cross-border routing decisions. Includes classification of major, minor, and exotic pairs relevant to the payments corridor.' .

ind:DccTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fx ;
    rdfs:label 'Dcc Transaction' ;
    rdfs:comment 'Transactional record capturing every Dynamic Currency Conversion event executed at the point of sale or online checkout. Records the original transaction currency, cardholder home currency, exchange rate applied, DCC margin percentage, converted amount, cardholder acceptance or decline of DCC offer, merchant MID, terminal TID, acquirer reference number (ARN), and scheme DCC compliance flags. Supports DCC revenue reporting, scheme compliance audits (Visa/Mastercard DCC rules), and cardholder dispute resolution for currency conversion disagreements.' .

ind:CorrespondentBank rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fx ;
    rdfs:label 'Correspondent Bank' ;
    rdfs:comment 'Master record for correspondent banking relationships maintained by the platform to facilitate cross-border payment routing. Captures the correspondent bank name, BIC/SWIFT code, IBAN format supported, nostro account details, supported currencies, supported payment corridors, settlement cut-off times, correspondent bank fees, regulatory jurisdiction, AML/KYC status, and relationship status. Serves as the SSOT for correspondent banking counterparty data used in SWIFT routing, cross-border settlement instructions, and treasury liquidity management.' .

ind:NostroAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fx ;
    rdfs:label 'Nostro Account' ;
    rdfs:comment 'Master record for each nostro account held by the platform at correspondent banks in foreign currencies. Captures the account number, correspondent bank reference, currency denomination, account type, opening balance, current balance, minimum balance threshold, overdraft limit, account status, and the treasury desk responsible for management. Nostro accounts are the operational funding pools for cross-border payment execution. Supports real-time liquidity monitoring, pre-funding adequacy checks, and reconciliation against correspondent bank statements.' .

ind:NostroBalance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fx ;
    rdfs:label 'Nostro Balance' ;
    rdfs:comment 'Transactional record capturing point-in-time balance snapshots and movements on each nostro account. Records the nostro account reference, value date, opening balance, closing balance, credit movements, debit movements, pending credits, pending debits, and reconciliation status against correspondent bank statements. Enables intraday liquidity monitoring, end-of-day reconciliation, and pre-funding adequacy validation before cross-border payment execution. Distinct from nostro_account (the master) as it captures the time-series balance history.' .

ind:PaymentCorridor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fx ;
    rdfs:label 'Payment Corridor' ;
    rdfs:comment 'Master configuration record defining a supported cross-border payment corridor between a source country and destination country. Captures the source country ISO code, destination country ISO code, supported currencies, available payment rails (SWIFT, local ACH, RTP, SEPA), regulatory restrictions, OFAC/sanctions screening requirements, estimated settlement time, corridor status, and applicable fee schedule reference. Serves as the routing decision table for cross-border payment execution and corridor availability checks.' .

ind:Exposure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fx ;
    rdfs:label 'Exposure' ;
    rdfs:comment 'Transactional record capturing the platform\'s open FX exposure position by currency at a point in time. Records the currency, exposure direction (long/short), gross notional exposure, net exposure after hedges, unhedged exposure, value date, exposure source (pending settlements, nostro balances, forward contracts), and risk limit utilization percentage. Enables treasury to monitor real-time FX risk positions, trigger hedging actions when exposure breaches thresholds, and report FX risk to the board and regulators.' .

ind:CrossBorderPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fx ;
    rdfs:label 'Cross Border Payment' ;
    rdfs:comment 'Core transactional record for every cross-border payment instruction initiated through the platform. Captures the payment reference, originating country, destination country, sender identity, beneficiary identity, beneficiary bank BIC, beneficiary IBAN/account number, payment amount, origination currency, destination currency, FX rate applied, converted amount, payment rail selected (SWIFT, SEPA, local ACH), SWIFT UETR, payment purpose code, regulatory reporting flags, OFAC screening status, and payment lifecycle status. The SSOT for cross-border payment execution within the FX domain.' .

ind:DccConfig rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fx ;
    rdfs:label 'Dcc Config' ;
    rdfs:comment 'Master configuration record governing DCC program parameters for each merchant or merchant category enrolled in the DCC service. Captures the merchant MID, enrolled currency pairs, DCC margin percentage, minimum transaction amount for DCC offer, DCC offer presentation method (terminal, online, IVR), scheme compliance settings (Visa DCC, Mastercard Currency Conversion), cardholder disclosure text reference, opt-in/opt-out default, and configuration effective dates. Drives the DCC eligibility and rate calculation logic at transaction time.' .

ind:FxFeeSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fx ;
    rdfs:label 'Fx Fee Schedule' ;
    rdfs:comment 'Reference master defining the fee structures applied to FX and cross-border payment services offered by the platform. Captures the fee schedule name, applicable service type (DCC, cross-border transfer, currency conversion, SWIFT wire), fee calculation method (flat, percentage, tiered), fee currency, minimum fee, maximum fee, applicable currency pairs or corridors, customer segment applicability, effective date, and expiry date. Serves as the pricing reference for FX revenue calculation and merchant/cardholder fee disclosure.' .

ind:RateMarginConfig rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fx ;
    rdfs:label 'Rate Margin Config' ;
    rdfs:comment 'Master configuration record defining the FX margin (spread) applied on top of the interbank mid-market rate for each customer segment, product type, or payment corridor. Captures the margin type (fixed spread, percentage markup, tiered by volume), base rate source, margin basis points, applicable currency pair or corridor, customer tier, product type, effective date, and approval authority. Governs how the platform marks up interbank rates to generate FX revenue while remaining competitive and compliant with PSD2 transparency requirements.' .

ind:Beneficiary rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fx ;
    rdfs:label 'Beneficiary' ;
    rdfs:comment 'Master record for beneficiary entities registered on the platform for recurring cross-border payment execution. Captures the beneficiary name, beneficiary type (individual, corporate), country of residence, bank name, bank BIC/SWIFT code, account number or IBAN, account currency, beneficiary address, identity verification status, sanctions screening status, and last payment date. Serves as the trusted beneficiary registry enabling faster cross-border payment processing by pre-validating and pre-screening recurring payment recipients.' .

ind:Settlement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Settlement ;
    rdfs:label 'Settlement' ;
    rdfs:comment 'Master reference table for settlement. ' .

ind:Transaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Transaction ;
    rdfs:label 'Transaction' ;
    rdfs:comment 'Master reference table for transaction. ' .

ind:Party rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Party' ;
    rdfs:comment 'Master reference table for party. Referenced by party_id.' .

ind:Policy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Policy' ;
    rdfs:comment 'Master reference table for risk_policy. Referenced by risk_policy_id.' .

ind:Acquirer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Settlement ;
    rdfs:label 'Acquirer' ;
    rdfs:comment 'Master reference table for acquirer. Referenced by originating_acquirer_id.' .

ind:CorridorBankAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fx ;
    rdfs:label 'Corridor Bank Assignment' ;
    rdfs:comment 'This association product represents the operational assignment of correspondent banks to payment corridors for cross-border payment routing. It captures the treasury and operations team\'s active management of which correspondent banks are authorized and prioritized for each corridor. Each record links one payment corridor to one correspondent bank with routing priority, settlement terms, fee overrides, and relationship lifecycle dates that exist only in the context of this specific corridor-bank pairing.. Existence Justification: In cross-border payments operations, payment corridors (e.g., US-to-EU, APAC-to-LATAM) require multiple correspondent banks for redundancy, cost optimization, and regulatory compliance, while each correspondent bank serves multiple corridors based on their geographic reach and currency capabilities. Treasury and operations teams actively manage these assignments with routing priorities, corridor-specific settlement terms, fee negotiations, and lifecycle management (effective dates, suspension, termination). This is not a derived correlation but an operational business process where relationship managers configure and maintain corridor-bank pairings as a core routing decision table.' .

ind:FeedCoverage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fx ;
    rdfs:label 'Feed Coverage' ;
    rdfs:comment 'This association product represents the operational coverage configuration between rate_feed and currency_pair. It captures which external FX rate feed providers supply rates for which currency pairs, along with feed-specific precision overrides, polling frequency adjustments, effective date ranges, primary source designation, and confidence weighting used for rate aggregation and failover logic. Each record links one rate_feed to one currency_pair with attributes that exist only in the context of this specific feed-pair subscription.. Existence Justification: In FX payment platforms, rate feed providers each cover different subsets of currency pairs with varying quality and latency characteristics. A single feed (e.g., Reuters) supplies rates for multiple pairs (EUR/USD, GBP/USD, USD/JPY), and a single currency pair (e.g., EUR/USD) is sourced from multiple feeds for redundancy, rate aggregation, and failover. The platform actively manages this feed-pair coverage configuration with pair-specific polling frequencies, precision overrides, primary source designation, and confidence weights used in rate aggregation algorithms.' .

ind:CasePartyInvolvement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Case Party Involvement' ;
    rdfs:comment 'This association product represents the investigative involvement relationship between compliance_case and party. It captures which parties are subjects, witnesses, or associated entities in each compliance investigation, along with their role, involvement timeline, and investigative status. Each record links one compliance_case to one party with attributes that exist only in the context of this specific investigation relationship.. Existence Justification: In compliance investigations, a single case routinely involves multiple parties (subject, witnesses, beneficial owners, associated entities), and a single party can be involved in multiple compliance cases over time in different roles. Compliance officers actively manage case party involvement as a distinct investigative concept, tracking each party\'s role, involvement status, interview dates, and risk contribution for each case. This is an operational M:N relationship that cannot be modeled with a simple FK without losing critical investigative tracking data.' .

# --- Attribute Properties ---
ind:chargebackId rdf:type rdf:Property ;
    rdfs:label 'Chargeback Id' ;
    rdfs:comment 'Unique surrogate primary key for the chargeback record in the dispute domain. Serves as the SSOT identifier for all chargeback lifecycle tracking per card scheme rules (Visa, Mastercard, Amex, Discover).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Chargeback .

ind:acquirerId rdf:type rdf:Property ;
    rdfs:label 'Acquirer Id' ;
    rdfs:comment 'Foreign key linking to settlement.acquirer. Business justification: Chargebacks are processed by acquiring banks; acquirer_reference is a denormalized text field. A proper FK to settlement.acquirer enables acquirer-level chargeback ratio reporting, scheme monitoring p' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Acquirer .

ind:authorizationId rdf:type rdf:Property ;
    rdfs:label 'Authorization Id' ;
    rdfs:comment 'Foreign key linking to transaction.authorization. Business justification: Original authorization data is required to validate the auth amount, response codes, and 3-DS results during chargeback assessment.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Authorization .

ind:bnplPlanId rdf:type rdf:Property ;
    rdfs:label 'Bnpl Plan Id' ;
    rdfs:comment 'Foreign key linking to product.bnpl_plan. Business justification: BNPL chargebacks require plan-specific processing (partial installment chargebacks, credit adjustment logic). This link supports BNPL chargeback calculation, installment-specific liability determinati' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BnplPlan .

ind:captureId rdf:type rdf:Property ;
    rdfs:label 'Capture Id' ;
    rdfs:comment 'Foreign key linking to transaction.capture. Business justification: Capture details (final amount, fees) are essential for reconciling chargeback amounts and settlement adjustments.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capture .

ind:cardProgramId rdf:type rdf:Property ;
    rdfs:label 'Card Program Id' ;
    rdfs:comment 'Foreign key linking to product.card_program. Business justification: Chargeback thresholds, reason codes, and liability rules are program-specific (e.g., debit vs credit chargeback rights differ). This link enables program-specific chargeback processing, ratio monitori' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CardProgram .

ind:cardholderAccountId rdf:type rdf:Property ;
    rdfs:label 'Cardholder Account Id' ;
    rdfs:comment 'Foreign key linking to cardholder.cardholder_account. Business justification: Chargebacks are initiated against a specific cardholder account for provisional credit posting, chargeback ratio tracking per account, and billing cycle impact assessment. Issuers must link each charg' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CardholderAccount .

ind:clearingRecordId rdf:type rdf:Property ;
    rdfs:label 'Clearing Record Id' ;
    rdfs:comment 'Foreign key linking to settlement.clearing_record. Business justification: A chargeback is raised against a specific cleared transaction. The clearing_record holds cleared_amount, interchange_category, and original_authorization_code — authoritative data for chargeback amoun' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClearingRecord .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to ledger.cost_center. Business justification: Chargebacks are allocated to cost centers (merchant services operations, fraud prevention, dispute resolution teams) for management accounting, budget variance analysis, and departmental P&L. Enables ' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:crossBorderPaymentId rdf:type rdf:Property ;
    rdfs:label 'Cross Border Payment Id' ;
    rdfs:comment 'Foreign key linking to fx.cross_border_payment. Business justification: Cross-border chargebacks must reference the originating payment to satisfy audit, compliance, and settlement reconciliation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrossBorderPayment .

ind:disputeCaseId rdf:type rdf:Property ;
    rdfs:label 'Dispute Case Id' ;
    rdfs:comment 'Reference to the parent dispute case record that initiated this chargeback filing. A dispute may progress through retrieval request, first chargeback, second chargeback, and arbitration stages — this links the chargeback to its overarching dispute case.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DisputeCase .

ind:ecosystemPartnerId rdf:type rdf:Property ;
    rdfs:label 'Ecosystem Partner Id' ;
    rdfs:comment 'Reference to the issuing bank (cardholder\'s bank) that initiated the chargeback on behalf of the cardholder. The issuing bank is the party that files the chargeback against the acquiring bank per card scheme rules.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EcosystemPartner .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Reference to the General Ledger entry in Oracle Financials (ERP) recording the financial adjustment associated with this chargeback. Enables reconciliation between the dispute management system and the financial accounting system for SOX compliance and revenue recognition.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to ledger.legal_entity. Business justification: Chargebacks create financial statement impact that must be allocated to the correct legal entity for consolidated reporting, regulatory filings (10-K/10-Q for public companies), and inter-company sett' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:merchantId rdf:type rdf:Property ;
    rdfs:label 'Merchant Id' ;
    rdfs:comment 'Reference to the merchant record against whom the chargeback has been filed. The Merchant Identification Number (MID) is the acquiring bank-assigned identifier for the merchant in the payment network.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Merchant .

ind:paymentProductId rdf:type rdf:Property ;
    rdfs:label 'Payment Product Id' ;
    rdfs:comment 'Foreign key linking to product.payment_product. Business justification: Chargeback performance dashboard requires product-level metrics for risk analysis and scheme reporting; linking each chargeback to its payment_product enables this.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentProduct .

ind:paymentTxnId rdf:type rdf:Property ;
    rdfs:label 'Payment Txn Id' ;
    rdfs:comment 'Foreign key linking to transaction.payment_txn. Business justification: Chargeback investigations need the detailed payment transaction record for settlement, network, and device info – a standard compliance and reporting requirement.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTxn .

ind:schemeId rdf:type rdf:Property ;
    rdfs:label 'Scheme Id' ;
    rdfs:comment 'Foreign key linking to network.scheme. Business justification: Chargebacks are filed under a specific card scheme; scheme_id enables scheme-level chargeback reporting required by Visa/Mastercard compliance.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Scheme .

ind:settlementId rdf:type rdf:Property ;
    rdfs:label 'Settlement Id' ;
    rdfs:comment 'Foreign key linking to settlement.settlement. Business justification: Chargeback settlement reports must link to the settlement record that includes the chargeback amount for traceability.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Settlement .

ind:transactionId rdf:type rdf:Property ;
    rdfs:label 'Transaction Id' ;
    rdfs:comment 'Reference to the originating payment transaction record in the transaction domain that is the subject of this chargeback filing. Links the chargeback to the full transaction detail including authorization, capture, and settlement data.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Net financial adjustment amount posted to the merchant\'s account as a result of this chargeback. Includes the chargeback amount plus any applicable scheme fees, processing fees, or interchange adjustments. Negative value indicates a debit to the merchant; positive value indicates a credit (e.g., upon successful representment).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Gross amount of the chargeback as filed by the issuing bank in the transaction currency. Represents the disputed amount that will be debited from the merchant\'s account if the chargeback is upheld. May differ from the original transaction amount in cases of partial chargebacks.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arbitrationDeadline rdf:type rdf:Property ;
    rdfs:label 'Arbitration Deadline' ;
    rdfs:comment 'Scheme-mandated deadline for filing an arbitration case with the card scheme after a failed pre-arbitration or second chargeback cycle. Arbitration is the final escalation path where the card scheme adjudicates the dispute and assigns liability. Missing this deadline forfeits the right to arbitration.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:arbitrationFilingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Arbitration Filing Timestamp' ;
    rdfs:comment 'Actual timestamp when the arbitration case was filed with the card scheme. Populated only when the chargeback has been escalated to the arbitration stage (cycle_stage = ARBITRATION).' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:arn rdf:type rdf:Property ;
    rdfs:label 'Arn' ;
    rdfs:comment 'Acquirer Reference Number uniquely identifying the originating payment transaction across the card scheme network. Primary linkage key between the chargeback and the settled transaction. Assigned by the acquiring bank at settlement and used by all parties to trace the transaction through the payment chain.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardScheme rdf:type rdf:Property ;
    rdfs:label 'Card Scheme' ;
    rdfs:comment 'Payment network brand (card scheme) under whose rules this chargeback is governed. Determines the applicable reason code taxonomy, response deadlines, cycle stages, and arbitration procedures. [ENUM-REF-CANDIDATE: VISA|MASTERCARD|AMEX|DISCOVER|UNIONPAY|OTHER — promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderDisputeReason rdf:type rdf:Property ;
    rdfs:label 'Cardholder Dispute Reason' ;
    rdfs:comment 'Free-text description of the cardholder\'s stated reason for disputing the transaction as captured by the issuing bank. Provides the narrative context behind the formal reason code classification. Used by the merchant in preparing the representment package.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally-known business identifier for the chargeback case as assigned by the Dispute and Chargeback Management System. Used by operations teams, merchants, and card schemes to reference the chargeback in correspondence, representment packages, and scheme portal submissions.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackStatus rdf:type rdf:Property ;
    rdfs:label 'Chargeback Status' ;
    rdfs:comment 'Current disposition and lifecycle status of the chargeback record. Tracks the chargeback from initial receipt through final resolution. RECEIVED: chargeback filed by issuer; UNDER_REVIEW: internal review in progress; AWAITING_RESPONSE: merchant response pending; REPRESENTED: merchant submitted representment; ACCEPTED: merchant accepted liability; WON: merchant successfully defended; LOST: chargeback upheld; ARBITRATION: escalated to scheme arbitration; CLOSED: final resolution reached. [ENUM-REF-CANDIDATE: RECEIVED|UNDER_REVIEW|AWAITING_RESPONSE|REPRESENTED|ACCEPTED|WON|LOST|ARBITRATION|CLOSED — promote to reference product]' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the chargeback record was first created in the Dispute and Chargeback Management System (Silver Layer). Represents the system ingestion time, distinct from the filing_timestamp which is the business event time when the issuer filed the chargeback with the card scheme.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the currency in which the chargeback amount is denominated. May differ from the original transaction currency in cross-border disputes where Dynamic Currency Conversion (DCC) was applied.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleStage rdf:type rdf:Property ;
    rdfs:label 'Cycle Stage' ;
    rdfs:comment 'Current stage in the chargeback lifecycle cycle as defined by card scheme rules. FIRST_CHARGEBACK is the initial filing by the issuer; SECOND_CHARGEBACK (also called pre-arbitration chargeback under Mastercard rules) occurs after a failed representment; PRE_ARBITRATION is the Visa pre-arbitration stage; ARBITRATION is the final scheme-level adjudication; COMPLIANCE is a scheme compliance filing.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineMet rdf:type rdf:Property ;
    rdfs:label 'Deadline Met' ;
    rdfs:comment 'Indicates whether the chargeback response was submitted on or before the scheme-mandated response deadline. True if response_timestamp is on or before response_deadline; False if the deadline was missed, resulting in automatic acceptance of the chargeback liability.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidencePackageRef rdf:type rdf:Property ;
    rdfs:label 'Evidence Package Ref' ;
    rdfs:comment 'Reference identifier for the evidence package (representment documentation) submitted by the merchant to contest the chargeback. Points to the document management system location containing delivery confirmations, signed receipts, authorization records, and other supporting evidence.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Filing Timestamp' ;
    rdfs:comment 'The principal business event timestamp recording when the chargeback was formally filed by the issuing bank with the card scheme. This is the scheme-recognized filing date used to calculate all response deadlines and compliance windows per card scheme rules.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fraudIndicator rdf:type rdf:Property ;
    rdfs:label 'Fraud Indicator' ;
    rdfs:comment 'Indicates whether this chargeback is classified as fraud-related based on the reason code category (True) or non-fraud (False). Fraud chargebacks (e.g., Visa reason code 10.x, Mastercard reason code 4837/4863) are tracked separately for fraud reporting, chargeback ratio monitoring, and Fraud Detection and Prevention Platform feedback loops.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartialChargeback rdf:type rdf:Property ;
    rdfs:label 'Is Partial Chargeback' ;
    rdfs:comment 'Indicates whether this chargeback is for a partial amount of the original transaction (True) or for the full transaction amount (False). Partial chargebacks occur when only a portion of the goods or services are disputed.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liabilityParty rdf:type rdf:Property ;
    rdfs:label 'Liability Party' ;
    rdfs:comment 'The party determined to bear financial liability for the chargeback upon final resolution. MERCHANT: merchant absorbs the loss; ISSUER: issuing bank absorbs the loss; ACQUIRER: acquiring bank absorbs the loss; SCHEME: card scheme absorbs the loss (rare, typically in compliance cases).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Amount' ;
    rdfs:comment 'The full amount of the original payment transaction that is the subject of this chargeback, in the original transaction currency. Used to identify partial chargebacks where chargeback_amount is less than the full transaction amount.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the currency in which the original payment transaction was denominated. Enables currency reconciliation in cross-border dispute scenarios involving Foreign Exchange (FX) or Dynamic Currency Conversion (DCC).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratioFlag rdf:type rdf:Property ;
    rdfs:label 'Ratio Flag' ;
    rdfs:comment 'Indicates whether this chargeback has been flagged as contributing to the merchant\'s chargeback ratio threshold breach under card scheme monitoring programs (e.g., Visa Chargeback Monitoring Program - VCMP, Mastercard Excessive Chargeback Program - ECP). Merchants exceeding scheme thresholds face fines and potential termination.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:representmentDeadline rdf:type rdf:Property ;
    rdfs:label 'Representment Deadline' ;
    rdfs:comment 'Scheme-mandated deadline by which the merchant must submit a representment (rebuttal) package to challenge the chargeback. Distinct from response_deadline in that it specifically governs the representment submission window after the merchant elects to contest the chargeback.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:representmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Representment Timestamp' ;
    rdfs:comment 'Actual timestamp when the merchant submitted the representment package to contest the chargeback. A representment is the merchant\'s formal response disputing the chargeback, including evidence such as delivery confirmation, signed receipts, or fraud documentation.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final resolution outcome of the chargeback after all dispute cycles are exhausted. MERCHANT_WON: representment was successful and chargeback reversed; ISSUER_WON: chargeback upheld and merchant debited; SPLIT_LIABILITY: liability shared between parties; WITHDRAWN: cardholder or issuer withdrew the dispute; EXPIRED: chargeback expired due to inaction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Timestamp when the chargeback reached its final resolution and the case was closed. Marks the end of the chargeback lifecycle. Used for SLA compliance measurement and financial reconciliation timing.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseDeadline rdf:type rdf:Property ;
    rdfs:label 'Response Deadline' ;
    rdfs:comment 'Scheme-mandated deadline by which the acquiring bank or merchant must submit a representment or accept the chargeback. Calculated from the filing timestamp per card scheme rules (e.g., Visa typically allows 30 calendar days; Mastercard 45 calendar days). Missing this deadline results in automatic chargeback acceptance.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'Actual timestamp when the merchant or acquiring bank submitted their response (representment package or acceptance) to the chargeback. Compared against response_deadline to determine deadline compliance status.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:schemeCaseReference rdf:type rdf:Property ;
    rdfs:label 'Scheme Case Reference' ;
    rdfs:comment 'Card scheme-assigned case identifier for the chargeback as provided by Visa, Mastercard, Amex, or Discover through their dispute resolution portals (e.g., Visa Resolve Online - VROL, Mastercard MATCH). Used for scheme-level tracking and arbitration submissions.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Scheme Fee Amount' ;
    rdfs:comment 'Fee charged by the card scheme (Visa, Mastercard, Amex, Discover) for processing the chargeback. Scheme fees are assessed per chargeback filing and may vary by scheme, reason code, and merchant chargeback ratio tier. Debited from the acquiring bank and typically passed through to the merchant.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaBreach rdf:type rdf:Property ;
    rdfs:label 'Sla Breach' ;
    rdfs:comment 'Indicates whether the internal SLA for chargeback processing was breached (True) for this case. Internal SLAs govern the time from chargeback receipt to merchant notification, evidence collection, and representment submission, distinct from the scheme-mandated response deadlines.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Name of the operational system of record from which this chargeback record was sourced (e.g., Dispute and Chargeback Management System). Supports data lineage tracking and reconciliation across the lakehouse architecture.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The date on which the original payment transaction that is the subject of this chargeback was processed. Used to verify chargeback filing timeliness against scheme-mandated windows (e.g., Visa allows chargebacks up to 120 days from transaction date in most cases).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the chargeback record in the system. Tracks the last modification across any field in the chargeback lifecycle, supporting audit trail requirements and change detection for downstream data consumers.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retrievalRequestId rdf:type rdf:Property ;
    rdfs:label 'Retrieval Request Id' ;
    rdfs:comment 'Unique surrogate identifier for the retrieval request record in the Dispute and Chargeback Management System. Primary key for this entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetrievalRequest .

ind:acquirerCode rdf:type rdf:Property ;
    rdfs:label 'Acquirer Code' ;
    rdfs:comment 'Identifier of the acquiring bank responsible for fulfilling the retrieval request by providing the requested transaction documentation to the issuing bank.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingAmount rdf:type rdf:Property ;
    rdfs:label 'Billing Amount' ;
    rdfs:comment 'Amount billed to the cardholder in their billing currency, which may differ from the transaction amount when Dynamic Currency Conversion (DCC) or foreign exchange conversion was applied. Used in cross-border dispute resolution.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCurrency rdf:type rdf:Property ;
    rdfs:label 'Billing Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the cardholder\'s billing currency. Relevant when DCC was applied and the billing currency differs from the transaction currency.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bin rdf:type rdf:Property ;
    rdfs:label 'Bin' ;
    rdfs:comment 'Bank Identification Number (BIN), also known as Issuer Identification Number (IIN), representing the first 6-8 digits of the PAN. Identifies the issuing bank and card product type. Used for scheme routing and issuer identification in the retrieval request workflow.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderDisputeCategory rdf:type rdf:Property ;
    rdfs:label 'Cardholder Dispute Category' ;
    rdfs:comment 'High-level category of the cardholder\'s dispute underlying the retrieval request. Aligns with card scheme dispute category frameworks (Visa Dispute Resolution; Mastercard Dispute Resolution Management). Used for dispute analytics and trend reporting.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysToFulfill rdf:type rdf:Property ;
    rdfs:label 'Days To Fulfill' ;
    rdfs:comment 'Number of calendar days elapsed between the request_date and the fulfillment_date. Populated upon fulfillment. Used for SLA performance analytics and scheme compliance benchmarking.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Document Delivery Method' ;
    rdfs:comment 'Method used to deliver the requested transaction documentation (sales draft, receipt, authorization record) to the issuing bank. Electronic delivery via scheme portal is the preferred method per PCI DSS and scheme rules.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTypesRequested rdf:type rdf:Property ;
    rdfs:label 'Document Types Requested' ;
    rdfs:comment 'Comma-separated list or description of the specific document types requested by the issuing bank (e.g., sales draft, transaction receipt, authorization record, imprinted voucher, signed cardholder receipt). Drives the fulfillment workflow and evidence package assembly.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentsProvided rdf:type rdf:Property ;
    rdfs:label 'Documents Provided' ;
    rdfs:comment 'Boolean flag indicating whether all requested transaction documentation has been provided to the issuing bank. True when the fulfillment package is complete and delivered; False when pending or partially fulfilled.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedToChargeback rdf:type rdf:Property ;
    rdfs:label 'Escalated To Chargeback' ;
    rdfs:comment 'Boolean flag indicating whether this retrieval request was escalated to a formal chargeback due to non-fulfillment within the scheme-mandated deadline. True indicates a chargeback has been filed; False indicates the request was resolved without chargeback escalation.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date on which the retrieval request was escalated to a formal chargeback. Populated only when escalated_to_chargeback is True. Used for SLA tracking and scheme compliance reporting.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fraudSuspected rdf:type rdf:Property ;
    rdfs:label 'Fraud Suspected' ;
    rdfs:comment 'Boolean flag indicating whether the retrieval request is associated with a suspected fraudulent transaction, as flagged by the issuing bank or the fraud detection platform. When True, the case may be escalated to the Fraud Detection and Prevention Platform for additional investigation.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Date' ;
    rdfs:comment 'Actual date on which the acquiring bank fulfilled the retrieval request by delivering the requested documentation to the issuing bank. Null if not yet fulfilled. Used to calculate response time and SLA compliance.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentDeadline rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Deadline' ;
    rdfs:comment 'Scheme-mandated deadline by which the acquiring bank must fulfill the retrieval request by delivering the requested documentation. Failure to meet this deadline typically results in automatic escalation to a chargeback. Calculated from request_date per applicable card scheme rules (Visa: typically 30 days; Mastercard: varies by reason code).' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current fulfillment status of the retrieval request indicating whether the acquiring bank has delivered the required documentation within the scheme deadline. Maps to LIFECYCLE_STATUS category for TRANSACTION_HEADER role. \'escalated_to_chargeback\' indicates the request was not fulfilled and a formal chargeback has been filed.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuerCode rdf:type rdf:Property ;
    rdfs:label 'Issuer Code' ;
    rdfs:comment 'Identifier of the issuing bank (cardholder\'s bank) that originated the retrieval request. The issuing bank initiates the pre-chargeback inquiry to obtain transaction documentation. Maps to PARTY_REFERENCE category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mcc rdf:type rdf:Property ;
    rdfs:label 'Mcc' ;
    rdfs:comment 'ISO 18245 four-digit Merchant Category Code classifying the type of business conducted by the merchant at the time of the original transaction. Used in dispute analysis and scheme reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantCountry rdf:type rdf:Property ;
    rdfs:label 'Merchant Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the merchant\'s country of operation where the original transaction occurred. Used for cross-border dispute routing and applicable scheme rule determination.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantName rdf:type rdf:Property ;
    rdfs:label 'Merchant Name' ;
    rdfs:comment 'Doing-business-as name of the merchant as it appears on the cardholder\'s statement for the original transaction. Used to identify the merchant in the retrieval request workflow and for cardholder communication.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mid rdf:type rdf:Property ;
    rdfs:label 'Mid' ;
    rdfs:comment 'Merchant Identification Number of the merchant whose transaction is subject to the retrieval request. Assigned by the acquiring bank during merchant onboarding. Used to route fulfillment obligations to the correct merchant.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panLastFour rdf:type rdf:Property ;
    rdfs:label 'Pan Last Four' ;
    rdfs:comment 'Last four digits of the cardholder\'s Primary Account Number (PAN) associated with the original transaction. Stored in truncated form per PCI DSS requirements to enable transaction identification without exposing full card data.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posEntryMode rdf:type rdf:Property ;
    rdfs:label 'Pos Entry Mode' ;
    rdfs:comment 'Method by which the cardholder\'s payment credentials were captured at the point of sale for the original transaction (e.g., EMV chip, magnetic stripe swipe, NFC contactless, manual key entry, e-commerce). Relevant to determining liability and document requirements in the retrieval request.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Card scheme reason code classifying the basis for the retrieval request (e.g., cardholder does not recognize transaction, potential fraud, copy request). Reason codes are scheme-specific (Visa and Mastercard maintain separate code sets). Drives document requirements and fulfillment obligations. [ENUM-REF-CANDIDATE: promote to reference product as codes vary extensively by scheme]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Human-readable description of the reason for the retrieval request corresponding to the reason_code. Provides context for operations teams handling the fulfillment workflow.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Boolean flag indicating whether this retrieval request is subject to regulatory reporting obligations (e.g., CFPB complaint reporting, FinCEN SAR-related inquiry, GDPR data subject request). Triggers inclusion in compliance reporting workflows.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Calendar date on which the retrieval request was formally issued by the issuing bank. This is the principal business event date that starts the fulfillment deadline clock per card scheme rules. Maps to BUSINESS_EVENT_TIMESTAMP category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseNotes rdf:type rdf:Property ;
    rdfs:label 'Response Notes' ;
    rdfs:comment 'Free-text notes entered by the acquiring bank or merchant operations team describing the fulfillment response, any issues encountered in locating documentation, or reasons for non-fulfillment. Supports case management and audit trail.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retrievalRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Retrieval Request Number' ;
    rdfs:comment 'Externally-known business identifier for the retrieval request, typically assigned by the card scheme or issuing bank. Used for cross-system tracking and scheme correspondence (e.g., Visa or Mastercard retrieval reference number). Maps to BUSINESS_IDENTIFIER category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Scheme Case Number' ;
    rdfs:comment 'Case or reference number assigned by the card scheme (Visa or Mastercard) to track this retrieval request within their dispute management systems. Used for scheme correspondence and audit trail.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tid rdf:type rdf:Property ;
    rdfs:label 'Tid' ;
    rdfs:comment 'Terminal Identification Number identifying the specific POS or mPOS terminal at which the original transaction was processed. Supports evidence collection and sales draft retrieval from the correct terminal.' ;
    rdfs:domain ind:RetrievalRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representmentId rdf:type rdf:Property ;
    rdfs:label 'Representment Id' ;
    rdfs:comment 'Unique surrogate identifier for the representment record in the Dispute and Chargeback Management System. Primary key for the representment data product. Entity role: TRANSACTION_HEADER — a discrete business event (merchant/acquirer rebuttal package) with its own lifecycle.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Representment .

ind:financialAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Financial Adjustment Id' ;
    rdfs:comment 'Reference to the financial adjustment record in the ERP (Oracle Financials) or settlement system generated upon acceptance of the representment. Links the dispute outcome to the corresponding GL/AR credit entry.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialAdjustment .

ind:representmentDisputeCaseId rdf:type rdf:Property ;
    rdfs:label 'Representment Dispute Case Id' ;
    rdfs:comment 'Reference to the overarching dispute case that encompasses the chargeback and representment. Provides traceability to the full dispute lifecycle record in the Dispute and Chargeback Management System.' ;
    rdfs:domain ind:Representment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DisputeCase .

ind:representmentDisputeDisputeCaseId rdf:type rdf:Property ;
    rdfs:label 'Representment Dispute Dispute Case Id' ;
    rdfs:comment 'Reference to the overarching dispute case that encompasses the chargeback and representment. Provides traceability to the full dispute lifecycle record in the Dispute and Chargeback Management System.' ;
    rdfs:domain ind:Representment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DisputeCase .

ind:assignedAnalyst rdf:type rdf:Property ;
    rdfs:label 'Assigned Analyst' ;
    rdfs:comment 'Name or identifier of the dispute analyst or team responsible for preparing and managing this representment case. Supports workload management and accountability tracking within the Dispute and Chargeback Management System.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackAmount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Amount' ;
    rdfs:comment 'The original chargeback amount as filed by the issuing bank. Retained on the representment record for direct comparison against the representment amount to identify partial representments.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackReasonCode rdf:type rdf:Property ;
    rdfs:label 'Chargeback Reason Code' ;
    rdfs:comment 'The original card scheme reason code assigned to the chargeback being rebutted. Retained on the representment for direct reference to understand the basis of the dispute and validate the representment strategy.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysToDeadline rdf:type rdf:Property ;
    rdfs:label 'Days To Deadline' ;
    rdfs:comment 'Number of calendar days between the representment creation date and the scheme-mandated response deadline. Positive values indicate days remaining; negative values indicate overdue status. Supports operational prioritization and SLA alerting.' ;
    rdfs:domain ind:Representment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deadlineCompliant rdf:type rdf:Property ;
    rdfs:label 'Deadline Compliant' ;
    rdfs:comment 'Indicates whether the representment was submitted on or before the scheme-mandated response deadline. True if submission_date is on or before response_deadline; False if submitted late. Late submissions are typically rejected by card schemes.' ;
    rdfs:domain ind:Representment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeCategory rdf:type rdf:Property ;
    rdfs:label 'Dispute Category' ;
    rdfs:comment 'High-level category classifying the nature of the underlying dispute being rebutted. Derived from the chargeback reason code family per card scheme classification. Supports portfolio-level dispute analytics and fraud trend reporting.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidencePackageReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Package Reference' ;
    rdfs:comment 'Reference identifier for the evidence package submitted with the representment (e.g., document store ID, S3 path, or case management reference). Links to the collection of supporting documents such as transaction receipts, delivery confirmations, and cardholder communications.' ;
    rdfs:domain ind:Representment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBankBin rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank Bin' ;
    rdfs:comment 'Bank Identification Number (BIN) / Issuer Identification Number (IIN) of the issuing bank that filed the original chargeback. Used for scheme routing, issuer analysis, and dispute pattern monitoring.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current state of the representment in its workflow lifecycle. Tracks progression from initial draft through submission, scheme decision, and potential escalation to pre-arbitration or arbitration. [ENUM-REF-CANDIDATE: draft|submitted|accepted|rejected|pre_arbitration|arbitration|closed — promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text operational notes added by dispute analysts during the representment lifecycle. Captures escalation rationale, issuer communications, scheme correspondence, and internal case management commentary.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeDate rdf:type rdf:Property ;
    rdfs:label 'Outcome Date' ;
    rdfs:comment 'The date on which the card scheme or issuing bank rendered the outcome decision on the representment. Used for cycle time analysis and financial adjustment timing.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcomeDecision rdf:type rdf:Property ;
    rdfs:label 'Outcome Decision' ;
    rdfs:comment 'The final or current decision rendered by the card scheme or issuing bank on the representment. Accepted means the chargeback is reversed in the merchant\'s favor; rejected means the chargeback stands; pre_arbitration and arbitration indicate escalation paths.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preArbitrationDeadline rdf:type rdf:Property ;
    rdfs:label 'Pre Arbitration Deadline' ;
    rdfs:comment 'The scheme-mandated deadline by which the acquirer must file for pre-arbitration if the representment is rejected and escalation is desired. Null if pre-arbitration is not applicable or not yet triggered.' ;
    rdfs:domain ind:Representment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preArbitrationEligible rdf:type rdf:Property ;
    rdfs:label 'Pre Arbitration Eligible' ;
    rdfs:comment 'Indicates whether this representment is eligible for escalation to the pre-arbitration stage if the outcome decision is rejected. Eligibility is determined by card scheme rules based on reason code, dispute amount, and prior cycle history.' ;
    rdfs:domain ind:Representment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preArbitrationFiled rdf:type rdf:Property ;
    rdfs:label 'Pre Arbitration Filed' ;
    rdfs:comment 'Indicates whether a pre-arbitration case has been formally filed following rejection of this representment. True if pre-arbitration has been initiated; False otherwise.' ;
    rdfs:domain ind:Representment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rebuttalNarrative rdf:type rdf:Property ;
    rdfs:label 'Rebuttal Narrative' ;
    rdfs:comment 'Free-text narrative written by the merchant or acquirer explaining the basis for the representment rebuttal. Describes why the chargeback is invalid, referencing supporting evidence. Key input for scheme adjudication.' ;
    rdfs:domain ind:Representment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Amount' ;
    rdfs:comment 'The actual monetary amount recovered by the merchant/acquirer following a successful representment outcome. May differ from representment_amount in cases of partial acceptance by the issuer.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Externally-known business identifier for the representment package, typically assigned by the acquiring bank or payment scheme upon submission. Used for cross-system tracking and scheme correspondence.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representmentType rdf:type rdf:Property ;
    rdfs:label 'Representment Type' ;
    rdfs:comment 'Classifies the representment by its position in the dispute cycle. First chargeback representment is the initial rebuttal; second chargeback representment follows a re-presentment rejection; pre-arbitration and arbitration are escalation stages.' ;
    rdfs:domain ind:Representment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'The channel through which the representment package was submitted to the card scheme or issuing bank (e.g., scheme portal, API integration, fax, mail, EDI). Supports operational analysis of submission method efficiency.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'The calendar date on which the representment package was actually submitted. Used in conjunction with response_deadline to calculate deadline compliance status.' ;
    rdfs:domain ind:Representment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'The exact date and time the representment package was formally submitted to the card scheme or issuing bank. This is the principal business event timestamp for the representment transaction. Critical for deadline compliance tracking.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:arbitrationCaseId rdf:type rdf:Property ;
    rdfs:label 'Arbitration Case Id' ;
    rdfs:comment 'Unique surrogate identifier for the arbitration case record in the Dispute and Chargeback Management System. Primary key for this entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArbitrationCase .

ind:arbitrationDecision rdf:type rdf:Property ;
    rdfs:label 'Arbitration Decision' ;
    rdfs:comment 'Formal outcome of the card scheme arbitration proceeding. Indicates whether the filing party\'s position was upheld, the respondent prevailed, liability was split, or the case was withdrawn before decision.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle status of the arbitration case. Tracks progression from initial filing through scheme review, decision issuance, and final closure or withdrawal. LIFECYCLE_STATUS for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date on which the arbitration case was formally closed in the Dispute and Chargeback Management System, following decision implementation, financial settlement, or withdrawal. Marks end of the arbitration lifecycle.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceCaseFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Case Flag' ;
    rdfs:comment 'Indicates whether this arbitration case has been designated as a compliance case (as opposed to a standard chargeback arbitration). Compliance cases arise from violations of card scheme rules rather than transaction disputes and follow a distinct scheme process.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceViolationType rdf:type rdf:Property ;
    rdfs:label 'Compliance Violation Type' ;
    rdfs:comment 'Type of card scheme rule violation cited in a compliance arbitration case (e.g., late presentment, invalid authorization, data integrity violation). Populated only when compliance_case_flag is true. [ENUM-REF-CANDIDATE: late_presentment|invalid_authorization|data_integrity|security_violation|processing_error|other — promote to reference product]' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Date on which the card scheme issued its formal arbitration decision. Used to track scheme turnaround time and trigger post-decision financial adjustment processing.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionRationale rdf:type rdf:Property ;
    rdfs:label 'Decision Rationale' ;
    rdfs:comment 'Narrative explanation or scheme-provided rationale for the arbitration decision outcome. Documents the basis for liability assignment and supports internal review, representment analysis, and regulatory audit trail.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeAmount rdf:type rdf:Property ;
    rdfs:label 'Dispute Amount' ;
    rdfs:comment 'Gross monetary amount of the original disputed transaction that is the subject of the arbitration. Expressed in the transaction currency. Part of MONETARY_TRIPLET for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the dispute transaction amount (e.g., USD, EUR, GBP). Required for cross-border dispute processing and FX conversion calculations. Part of MONETARY_TRIPLET.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationCycleCount rdf:type rdf:Property ;
    rdfs:label 'Escalation Cycle Count' ;
    rdfs:comment 'Number of dispute lifecycle cycles (chargeback, representment, pre-arbitration) completed before escalation to formal arbitration. Provides context on the dispute history depth and scheme compliance with mandatory pre-arbitration steps.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidencePackageSubmitted rdf:type rdf:Property ;
    rdfs:label 'Evidence Package Submitted' ;
    rdfs:comment 'Indicates whether the responding party has submitted a complete evidence package (representment documentation, transaction records, cardholder communications) in response to the arbitration filing.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Evidence Submission Date' ;
    rdfs:comment 'Date on which the evidence package was submitted to the card scheme for the arbitration proceeding. Used to verify compliance with scheme-mandated evidence submission deadlines.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Calendar date on which the arbitration case was formally filed with the card scheme. BUSINESS_EVENT_TIMESTAMP (date precision) for the arbitration lifecycle. Used to calculate scheme-mandated response deadlines and compliance with filing windows.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingParty rdf:type rdf:Property ;
    rdfs:label 'Filing Party' ;
    rdfs:comment 'Identifies which party in the payment chain initiated the arbitration filing with the card scheme. Either the issuing bank (cardholder\'s bank) or the acquiring bank (merchant\'s bank). Determines the direction of liability argument.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAdjustmentDate rdf:type rdf:Property ;
    rdfs:label 'Gl Adjustment Date' ;
    rdfs:comment 'Date on which the financial liability adjustment was posted to the General Ledger following the arbitration decision. Used for period-end financial reconciliation and revenue recognition in Oracle Financials.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glAdjustmentPosted rdf:type rdf:Property ;
    rdfs:label 'Gl Adjustment Posted' ;
    rdfs:comment 'Indicates whether the financial liability adjustment resulting from the arbitration decision has been posted to the General Ledger in Oracle Financials. Supports financial close reconciliation and SOX compliance.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hearingDate rdf:type rdf:Property ;
    rdfs:label 'Hearing Date' ;
    rdfs:comment 'Scheduled or actual date of the formal arbitration hearing or review session conducted by the card scheme. May be null if the scheme resolves the case on documentary evidence without a formal hearing.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalCaseNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Case Notes' ;
    rdfs:comment 'Free-text field for internal operational notes, analyst observations, and case management commentary related to the arbitration proceeding. Not shared with the card scheme; used for internal dispute team coordination.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuerBin rdf:type rdf:Property ;
    rdfs:label 'Issuer Bin' ;
    rdfs:comment 'Bank Identification Number (BIN) / Issuer Identification Number (IIN) of the issuing bank involved in the arbitration. Used to identify the card-issuing institution and route scheme communications. 6-8 digit prefix per ISO 7812.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Amount' ;
    rdfs:comment 'Net monetary amount of financial liability assigned to the losing party following the arbitration decision. Represents the final financial obligation resulting from the arbitration outcome. Part of MONETARY_TRIPLET — net total component.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Liability Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the financial liability assignment amount. Ensures accurate multi-currency financial reporting and GL posting.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liableParty rdf:type rdf:Property ;
    rdfs:label 'Liable Party' ;
    rdfs:comment 'Party assigned financial liability by the card scheme arbitration decision. Determines which entity bears the financial loss from the disputed transaction and scheme fees.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Date' ;
    rdfs:comment 'Date of the original payment transaction that is the subject of the arbitration dispute. Used for aging analysis, scheme filing window compliance verification, and statute of limitations assessment.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preArbitrationCycleCompleted rdf:type rdf:Property ;
    rdfs:label 'Pre Arbitration Cycle Completed' ;
    rdfs:comment 'Indicates whether the mandatory pre-arbitration cycle (second chargeback and pre-arbitration exchange) was completed before escalation to formal arbitration. Required by card scheme rules before arbitration filing is accepted.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:schemeArbitrationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Scheme Arbitration Fee Amount' ;
    rdfs:comment 'Fee charged by the card scheme for processing the arbitration case. Typically assessed against the losing party per scheme rules. Part of MONETARY_TRIPLET — adjustment/fee component. Amount in scheme fee currency.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:schemeFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Scheme Fee Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the scheme arbitration fee amount. May differ from the dispute transaction currency for cross-border cases.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHolderId rdf:type rdf:Property ;
    rdfs:label 'Account Holder Id' ;
    rdfs:comment 'Internal surrogate identifier of the cardholder who initiated or is associated with the dispute. Links to the Cardholder domain for identity, contact, and account details.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountHolder .

ind:amlScreeningResultId rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Result Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_aml_screening_result. Business justification: AML screening is performed on entities involved in a dispute; attaching the screening result to the case supports compliance decision-making.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AmlScreeningResult .

ind:cardholderProfileId rdf:type rdf:Property ;
    rdfs:label 'Cardholder Profile Id' ;
    rdfs:comment 'Internal surrogate identifier of the cardholder who initiated or is associated with the dispute. Links to the Cardholder domain for identity, contact, and account details.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CardholderProfile .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to ledger.gl_account. Business justification: Case settlement accounting: dispute case settlements affect GL accounts; linking enables accurate ledger posting and reconciliation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:productFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Product Fee Schedule Id' ;
    rdfs:comment 'Foreign key linking to product.product_fee_schedule. Business justification: Dispute cases frequently challenge specific fees assessed under a fee schedule. Linking enables fee validation, adjustment calculation, and regulatory reporting of fee-related disputes—core dispute re' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductFeeSchedule .

ind:arbitrationFilingDate rdf:type rdf:Property ;
    rdfs:label 'Arbitration Filing Date' ;
    rdfs:comment 'Date on which the dispute was escalated to card scheme arbitration after pre-arbitration failed to reach resolution. Null if the case did not reach arbitration. Arbitration decisions are binding and final per card scheme rules.' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargebackFilingDate rdf:type rdf:Property ;
    rdfs:label 'Chargeback Filing Date' ;
    rdfs:comment 'Date on which the formal chargeback was filed with the card scheme by the issuing bank. Marks the start of the chargeback lifecycle stage and triggers merchant response deadlines. Null if the case has not yet reached chargeback stage.' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Timestamp' ;
    rdfs:comment 'Date and time when the dispute case was formally closed and all activities concluded. Null if the case is still open. Used to calculate total case duration and measure resolution cycle time against SLA targets.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disputeChannel rdf:type rdf:Property ;
    rdfs:label 'Dispute Channel' ;
    rdfs:comment 'Channel through which the cardholder or issuing bank initiated the dispute. Values: online (web portal), phone (call center), branch (in-person), mobile_app (mobile banking app), scheme_portal (direct card scheme submission). Used for channel analytics and process optimization.' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'High-level classification of the dispute category as defined by card scheme rules. Values: fraud (unauthorized transaction), authorization (authorization-related issue), processing_error (duplicate, incorrect amount, etc.), consumer_dispute (goods/services not received or not as described), compliance (regulatory or scheme compliance violation).' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Evidence Submitted Flag' ;
    rdfs:comment 'Indicates whether the merchant has submitted an evidence package (e.g., transaction receipts, delivery confirmation, signed authorization) in response to the chargeback. True = evidence package received. Used to track representment completeness and SLA compliance.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interchangeFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Interchange Fee Amount' ;
    rdfs:comment 'Interchange Reimbursement Fee amount associated with the disputed transaction, which may be reversed or adjusted as part of the chargeback process. Relevant for financial reconciliation between the acquiring bank and issuing bank.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:is3dsAuthenticated rdf:type rdf:Property ;
    rdfs:label 'Is 3ds Authenticated' ;
    rdfs:comment 'Indicates whether the original transaction was authenticated using 3-D Secure (3DS) protocol at the time of authorization. True = 3DS authentication was performed. Relevant for liability shift determination — 3DS-authenticated transactions shift chargeback liability to the issuer.' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFraudConfirmed rdf:type rdf:Property ;
    rdfs:label 'Is Fraud Confirmed' ;
    rdfs:comment 'Indicates whether the dispute has been confirmed as a fraudulent transaction by the fraud investigation team or card scheme ruling. True = confirmed fraud; False = not confirmed as fraud. Used for fraud analytics, SAR filing decisions, and AML reporting.' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this dispute case record in the data platform. Used for incremental ETL processing, change detection, and audit trail compliance.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current stage in the dispute lifecycle workflow as governed by card scheme rules. Progresses from retrieval_request through chargeback, representment, pre_arbitration, arbitration, to closed. Drives SLA deadlines and permissible actions at each stage.' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openTimestamp rdf:type rdf:Property ;
    rdfs:label 'Open Timestamp' ;
    rdfs:comment 'Date and time when the dispute case was formally opened in the Dispute and Chargeback Management System. Serves as the principal business event timestamp and the anchor for all SLA deadline calculations per card scheme rules.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalTransactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the original payment transaction. May differ from dispute_currency_code in Dynamic Currency Conversion (DCC) scenarios or cross-border transactions.' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Operational priority assigned to the dispute case for analyst workqueue management. Critical cases (e.g., large-value disputes, regulatory escalations, VIP cardholders) receive expedited handling. Drives SLA tier assignment and escalation workflows.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representmentDate rdf:type rdf:Property ;
    rdfs:label 'Representment Date' ;
    rdfs:comment 'Date on which the merchant submitted a representment (rebuttal) package challenging the chargeback. Null if no representment has been filed. Used to track merchant response timeliness and advance the lifecycle stage.' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Deadline by which the merchant or acquiring bank must submit a representment response or evidence package for the current lifecycle stage. Calculated per card scheme rules (e.g., Visa allows 30 days for representment). Breach of this date results in automatic case loss.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sarFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Sar Filed Flag' ;
    rdfs:comment 'Indicates whether a Suspicious Activity Report (SAR) was filed with FinCEN in connection with this dispute case due to suspected money laundering, fraud patterns, or other financial crimes identified during the dispute investigation.' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Adjustment Amount' ;
    rdfs:comment 'Net financial adjustment amount applied to the settlement account as a result of the dispute resolution. May differ from dispute_amount due to partial recoveries, fees, or write-offs. Negative value indicates a debit to the merchant; positive indicates a credit to the cardholder.' ;
    rdfs:domain ind:DisputeCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidencePackageId rdf:type rdf:Property ;
    rdfs:label 'Evidence Package Id' ;
    rdfs:comment 'Unique surrogate identifier for the evidence package record in the dispute and chargeback management system. Primary key for this entity.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EvidencePackage .

ind:preArbitrationId rdf:type rdf:Property ;
    rdfs:label 'Pre Arbitration Id' ;
    rdfs:comment 'Foreign key linking to dispute.pre_arbitration. Business justification: An evidence_package can be assembled to support a pre-arbitration filing. The package_type field on evidence_package confirms it can serve different dispute stages. Linking evidence_package to pre_arb' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PreArbitration .

ind:acquirerReference rdf:type rdf:Property ;
    rdfs:label 'Acquirer Reference' ;
    rdfs:comment 'The acquiring bank\'s internal reference or case number for this dispute, used for cross-referencing with the acquiring bank\'s dispute management records and reconciliation.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assembly Timestamp' ;
    rdfs:comment 'Date and time when the evidence package was fully assembled and marked ready for submission. Represents the principal business event time for this entity — the moment the package became a complete evidentiary artifact.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disputedTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Transaction Amount' ;
    rdfs:comment 'The monetary amount of the original transaction being disputed, in the transaction currency. Used to assess financial exposure and validate that the evidence package addresses the correct transaction value.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputedTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Disputed Transaction Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the disputed transaction amount (e.g., USD, EUR, GBP). Required for cross-border dispute processing and FX-related chargeback reason codes.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCount rdf:type rdf:Property ;
    rdfs:label 'Document Count' ;
    rdfs:comment 'Total number of individual evidence documents included in this package. Used for completeness validation and scheme submission compliance checks.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidenceTypesIncluded rdf:type rdf:Property ;
    rdfs:label 'Evidence Types Included' ;
    rdfs:comment 'Pipe-delimited list of evidence type codes included in this package (e.g., \'AUTH_RECORD|DELIVERY_CONF|3DS_PROOF\'). Provides a consolidated summary of all evidence categories present without requiring a join to the document-level detail table.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:has3dsAuthenticationProof rdf:type rdf:Property ;
    rdfs:label 'Has 3ds Authentication Proof' ;
    rdfs:comment 'Indicates whether the evidence package includes 3-D Secure (3DS) authentication proof (e.g., authentication value, ECI indicator, CAVV) demonstrating the transaction was authenticated under PSD2 Strong Customer Authentication (SCA) requirements.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasAuthorizationRecord rdf:type rdf:Property ;
    rdfs:label 'Has Authorization Record' ;
    rdfs:comment 'Indicates whether the evidence package includes an authorization record (approval code, authorization timestamp, and response code) as evidence that the transaction was properly authorized at the time of the original payment.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasAvsCvvMatch rdf:type rdf:Property ;
    rdfs:label 'Has Avs Cvv Match' ;
    rdfs:comment 'Indicates whether the evidence package includes the Address Verification System (AVS) and/or Card Verification Value (CVV) match result from the original authorization, demonstrating the cardholder\'s identity was verified at point of sale.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasCardholderCommunication rdf:type rdf:Property ;
    rdfs:label 'Has Cardholder Communication' ;
    rdfs:comment 'Indicates whether the evidence package includes documented communication with the cardholder (e.g., email correspondence, chat logs, signed agreements) relevant to the disputed transaction.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasDeliveryConfirmation rdf:type rdf:Property ;
    rdfs:label 'Has Delivery Confirmation' ;
    rdfs:comment 'Indicates whether the evidence package includes a delivery confirmation document (e.g., signed proof of delivery, carrier tracking confirmation) to rebut non-receipt chargebacks.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasShippingRecord rdf:type rdf:Property ;
    rdfs:label 'Has Shipping Record' ;
    rdfs:comment 'Indicates whether the evidence package includes a shipping record (e.g., carrier waybill, tracking number, shipment manifest) as evidence of goods dispatch for merchandise-related disputes.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasSignedReceipt rdf:type rdf:Property ;
    rdfs:label 'Has Signed Receipt' ;
    rdfs:comment 'Indicates whether the evidence package includes a signed transaction receipt (physical or electronic) bearing the cardholder\'s signature or PIN-verified acknowledgment at the point of sale.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAutoAssembled rdf:type rdf:Property ;
    rdfs:label 'Is Auto Assembled' ;
    rdfs:comment 'Indicates whether the evidence package was assembled automatically by the dispute management system\'s Straight-Through Processing (STP) engine, or manually by a dispute analyst. Supports STP rate reporting and automation analytics.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuerReference rdf:type rdf:Property ;
    rdfs:label 'Issuer Reference' ;
    rdfs:comment 'The issuing bank\'s case or reference number for the chargeback, as communicated in the chargeback notification. Used to correlate the evidence package with the issuer\'s dispute record.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeReason rdf:type rdf:Property ;
    rdfs:label 'Outcome Reason' ;
    rdfs:comment 'Textual explanation or scheme-provided reason code description for the dispute outcome decision. Captures why the evidence package was accepted or rejected to support root cause analysis and process improvement.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageNotes rdf:type rdf:Property ;
    rdfs:label 'Package Notes' ;
    rdfs:comment 'Free-text notes entered by the dispute analyst regarding the evidence package, including special circumstances, escalation context, or instructions for the reviewing party. Not transmitted to the card scheme.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageOutcome rdf:type rdf:Property ;
    rdfs:label 'Package Outcome' ;
    rdfs:comment 'Final resolution outcome of the evidence package submission: won (dispute resolved in merchant\'s favor), lost (chargeback upheld), partial_win (partial amount recovered), withdrawn (package retracted), or pending (awaiting decision).' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Package Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to the evidence package, used in scheme submissions and merchant communications. Follows the EVP- prefix convention.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle status of the evidence package: draft (being assembled), assembled (complete but not yet submitted), submitted (sent to card scheme or issuer), accepted (acknowledged by receiving party), rejected (refused by receiving party), or withdrawn (retracted before decision).' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Classification of the evidence package by the dispute stage it supports: representment (first chargeback rebuttal), pre_arbitration (pre-arb response), arbitration (scheme arbitration filing), retrieval_response (response to retrieval request), or good_faith (voluntary compliance submission). [ENUM-REF-CANDIDATE: representment|pre_arbitration|arbitration|retrieval_response|good_faith — promote to reference product]' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveredAmount rdf:type rdf:Property ;
    rdfs:label 'Recovered Amount' ;
    rdfs:comment 'The monetary amount recovered in the merchant\'s favor as a result of the evidence package submission. May be equal to the full disputed amount (full win), a partial amount (partial win), or zero (loss). Denominated in the disputed transaction currency.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Card scheme or issuer-provided code indicating why the evidence package was rejected (e.g., late submission, insufficient evidence, incorrect format). Populated only when package_status is \'rejected\'. Used for defect analysis and process improvement.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Date' ;
    rdfs:comment 'The card scheme-mandated deadline by which the evidence package must be submitted to avoid forfeiture of the dispute. Derived from chargeback receipt date plus scheme-specific response windows (e.g., Visa 30 days, Mastercard 45 days).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:schemeSubmissionConfirmation rdf:type rdf:Property ;
    rdfs:label 'Scheme Submission Confirmation' ;
    rdfs:comment 'Confirmation or acknowledgment number returned by the card scheme portal (e.g., Visa Resolve Online, Mastercard Connect) upon successful receipt of the evidence package submission. Used for reconciliation and proof of timely submission.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDeadlineMet rdf:type rdf:Property ;
    rdfs:label 'Sla Deadline Met' ;
    rdfs:comment 'Indicates whether the evidence package was submitted before the card scheme response deadline. False indicates a missed SLA, which results in automatic forfeiture of the dispute. Critical for operational performance monitoring.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submittedByUser rdf:type rdf:Property ;
    rdfs:label 'Submitted By User' ;
    rdfs:comment 'Username or employee identifier of the individual or automated process that submitted the evidence package to the card scheme or issuer. Supports audit trail requirements under SOX and PCI DSS.' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Total File Size Bytes' ;
    rdfs:comment 'Aggregate file size in bytes of all documents included in the evidence package. Used to validate compliance with card scheme maximum submission size limits (e.g., Visa 5MB per package).' ;
    rdfs:domain ind:EvidencePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingId rdf:type rdf:Property ;
    rdfs:label 'Billing Id' ;
    rdfs:comment 'Foreign key linking to interchange.billing. Business justification: Dispute financial adjustments (chargeback reversals, representment recoveries) must post to specific interchange billing cycles. Acquirer billing reconciliation requires linking each adjustment to the' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Billing .

ind:originalTransactionId rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Id' ;
    rdfs:comment 'Reference to the original payment transaction record that is the subject of the dispute. Enables traceability from the financial adjustment back to the source authorization and capture event.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:rateId rdf:type rdf:Property ;
    rdfs:label 'Rate Id' ;
    rdfs:comment 'Foreign key linking to fx.fx_rate. Business justification: Financial adjustments often involve currency conversion; audit requires the FX rate used for the adjustment.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rate .

ind:reversalReferenceFinancialAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Reversal Reference Financial Adjustment Id' ;
    rdfs:comment 'Reference to the original financial adjustment record that this entry reverses. Populated only when reversal_flag is True, enabling full audit trail of reversal chains.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialAdjustment .

ind:settlementBatchId rdf:type rdf:Property ;
    rdfs:label 'Settlement Batch Id' ;
    rdfs:comment 'Foreign key linking to settlement.settlement_batch. Business justification: Dispute financial adjustments are posted to settlement batches; settlement_batch_reference is a denormalized text field. A proper FK to settlement.settlement_batch enables batch-level dispute impact r' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SettlementBatch .

ind:settlementInstructionId rdf:type rdf:Property ;
    rdfs:label 'Settlement Instruction Id' ;
    rdfs:comment 'Foreign key linking to settlement.instruction. Business justification: Dispute resolution generates settlement instructions to execute financial adjustments (debit/credit postings). Direct FK enables end-to-end tracing from dispute outcome to settlement execution, suppor' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instruction .

ind:adjustmentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the adjustment amount. Identifies the currency in which the financial adjustment is denominated.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Event Timestamp' ;
    rdfs:comment 'Precise date and time when the financial adjustment event was triggered in the Dispute and Chargeback Management System. Represents the real-world business event time, distinct from the GL posting date.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adjustmentNotes rdf:type rdf:Property ;
    rdfs:label 'Adjustment Notes' ;
    rdfs:comment 'Free-text operational notes or comments recorded by dispute analysts regarding the financial adjustment, such as manual override justifications, scheme correspondence references, or exception handling details.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this financial adjustment, used in reconciliation, GL posting, and scheme communications. Assigned by the Dispute and Chargeback Management System or card scheme.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle state of the financial adjustment record within the dispute processing workflow. Drives GL posting eligibility and settlement batch inclusion.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Classification of the financial adjustment event within the dispute lifecycle. Determines the direction of fund flow and the applicable card scheme rules. [ENUM-REF-CANDIDATE: chargeback_debit|representment_credit|arbitration_fee|compliance_assessment|final_settlement|pre_arbitration_debit|pre_compliance_fee|good_faith_collection — promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Posted Flag' ;
    rdfs:comment 'Indicates whether this financial adjustment was automatically posted to the GL via Straight-Through Processing (STP) (True) or required manual intervention before posting (False). Supports operational efficiency reporting and STP rate analytics.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether this financial adjustment represents a debit (funds withdrawn from the merchant or acquirer) or a credit (funds returned). Critical for GL double-entry accounting and settlement reconciliation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Outcome' ;
    rdfs:comment 'Final outcome of the dispute case associated with this financial adjustment. Determines whether the adjustment represents a permanent financial liability or will be reversed upon successful representment or arbitration.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStage rdf:type rdf:Property ;
    rdfs:label 'Dispute Stage' ;
    rdfs:comment 'Stage in the dispute lifecycle at which this financial adjustment was generated. Determines the applicable card scheme rules, financial liability, and response rights for each party.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialPeriod rdf:type rdf:Property ;
    rdfs:label 'Financial Period' ;
    rdfs:comment 'Accounting period (YYYY-MM) to which this financial adjustment is attributed for revenue recognition, period-end close, and regulatory financial reporting. Aligned with Oracle Financials GL calendar.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxConversionRate rdf:type rdf:Property ;
    rdfs:label 'Fx Conversion Rate' ;
    rdfs:comment 'Exchange rate applied when converting the adjustment amount from the transaction currency to the settlement currency. Applicable for cross-border disputes involving Dynamic Currency Conversion (DCC) or multi-currency settlement.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Gl Cost Center Code' ;
    rdfs:comment 'Oracle Financials cost center dimension code associated with this adjustment for internal financial reporting and P&L attribution within the dispute operations function.' ;
    rdfs:domain ind:FinancialAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeAmount rdf:type rdf:Property ;
    rdfs:label 'Interchange Amount' ;
    rdfs:comment 'Interchange Reimbursement Fee (IRF) component of the financial adjustment, representing the fee paid between the acquiring bank and issuing bank as part of the dispute resolution. Relevant for chargeback debits and representment credits.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'Calendar date on which the financial adjustment was posted to the General Ledger (GL) and included in the settlement batch. Drives financial period recognition and regulatory reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this financial adjustment has been reversed (True) or remains active (False). A reversal occurs when a chargeback is rescinded, a representment is accepted, or an error correction is applied.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'Net amount posted to the settlement batch after applying any scheme fees, interchange adjustments, or currency conversion. May differ from adjustment_amount when FX conversion or fee netting applies.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the settlement amount. May differ from adjustment_currency_code when Dynamic Currency Conversion (DCC) or cross-border settlement applies.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifies the operational system of record that originated this financial adjustment record (e.g., Dispute and Chargeback Management System, ERP Oracle Financials, card scheme network feed, or manual entry). Supports data lineage and reconciliation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each immutable event record in the dispute lifecycle event log. Primary key for this append-only audit table. Role: EVENT_LOG.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeId rdf:type rdf:Property ;
    rdfs:label 'Fee Id' ;
    rdfs:comment 'Foreign key linking to dispute.fee. Business justification: Dispute lifecycle events include fee assessment events. The scheme_fee_amount field on dispute_lifecycle_event is denormalized from the fee record. Linking dispute_lifecycle_event to fee normalizes th' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fee .

ind:merchantResponseId rdf:type rdf:Property ;
    rdfs:label 'Merchant Response Id' ;
    rdfs:comment 'Foreign key linking to dispute.merchant_response. Business justification: Dispute lifecycle events include merchant response submission events. Linking dispute_lifecycle_event to merchant_response enables tracing which merchant response triggered a specific state transition' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchantResponse .

ind:acquirerMid rdf:type rdf:Property ;
    rdfs:label 'Acquirer Mid' ;
    rdfs:comment 'The Merchant Identification Number assigned by the acquiring bank to the merchant involved in this dispute event. Used for merchant-level dispute tracking, chargeback ratio monitoring, and acquirer reporting.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actorType rdf:type rdf:Property ;
    rdfs:label 'Actor Type' ;
    rdfs:comment 'Category of the party that triggered or performed this lifecycle event. Identifies whether the action was taken by the issuing bank, acquiring bank, card scheme, merchant, or an internal analyst. Critical for accountability and regulatory audit trails.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arbitrationOutcome rdf:type rdf:Property ;
    rdfs:label 'Arbitration Outcome' ;
    rdfs:comment 'The final decision rendered by the card scheme in arbitration proceedings. Populated only when event_type is arbitration_decided. Determines final financial liability allocation between issuer and acquirer.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The payment channel through which the original disputed transaction was conducted. Influences applicable chargeback reason codes, liability rules, and fraud classification under card scheme rules. [ENUM-REF-CANDIDATE: card_present|card_not_present|atm|contactless|ecommerce|mobile|recurring — promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackCycle rdf:type rdf:Property ;
    rdfs:label 'Chargeback Cycle' ;
    rdfs:comment 'Identifies the current cycle stage of the chargeback process at the time of this event. Distinguishes first chargeback from second chargeback (re-presentment response), pre-arbitration, and formal arbitration stages per card scheme rules.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventNotes rdf:type rdf:Property ;
    rdfs:label 'Event Notes' ;
    rdfs:comment 'Free-text narrative describing the context, rationale, or outcome of this lifecycle event. Captures analyst commentary, scheme decision rationale, or system-generated explanations. EVENT_PAYLOAD_OR_VALUE per EVENT_LOG role.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Sequence Number' ;
    rdfs:comment 'Monotonically increasing sequence number of this event within the parent dispute case, starting at 1 for the first event. Enables ordered reconstruction of the complete dispute lifecycle timeline and detection of out-of-order event ingestion.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone offset) at which this lifecycle event occurred. Authoritative event time used for SLA deadline tracking, regulatory audit trails, and dispute analytics. Conforms to yyyy-MM-ddTHH:mm:ss.SSSXXX format. EVENT_TIMESTAMP per EVENT_LOG role.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Discriminator classifying the kind of lifecycle event that occurred in the dispute workflow. Drives downstream routing, SLA monitoring, and regulatory reporting. EVENT_TYPE_OR_CHANNEL per EVENT_LOG role. [ENUM-REF-CANDIDATE: case_opened|retrieval_sent|chargeback_filed|representment_submitted|pre_arbitration_filed|arbitration_decided|case_closed|deadline_breached — promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeadlineBreached rdf:type rdf:Property ;
    rdfs:label 'Is Deadline Breached' ;
    rdfs:comment 'Indicates whether the response deadline for this lifecycle event stage was breached (True) or met on time (False). Drives automatic escalation workflows, scheme penalty assessments, and SLA reporting.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFraudRelated rdf:type rdf:Property ;
    rdfs:label 'Is Fraud Related' ;
    rdfs:comment 'Indicates whether this dispute event is classified as fraud-related (True) based on the chargeback reason code or fraud detection platform signals. Drives SAR/STR filing obligations, fraud analytics, and scheme fraud reporting thresholds.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newState rdf:type rdf:Property ;
    rdfs:label 'New State' ;
    rdfs:comment 'The dispute case state immediately after this event was applied. Represents the current state of the dispute case as of this event. Used for SLA tracking, workflow routing, and regulatory reporting. [ENUM-REF-CANDIDATE: new|retrieval_pending|chargeback_pending|representment_pending|pre_arbitration_pending|arbitration_pending|resolved|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousState rdf:type rdf:Property ;
    rdfs:label 'Previous State' ;
    rdfs:comment 'The dispute case state immediately before this event was applied. Together with new_state, provides a complete state-transition record for audit and analytics. Enables reconstruction of the full dispute lifecycle history. [ENUM-REF-CANDIDATE: new|retrieval_pending|chargeback_pending|representment_pending|pre_arbitration_pending|arbitration_pending|resolved|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingRegion rdf:type rdf:Property ;
    rdfs:label 'Processing Region' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the region where this dispute event was processed. Determines applicable regulatory framework (e.g., PSD2 in EU, Regulation E in US), jurisdiction for compliance reporting, and cross-border dispute rules.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Timestamp' ;
    rdfs:comment 'The actual date and time at which the required response or evidence package was submitted for this event stage. Compared against response_deadline to determine SLA compliance and deadline breach status.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'The number of hours within which the required action for this event type must be completed per card scheme rules and internal SLA commitments. Used to compute response_deadline and monitor SLA compliance.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:threeDsAuthenticationResult rdf:type rdf:Property ;
    rdfs:label 'Three Ds Authentication Result' ;
    rdfs:comment 'The outcome of 3-D Secure (3DS) authentication for the original disputed transaction. Determines liability shift applicability under card scheme rules — authenticated transactions shift liability to the issuer, affecting dispute outcome and representment strategy.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeParameterId rdf:type rdf:Property ;
    rdfs:label 'Scheme Parameter Id' ;
    rdfs:comment 'Foreign key linking to network.scheme_parameter. Business justification: Pre-arbitration processes are governed by scheme parameters specifying response deadlines, eligible escalation conditions, and filing requirements. Linking pre_arbitration to the governing scheme_para' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SchemeParameter .

ind:acquirerBankCode rdf:type rdf:Property ;
    rdfs:label 'Acquirer Bank Code' ;
    rdfs:comment 'Bank Identification Number (BIN) of the merchant\'s acquiring bank that processed the original transaction.' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNotes rdf:type rdf:Property ;
    rdfs:label 'Case Notes' ;
    rdfs:comment 'Internal notes and commentary regarding the pre-arbitration case, including strategy considerations, evidence assessment, and communication history.' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the liability amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadlineComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Deadline Compliance Status' ;
    rdfs:comment 'Indicates whether the responding party met the scheme-mandated response deadline: compliant (on time), late (submitted after deadline but accepted), or missed (no response submitted).' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Detailed explanation of why the case was escalated to pre-arbitration after representment rejection, including the basis for challenging the issuer\'s decision.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceSubmissionCount rdf:type rdf:Property ;
    rdfs:label 'Evidence Submission Count' ;
    rdfs:comment 'Number of evidence documents or packages submitted by the filing party to support their pre-arbitration claim.' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Fee charged by the card scheme for filing a pre-arbitration case. This fee is typically assessed to the losing party upon case resolution.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this pre-arbitration record was last updated, tracking any changes to status, outcome, or case details.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Final outcome of the pre-arbitration case: accepted (filing party wins, liability assigned), rejected (responding party wins, original decision stands), escalated_to_arbitration (unresolved, proceeding to formal arbitration), withdrawn (filing party withdrew claim), or pending (outcome not yet determined).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preArbitrationStatus rdf:type rdf:Property ;
    rdfs:label 'Pre Arbitration Status' ;
    rdfs:comment 'Current lifecycle status of the pre-arbitration case: filed (submitted to scheme), pending_response (awaiting counterparty response), under_review (scheme reviewing submissions), accepted (pre-arb claim accepted), rejected (pre-arb claim denied), escalated_to_arbitration (proceeding to formal arbitration), withdrawn (filing party withdrew), or expired (deadline passed without resolution). [ENUM-REF-CANDIDATE: filed|pending_response|under_review|accepted|rejected|escalated_to_arbitration|withdrawn|expired — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date when the pre-arbitration case reached final resolution (accepted, rejected, or escalated to arbitration). Null if case is still pending.' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDate rdf:type rdf:Property ;
    rdfs:label 'Response Date' ;
    rdfs:comment 'Actual date when the responding party submitted their response to the pre-arbitration case. Null if no response has been received.' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Response Received Flag' ;
    rdfs:comment 'Boolean indicator of whether a response has been received from the responding party. True if response submitted, False if pending or no response.' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:schemeDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Scheme Decision Date' ;
    rdfs:comment 'Date when the card scheme issued their official decision on the pre-arbitration case, determining liability assignment.' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'Date when the filing party voluntarily withdrew the pre-arbitration case. Null if case was not withdrawn.' ;
    rdfs:domain ind:PreArbitration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Explanation for why the filing party withdrew the pre-arbitration case, such as settlement reached, insufficient evidence, or strategic decision.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleConfigId rdf:type rdf:Property ;
    rdfs:label 'Rule Config Id' ;
    rdfs:comment 'Primary key for rule_config' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RuleConfig .

ind:actionParameters rdf:type rdf:Property ;
    rdfs:label 'Action Parameters' ;
    rdfs:comment 'Configuration parameters or metadata required to execute the auto action, stored as JSON or key-value pairs.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Approval workflow status indicating whether the rule configuration has been reviewed and authorized for production use.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Identifier or name of the user or role who approved this rule configuration for production deployment.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when this rule configuration was approved, recorded in ISO 8601 format.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:autoActionType rdf:type rdf:Property ;
    rdfs:label 'Auto Action Type' ;
    rdfs:comment 'Automated action to be taken when the rule conditions are met during dispute processing.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text field capturing compliance considerations, regulatory alignment, or audit notes related to this rule configuration.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionExpression rdf:type rdf:Property ;
    rdfs:label 'Condition Expression' ;
    rdfs:comment 'Structured or semi-structured expression defining the logical conditions under which this rule is triggered. May be JSON, XML, or domain-specific language.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeAgeThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Dispute Age Threshold Days' ;
    rdfs:comment 'Maximum age of the dispute in days for this rule to apply, enabling time-sensitive rule logic.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date from which this dispute rule configuration becomes active and applicable to dispute processing.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evidenceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Evidence Required Flag' ;
    rdfs:comment 'Indicates whether supporting evidence must be present for the rule action to be executed.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceTypeList rdf:type rdf:Property ;
    rdfs:label 'Evidence Type List' ;
    rdfs:comment 'Comma-separated or pipe-separated list of evidence types required for this rule to trigger, such as delivery_confirmation, signature, invoice.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionCount rdf:type rdf:Property ;
    rdfs:label 'Execution Count' ;
    rdfs:comment 'Cumulative count of how many times this rule has been executed since activation, used for monitoring and analytics.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date on which this dispute rule configuration ceases to be active. Null indicates no expiration.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:failureCount rdf:type rdf:Property ;
    rdfs:label 'Failure Count' ;
    rdfs:comment 'Cumulative count of failed rule executions where the rule action could not be completed due to errors or exceptions.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Boolean flag indicating whether this rule configuration is currently active and being applied in dispute processing workflows.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastExecutedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Executed Timestamp' ;
    rdfs:comment 'Date and time when this rule was last executed in a dispute processing workflow, recorded in ISO 8601 format.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxDisputeCount rdf:type rdf:Property ;
    rdfs:label 'Max Dispute Count' ;
    rdfs:comment 'Maximum number of disputes this rule can process within a defined time window, used for rate limiting or risk control.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:merchantSegment rdf:type rdf:Property ;
    rdfs:label 'Merchant Segment' ;
    rdfs:comment 'Merchant classification or segment to which this rule applies, enabling segment-specific dispute handling strategies. May reference MCC (Merchant Category Code) ranges or internal merchant tiers.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Identifier or name of the user or system process that last modified this rule configuration record.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRecipientList rdf:type rdf:Property ;
    rdfs:label 'Notification Recipient List' ;
    rdfs:comment 'Comma-separated list of email addresses or user identifiers to be notified when this rule is triggered.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Required Flag' ;
    rdfs:comment 'Indicates whether a notification must be sent to stakeholders when this rule is triggered.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric priority ranking for rule evaluation order when multiple rules may apply to the same dispute. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Unique business identifier code for the dispute rule configuration, used for external reference and system integration.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed textual description of the rule logic, business rationale, and intended use case for this dispute rule configuration.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name of the dispute rule configuration describing its purpose and scope.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleOwner rdf:type rdf:Property ;
    rdfs:label 'Rule Owner' ;
    rdfs:comment 'Business owner or team responsible for maintaining and governing this dispute rule configuration.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the dispute rule configuration indicating whether it is actively applied in dispute processing.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classification of the dispute rule configuration indicating the type of automated action or decision logic it governs.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successCount rdf:type rdf:Property ;
    rdfs:label 'Success Count' ;
    rdfs:comment 'Cumulative count of successful rule executions where the rule conditions were met and the action was successfully applied.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Threshold Amount' ;
    rdfs:comment 'Monetary threshold value that triggers or qualifies the rule action. Used for auto-accept or auto-representment eligibility based on dispute amount.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdCurrency rdf:type rdf:Property ;
    rdfs:label 'Threshold Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the threshold amount.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeWindowHours rdf:type rdf:Property ;
    rdfs:label 'Time Window Hours' ;
    rdfs:comment 'Time window in hours for evaluating max dispute count or other time-bound rule conditions.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionAgeThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Transaction Age Threshold Days' ;
    rdfs:comment 'Maximum age of the original transaction in days for this rule to apply, used for representment eligibility assessment.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Version number of this rule configuration, incremented with each modification to support audit trail and rollback capabilities.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winRateThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Win Rate Threshold Pct' ;
    rdfs:comment 'Minimum historical win rate percentage for similar disputes required for auto-representment eligibility under this rule.' ;
    rdfs:domain ind:RuleConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'Identifier or name of the user or system process that created this rule configuration record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratioMonitorId rdf:type rdf:Property ;
    rdfs:label 'Ratio Monitor Id' ;
    rdfs:comment 'Primary key for ratio_monitor' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RatioMonitor .

ind:merchantAccountId rdf:type rdf:Property ;
    rdfs:label 'Merchant Account Id' ;
    rdfs:comment 'Foreign key linking to merchant.merchant_account. Business justification: Scheme monitoring programs operate at MID/account level. A merchant can have multiple merchant_accounts with distinct MIDs. Linking ratio_monitor to merchant_account enables direct enforcement of enha' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchantAccount .

ind:riskProfileId rdf:type rdf:Property ;
    rdfs:label 'Risk Profile Id' ;
    rdfs:comment 'Foreign key linking to merchant.merchant_risk_profile. Business justification: When a ratio_monitor record shows threshold breach (VDMP/ECP enrollment), risk ops must update the merchant_risk_profile to adjust reserve_percentage, risk_tier, and enhanced_monitoring_required. This' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentsFintech .

ind:acquirerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Acquirer Notification Date' ;
    rdfs:comment 'The date the acquiring bank notified the merchant of the chargeback ratio threshold breach and required remediation actions.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Assessment Fee Amount' ;
    rdfs:comment 'The monetary penalty or assessment fee imposed by the card scheme for the chargeback ratio threshold breach during this monitoring period. Fees escalate with severity and duration of non-compliance.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Assessment Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the assessment fee amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackRatioPercentage rdf:type rdf:Property ;
    rdfs:label 'Chargeback Ratio Percentage' ;
    rdfs:comment 'The calculated chargeback ratio expressed as a percentage: (total_chargeback_count / total_transaction_count) * 100. Core metric for determining scheme program threshold breaches.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance status of the merchant with respect to card scheme chargeback ratio requirements for this monitoring period.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consecutiveMonthsInProgram rdf:type rdf:Property ;
    rdfs:label 'Consecutive Months In Program' ;
    rdfs:comment 'The number of consecutive months the merchant has been enrolled in the chargeback monitoring program as of this monitoring period. Used to track escalation and potential termination risk.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:excessiveThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Excessive Threshold Percentage' ;
    rdfs:comment 'The excessive chargeback ratio threshold percentage defined by the card scheme program for this monitoring period. Typically 1.8% for Visa VDMP excessive threshold.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudChargebackCount rdf:type rdf:Property ;
    rdfs:label 'Fraud Chargeback Count' ;
    rdfs:comment 'The subset of total chargebacks that were classified as fraud-related (reason codes 10.4, 4837, etc.) during the monitoring period. Used for Visa Fraud Monitoring Program (VFM) tracking.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fraudRatioPercentage rdf:type rdf:Property ;
    rdfs:label 'Fraud Ratio Percentage' ;
    rdfs:comment 'The calculated fraud chargeback ratio expressed as a percentage: (fraud_chargeback_count / total_transaction_count) * 100. Used for Visa Fraud Monitoring Program (VFM) compliance.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:highRiskIndicator rdf:type rdf:Property ;
    rdfs:label 'High Risk Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the merchant is classified as high-risk by the acquirer or card scheme, which may result in stricter chargeback ratio thresholds or enhanced monitoring.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumChargebackThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Chargeback Threshold' ;
    rdfs:comment 'The minimum number of chargebacks required during the monitoring period for the merchant to be subject to the chargeback monitoring program. Typically 100 chargebacks for Visa VDMP standard threshold.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumTransactionThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Transaction Threshold' ;
    rdfs:comment 'The minimum number of transactions required during the monitoring period for the merchant to be subject to the chargeback monitoring program. Typically 1,000 transactions for Visa VDMP.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monitoringPeriodMonth rdf:type rdf:Property ;
    rdfs:label 'Monitoring Period Month' ;
    rdfs:comment 'The calendar month for which this chargeback ratio is calculated and monitored. Typically the first day of the month (YYYY-MM-01 format).' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringProgramType rdf:type rdf:Property ;
    rdfs:label 'Monitoring Program Type' ;
    rdfs:comment 'The specific card scheme chargeback monitoring program under which this merchant is being tracked. Examples: VDMP (Visa Dispute Monitoring Program), VFM (Visa Fraud Monitoring), MCP (Mastercard Chargeback Program), ECMP (Excessive Chargeback Merchant Program).' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Monitoring Record Status' ;
    rdfs:comment 'Current lifecycle status of this monitoring record. Active indicates ongoing monitoring; Closed indicates the monitoring period has concluded; Under Review indicates pending scheme or acquirer review.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Program Enrollment Date' ;
    rdfs:comment 'The date the merchant was enrolled into the card scheme chargeback monitoring program due to threshold breach. Null if merchant is not currently enrolled.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programExitDate rdf:type rdf:Property ;
    rdfs:label 'Program Exit Date' ;
    rdfs:comment 'The date the merchant successfully exited the card scheme chargeback monitoring program by achieving compliance. Null if merchant is still enrolled or was never enrolled.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country or region code where the merchant operates. Card scheme monitoring programs may have regional variations in thresholds and rules.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationPlanReference rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan Reference' ;
    rdfs:comment 'Reference identifier or document number for the merchants chargeback remediation plan submitted to address the threshold breach. Required for merchants enrolled in monitoring programs.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'The end date of the rolling review period used to calculate the chargeback ratio.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'The start date of the rolling review period used to calculate the chargeback ratio. Card schemes typically use a rolling 12-month or 6-month window.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:schemeNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Scheme Notification Date' ;
    rdfs:comment 'The date the card scheme officially notified the acquirer and merchant of the chargeback ratio threshold breach and program enrollment.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standardThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Standard Threshold Percentage' ;
    rdfs:comment 'The standard chargeback ratio threshold percentage defined by the card scheme program for this monitoring period. Typically 0.9% for Visa VDMP standard threshold.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdLevelBreached rdf:type rdf:Property ;
    rdfs:label 'Threshold Level Breached' ;
    rdfs:comment 'The severity level of the chargeback ratio threshold breach, if any. Indicates which tier of the card scheme monitoring program the merchant has entered. None indicates compliance; other values indicate escalating severity.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalChargebackCount rdf:type rdf:Property ;
    rdfs:label 'Total Chargeback Count' ;
    rdfs:comment 'The total number of chargebacks received against the merchant during the monitoring period month. Numerator for chargeback ratio calculation.' ;
    rdfs:domain ind:RatioMonitor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Total Transaction Count' ;
    rdfs:comment 'The total number of transactions processed by the merchant during the monitoring period month. Denominator for chargeback ratio calculation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimId rdf:type rdf:Property ;
    rdfs:label 'Claim Id' ;
    rdfs:comment 'Primary key for claim' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Claim .

ind:claimChargebackCaseChargebackId rdf:type rdf:Property ;
    rdfs:label 'Claim Chargeback Case Chargeback Id' ;
    rdfs:comment 'Reference to the formal chargeback case record if this claim was escalated to the chargeback process.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Chargeback .

ind:claimChargebackId rdf:type rdf:Property ;
    rdfs:label 'Claim Chargeback Id' ;
    rdfs:comment 'Reference to the formal chargeback case record if this claim was escalated to the chargeback process.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Chargeback .

ind:partyId rdf:type rdf:Property ;
    rdfs:label 'Party Id' ;
    rdfs:comment 'Foreign key linking to compliance.party. Business justification: Claims are filed by cardholders (parties) requiring identity verification, AML screening, and sanctions checks per KYC regulations. Links claim to cardholder party record for compliance verification, ' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:actualResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Date' ;
    rdfs:comment 'The actual date on which the claim was resolved (approved, denied, or withdrawn).' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cardholderStatement rdf:type rdf:Property ;
    rdfs:label 'Cardholder Statement' ;
    rdfs:comment 'Free-text narrative provided by the cardholder describing the reason for the dispute and supporting details.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Externally-visible unique claim identifier provided to the cardholder for tracking and reference purposes.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle status of the dispute claim: submitted, under review, pending documentation, approved, denied, withdrawn, or escalated to chargeback. [ENUM-REF-CANDIDATE: submitted|under_review|pending_documentation|approved|denied|withdrawn|escalated_to_chargeback — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Classification of the dispute claim based on the nature of the cardholders assertion: unauthorized transaction, item not received, item not as described, duplicate charge, credit not processed, or service not rendered.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactAttemptCount rdf:type rdf:Property ;
    rdfs:label 'Contact Attempt Count' ;
    rdfs:comment 'The number of times the dispute resolution team attempted to contact the cardholder for additional information or clarification.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentationReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Documentation Reference Code' ;
    rdfs:comment 'Reference identifier linking to the document management system where supporting evidence files are stored.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedToChargebackFlag rdf:type rdf:Property ;
    rdfs:label 'Escalated To Chargeback Flag' ;
    rdfs:comment 'Boolean indicator of whether this claim was escalated to a formal chargeback filing with the card network.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Resolution Date' ;
    rdfs:comment 'The target date by which the claim investigation and resolution is expected to be completed, based on regulatory timelines and internal SLAs.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fraudIndicatorFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Indicator Flag' ;
    rdfs:comment 'Boolean indicator of whether the claim was flagged as potentially fraudulent and routed to the fraud investigation team.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'Numerical fraud risk score assigned by the fraud detection platform, ranging from 0.00 (low risk) to 100.00 (high risk).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialTriageOutcome rdf:type rdf:Property ;
    rdfs:label 'Initial Triage Outcome' ;
    rdfs:comment 'The outcome of the initial automated or manual triage assessment: accepted for review, rejected due to insufficient information, rejected as out of timeframe, escalated to fraud investigation, or provisional credit issued.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Contact Timestamp' ;
    rdfs:comment 'The date and time of the most recent contact attempt or successful communication with the cardholder regarding this claim.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'The date and time when this claim record was last updated in the dispute management system.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:merchantCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Merchant Category Code' ;
    rdfs:comment 'Four-digit code classifying the type of goods or services provided by the merchant involved in the disputed transaction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Provisional Credit Amount' ;
    rdfs:comment 'The monetary amount of provisional credit issued to the cardholder, if applicable.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisionalCreditDate rdf:type rdf:Property ;
    rdfs:label 'Provisional Credit Date' ;
    rdfs:comment 'The date on which provisional credit was posted to the cardholder account.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:provisionalCreditIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Provisional Credit Issued Flag' ;
    rdfs:comment 'Boolean indicator of whether a provisional credit was issued to the cardholder account while the claim is under investigation, as required by Regulation E for certain dispute types.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Internal notes documenting the investigation findings, decision rationale, and resolution details.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for the claim resolution outcome, aligned with card scheme reason code taxonomies.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentationProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Provided Flag' ;
    rdfs:comment 'Boolean indicator of whether the cardholder provided supporting documentation (receipts, correspondence, delivery confirmations) with the claim submission.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionArn rdf:type rdf:Property ;
    rdfs:label 'Transaction Arn' ;
    rdfs:comment 'The 23-digit Acquirer Reference Number uniquely identifying the disputed transaction across the payment network.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triageTimestamp rdf:type rdf:Property ;
    rdfs:label 'Triage Timestamp' ;
    rdfs:comment 'The date and time when the initial triage assessment was completed.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:merchantContactId rdf:type rdf:Property ;
    rdfs:label 'Merchant Contact Id' ;
    rdfs:comment 'Foreign key linking to merchant.merchant_contact. Business justification: merchant_response stores merchant_contact_email, merchant_contact_name, merchant_contact_phone as denormalized text. merchant_contact has can_receive_dispute_notifications specifically for this purpos' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchantContact .

ind:webhookDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Webhook Delivery Id' ;
    rdfs:comment 'Foreign key linking to gateway.webhook_delivery. Business justification: Dispute notification webhooks (chargeback.received, retrieval_request.created) trigger merchant responses. Tracking which webhook delivery initiated each merchant_response is essential for SLA complia' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WebhookDelivery .

ind:acquirerFeedbackNotes rdf:type rdf:Property ;
    rdfs:label 'Acquirer Feedback Notes' ;
    rdfs:comment 'Internal notes or feedback provided by the acquirer reviewer regarding the quality, completeness, or deficiencies of the merchant response.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquirerReviewCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acquirer Review Completed Timestamp' ;
    rdfs:comment 'Date and time when the acquirer completed their review of the merchant response and made a decision on whether to proceed with representment.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:acquirerReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Acquirer Review Status' ;
    rdfs:comment 'Status of the acquirers internal review of the merchant response. Indicates whether the response meets quality standards for formal representment to the issuer.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedResponseFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Response Flag' ;
    rdfs:comment 'Indicates whether this response was generated automatically by the merchants dispute management system or submitted manually by a merchant representative. True if automated.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cardholderName rdf:type rdf:Property ;
    rdfs:label 'Cardholder Name' ;
    rdfs:comment 'Name of the cardholder who initiated the dispute. Included for merchant reference and evidence matching purposes.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Notification Date' ;
    rdfs:comment 'Date when the merchant was first notified of the dispute or retrieval request. Used to calculate response deadline and track merchant response time.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liabilityAcceptanceAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Acceptance Amount' ;
    rdfs:comment 'Monetary amount that the merchant accepts liability for in cases of partial acceptance. Null if merchant contests the full dispute amount.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityAcceptanceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Liability Acceptance Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the liability acceptance amount. Typically matches the original transaction currency.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantRebuttalNarrative rdf:type rdf:Property ;
    rdfs:label 'Merchant Rebuttal Narrative' ;
    rdfs:comment 'Free-text explanation provided by the merchant describing their position, justification, and defense against the dispute claim. May include transaction details, customer interaction history, and policy references.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representmentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Representment Eligible Flag' ;
    rdfs:comment 'Indicates whether this merchant response qualifies for formal representment to the issuer based on acquirer review, evidence quality, and card scheme rules. True if eligible.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseChannel rdf:type rdf:Property ;
    rdfs:label 'Response Channel' ;
    rdfs:comment 'Channel or interface through which the merchant submitted their response to the acquirer (e.g., dispute management portal, API integration, email submission).' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Response Confidence Score' ;
    rdfs:comment 'Automated confidence score (0-100) indicating the predicted likelihood of winning the dispute based on evidence quality, reason code, and historical outcomes. Used for prioritization and strategy.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Response Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the language in which the merchant rebuttal narrative and evidence were submitted.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Response Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this merchant response for tracking and correspondence purposes.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Current lifecycle status of the merchant response in the dispute workflow. Tracks progression from draft through acquirer review to final disposition.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTurnaroundDays rdf:type rdf:Property ;
    rdfs:label 'Response Turnaround Days' ;
    rdfs:comment 'Number of calendar days between dispute notification and merchant response submission. Used for performance tracking and SLA monitoring.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseType rdf:type rdf:Property ;
    rdfs:label 'Response Type' ;
    rdfs:comment 'Classification of the merchants position in response to the dispute notification. Indicates whether merchant accepts, contests, or partially accepts the chargeback claim.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Response Version Number' ;
    rdfs:comment 'Version number tracking revisions to the merchant response. Incremented each time the merchant updates their response before final submission.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether the merchant response was submitted after the deadline, resulting in automatic forfeiture of representment rights. True if deadline missed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:withdrawalRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Requested Flag' ;
    rdfs:comment 'Indicates whether the merchant has requested to withdraw this response and accept the chargeback liability. True if withdrawal requested.' ;
    rdfs:domain ind:MerchantResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:schemeFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Scheme Fee Schedule Id' ;
    rdfs:comment 'Reference to the fee schedule or pricing configuration that determined the assessed fee amount. Links to the applicable scheme fee table or internal pricing rule used to calculate this charge.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SchemeFeeSchedule .

ind:amountUsd rdf:type rdf:Property ;
    rdfs:label 'Amount Usd' ;
    rdfs:comment 'Fee amount converted to US Dollars (USD) using the FX rate applied at assessment date. Enables normalized cross-currency reporting and analytics across all dispute fee records.' ;
    rdfs:domain ind:Fee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessingEntityName rdf:type rdf:Property ;
    rdfs:label 'Assessing Entity Name' ;
    rdfs:comment 'Human-readable name of the specific entity that assessed the fee (e.g., \'Visa Inc.\', \'Mastercard International\', \'Chase Merchant Services\'). Complements assessed_by for reporting and reconciliation.' ;
    rdfs:domain ind:Fee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'Calendar date on which the fee was formally assessed or levied by the assessing entity. Used as the primary business event date for billing period assignment and regulatory reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assessment Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) when the fee was assessed. Provides sub-day precision for SLA tracking, real-time processing audit, and dispute deadline calculations.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingPeriod rdf:type rdf:Property ;
    rdfs:label 'Billing Period' ;
    rdfs:comment 'The billing cycle period (YYYY-MM format) to which this fee is attributed for invoicing and financial reporting. Aligns with monthly scheme billing cycles and ERP accounts payable periods.' ;
    rdfs:domain ind:Fee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeFeeNotes rdf:type rdf:Property ;
    rdfs:label 'Dispute Fee Notes' ;
    rdfs:comment 'Free-text notes or comments entered by dispute operations staff regarding this fee record. May include waiver justification details, scheme correspondence references, or escalation context.' ;
    rdfs:domain ind:Fee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Contractual or scheme-mandated deadline by which the fee must be paid. Drives overdue detection, collections escalation, and SLA compliance monitoring.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Status' ;
    rdfs:comment 'Current lifecycle status of the fee record. Tracks progression from initial assessment through invoicing, payment, waiver, or secondary dispute of the fee itself.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeType rdf:type rdf:Property ;
    rdfs:label 'Fee Type' ;
    rdfs:comment 'Classification of the fee assessed in connection with the dispute. Distinguishes scheme chargeback fees, arbitration filing fees, compliance assessment fines, retrieval request fees, pre-arbitration fees, and internal processing fees. [ENUM-REF-CANDIDATE: chargeback_fee|arbitration_fee|compliance_assessment|retrieval_request_fee|internal_processing_fee|pre_arbitration_fee|scheme_penalty|network_fine — promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxRateApplied rdf:type rdf:Property ;
    rdfs:label 'Fx Rate Applied' ;
    rdfs:comment 'The FX exchange rate used to convert the fee amount from the fee currency to USD at the time of assessment. Supports audit trail for currency conversion and DCC-related fee reconciliation.' ;
    rdfs:domain ind:Fee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReference rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference' ;
    rdfs:comment 'Reference number of the invoice or billing statement on which this fee appears. Links the fee record to the ERP accounts payable or accounts receivable invoice for payment tracking and reconciliation.' ;
    rdfs:domain ind:Fee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Net Fee Amount' ;
    rdfs:comment 'Final collectible fee amount after applying any waivers or adjustments (fee_amount minus waiver_amount). Represents the actual amount due for billing and GL posting.' ;
    rdfs:domain ind:Fee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Date on which the fee was settled or paid. Populated when payment_status transitions to \'paid\' or \'partially_paid\'. Used for cash flow reporting and aging analysis.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current payment collection status of the net fee amount. Tracks whether the fee has been paid, remains outstanding, is overdue, or has been written off. Distinct from fee_status which tracks the assessment lifecycle.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for this fee record as assigned by the assessing entity (card scheme, acquirer, or internal billing system). Used for reconciliation and invoice matching.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Scheme Reason Code' ;
    rdfs:comment 'Card scheme-specific reason code associated with the chargeback or dispute event that triggered this fee (e.g., Visa reason code 10.4, Mastercard reason code 4853). Aligns with ISO 8583 and scheme rule classifications.' ;
    rdfs:domain ind:Fee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverAmount rdf:type rdf:Property ;
    rdfs:label 'Waiver Amount' ;
    rdfs:comment 'Monetary amount waived from the original fee_amount. Supports partial waivers where only a portion of the assessed fee is forgiven. Zero if no waiver applied.' ;
    rdfs:domain ind:Fee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Flag' ;
    rdfs:comment 'Indicates whether this fee has been fully waived by the assessing entity. When True, the fee amount is not expected to be collected. Distinct from partial adjustments tracked in fee_waiver_amount.' ;
    rdfs:domain ind:Fee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Reason code explaining why the fee was waived. Applicable only when waiver_flag is True. Supports audit and compliance reporting for fee waiver decisions.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irfTableId rdf:type rdf:Property ;
    rdfs:label 'Irf Table Id' ;
    rdfs:comment 'Unique identifier for the interchange reimbursement fee table record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IrfTable .

ind:currencyPairId rdf:type rdf:Property ;
    rdfs:label 'Currency Pair Id' ;
    rdfs:comment 'Foreign key linking to fx.currency_pair. Business justification: Interchange rate tables publish rates per currency pair (e.g., USD/EUR domestic vs cross-border rates). Essential for multi-currency interchange rate management and scheme compliance reporting across ' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CurrencyPair .

ind:irfRateCategoryId rdf:type rdf:Property ;
    rdfs:label 'Irf Rate Category Id' ;
    rdfs:comment 'Foreign key linking to interchange.irf_rate_category. Business justification: irf_table references its category; adds irf_rate_category_id FK to irf_rate_category' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IrfRateCategory .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Foreign key linking to interchange.program. Business justification: irf_table.program_identifier (STRING) stores the scheme program code that governs this IRF rate entry (e.g., Visa Utility, Mastercard Merit). The program product is the authoritative master for card s' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:acquirerCountryCode rdf:type rdf:Property ;
    rdfs:label 'Acquirer Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the acquiring bank. Used for domestic vs. cross-border interchange rate determination. Null indicates rate applies regardless of acquirer country.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationMethod rdf:type rdf:Property ;
    rdfs:label 'Authorization Method' ;
    rdfs:comment 'Card authorization method required for this interchange rate (chip, contactless, magnetic stripe, manual entry, ecommerce, token). Null indicates no specific method requirement.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binRangeHigh rdf:type rdf:Property ;
    rdfs:label 'Bin Range High' ;
    rdfs:comment 'Upper bound of the BIN/IIN range to which this interchange rate applies. Used for BIN-level interchange qualification rules. Null indicates no BIN restriction.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binRangeLow rdf:type rdf:Property ;
    rdfs:label 'Bin Range Low' ;
    rdfs:comment 'Lower bound of the BIN/IIN range to which this interchange rate applies. Used for BIN-level interchange qualification rules. Null indicates no BIN restriction.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardProductTier rdf:type rdf:Property ;
    rdfs:label 'Card Product Tier' ;
    rdfs:comment 'Card product tier or brand level (e.g., Standard, Rewards, Premium, Signature, World, World Elite, Platinum, Infinite). Higher tiers typically carry higher interchange rates. [ENUM-REF-CANDIDATE: standard|rewards|premium|signature|world|world_elite|platinum|infinite — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardType rdf:type rdf:Property ;
    rdfs:label 'Card Type' ;
    rdfs:comment 'Type of payment card to which this interchange rate applies (credit, debit, prepaid, commercial, purchasing). Critical qualifier for rate selection.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfAcceptanceCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Of Acceptance Category' ;
    rdfs:comment 'Internal classification category used for cost-of-acceptance reporting and analysis (e.g., low-cost, standard, premium, high-cost). Supports merchant pricing strategy and portfolio profitability analysis.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durbinCapAmount rdf:type rdf:Property ;
    rdfs:label 'Durbin Cap Amount' ;
    rdfs:comment 'Maximum interchange fee amount allowed under Regulation II Durbin Amendment for regulated debit transactions. Null if not subject to Durbin caps.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durbinRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Durbin Regulated Flag' ;
    rdfs:comment 'Indicates whether this interchange rate is subject to Regulation II Durbin Amendment caps (True for regulated debit, False otherwise). Critical for US debit interchange compliance.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date when this interchange rate schedule expires and is no longer applicable. Null indicates an open-ended schedule currently in effect.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date when this interchange rate schedule becomes effective and applicable to transactions. Part of the temporal validity window for this rate.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interchangeCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Interchange Category Code' ;
    rdfs:comment 'Scheme-specific code identifying the interchange rate category (e.g., CPS Retail, Merit III, Core Value, Standard). This is the authoritative classification used by the card scheme.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeCategoryName rdf:type rdf:Property ;
    rdfs:label 'Interchange Category Name' ;
    rdfs:comment 'Human-readable name of the interchange rate category (e.g., Card Present Signature Preferred Retail, Electronic Commerce Basic).' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Interchange Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the interchange fee amounts (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeFixedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Interchange Fixed Fee Amount' ;
    rdfs:comment 'Fixed per-transaction fee component of the interchange in the currency specified by interchange_currency_code (e.g., $0.10). Combined with percentage rate to calculate total IRF.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interchangeRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Interchange Rate Percentage' ;
    rdfs:comment 'Percentage rate component of the interchange fee applied to the transaction amount (e.g., 1.65% stored as 0.0165). Used in cost-of-acceptance calculations.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalRateCode rdf:type rdf:Property ;
    rdfs:label 'Internal Rate Code' ;
    rdfs:comment 'Internal company-specific code or identifier for this interchange rate, used for mapping to internal pricing and cost-of-acceptance systems. May differ from scheme category code.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Transaction Amount' ;
    rdfs:comment 'Maximum transaction amount for which this interchange rate applies, in the currency specified by interchange_currency_code. Null indicates no maximum.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Transaction Amount' ;
    rdfs:comment 'Minimum transaction amount required for this interchange rate to apply, in the currency specified by interchange_currency_code. Null indicates no minimum.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationCriteria rdf:type rdf:Property ;
    rdfs:label 'Qualification Criteria' ;
    rdfs:comment 'Detailed business rules and conditions that must be met for a transaction to qualify for this interchange rate (e.g., EMV chip, AVS match, settlement within 24 hours). Free-text field capturing scheme-specific requirements.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of this interchange rate schedule (active, pending, expired, superseded, withdrawn). Used for rate version management and historical analysis.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateVersion rdf:type rdf:Property ;
    rdfs:label 'Rate Version' ;
    rdfs:comment 'Version identifier for this interchange rate schedule, assigned by the card scheme. Used to track rate changes over time and ensure correct rate application.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this interchange rate record was first created in the system. Used for audit trail and data lineage.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Name or identifier of the source system from which this interchange rate data originated (e.g., Visa Rate Feed, Mastercard Portal, Manual Entry). Used for data lineage and reconciliation.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp when this interchange rate record was last modified. Used for audit trail and change tracking.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting regulatory compliance considerations for this interchange rate (e.g., PSD2 caps, Durbin Amendment applicability, regional regulations). Used for compliance audit and legal review.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeBulletinReference rdf:type rdf:Property ;
    rdfs:label 'Scheme Bulletin Reference' ;
    rdfs:comment 'Reference number or identifier of the card scheme bulletin or notice that announced this interchange rate change. Used for traceability and compliance documentation.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemePublicationDate rdf:type rdf:Property ;
    rdfs:label 'Scheme Publication Date' ;
    rdfs:comment 'Date when the card scheme officially published this interchange rate schedule. Used for audit trail and regulatory reporting.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementTimeframeHours rdf:type rdf:Property ;
    rdfs:label 'Settlement Timeframe Hours' ;
    rdfs:comment 'Maximum number of hours between authorization and settlement for this interchange rate to apply (e.g., 24, 48, 72). Null indicates no settlement timeframe requirement.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionRegion rdf:type rdf:Property ;
    rdfs:label 'Transaction Region' ;
    rdfs:comment 'Geographic scope of the transaction (domestic, intra-regional, inter-regional, cross-border). Determines applicable interchange rate tier.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Type of transaction to which this interchange rate applies (card present, card not present, ecommerce, mail/telephone order, recurring, contactless). Key qualifier for interchange eligibility.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationTimeframeHours rdf:type rdf:Property ;
    rdfs:label 'Authorization Timeframe Hours' ;
    rdfs:comment 'The maximum number of hours between authorization and capture for transactions to qualify for this interchange rate category.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avsRequired rdf:type rdf:Property ;
    rdfs:label 'Avs Required' ;
    rdfs:comment 'Indicates whether Address Verification System (AVS) validation is required to qualify for this interchange rate category.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:binRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Bin Range End' ;
    rdfs:comment 'The ending Bank Identification Number (BIN) or Issuer Identification Number (IIN) in the range of card products that qualify for this interchange rate category.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binRangeStart rdf:type rdf:Property ;
    rdfs:label 'Bin Range Start' ;
    rdfs:comment 'The starting Bank Identification Number (BIN) or Issuer Identification Number (IIN) in the range of card products that qualify for this interchange rate category.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardNotPresentIndicator rdf:type rdf:Property ;
    rdfs:label 'Card Not Present Indicator' ;
    rdfs:comment 'Indicates whether this interchange rate category applies to card-not-present (CNP) transactions such as e-commerce, mail order, or telephone order.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cardPresentIndicator rdf:type rdf:Property ;
    rdfs:label 'Card Present Indicator' ;
    rdfs:comment 'Indicates whether this interchange rate category applies to card-present (CP) transactions where the physical card is presented at the Point of Sale (POS).' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'The unique code assigned by the card scheme to identify this interchange rate category (e.g., CPS_RETAIL, MERIT_III, OPTBLUE_TIER1).' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'The full business name of the interchange rate category as published by the card scheme (e.g., Visa CPS/Retail, Mastercard Merit III, Amex OptBlue Standard).' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryType rdf:type rdf:Property ;
    rdfs:label 'Category Type' ;
    rdfs:comment 'The classification of the interchange rate category based on card product type and transaction characteristics. [ENUM-REF-CANDIDATE: standard|premium|commercial|debit|credit|prepaid|rewards|government|healthcare — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactlessEligible rdf:type rdf:Property ;
    rdfs:label 'Contactless Eligible' ;
    rdfs:comment 'Indicates whether contactless NFC transactions are eligible for this interchange rate category.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossBorderTransactionIndicator rdf:type rdf:Property ;
    rdfs:label 'Cross Border Transaction Indicator' ;
    rdfs:comment 'Indicates whether this interchange rate category applies to cross-border transactions where the acquiring and issuing banks are in different countries.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cvvRequired rdf:type rdf:Property ;
    rdfs:label 'Cvv Required' ;
    rdfs:comment 'Indicates whether Card Verification Value (CVV) validation is required to qualify for this interchange rate category.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:domesticTransactionIndicator rdf:type rdf:Property ;
    rdfs:label 'Domestic Transaction Indicator' ;
    rdfs:comment 'Indicates whether this interchange rate category applies to domestic transactions where the acquiring and issuing banks are in the same country.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downgradeCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Downgrade Category Code' ;
    rdfs:comment 'The interchange rate category code to which a transaction will be downgraded if it fails to meet the qualification criteria for this category.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downgradeRulesDescription rdf:type rdf:Property ;
    rdfs:label 'Downgrade Rules Description' ;
    rdfs:comment 'A detailed textual description of the conditions under which a transaction will be downgraded from this interchange rate category to a lower-tier category.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durbinRegulatedIndicator rdf:type rdf:Property ;
    rdfs:label 'Durbin Regulated Indicator' ;
    rdfs:comment 'Indicates whether this interchange rate category is subject to Durbin Amendment (Regulation II) caps for debit card transactions issued by regulated financial institutions.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emvChipRequired rdf:type rdf:Property ;
    rdfs:label 'Emv Chip Required' ;
    rdfs:comment 'Indicates whether EMV chip authentication is required for transactions to qualify for this interchange rate category.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'The date on which this interchange rate category ceases to be active and is no longer applicable to new transactions.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:irfRateCategoryStatus rdf:type rdf:Property ;
    rdfs:label 'Irf Rate Category Status' ;
    rdfs:comment 'The current lifecycle status of this interchange rate category within the card schemes published rate structure.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mccRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Mcc Range End' ;
    rdfs:comment 'The ending Merchant Category Code (MCC) in the range of merchant types that qualify for this interchange rate category.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mccRangeStart rdf:type rdf:Property ;
    rdfs:label 'Mcc Range Start' ;
    rdfs:comment 'The starting Merchant Category Code (MCC) in the range of merchant types that qualify for this interchange rate category.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Parent Category Code' ;
    rdfs:comment 'The code of the parent or umbrella interchange rate category under which this category is nested in the schemes taxonomy.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCriteriaDescription rdf:type rdf:Property ;
    rdfs:label 'Qualification Criteria Description' ;
    rdfs:comment 'A detailed textual description of all the business and technical criteria that a transaction must meet to qualify for this interchange rate category.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemePublicationReference rdf:type rdf:Property ;
    rdfs:label 'Scheme Publication Reference' ;
    rdfs:comment 'The reference identifier or document name from the card schemes official publication where this interchange rate category is defined (e.g., Visa USA Interchange Reimbursement Fees April 2024).' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTimeframeDays rdf:type rdf:Property ;
    rdfs:label 'Settlement Timeframe Days' ;
    rdfs:comment 'The number of days within which transactions in this interchange rate category must be settled to qualify for the published interchange rate.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:threeDSecureRequired rdf:type rdf:Property ;
    rdfs:label 'Three D Secure Required' ;
    rdfs:comment 'Indicates whether 3-D Secure authentication is required for card-not-present transactions to qualify for this interchange rate category.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionAmountMax rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount Max' ;
    rdfs:comment 'The maximum transaction amount allowed to qualify for this interchange rate category, in the base currency of the scheme.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionAmountMin rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount Min' ;
    rdfs:comment 'The minimum transaction amount required to qualify for this interchange rate category, in the base currency of the scheme.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mdrConfigId rdf:type rdf:Property ;
    rdfs:label 'Mdr Config Id' ;
    rdfs:comment 'Unique identifier for the MDR configuration record. Primary key.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MdrConfig .

ind:acquiringBankLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Acquiring Bank Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to ledger.legal_entity. Business justification: MDR configuration must associate the acquiring bank legal entity for compliance and fee allocation reporting.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:acquiringPartyId rdf:type rdf:Property ;
    rdfs:label 'Acquiring Party Id' ;
    rdfs:comment 'Foreign key linking to compliance.party. Business justification: Acquiring banks are legal entities requiring KYC/AML verification tracked as compliance parties. Regulatory reporting (SAR, CTR) and audit trails require party-level compliance data for all acquiring ' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:participantId rdf:type rdf:Property ;
    rdfs:label 'Participant Id' ;
    rdfs:comment 'Foreign key linking to settlement.participant. Business justification: MDR configurations are established by acquiring participants for their merchant portfolios. Linking mdr_config to the acquiring participant enables participant-level MDR portfolio management and inter' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Participant .

ind:blendedRatePercent rdf:type rdf:Property ;
    rdfs:label 'Blended Rate Percent' ;
    rdfs:comment 'The blended MDR percentage applied to all transactions for this merchant, expressed as a decimal (e.g., 0.0275 for 2.75%).' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:configurationStatus rdf:type rdf:Property ;
    rdfs:label 'Configuration Status' ;
    rdfs:comment 'Current lifecycle status of this MDR configuration record.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference number of the merchant service agreement or contract that governs this MDR configuration.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedTransactionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Transaction Fee Amount' ;
    rdfs:comment 'Fixed per-transaction fee charged to the merchant in addition to percentage-based MDR.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interchangePlusMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Interchange Plus Margin Percent' ;
    rdfs:comment 'The margin percentage added on top of interchange fees for interchange-plus pricing model, expressed as a decimal.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchantSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Merchant Segment Code' ;
    rdfs:comment 'Classification code representing the merchant segment or tier (e.g., enterprise, SMB, micro-merchant) for tiered pricing strategies.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlySubscriptionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Subscription Fee Amount' ;
    rdfs:comment 'Fixed monthly subscription fee for subscription-based pricing models.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyVolumeThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Volume Threshold Amount' ;
    rdfs:comment 'Monthly transaction volume threshold that triggers rate adjustments or tier changes for volume-based pricing.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingModelType rdf:type rdf:Property ;
    rdfs:label 'Pricing Model Type' ;
    rdfs:comment 'The pricing model applied to this merchant: flat rate, tiered pricing, interchange-plus, subscription-based, or blended rate.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSharePercent rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Percent' ;
    rdfs:comment 'Percentage of MDR revenue shared with partners or sub-acquirers in payment facilitator or ISO arrangements, expressed as a decimal.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier1RatePercent rdf:type rdf:Property ;
    rdfs:label 'Tier 1 Rate Percent' ;
    rdfs:comment 'MDR percentage applied to transactions in tier 1 pricing band, expressed as a decimal.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier1ThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Tier 1 Threshold Amount' ;
    rdfs:comment 'Transaction amount threshold for tier 1 pricing band in tiered pricing models. Transactions below this amount use tier 1 rate.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2RatePercent rdf:type rdf:Property ;
    rdfs:label 'Tier 2 Rate Percent' ;
    rdfs:comment 'MDR percentage applied to transactions in tier 2 pricing band, expressed as a decimal.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2ThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Tier 2 Threshold Amount' ;
    rdfs:comment 'Transaction amount threshold for tier 2 pricing band in tiered pricing models. Transactions between tier 1 and tier 2 thresholds use tier 2 rate.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier3RatePercent rdf:type rdf:Property ;
    rdfs:label 'Tier 3 Rate Percent' ;
    rdfs:comment 'MDR percentage applied to transactions above tier 2 threshold in tiered pricing models, expressed as a decimal.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionChannel rdf:type rdf:Property ;
    rdfs:label 'Transaction Channel' ;
    rdfs:comment 'Transaction channel or entry mode this MDR configuration applies to (e.g., card-present POS, ecommerce, mail/telephone order).' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msfScheduleId rdf:type rdf:Property ;
    rdfs:label 'Msf Schedule Id' ;
    rdfs:comment 'Unique identifier for the merchant service fee schedule record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MsfSchedule .

ind:annualFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Fee Amount' ;
    rdfs:comment 'Annual membership or service fee charged to the merchant.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avsFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Avs Fee Amount' ;
    rdfs:comment 'Fee charged per Address Verification System check performed during transaction authorization.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Batch Fee Amount' ;
    rdfs:comment 'Fee charged per batch settlement submission by the merchant.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Fee Amount' ;
    rdfs:comment 'Fee charged to the merchant for each chargeback dispute processed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Months' ;
    rdfs:comment 'Duration in months for which this fee schedule is contractually binding.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:durbinExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Durbin Exempt Flag' ;
    rdfs:comment 'Indicates whether this fee schedule applies to Durbin Amendment exempt transactions (small issuer or government/reloadable prepaid cards).' ;
    rdfs:domain ind:MsfSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earlyTerminationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Early Termination Fee Amount' ;
    rdfs:comment 'Fee charged if the merchant terminates the agreement before the contract term expires.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interchangePassThroughFlag rdf:type rdf:Property ;
    rdfs:label 'Interchange Pass Through Flag' ;
    rdfs:comment 'Indicates whether interchange fees are passed through to the merchant at cost (true) or bundled into the service fee (false).' ;
    rdfs:domain ind:MsfSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internationalTransactionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'International Transaction Fee Amount' ;
    rdfs:comment 'Additional fee charged for cross-border or international payment transactions.' ;
    rdfs:domain ind:MsfSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyAccountFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Account Fee Amount' ;
    rdfs:comment 'Fixed monthly account maintenance or service fee charged to the merchant.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyMinimumFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Minimum Fee Amount' ;
    rdfs:comment 'Minimum monthly fee that the merchant must pay regardless of transaction volume.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msfScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Msf Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the merchant service fee schedule.' ;
    rdfs:domain ind:MsfSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciComplianceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Pci Compliance Fee Amount' ;
    rdfs:comment 'Fee charged for PCI DSS compliance validation, scanning, or non-compliance penalties.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perTransactionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Per Transaction Fee Amount' ;
    rdfs:comment 'Fixed fee amount charged per transaction processed under this schedule.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentageRate rdf:type rdf:Property ;
    rdfs:label 'Percentage Rate' ;
    rdfs:comment 'Percentage rate applied to transaction amount as part of the merchant service fee (e.g., 2.5% represented as 0.02500).' ;
    rdfs:domain ind:MsfSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retrievalRequestFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Retrieval Request Fee Amount' ;
    rdfs:comment 'Fee charged for processing a retrieval request (pre-chargeback inquiry) from the issuing bank.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'Accounting method used to recognize revenue from this fee schedule (accrual, cash, deferred, straight-line).' ;
    rdfs:domain ind:MsfSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Business-friendly name or label for this merchant service fee schedule.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the fee schedule structure (standard, custom, promotional, tiered, interchange-plus, flat-rate).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Statement Fee Amount' ;
    rdfs:comment 'Fee charged for generating and delivering monthly or periodic account statements to the merchant.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voiceAuthorizationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Voice Authorization Fee Amount' ;
    rdfs:comment 'Fee charged when a merchant obtains authorization via phone rather than electronic terminal.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTierThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Threshold Amount' ;
    rdfs:comment 'Monthly transaction volume threshold amount that qualifies the merchant for this fee schedule tier.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTierThresholdCount rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Threshold Count' ;
    rdfs:comment 'Monthly transaction count threshold that qualifies the merchant for this fee schedule tier.' ;
    rdfs:domain ind:MsfSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:schemeFeeTableId rdf:type rdf:Property ;
    rdfs:label 'Scheme Fee Table Id' ;
    rdfs:comment 'Unique identifier for the scheme fee table record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SchemeFeeTable .

ind:volumeTierThresholdId rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Threshold Id' ;
    rdfs:comment 'Foreign key linking to interchange.volume_tier_threshold. Business justification: scheme_fee_table embeds volume tier bounds (volume_tier_lower_bound, volume_tier_upper_bound, volume_tier_unit) directly on the fee record. The volume_tier_threshold product is the authoritative SSOT ' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VolumeTierThreshold .

ind:assessmentBasis rdf:type rdf:Property ;
    rdfs:label 'Assessment Basis' ;
    rdfs:comment 'Basis on which assessment fees are calculated: gross volume (total transaction value including refunds), net volume (purchases minus refunds), or transaction count.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardProductType rdf:type rdf:Property ;
    rdfs:label 'Card Product Type' ;
    rdfs:comment 'Type of card product to which this fee applies: credit, debit, prepaid, commercial (business/corporate), or all card types.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalWalletIndicator rdf:type rdf:Property ;
    rdfs:label 'Digital Wallet Indicator' ;
    rdfs:comment 'Indicates whether this fee applies specifically to digital wallet or tokenized transactions (e.g., Apple Pay, Google Pay, Samsung Pay). True if digital-wallet-specific, false otherwise.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:domesticInternationalIndicator rdf:type rdf:Property ;
    rdfs:label 'Domestic International Indicator' ;
    rdfs:comment 'Specifies whether the fee applies to domestic transactions (same country acquirer/issuer), international (cross-border), or both.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCode rdf:type rdf:Property ;
    rdfs:label 'Fee Code' ;
    rdfs:comment 'Scheme-assigned alphanumeric code uniquely identifying this fee within the scheme\'s fee schedule.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the fee is denominated (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeDescription rdf:type rdf:Property ;
    rdfs:label 'Fee Description' ;
    rdfs:comment 'Detailed description of the fee purpose, calculation methodology, and any special conditions or exemptions as published by the card scheme.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeFixedAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Fixed Amount' ;
    rdfs:comment 'Fixed fee amount per transaction in the fee currency. Null if fee is not fixed-amount-based.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeName rdf:type rdf:Property ;
    rdfs:label 'Fee Name' ;
    rdfs:comment 'Descriptive name of the specific fee as published by the card scheme (e.g., \'Visa Assessment Fee\', \'Mastercard Cross-Border Volume Fee\', \'Amex Digital Enablement Fee\').' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Fee Rate Percentage' ;
    rdfs:comment 'Percentage rate applied to transaction value, expressed as decimal (e.g., 0.00125 for 12.5 basis points). Null if fee is not percentage-based.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeRateType rdf:type rdf:Property ;
    rdfs:label 'Fee Rate Type' ;
    rdfs:comment 'Structure of the fee calculation: percentage (basis points of transaction value), fixed (flat amount per transaction), tiered (volume-based brackets), or hybrid (combination).' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Fee Amount' ;
    rdfs:comment 'Maximum fee amount charged per transaction, capping percentage-based fees for high-value transactions.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mccRangeHigh rdf:type rdf:Property ;
    rdfs:label 'Mcc Range High' ;
    rdfs:comment 'Upper bound of MCC range to which this fee applies. Used for merchant-category-specific fees. Null if fee applies to all MCCs.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mccRangeLow rdf:type rdf:Property ;
    rdfs:label 'Mcc Range Low' ;
    rdfs:comment 'Lower bound of MCC range to which this fee applies. Used for merchant-category-specific fees. Null if fee applies to all MCCs.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Fee Amount' ;
    rdfs:comment 'Minimum fee amount charged per transaction, regardless of percentage calculation. Ensures floor for low-value transactions.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partyType rdf:type rdf:Property ;
    rdfs:label 'Party Type' ;
    rdfs:comment 'Indicates which party in the payment chain is charged this fee: acquirer (merchant\'s bank), issuer (cardholder\'s bank), or both.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeDSecureIndicator rdf:type rdf:Property ;
    rdfs:label 'Three D Secure Indicator' ;
    rdfs:comment 'Indicates whether this fee applies to transactions authenticated via 3-D Secure protocol (3DS 1.0 or 3DS 2.0). True if 3DS-specific, false otherwise.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:binInterchangeRuleId rdf:type rdf:Property ;
    rdfs:label 'Bin Interchange Rule Id' ;
    rdfs:comment 'Unique surrogate primary key identifying a BIN-level interchange qualification rule record in the silver layer lakehouse. Entity role: MASTER_RESOURCE — represents a configuration/rule resource governing interchange qualification for a BIN range.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BinInterchangeRule .

ind:supersededByRuleBinInterchangeRuleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rule Bin Interchange Rule Id' ;
    rdfs:comment 'Reference to the bin_interchange_rule_id of the newer rule that supersedes this record when rule_status is \'superseded\'. Enables rule lineage tracking and historical interchange qualification reconstruction.' ;
    rdfs:domain ind:BinInterchangeRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BinInterchangeRule .

ind:authorizationIndicator rdf:type rdf:Property ;
    rdfs:label 'Authorization Indicator' ;
    rdfs:comment 'Specifies the type of authorization associated with this interchange rule: pre-authorization (hotel/car rental), final authorization, or incremental authorization. Different authorization types may qualify for distinct interchange rates.' ;
    rdfs:domain ind:BinInterchangeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardNotPresentEligible rdf:type rdf:Property ;
    rdfs:label 'Card Not Present Eligible' ;
    rdfs:comment 'Indicates whether this interchange rule applies to card-not-present (CNP) transactions, such as e-commerce, mail order, or telephone order (MOTO) transactions. CNP transactions typically carry higher interchange rates due to elevated fraud risk.' ;
    rdfs:domain ind:BinInterchangeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cardPresentEligible rdf:type rdf:Property ;
    rdfs:label 'Card Present Eligible' ;
    rdfs:comment 'Indicates whether this interchange rule applies to card-present (CP) transactions, where the physical card or device is used at a POS or mPOS terminal. Card-present transactions typically qualify for lower interchange rates than card-not-present.' ;
    rdfs:domain ind:BinInterchangeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the issuing country associated with this BIN range (e.g., USA, GBR, DEU). Determines domestic vs. cross-border interchange rate applicability and regulatory jurisdiction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Border Flag' ;
    rdfs:comment 'Indicates whether this interchange rule applies specifically to cross-border transactions where the issuing country differs from the acquiring country. Cross-border transactions typically attract higher interchange rates and additional scheme fees.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataQualityIndicator rdf:type rdf:Property ;
    rdfs:label 'Data Quality Indicator' ;
    rdfs:comment 'Indicates the level of transaction data (Level 1, Level 2, Level 3) required for interchange qualification under this rule. Level 2/3 data (enhanced transaction detail for B2B/commercial cards) may qualify for lower interchange rates.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durbinExemptReason rdf:type rdf:Property ;
    rdfs:label 'Durbin Exempt Reason' ;
    rdfs:comment 'Reason code explaining why a BIN range is exempt from Durbin Amendment regulated interchange caps. Applicable only when durbin_regulated_flag is False. Small issuers (assets < $10B), government-administered programs, and certain prepaid products qualify for exemption.' ;
    rdfs:domain ind:BinInterchangeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installmentEligible rdf:type rdf:Property ;
    rdfs:label 'Installment Eligible' ;
    rdfs:comment 'Indicates whether this interchange rule applies to installment payment transactions, including BNPL (Buy Now Pay Later) arrangements. Installment transactions may carry distinct interchange qualification criteria.' ;
    rdfs:domain ind:BinInterchangeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interchangeFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Interchange Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the interchange fixed fee is denominated (e.g., USD, EUR, GBP). Required for cross-border interchange cost calculations and multi-currency acquiring portfolios.' ;
    rdfs:domain ind:BinInterchangeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeFixedFee rdf:type rdf:Property ;
    rdfs:label 'Interchange Fixed Fee' ;
    rdfs:comment 'The fixed per-transaction fee component of the interchange, expressed in the applicable currency (e.g., 0.1000 = $0.10 per transaction). Combined with interchange_rate_percent to compute total interchange cost per transaction.' ;
    rdfs:domain ind:BinInterchangeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interchangeRatePercent rdf:type rdf:Property ;
    rdfs:label 'Interchange Rate Percent' ;
    rdfs:comment 'The percentage-based component of the interchange fee applied to the transaction amount for qualifying transactions under this BIN rule (e.g., 1.6500 represents 1.65%). Used in cost-of-acceptance calculations for acquiring portfolios. Serves as the MEASUREMENT_OR_VALUE for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:BinInterchangeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mccList rdf:type rdf:Property ;
    rdfs:label 'Mcc List' ;
    rdfs:comment 'Comma-separated list of MCC (Merchant Category Code) values that are included or excluded from this interchange rule, as determined by mcc_restriction_type. For example, \'5411,5412,5499\' for grocery MCCs. Null when mcc_restriction_type is \'all\'.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mccRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Mcc Restriction Type' ;
    rdfs:comment 'Defines how MCC (Merchant Category Code) restrictions apply to this interchange rule: \'all\' means no MCC restriction (applies to all MCCs), \'include\' means only specified MCCs qualify, \'exclude\' means specified MCCs are excluded, \'none\' means no transactions qualify regardless of MCC.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurringEligible rdf:type rdf:Property ;
    rdfs:label 'Recurring Eligible' ;
    rdfs:comment 'Indicates whether this interchange rule applies to recurring or subscription-based transactions. Recurring transactions may qualify for specific interchange programs with distinct rate structures.' ;
    rdfs:domain ind:BinInterchangeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemRuleRef rdf:type rdf:Property ;
    rdfs:label 'Source System Rule Ref' ;
    rdfs:comment 'The native rule identifier or reference code from the originating operational system (Transaction Processing Platform or Payment Gateway) from which this BIN interchange rule was sourced. Supports data lineage and reconciliation back to the system of record.' ;
    rdfs:domain ind:BinInterchangeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeDsRequired rdf:type rdf:Property ;
    rdfs:label 'Three Ds Required' ;
    rdfs:comment 'Indicates whether 3-D Secure (3DS) authentication is required for card-not-present transactions to qualify for this interchange rate. 3DS-authenticated transactions may qualify for lower interchange rates and shift fraud liability to the issuer. Relevant under PSD2 SCA requirements.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tokenizationEligible rdf:type rdf:Property ;
    rdfs:label 'Tokenization Eligible' ;
    rdfs:comment 'Indicates whether transactions using a DPAN (Device Primary Account Number) or network token issued by a TSP (Token Service Provider) for this BIN range are eligible for this interchange rate. Tokenized transactions may qualify for distinct interchange rates.' ;
    rdfs:domain ind:BinInterchangeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionMaxAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Max Amount' ;
    rdfs:comment 'Maximum transaction amount (in the fee currency) eligible for this interchange rate category. Transactions exceeding this threshold may be subject to different interchange rates or require additional qualification criteria.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionMinAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Min Amount' ;
    rdfs:comment 'Minimum transaction amount (in the fee currency) required for a transaction to qualify for this interchange rate category. Transactions below this threshold may downgrade to a less favorable interchange tier.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationId rdf:type rdf:Property ;
    rdfs:label 'Qualification Id' ;
    rdfs:comment 'Unique identifier for the interchange qualification record. Primary key for this transactional record of interchange rate qualification outcome.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Qualification .

ind:cardholderPartyId rdf:type rdf:Property ;
    rdfs:label 'Cardholder Party Id' ;
    rdfs:comment 'Foreign key linking to compliance.party. Business justification: Interchange qualification for high-value or cross-border transactions requires cardholder compliance checks (sanctions screening, PEP status). Real business process: enhanced due diligence on transact' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Foreign key linking to merchant.merchant_location. Business justification: Interchange qualification occurs at the transaction level, which maps to a specific merchant location. Linking qualification to merchant_location enables location-level interchange qualification analy' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:settlementCycleId rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle Id' ;
    rdfs:comment 'Foreign key linking to settlement.cycle. Business justification: Enables qualification data to be associated with the settlement cycle used in interchange fee calculations and audit trails.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cycle .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'Date on which the transaction was authorized. Time between authorization and settlement is a factor in interchange qualification.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:avsResultCode rdf:type rdf:Property ;
    rdfs:label 'Avs Result Code' ;
    rdfs:comment 'Result code from address verification system check performed during authorization. AVS match is a qualifying criterion for many card-not-present interchange categories.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Card Present Flag' ;
    rdfs:comment 'Indicates whether the transaction was card-present (face-to-face) or card-not-present (e-commerce, mail order, phone order). Card-present transactions typically qualify for lower interchange rates.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactlessFlag rdf:type rdf:Property ;
    rdfs:label 'Contactless Flag' ;
    rdfs:comment 'Indicates whether the transaction was processed using contactless NFC technology (tap-to-pay). Contactless transactions may qualify for specific interchange categories.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cvvResultCode rdf:type rdf:Property ;
    rdfs:label 'Cvv Result Code' ;
    rdfs:comment 'Result code from CVV verification performed during authorization. CVV match is a qualifying criterion for card-not-present transactions to achieve optimal interchange rates.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downgradeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Downgrade Reason Code' ;
    rdfs:comment 'Code indicating why the transaction was downgraded to a higher interchange rate category. Null if transaction qualified for optimal rate. Common reasons include missing AVS, non-EMV, delayed settlement, or missing Level 2/3 data.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downgradeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Downgrade Reason Description' ;
    rdfs:comment 'Human-readable description of why the transaction was downgraded, providing detail on the specific qualification criteria that were not met.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emvChipFlag rdf:type rdf:Property ;
    rdfs:label 'Emv Chip Flag' ;
    rdfs:comment 'Indicates whether the transaction was processed using EMV chip technology. EMV transactions typically qualify for preferential interchange rates due to enhanced security.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irfFixedAmount rdf:type rdf:Property ;
    rdfs:label 'Irf Fixed Amount' ;
    rdfs:comment 'The fixed fee component of the qualified interchange fee applied to the transaction. Expressed in the settlement currency.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irfRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Irf Rate Percentage' ;
    rdfs:comment 'The percentage rate component of the qualified interchange fee applied to the transaction amount. Expressed as a decimal (e.g., 0.0175 for 1.75%).' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:level2DataPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Level 2 Data Present Flag' ;
    rdfs:comment 'Indicates whether Level 2 enhanced data (tax amount, customer code, etc.) was provided with the transaction. Level 2 data is required for commercial card interchange optimization.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:level3DataPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Level 3 Data Present Flag' ;
    rdfs:comment 'Indicates whether Level 3 line-item data (item descriptions, quantities, unit costs) was provided with the transaction. Level 3 data is required for optimal commercial and purchasing card interchange rates.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Status indicating whether the transaction qualified for the optimal interchange rate, was downgraded to a higher-cost tier, is exempt from interchange, or encountered an error during qualification.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qualification Timestamp' ;
    rdfs:comment 'Timestamp when the interchange qualification process was executed and the IRF category was determined. Represents the business event time of qualification.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'Date on which the transaction was settled and interchange fees were calculated and transferred between acquiring and issuing banks. Delayed settlement can result in interchange downgrades.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:threeDsAuthenticationFlag rdf:type rdf:Property ;
    rdfs:label 'Three Ds Authentication Flag' ;
    rdfs:comment 'Indicates whether the transaction was authenticated using 3-D Secure protocol (Verified by Visa, Mastercard SecureCode). 3DS authentication is a qualifying criterion for e-commerce interchange optimization.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'The gross transaction amount on which the interchange fee was calculated. Expressed in the transaction currency before any currency conversion.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the original transaction amount. May differ from settlement currency if cross-border transaction.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Foreign key linking to partner.agreement. Business justification: Billing cycles reference specific partner agreements for contract terms, rate schedules, and revenue share calculations. Critical for reconciliation, compliance audits, and dispute resolution in payme' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:schemeInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Scheme Invoice Id' ;
    rdfs:comment 'Foreign key linking to interchange.scheme_invoice. Business justification: Interchange billing records are associated with a scheme invoice; adds scheme_invoice_id FK' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SchemeInvoice .

ind:billingStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Status' ;
    rdfs:comment 'Current lifecycle status of the interchange billing record indicating its processing state. [ENUM-REF-CANDIDATE: DRAFT|PENDING|BILLED|SETTLED|DISPUTED|ADJUSTED|CANCELLED — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleIdentifier rdf:type rdf:Property ;
    rdfs:label 'Cycle Identifier' ;
    rdfs:comment 'A code or identifier representing the billing cycle frequency and sequence (e.g., monthly, weekly) for this interchange billing.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyAmount rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Amount' ;
    rdfs:comment 'The monetary difference identified during reconciliation between the billed amount and expected amount, if any.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'The date on which this interchange billing transaction was posted to the General Ledger in the ERP system.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossInterchangeAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Interchange Amount' ;
    rdfs:comment 'The total gross Interchange Reimbursement Fee (IRF) amount before any deductions or adjustments for the billing period.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interchangeQualificationTier rdf:type rdf:Property ;
    rdfs:label 'Interchange Qualification Tier' ;
    rdfs:comment 'The interchange rate qualification tier applied to the transactions in this billing, determining the applicable IRF rate structure.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Settlement Amount' ;
    rdfs:comment 'The final net amount to be settled between acquirer and issuer after all fees, adjustments, and deductions. This is the amount billed or credited.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The end date of the billing period for which interchange fees are calculated and billed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The start date of the billing period for which interchange fees are calculated and billed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status of the reconciliation process comparing this billing record against the card scheme\'s invoice and internal transaction records.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'The accounting date on which the interchange revenue or expense is recognized in the financial statements.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costOfAcceptanceId rdf:type rdf:Property ;
    rdfs:label 'Cost Of Acceptance Id' ;
    rdfs:comment 'Unique identifier for the cost of acceptance record.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountingPeriodId rdf:type rdf:Property ;
    rdfs:label 'Accounting Period Id' ;
    rdfs:comment 'Reference to the settlement period during which these costs were incurred.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountingPeriod .

ind:complianceCaseId rdf:type rdf:Property ;
    rdfs:label 'Compliance Case Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_case. Business justification: Cost-of-acceptance analysis is often triggered by compliance cases investigating pricing exceptions, merchant complaints, or regulatory inquiries. Real business process: compliance investigations requ' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceCase .

ind:averageTicketSize rdf:type rdf:Property ;
    rdfs:label 'Average Ticket Size' ;
    rdfs:comment 'Average transaction amount calculated as gross transaction volume divided by transaction count.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:binRangeCount rdf:type rdf:Property ;
    rdfs:label 'Bin Range Count' ;
    rdfs:comment 'Number of distinct Bank Identification Number (BIN) or Issuer Identification Number (IIN) ranges represented in the transactions for this settlement period.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calculationDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Date' ;
    rdfs:comment 'The date on which the cost of acceptance calculation was performed.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'The pricing model or calculation method used to determine the cost of acceptance for this merchant.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardNotPresentVolume rdf:type rdf:Property ;
    rdfs:label 'Card Not Present Volume' ;
    rdfs:comment 'Total transaction volume for card-not-present (CNP) transactions processed via e-commerce, mail order, or telephone order channels.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cardPresentVolume rdf:type rdf:Property ;
    rdfs:label 'Card Present Volume' ;
    rdfs:comment 'Total transaction volume for card-present (CP) transactions processed via Point of Sale (POS) or mobile Point of Sale (mPOS) terminals.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackVolume rdf:type rdf:Property ;
    rdfs:label 'Chargeback Volume' ;
    rdfs:comment 'Total transaction volume associated with chargebacks initiated during the settlement period, impacting net margin calculations.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costOfAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Of Acceptance Status' ;
    rdfs:comment 'Current lifecycle status of the cost of acceptance record indicating its processing state.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCardVolume rdf:type rdf:Property ;
    rdfs:label 'Credit Card Volume' ;
    rdfs:comment 'Total transaction volume processed using credit cards during the settlement period.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossBorderVolume rdf:type rdf:Property ;
    rdfs:label 'Cross Border Volume' ;
    rdfs:comment 'Total transaction volume for cross-border transactions where the issuing bank country differs from the acquiring bank country.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitCardVolume rdf:type rdf:Property ;
    rdfs:label 'Debit Card Volume' ;
    rdfs:comment 'Total transaction volume processed using debit cards during the settlement period.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:domesticVolume rdf:type rdf:Property ;
    rdfs:label 'Domestic Volume' ;
    rdfs:comment 'Total transaction volume for domestic transactions where the issuing bank and acquiring bank are in the same country.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveRateBps rdf:type rdf:Property ;
    rdfs:label 'Effective Rate Bps' ;
    rdfs:comment 'Effective cost of acceptance rate expressed in basis points (bps), calculated as (total cost / gross transaction volume) * 10000.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossTransactionVolume rdf:type rdf:Property ;
    rdfs:label 'Gross Transaction Volume' ;
    rdfs:comment 'Total Payment Volume (TPV) representing the gross value of all transactions processed during the settlement period before any fees or deductions.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mdrPercentage rdf:type rdf:Property ;
    rdfs:label 'Mdr Percentage' ;
    rdfs:comment 'Merchant Discount Rate (MDR) percentage applied to the merchant for this settlement period, representing the total fee as a percentage of transaction volume.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netMargin rdf:type rdf:Property ;
    rdfs:label 'Net Margin' ;
    rdfs:comment 'Net margin calculated as total MSF revenue minus total interchange cost and total scheme fees, representing the acquiring portfolio profitability.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundVolume rdf:type rdf:Property ;
    rdfs:label 'Refund Volume' ;
    rdfs:comment 'Total transaction volume associated with refunds processed during the settlement period.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementEndDate rdf:type rdf:Property ;
    rdfs:label 'Settlement End Date' ;
    rdfs:comment 'The end date of the settlement period covered by this cost of acceptance record.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementStartDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Start Date' ;
    rdfs:comment 'The start date of the settlement period covered by this cost of acceptance record.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalInterchangeCost rdf:type rdf:Property ;
    rdfs:label 'Total Interchange Cost' ;
    rdfs:comment 'Total Interchange Reimbursement Fee (IRF) paid to issuing banks for all transactions during the settlement period.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMsfRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Msf Revenue' ;
    rdfs:comment 'Total Merchant Service Fee (MSF) revenue collected from the merchant for payment processing services during the settlement period.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSchemeFees rdf:type rdf:Property ;
    rdfs:label 'Total Scheme Fees' ;
    rdfs:comment 'Total assessment fees charged by card schemes (Visa, Mastercard, etc.) for network usage during the settlement period.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCount rdf:type rdf:Property ;
    rdfs:label 'Transaction Count' ;
    rdfs:comment 'Total number of transactions processed for the merchant during the settlement period.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downgradeId rdf:type rdf:Property ;
    rdfs:label 'Downgrade Id' ;
    rdfs:comment 'Unique identifier for the interchange downgrade event.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Downgrade .

ind:acquirerReferenceData rdf:type rdf:Property ;
    rdfs:label 'Acquirer Reference Data' ;
    rdfs:comment 'Additional reference data provided by the acquiring bank for tracking and reconciliation purposes.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorization Timestamp' ;
    rdfs:comment 'The precise date and time when the transaction was authorized by the issuing bank.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:avsResponseCode rdf:type rdf:Property ;
    rdfs:label 'Avs Response Code' ;
    rdfs:comment 'Code returned by the issuer indicating the result of address verification, which is often required for optimal interchange qualification.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Capture Timestamp' ;
    rdfs:comment 'The precise date and time when the authorized transaction was captured for settlement.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cvvResponseCode rdf:type rdf:Property ;
    rdfs:label 'Cvv Response Code' ;
    rdfs:comment 'Code returned by the issuer indicating the result of CVV verification, which is often required for optimal interchange qualification in card-not-present transactions.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'The date and time when the interchange downgrade was identified and recorded in the system.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downgradedIrfRateBps rdf:type rdf:Property ;
    rdfs:label 'Downgraded Irf Rate Bps' ;
    rdfs:comment 'The actual interchange rate in basis points applied after the downgrade, representing a higher cost to the merchant.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emvChipTransaction rdf:type rdf:Property ;
    rdfs:label 'Emv Chip Transaction' ;
    rdfs:comment 'Flag indicating whether the transaction used EMV chip technology, which typically qualifies for lower interchange rates.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incrementalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Incremental Cost Amount' ;
    rdfs:comment 'The additional interchange fee cost incurred by the merchant due to the downgrade, calculated as the rate differential applied to the transaction amount.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incrementalCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Incremental Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the incremental cost amount.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantProcessingChannel rdf:type rdf:Property ;
    rdfs:label 'Merchant Processing Channel' ;
    rdfs:comment 'The channel through which the transaction was processed, affecting interchange qualification criteria.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalIrfRateBps rdf:type rdf:Property ;
    rdfs:label 'Original Irf Rate Bps' ;
    rdfs:comment 'The optimal interchange rate in basis points that would have applied if the transaction had not been downgraded.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preventableFlag rdf:type rdf:Property ;
    rdfs:label 'Preventable Flag' ;
    rdfs:comment 'Indicates whether the downgrade could have been prevented through merchant action or system configuration changes.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateDifferentialBps rdf:type rdf:Property ;
    rdfs:label 'Rate Differential Bps' ;
    rdfs:comment 'The difference in basis points between the downgraded rate and the original qualified rate, representing the incremental cost penalty.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remediationActionRecommended rdf:type rdf:Property ;
    rdfs:label 'Remediation Action Recommended' ;
    rdfs:comment 'Suggested corrective action for the merchant to prevent future downgrades of this type, used for merchant coaching and optimization.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementDelayDays rdf:type rdf:Property ;
    rdfs:label 'Settlement Delay Days' ;
    rdfs:comment 'Number of days between authorization and settlement, where excessive delay can trigger interchange downgrades.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:threeDsAuthenticationStatus rdf:type rdf:Property ;
    rdfs:label 'Three Ds Authentication Status' ;
    rdfs:comment 'Status of 3-D Secure authentication for the transaction, which can affect interchange qualification for e-commerce transactions.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payableId rdf:type rdf:Property ;
    rdfs:label 'Payable Id' ;
    rdfs:comment 'Foreign key linking to ledger.payable. Business justification: Scheme invoices become payables in the ledger - natural accounts payable workflow. Links scheme billing to AP processing, payment scheduling, and cash management.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payable .

ind:settlementAccountId rdf:type rdf:Property ;
    rdfs:label 'Settlement Account Id' ;
    rdfs:comment 'Foreign key linking to settlement.settlement_account. Business justification: Scheme invoices are paid from/to designated settlement accounts. The payment of scheme fees requires knowing which settlement account is debited/credited — a core treasury and scheme fee payment opera' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SettlementAccount .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'The last date of the billing period covered by this scheme invoice. Defines the end of the time window for which fees and assessments are being charged.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'The first date of the billing period covered by this scheme invoice. Defines the beginning of the time window for which fees and assessments are being charged.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargebackProcessingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Processing Fee Amount' ;
    rdfs:comment 'The portion of the invoice representing fees charged by the card scheme for processing chargebacks and disputes during the billing period. Includes fees for dispute lifecycle management and arbitration services.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compliancePenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Compliance Penalty Amount' ;
    rdfs:comment 'The portion of the invoice representing penalties or fines assessed by the card scheme for non-compliance with network rules, PCI DSS requirements, or other regulatory standards. Zero if no penalties were assessed.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The cost center or business unit code responsible for this scheme invoice expense. Used for internal cost allocation and management reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Cross Border Fee Amount' ;
    rdfs:comment 'The portion of the invoice representing fees charged for cross-border or international transactions where the issuing bank and acquiring bank are in different countries or regions.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'The date on which this invoice was formally disputed with the card scheme. Null if invoice has not been disputed.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:comment 'The reason code provided if this invoice is disputed. Indicates the nature of the dispute (e.g., incorrect fee calculation, unrecognized charges, billing error). Null if invoice is not disputed.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'The date on which the dispute for this invoice was resolved. Null if dispute is still open or if invoice was never disputed.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interchangeReimbursementFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Interchange Reimbursement Fee Amount' ;
    rdfs:comment 'The portion of the invoice representing Interchange Reimbursement Fees (IRF) paid between acquiring and issuing banks through the card scheme. This is the fee paid by the acquiring bank to the issuing bank for each transaction.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Invoice Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which this scheme invoice is denominated. All monetary amounts on this invoice are expressed in this currency.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date on which the card scheme issued this invoice. This is the principal business event timestamp representing when the billing statement was generated and sent.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Invoice Document Url' ;
    rdfs:comment 'The URL or file path to the original invoice document (PDF or other format) provided by the card scheme. Used for audit trail and detailed line-item review.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The externally-known unique invoice number assigned by the card scheme (Visa, Mastercard, Amex, Discover) for this billing statement. This is the business identifier used for reconciliation and payment reference.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the scheme invoice indicating its payment and processing state. Tracks the invoice from issuance through payment completion or dispute resolution.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkParticipationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Network Participation Fee Amount' ;
    rdfs:comment 'The portion of the invoice representing fees charged for participation in the card scheme network. This is a recurring membership or access fee for being part of the payment network.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The payment instrument or method used to settle this scheme invoice. Indicates how the payment was made to the card scheme.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'The unique reference number or transaction identifier for the payment made to settle this invoice. Used for payment reconciliation and audit trail. Null if invoice is unpaid.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationReference rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Reference' ;
    rdfs:comment 'The reference identifier linking this scheme invoice to the internal reconciliation record or general ledger entry. Used to track the invoice through the accounts payable and financial close process.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeServiceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Scheme Service Fee Amount' ;
    rdfs:comment 'The portion of the invoice representing fees for specific card scheme services such as tokenization, fraud prevention, dispute resolution, or other value-added services provided by the network.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'The total amount of taxes (VAT, GST, sales tax, or other applicable taxes) applied to this scheme invoice. Zero if no taxes are applicable.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmountDue rdf:type rdf:Property ;
    rdfs:label 'Total Amount Due' ;
    rdfs:comment 'The total amount payable to the card scheme for this invoice, representing the sum of all line-item fees, assessments, and charges. This is the net total amount due before any adjustments or credits.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionValue rdf:type rdf:Property ;
    rdfs:label 'Transaction Value' ;
    rdfs:comment 'The total monetary value of all transactions processed through the card scheme network during the billing period, expressed in the invoice currency. Represents the Total Payment Volume (TPV) or Gross Merchandise Value (GMV) for fee calculation purposes.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionVolume rdf:type rdf:Property ;
    rdfs:label 'Transaction Volume' ;
    rdfs:comment 'The total number of transactions processed through the card scheme network during the billing period covered by this invoice. Used to validate volume-based fee calculations.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'The user ID or system identifier of the person or process that last modified this scheme invoice record. Used for audit trail and accountability.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyId rdf:type rdf:Property ;
    rdfs:label 'Policy Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_policy. Business justification: Interchange programs embed risk policies. Program eligibility requires risk policy compliance (e.g., Durbin regulation, installment eligibility, cross-border restrictions). Essential for program confi' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:regulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_obligation. Business justification: Program eligibility and rate structures must comply with specific regulatory obligations; linking enables compliance checks and reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'True if enrollment into the program requires manual approval.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Timestamp when the program was approved for activation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cardNotPresentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Card Not Present Eligible Flag' ;
    rdfs:comment 'True if card-not-present (e-commerce) transactions are eligible.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cardPresentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Card Present Eligible Flag' ;
    rdfs:comment 'True if card-present (in-store) transactions are eligible.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cardTypeEligibility rdf:type rdf:Property ;
    rdfs:label 'Card Type Eligibility' ;
    rdfs:comment 'Card types that qualify for the program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Border Eligible Flag' ;
    rdfs:comment 'True if transactions crossing national borders qualify for the program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityCriteriaDescription rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria Description' ;
    rdfs:comment 'Detailed rules that determine transaction qualification for the program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentRequirements rdf:type rdf:Property ;
    rdfs:label 'Enrollment Requirements' ;
    rdfs:comment 'Textual description of the criteria a merchant or issuer must satisfy to enroll in the program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Fee Amount' ;
    rdfs:comment 'Flat fee amount charged per transaction under this program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installmentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Installment Eligible Flag' ;
    rdfs:comment 'True if installment-based transactions qualify.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mccEligibility rdf:type rdf:Property ;
    rdfs:label 'Mcc Eligibility' ;
    rdfs:comment 'Merchant category codes (MCC) that are eligible for the program. Multiple codes may be stored as a delimited list.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'External code used to identify the interchange program in scheme documentation.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Human-readable name of the interchange program.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the interchange program.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCriteriaCode rdf:type rdf:Property ;
    rdfs:label 'Qualification Criteria Code' ;
    rdfs:comment 'Code referencing a detailed rule set that defines qualification logic.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePercentage rdf:type rdf:Property ;
    rdfs:label 'Rate Percentage' ;
    rdfs:comment 'Percentage of transaction amount charged as interchange under this program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateStructureType rdf:type rdf:Property ;
    rdfs:label 'Rate Structure Type' ;
    rdfs:comment 'Indicates whether the program uses a percentage rate, a fixed fee, or a combination.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurringEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Recurring Eligible Flag' ;
    rdfs:comment 'True if recurring (subscription) transactions qualify.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierLevel rdf:type rdf:Property ;
    rdfs:label 'Tier Level' ;
    rdfs:comment 'Tier classification that determines rate structure.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenizationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Tokenization Eligible Flag' ;
    rdfs:comment 'True if tokenized card transactions are eligible under the program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossBorderFeeRuleId rdf:type rdf:Property ;
    rdfs:label 'Cross Border Fee Rule Id' ;
    rdfs:comment 'Unique identifier for the cross-border fee rule record. Primary key for this entity.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrossBorderFeeRule .

ind:paymentCorridorId rdf:type rdf:Property ;
    rdfs:label 'Payment Corridor Id' ;
    rdfs:comment 'Foreign key linking to fx.payment_corridor. Business justification: Cross-border fee rules map to payment corridors defining country-currency-rail combinations. Essential for corridor-based fee routing, regulatory compliance, and settlement path determination in cross' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentCorridor .

ind:supersededByRuleCrossBorderFeeRuleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rule Cross Border Fee Rule Id' ;
    rdfs:comment 'Reference to the cross-border fee rule that replaces this rule when it is superseded. Supports rule lineage and historical analysis.' ;
    rdfs:domain ind:CrossBorderFeeRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrossBorderFeeRule .

ind:crossBorderAssessmentRatePercent rdf:type rdf:Property ;
    rdfs:label 'Cross Border Assessment Rate Percent' ;
    rdfs:comment 'Percentage-based cross-border assessment fee applied to the transaction amount when the issuing country differs from the acquiring country. Expressed as a decimal percentage (e.g., 1.25000 for 1.25%).' ;
    rdfs:domain ind:CrossBorderFeeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossBorderFixedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Cross Border Fixed Fee Amount' ;
    rdfs:comment 'Fixed monetary fee applied per cross-border transaction, independent of transaction amount. Used in conjunction with or as an alternative to percentage-based fees.' ;
    rdfs:domain ind:CrossBorderFeeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyConversionFeeRatePercent rdf:type rdf:Property ;
    rdfs:label 'Currency Conversion Fee Rate Percent' ;
    rdfs:comment 'Percentage-based fee applied when currency conversion occurs in a cross-border transaction. Represents the FX markup over the wholesale exchange rate.' ;
    rdfs:domain ind:CrossBorderFeeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dccFeeRatePercent rdf:type rdf:Property ;
    rdfs:label 'Dcc Fee Rate Percent' ;
    rdfs:comment 'Fee rate applied when Dynamic Currency Conversion is offered at the point of sale, allowing the cardholder to see the transaction amount in their home currency.' ;
    rdfs:domain ind:CrossBorderFeeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the destination country (typically the issuing country or cardholder country of residence).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationRegionCode rdf:type rdf:Property ;
    rdfs:label 'Destination Region Code' ;
    rdfs:comment 'Regional grouping code for the destination country used for regional cross-border fee structures and compliance segmentation.' ;
    rdfs:domain ind:CrossBorderFeeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Originating Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country where the transaction originates (typically the acquiring country or merchant location country).' ;
    rdfs:domain ind:CrossBorderFeeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingRegionCode rdf:type rdf:Property ;
    rdfs:label 'Originating Region Code' ;
    rdfs:comment 'Regional grouping code for the originating country (e.g., EEA, NAFTA, APAC) used for regional cross-border fee structures.' ;
    rdfs:domain ind:CrossBorderFeeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether this cross-border fee rule is subject to specific regulatory compliance requirements (e.g., PSD2 in EU, Durbin Amendment caps).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Name of the regulatory framework or jurisdiction-specific regulation governing this cross-border fee rule (e.g., PSD2, Regulation II, local central bank rules).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftCorrespondentFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Swift Correspondent Fee Amount' ;
    rdfs:comment 'Fixed fee component for SWIFT messaging and correspondent banking services used in cross-border settlement. Applies when international wire transfers are required for settlement.' ;
    rdfs:domain ind:CrossBorderFeeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingExceptionId rdf:type rdf:Property ;
    rdfs:label 'Pricing Exception Id' ;
    rdfs:comment 'Unique identifier for the pricing exception record. Primary key for the pricing exception entity.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingException .

ind:merchantPricingPlanId rdf:type rdf:Property ;
    rdfs:label 'Merchant Pricing Plan Id' ;
    rdfs:comment 'Foreign key linking to merchant.merchant_pricing_plan. Business justification: A pricing exception overrides or modifies a standard merchant pricing plan. Linking pricing_exception to merchant_pricing_plan is required for contract management, exception approval workflows, and re' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchantPricingPlan .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name or title of the executive or committee that authorized this pricing exception (e.g., Chief Revenue Officer, Pricing Committee, Regional VP).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date on which this pricing exception was formally approved by the designated authority.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether this pricing exception automatically renews at the end of its term. True means exception continues unless terminated, false means it expires on effective_end_date.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Detailed explanation of the business rationale for granting this exception, including competitive factors, strategic value, volume commitments, or relationship considerations.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Date' ;
    rdfs:comment 'Date of the most recent compliance review of this exception to ensure it meets regulatory requirements, internal policy, and audit standards.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Unique business code identifying this pricing exception for reference in contracts, invoices, and reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionFixedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Exception Fixed Fee Amount' ;
    rdfs:comment 'The negotiated per-transaction fixed fee granted under this exception. May be zero for full waiver.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionName rdf:type rdf:Property ;
    rdfs:label 'Exception Name' ;
    rdfs:comment 'Descriptive name for the pricing exception, typically referencing the merchant, partner, or program name.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Exception Rate Percent' ;
    rdfs:comment 'The negotiated exception rate granted to the merchant, portfolio, or partner. Expressed as decimal (e.g., 0.0225 for 2.25%).' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Status' ;
    rdfs:comment 'Current lifecycle status of the pricing exception. Draft is under construction, pending_approval awaits authorization, active is in force, suspended is temporarily inactive, expired has passed end date, terminated was cancelled before expiry.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionType rdf:type rdf:Property ;
    rdfs:label 'Exception Type' ;
    rdfs:comment 'Category of pricing exception granted. MDR discount reduces merchant discount rate, MSF waiver eliminates merchant service fees, IRF adjustment modifies interchange reimbursement fee pass-through, volume incentive provides tiered pricing based on transaction volume, promotional is temporary campaign pricing, custom is bespoke arrangement.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Max Transaction Amount' ;
    rdfs:comment 'The maximum transaction amount for which this exception applies. Null if no maximum threshold.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mccScope rdf:type rdf:Property ;
    rdfs:label 'Mcc Scope' ;
    rdfs:comment 'Defines whether the exception applies to specific MCC codes, a range of MCCs, or all merchant categories.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Min Transaction Amount' ;
    rdfs:comment 'The minimum transaction amount required for this exception to apply. Null if no minimum threshold.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateDiscountBps rdf:type rdf:Property ;
    rdfs:label 'Rate Discount Bps' ;
    rdfs:comment 'The discount granted expressed in basis points (1 bps = 0.01%). Calculated as (standard_rate_percent - exception_rate_percent) * 10000. Used for revenue impact analysis.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the revenue impact estimate.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Estimate' ;
    rdfs:comment 'Estimated annual revenue impact (reduction) of granting this exception, calculated at time of approval. Used for financial planning and exception portfolio management.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardFixedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Fixed Fee Amount' ;
    rdfs:comment 'The standard per-transaction fixed fee (Merchant Service Fee component) that would normally apply before the exception.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardRatePercent rdf:type rdf:Property ;
    rdfs:label 'Standard Rate Percent' ;
    rdfs:comment 'The standard Merchant Discount Rate (MDR) or percentage-based fee that would normally apply before the exception. Expressed as decimal (e.g., 0.0275 for 2.75%).' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required to terminate this pricing exception, as specified in the contract.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeTierCurrency rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the volume tier threshold.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByTierVolumeTierThresholdId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Tier Volume Tier Threshold Id' ;
    rdfs:comment 'Reference to the volume_tier_threshold_id that replaces this configuration when a new version is published. Null if this is the current active version.' ;
    rdfs:domain ind:VolumeTierThreshold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VolumeTierThreshold .

ind:applicableFixedFee rdf:type rdf:Property ;
    rdfs:label 'Applicable Fixed Fee' ;
    rdfs:comment 'Fixed fee amount per transaction that applies when this tier threshold is met.' ;
    rdfs:domain ind:VolumeTierThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableRatePercent rdf:type rdf:Property ;
    rdfs:label 'Applicable Rate Percent' ;
    rdfs:comment 'Interchange rate percentage or MDR percentage that applies when this tier threshold is met. Expressed as decimal (e.g., 0.0250 for 2.50%).' ;
    rdfs:domain ind:VolumeTierThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountRatePercent rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Percent' ;
    rdfs:comment 'Discount percentage applied to standard rates when merchant qualifies for this volume tier. Expressed as decimal (e.g., 0.0050 for 0.50% discount).' ;
    rdfs:domain ind:VolumeTierThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerBound rdf:type rdf:Property ;
    rdfs:label 'Lower Bound' ;
    rdfs:comment 'Minimum volume threshold value required to qualify for this tier (inclusive). Null indicates no lower limit.' ;
    rdfs:domain ind:VolumeTierThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPeriod rdf:type rdf:Property ;
    rdfs:label 'Measurement Period' ;
    rdfs:comment 'Time period over which volume is measured to determine tier qualification (e.g., monthly, quarterly, annual, rolling 30 days). [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|annual|rolling_30_days|rolling_90_days — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VolumeTierThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Unit of measure for the threshold bounds (count for transaction volume, currency_amount for TPV, percentage for rate-based thresholds).' ;
    rdfs:domain ind:VolumeTierThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Amount' ;
    rdfs:comment 'Fixed rebate amount provided to merchant or issuer when this volume tier is achieved during the measurement period.' ;
    rdfs:domain ind:VolumeTierThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdType rdf:type rdf:Property ;
    rdfs:label 'Threshold Type' ;
    rdfs:comment 'Type of volume measurement used to determine tier qualification (transaction count, TPV amount, monthly volume, annual volume, or quarterly volume).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Business identifier code for the volume tier (e.g., TIER_1, TIER_GOLD, TIER_PLATINUM).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Human-readable name of the volume tier (e.g., Bronze, Silver, Gold, Platinum).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Status' ;
    rdfs:comment 'Current lifecycle status of the volume tier threshold configuration.' ;
    rdfs:domain ind:VolumeTierThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperBound rdf:type rdf:Property ;
    rdfs:label 'Upper Bound' ;
    rdfs:comment 'Maximum volume threshold value for this tier (exclusive). Null indicates no upper limit.' ;
    rdfs:domain ind:VolumeTierThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultIrfRateCategoryId rdf:type rdf:Property ;
    rdfs:label 'Default Irf Rate Category Id' ;
    rdfs:comment 'Foreign key linking to interchange.irf_rate_category. Business justification: Pricing engine needs a default IRF rate category per merchant to calculate fees; merchants are enrolled in a rate category for fee simulation and reporting.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IrfRateCategory .

ind:jurisdictionProfileId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Profile Id' ;
    rdfs:comment 'Foreign key linking to compliance.jurisdiction_profile. Business justification: Merchants operate under jurisdiction-specific AML/CTF regimes, transaction limits, and data residency requirements. The jurisdiction_profile governs which compliance controls apply to the merchant. Co' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JurisdictionProfile .

ind:payfacParentMerchantId rdf:type rdf:Property ;
    rdfs:label 'Payfac Parent Merchant Id' ;
    rdfs:comment 'Foreign key reference to the parent Payment Facilitator (PayFac) merchant if this merchant is a sub-merchant operating under a PayFac model. Null for direct merchants and top-level PayFacs. Used for hierarchical reporting and liability management.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Merchant .

ind:primaryAcquirerId rdf:type rdf:Property ;
    rdfs:label 'Primary Acquirer Id' ;
    rdfs:comment 'Foreign key linking to settlement.acquirer. Business justification: Every merchant is onboarded with a primary acquirer responsible for settlement processing. This link is essential for acquirer-level merchant portfolio reporting, settlement limit enforcement, and reg' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Acquirer .

ind:revenueGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Revenue Gl Account Id' ;
    rdfs:comment 'Foreign key linking to ledger.gl_account. Business justification: Revenue from merchant transactions must be posted to a specific GL account; linking enables automated journal entry generation for compliance and audit.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:routingEndpointId rdf:type rdf:Property ;
    rdfs:label 'Routing Endpoint Id' ;
    rdfs:comment 'Foreign key linking to network.network_endpoint. Business justification: Required for assigning a specific network endpoint for transaction routing during merchant onboarding, enabling routing decisions per merchant.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Endpoint .

ind:underwritingPolicyId rdf:type rdf:Property ;
    rdfs:label 'Underwriting Policy Id' ;
    rdfs:comment 'Foreign key linking to risk.underwriting_policy. Business justification: Every merchant is assigned an underwriting policy that defines risk limits; this link supports policy enforcement and compliance reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnderwritingPolicy .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'The date when the merchant was activated for live transaction processing. May differ from onboarding_date if there is a testing or approval period. Marks the start of revenue-generating activity.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line1' ;
    rdfs:comment 'The first line of the merchant\'s registered business address (street number and name). Used for KYB verification, regulatory reporting, and correspondence. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line2' ;
    rdfs:comment 'The second line of the merchant\'s registered business address (suite, floor, building name). Optional field. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCity rdf:type rdf:Property ;
    rdfs:label 'Business City' ;
    rdfs:comment 'The city or municipality of the merchant\'s registered business address. Used for geographic analysis, tax jurisdiction determination, and regulatory reporting. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCountry rdf:type rdf:Property ;
    rdfs:label 'Business Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the merchant\'s registered business address. Used for sanctions screening, cross-border rules, and regulatory reporting. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessPostalCode rdf:type rdf:Property ;
    rdfs:label 'Business Postal Code' ;
    rdfs:comment 'The postal code or ZIP code of the merchant\'s registered business address. Used for address verification, tax calculation, and geographic analysis. Format varies by country. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Business Registration Number' ;
    rdfs:comment 'The official business registration or company number issued by the government authority in the incorporation jurisdiction. Used for KYB (Know Your Business) verification and legal entity validation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessStateProvince rdf:type rdf:Property ;
    rdfs:label 'Business State Province' ;
    rdfs:comment 'The state, province, or administrative region of the merchant\'s registered business address. Used for tax jurisdiction, regulatory compliance, and geographic segmentation. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessType rdf:type rdf:Property ;
    rdfs:label 'Business Type' ;
    rdfs:comment 'The legal structure and classification of the merchant business entity. Determines regulatory requirements, tax treatment, and liability structure.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackThresholdCount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Threshold Count' ;
    rdfs:comment 'The maximum number of chargebacks allowed per month before the merchant is flagged for review or placed in a monitoring program. Exceeding this threshold may result in increased reserves, fines, or termination.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargebackThresholdRatio rdf:type rdf:Property ;
    rdfs:label 'Chargeback Threshold Ratio' ;
    rdfs:comment 'The maximum allowed chargeback ratio (chargebacks divided by total transactions) expressed as a decimal (e.g., 0.0100 for 1.00%). Exceeding this threshold triggers card scheme monitoring programs and potential penalties.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'The trade name or DBA (Doing Business As) name under which the merchant operates and is publicly known. May differ from legal business name. Displayed on cardholder statements.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationCountry rdf:type rdf:Property ;
    rdfs:label 'Incorporation Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the country where the merchant business is legally incorporated or registered. Used for regulatory compliance, sanctions screening, and cross-border payment rules.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Date' ;
    rdfs:comment 'The date when KYC/KYB verification was successfully completed for the merchant. Used for compliance audit trails and periodic re-verification scheduling.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Status' ;
    rdfs:comment 'Current status of the KYC/KYB (Know Your Business) verification process for the merchant. Indicates whether identity verification, business documentation, and beneficial ownership checks have been completed and approved.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBusinessName rdf:type rdf:Property ;
    rdfs:label 'Legal Business Name' ;
    rdfs:comment 'The official registered legal name of the merchant business entity as recorded in incorporation or business registration documents. Used for regulatory reporting, compliance verification, and legal contracts.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdrRate rdf:type rdf:Property ;
    rdfs:label 'Mdr Rate' ;
    rdfs:comment 'The percentage rate charged to the merchant for payment processing services, expressed as a decimal (e.g., 0.0275 for 2.75%). Represents the merchant\'s cost of acceptance. Varies by card type, transaction type, and merchant volume tier.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyProcessingLimit rdf:type rdf:Property ;
    rdfs:label 'Monthly Processing Limit' ;
    rdfs:comment 'The maximum total payment volume (in processing currency) that the merchant is authorized to process per calendar month. Used for risk management and fraud prevention. Exceeding this limit may trigger holds or additional review.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'The date when the merchant was successfully onboarded to the payment platform and assigned a MID. Marks the start of the merchant relationship and eligibility for transaction processing.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingCountry rdf:type rdf:Property ;
    rdfs:label 'Operating Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the primary country where the merchant conducts business operations. May differ from incorporation country for multinational merchants.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'The email address of the primary business contact for the merchant account. Used for operational notifications, settlement reports, dispute alerts, and compliance communications.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'The full name of the primary business contact person for the merchant account. Used for operational communication, support escalation, and account management.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'The phone number of the primary business contact for the merchant account. Used for urgent operational communication, fraud alerts, and account verification. Format varies by country.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'The risk classification assigned to the merchant based on MCC, transaction patterns, chargeback history, geographic location, and business model. Determines monitoring intensity, reserve requirements, and processing limits.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Settlement Account Number' ;
    rdfs:comment 'The bank account number where merchant settlement funds are deposited. Encrypted at rest. Used for ACH, wire transfer, or RTGS settlement processing. Format varies by country and payment rail.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Frequency' ;
    rdfs:comment 'The frequency at which settled funds are transferred to the merchant\'s bank account. Configured based on merchant agreement, risk profile, and processing volume.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Settlement Routing Number' ;
    rdfs:comment 'The bank routing number, sort code, or SWIFT/BIC code for the merchant\'s settlement account. Used to route settlement funds to the correct financial institution. Format varies by jurisdiction (e.g., ABA routing number in USA, sort code in UK, SWIFT BIC internationally).' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'The government-issued tax identification number for the merchant business entity. Format varies by jurisdiction (e.g., EIN in USA, VAT number in EU, GST number in India). Used for tax reporting, regulatory compliance, and identity verification.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'The date when the merchant relationship was terminated and the merchant was offboarded from the payment platform. Nullable for active merchants. Used for retention analysis and regulatory record-keeping.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionLimitSingle rdf:type rdf:Property ;
    rdfs:label 'Transaction Limit Single' ;
    rdfs:comment 'The maximum amount (in processing currency) allowed for a single transaction. Transactions exceeding this limit are declined at authorization. Set based on merchant risk profile and business model.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'The primary website URL of the merchant business. Used for business verification, fraud screening, and customer service reference. Required for e-commerce merchants.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationId rdf:type rdf:Property ;
    rdfs:label 'Application Id' ;
    rdfs:comment 'Unique identifier for the merchant application record. Primary key for the merchant application entity.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Application .

ind:applicationMerchantId rdf:type rdf:Property ;
    rdfs:label 'Application Merchant Id' ;
    rdfs:comment 'Identifier of the parent Payment Facilitator if this is a sub-merchant application. Establishes hierarchical relationship for settlement and liability.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Merchant .

ind:kybVerificationId rdf:type rdf:Property ;
    rdfs:label 'Kyb Verification Id' ;
    rdfs:comment 'Foreign key linking to merchant.kyb_verification. Business justification: The merchant onboarding application triggers KYB verification. application currently stores kyb_verification_status as a denormalized field. Adding kyb_verification_id links the application to its aut' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KybVerification .

ind:onboardingApplicationId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Application Id' ;
    rdfs:comment 'Foreign key linking to partner.onboarding_application. Business justification: A merchant application submitted through a partner channel is directly spawned from or linked to the partner\'s onboarding application. This FK is required for partner-driven merchant acquisition repor' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OnboardingApplication .

ind:parentPayfacMerchantId rdf:type rdf:Property ;
    rdfs:label 'Parent Payfac Merchant Id' ;
    rdfs:comment 'Identifier of the parent Payment Facilitator if this is a sub-merchant application. Establishes hierarchical relationship for settlement and liability.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Merchant .

ind:sanctionsCheckId rdf:type rdf:Property ;
    rdfs:label 'Sanctions Check Id' ;
    rdfs:comment 'Foreign key linking to compliance.sanctions_check. Business justification: Every merchant application requires OFAC/sanctions screening before approval. The ofac_screening_status field is denormalized — the FK to the sanctions_check record that performed this screening is re' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SanctionsCheck .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Externally visible unique application reference number assigned at submission. Used for tracking and customer communication throughout the onboarding lifecycle.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle status of the merchant application. Tracks progression from initial draft through underwriting review to final disposition. [ENUM-REF-CANDIDATE: draft|submitted|under_review|pending_documentation|approved|rejected|withdrawn|expired — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'Classification of the application purpose: new merchant onboarding, change to existing merchant profile, reinstatement after termination, upgrade or downgrade of service tier, or reactivation of dormant account.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Bank account number for merchant settlement deposits. Used for ACH credit transfers of processed transaction funds. Subject to account verification before approval.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountType rdf:type rdf:Property ;
    rdfs:label 'Bank Account Type' ;
    rdfs:comment 'Type of bank account designated for settlement. Determines ACH transaction codes and processing rules.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Number' ;
    rdfs:comment 'Nine-digit ABA routing number for the merchant\'s settlement bank. Used for ACH settlement processing and account verification.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCountryCode rdf:type rdf:Property ;
    rdfs:label 'Business Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the merchant\'s principal place of business. Used for cross-border risk assessment and sanctions screening.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessDescription rdf:type rdf:Property ;
    rdfs:label 'Business Description' ;
    rdfs:comment 'Detailed narrative description of the merchant\'s business model, products sold, services offered, and target customer base. Used by underwriters to assess risk and validate MCC classification.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Business Website Url' ;
    rdfs:comment 'Primary website URL for the merchant\'s business. Used for business verification, fraud screening, and brand reputation assessment.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address of the primary business contact. Used for application status notifications and ongoing merchant communication.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactFirstName rdf:type rdf:Property ;
    rdfs:label 'Contact First Name' ;
    rdfs:comment 'First name of the primary business contact or authorized representative for the merchant application.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactLastName rdf:type rdf:Property ;
    rdfs:label 'Contact Last Name' ;
    rdfs:comment 'Last name of the primary business contact or authorized representative for the merchant application.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary phone number for the business contact. Used for verification calls and urgent communication during underwriting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCheckPerformedFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Check Performed Flag' ;
    rdfs:comment 'Indicates whether a credit bureau check was performed on the business owner. Required for most merchant applications per underwriting policy.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditScore rdf:type rdf:Property ;
    rdfs:label 'Credit Score' ;
    rdfs:comment 'Personal credit score of the principal business owner obtained from credit bureau. Used for creditworthiness assessment and pricing determination.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decisionCode rdf:type rdf:Property ;
    rdfs:label 'Decision Code' ;
    rdfs:comment 'Final underwriting decision outcome. Determines next steps in merchant onboarding workflow and triggers downstream provisioning or notification processes.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Documentation Received Flag' ;
    rdfs:comment 'Indicates whether all required documentation has been received and validated. Gates progression to final approval stage.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doingBusinessAsName rdf:type rdf:Property ;
    rdfs:label 'Doing Business As Name' ;
    rdfs:comment 'Trade name or DBA name under which the merchant operates. May differ from legal name and appears on customer-facing materials.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAverageTicket rdf:type rdf:Property ;
    rdfs:label 'Estimated Average Ticket' ;
    rdfs:comment 'Projected average transaction amount in base currency. Used for fraud risk modeling and chargeback exposure assessment.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMonthlyVolume rdf:type rdf:Property ;
    rdfs:label 'Estimated Monthly Volume' ;
    rdfs:comment 'Merchant\'s projected monthly payment processing volume in base currency. Used for risk assessment, pricing tier determination, and reserve calculation.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerDateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Owner Date Of Birth' ;
    rdfs:comment 'Date of birth of the principal business owner. Used for identity verification and age validation during KYC process.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerFirstName rdf:type rdf:Property ;
    rdfs:label 'Owner First Name' ;
    rdfs:comment 'First name of the principal business owner or majority stakeholder. Required for KYC verification and beneficial ownership identification per FinCEN rules.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerLastName rdf:type rdf:Property ;
    rdfs:label 'Owner Last Name' ;
    rdfs:comment 'Last name of the principal business owner or majority stakeholder. Required for KYC verification and beneficial ownership identification per FinCEN rules.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerSsn rdf:type rdf:Property ;
    rdfs:label 'Owner Ssn' ;
    rdfs:comment 'Social Security Number of the principal business owner. Required for personal credit check, identity verification, and OFAC screening during underwriting.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of business ownership held by the principal owner. Used to determine beneficial ownership reporting requirements per FinCEN 25% threshold rule.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payfacSubMerchantFlag rdf:type rdf:Property ;
    rdfs:label 'Payfac Sub Merchant Flag' ;
    rdfs:comment 'Indicates whether this application is for a sub-merchant under a Payment Facilitator model. Determines underwriting requirements and settlement hierarchy.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'Source of the merchant application referral (e.g., direct, partner, web, sales_rep). Used for marketing attribution and channel performance analysis.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedMcc rdf:type rdf:Property ;
    rdfs:label 'Requested Mcc' ;
    rdfs:comment 'Four-digit MCC code requested by the merchant that classifies their business type. Subject to underwriter validation and may be adjusted based on actual business model. Determines interchange rates and risk profile.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedProcessingMethods rdf:type rdf:Property ;
    rdfs:label 'Requested Processing Methods' ;
    rdfs:comment 'Comma-separated list of payment processing methods requested by merchant (e.g., card_present, card_not_present, ecommerce, moto, recurring). Determines equipment needs and risk profile.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDocumentationChecklist rdf:type rdf:Property ;
    rdfs:label 'Required Documentation Checklist' ;
    rdfs:comment 'Comma-separated list of required documents for application completion (e.g., articles_of_incorporation, bank_statement, voided_check, government_id). Varies by business type and risk profile.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Quantitative risk assessment score assigned during underwriting. Combines credit risk, fraud risk, and business risk factors. Used for pricing tier assignment and reserve determination.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwritingCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Underwriting Complete Timestamp' ;
    rdfs:comment 'Date and time when underwriting review was completed and final decision was rendered. Used for SLA compliance reporting and cycle time analysis.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:underwritingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Underwriting Start Timestamp' ;
    rdfs:comment 'Date and time when the application entered underwriting review. Used for SLA tracking and process efficiency measurement.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:merchantSettlementAccountId rdf:type rdf:Property ;
    rdfs:label 'Merchant Settlement Account Id' ;
    rdfs:comment 'Reference to the settlement account where funds for transactions at this location are deposited.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchantSettlementAccount .

ind:pciComplianceId rdf:type rdf:Property ;
    rdfs:label 'Pci Compliance Id' ;
    rdfs:comment 'Foreign key linking to merchant.pci_compliance. Business justification: merchant_location stores pci_compliance_level and pci_attestation_date as denormalized fields. In PCI DSS, each physical location (especially those with card-present terminals) may have its own PCI co' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PciCompliance .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line for the merchant location (street number, street name, suite/unit).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for additional location details (building, floor, department).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality where the merchant location is situated.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyTransactionLimit rdf:type rdf:Property ;
    rdfs:label 'Daily Transaction Limit' ;
    rdfs:comment 'Maximum total transaction volume allowed per day for this location, used for risk management and fraud prevention.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date when this location was deactivated or closed, ceasing transaction processing.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for location-specific communications and notifications.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudMonitoringEnabled rdf:type rdf:Property ;
    rdfs:label 'Fraud Monitoring Enabled' ;
    rdfs:comment 'Indicates whether real-time fraud detection and prevention monitoring is enabled for transactions at this location.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'Date of the most recent transaction processed at this location, used for dormancy monitoring and lifecycle management.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the merchant location in decimal degrees for mapping and proximity analytics.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Business name or identifier for this specific merchant location (e.g., \'Downtown Store\', \'Airport Terminal 3\').' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational status of the merchant location in its lifecycle: active (processing transactions), inactive (temporarily not processing), suspended (compliance hold), pending (onboarding), or closed (permanently offboarded).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the merchant location type: physical storefront, kiosk, online, mobile Point of Sale (mPOS), virtual, or pop-up.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the merchant location in decimal degrees for mapping and proximity analytics.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours for the location (e.g., \'Mon-Fri 9AM-5PM, Sat 10AM-2PM\') used for customer service and transaction pattern analysis.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the merchant location.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the merchant location address.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTier rdf:type rdf:Property ;
    rdfs:label 'Risk Tier' ;
    rdfs:comment 'Risk classification tier for this location: low, medium, high, or critical, determining monitoring intensity and processing controls.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:singleTransactionLimit rdf:type rdf:Property ;
    rdfs:label 'Single Transaction Limit' ;
    rdfs:comment 'Maximum amount allowed for a single transaction at this location, enforced during authorization.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative region of the merchant location.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier for the merchant location (e.g., America/New_York, Europe/London) used for transaction timestamp normalization.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:canReceiveDisputeNotifications rdf:type rdf:Property ;
    rdfs:label 'Can Receive Dispute Notifications' ;
    rdfs:comment 'Indicates whether this contact should receive chargeback and dispute notifications. Enables targeted communication for time-sensitive dispute response requirements.' ;
    rdfs:domain ind:MerchantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:canReceivePciData rdf:type rdf:Property ;
    rdfs:label 'Can Receive Pci Data' ;
    rdfs:comment 'Indicates whether this contact is authorized to receive communications containing Payment Card Industry (PCI) sensitive data. Ensures PCI DSS compliance in data transmission.' ;
    rdfs:domain ind:MerchantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:canReceiveSettlementReports rdf:type rdf:Property ;
    rdfs:label 'Can Receive Settlement Reports' ;
    rdfs:comment 'Indicates whether this contact should receive settlement and funding reports. Used for financial reconciliation and treasury management communications.' ;
    rdfs:domain ind:MerchantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the merchant contact record. Determines whether the contact should receive communications and appear in active contact lists.' ;
    rdfs:domain ind:MerchantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact role within the merchant organization. Determines the purpose and scope of communication with this contact.' ;
    rdfs:domain ind:MerchantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User identifier or system account that created this contact record. Supports audit trail and accountability for data governance.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Business unit or department within the merchant organization where the contact works. Used for routing communications to appropriate functional areas.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date when this contact record became active and valid for the merchant relationship. Supports temporal tracking and audit requirements.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date when this contact record ceased to be active for the merchant relationship. Null for currently active contacts. Supports historical tracking and compliance audit trails.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emailOptOutFlag rdf:type rdf:Property ;
    rdfs:label 'Email Opt Out Flag' ;
    rdfs:comment 'Indicates whether the contact has opted out of marketing or non-essential email communications. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:MerchantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Facsimile number for document transmission. Used for formal dispute documentation and regulatory correspondence requiring written records.' ;
    rdfs:domain ind:MerchantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the merchant contact person. Used for personalized communication and identification.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAuthorizedSigner rdf:type rdf:Property ;
    rdfs:label 'Is Authorized Signer' ;
    rdfs:comment 'Indicates whether this contact has legal authority to sign contracts and agreements on behalf of the merchant. Critical for KYC and contract execution workflows.' ;
    rdfs:domain ind:MerchantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is the primary point of contact for the merchant. Used to prioritize communication routing and escalation paths.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Professional title or position of the contact within the merchant organization. Indicates authority level and functional responsibility.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Expiry Date' ;
    rdfs:comment 'Date when the current KYC verification expires and re-verification is required. Supports periodic review requirements under AML and CTF regulations.' ;
    rdfs:domain ind:MerchantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date of the most recent communication or interaction with this contact. Used for relationship management and contact data quality maintenance.' ;
    rdfs:domain ind:MerchantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User identifier or system account that last modified this contact record. Supports audit trail and accountability for data changes.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name or surname of the merchant contact person. Used for formal identification and communication.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the merchant contact person. Optional field for complete name representation.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile or cellular phone number for SMS notifications and mobile communication. Used for time-sensitive alerts and two-factor authentication.' ;
    rdfs:domain ind:MerchantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneExtension rdf:type rdf:Property ;
    rdfs:label 'Phone Extension' ;
    rdfs:comment 'Internal extension number for direct routing within the merchant organization phone system. Enables direct contact bypass of main switchboard.' ;
    rdfs:domain ind:MerchantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'Contact\'s preferred method for receiving communications from the payment processor. Ensures compliance with communication preferences and improves response rates.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-2 three-letter language code indicating the contact\'s preferred language for communication. Supports multilingual merchant base and regulatory compliance in international markets.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsOptOutFlag rdf:type rdf:Property ;
    rdfs:label 'Sms Opt Out Flag' ;
    rdfs:comment 'Indicates whether the contact has opted out of SMS or text message communications. Required for compliance with telecommunications regulations and privacy laws.' ;
    rdfs:domain ind:MerchantContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statusReason rdf:type rdf:Property ;
    rdfs:label 'Status Reason' ;
    rdfs:comment 'Explanation or reason code for the current contact status. Provides audit trail for status changes and supports compliance documentation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the contact\'s location. Used for scheduling communications during business hours and timestamping interactions appropriately.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceKycVerificationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Kyc Verification Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_kyc_verification. Business justification: KYB verification results are derived from detailed compliance KYC verification records; linking provides traceability for regulatory audits and risk assessments.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceKycVerification .

ind:adverseMediaCheckResult rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Check Result' ;
    rdfs:comment 'Outcome of adverse media screening to identify negative news, criminal activity, fraud, or reputational risks associated with the business entity.' ;
    rdfs:domain ind:KybVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Aml Screening Result' ;
    rdfs:comment 'Outcome of Anti-Money Laundering screening checks to identify potential money laundering risks or suspicious activity patterns.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessIdentityCheckResult rdf:type rdf:Property ;
    rdfs:label 'Business Identity Check Result' ;
    rdfs:comment 'Outcome of the business entity identity verification check confirming legal existence, registration status, and business name match against official registries.' ;
    rdfs:domain ind:KybVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctfScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Ctf Screening Result' ;
    rdfs:comment 'Outcome of Counter-Terrorism Financing screening checks to identify potential terrorism financing risks or connections to terrorist organizations.' ;
    rdfs:domain ind:KybVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourcesUsed rdf:type rdf:Property ;
    rdfs:label 'Data Sources Used' ;
    rdfs:comment 'Comma-separated list of data sources and registries consulted during KYB verification (e.g., Companies House, Dun & Bradstreet, OFAC SDN, Dow Jones Watchlist).' ;
    rdfs:domain ind:KybVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTypesVerified rdf:type rdf:Property ;
    rdfs:label 'Document Types Verified' ;
    rdfs:comment 'Comma-separated list of document types that were verified during the KYB process (e.g., articles of incorporation, business license, tax ID certificate, bank statement).' ;
    rdfs:domain ind:KybVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Document Verification Status' ;
    rdfs:comment 'Status of business document verification including articles of incorporation, business licenses, tax certificates, and other supporting documentation.' ;
    rdfs:domain ind:KybVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'Date when the business entity was officially incorporated or registered as verified during KYB checks.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manualReviewReason rdf:type rdf:Property ;
    rdfs:label 'Manual Review Reason' ;
    rdfs:comment 'Explanation of why manual compliance review is required, detailing specific alerts, inconclusive checks, or policy triggers.' ;
    rdfs:domain ind:KybVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manualReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Manual Review Required Flag' ;
    rdfs:comment 'Boolean indicator that the KYB verification results require manual review by compliance officers due to inconclusive results, risk alerts, or policy exceptions.' ;
    rdfs:domain ind:KybVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic KYB re-verification or refresh based on risk tier and regulatory requirements for ongoing due diligence.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ofacScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Ofac Screening Result' ;
    rdfs:comment 'Specific outcome of screening against the US Office of Foreign Assets Control Specially Designated Nationals and Blocked Persons List.' ;
    rdfs:domain ind:KybVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallKybDecision rdf:type rdf:Property ;
    rdfs:label 'Overall Kyb Decision' ;
    rdfs:comment 'Final pass or fail decision for the KYB verification determining whether the merchant is approved for onboarding, rejected, conditionally approved, or requires manual review.' ;
    rdfs:domain ind:KybVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pepScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Pep Screening Result' ;
    rdfs:comment 'Outcome of screening to identify if the business or its beneficial owners are politically exposed persons requiring enhanced due diligence.' ;
    rdfs:domain ind:KybVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Detailed explanation of why the KYB verification was rejected or failed, including specific check failures and compliance concerns.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Completed Timestamp' ;
    rdfs:comment 'Timestamp when manual compliance review of the KYB verification was completed and final decision was rendered.' ;
    rdfs:domain ind:KybVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Internal compliance notes and comments recorded by the reviewer during manual review of the KYB verification, documenting decision rationale.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskFactors rdf:type rdf:Property ;
    rdfs:label 'Risk Factors' ;
    rdfs:comment 'Comma-separated list of specific risk factors identified during KYB verification (e.g., high-risk MCC, high-risk jurisdiction, adverse media, PEP association).' ;
    rdfs:domain ind:KybVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uboCount rdf:type rdf:Property ;
    rdfs:label 'Ubo Count' ;
    rdfs:comment 'Number of Ultimate Beneficial Owners identified and verified during the KYB process who meet the ownership or control threshold.' ;
    rdfs:domain ind:KybVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uboScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Ubo Screening Result' ;
    rdfs:comment 'Outcome of the Ultimate Beneficial Owner screening check verifying individuals who own or control 25% or more of the business entity.' ;
    rdfs:domain ind:KybVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationCostAmount rdf:type rdf:Property ;
    rdfs:label 'Verification Cost Amount' ;
    rdfs:comment 'Cost charged by the verification provider for performing the KYB verification checks, used for cost tracking and merchant billing.' ;
    rdfs:domain ind:KybVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Verification Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the verification cost amount.' ;
    rdfs:domain ind:KybVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date when the KYB verification was performed and results were received from the verification provider.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Verification Expiry Date' ;
    rdfs:comment 'Date when the current KYB verification expires and requires renewal to maintain merchant compliance status.' ;
    rdfs:domain ind:KybVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to perform the KYB verification indicating whether checks were fully automated, manual, or a hybrid combination.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationProvider rdf:type rdf:Property ;
    rdfs:label 'Verification Provider' ;
    rdfs:comment 'Name of the third-party KYB verification service provider that performed the business identity and compliance checks (e.g., Refinitiv, LexisNexis, Dow Jones).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Verification Reference Number' ;
    rdfs:comment 'External reference number assigned by the verification provider for tracking and audit purposes.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Current lifecycle status of the KYB verification process indicating whether checks are pending, in progress, completed successfully, failed, expired, or require manual review.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficialOwnerId rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Id' ;
    rdfs:comment 'Unique identifier for the beneficial owner record. Primary key for the beneficial owner entity.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:watchlistEntryId rdf:type rdf:Property ;
    rdfs:label 'Watchlist Entry Id' ;
    rdfs:comment 'Foreign key linking to compliance.watchlist_entry. Business justification: When a beneficial owner matches a sanctions/watchlist entry, that match must be recorded on the beneficial_owner record for ongoing monitoring and SAR filing decisions. This is a core KYB/AML requirem' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WatchlistEntry .

ind:adverseMediaScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Screening Date' ;
    rdfs:comment 'Timestamp when the most recent adverse media screening was performed on the beneficial owner.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adverseMediaScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Screening Status' ;
    rdfs:comment 'Result of adverse media screening to identify negative news or reputational risks associated with the beneficial owner. Part of enhanced due diligence process.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlRiskRating rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Rating' ;
    rdfs:comment 'Overall AML risk rating assigned to the beneficial owner based on risk factors including PEP status, sanctions screening, country risk, and ownership structure.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficialOwnerStatus rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Status' ;
    rdfs:comment 'Current lifecycle status of the beneficial owner record. Indicates whether the record is active, under review, or has been rejected due to compliance issues.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlRole rdf:type rdf:Property ;
    rdfs:label 'Control Role' ;
    rdfs:comment 'Role or position held by the beneficial owner that grants significant control over the merchant entity. Required for FinCEN CDD Rule compliance to identify individuals with control authority. [ENUM-REF-CANDIDATE: director|officer|shareholder|trustee|beneficiary|authorized_signatory|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlRoleDescription rdf:type rdf:Property ;
    rdfs:label 'Control Role Description' ;
    rdfs:comment 'Detailed description of the beneficial owner\'s control role and responsibilities within the merchant entity. Provides context for the nature of control exercised.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfResidence rdf:type rdf:Property ;
    rdfs:label 'Country Of Residence' ;
    rdfs:comment 'Country where the beneficial owner currently resides using ISO 3166-1 alpha-3 country code. Used for tax reporting and regulatory compliance.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Date of birth of the beneficial owner in yyyy-MM-dd format. Required for identity verification, age validation, and AML screening under FinCEN CDD Rule.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fullLegalName rdf:type rdf:Property ;
    rdfs:label 'Full Legal Name' ;
    rdfs:comment 'Complete legal name of the beneficial owner as it appears on government-issued identification documents. Required for BSA/AML compliance and identity verification.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governmentIdExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Government Id Expiration Date' ;
    rdfs:comment 'Expiration date of the government-issued identification document. Used to ensure validity of identity verification.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:governmentIdIssuingCountry rdf:type rdf:Property ;
    rdfs:label 'Government Id Issuing Country' ;
    rdfs:comment 'Country that issued the government identification document using ISO 3166-1 alpha-3 country code.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governmentIdNumber rdf:type rdf:Property ;
    rdfs:label 'Government Id Number' ;
    rdfs:comment 'Unique identification number from the government-issued document. Encrypted at rest and used for identity verification and AML screening.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governmentIdType rdf:type rdf:Property ;
    rdfs:label 'Government Id Type' ;
    rdfs:comment 'Type of government-issued identification document provided by the beneficial owner for identity verification. Required under FinCEN CDD Rule.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Date' ;
    rdfs:comment 'Timestamp when the beneficial owner\'s identity was successfully verified. Required for audit trail and compliance reporting.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:identityVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Method' ;
    rdfs:comment 'Method used to verify the identity of the beneficial owner. Supports multiple verification channels to meet regulatory requirements.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationProvider rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Provider' ;
    rdfs:comment 'Name of the third-party service or internal system used to perform identity verification. Used for audit trail and vendor management.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Status' ;
    rdfs:comment 'Status of the identity verification process for the beneficial owner. Indicates whether identity has been successfully verified, is pending review, or has failed verification checks.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPep rdf:type rdf:Property ;
    rdfs:label 'Is Pep' ;
    rdfs:comment 'Boolean flag indicating whether the beneficial owner is a Politically Exposed Person. PEPs require enhanced due diligence under FATF recommendations and AML regulations.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycRefreshDueDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Refresh Due Date' ;
    rdfs:comment 'Date when the beneficial owner KYC information is due for periodic refresh and re-verification. Required for ongoing due diligence under AML regulations.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'Country of citizenship of the beneficial owner using ISO 3166-1 alpha-3 country code. Required for sanctions screening and cross-border compliance.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pepClassification rdf:type rdf:Property ;
    rdfs:label 'Pep Classification' ;
    rdfs:comment 'Classification of the PEP status indicating whether the individual is a domestic PEP, foreign PEP, member of international organization, family member, or close associate of a PEP.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pepPositionTitle rdf:type rdf:Property ;
    rdfs:label 'Pep Position Title' ;
    rdfs:comment 'Title or position held by the beneficial owner that qualifies them as a PEP. Examples include government official, senior executive of state-owned enterprise, or high-ranking military officer.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Residential Address Line1' ;
    rdfs:comment 'Primary street address line of the beneficial owner\'s residential address. Required for identity verification and KYC compliance.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Residential Address Line2' ;
    rdfs:comment 'Secondary address line for apartment, suite, or unit number of the beneficial owner\'s residential address.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialCity rdf:type rdf:Property ;
    rdfs:label 'Residential City' ;
    rdfs:comment 'City or municipality of the beneficial owner\'s residential address.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialCountry rdf:type rdf:Property ;
    rdfs:label 'Residential Country' ;
    rdfs:comment 'Country of the beneficial owner\'s residential address using ISO 3166-1 alpha-3 country code.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialPostalCode rdf:type rdf:Property ;
    rdfs:label 'Residential Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the beneficial owner\'s residential address.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialStateProvince rdf:type rdf:Property ;
    rdfs:label 'Residential State Province' ;
    rdfs:comment 'State, province, or region of the beneficial owner\'s residential address.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsMatchDetails rdf:type rdf:Property ;
    rdfs:label 'Sanctions Match Details' ;
    rdfs:comment 'Details of any sanctions list matches including list name, match score, and reason for match. Used for investigation and resolution of potential sanctions violations.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Date' ;
    rdfs:comment 'Timestamp when the most recent sanctions screening was performed on the beneficial owner. Required for audit trail and compliance monitoring.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sanctionsScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Status' ;
    rdfs:comment 'Result of sanctions screening against OFAC, UN, EU, and other sanctions lists. Indicates whether the beneficial owner is clear, has a match, or requires further review.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOfFunds rdf:type rdf:Property ;
    rdfs:label 'Source Of Funds' ;
    rdfs:comment 'Description of the origin of funds used by the beneficial owner in the merchant relationship. Required for enhanced due diligence and AML compliance.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOfWealth rdf:type rdf:Property ;
    rdfs:label 'Source Of Wealth' ;
    rdfs:comment 'Description of how the beneficial owner accumulated their wealth. Required for enhanced due diligence on high-risk individuals and PEPs.' ;
    rdfs:domain ind:BeneficialOwner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Clearing Gl Account Id' ;
    rdfs:comment 'Foreign key linking to ledger.gl_account. Business justification: Merchant processing accounts map to GL clearing accounts for transaction posting and daily settlement reconciliation. Each merchant account (card-present, card-not-present) posts to a specific GL clea' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:dccConfigId rdf:type rdf:Property ;
    rdfs:label 'Dcc Config Id' ;
    rdfs:comment 'Foreign key linking to fx.dcc_config. Business justification: DCC is enabled at account level (dynamic_currency_conversion_enabled flag exists). Different merchant accounts (e.g., card-present vs CNP) may use distinct DCC configs. This link operationalizes which' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DccConfig .

ind:fxFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Fx Fee Schedule Id' ;
    rdfs:comment 'Foreign key linking to fx.fx_fee_schedule. Business justification: Merchant accounts with multi_currency_enabled or dynamic_currency_conversion_enabled are subject to FX fee schedules. This link drives accurate FX fee billing, merchant statement generation, and prici' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FxFeeSchedule .

ind:merchantIntegrationId rdf:type rdf:Property ;
    rdfs:label 'Merchant Integration Id' ;
    rdfs:comment 'Foreign key linking to gateway.merchant_integration. Business justification: A merchant_account\'s processing capabilities (CNP, tokenization, 3DS, multi-currency) are governed by its gateway integration configuration. Authorization routing and capability checks require this li' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchantIntegration .

ind:multiNetworkRoutingId rdf:type rdf:Property ;
    rdfs:label 'Multi Network Routing Id' ;
    rdfs:comment 'Foreign key linking to network.multi_network_routing. Business justification: Durbin Amendment (Regulation II) requires debit transactions to be routable over at least two unaffiliated networks. Each merchant account must be assigned a multi-network routing profile governing de' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MultiNetworkRouting .

ind:threedsConfigId rdf:type rdf:Property ;
    rdfs:label 'Threeds Config Id' ;
    rdfs:comment 'Foreign key linking to gateway.threeds_config. Business justification: merchant_account has three_ds_required and three_ds_version as denormalized fields. The authoritative 3DS configuration (challenge preference, exemption rules, protocol version) governing a merchant_a' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThreedsConfig .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-visible unique account number assigned to this processing account for identification in statements and reports.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the merchant processing account. Active accounts can process transactions; suspended/restricted accounts have limited processing; closed accounts are terminated.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the processing account model: standard merchant account, Payment Facilitator (PayFac) sub-merchant account, Independent Sales Organization (ISO) account, aggregator account, marketplace account, or direct acquiring account.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avsCheckEnabled rdf:type rdf:Property ;
    rdfs:label 'Avs Check Enabled' ;
    rdfs:comment 'Indicates whether Address Verification System checks are enabled for card-not-present transactions to validate cardholder billing address.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:batchSettlementEnabled rdf:type rdf:Property ;
    rdfs:label 'Batch Settlement Enabled' ;
    rdfs:comment 'Indicates whether this account uses batch settlement processing where transactions are grouped and settled in scheduled batches rather than real-time settlement.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cardNotPresentEnabled rdf:type rdf:Property ;
    rdfs:label 'Card Not Present Enabled' ;
    rdfs:comment 'Indicates whether this account is authorized to process card-not-present transactions such as e-commerce, mail order, or telephone order (MOTO) payments.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cardPresentEnabled rdf:type rdf:Property ;
    rdfs:label 'Card Present Enabled' ;
    rdfs:comment 'Indicates whether this account is authorized to process card-present transactions via Point of Sale (POS) or mobile Point of Sale (mPOS) terminals.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargebackThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Chargeback Threshold Percentage' ;
    rdfs:comment 'Maximum acceptable chargeback ratio (chargebacks divided by total transactions) expressed as a percentage. Exceeding this threshold may trigger account review or restrictions per card scheme monitoring programs.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossBorderProcessingEnabled rdf:type rdf:Property ;
    rdfs:label 'Cross Border Processing Enabled' ;
    rdfs:comment 'Indicates whether this account is authorized to process cross-border transactions where the cardholder and merchant are in different countries.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cvvCheckEnabled rdf:type rdf:Property ;
    rdfs:label 'Cvv Check Enabled' ;
    rdfs:comment 'Indicates whether Card Verification Value (CVV/CVV2/CVC) validation is enabled for card-not-present transactions to verify card possession.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dynamicCurrencyConversionEnabled rdf:type rdf:Property ;
    rdfs:label 'Dynamic Currency Conversion Enabled' ;
    rdfs:comment 'Indicates whether this account is enabled for Dynamic Currency Conversion, allowing cardholders to see and pay in their home currency at the point of sale.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enhancedMonitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Enhanced Monitoring Required' ;
    rdfs:comment 'Indicates whether this account is subject to enhanced transaction monitoring due to elevated risk profile, regulatory requirements, or past compliance issues.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Fraud Threshold Percentage' ;
    rdfs:comment 'Maximum acceptable fraud ratio (fraudulent transactions divided by total transactions) expressed as a percentage. Exceeding this threshold may trigger enhanced fraud controls or account restrictions.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installmentPaymentEnabled rdf:type rdf:Property ;
    rdfs:label 'Installment Payment Enabled' ;
    rdfs:comment 'Indicates whether this account supports installment payment plans where a single purchase is split into multiple scheduled payments.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monthlyTransactionLimit rdf:type rdf:Property ;
    rdfs:label 'Monthly Transaction Limit' ;
    rdfs:comment 'Maximum total transaction volume (in processing currency) that this account is permitted to process within a single calendar month. Used for risk management and underwriting controls.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:multiCurrencyEnabled rdf:type rdf:Property ;
    rdfs:label 'Multi Currency Enabled' ;
    rdfs:comment 'Indicates whether this account is configured to accept and process transactions in multiple currencies beyond the primary processing currency.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:realTimeSettlementEnabled rdf:type rdf:Property ;
    rdfs:label 'Real Time Settlement Enabled' ;
    rdfs:comment 'Indicates whether this account supports real-time or near-real-time settlement where funds are transferred to the merchant immediately or within minutes of transaction authorization.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurringBillingEnabled rdf:type rdf:Property ;
    rdfs:label 'Recurring Billing Enabled' ;
    rdfs:comment 'Indicates whether this account is configured to support recurring or subscription-based billing transactions.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reserveAccountRequired rdf:type rdf:Property ;
    rdfs:label 'Reserve Account Required' ;
    rdfs:comment 'Indicates whether this merchant account is required to maintain a reserve account (holdback) to cover potential chargebacks, refunds, or other liabilities.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reservePercentage rdf:type rdf:Property ;
    rdfs:label 'Reserve Percentage' ;
    rdfs:comment 'Percentage of transaction volume withheld in reserve account to cover potential chargebacks and refunds. Null if no reserve is required.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaExemptionAllowed rdf:type rdf:Property ;
    rdfs:label 'Sca Exemption Allowed' ;
    rdfs:comment 'Indicates whether this account is permitted to apply Strong Customer Authentication exemptions for low-risk or low-value transactions under PSD2 regulations.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportedCardSchemes rdf:type rdf:Property ;
    rdfs:label 'Supported Card Schemes' ;
    rdfs:comment 'Comma-separated list of card payment networks enabled for this account (e.g., Visa, Mastercard, Amex, Discover, JCB, UnionPay, Diners).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedPaymentMethods rdf:type rdf:Property ;
    rdfs:label 'Supported Payment Methods' ;
    rdfs:comment 'Comma-separated list of payment methods enabled for this account (e.g., card_present, card_not_present, digital_wallet, ach, bank_transfer, qr_code, bnpl).' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Tokenization Enabled' ;
    rdfs:comment 'Indicates whether payment tokenization is enabled for this account to replace sensitive Primary Account Number (PAN) data with non-sensitive tokens.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mccAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Mcc Assignment Id' ;
    rdfs:comment 'Unique identifier for the MCC assignment record. Primary key for the MCC assignment entity.' ;
    rdfs:domain ind:MccAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assigningAuthority rdf:type rdf:Property ;
    rdfs:label 'Assigning Authority' ;
    rdfs:comment 'Entity that assigned or approved the MCC. Can be a card scheme (Visa, Mastercard, Amex, Discover) or the acquiring bank/payment facilitator. Determines the authoritative source for the MCC classification.' ;
    rdfs:domain ind:MccAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'Date on which the MCC was assigned to the merchant or merchant location. Represents the business event date of the assignment decision.' ;
    rdfs:domain ind:MccAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentRationale rdf:type rdf:Property ;
    rdfs:label 'Assignment Rationale' ;
    rdfs:comment 'Free-text explanation or business justification for the MCC assignment. May include details about the merchant\'s primary business activity, product mix, or regulatory considerations that influenced the MCC selection.' ;
    rdfs:domain ind:MccAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the MCC assignment. Active assignments are used for transaction processing; pending assignments await approval; suspended or revoked assignments are temporarily or permanently disabled.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Categorized reason for changing the MCC from a previous assignment. Applicable only when previous_mcc_code is populated. Used for audit trail and compliance reporting. [ENUM-REF-CANDIDATE: business_change|correction|scheme_mandate|fraud_mitigation|merchant_request|regulatory_requirement|audit_finding|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mccCode rdf:type rdf:Property ;
    rdfs:label 'Mcc Code' ;
    rdfs:comment 'Four-digit code that classifies the merchant\'s type of business. Determines interchange rates, spending category analytics, and fraud risk profiling. Assigned by card schemes (Visa, Mastercard) or acquirer.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mccDescription rdf:type rdf:Property ;
    rdfs:label 'Mcc Description' ;
    rdfs:comment 'Human-readable description of the MCC code, describing the business category (e.g., \'Grocery Stores and Supermarkets\', \'Airlines\', \'Hotels and Motels\').' ;
    rdfs:domain ind:MccAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousMccCode rdf:type rdf:Property ;
    rdfs:label 'Previous Mcc Code' ;
    rdfs:comment 'The MCC code that was previously assigned to this merchant or location before the current assignment. Nullable for initial assignments. Used to track MCC change history and analyze reclassification patterns.' ;
    rdfs:domain ind:MccAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Risk classification associated with this MCC for fraud detection and prevention purposes. High-risk MCCs (e.g., gambling, adult entertainment, travel) trigger enhanced monitoring and fraud rules.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Scheme Approval Date' ;
    rdfs:comment 'Date on which the card scheme approved this MCC assignment. Nullable if scheme approval is not required or has not yet been obtained.' ;
    rdfs:domain ind:MccAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:schemeApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Scheme Approval Reference' ;
    rdfs:comment 'Reference number or case ID provided by the card scheme when approving this MCC assignment. Used for audit trail and dispute resolution.' ;
    rdfs:domain ind:MccAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Scheme Approval Required Flag' ;
    rdfs:comment 'Indicates whether this MCC assignment requires explicit approval from the card scheme (Visa, Mastercard, etc.) before it can be activated. True for high-risk or restricted MCCs.' ;
    rdfs:domain ind:MccAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'Unique identifier of this MCC assignment record in the source operational system. Used for data lineage and reconciliation.' ;
    rdfs:domain ind:MccAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueShareScheduleId rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Schedule Id' ;
    rdfs:comment 'Foreign key linking to partner.revenue_share_schedule. Business justification: In ISO/PayFac models, a merchant pricing plan\'s MDR split and residual rates are directly governed by the partner\'s revenue share schedule. This link is essential for pricing configuration, partner re' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueShareSchedule .

ind:achTransactionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Ach Transaction Fee Amount' ;
    rdfs:comment 'Fee charged per ACH (bank transfer) transaction processed for the merchant, expressed in the plan\'s base currency. Typically lower than card transaction fees.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amexRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Amex Rate Percentage' ;
    rdfs:comment 'Separate MDR percentage applied specifically to American Express card transactions, which often have different pricing than Visa/Mastercard, expressed as a decimal.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyConversionMarkupPercentage rdf:type rdf:Property ;
    rdfs:label 'Currency Conversion Markup Percentage' ;
    rdfs:comment 'Markup percentage applied to the foreign exchange (FX) rate when Dynamic Currency Conversion (DCC) is offered to cardholders, expressed as a decimal (e.g., 0.0300 for 3.00% above spot rate).' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitCardRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Debit Card Rate Percentage' ;
    rdfs:comment 'MDR percentage applied specifically to debit card transactions, typically lower than credit card rates due to Regulation II (Durbin Amendment) caps, expressed as a decimal.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interchangeMarkupPercentage rdf:type rdf:Property ;
    rdfs:label 'Interchange Markup Percentage' ;
    rdfs:comment 'The markup percentage added on top of the actual interchange cost in interchange-plus pricing models (e.g., 0.0050 for 0.50% above interchange). Null for non-interchange-plus models.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interchangePassthroughFlag rdf:type rdf:Property ;
    rdfs:label 'Interchange Passthrough Flag' ;
    rdfs:comment 'Indicates whether actual interchange fees (IRF) are passed through to the merchant at cost (true) or absorbed into a blended rate (false). True for interchange-plus and cost-plus models.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internationalTransactionFeePercentage rdf:type rdf:Property ;
    rdfs:label 'International Transaction Fee Percentage' ;
    rdfs:comment 'Additional percentage fee applied to cross-border transactions where the card issuer is in a different country than the merchant, expressed as a decimal (e.g., 0.0100 for 1.00%).' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mdrRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Mdr Rate Percentage' ;
    rdfs:comment 'The base percentage rate charged to the merchant per transaction, expressed as a decimal (e.g., 0.0275 for 2.75%). This is the primary revenue component for flat-rate and blended pricing models.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchantPricingPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Merchant Pricing Plan Status' ;
    rdfs:comment 'Current lifecycle status of the pricing plan. Active plans are available for assignment; inactive plans are no longer offered but may still govern existing merchants; pending plans are under approval; suspended plans are temporarily unavailable; archived plans are historical records only.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:midQualifiedRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Mid Qualified Rate Percentage' ;
    rdfs:comment 'The middle MDR percentage tier in tiered pricing models, applied to transactions that partially meet qualification criteria (e.g., keyed-in transactions, rewards cards), expressed as a decimal.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonQualifiedRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Non Qualified Rate Percentage' ;
    rdfs:comment 'The highest MDR percentage tier in tiered pricing models, applied to transactions that fail qualification criteria (e.g., corporate cards, international cards, manually entered), expressed as a decimal.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payfacSubMerchantEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Payfac Sub Merchant Eligible Flag' ;
    rdfs:comment 'Indicates whether this pricing plan is available for assignment to sub-merchants under a Payment Facilitator (PayFac) model. True if eligible for PayFac sub-merchants; false if only for direct merchants.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pciNonCompliancePenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Pci Non Compliance Penalty Amount' ;
    rdfs:comment 'Monthly penalty fee charged to merchants who fail to maintain PCI DSS compliance, expressed in the plan\'s base currency. Escalates with duration of non-compliance.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Externally-known unique business identifier for the pricing plan, used in contracts and merchant communications.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed description of the pricing plan, including key features, target merchant segments, and value proposition.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable name of the pricing plan (e.g., \'Standard Retail\', \'Enterprise Plus\', \'Startup Flat Rate\').' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifiedRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Qualified Rate Percentage' ;
    rdfs:comment 'The lowest MDR percentage tier in tiered pricing models, applied to transactions that meet all qualification criteria (e.g., swiped consumer credit cards), expressed as a decimal.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Fee Amount' ;
    rdfs:comment 'Fee charged to the merchant for processing a refund or credit transaction, expressed in the plan\'s base currency. Some plans waive this fee; others charge per refund.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:setupFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Setup Fee Amount' ;
    rdfs:comment 'One-time fee charged when a merchant is onboarded and assigned to this pricing plan, covering account setup, KYC processing, and initial configuration, expressed in the plan\'s base currency.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'Identifier of the system user or administrator who last modified this pricing plan record. Used for audit trail and accountability.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Merchant Fee Schedule Id' ;
    rdfs:comment 'System-generated unique identifier for each merchant fee schedule record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchantFeeSchedule .

ind:acquirerEndpointId rdf:type rdf:Property ;
    rdfs:label 'Acquirer Endpoint Id' ;
    rdfs:comment 'Foreign key linking to gateway.acquirer_endpoint. Business justification: Fee schedules in acquiring are often acquirer-specific — different acquirers carry different transaction fees and interchange pass-through rates. Billing reconciliation, acquirer cost analysis, and fe' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AcquirerEndpoint .

ind:feeGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Fee Gl Account Id' ;
    rdfs:comment 'Foreign key linking to ledger.gl_account. Business justification: Fee schedule entries must post to specific GL accounts (MDR income, interchange markup, per-transaction fee revenue). Payments fintechs automate journal entry derivation by mapping each fee type to a ' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:applicableTransactionType rdf:type rdf:Property ;
    rdfs:label 'Applicable Transaction Type' ;
    rdfs:comment 'Transaction type that triggers the fee.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'Frequency at which a recurring fee is billed.' ;
    rdfs:domain ind:MerchantFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Date when the fee schedule becomes binding.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date when the fee schedule expires or is superseded (null for open-ended).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeBasis rdf:type rdf:Property ;
    rdfs:label 'Fee Basis' ;
    rdfs:comment 'Determines how the fee amount is calculated.' ;
    rdfs:domain ind:MerchantFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCapAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Cap Amount' ;
    rdfs:comment 'Maximum total fee that can be charged within a billing period.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeCapCurrency rdf:type rdf:Property ;
    rdfs:label 'Fee Cap Currency' ;
    rdfs:comment 'Currency for the fee cap amount.' ;
    rdfs:domain ind:MerchantFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCategory rdf:type rdf:Property ;
    rdfs:label 'Fee Category' ;
    rdfs:comment 'High-level grouping of the fee purpose.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Fee Exempt Flag' ;
    rdfs:comment 'True if the merchant is exempt from this fee under special conditions.' ;
    rdfs:domain ind:MerchantFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeExemptReason rdf:type rdf:Property ;
    rdfs:label 'Fee Exempt Reason' ;
    rdfs:comment 'Narrative explaining why the fee is exempted.' ;
    rdfs:domain ind:MerchantFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeOverrideAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Fee Override Allowed Flag' ;
    rdfs:comment 'True if the fee amount or rate can be manually overridden for a specific merchant.' ;
    rdfs:domain ind:MerchantFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Fee Override Reason' ;
    rdfs:comment 'Explanation for any manual override of the fee.' ;
    rdfs:domain ind:MerchantFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feePercentage rdf:type rdf:Property ;
    rdfs:label 'Fee Percentage' ;
    rdfs:comment 'Percentage applied to the transaction amount when fee_basis is percentage.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeSource rdf:type rdf:Property ;
    rdfs:label 'Fee Source' ;
    rdfs:comment 'Origin of the fee definition.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeTaxableFlag rdf:type rdf:Property ;
    rdfs:label 'Fee Taxable Flag' ;
    rdfs:comment 'Indicates whether the fee is subject to tax.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeVersion rdf:type rdf:Property ;
    rdfs:label 'Fee Version' ;
    rdfs:comment 'Incremental version number for change management.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether the fee recurs on a regular billing cycle.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date when the fee schedule was last reviewed for accuracy or compliance.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Max Fee Amount' ;
    rdfs:comment 'Ceiling amount that the fee will not exceed.' ;
    rdfs:domain ind:MerchantFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchantFeeScheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Merchant Fee Schedule Description' ;
    rdfs:comment 'Human-readable description of the fee schedule purpose and any special conditions.' ;
    rdfs:domain ind:MerchantFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantFeeScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Merchant Fee Schedule Status' ;
    rdfs:comment 'Current lifecycle state of the fee schedule.' ;
    rdfs:domain ind:MerchantFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Min Fee Amount' ;
    rdfs:comment 'Floor amount that the fee will not go below.' ;
    rdfs:domain ind:MerchantFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Numeric priority used when multiple schedules could apply; lower numbers have higher precedence.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Human-readable code used to reference the fee schedule in merchant contracts and internal systems.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'Applicable tax rate when fee_taxable_flag is true.' ;
    rdfs:domain ind:MerchantFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierEndAmount rdf:type rdf:Property ;
    rdfs:label 'Tier End Amount' ;
    rdfs:comment 'Upper bound of transaction amount for a tiered fee range (exclusive).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tier Rate Percentage' ;
    rdfs:comment 'Percentage applied within the defined tier range.' ;
    rdfs:domain ind:MerchantFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierStartAmount rdf:type rdf:Property ;
    rdfs:label 'Tier Start Amount' ;
    rdfs:comment 'Lower bound of transaction amount for a tiered fee range (inclusive).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correspondentBankId rdf:type rdf:Property ;
    rdfs:label 'Correspondent Bank Id' ;
    rdfs:comment 'Foreign key linking to fx.correspondent_bank. Business justification: International merchant settlement accounts route funds through correspondent banks for cross-border FX settlement. Treasury and settlement operations teams require this link for nostro account reconci' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrespondentBank .

ind:accountCloseDate rdf:type rdf:Property ;
    rdfs:label 'Account Close Date' ;
    rdfs:comment 'Date when the bank account was closed or de-activated (nullable).' ;
    rdfs:domain ind:MerchantSettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountHolderName rdf:type rdf:Property ;
    rdfs:label 'Account Holder Name' ;
    rdfs:comment 'Legal name of the individual or organization that holds the settlement bank account.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHolderType rdf:type rdf:Property ;
    rdfs:label 'Account Holder Type' ;
    rdfs:comment 'Indicates whether the account holder is an individual or a legal entity.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumberMasked rdf:type rdf:Property ;
    rdfs:label 'Account Number Masked' ;
    rdfs:comment 'Bank account number displayed with masking for security (e.g., ****1234).' ;
    rdfs:domain ind:MerchantSettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumberToken rdf:type rdf:Property ;
    rdfs:label 'Account Number Token' ;
    rdfs:comment 'PCI-P2PE token representing the underlying bank account number.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountOpenDate rdf:type rdf:Property ;
    rdfs:label 'Account Open Date' ;
    rdfs:comment 'Date when the bank account was originally opened.' ;
    rdfs:domain ind:MerchantSettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankBranch rdf:type rdf:Property ;
    rdfs:label 'Bank Branch' ;
    rdfs:comment 'Branch or location identifier of the bank (e.g., city or branch code).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Name of the financial institution where the settlement account is held.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bicSwift rdf:type rdf:Property ;
    rdfs:label 'Bic Swift' ;
    rdfs:comment 'SWIFT code identifying the bank for international transfers.' ;
    rdfs:domain ind:MerchantSettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'Standardized international bank account number used for cross-border settlements.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this is the merchant\'s primary settlement account.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTokenized rdf:type rdf:Property ;
    rdfs:label 'Is Tokenized' ;
    rdfs:comment 'True if the account number is stored as a token rather than clear text.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful verification of the account.' ;
    rdfs:domain ind:MerchantSettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:merchantSettlementAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Merchant Settlement Account Status' ;
    rdfs:comment 'Current lifecycle state of the settlement account.' ;
    rdfs:domain ind:MerchantSettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciCompliant rdf:type rdf:Property ;
    rdfs:label 'Pci Compliant' ;
    rdfs:comment 'True if the settlement account handling meets PCI DSS requirements.' ;
    rdfs:domain ind:MerchantSettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Domestic routing number used for ACH or wire transfers.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingLimitId rdf:type rdf:Property ;
    rdfs:label 'Processing Limit Id' ;
    rdfs:comment 'System-generated unique identifier for the processing limit record.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessingLimit .

ind:controlId rdf:type rdf:Property ;
    rdfs:label 'Control Id' ;
    rdfs:comment 'Reference to the specific compliance rule governing this limit.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Control .

ind:fraudVelocityControlId rdf:type rdf:Property ;
    rdfs:label 'Fraud Velocity Control Id' ;
    rdfs:comment 'Foreign key linking to fraud.fraud_velocity_control. Business justification: Processing limits are frequently set or tightened in direct response to fraud velocity control breaches. Risk operations teams need to reference the specific velocity control that mandated a limit cha' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FraudVelocityControl .

ind:underwritingDecisionId rdf:type rdf:Property ;
    rdfs:label 'Underwriting Decision Id' ;
    rdfs:comment 'Reference to the underwriting decision record that approved the limit.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnderwritingDecision .

ind:cardNotPresentLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Card Not Present Limit Amount' ;
    rdfs:comment 'Maximum amount allowed for card-not-present (CNP) transactions.' ;
    rdfs:domain ind:ProcessingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossBorderLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Cross Border Limit Amount' ;
    rdfs:comment 'Maximum monetary value for cross-border transactions.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyTransactionCountLimit rdf:type rdf:Property ;
    rdfs:label 'Daily Transaction Count Limit' ;
    rdfs:comment 'Maximum number of individual transactions permitted per day.' ;
