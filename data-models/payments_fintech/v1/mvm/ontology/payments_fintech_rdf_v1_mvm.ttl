ind:postingRule rdf:type rdf:Property ;
    rdfs:label 'Posting Rule' ;
    rdfs:comment 'Rule that determines when transactions are recognized in the ledger.' ;
    rdfs:domain ind:Config ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainedEarningsAccount rdf:type rdf:Property ;
    rdfs:label 'Retained Earnings Account' ;
    rdfs:comment 'Account code where retained earnings are posted.' ;
