    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:occurrenceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Occurrence Timestamp' ;
    rdfs:comment 'Exact time the fraudulent loss was realized in the payment flow.' ;
