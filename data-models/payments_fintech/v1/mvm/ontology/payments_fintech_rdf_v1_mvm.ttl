ind:regulatoryReporting rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting' ;
    rdfs:comment 'Regulatory frameworks applicable to the product.' ;
    rdfs:domain ind:A2aProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementWindowDays rdf:type rdf:Property ;
    rdfs:label 'Settlement Window Days' ;
    rdfs:comment 'Number of days between transaction initiation and settlement.' ;
    rdfs:domain ind:A2aProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stpEligibility rdf:type rdf:Property ;
    rdfs:label 'Stp Eligibility' ;
    rdfs:comment 'Indicates whether transactions can be processed end-to-end without manual intervention.' ;
    rdfs:domain ind:A2aProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liabilityGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Liability Gl Account Id' ;
    rdfs:comment 'Foreign key linking to ledger.gl_account. Business justification: Virtual account products hold customer balances that must be tracked as liabilities on the balance sheet. Financial reporting and regulatory capital adequacy calculations require mapping virtual accou' ;
    rdfs:domain ind:VirtualAccountProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:allowedMccCodes rdf:type rdf:Property ;
    rdfs:label 'Allowed Mcc Codes' ;
    rdfs:comment 'Comma-separated list of Merchant Category Codes permitted for transactions on this virtual account.' ;
    rdfs:domain ind:VirtualAccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Business classification that groups the product for reporting and eligibility rules.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Issuance Fee Amount' ;
    rdfs:comment 'One-time fee charged when the virtual account is created.' ;
