ind:supportContactPhone rdf:type rdf:Property ;
    rdfs:label 'Support Contact Phone' ;
    rdfs:comment 'Phone number of the merchant\'s technical support contact for this integration.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
