    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalFeesAmount rdf:type rdf:Property ;
    rdfs:label 'Total Fees Amount' ;
    rdfs:comment 'Total fees deducted from the gross amount for the cycle.' ;
