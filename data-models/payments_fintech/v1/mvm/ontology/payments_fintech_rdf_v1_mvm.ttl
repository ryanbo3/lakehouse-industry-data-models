ind:reserveGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Reserve Gl Account Id' ;
    rdfs:comment 'Foreign key linking to ledger.gl_account. Business justification: Risk profiles drive reserve requirements; reserve balances are held in specific GL liability accounts. Payments fintechs link risk profiles to reserve GL accounts for financial reporting of merchant r' ;
    rdfs:domain ind:RiskProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:businessModelRiskClassification rdf:type rdf:Property ;
    rdfs:label 'Business Model Risk Classification' ;
    rdfs:comment 'Risk classification based on the merchant\'s business model and industry exposure.' ;
    rdfs:domain ind:RiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackRate3mRolling rdf:type rdf:Property ;
    rdfs:label 'Chargeback Rate 3m Rolling' ;
    rdfs:comment 'Average chargeback rate over the trailing three-month window.' ;
