ind:averageMonthlyVolume rdf:type rdf:Property ;
    rdfs:label 'Average Monthly Volume' ;
    rdfs:comment 'Average monetary volume of transactions per month for the sub-merchant.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:industryCode rdf:type rdf:Property ;
    rdfs:label 'Industry Code' ;
    rdfs:comment 'Standard industry code describing the sub-merchant\'s sector.' ;
