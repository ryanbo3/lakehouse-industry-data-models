ind:limitType rdf:type rdf:Property ;
    rdfs:label 'Limit Type' ;
    rdfs:comment 'Category of the limit, indicating which transaction dimension it governs. [ENUM-REF-CANDIDATE: single_transaction|daily_volume|monthly_tpv|transaction_count|cnp|cross_border|refund — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
