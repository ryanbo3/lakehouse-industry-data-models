ind:pciDssAuditId rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Audit Id' ;
    rdfs:comment 'Foreign key linking to compliance.pci_dss_audit. Business justification: A merchant\'s PCI compliance record is directly produced by a PCI DSS audit. QSA assessments (pci_dss_audit) determine the merchant\'s compliance level and next assessment date. Payments compliance team' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PciDssAudit .

ind:aocReference rdf:type rdf:Property ;
    rdfs:label 'Aoc Reference' ;
    rdfs:comment 'Identifier or URI of the Attestation of Compliance (AOC) document submitted by the merchant.' ;
    rdfs:domain ind:PciCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedQsaName rdf:type rdf:Property ;
    rdfs:label 'Assigned Qsa Name' ;
