ind:nickname rdf:type rdf:Property ;
    rdfs:label 'Nickname' ;
    rdfs:comment 'User-defined short name for the settlement account, used in UI displays.' ;
    rdfs:domain ind:SettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerPartyType rdf:type rdf:Property ;
    rdfs:label 'Owner Party Type' ;
    rdfs:comment 'Indicates whether the account belongs to an acquiring bank, issuing bank, or payment scheme.' ;
    rdfs:domain ind:SettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtgsSupported rdf:type rdf:Property ;
    rdfs:label 'Rtgs Supported' ;
    rdfs:comment 'Indicates whether the account can be used for Real-Time Gross Settlement transfers.' ;
    rdfs:domain ind:SettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rtpSupported rdf:type rdf:Property ;
    rdfs:label 'Rtp Supported' ;
    rdfs:comment 'Indicates whether the account can be used for Real-Time Payments transfers.' ;
    rdfs:domain ind:SettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Account Status' ;
    rdfs:comment 'Current lifecycle status of the settlement account.' ;
    rdfs:domain ind:SettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCycle rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle' ;
    rdfs:comment 'Frequency at which the account participates in settlement runs.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Status Effective Date' ;
    rdfs:comment 'Date on which the current status became effective.' ;
    rdfs:domain ind:SettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reserveAccountId rdf:type rdf:Property ;
    rdfs:label 'Reserve Account Id' ;
    rdfs:comment 'Unique system-generated identifier for the reserve account record.' ;
    rdfs:domain ind:Settlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReserveAccount .

ind:heldAmount rdf:type rdf:Property ;
    rdfs:label 'Held Amount' ;
    rdfs:comment 'Principal amount currently held in the reserve account.' ;
    rdfs:domain ind:ReserveAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Release Timestamp' ;
    rdfs:comment 'Timestamp of the most recent reserve fund release.' ;
    rdfs:domain ind:ReserveAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nextReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Release Timestamp' ;
    rdfs:comment 'Planned timestamp for the upcoming reserve fund release.' ;
    rdfs:domain ind:ReserveAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releaseConditions rdf:type rdf:Property ;
    rdfs:label 'Release Conditions' ;
    rdfs:comment 'Business rules or triggers that allow reserve release (e.g., chargeback threshold met).' ;
    rdfs:domain ind:ReserveAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseInterval rdf:type rdf:Property ;
    rdfs:label 'Release Interval' ;
    rdfs:comment 'Scheduled frequency at which reserve funds may be released.' ;
    rdfs:domain ind:ReserveAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Reserve Account Number' ;
    rdfs:comment 'External reference number assigned to the reserve account for reporting and reconciliation.' ;
    rdfs:domain ind:ReserveAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveCapAmount rdf:type rdf:Property ;
    rdfs:label 'Reserve Cap Amount' ;
    rdfs:comment 'Maximum monetary cap for a capped reserve type.' ;
    rdfs:domain ind:ReserveAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reserveName rdf:type rdf:Property ;
    rdfs:label 'Reserve Name' ;
    rdfs:comment 'Human-readable name identifying the reserve account (e.g., "Merchant XYZ Rolling Reserve").' ;
    rdfs:domain ind:ReserveAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveType rdf:type rdf:Property ;
    rdfs:label 'Reserve Type' ;
    rdfs:comment 'Classification of the reserve mechanism: rolling, capped, or fixed.' ;
    rdfs:domain ind:ReserveAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementReserveAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Reserve Account Status' ;
    rdfs:comment 'Current lifecycle status of the reserve account.' ;
    rdfs:domain ind:ReserveAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionSequence rdf:type rdf:Property ;
    rdfs:label 'Deduction Sequence' ;
    rdfs:comment 'Ordered list of deductions applied to the gross amount (e.g., MDR, interchange, chargebacks, reserves).' ;
    rdfs:domain ind:FundingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingScheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Funding Schedule Description' ;
    rdfs:comment 'Optional narrative describing special rules or notes for the schedule.' ;
    rdfs:domain ind:FundingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Funding Schedule Status' ;
    rdfs:comment 'Current operational status of the schedule.' ;
    rdfs:domain ind:FundingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Hold Period Days' ;
    rdfs:comment 'Number of days to hold settled proceeds before they become eligible for funding.' ;
    rdfs:domain ind:FundingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastRunStatus rdf:type rdf:Property ;
    rdfs:label 'Last Run Status' ;
    rdfs:comment 'Result of the most recent funding run.' ;
    rdfs:domain ind:FundingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Run Timestamp' ;
    rdfs:comment 'Timestamp when the schedule was last executed.' ;
    rdfs:domain ind:FundingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:minimumFundingThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Funding Threshold' ;
    rdfs:comment 'Minimum net proceeds required before a funding run is triggered.' ;
    rdfs:domain ind:FundingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Run Timestamp' ;
    rdfs:comment 'Planned timestamp for the next funding execution.' ;
    rdfs:domain ind:FundingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:externalReference rdf:type rdf:Property ;
    rdfs:label 'External Reference' ;
    rdfs:comment 'Reference identifier from external payment network or partner.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdrAmount rdf:type rdf:Property ;
    rdfs:label 'Mdr Amount' ;
    rdfs:comment 'MDR fee deducted from the gross payout.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchantMid rdf:type rdf:Property ;
    rdfs:label 'Merchant Mid' ;
    rdfs:comment 'Merchant Identification Number of the receiving merchant.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msfAmount rdf:type rdf:Property ;
    rdfs:label 'Msf Amount' ;
    rdfs:comment 'MSF fee deducted from the gross payout.' ;
    rdfs:domain ind:MerchantPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPayoutAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payout Amount' ;
    rdfs:comment 'Net amount transferred to the merchant after all deductions.' ;
    rdfs:domain ind:MerchantPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partyReference rdf:type rdf:Property ;
    rdfs:label 'Party Reference' ;
    rdfs:comment 'Reference to the merchant party receiving the payout.' ;
    rdfs:domain ind:MerchantPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payoutAmount rdf:type rdf:Property ;
    rdfs:label 'Payout Amount' ;
    rdfs:comment 'Total gross amount before any deductions.' ;
    rdfs:domain ind:MerchantPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payoutMethod rdf:type rdf:Property ;
    rdfs:label 'Payout Method' ;
    rdfs:comment 'Method used to transfer the payout funds.' ;
    rdfs:domain ind:MerchantPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payoutReference rdf:type rdf:Property ;
    rdfs:label 'Payout Reference' ;
    rdfs:comment 'Unique reference code assigned to the payout transaction by the system.' ;
    rdfs:domain ind:MerchantPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payoutStatus rdf:type rdf:Property ;
    rdfs:label 'Payout Status' ;
    rdfs:comment 'Current processing status of the payout.' ;
    rdfs:domain ind:MerchantPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payoutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payout Timestamp' ;
    rdfs:comment 'Timestamp when the payout was initiated.' ;
    rdfs:domain ind:MerchantPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Total refunds deducted from the payout.' ;
    rdfs:domain ind:MerchantPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reserveHoldAmount rdf:type rdf:Property ;
    rdfs:label 'Reserve Hold Amount' ;
    rdfs:comment 'Amount held in reserve and not released.' ;
    rdfs:domain ind:MerchantPayout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementExceptionId rdf:type rdf:Property ;
    rdfs:label 'Settlement Exception Id' ;
    rdfs:comment 'Unique system-generated identifier for the settlement exception record.' ;
    rdfs:domain ind:Settlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SettlementException .

ind:affectedInstructionId rdf:type rdf:Property ;
    rdfs:label 'Affected Instruction Id' ;
    rdfs:comment 'Identifier of the specific settlement instruction linked to the exception.' ;
    rdfs:domain ind:SettlementException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instruction .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Description of the action taken to remediate the exception.' ;
    rdfs:domain ind:SettlementException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Technical error code returned by the processing engine.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Human-readable error description associated with the exception.' ;
    rdfs:domain ind:PaymentsFintech ;
