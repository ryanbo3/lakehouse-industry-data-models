    rdfs:range xsd:boolean .

ind:contractEffectiveEnd rdf:type rdf:Property ;
    rdfs:label 'Contract Effective End' ;
    rdfs:comment 'Contract end date (nullable if open-ended).' ;
    rdfs:domain ind:PartnerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractEffectiveStart rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Start' ;
