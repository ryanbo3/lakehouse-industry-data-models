    rdfs:comment 'Origin of the risk assessment data.' ;
    rdfs:domain ind:RiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDecisionReason rdf:type rdf:Property ;
    rdfs:label 'Risk Decision Reason' ;
    rdfs:comment 'Free-text explanation for the risk decision applied to the counterparty.' ;
    rdfs:domain ind:RiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskExposureLimit rdf:type rdf:Property ;
    rdfs:label 'Risk Exposure Limit' ;
    rdfs:comment 'Maximum monetary exposure the organization is willing to accept for this counterparty.' ;
    rdfs:domain ind:RiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskExposureUsed rdf:type rdf:Property ;
