    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskEventStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Event Status' ;
    rdfs:comment 'Current lifecycle status of the risk event record.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Business-defined severity of the event, used for prioritization and escalation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCaseId rdf:type rdf:Property ;
    rdfs:label 'Risk Case Id' ;
    rdfs:comment 'Unique system-generated identifier for the risk investigation case.' ;
