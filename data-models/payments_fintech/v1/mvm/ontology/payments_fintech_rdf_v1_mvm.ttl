ind:activationRules rdf:type rdf:Property ;
    rdfs:label 'Activation Rules' ;
    rdfs:comment 'Business rules or conditions that must be satisfied for the feature to be activated (e.g., eligibility criteria, risk thresholds).' ;
    rdfs:domain ind:Feature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureCode rdf:type rdf:Property ;
    rdfs:label 'Feature Code' ;
    rdfs:comment 'Unique business code used to reference the feature in configurations and contracts.' ;
    rdfs:domain ind:Feature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureDescription rdf:type rdf:Property ;
    rdfs:label 'Feature Description' ;
    rdfs:comment 'Detailed description of the feature, its purpose and behavior.' ;
    rdfs:domain ind:Feature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureName rdf:type rdf:Property ;
    rdfs:label 'Feature Name' ;
    rdfs:comment 'Human-readable name of the feature.' ;
    rdfs:domain ind:Feature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureStatus rdf:type rdf:Property ;
