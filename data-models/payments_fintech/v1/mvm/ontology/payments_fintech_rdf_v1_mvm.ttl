ind:entityName rdf:type rdf:Property ;
    rdfs:label 'Entity Name' ;
    rdfs:comment 'Legal name of the individual, organization, or vessel as listed on the watchlist.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationNumber rdf:type rdf:Property ;
    rdfs:label 'Identification Number' ;
    rdfs:comment 'Official identifier such as passport number, national ID, or tax ID.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationType rdf:type rdf:Property ;
    rdfs:label 'Identification Type' ;
    rdfs:comment 'Type of the identification number provided.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listEntryReference rdf:type rdf:Property ;
    rdfs:label 'List Entry Reference' ;
    rdfs:comment 'Identifier used by the source list to reference this entry (e.g., SDN ID).' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listSource rdf:type rdf:Property ;
    rdfs:label 'List Source' ;
    rdfs:comment 'Originating sanctions or watchlist source for the entry.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listVersionDate rdf:type rdf:Property ;
    rdfs:label 'List Version Date' ;
    rdfs:comment 'Date of the version of the source list that contains this entry.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:placeOfBirth rdf:type rdf:Property ;
    rdfs:label 'Place Of Birth' ;
    rdfs:comment 'Geographic location where the individual was born.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsType rdf:type rdf:Property ;
    rdfs:label 'Sanctions Type' ;
    rdfs:comment 'Primary type of sanction applied to the entity.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceUrl rdf:type rdf:Property ;
    rdfs:label 'Source Url' ;
    rdfs:comment 'Web address or document reference where the entry was originally published.' ;
    rdfs:domain ind:WatchlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachedFileReference rdf:type rdf:Property ;
    rdfs:label 'Attached File Reference' ;
    rdfs:comment 'Reference to the file storage location (e.g., S3 key).' ;
    rdfs:domain ind:PolicyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionScope rdf:type rdf:Property ;
    rdfs:label 'Distribution Scope' ;
    rdfs:comment 'Intended audience or reach of the policy.' ;
    rdfs:domain ind:PolicyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDocumentDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Document Description' ;
    rdfs:comment 'Narrative description of the policy purpose and scope.' ;
    rdfs:domain ind:PolicyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDocumentName rdf:type rdf:Property ;
    rdfs:label 'Policy Document Name' ;
    rdfs:comment 'Human-readable name of the policy or procedure.' ;
    rdfs:domain ind:PolicyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDocumentStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Document Status' ;
    rdfs:comment 'Current lifecycle status of the policy.' ;
    rdfs:domain ind:PolicyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlCtfRegime rdf:type rdf:Property ;
    rdfs:label 'Aml Ctf Regime' ;
    rdfs:comment 'Classification of the jurisdiction\'s anti-money-laundering and counter-terrorism financing regime (e.g., FATF, Non-FATF).' ;
    rdfs:domain ind:JurisdictionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableRegulations rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulations' ;
    rdfs:comment 'Comma-separated list of regulation codes that apply in this jurisdiction (e.g., PSD2, Reg E, APRA CPS 234).' ;
    rdfs:domain ind:JurisdictionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOwner rdf:type rdf:Property ;
    rdfs:label 'Compliance Owner' ;
    rdfs:comment 'Name of the internal owner responsible for this jurisdiction\'s compliance data.' ;
    rdfs:domain ind:JurisdictionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProtectionLaw rdf:type rdf:Property ;
    rdfs:label 'Data Protection Law' ;
    rdfs:comment 'Primary data-privacy legislation governing the jurisdiction (e.g., GDPR).' ;
    rdfs:domain ind:JurisdictionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataResidencyRequirements rdf:type rdf:Property ;
    rdfs:label 'Data Residency Requirements' ;
    rdfs:comment 'Specific data residency or localisation obligations imposed by the jurisdiction.' ;
    rdfs:domain ind:JurisdictionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatfMutualEvaluationRating rdf:type rdf:Property ;
    rdfs:label 'Fatf Mutual Evaluation Rating' ;
    rdfs:comment 'Latest FATF mutual-evaluation rating for the jurisdiction.' ;
    rdfs:domain ind:JurisdictionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionProfileDescription rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Profile Description' ;
    rdfs:comment 'Extended textual description of the jurisdiction profile.' ;
    rdfs:domain ind:JurisdictionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionProfileName rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Profile Name' ;
    rdfs:comment 'Human-readable name of the jurisdiction (e.g., United States, European Union).' ;
    rdfs:domain ind:JurisdictionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionProfileStatus rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Profile Status' ;
    rdfs:comment 'Current lifecycle status of the jurisdiction profile.' ;
    rdfs:domain ind:JurisdictionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionType rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Type' ;
    rdfs:comment 'Specific type classification of the jurisdiction.' ;
    rdfs:domain ind:JurisdictionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Identifier' ;
    rdfs:comment '20-character global identifier for legal entities operating in the jurisdiction.' ;
    rdfs:domain ind:JurisdictionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDailyVolume rdf:type rdf:Property ;
    rdfs:label 'Max Daily Volume' ;
    rdfs:comment 'Regulatory limit on total daily transaction volume for a participant.' ;
    rdfs:domain ind:JurisdictionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:privacyRegulation rdf:type rdf:Property ;
    rdfs:label 'Privacy Regulation' ;
    rdfs:comment 'Specific privacy regulation reference applicable in the jurisdiction.' ;
    rdfs:domain ind:JurisdictionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryZone rdf:type rdf:Property ;
    rdfs:label 'Regulatory Zone' ;
    rdfs:comment 'Geographic regulatory zone grouping (e.g., EU, APAC).' ;
    rdfs:domain ind:JurisdictionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsRegimeMembership rdf:type rdf:Property ;
    rdfs:label 'Sanctions Regime Membership' ;
    rdfs:comment 'Sanctions lists or regimes the jurisdiction participates in.' ;
    rdfs:domain ind:JurisdictionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumberFormat rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number Format' ;
    rdfs:comment 'Pattern or description of the tax ID format used in the jurisdiction.' ;
    rdfs:domain ind:JurisdictionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultCurrencyPairId rdf:type rdf:Property ;
    rdfs:label 'Default Currency Pair Id' ;
    rdfs:comment 'Foreign key linking to fx.currency_pair. Business justification: Partner defines a default currency pair for all cross-border payments, needed for routing, DCC offers and regulatory reporting.' ;
    rdfs:domain ind:EcosystemPartner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CurrencyPair .

ind:parentPartnerEcosystemPartnerId rdf:type rdf:Property ;
    rdfs:label 'Parent Partner Ecosystem Partner Id' ;
    rdfs:comment 'Identifier of the parent partner in hierarchical relationships, if applicable.' ;
    rdfs:domain ind:EcosystemPartner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EcosystemPartner .

ind:apiIntegrationEndpoint rdf:type rdf:Property ;
    rdfs:label 'Api Integration Endpoint' ;
    rdfs:comment 'Base URL or endpoint used for API integration with the partner.' ;
    rdfs:domain ind:EcosystemPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiKeyIdentifier rdf:type rdf:Property ;
    rdfs:label 'Api Key Identifier' ;
    rdfs:comment 'Identifier for the API key used to authenticate calls to the partner.' ;
    rdfs:domain ind:EcosystemPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Contact Address Line1' ;
    rdfs:comment 'First line of the partner\'s primary mailing address.' ;
    rdfs:domain ind:EcosystemPartner ;
    rdf:type owl:DatatypeProperty ;
