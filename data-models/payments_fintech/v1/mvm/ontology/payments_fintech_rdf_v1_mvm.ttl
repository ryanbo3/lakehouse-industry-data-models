    rdfs:range xsd:decimal .

ind:maintenanceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Maintenance Fee Amount' ;
    rdfs:comment 'Recurring fee for maintaining the virtual account product.' ;
    rdfs:domain ind:VirtualAccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Max Balance Amount' ;
    rdfs:comment 'Upper bound on the cumulative balance that can be held in the virtual account.' ;
    rdfs:domain ind:VirtualAccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promoEligible rdf:type rdf:Property ;
    rdfs:label 'Promo Eligible' ;
    rdfs:comment 'Indicates whether the product can be included in promotional offers.' ;
    rdfs:domain ind:VirtualAccountProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spendControlRules rdf:type rdf:Property ;
    rdfs:label 'Spend Control Rules' ;
    rdfs:comment 'JSON-encoded rules that define merchant category restrictions, geographic limits, and velocity controls.' ;
