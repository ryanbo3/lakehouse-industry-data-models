    rdfs:comment 'Current lifecycle status of the feature.' ;
    rdfs:domain ind:Feature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureType rdf:type rdf:Property ;
    rdfs:label 'Feature Type' ;
    rdfs:comment 'Categorization of the feature based on its functional role.' ;
