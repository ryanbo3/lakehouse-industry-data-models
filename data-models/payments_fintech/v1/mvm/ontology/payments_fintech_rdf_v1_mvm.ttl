ind:steps rdf:type rdf:Property ;
    rdfs:label 'Steps' ;
    rdfs:comment 'Chronological description of steps taken during investigation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Brief title or description of the investigation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceId rdf:type rdf:Property ;
    rdfs:label 'Evidence Id' ;
    rdfs:comment 'Unique surrogate key for each fraud evidence record.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidenceFraudCaseId rdf:type rdf:Property ;
    rdfs:label 'Evidence Fraud Case Id' ;
    rdfs:comment 'Identifier of the fraud case to which this evidence belongs.' ;
    rdfs:domain ind:Evidence ;
    rdf:type owl:ObjectProperty ;
