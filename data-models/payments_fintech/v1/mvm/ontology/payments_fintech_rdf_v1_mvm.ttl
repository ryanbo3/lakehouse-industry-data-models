    rdfs:domain ind:Cardholder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CardholderProfile .

ind:amlCheckPassed rdf:type rdf:Property ;
    rdfs:label 'Aml Check Passed' ;
    rdfs:comment 'Result of the Anti-Money-Laundering screening performed during verification.' ;
    rdfs:domain ind:CardholderKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ctfCheckPassed rdf:type rdf:Property ;
    rdfs:label 'Ctf Check Passed' ;
    rdfs:comment 'Result of the Counter-Terrorism Financing screening performed during verification.' ;
    rdfs:domain ind:CardholderKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentHash rdf:type rdf:Property ;
    rdfs:label 'Document Hash' ;
    rdfs:comment 'SHA-256 hash of the submitted document to ensure integrity.' ;
    rdfs:domain ind:CardholderKycVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Type of identity document submitted for verification.' ;
    rdfs:domain ind:Cardholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isScaCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Sca Compliant' ;
    rdfs:comment 'Indicates whether the verification satisfies Strong Customer Authentication requirements.' ;
    rdfs:domain ind:Cardholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuedAt rdf:type rdf:Property ;
    rdfs:label 'Issued At' ;
    rdfs:comment 'Exact time when the KYC verification was performed.' ;
