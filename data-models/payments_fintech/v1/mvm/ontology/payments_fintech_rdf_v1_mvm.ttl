ind:investigationSummary rdf:type rdf:Property ;
    rdfs:label 'Investigation Summary' ;
    rdfs:comment 'Free-text summary of investigative findings and actions.' ;
    rdfs:domain ind:RiskCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycStatusAtTime rdf:type rdf:Property ;
    rdfs:label 'Kyc Status At Time' ;
    rdfs:comment 'KYC verification status of the party when the case was opened.' ;
