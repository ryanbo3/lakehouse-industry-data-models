    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactCountry rdf:type rdf:Property ;
    rdfs:label 'Contact Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the partner\'s primary mailing address.' ;
