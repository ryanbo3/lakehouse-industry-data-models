    rdfs:range xsd:string .

ind:periodVersion rdf:type rdf:Property ;
    rdfs:label 'Period Version' ;
    rdfs:comment 'Version number of the period record to support re-open/re-close scenarios and audit trails.' ;
    rdfs:domain ind:AccountingPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversalOfJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Reversal Of Journal Entry Id' ;
    rdfs:comment 'Identifier of the original journal entry that this entry reverses, if applicable.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:accountingDate rdf:type rdf:Property ;
    rdfs:label 'Accounting Date' ;
    rdfs:comment 'The fiscal date to which the entry is posted for financial reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Code' ;
    rdfs:comment 'Code indicating the business reason for the adjustment.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Organizational department associated with the entry.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryNumber rdf:type rdf:Property ;
    rdfs:label 'Entry Number' ;
    rdfs:comment 'Business identifier assigned to the journal entry, often used in accounting reports.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Classification of the journal entry source such as payment processing, settlement, manual adjustment, intercompany, or recurring.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Date' ;
    rdfs:comment 'Date for which the exchange rate is applicable.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intercompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Flag' ;
    rdfs:comment 'True if the entry records an intercompany transaction.' ;
