ind:transactionVolumeLast30d rdf:type rdf:Property ;
    rdfs:label 'Transaction Volume Last 30d' ;
    rdfs:comment 'Aggregate count of transactions processed for the party over the preceding 30-day window.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedEntityRef rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Ref' ;
    rdfs:comment 'Unique identifier of the affected entity (e.g., transaction_id, merchant_id).' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedEntityType rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Type' ;
    rdfs:comment 'The type of business entity that the event pertains to.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'Probability confidence of the risk prediction (0-1 range).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Level of escalation required based on severity and impact.' ;
