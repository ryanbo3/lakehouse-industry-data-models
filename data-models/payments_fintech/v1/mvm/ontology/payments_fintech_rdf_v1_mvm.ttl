    rdfs:comment 'Day of month when billing cycle starts (1-31).' ;
    rdfs:domain ind:CardholderAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currencyConversionFlag rdf:type rdf:Property ;
