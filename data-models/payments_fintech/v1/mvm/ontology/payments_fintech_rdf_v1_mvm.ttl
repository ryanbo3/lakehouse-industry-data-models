    rdfs:comment 'Current processing status of the funding confirmation.' ;
    rdfs:domain ind:FundingConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingCurrency rdf:type rdf:Property ;
