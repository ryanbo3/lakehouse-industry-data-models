ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Internal version counter for the BOM record.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomLineId rdf:type rdf:Property ;
    rdfs:label 'Bom Line Id' ;
    rdfs:comment 'Unique identifier for the engineering_bom_line data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentAssemblyPartMasterId rdf:type rdf:Property ;
    rdfs:label 'Parent Assembly Part Master Id' ;
    rdfs:comment 'Foreign key linking to engineering.part_master. Business justification: Parent assembly reference is a part_master; replace with descriptive FK to part_master.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartMaster .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supply_supplier. Business justification: Supplier Management Process: engineering part master must be linked to the external supplier record for PPAP, cost, and lead-time tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:cadModelReference rdf:type rdf:Property ;
    rdfs:label 'Cad Model Reference' ;
    rdfs:comment 'Path or identifier of the CAD 3D model stored in the PLM system.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Usd' ;
    rdfs:comment 'Standard cost of the part in US dollars as defined in the ERP system.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticality rdf:type rdf:Property ;
    rdfs:label 'Criticality' ;
    rdfs:comment 'Criticality of the part to vehicle safety or performance.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eolReason rdf:type rdf:Property ;
    rdfs:label 'Eol Reason' ;
    rdfs:comment 'Reason for part end-of-life (e.g., technology superseded, supplier discontinued).' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Result of the latest inspection.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

