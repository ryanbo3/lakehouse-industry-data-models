    rdfs:range xsd:string .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Current release state of the BOM.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPartsCount rdf:type rdf:Property ;
