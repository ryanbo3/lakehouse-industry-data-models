ind:tsbPartRequirementId rdf:type rdf:Property ;
    rdfs:label 'Tsb Part Requirement Id' ;
    rdfs:comment 'System-generated unique identifier for this TSB-to-part requirement record.' ;
    rdfs:domain ind:TsbPartRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isPrimaryPart rdf:type rdf:Property ;
    rdfs:label 'Is Primary Part' ;
    rdfs:comment 'Indicates whether this part is the primary component being replaced (true) or a supplemental part (gasket, fastener, fluid). Identified in detection reasoning as relationship-specific data.' ;
    rdfs:domain ind:TsbPartRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partRoleInProcedure rdf:type rdf:Property ;
    rdfs:label 'Part Role In Procedure' ;
    rdfs:comment 'Categorizes the part\'s function within the TSB repair procedure (e.g., primary replacement component, supplemental gasket, consumable fluid, diagnostic tool, optional upgrade). Identified in detection reasoning as relationship-specific data.' ;
    rdfs:domain ind:TsbPartRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredParts rdf:type rdf:Property ;
    rdfs:label 'Required Parts' ;
    rdfs:comment 'Comma-separated list of part numbers and revisions needed for the repair. [Moved from tsb: The tsb.required_parts STRING attribute is a denormalized representation of the M:N relationship. This comma-separated list should be normalized into individual tsb_part_requirement records. This is the classic indicator of a collapsed M:N relationship.]' ;
    rdfs:domain ind:TsbPartRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingOperationId rdf:type rdf:Property ;
    rdfs:label 'Routing Operation Id' ;
    rdfs:comment 'Primary key for the routing operation association record' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCriticalPath rdf:type rdf:Property ;
    rdfs:label 'Is Critical Path' ;
    rdfs:comment 'Indicates whether this operation is on the critical path for this routing, affecting overall production lead time.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardCycleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Standard Cycle Time Seconds' ;
    rdfs:comment 'Standard cycle time in seconds for this specific operation at this work center within this routing. This is operation-specific and may differ from the work center\'s general cycle_time_seconds. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:RoutingOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testRequirementComplianceId rdf:type rdf:Property ;
    rdfs:label 'Test Requirement Compliance Id' ;
    rdfs:comment 'Primary key for the test_requirement_compliance association' ;
    rdfs:domain ind:TestRequirementCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByAuthority rdf:type rdf:Property ;
