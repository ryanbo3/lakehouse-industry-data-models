ind:msrpCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Msrp Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the MSRP amount (e.g., USD, EUR, CNY, JPY).' ;
