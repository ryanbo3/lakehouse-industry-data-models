ind:customsTariffCode rdf:type rdf:Property ;
    rdfs:label 'Customs Tariff Code' ;
    rdfs:comment 'HS-8 tariff classification code used for import duties.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Last Received Date' ;
    rdfs:comment 'Date when the part was most recently received at the plant.' ;
    rdfs:domain ind:InboundPart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReceivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Last Received Quantity' ;
    rdfs:comment 'Quantity of the part received on the most recent receipt.' ;
    rdfs:domain ind:InboundPart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotSize rdf:type rdf:Property ;
    rdfs:label 'Lot Size' ;
    rdfs:comment 'Standard production batch size for the part.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Category indicating whether the part is raw material, sub-assembly, CKD kit, finished good, or service item.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oemPartNumber rdf:type rdf:Property ;
    rdfs:label 'Oem Part Number' ;
    rdfs:comment 'Original Equipment Manufacturer part number used internally for cross-reference.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUom rdf:type rdf:Property ;
    rdfs:label 'Price Uom' ;
    rdfs:comment 'Unit of measure used for the price (e.g., each, kilogram).' ;
    rdfs:domain ind:InboundPart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPointQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Quantity' ;
    rdfs:comment 'Inventory level that triggers a new purchase order.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'Buffer inventory quantity maintained to protect against supply variability.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingNominationId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Nomination Id' ;
    rdfs:comment 'System-generated unique identifier for each sourcing nomination record.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingNomination .

ind:customerOrganizationAccountId rdf:type rdf:Property ;
    rdfs:label 'Customer Organization Account Id' ;
    rdfs:comment 'Foreign key linking to customer.organization_account. Business justification: Fleet and government contracts often include customer-directed sourcing (e.g., fleet operator specifies tire brand, government contract mandates domestic suppliers). Tracks customer-driven supplier se' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrganizationAccount .

ind:isJis rdf:type rdf:Property ;
    rdfs:label 'Is Jis' ;
    rdfs:comment 'Indicates whether the nominated part is required under a JIS delivery strategy.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isJit rdf:type rdf:Property ;
    rdfs:label 'Is Jit' ;
    rdfs:comment 'Indicates whether the nominated part is required under a JIT delivery strategy.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kitType rdf:type rdf:Property ;
    rdfs:label 'Kit Type' ;
    rdfs:comment 'Specifies whether the part is supplied as a Completely Knocked Down (CKD) or Semi-Knocked Down (SKD) kit, or not a kit.' ;
    rdfs:domain ind:SourcingNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominatedVolume rdf:type rdf:Property ;
    rdfs:label 'Nominated Volume' ;
    rdfs:comment 'Total quantity of the part the supplier is expected to deliver for the program.' ;
    rdfs:domain ind:SourcingNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nominationDate rdf:type rdf:Property ;
    rdfs:label 'Nomination Date' ;
    rdfs:comment 'Timestamp when the OEM formally recorded the nomination.' ;
    rdfs:domain ind:SourcingNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nominationNumber rdf:type rdf:Property ;
    rdfs:label 'Nomination Number' ;
    rdfs:comment 'Human-readable business code assigned to the nomination for tracking and reference.' ;
    rdfs:domain ind:SourcingNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominationStatus rdf:type rdf:Property ;
    rdfs:label 'Nomination Status' ;
    rdfs:comment 'Current lifecycle status of the nomination.' ;
    rdfs:domain ind:SourcingNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Qualitative assessment of supply risk for the nominated part.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sorReference rdf:type rdf:Property ;
    rdfs:label 'Sor Reference' ;
    rdfs:comment 'Reference code linking to the SOR document that defines functional and performance requirements.' ;
    rdfs:domain ind:SourcingNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPiecePrice rdf:type rdf:Property ;
    rdfs:label 'Target Piece Price' ;
    rdfs:comment 'Target unit price (per piece) the OEM aims to achieve with the nominated supplier.' ;
    rdfs:domain ind:SourcingNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfqId rdf:type rdf:Property ;
    rdfs:label 'Rfq Id' ;
    rdfs:comment 'System-generated unique identifier for the RFQ record.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfq .

ind:attachmentFlag rdf:type rdf:Property ;
    rdfs:label 'Attachment Flag' ;
    rdfs:comment 'Indicates whether supporting documents are attached to the RFQ.' ;
