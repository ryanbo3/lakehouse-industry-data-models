    rdfs:range xsd:integer .

ind:fuelConsumptionLPer100km rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumption L Per 100km' ;
    rdfs:comment 'Average liters of fuel used per 100 kilometers by the carrier on this lane.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laneType rdf:type rdf:Property ;
    rdfs:label 'Lane Type' ;
    rdfs:comment 'Indicates whether the lane is domestic, export, or import.' ;
