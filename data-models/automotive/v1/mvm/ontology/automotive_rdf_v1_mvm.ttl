    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleProgramDescription rdf:type rdf:Property ;
    rdfs:label 'Vehicle Program Description' ;
    rdfs:comment 'Free-form textual description of the program objectives and scope.' ;
    rdfs:domain ind:VehicleProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleProgramStatus rdf:type rdf:Property ;
    rdfs:label 'Vehicle Program Status' ;
    rdfs:comment 'Current lifecycle status of the program.' ;
    rdfs:domain ind:VehicleProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomChangeId rdf:type rdf:Property ;
    rdfs:label 'Bom Change Id' ;
    rdfs:comment 'Identifier of the engineering change order linked to this BOM revision.' ;
    rdfs:domain ind:Bom ;
