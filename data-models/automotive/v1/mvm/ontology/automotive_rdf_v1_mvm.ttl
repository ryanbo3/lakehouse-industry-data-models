ind:authorizedDealerRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Authorized Dealer Required Flag' ;
    rdfs:comment 'Indicates whether warranty service must be performed at an authorized dealer (true) or can be performed at any qualified service center (false).' ;
