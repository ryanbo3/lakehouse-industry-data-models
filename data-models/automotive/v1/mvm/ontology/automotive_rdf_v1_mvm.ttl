    rdfs:comment 'Current purchase cost of the material per kilogram in US dollars.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:densityKgPerM3 rdf:type rdf:Property ;
    rdfs:label 'Density Kg Per M3' ;
    rdfs:comment 'Mass per unit volume of the material.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elongationPercent rdf:type rdf:Property ;
    rdfs:label 'Elongation Percent' ;
    rdfs:comment 'Percent increase in length at fracture, indicating ductility.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalImpactScore rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Score' ;
    rdfs:comment 'Numeric score representing the material\'s environmental footprint.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeOrAlloy rdf:type rdf:Property ;
    rdfs:label 'Grade Or Alloy' ;
    rdfs:comment 'Specific grade or alloy designation (e.g., 6061-T6, 304L).' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialClass rdf:type rdf:Property ;
    rdfs:label 'Material Class' ;
    rdfs:comment 'High-level classification of the material type.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialSpecificationName rdf:type rdf:Property ;
    rdfs:label 'Material Specification Name' ;
    rdfs:comment 'Human-readable name of the material specification.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialSpecificationStatus rdf:type rdf:Property ;
    rdfs:label 'Material Specification Status' ;
    rdfs:comment 'Current operational status of the specification.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialSpecificationType rdf:type rdf:Property ;
    rdfs:label 'Material Specification Type' ;
    rdfs:comment 'Primary functional category of the material.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificHeatJPerKgk rdf:type rdf:Property ;
    rdfs:label 'Specific Heat J Per Kgk' ;
    rdfs:comment 'Energy required to raise the temperature of 1 kg of material by 1 K.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surfaceTreatment rdf:type rdf:Property ;
    rdfs:label 'Surface Treatment' ;
    rdfs:comment 'Required surface finishing process for the material.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tensileStrengthMpa rdf:type rdf:Property ;
    rdfs:label 'Tensile Strength Mpa' ;
    rdfs:comment 'Maximum stress the material can withstand while being stretched before breaking.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thermalConductivityWPerMk rdf:type rdf:Property ;
    rdfs:label 'Thermal Conductivity W Per Mk' ;
    rdfs:comment 'Rate at which heat passes through the material.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldStrengthMpa rdf:type rdf:Property ;
    rdfs:label 'Yield Strength Mpa' ;
    rdfs:comment 'Stress at which material begins to deform plastically.' ;
    rdfs:domain ind:MaterialSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentId rdf:type rdf:Property ;
    rdfs:label 'Document Id' ;
    rdfs:comment 'Unique surrogate key for the engineering document record.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Business identifier assigned to the document (e.g., drawing number, specification code).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Category of the engineering document. [ENUM-REF-CANDIDATE: drawing|specification|test_report|analysis_report|fmea|dvp|meeting_minutes — promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineeringDocumentStatus rdf:type rdf:Property ;
    rdfs:label 'Engineering Document Status' ;
    rdfs:comment 'Current lifecycle state of the document.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'Logical path or URI to the document file in the repository.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the document file in bytes.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'File format of the stored document.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDigitalTwinReady rdf:type rdf:Property ;
    rdfs:label 'Is Digital Twin Ready' ;
    rdfs:comment 'Indicates whether the document is linked to a digital twin model.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionPolicy rdf:type rdf:Property ;
    rdfs:label 'Retention Policy' ;
    rdfs:comment 'Policy governing how long the document must be retained.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revision rdf:type rdf:Property ;
    rdfs:label 'Revision' ;
    rdfs:comment 'Revision identifier indicating the version of the document (e.g., A, B, C, 1.0, 2.1).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierPlantId rdf:type rdf:Property ;
    rdfs:label 'Supplier Plant Id' ;
    rdfs:comment 'Foreign key linking to supply.supply_supplier_plant. Business justification: Part approvals are granted at the plant level — a supplier may have multiple plants and each plant\'s manufacturing process must be independently approved. This FK links the approval to the specific pl' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierPlant .

ind:approvalNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Number' ;
    rdfs:comment 'External business identifier assigned to the approval record, often used in audit and reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalOutcome rdf:type rdf:Property ;
    rdfs:label 'Approval Outcome' ;
    rdfs:comment 'Result of the PPAP review: approved, interim approval, or rejected.' ;
    rdfs:domain ind:SupplierPartApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalScore rdf:type rdf:Property ;
    rdfs:label 'Approval Score' ;
    rdfs:comment 'Numeric score (0-100) reflecting overall assessment of the part\'s compliance.' ;
    rdfs:domain ind:SupplierPartApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Name of the engineer or manager who approved the part.' ;
    rdfs:domain ind:SupplierPartApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capabilityStudyStatus rdf:type rdf:Property ;
    rdfs:label 'Capability Study Status' ;
    rdfs:comment 'Status of the capability study element.' ;
    rdfs:domain ind:SupplierPartApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Business classification indicating the importance of the part.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Control Plan Status' ;
    rdfs:comment 'Status of the control plan element.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designRecordsStatus rdf:type rdf:Property ;
    rdfs:label 'Design Records Status' ;
    rdfs:comment 'Status of the design records element within the PPAP package.' ;
    rdfs:domain ind:SupplierPartApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msaStatus rdf:type rdf:Property ;
    rdfs:label 'Msa Status' ;
    rdfs:comment 'Status of the MSA element.' ;
    rdfs:domain ind:SupplierPartApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Status' ;
    rdfs:comment 'Aggregated status of the approval record.' ;
    rdfs:domain ind:SupplierPartApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfmeaStatus rdf:type rdf:Property ;
    rdfs:label 'Pfmea Status' ;
    rdfs:comment 'Status of the Process FMEA element.' ;
    rdfs:domain ind:SupplierPartApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppapSubmissionLevel rdf:type rdf:Property ;
    rdfs:label 'Ppap Submission Level' ;
    rdfs:comment 'Level of PPAP submission (1-5) indicating the depth of documentation provided.' ;
    rdfs:domain ind:SupplierPartApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplePartsStatus rdf:type rdf:Property ;
    rdfs:label 'Sample Parts Status' ;
    rdfs:comment 'Status of the sample parts element.' ;
    rdfs:domain ind:SupplierPartApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeId rdf:type rdf:Property ;
    rdfs:label 'Route Id' ;
    rdfs:comment 'Foreign key linking to logistics.route. Business justification: A shipment follows a defined logistics route (origin-destination path). shipment has origin_location and destination_location as free-text strings. Adding route_id normalizes the route reference and e' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Route .

ind:vesselVoyageId rdf:type rdf:Property ;
    rdfs:label 'Vessel Voyage Id' ;
    rdfs:comment 'Foreign key linking to logistics.vessel_voyage. Business justification: A shipment involving ocean transport is associated with a specific vessel voyage. Adding vessel_voyage_id to shipment normalizes the voyage reference currently captured only as free-text (voyage_numbe' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VesselVoyage .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Real timestamp when the shipment was received at the destination.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Real timestamp when the shipment left the origin plant.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:containerNumber rdf:type rdf:Property ;
    rdfs:label 'Container Number' ;
    rdfs:comment 'Standard container identification number when applicable.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Document Number' ;
    rdfs:comment 'Reference number for customs clearance documents.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayReason rdf:type rdf:Property ;
    rdfs:label 'Delay Reason' ;
    rdfs:comment 'Explanation for any delay beyond the planned arrival.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Location' ;
    rdfs:comment 'Geographic location (city) of the destination dealer or yard.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportImportFlag rdf:type rdf:Property ;
    rdfs:label 'Export Import Flag' ;
    rdfs:comment 'Indicates whether the shipment is an export, import, or domestic movement.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'Gross transportation cost before discounts or adjustments.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International commercial term governing responsibilities and costs.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadType rdf:type rdf:Property ;
    rdfs:label 'Load Type' ;
    rdfs:comment 'Classification of the shipment load.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netCost rdf:type rdf:Property ;
    rdfs:label 'Net Cost' ;
    rdfs:comment 'Final freight cost after discounts and adjustments.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfUnits rdf:type rdf:Property ;
    rdfs:label 'Number Of Units' ;
    rdfs:comment 'Count of individual vehicles or kits included in the shipment.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originLocation rdf:type rdf:Property ;
    rdfs:label 'Origin Location' ;
    rdfs:comment 'Geographic location (city) of the origin plant.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originPlantCode rdf:type rdf:Property ;
    rdfs:label 'Origin Plant Code' ;
    rdfs:comment 'Identifier of the manufacturing plant where the shipment originates.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Date' ;
    rdfs:comment 'Estimated date the shipment should arrive at the destination.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Date' ;
    rdfs:comment 'Scheduled date for shipment departure from the origin plant.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Business-visible shipment number assigned by SAP SD for tracking and reference.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Control Flag' ;
    rdfs:comment 'True if the shipment requires temperature-controlled transport.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trackingUrl rdf:type rdf:Property ;
    rdfs:label 'Tracking Url' ;
    rdfs:comment 'Web link to real-time shipment tracking information.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vinList rdf:type rdf:Property ;
    rdfs:label 'Vin List' ;
    rdfs:comment 'List of VINs for all vehicles in the shipment, separated by commas.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Cbm' ;
    rdfs:comment 'Total cargo volume of the shipment in cubic meters.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsMovementId rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Id' ;
    rdfs:comment 'Foreign key linking to inventory.goods_movement. Business justification: Enables Shipment Leg Cost Allocation: reconciles each logistics leg with the corresponding inventory goods movement for cost analysis.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsMovement .

ind:containerCode rdf:type rdf:Property ;
    rdfs:label 'Container Code' ;
    rdfs:comment 'Identifier of the shipping container or trailer used for the leg.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costType rdf:type rdf:Property ;
    rdfs:label 'Cost Type' ;
    rdfs:comment 'Category of cost represented by cost_amount.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Status' ;
    rdfs:comment 'Current status of customs clearance for the leg.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceKm rdf:type rdf:Property ;
    rdfs:label 'Distance Km' ;
    rdfs:comment 'Physical distance covered in this leg, measured in kilometers.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionsKgCo2 rdf:type rdf:Property ;
    rdfs:label 'Emissions Kg Co2' ;
    rdfs:comment 'Estimated carbon dioxide emissions for the leg.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelConsumptionLiters rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumption Liters' ;
    rdfs:comment 'Total fuel used by the vehicle during the leg.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Handling Instructions' ;
    rdfs:comment 'Special handling notes for the cargo on this leg.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialType rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Type' ;
    rdfs:comment 'Classification of hazardous material (e.g., flammable, corrosive).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legSequence rdf:type rdf:Property ;
    rdfs:label 'Leg Sequence' ;
    rdfs:comment 'Ordinal position of the leg within the multi-modal shipment.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legStatus rdf:type rdf:Property ;
    rdfs:label 'Leg Status' ;
    rdfs:comment 'Current operational status of the leg.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odometerEnd rdf:type rdf:Property ;
    rdfs:label 'Odometer End' ;
    rdfs:comment 'Vehicle odometer reading at the end of the leg (kilometers).' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:odometerStart rdf:type rdf:Property ;
    rdfs:label 'Odometer Start' ;
    rdfs:comment 'Vehicle odometer reading at the start of the leg (kilometers).' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Timestamp' ;
    rdfs:comment 'Scheduled arrival date-time for the leg.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Timestamp' ;
    rdfs:comment 'Scheduled departure date-time for the leg.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Security seal identifier applied to containers or trailers.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlRequired rdf:type rdf:Property ;
    rdfs:label 'Temperature Control Required' ;
    rdfs:comment 'Indicates whether the cargo requires temperature-controlled transport.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Maximum temperature setting for the leg when temperature control is required.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Minimum temperature setting for the leg when temperature control is required.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-provided tracking identifier for the leg.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic Meters' ;
    rdfs:comment 'Total cargo volume for the leg, measured in cubic meters.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightTons rdf:type rdf:Property ;
    rdfs:label 'Weight Tons' ;
    rdfs:comment 'Total weight of cargo transported on this leg, expressed in metric tons.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadPlanId rdf:type rdf:Property ;
    rdfs:label 'Load Plan Id' ;
    rdfs:comment 'Identifier of the load planning record associated with this transport order.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoadPlan .

ind:originVehicleCompoundId rdf:type rdf:Property ;
    rdfs:label 'Origin Vehicle Compound Id' ;
    rdfs:comment 'Foreign key linking to logistics.vehicle_compound. Business justification: vehicle_transport_order has origin_compound as a free-text STRING. This is a denormalized reference to the vehicle_compound master. Adding origin_vehicle_compound_id as a proper FK normalizes the orig' ;
    rdfs:domain ind:VehicleTransportOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleCompound .

ind:carrierContact rdf:type rdf:Property ;
    rdfs:label 'Carrier Contact' ;
    rdfs:comment 'Primary phone number for the carrier\'s dispatch desk.' ;
    rdfs:domain ind:VehicleTransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRegulationCode rdf:type rdf:Property ;
    rdfs:label 'Compliance Regulation Code' ;
    rdfs:comment 'Code of the regulatory requirement applicable to the shipment (e.g., IATF, EPA).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedPickupDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Pickup Date' ;
    rdfs:comment 'Date the carrier confirmed for vehicle pickup.' ;
    rdfs:domain ind:VehicleTransportOrder ;
