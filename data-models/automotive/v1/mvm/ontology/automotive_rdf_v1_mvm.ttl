    rdfs:comment 'Total kilometers driven or sailed by the carrier for shipments on this lane in the period.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalShipments rdf:type rdf:Property ;
