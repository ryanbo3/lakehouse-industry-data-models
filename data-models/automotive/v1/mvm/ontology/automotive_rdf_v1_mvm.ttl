    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppapOnTimeCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Ppap On Time Completion Rate' ;
    rdfs:comment 'Percentage of PPAP submissions completed within the agreed timeframe.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppmDefectRate rdf:type rdf:Property ;
    rdfs:label 'Ppm Defect Rate' ;
    rdfs:comment 'Defect rate expressed in parts per million for supplied parts during the period.' ;
