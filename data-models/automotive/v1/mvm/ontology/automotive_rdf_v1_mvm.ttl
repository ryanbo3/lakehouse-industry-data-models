ind:compoundCode rdf:type rdf:Property ;
    rdfs:label 'Compound Code' ;
    rdfs:comment 'Unique business code used to reference the compound in operational systems.' ;
    rdfs:domain ind:VehicleCompound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundType rdf:type rdf:Property ;
