# RDFS Schema for Business: Automotive

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/automotive#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Automotive ---
ind:Automotive rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Automotive' ;
    rdfs:comment 'Automotive is a major manufacturing industry producing cars, trucks, SUVs, and commercial vehicles along with hybrid and electric powertrains, connected mobility services, and autonomous driving technologies.' .

# --- Domain Classes ---
ind:Vehicle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Automotive ;
    rdfs:label 'Vehicle' ;
    rdfs:comment 'SSOT for all vehicle master data across the enterprise. Owns VIN-level vehicle identity, model configurations, trim levels, MY (Model Year) lifecycle from SOP (Start of Production) to EOP (End of Production), powertrain variants (ICE, HEV, PHEV, EV), platform architectures, and ADAS feature sets. Serves as the authoritative reference for every downstream domain that needs to identify or describe a vehicle instance.' .

ind:Engineering rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Automotive ;
    rdfs:label 'Engineering' ;
    rdfs:comment 'Manages the full product design and development lifecycle including CAD (Computer-Aided Design), CAE (Computer-Aided Engineering), PLM (Product Lifecycle Management), and digital twin modeling. Owns engineering BOM, design specifications, CFD (Computational Fluid Dynamics), FEA (Finite Element Analysis), NVH (Noise Vibration Harshness) testing, prototype validation, and engineering change orders (ECO/ECN). Integrates with Siemens Teamcenter, CATIA, and ENOVIA for collaborative engineering.' .

ind:Manufacturing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Automotive ;
    rdfs:label 'Manufacturing' ;
    rdfs:comment 'Core production and assembly operations across all manufacturing plants. Manages shop floor execution via MES (Manufacturing Execution System), work order scheduling, production line sequencing (JIS - Just-in-Sequence), WIP (Work in Progress) tracking, and build traceability. Includes stamping, body shop, paint, and final assembly processes. Integrates with AGV (Automated Guided Vehicle), PLC (Programmable Logic Controller), and SCADA systems for real-time production control.' .

ind:Supply rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Automotive ;
    rdfs:label 'Supply' ;
    rdfs:comment 'Governs the inbound supply chain from tier-1 and tier-2 suppliers through to plant receiving. Owns supplier master data, RFQ (Request for Quotation) events, PPAP (Production Part Approval Process) records, JIT/JIS delivery schedules, inbound logistics, supplier performance metrics (PPM - Parts Per Million defect rates, OTD - On-Time Delivery), and CKD/SKD kit management for global assembly operations. Integrates with SAP MM and PTC Windchill.' .

ind:Quality rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Automotive ;
    rdfs:label 'Quality' ;
    rdfs:comment 'End-to-end quality assurance and control across design, manufacturing, and field operations. Owns APQP plans, FMEA (Failure Mode and Effects Analysis), SPC (Statistical Process Control) data, inspection plans, quality audits, defect tracking, and PPM rates. Includes incoming material inspection, in-process quality gates, final vehicle PDI (Pre-Delivery Inspection), NCAP/WLTP test results, and corrective action (8D, 5-Why) processes. Supports IATF 16949 compliance.' .

ind:Logistics rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Automotive ;
    rdfs:label 'Logistics' ;
    rdfs:comment 'Outbound logistics and distribution including finished vehicle transportation, vehicle storage yards, compound operations, carrier management, and delivery scheduling. Manages vehicle shipment from plant to dealer, rail/truck/vessel logistics, port processing, last-mile delivery, and CKD/SKD kit logistics. Tracks in-transit inventory, delivery lead times, transportation costs, carrier performance, and OTD metrics. Includes export/import operations for global distribution.' .

ind:Inventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Automotive ;
    rdfs:label 'Inventory' ;
    rdfs:comment 'Inventory management for raw materials, components, WIP (Work in Progress), finished goods, and service parts across plants, warehouses, and dealer networks. Manages stock levels, inventory movements, cycle counting, MRP (Material Requirements Planning) execution, and SKU master data. Tracks inventory accuracy, turnover rates, obsolescence, and safety stock levels. Includes warehouse management (SAP WM), lot traceability, and serialized inventory for high-value components (ECU, batteries).' .

ind:Customer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Automotive ;
    rdfs:label 'Customer' ;
    rdfs:comment 'SSOT for all customer identities including retail buyers, fleet operators, corporate accounts, and government entities. Manages customer profiles, contact information, preferences, vehicle ownership history, loyalty program membership, household linkages, and customer segmentation. Tracks NPS (Net Promoter Score), CLTV (Customer Lifetime Value), and customer journey touchpoints. Supports both B2C and B2B customer types with unified identity management. Integrates with Salesforce Automotive Cloud.' .

ind:Sales rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Automotive ;
    rdfs:label 'Sales' ;
    rdfs:comment 'Sales operations including lead management, opportunity tracking, quote generation, order capture, and sales performance analytics. Manages MSRP (Manufacturer Suggested Retail Price), incentive programs, fleet sales, and commercial vehicle contracts. Tracks sales pipeline, conversion rates, and regional sales performance. Integrates with dealer networks and Salesforce Automotive Cloud for unified sales execution across direct and indirect channels. Interfaces with SAP SD.' .

ind:Dealer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Automotive ;
    rdfs:label 'Dealer' ;
    rdfs:comment 'Dealer network management including dealer profiles, franchise agreements, territory assignments, and dealer performance scorecards. Manages dealer inventory allocation, vehicle allocation rules, dealer incentive programs, and DMS (Dealer Management System) integration. Tracks dealer sales performance, customer satisfaction scores, service capacity, and parts inventory at dealer locations. Supports both OEM-owned and independent franchise dealer models. Integrates with CDK Global DMS.' .

ind:Aftersales rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Automotive ;
    rdfs:label 'Aftersales' ;
    rdfs:comment 'Post-sale customer support including warranty management, service campaigns, recall execution, and parts distribution. Manages service appointments, repair orders, TSB (Technical Service Bulletin) distribution, DTC (Diagnostic Trouble Code) analysis, and labor time standards. Tracks warranty claims, parts consumption, service revenue, and customer retention. Includes field service operations and authorized service center network management. Integrates with CDK Global DMS and OBD (On-Board Diagnostics) systems.' .

ind:Billing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Automotive ;
    rdfs:label 'Billing' ;
    rdfs:comment 'SSOT for all revenue transactions and receivables. Owns dealer invoices, retail customer billing, fleet account statements, parts and service charges, payment records, credit notes, and dispute management. Handles invoicing, payment receipt, credit memos, and financial settlement for vehicle sales and services. Integrates with SAP SD/FI and supports MSRP-based and negotiated pricing models.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Automotive ;
    rdfs:label 'Finance' ;
    rdfs:comment 'Core financial management including general ledger, accounts payable, accounts receivable, cost center accounting, and financial reporting. Manages CapEx (Capital Expenditure) tracking, budget planning, FY (Fiscal Year) close, EBITDA reporting, profitability analysis by vehicle line/plant/region, and intercompany settlements. Tracks manufacturing cost (material, labor, overhead), warranty reserves, and inventory valuation. Supports SOX compliance, IFRS/GAAP reporting. Integrates with SAP FI/CO.' .

ind:Compliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Automotive ;
    rdfs:label 'Compliance' ;
    rdfs:comment 'Regulatory compliance and homologation management across all global markets. Owns CAFE (Corporate Average Fuel Economy) reporting, EPA/CARB emissions certifications, NHTSA FMVSS homologation records, WLTP/Euro NCAP test submissions, UNECE type approvals, and recall regulatory filings. Manages compliance testing, certification documentation, regulatory submissions, and audit trails. Ensures adherence to environmental, safety, and trade regulations across jurisdictions.' .

# --- Data Product Classes (Tables) ---
ind:Plant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Plant' ;
    rdfs:comment 'Master record for each manufacturing plant or assembly facility operated by Automotive. Captures plant identity, location, type (stamping, body shop, paint, final assembly, CKD/SKD), production capacity, SOP/EOP dates, plant code, and operational status. SSOT for plant-level identity referenced across MES, SAP PP, and logistics domains.' .

ind:ProductionLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Production Line' ;
    rdfs:comment 'Master record for each production line within a plant, including stamping lines, body shop lines, paint booths, and final assembly lines. Tracks line code, line type, designed throughput (JPH - Jobs Per Hour), current shift configuration, AGV integration flags, PLC/SCADA system references, and operational status. Owned by manufacturing as the SSOT for line-level capacity and configuration.' .

ind:WorkCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Work Center' ;
    rdfs:comment 'Master record for individual work centers (stations) within a production line. Captures work center code, name, type (manual, automated, robotic), cycle time standard, takt time, capacity category, shift availability, and associated PLC/SCADA node identifiers. Supports JIS sequencing and MES shop floor execution at the station level.' .

ind:ProductionOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Production Order' ;
    rdfs:comment 'Core transactional record representing a manufacturing work order issued to produce a specific vehicle or sub-assembly. Captures order number, order type (vehicle build, sub-assembly, rework), planned and actual start/finish dates, target quantity, produced quantity, order status, priority, shift assignment, and MES order reference. Links to plant, production line, and vehicle configuration. SSOT for shop floor execution tracking in SAP PP and Apriso MES.' .

ind:BuildSequence rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Build Sequence' ;
    rdfs:comment 'JIS (Just-in-Sequence) build sequence record defining the ordered sequence of vehicles to be assembled on a production line for a given shift or production run. Captures sequence number, planned build date, shift, line assignment, vehicle configuration reference (model, trim, powertrain, color), sequence status, and freeze timestamp. Critical for JIS supplier call-offs and AGV routing. Sourced from Apriso MES sequencing module.' .

ind:VehicleBuild rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Vehicle Build' ;
    rdfs:comment 'Transactional record capturing the actual build event for a single vehicle unit on the shop floor, from body-in-white through final assembly. Tracks VIN assignment, production order reference, actual start and completion timestamps per build stage (stamping, body shop, paint, trim, chassis, final), build status, shift, operator team, and any hold or rework flags. SSOT for vehicle-level build traceability and genealogy in the manufacturing domain.' .

ind:BuildStage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Build Stage' ;
    rdfs:comment 'Reference master defining the standard build stages in the vehicle manufacturing process (e.g., Stamping, Body Shop, E-Coat, Paint, Trim-1, Chassis, Trim-2, Final, PDI). Captures stage code, stage name, sequence order, process area, standard cycle time, and applicable vehicle types. Used to structure vehicle_build traceability and production reporting.' .

ind:ShopFloorEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Shop Floor Event' ;
    rdfs:comment 'Granular transactional record capturing real-time shop floor events generated by MES, PLC, and SCADA systems during production. Includes event type (station entry, station exit, torque confirmation, weld completion, paint cure, AGV arrival, hold trigger, alarm), event timestamp, work center, production order reference, VIN reference, operator ID, and event payload. Enables real-time production monitoring and OEE (Overall Equipment Effectiveness) calculation.' .

ind:ProductionSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Production Schedule' ;
    rdfs:comment 'Master production schedule (MPS) record defining planned vehicle production volumes by plant, production line, model, MY (Model Year), and time period (daily, weekly, monthly). Captures scheduled quantity, confirmed quantity, schedule version, freeze horizon, schedule status, and MRP run reference. Integrates with SAP PP MRP and supports capacity planning and supplier call-off generation.' .

ind:Shift rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Shift' ;
    rdfs:comment 'Reference master for production shift definitions at each plant and production line. Captures shift code, shift name (Day, Afternoon, Night, Weekend), planned start and end times, break schedule, planned production hours, and applicable plant and line assignments. Used for production order scheduling, OEE calculation, and workforce planning integration.' .

ind:DowntimeEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Downtime Event' ;
    rdfs:comment 'Transactional record capturing unplanned and planned production downtime events at the work center or line level. Tracks downtime start and end timestamps, duration (minutes), downtime category (mechanical failure, tooling change, material shortage, quality hold, scheduled maintenance, changeover), affected work center, production order impact, and responsible team. Critical for OEE analysis and SCADA-integrated downtime reporting.' .

ind:ProductionBom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Production Bom' ;
    rdfs:comment 'Manufacturing Bill of Materials (BOM) record representing the production-level BOM used on the shop floor for a specific vehicle configuration and model year. Distinct from the engineering BOM (eBOM) in the engineering domain — this is the manufacturing BOM (mBOM) as released to production. Captures BOM header (vehicle model, MY, plant, effectivity dates), BOM status, and reference to the engineering change order that authorized it. Managed via SAP PP and Teamcenter PLM BOM transfer.' .

ind:BomComponent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Bom Component' ;
    rdfs:comment 'Line-item record within a manufacturing BOM representing a single component or sub-assembly required to build a vehicle. Captures component part number, description, quantity per vehicle, unit of measure, installation work center, installation sequence, alternative part references, effectivity start/end dates, and scrap factor. Supports JIT/JIS material call-offs and shop floor assembly instructions.' .

ind:MaterialConsumption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Material Consumption' ;
    rdfs:comment 'Transactional record capturing actual material consumption (goods issue) against a production order on the shop floor. Tracks consumed part number, quantity consumed, unit of measure, consumption timestamp, work center, production order reference, storage location, batch number, and variance from planned BOM quantity. Feeds SAP MM goods movement and cost accounting for production variance reporting.' .

ind:ReworkOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Rework Order' ;
    rdfs:comment 'Transactional record for rework or repair operations initiated on a vehicle or sub-assembly that failed an in-process quality check. Captures rework order number, originating production order, VIN reference, defect description, rework type (in-line repair, offline rework, teardown), assigned work center, planned and actual rework hours, rework status, and disposition (repaired, scrapped, concession). Integrates with quality domain defect records.' .

ind:ProductionConfirmation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Production Confirmation' ;
    rdfs:comment 'Transactional record confirming the completion of a production order or a partial operation within a production order. Captures confirmation number, production order reference, confirmed quantity (yield and scrap), actual activity times (setup, machine, labor), confirmation timestamp, shift, work center, and operator. Triggers SAP PP order settlement and inventory goods receipt. SSOT for actual production output reporting.' .

ind:CapacityPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Capacity Plan' ;
    rdfs:comment 'Master record for plant and line capacity planning, capturing planned production capacity by plant, production line, shift pattern, and planning period (weekly/monthly). Includes rated capacity (JPH × available hours), demonstrated capacity, capacity utilization percentage, bottleneck work center, planned overtime hours, and capacity plan version. Supports S&OP (Sales and Operations Planning) and capital investment decisions.' .

ind:ProductionVariant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Production Variant' ;
    rdfs:comment 'Reference master defining the valid production variants (option combinations) that can be built on a specific production line for a given model year. Captures variant code, model, MY, powertrain type (ICE, HEV, PHEV, BEV), body style, trim level, market destination, and line compatibility flags. Supports build sequence feasibility validation and JIS sequencing rules. Distinct from the commercial product catalog — this is the manufacturing-feasible variant definition.' .

ind:Dealership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dealer ;
    rdfs:label 'Dealership' ;
    rdfs:comment 'Master record for each dealer location in the OEM franchise network. Captures dealer legal entity, DMS (Dealer Management System) integration identifiers (CDK Global), franchise type (OEM-owned vs independent), physical address, contact details, operational status, market region, and channel classification. This is the SSOT for dealer identity across the enterprise.' .

ind:FranchiseAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dealer ;
    rdfs:label 'Franchise Agreement' ;
    rdfs:comment 'Formal franchise contract between the OEM and an independent or OEM-owned dealer. Tracks agreement effective dates, expiration, renewal terms, franchise tier, authorized vehicle lines (nameplates), territory rights, performance obligations, and agreement status. Supports both new franchise grants and renewals.' .

ind:DealerTerritory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dealer ;
    rdfs:label 'Dealer Territory' ;
    rdfs:comment 'Geographic sales territory assigned to a dealership. Defines primary area of responsibility (PAR), zip/postal code coverage, county or region boundaries, territory type (exclusive, shared, open), effective dates, and overlap rules. Used for vehicle allocation, market representation planning, and dealer performance benchmarking.' .

ind:Contact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dealer ;
    rdfs:label 'Contact' ;
    rdfs:comment 'Key personnel contacts at a dealership including dealer principal, general manager, sales manager, service manager, parts manager, and F&I manager. Tracks role, contact details, tenure, certification status, and active flag. Supports OEM communications, training enrollment, and dealer portal access management.' .

ind:Certification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dealer ;
    rdfs:label 'Certification' ;
    rdfs:comment 'Tracks OEM-issued certifications and program enrollments for a dealership, such as EV-certified dealer, ADAS service authorization, luxury brand certification, and IATF 16949 compliance status. Includes certification type, issuing body, issue date, expiry date, renewal requirements, and current status. Drives eligibility for vehicle allocation and incentive programs.' .

ind:VehicleAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dealer ;
    rdfs:label 'Vehicle Allocation' ;
    rdfs:comment 'Records the OEM\'s allocation of specific vehicle units (by VIN or allocation batch) to a dealership for a given model year and production period. Captures allocation quantity, nameplate, trim, powertrain type (ICE/HEV/PHEV/EV), allocation rule applied, priority tier, acceptance status, and delivery window. Core operational record linking manufacturing output to dealer inventory pipeline.' .

ind:DealerInventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dealer ;
    rdfs:label 'Dealer Inventory' ;
    rdfs:comment 'Real-time inventory of vehicles physically on-hand or in-transit at a dealership. Tracks VIN, nameplate, model year, trim, exterior/interior color, powertrain, days-on-lot, acquisition cost, current asking price, inventory status (available, sold, demo, loaner, in-transit), and PDI (Pre-Delivery Inspection) completion flag. Sourced from CDK Global DMS inventory module.' .

ind:PartsInventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dealer ;
    rdfs:label 'Parts Inventory' ;
    rdfs:comment 'Dealer-level parts and accessories inventory managed through the CDK Global DMS parts module. Tracks OEM part number, SKU, description, quantity on hand, quantity on order, bin location, reorder point, supersession chain, price, and parts classification (mechanical, body, electrical, accessories). Supports service operations and parts counter sales.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dealer ;
    rdfs:label 'Order' ;
    rdfs:comment 'Dealer stock orders and customer-specific vehicle orders placed by the dealership with the OEM. Captures order type (stock vs retail), nameplate, MY, configuration (trim, options, packages), order date, requested delivery date, order status (submitted, confirmed, scheduled, produced, shipped, delivered), and OTD (On-Time Delivery) tracking. Integrates with SAP SD and CDK Global DMS.' .

ind:RetailSale rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dealer ;
    rdfs:label 'Retail Sale' ;
    rdfs:comment 'Records the retail sale of a new or used vehicle by a dealership to an end customer. Captures VIN, sale date, sale price, MSRP, discount amount, trade-in details, financing type (cash, retail finance, lease), F&I products sold, salesperson, and deal status. Sourced from CDK Global DMS F&I module. SSOT for dealer-level vehicle sales transactions.' .

ind:DealerServiceAppointment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dealer ;
    rdfs:label 'Dealer Service Appointment' ;
    rdfs:comment 'Scheduled service appointments at a dealership for vehicle maintenance, warranty repair, recall service, or customer-pay work. Tracks appointment date/time, customer, VIN, service type, advisor assigned, estimated duration, appointment status (scheduled, checked-in, in-progress, completed, no-show), and transportation option (loaner, shuttle, wait). Sourced from CDK Global DMS service scheduling module.' .

ind:DealerRepairOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dealer ;
    rdfs:label 'Dealer Repair Order' ;
    rdfs:comment 'Detailed repair order (RO) record for each vehicle service event at a dealership. Captures RO number, open/close dates, VIN, mileage-in, complaint/cause/correction (3C), labor operations, technician assignments, parts consumed, warranty vs customer-pay vs internal split, total labor hours, total parts cost, and RO status. Core operational record for dealer service operations sourced from CDK Global DMS.' .

ind:DealerIncentiveClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dealer ;
    rdfs:label 'Dealer Incentive Claim' ;
    rdfs:comment 'Individual dealer claims submitted against OEM incentive programs. Tracks claim submission date, program, claim period, claimed units or metric, supporting evidence, claim status (submitted, under review, approved, rejected, paid), approved amount, and payment reference. Integrates with SAP FI for payout processing.' .

ind:FloorPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dealer ;
    rdfs:label 'Floor Plan' ;
    rdfs:comment 'Dealer vehicle floor plan financing records tracking the financing of new vehicle inventory. Captures financing institution, credit line amount, outstanding balance, per-unit floor plan cost, curtailment schedule, aged inventory flags, and floor plan audit dates. Critical for dealer financial health monitoring and OEM floor plan assistance program administration.' .

ind:DealerWarrantyClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dealer ;
    rdfs:label 'Dealer Warranty Claim' ;
    rdfs:comment 'Warranty claims submitted by the dealership to the OEM for reimbursement of warranty repair labor and parts. Captures VIN, repair order reference, failure date, mileage at failure, DTC (Diagnostic Trouble Code), causal part number, labor operation codes, claimed labor hours, claimed parts cost, submission date, OEM adjudication status (approved, rejected, partially approved), and reimbursement amount.' .

ind:RecallCompletion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Dealer ;
    rdfs:label 'Recall Completion' ;
    rdfs:comment 'Tracks the completion of NHTSA safety recalls and OEM service campaigns at the dealer level. Records recall/campaign number, VIN remediated, completion date, technician, parts used, labor time, reimbursement claimed, and completion status. Supports NHTSA compliance reporting and OEM recall closure rate monitoring.' .

ind:Invoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice' ;
    rdfs:comment 'Core billing document representing a formal demand for payment issued to dealers, retail customers, fleet accounts, or corporate buyers for vehicle sales, parts, or services. Captures invoice number, invoice date, due date, invoice type (dealer/retail/fleet/parts/service), billing entity, billing address, currency, total amount, tax amount, discount amount, net amount, payment terms, invoice status (draft/issued/partially_paid/paid/cancelled/disputed), SAP SD billing document reference, MSRP-based or negotiated pricing flag, and model year context. SSOT for all outbound billing documents in the enterprise.' .

ind:InvoiceLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice Line' ;
    rdfs:comment 'Individual line item on a billing invoice representing a specific charge for a vehicle unit, parts SKU, labor operation, accessory, or service fee. Captures line number, item type (vehicle/part/labor/accessory/fee), item code, item description, VIN reference for vehicle lines, part number for parts lines, quantity, unit price, MSRP, negotiated price, discount amount, tax code, tax amount, line total, and revenue category. Supports multi-line invoices for mixed vehicle and parts/service billing.' .

ind:Payment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment' ;
    rdfs:comment 'Record of a payment received against an invoice or account balance from a dealer, retail customer, fleet operator, or corporate account. Captures payment date, payment method (wire/ACH/check/credit_card/floorplan/dealer_draft), payment amount, currency, applied invoice references, bank reference number, clearing date, payment status (pending/cleared/returned/reversed), SAP FI clearing document reference, and payer entity type. SSOT for all inbound payment receipts in the billing domain.' .

ind:PaymentAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment Allocation' ;
    rdfs:comment 'Association record linking a payment to one or more invoice lines, capturing how a single payment is distributed across multiple invoices or partial invoice settlements. Tracks allocated amount per invoice, allocation date, allocation type (full/partial/advance/overpayment), remaining balance after allocation, and clearing status. Enables accurate accounts receivable aging and open item management aligned with SAP FI open item clearing.' .

ind:Account rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Account' ;
    rdfs:comment 'Billing account master record representing the financial relationship between Automotive and a billing party (dealer, retail customer, fleet operator, or corporate account). Captures account number, account type (dealer/retail/fleet/corporate/government), account name, billing address, payment terms, credit limit, credit exposure, currency, tax registration number, VAT ID, account status (active/suspended/closed), assigned credit controller, SAP FI customer account reference, and DMS account linkage for dealer accounts. Distinct from the customer identity record owned by the customer domain.' .

ind:Receivable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Receivable' ;
    rdfs:comment 'Open accounts receivable item representing an outstanding amount owed by a billing account against a specific invoice. Tracks original invoice amount, outstanding balance, due date, days past due, aging bucket (current/30/60/90/120+), dunning level, last dunning date, dispute flag, dispute reference, write-off flag, and SAP FI open item reference. SSOT for AR aging and collections management across dealer, retail, and fleet receivables.' .

ind:DealerStatement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Dealer Statement' ;
    rdfs:comment 'Periodic account statement issued to a dealer summarizing all invoices, credit memos, debit memos, payments, and open balances within a statement period. Captures statement number, dealer account reference, statement period start/end dates, opening balance, total charges, total credits, total payments received, closing balance, statement status (draft/issued/acknowledged), and CDK Global DMS statement reference. Supports dealer reconciliation and floorplan financing reporting.' .

ind:PriceCondition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Price Condition' ;
    rdfs:comment 'Pricing condition record defining the applicable price, discount, surcharge, or tax condition for a billing transaction based on customer type, vehicle model, region, and validity period. Captures condition type (MSRP/negotiated/fleet_discount/dealer_margin/volume_rebate/freight/PDI_charge/tax), condition value, condition unit, scale basis, validity start/end dates, pricing procedure reference, and SAP SD condition record reference (KONP/KONV). Supports both MSRP-based and negotiated pricing models as required by the billing domain.' .

ind:PaymentTerm rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment Term' ;
    rdfs:comment 'Reference master for standard payment terms offered to billing accounts, defining due date calculation rules, early payment discount percentages, and penalty terms. Captures payment term code, description, net due days, discount percentage 1 and 2, discount days 1 and 2, penalty rate, penalty grace days, applicable account types (dealer/fleet/retail/corporate), and SAP FI payment term reference (T052). Used to standardize billing terms across all invoice types.' .

ind:TaxCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Reference master for tax codes applicable to automotive billing transactions across jurisdictions, capturing tax code identifier, tax type (VAT/GST/sales_tax/excise/luxury_tax/environmental_levy), jurisdiction (federal/state/local/EU/APAC), applicable transaction types, tax rate percentage, effective date, expiry date, tax authority reference, and SAP FI/SD tax code mapping. Supports multi-jurisdiction billing for domestic and export vehicle sales, parts, and services.' .

ind:RebateAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Rebate Agreement' ;
    rdfs:comment 'Dealer or fleet rebate agreement defining the terms under which volume-based or performance-based rebates are accrued and settled. Captures agreement number, agreement type (volume_rebate/loyalty_bonus/conquest_bonus/fleet_incentive/model_mix_bonus), beneficiary account, vehicle model scope, agreement period, target volume, achieved volume, rebate rate or amount, accrual method (periodic/milestone), settlement frequency (monthly/quarterly/annual), settlement status, and SAP SD rebate agreement reference (BO01/BO02). Drives credit memo generation upon settlement.' .

ind:Opportunity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Opportunity' ;
    rdfs:comment 'Core sales opportunity record tracking a potential vehicle sale from initial identification through close. Captures prospect vehicle interest, estimated deal value, probability of close, sales stage, assigned sales representative, source channel, and expected close date. Aligns with Salesforce Automotive Cloud Opportunity object and SAP SD pre-sales pipeline. Covers retail, fleet, and commercial vehicle opportunities.' .

ind:Lead rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Lead' ;
    rdfs:comment 'Inbound or outbound sales lead representing an individual or organization expressing interest in purchasing a vehicle. Tracks lead source (web, dealer walk-in, event, referral, digital campaign), lead status, assigned owner, vehicle interest category (ICE, EV, HEV, PHEV), and qualification score. Feeds into opportunity pipeline upon qualification. Sourced from Salesforce Automotive Cloud Lead object.' .

ind:Quote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Quote' ;
    rdfs:comment 'Formal vehicle sales quotation issued to a prospect or customer, detailing configured vehicle, MSRP, applied incentives, trade-in allowance, financing terms, accessories, and net selling price. Tracks quote version, expiry date, quote status, and issuing dealer or direct sales channel. Supports retail, fleet, and CKD/SKD export quotes. Linked to SAP SD quotation (VA21) and Salesforce Automotive Cloud Quote.' .

ind:QuoteLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Quote Line' ;
    rdfs:comment 'Individual line item within a vehicle sales quote, representing a specific vehicle configuration, accessory, service package, or fee. Captures line type, configured model code, option packages, unit price, discount amount, incentive applied, and line-level tax. Enables multi-vehicle fleet quotes and accessory bundling. Child entity of quote.' .

ind:VehicleOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Vehicle Order' ;
    rdfs:comment 'Confirmed customer vehicle purchase order capturing the commercial commitment to buy a specific configured vehicle. Records order type (retail, fleet, government, export), ordered VIN or build-to-order configuration, agreed selling price, payment method, financing reference, delivery commitment date, and order status lifecycle (placed, confirmed, in-production, shipped, delivered). Interfaces with SAP SD sales order (VA01) and triggers manufacturing scheduling.' .

ind:OrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Order Line' ;
    rdfs:comment 'Individual line item within a vehicle order representing a specific vehicle unit, accessory, extended warranty, or service contract. Captures VIN assignment (when available), model code, trim level, exterior/interior color, option packages, unit net price, quantity, and line fulfillment status. Supports multi-unit fleet orders with individual VIN-level tracking per line.' .

ind:IncentiveProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Incentive Program' ;
    rdfs:comment 'Master record for OEM-sponsored sales incentive programs including customer cash rebates, dealer cash allowances, low-APR financing offers, lease support, conquest bonuses, loyalty rewards, and fleet incentives. Captures program code, program type, eligible model year and nameplate, start and end dates, maximum incentive amount, funding source (OEM vs regional), stackability rules, and eligibility criteria. Managed centrally and distributed to dealer network.' .

ind:SalesIncentiveClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Sales Incentive Claim' ;
    rdfs:comment 'Transactional record of an incentive applied to a specific vehicle sale or lease transaction. Captures the incentive program applied, claimed amount, claim date, approving authority, claim status (submitted, approved, paid, rejected), dealer or direct channel submitting the claim, and supporting documentation references. Enables incentive spend tracking and reconciliation against program budgets.' .

ind:FleetContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Fleet Contract' ;
    rdfs:comment 'Commercial agreement governing the sale or lease of multiple vehicles to a fleet customer (corporate, government, rental, utility). Captures fleet account reference, contracted volume commitments, agreed pricing tiers, eligible nameplates and model years, contract term, delivery schedule, fleet incentive program linkage, and contract status. Supports national fleet accounts and government procurement contracts. Distinct from retail sales orders due to volume pricing, multi-delivery scheduling, and contract lifecycle management.' .

ind:FleetContractLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Fleet Contract Line' ;
    rdfs:comment 'Individual vehicle allocation line within a fleet contract specifying a particular nameplate, model year, trim, powertrain type (ICE/EV/HEV/PHEV), quantity committed, unit contracted price, and delivery window. Tracks fulfillment status per line against the parent fleet contract. Enables granular fleet order management and delivery scheduling.' .

ind:MsrpSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Msrp Schedule' ;
    rdfs:comment 'Official Manufacturer Suggested Retail Price schedule for each vehicle nameplate, model year, trim level, and option package combination. Captures base MSRP, destination and delivery charge, gas guzzler tax (if applicable), effective date, market region, and currency. Serves as the pricing reference baseline for all quotes, orders, and incentive calculations. Updated at model year launch and mid-cycle adjustments.' .

ind:SalesTerritory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Sales Territory' ;
    rdfs:comment 'Geographic or channel-based sales territory definition used to assign sales representatives, dealers, and regional managers to specific market areas. Captures territory code, territory name, region hierarchy (national/regional/district/zone), assigned sales manager, territory type (retail/fleet/export), and effective dates. Supports regional sales performance tracking and quota allocation.' .

ind:Rep rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Rep' ;
    rdfs:comment 'Master record for OEM direct sales representatives and field sales personnel responsible for managing dealer relationships, fleet accounts, and direct sales channels. Captures employee reference, assigned territory, sales role (retail field rep, fleet account manager, national account executive, export sales), quota assignment, certification status, and active status. Distinct from dealer-side sales staff managed in the dealer domain.' .

ind:Quota rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Quota' ;
    rdfs:comment 'Sales volume and revenue quota assigned to a sales representative, dealer, sales territory, or regional team for a defined period (monthly, quarterly, annual). Captures quota type (unit volume, revenue, EV mix, fleet penetration), target value, model year or fiscal period, assigned entity type and reference, and quota approval status. Enables sales performance tracking against targets.' .

ind:Activity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Activity' ;
    rdfs:comment 'Record of a sales-related interaction or activity logged against a lead, opportunity, or customer account. Captures activity type (call, email, test drive, demo, site visit, proposal presentation), activity date and time, outcome, next action, associated opportunity or lead reference, and sales rep performing the activity. Sourced from Salesforce Automotive Cloud Activity/Task/Event objects. Supports pipeline velocity and conversion analysis.' .

ind:Campaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sales ;
    rdfs:label 'Campaign' ;
    rdfs:comment 'Master record for a structured sales and marketing campaign targeting specific customer segments, nameplates, or market regions to drive vehicle sales. Captures campaign name, campaign type (model launch, clearance, seasonal, conquest, loyalty), target nameplate and model year, target customer segment, campaign period, budget allocation, participating dealers or regions, and campaign objectives. Distinct from incentive programs — campaigns coordinate multi-channel outreach while incentive programs define financial offers.' .

ind:VinRegistry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vehicle ;
    rdfs:label 'Vin Registry' ;
    rdfs:comment 'SSOT for every physical vehicle instance identified by its 17-character VIN per ISO 3779. Captures decoded VIN structure (WMI, VDS, VIS), manufacturing plant code, production sequence number, build date, model year (MY), line-off timestamp, homologation market, and current lifecycle status (pre-production, in-production, in-transit, in-service, end-of-life). This is the enterprise anchor record — the single identity key — that every downstream domain (sales, aftersales, logistics, mobility, finance) references to identify a specific vehicle unit.' .

ind:Model rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vehicle ;
    rdfs:label 'Model' ;
    rdfs:comment 'Defines the commercial vehicle model (nameplate) as a business entity — e.g., F-150, Camry, Model 3. Captures model name, brand/marque, vehicle segment (sedan, SUV, pickup, commercial), body style, drive configuration (FWD, RWD, AWD, 4WD), primary market, launch MY, EOP MY, and program code. Serves as the top-level classification anchor for all vehicle configurations and trim hierarchies.' .

ind:ModelYearProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vehicle ;
    rdfs:label 'Model Year Program' ;
    rdfs:comment 'Governs the MY (Model Year) lifecycle for each model, from SOP (Start of Production) through EOP (End of Production). Tracks planned SOP date, actual SOP date, planned EOP date, actual EOP date, regulatory MY designation, CAFE compliance year, homologation status per market, and program phase (concept, development, launch, production, wind-down). Links model to its annual production program and drives downstream planning in manufacturing and supply chain.' .

ind:TrimLevel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vehicle ;
    rdfs:label 'Trim Level' ;
    rdfs:comment 'Defines the ordered hierarchy of trim grades within a model-MY combination (e.g., Base, XL, XLT, Lariat, Platinum, Limited). Captures trim code, trim name, market positioning tier, MSRP base price, standard feature set description, target market region, and active/inactive status. Trim levels are the primary commercial differentiation unit used in sales, dealer ordering, and MSRP pricing.' .

ind:PowertrainVariant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vehicle ;
    rdfs:label 'Powertrain Variant' ;
    rdfs:comment 'Authoritative catalog of all powertrain configurations available across the vehicle lineup. Captures powertrain type (ICE, HEV, PHEV, BEV, FCEV), engine displacement, cylinder count, fuel type, electric motor peak power (kW), combined system power, transmission type, drive type, EPA/WLTP fuel economy or range rating, CO2 emissions (g/km), battery capacity (kWh for EV/PHEV), and charging standard (CCS, CHAdeMO, NACS). Used for homologation, CAFE compliance, and consumer-facing specifications.' .

ind:Platform rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vehicle ;
    rdfs:label 'Platform' ;
    rdfs:comment 'Defines the vehicle platform (architecture) that underpins one or more models. Captures platform code, platform name, architecture generation, wheelbase range, track width range, structural material strategy (steel, aluminum, mixed), compatible powertrain families, maximum GVW rating, and platform owner business unit. Platforms are shared across multiple nameplates and model years, making this a critical cross-model reference for engineering, manufacturing, and supply chain.' .

ind:Configuration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vehicle ;
    rdfs:label 'Configuration' ;
    rdfs:comment 'The fully specified, buildable vehicle configuration combining model, MY, trim, powertrain, and market. Each record represents a unique orderable specification (analogous to a manufacturing SKU or dealer order code). Captures configuration code, market region, build feasibility status, MSRP, destination charge, fuel economy label values, emissions certification status, and production plant assignment. This is the master configuration record that bridges product planning to manufacturing BOM explosion and dealer order management.' .

ind:BuildSpec rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vehicle ;
    rdfs:label 'Build Spec' ;
    rdfs:comment 'The as-built specification record for a specific VIN, capturing the exact combination of configuration, options, colors, powertrain, and features installed on that vehicle unit as it rolled off the production line. Captures VIN reference, configuration code, exterior color, interior trim selection, all installed option codes, actual build date, plant code, production sequence number, and any deviation from standard specification (e.g., special order, fleet spec, running change). This is the definitive as-built record used by aftersales, warranty, recall population identification, and residual value analytics.' .

ind:Homologation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vehicle ;
    rdfs:label 'Homologation' ;
    rdfs:comment 'Tracks the regulatory type-approval and homologation status of vehicle configurations for each target market. Captures homologation type (whole vehicle type approval, component approval), regulatory framework (FMVSS, ECE, NCAP, CARB, EPA), approval authority, certificate number, approval date, expiry date, applicable model/MY/market, emissions standard tier (e.g., EPA Tier 3, Euro 6d), and compliance status. Critical for market launch readiness and regulatory reporting.' .

ind:EcuCatalog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vehicle ;
    rdfs:label 'Ecu Catalog' ;
    rdfs:comment 'Catalog of all ECU (Electronic Control Unit) and embedded software modules installed across vehicle configurations. Captures ECU code, ECU name, ECU function (engine control, transmission control, ADAS domain controller, body control, infotainment, OBD gateway), supplier, hardware part number, software baseline version, OTA-updatable flag, communication protocol (CAN, LIN, Ethernet, AUTOSAR), and applicable vehicle configurations. Supports OTA update management, cybersecurity compliance, and aftersales diagnostics.' .

ind:MsrpPricing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vehicle ;
    rdfs:label 'Msrp Pricing' ;
    rdfs:comment 'Manages the MSRP (Manufacturer Suggested Retail Price) schedule for vehicle configurations, trim levels, and option packages by market and MY. Captures base MSRP, destination and delivery charge, gas guzzler tax (if applicable), federal EV tax credit eligibility, effective date, expiry date, currency, and market region. Provides the authoritative pricing reference for dealer ordering, window sticker generation, and sales analytics. Distinct from dealer invoice pricing (owned by billing domain).' .

ind:LifecycleEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vehicle ;
    rdfs:label 'Lifecycle Event' ;
    rdfs:comment 'Transactional log of significant lifecycle state transitions for a specific VIN throughout its life. Captures event type (manufactured, PDI-completed, shipped-to-dealer, sold-retail, sold-fleet, exported, titled, re-acquired, scrapped, stolen, total-loss), event timestamp, event location, responsible party, odometer reading at event, and triggering system. Provides the complete lifecycle audit trail for a vehicle unit from production to end-of-life, supporting title history, recall tracking, and residual value analytics.' .

ind:VehicleProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Vehicle Program' ;
    rdfs:comment 'Master record for a vehicle development program (nameplate/platform program), capturing program code, program name, vehicle segment, platform architecture, SOP (Start of Production) target date, EOP (End of Production) date, MY (Model Year) scope, program phase (concept, development, validation, launch), program director, budget allocation, and program status. Serves as the top-level anchor for all engineering activities within a development cycle. Owned by Siemens Teamcenter PLM.' .

ind:Bom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Bom' ;
    rdfs:comment 'Engineering Bill of Materials (eBOM) header record representing the complete structured parts list for a vehicle program or variant at a specific revision level. Captures BOM type (eBOM, mBOM, sBOM), program reference, model year, configuration context, effectivity dates, release status, BOM owner, and PLM system source. The eBOM is the authoritative design-intent parts structure managed in Siemens Teamcenter and ENOVIA before handoff to manufacturing BOM.' .

ind:BomLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Bom Line' ;
    rdfs:comment 'Individual line item within an engineering BOM, representing a single part-to-parent relationship in the BOM hierarchy. Captures parent assembly reference, child part number, find number, quantity, unit of measure, effectivity start/end dates, variant applicability, substitution flags, BOM level, and engineering change reference. Supports multi-level BOM explosion and where-used analysis. Sourced from Siemens Teamcenter BOM Management.' .

ind:PartMaster rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Part Master' ;
    rdfs:comment 'Engineering part master record representing a unique part or component managed within the PLM system. Captures part number, part name, part classification, material type, weight, dimensions, drawing number, CAD model reference, lifecycle state (in-work, released, obsolete), revision level, owning engineer, supplier part number, REACH/RoHS compliance flag, and part family. Authoritative source for engineering part identity in Siemens Teamcenter / PTC Windchill.' .

ind:DesignSpecification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Design Specification' ;
    rdfs:comment 'Engineering design specification document record capturing the technical requirements and design intent for a vehicle system, subsystem, or component. Includes specification number, title, specification type (system, subsystem, component, interface), applicable program, revision history, author, approval status, linked requirements, target performance values, and regulatory references (FMVSS, UNECE, NCAP). Managed in Teamcenter or ENOVIA document management.' .

ind:Change rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Change' ;
    rdfs:comment 'Engineering Change Order/Notice (ECO/ECN) record capturing a formal request to modify a part, assembly, design specification, or BOM. Includes change number, change type (ECR/ECO/ECN), title, reason for change (cost reduction, quality, regulatory, customer request), affected parts list, affected programs, initiator, approver chain, priority, implementation date, cost impact estimate, and change status (draft, under review, approved, implemented, rejected). Managed in Siemens Teamcenter Change Management.' .

ind:ValidationTest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Validation Test' ;
    rdfs:comment 'Engineering validation test record capturing a physical or virtual test event performed on a prototype or production-intent part/vehicle. Includes test ID, test type (DVP — Design Verification Plan, PVP — Process Validation Plan, PPAP, durability, emissions, NCAP/WLTP, FMVSS), test name, test standard reference, test facility, test date, test engineer, test result (pass/fail/conditional), measured values vs. targets, and disposition. Supports DVP&R (Design Verification Plan and Report) tracking.' .

ind:EngineeringTestResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Engineering Test Result' ;
    rdfs:comment 'Detailed test result record capturing individual measurement data points from a validation test event. Includes result ID, parent test reference, measurement parameter name, unit of measure, measured value, target value, tolerance band (min/max), pass/fail status, test condition description, channel or sensor ID, timestamp of measurement, and data file reference. Enables granular traceability of test outcomes against engineering targets and regulatory thresholds.' .

ind:Milestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Milestone' ;
    rdfs:comment 'Engineering program milestone record capturing key gate reviews and decision points in the vehicle development process. Includes milestone ID, milestone name (P0 concept freeze, P1 design freeze, P2 prototype release, P3 pilot build, SOP), program reference, planned date, actual date, milestone owner, gate review outcome (approved, conditional, deferred), open action items count, and sign-off authority. Supports APQP (Advanced Product Quality Planning) phase gate management.' .

ind:FmeaRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Fmea Record' ;
    rdfs:comment 'FMEA (Failure Mode and Effects Analysis) record capturing the systematic risk analysis of a design or process. Includes FMEA ID, FMEA type (DFMEA — Design FMEA, PFMEA — Process FMEA), associated part or process, failure mode description, potential effect of failure, severity rating, potential cause, occurrence rating, current controls, detection rating, RPN (Risk Priority Number), recommended actions, responsible engineer, and completion date. Managed per IATF 16949 and AIAG-VDA FMEA methodology.' .

ind:DvpPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Dvp Plan' ;
    rdfs:comment 'Design Verification Plan (DVP) record defining the complete test plan for validating a vehicle system or component against its design specifications. Captures DVP ID, plan title, associated part or system, program reference, total test count, completion percentage, responsible engineer, approval status, linked specification, and planned vs. actual completion dates. Acts as the master test planning document that governs all validation_test records for a given scope.' .

ind:HomologationRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Homologation Requirement' ;
    rdfs:comment 'Homologation and regulatory requirement record capturing the specific regulatory standards and type-approval requirements that a vehicle or component must satisfy for a target market. Includes requirement ID, regulation name (FMVSS, ECE-R, CARB, Euro NCAP, WLTP, EPA), regulation number, market/region applicability, requirement description, compliance method (test, calculation, declaration), linked validation tests, compliance status, and submission deadline. Supports regulatory compliance and homologation engineering activities.' .

ind:EcuSpecification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Ecu Specification' ;
    rdfs:comment 'ECU (Electronic Control Unit) software and hardware specification record capturing the technical definition of an automotive electronic control module. Includes ECU ID, ECU name, ECU type (engine control, transmission, ADAS, body control, battery management), hardware part number, software version, calibration dataset reference, communication protocol (CAN, LIN, Ethernet, FlexRay), functional safety level (ASIL rating per ISO 26262), supplier reference, and release status. Critical for EV, HEV, and ADAS program engineering.' .

ind:PowertrainSpec rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Powertrain Spec' ;
    rdfs:comment 'Powertrain engineering specification record capturing the technical definition of an ICE, HEV, PHEV, or EV powertrain system. Includes spec ID, powertrain type (ICE, HEV, PHEV, BEV, FCEV), engine or motor displacement/power rating, torque output, transmission type, battery capacity (kWh) for electrified variants, fuel type, emissions standard compliance (Euro 6, EPA Tier 3, CARB LEV III), WLTP/EPA range rating, thermal management approach, and target program applicability. Supports R&D and powertrain engineering teams.' .

ind:MaterialSpecification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Material Specification' ;
    rdfs:comment 'Engineering material specification record defining the approved materials for use in vehicle components. Captures spec ID, material name, material class (steel, aluminum, polymer, composite, glass), grade or alloy designation, mechanical properties (tensile strength, yield strength, elongation), thermal properties, density, surface treatment requirements, applicable standards (SAE, ASTM, DIN), REACH/RoHS compliance status, approved supplier list, and application restrictions. Supports part design and supplier qualification.' .

ind:Document rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Document' ;
    rdfs:comment 'Engineering document record serving as the metadata catalog for all controlled engineering documents managed in the PLM system. Includes document ID, document number, title, document type (drawing, specification, test report, analysis report, FMEA, DVP, meeting minutes), revision level, author, approval status, release date, associated program and part references, document format, storage location reference, and retention policy. Supports document control per IATF 16949 and ISO 9001 requirements.' .

ind:SupplierPartApproval rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supplier Part Approval' ;
    rdfs:comment 'PPAP (Production Part Approval Process) record capturing the formal approval of a supplier-produced part for use in production. Includes approval ID, part number, supplier reference, PPAP submission level (1–5), submission date, approval date, approver, PPAP elements status (design records, PFMEA, control plan, MSA, capability study, sample parts), approval outcome (approved, interim approval, rejected), and expiry date. Mandated by IATF 16949 and AIAG PPAP standards for all production parts.' .

ind:Shipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Shipment' ;
    rdfs:comment 'Core master record for each outbound vehicle shipment from plant to dealer or distribution point. Captures shipment origin (plant/compound), destination (dealer/port/yard), transport mode (rail, truck, vessel, CKD/SKD), shipment status, planned and actual departure/arrival dates, OTD tracking, and associated VINs. Primary operational entity for finished vehicle logistics. Sourced from SAP SD outbound delivery and MES traceability.' .

ind:ShipmentLeg rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Shipment Leg' ;
    rdfs:comment 'Individual transport leg within a multi-modal shipment, representing a discrete movement segment (e.g., plant to rail yard, rail yard to port, port to dealer compound). Tracks leg sequence, transport mode, carrier assignment, origin/destination facility, planned and actual departure/arrival timestamps, distance, leg-level status, and mode-specific details (rail car number/type for rail legs, vessel name/IMO/voyage for ocean legs). After merges, this product also carries rail car assignment details and vessel voyage references for their respective transport modes. Enables end-to-end multi-modal visibility for each VIN or batch.' .

ind:VehicleTransportOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Vehicle Transport Order' ;
    rdfs:comment 'Transport order issued to a carrier for the movement of finished vehicles. Captures order number, issuing plant, carrier reference, transport mode, vehicle count, VIN list, origin compound, destination, requested pickup date, confirmed pickup date, and order status. Represents the contractual instruction to move vehicles and is the primary document linking shipments to carrier execution. Sourced from SAP TM or SAP SD.' .

ind:LogisticsDeliverySchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Logistics Delivery Schedule' ;
    rdfs:comment 'Planned delivery schedule for finished vehicles from plant or distribution compound to dealer network. Captures scheduled delivery windows, dealer allocation, vehicle model/trim/color mix, planned quantities, transport mode, and scheduling horizon (weekly/monthly). Supports OTD planning, dealer inventory replenishment, and logistics capacity allocation. Linked to dealer orders and production scheduling.' .

ind:Carrier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Carrier' ;
    rdfs:comment 'Master record for transport carriers (road haulers, rail operators, ocean shipping lines, port logistics providers) engaged for finished vehicle and CKD/SKD kit logistics. Captures carrier legal name, SCAC code, DOT number, transport modes supported, operating regions, contract reference, insurance certificate details, IATF 16949 compliance status, carrier tier classification, and performance rating. SSOT for carrier identity within the logistics domain. Referenced by transport orders, shipment legs, freight invoices, damage claims, and rate contracts.' .

ind:CarrierPerformance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Carrier Performance' ;
    rdfs:comment 'Periodic carrier performance scorecard capturing OTD rate, damage rate (PPM), transit time compliance, claim frequency, and overall carrier rating per lane and transport mode. Tracks performance against contracted SLAs, flags underperforming carriers, and supports carrier qualification reviews. Aggregated at carrier-lane-period level for logistics procurement decisions.' .

ind:VehicleCompound rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Vehicle Compound' ;
    rdfs:comment 'Master record for vehicle storage compounds, yards, and staging areas used in the outbound logistics network (plant yards, rail yards, port compounds, regional distribution centers). Captures compound name, location, type (plant/port/regional/dealer prep), storage capacity (units), current occupancy, operator, PDI capability flag, and compound status. Enables compound capacity planning and in-transit inventory tracking.' .

ind:CompoundMovement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Compound Movement' ;
    rdfs:comment 'Transactional record of a vehicle\'s physical movement into, within, or out of a compound or yard. Captures VIN, movement type (inbound/outbound/internal transfer), origin bay/zone, destination bay/zone, movement timestamp, operator ID, and associated transport order. Provides granular yard management traceability and supports compound throughput analysis.' .

ind:InTransitInventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'In Transit Inventory' ;
    rdfs:comment 'Real-time and point-in-time snapshot of finished vehicles currently in transit between plant and dealer, including vehicles on rail, truck, vessel, or staged at intermediate compounds. Captures VIN, current location (last known compound or leg), transport mode, origin, destination, estimated arrival date, days in transit, and transit status. Critical for dealer allocation visibility and OTD monitoring.' .

ind:PortProcessing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Port Processing' ;
    rdfs:comment 'Record of port-of-entry or port-of-exit processing activities for finished vehicles in export/import operations. Captures port facility, vessel name, voyage number, arrival/departure dates, customs clearance status, homologation inspection status, PDI completion, port charges, and release authorization. Supports global distribution and import compliance tracking per UNECE and local customs regulations.' .

ind:VesselVoyage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Vessel Voyage' ;
    rdfs:comment 'Master record for ocean vessel voyages used in finished vehicle export/import logistics. Captures vessel name, IMO number, voyage number, shipping line, origin port, destination port, planned and actual departure/arrival dates, vehicle capacity (units), booked units, and voyage status. Enables RoRo vessel capacity planning and export shipment scheduling.' .

ind:TransportRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Transport Rate' ;
    rdfs:comment 'Contracted transport rate master for carrier lanes, defining the agreed cost per unit (vehicle or container) by origin-destination pair, transport mode, vehicle type/size class, and effective date range. Captures base rate, fuel surcharge structure, accessorial charges, currency, and rate validity period. Used for freight cost estimation, invoice verification, and logistics cost planning.' .

ind:Lane rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Lane' ;
    rdfs:comment 'Master record defining a logistics lane as an origin-destination pair for finished vehicle or CKD/SKD transport. Captures origin facility (plant/compound/port), destination facility (dealer/compound/port), transport mode, distance, standard transit time, lane status, and assigned primary/backup carriers. Serves as the reference for route planning, rate assignment, and OTD benchmarking.' .

ind:VehicleHandover rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Vehicle Handover' ;
    rdfs:comment 'Record of formal vehicle handover from logistics/compound to dealer or end customer. Captures VIN, handover date, handover location, receiving party (dealer/customer), handover type (dealer stock/retail customer), odometer reading at handover, handover condition, PDI reference, and acceptance signature status. Marks the transfer of custody and triggers downstream billing and warranty start events.' .

ind:Supplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'Master record for all tier-1 and tier-2 suppliers in the automotive supply chain. Captures supplier identity, classification (direct/indirect, tier level), IATF 16949 certification status, DUNS number, geographic footprint, commodity codes, preferred currency, payment terms, and supplier lifecycle status (active, probation, disqualified). SSOT for supplier identity within the supply domain; integrates with SAP MM vendor master and PTC Windchill supplier collaboration.' .

ind:SupplierPlant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supplier Plant' ;
    rdfs:comment 'Represents the specific manufacturing or distribution plant/site of a supplier that ships parts to an OEM assembly plant. Captures plant address, plant code, production capabilities, capacity constraints, dock-to-dock lead time, customs zone, and plant-level quality certifications. Enables JIT/JIS scheduling at the plant-to-plant level and supports CKD/SKD kit origin tracking.' .

ind:InboundPart rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Inbound Part' ;
    rdfs:comment 'Master record for every purchased part number sourced from external suppliers. Captures OEM part number, supplier part number cross-reference, commodity group, material type (raw, sub-assembly, CKD kit), unit of measure, PPAP approval status, engineering change level, hazardous material flag, country of origin, and customs tariff code. Bridges SAP MM material master and PTC Windchill parts classification for supply-domain-owned purchased parts.' .

ind:SourcingNomination rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Sourcing Nomination' ;
    rdfs:comment 'Records the formal OEM decision to nominate a specific supplier for a given part or commodity within a model year program. Captures nomination date, program/platform code, nominated supplier, awarded annual volume, target piece price, SOR (Statement of Requirements) reference, nomination status (nominated, confirmed, withdrawn), and the responsible commodity buyer. Precedes the RFQ and PPAP process. SSOT for sourcing award decisions; distinct from procurement domain\'s strategic sourcing strategy — this is the operational award record.' .

ind:Rfq rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Rfq' ;
    rdfs:comment 'Transactional record of a Request for Quotation event issued to one or more suppliers for a specific part, assembly, or service. Captures RFQ number, issue date, response due date, commodity, target price, annual volume estimate, program/model year, tooling requirements, and RFQ status (open, closed, awarded, cancelled). Integrates with SAP MM RFQ (ME41) and PTC Windchill supplier collaboration portal.' .

ind:RfqResponse rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Rfq Response' ;
    rdfs:comment 'Captures a supplier\'s formal quotation response to an RFQ. Records quoted unit price, tooling cost, amortization terms, lead time, capacity commitment, exceptions to SOR, validity period, and response status (submitted, under review, accepted, rejected). Supports competitive bid analysis and supplier selection decisions. One RFQ may have multiple responses from competing suppliers.' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Legally binding procurement document issued to a supplier authorizing delivery of parts or materials at agreed price and schedule. Captures PO number, PO type (standard, blanket, scheduling agreement), supplier, plant, delivery terms (Incoterms), payment terms, total value, currency, and PO status (open, partially delivered, closed, cancelled). SSOT for purchase commitments; sourced from SAP MM (ME21N/ME22N).' .

ind:PoLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Po Line' ;
    rdfs:comment 'Individual line item within a purchase order representing a specific part number, quantity, unit price, delivery date, and plant destination. Captures line number, material number, ordered quantity, confirmed quantity, net price, delivery date, goods receipt quantity, and invoice quantity. Enables line-level tracking of delivery performance and invoice matching (3-way match) in SAP MM.' .

ind:SchedulingAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Scheduling Agreement' ;
    rdfs:comment 'Long-term supply agreement with a supplier defining the framework for JIT/JIS delivery of parts over a model year or contract period. Captures agreement number, validity start/end dates, target annual volume, release horizon (firm/forecast weeks), delivery rhythm (daily, weekly), Kanban flag, and agreement status. The scheduling agreement is the backbone of JIT supply in SAP MM (ME31L/ME32L).' .

ind:SupplyDeliverySchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supply Delivery Schedule' ;
    rdfs:comment 'JIT/JIS delivery schedule line issued against a scheduling agreement, specifying exact quantities and delivery dates/times for a part to a plant dock. Captures schedule line date, time, required quantity, cumulative quantity, schedule type (firm, forecast, JIS sequence), dock door, and transmission status (sent, acknowledged, revised). Drives supplier production and logistics planning. Sourced from SAP MM schedule lines (EKET).' .

ind:SupplyPpapSubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supply Ppap Submission' ;
    rdfs:comment 'Production Part Approval Process submission record tracking the formal approval of a supplier\'s manufacturing process for a specific part. Captures PPAP level (1–5), submission date, part number, supplier, engineering change level, submission reason (new part, engineering change, tooling move), PPAP elements checklist status, PSW (Part Submission Warrant) status, and approval/rejection date. Integrates with PTC Windchill and SAP QM. SSOT for PPAP compliance.' .

ind:InboundShipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Inbound Shipment' ;
    rdfs:comment 'Tracks an inbound shipment of parts from a supplier plant to an OEM receiving dock. Captures ASN (Advance Shipping Notice) number, carrier, mode of transport (road, rail, air, sea), departure date/time, estimated arrival date/time, actual arrival date/time, total weight, total volume, number of containers/pallets, customs declaration number, and shipment status (in transit, arrived, cleared, received). Integrates with SAP MM inbound delivery (VL31N).' .

ind:SupplierScorecard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supplier Scorecard' ;
    rdfs:comment 'Periodic (monthly/quarterly) performance evaluation record for a supplier across key KPIs including PPM (Parts Per Million defect rate), OTD (On-Time Delivery percentage), delivery quantity accuracy, PPAP on-time completion rate, responsiveness score, and overall supplier rating. Captures evaluation period, scoring methodology version, individual KPI values, weighted total score, performance tier (preferred, approved, conditional, disqualified), and corrective action flag.' .

ind:CorrectiveAction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Supplier corrective action request (SCAR) issued when a supplier fails to meet quality, delivery, or compliance requirements. Captures SCAR number, triggering event (PPM breach, OTD failure, audit finding), root cause category, 8D report reference, containment action, permanent corrective action, verification date, and closure status. Drives supplier development and continuous improvement programs.' .

ind:InboundInspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Inbound Inspection' ;
    rdfs:comment 'Incoming quality inspection record for parts received from a supplier at an OEM plant. Captures inspection lot number, inspection date, part number, supplier, sample size, inspection method (AQL sampling, 100% check, skip-lot), number of defects found, defect type codes, inspection result (pass, fail, conditional release), and disposition (accept, return to supplier, sort and use). Integrates with SAP QM inspection lots.' .

ind:PriceAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Price Agreement' ;
    rdfs:comment 'Formally agreed piece price and commercial terms between the OEM and a supplier for a specific part over a defined period. Captures agreement number, part number, supplier, effective date, expiry date, agreed unit price, currency, annual price reduction commitment (APR), tooling amortization terms, price adjustment triggers (material index, FX), and agreement status (active, expired, under negotiation). Distinct from the purchase order — this is the commercial price framework.' .

ind:AftersalesRepairOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Aftersales Repair Order' ;
    rdfs:comment 'Core transactional record capturing a vehicle service or repair event at an authorized service center or dealership. Tracks RO number, vehicle VIN, customer, service advisor, open/close dates, labor operations performed, parts consumed, total labor cost, total parts cost, total RO value, payment method, warranty vs. customer pay vs. internal pay type, DMS source (CDK Global), mileage at write-up, promised completion time, actual completion time, technician assignments, and RO status lifecycle (open, in-progress, quality-check, closed, invoiced).' .

ind:RepairOrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Repair Order Line' ;
    rdfs:comment 'Individual labor operation or job line within a repair order. Captures operation code, labor time standard (flat-rate hours), actual technician hours, labor rate, line total, technician ID, cause/complaint/correction (3C) narrative, warranty flag, sublet flag, and line status. Supports granular cost analysis and technician productivity tracking per CDK Global DMS job line structure.' .

ind:AftersalesWarrantyClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Aftersales Warranty Claim' ;
    rdfs:comment 'Warranty claim submitted by a dealer or authorized service center to the OEM for reimbursement of warranty-covered repairs. Tracks claim number, VIN, repair order reference, failure date, repair date, claim submission date, claim status (submitted, approved, rejected, adjusted, paid), approved labor hours, approved parts cost, total claim amount, rejection reason code, goodwill flag, campaign/recall linkage, and OEM adjudication outcome. Integrates with SAP SD warranty module and CDK Global DMS.' .

ind:WarrantyPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Warranty Policy' ;
    rdfs:comment 'Master definition of warranty coverage terms applicable to a vehicle nameplate, model year, powertrain type, or market. Captures warranty type (basic/bumper-to-bumper, powertrain, corrosion, emissions, EV battery, ADAS), coverage duration in months, coverage distance in miles/km, deductible amount, transferability flag, market/region applicability, SOP and EOP dates, and governing regulatory body (NHTSA, EPA). Serves as the authoritative reference for warranty eligibility determination.' .

ind:VehicleWarranty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Vehicle Warranty' ;
    rdfs:comment 'VIN-level warranty entitlement record linking a specific vehicle to its applicable warranty policies. Tracks warranty start date (in-service date), expiration date, remaining months, remaining mileage, warranty status (active, expired, voided), extended warranty flag, CPO (Certified Pre-Owned) warranty flag, and any warranty transfer history. This is the SSOT for whether a specific vehicle is under warranty at any point in time.' .

ind:ServiceCampaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Service Campaign' ;
    rdfs:comment 'Master record for a service campaign (recall or non-safety field action) issued by the OEM. Captures NHTSA recall number, campaign code, campaign type (safety recall, emissions recall, customer satisfaction program, technical service bulletin action), affected nameplate/model year range, affected VIN population count, remedy description, estimated repair time, parts required, campaign open date, campaign close date, regulatory reporting status, and NHTSA/UNECE compliance flags. Integrates with NHTSA recall database and SAP QM.' .

ind:CampaignVin rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Campaign Vin' ;
    rdfs:comment 'Association record linking a specific VIN to an open service campaign or recall. Tracks VIN, campaign code, notification status (not notified, notified, scheduled, completed, parts-on-order, owner-refused), remedy completion date, dealer code where remedy was performed, parts consumed for remedy, and compliance deadline. Enables OEM and NHTSA to track recall completion rates at the individual vehicle level.' .

ind:AftersalesServiceAppointment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Aftersales Service Appointment' ;
    rdfs:comment 'Scheduled service appointment record for a vehicle at a dealership or authorized service center. Captures appointment date/time, customer contact, VIN, service type (maintenance, warranty repair, recall, PDI, customer pay), service advisor assigned, estimated duration, transportation option (loaner, shuttle, wait), appointment source (online, phone, DMS, mobile app), confirmation status, check-in time, and no-show flag. Sourced from CDK Global DMS scheduling module.' .

ind:Tsb rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Tsb' ;
    rdfs:comment 'Technical Service Bulletin master record issued by OEM engineering to communicate repair procedures, diagnostic guidance, or part supersessions to the dealer service network. Captures TSB number, title, affected nameplate/model year/VIN range, symptom description, root cause, recommended repair procedure, required parts list, estimated labor time, issue date, supersession reference, and distribution status to dealer network. Integrates with PTC Windchill and CDK Global DMS.' .

ind:LaborTimeStandard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Labor Time Standard' ;
    rdfs:comment 'Reference master for flat-rate labor time standards (operation times) used to price warranty claims and customer-pay repair operations. Captures operation code, operation description, applicable nameplate/model year range, standard flat-rate hours, skill level required, special tool requirement flag, last revision date, and source (OEM labor time guide or MOTOR/Alldata industry standard). Used by CDK Global DMS to auto-populate labor time on repair order lines.' .

ind:ServicePart rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Service Part' ;
    rdfs:comment 'Aftersales service parts master record for parts stocked and consumed in dealer service and repair operations. Captures OEM part number, supersession chain (current and all prior part numbers), part description, part category (mechanical, electrical, body, consumable, fluid, accessory), unit of measure, standard list price, dealer net price, core charge amount, weight, hazmat flag, country of origin, minimum order quantity, and lifecycle status (active, superseded, discontinued, obsolete). Serves as the aftersales-specific view of the parts catalog optimized for service ordering and warranty claims — distinct from the manufacturing BOM parts master in the engineering domain.' .

ind:PartsOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Parts Order' ;
    rdfs:comment 'Parts order placed by a dealer or service center to the OEM parts distribution center (PDC) or regional warehouse. Captures order number, ordering dealer code, PDC fulfillment location, order date, requested delivery date, order type (stock, emergency, campaign/recall, special), order status (submitted, confirmed, picked, shipped, received, invoiced), total order value, freight terms, and backorder flags. Integrates with SAP MM and dealer DMS parts ordering module.' .

ind:PartsOrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Parts Order Line' ;
    rdfs:comment 'Individual line item within a dealer parts order. Captures part number, ordered quantity, confirmed quantity, shipped quantity, unit price, line total, backorder quantity, estimated availability date, and substitution part number if original is unavailable. Enables granular parts fulfillment tracking and backorder management at the line level.' .

ind:ServiceContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Service Contract' ;
    rdfs:comment 'Extended service contract or vehicle service agreement (VSA) sold to a customer beyond the standard OEM warranty. Captures contract number, VIN, customer reference, contract type (powertrain, comprehensive, maintenance plan, tire and wheel), coverage start date, coverage end date, coverage mileage limit, deductible amount, selling dealer, administrator (OEM or third-party), contract status (active, expired, cancelled, transferred), and total contract value. Distinct from the OEM warranty_policy which is factory-issued.' .

ind:ServiceContractClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Service Contract Claim' ;
    rdfs:comment 'Claim submitted against an extended service contract or VSA for a covered repair. Tracks claim number, service contract reference, repair order reference, VIN, claim submission date, covered repair description, claimed labor amount, claimed parts amount, deductible applied, approved amount, claim status (pending, approved, denied, paid), and denial reason code. Distinct from OEM warranty_claim which is submitted to the manufacturer.' .

ind:GoodwillAdjustment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Goodwill Adjustment' ;
    rdfs:comment 'Goodwill or customer assistance transaction where the OEM or dealer provides financial relief to a customer for a repair outside standard warranty coverage. Captures adjustment number, VIN, customer reference, repair order reference, goodwill type (full coverage, partial coverage, parts-only, labor-only, cash reimbursement), requested amount, approved amount, approval authority level (service manager, zone manager, regional, national), business justification narrative, policy exception code, and customer retention outcome. Tracks OEM goodwill spend against budget allocations and enables cost management reporting by region, model, and failure type.' .

ind:ServiceCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Service Center' ;
    rdfs:comment 'Master record for authorized service centers and dealership service departments in the OEM aftersales network. Captures service center code, name, address, dealer group affiliation, authorization level (warranty, recall, certified collision, EV-certified, ADAS-calibration), service bay count, technician headcount, CDK Global DMS instance ID, operating hours, loaner fleet size, and network status (active, suspended, terminated). Distinct from the dealer domain\'s dealer profile — this is the service-operations-specific view.' .

ind:Technician rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Technician' ;
    rdfs:comment 'Master record for service technicians employed at authorized service centers. Captures technician ID, name, service center assignment, certification level (ASE, OEM-certified, EV-certified, ADAS-certified), specialization (powertrain, electrical, body, diagnostics), flat-rate efficiency rating, current active RO count, hire date, and certification expiry dates. This is the aftersales-specific technician profile focused on service capacity and certification — distinct from the workforce domain\'s employee record.' .

ind:PartsReturn rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Parts Return' ;
    rdfs:comment 'Parts return transaction record for defective, warranty-core, or over-ordered parts returned from a dealer to the OEM PDC. Captures return authorization number, originating dealer, return reason code (warranty defect, core return, overstock, campaign supersession), part number, quantity returned, credit amount, return shipment tracking, OEM inspection outcome (accepted, rejected, partial credit), and credit memo reference. Integrates with SAP MM returns management.' .

ind:SkuMaster rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Sku Master' ;
    rdfs:comment 'SSOT for all Stock Keeping Unit (SKU) definitions across the enterprise. Owns the material master record for raw materials, production components, WIP sub-assemblies, finished vehicles, and service parts. Aligned with SAP MM material master (MARA/MARC). Captures SKU identity, classification, unit of measure, weight/dimensions, hazardous material flags, shelf-life, and MRP planning parameters. Referenced by all inventory movement and stock transactions.' .

ind:StorageLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Master record for all physical and logical storage locations within plants, warehouses, distribution centers, and dealer parts depots. Captures location hierarchy (plant → warehouse → storage type → storage bin), location type (bulk, rack, floor, cold-chain), capacity constraints, and WM (Warehouse Management) configuration. Aligned with SAP WM storage location and bin master. Enables precise bin-level inventory tracking and AGV routing.' .

ind:StockBalance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Balance' ;
    rdfs:comment 'Current on-hand stock balance snapshot for each SKU at each storage location, plant, and valuation area. Captures unrestricted stock, quality inspection stock, blocked stock, consignment stock, in-transit stock, and safety stock levels. Aligned with SAP MM stock overview (MMBE / MARD). Supports MRP execution, inventory turnover analysis, and obsolescence monitoring. Updated by every goods movement transaction.' .

ind:GoodsMovement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Goods Movement' ;
    rdfs:comment 'Transactional record of every inventory movement event including goods receipts (GR), goods issues (GI), stock transfers, returns, and scrapping. Aligned with SAP MM material document (MSEG/MKPF). Captures movement type, quantity, source and destination storage locations, reference document (purchase order, production order, delivery), posting date, and batch/serial number. Provides full audit trail for lot traceability and IATF 16949 compliance.' .

ind:StockTransferOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Transfer Order' ;
    rdfs:comment 'Warehouse Management transfer order governing the physical movement of stock between storage bins, storage types, or plants. Aligned with SAP WM transfer order (LT0A). Captures source and destination bin, transfer quantity, movement reason, AGV assignment, picker assignment, confirmation status, and execution timestamps. Supports JIT/JIS sequencing for line-side replenishment and inter-plant stock balancing.' .

ind:MrpRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Mrp Requirement' ;
    rdfs:comment 'MRP (Material Requirements Planning) planned requirement record generated by SAP MRP run (MD04/MD05). Captures dependent and independent demand requirements for each SKU, planned order proposals, reorder points, lot sizes, lead times, and exception messages. Drives procurement requisitions and production orders. Supports safety stock calculation, demand smoothing, and supply gap analysis across the manufacturing network.' .

ind:CycleCount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Cycle Count' ;
    rdfs:comment 'Physical inventory cycle count event record for a specific SKU at a specific storage location. Aligned with SAP MM physical inventory document (MI01/MI07). Captures count date, counted quantity, book quantity, variance quantity, variance percentage, count status (planned, counted, posted, approved), counter identity, and recount flag. Supports inventory accuracy KPIs, ABC classification-driven count frequency, and IATF 16949 inventory control requirements.' .

ind:FinishedVehicleStock rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Finished Vehicle Stock' ;
    rdfs:comment 'Finished vehicle inventory record tracking completed vehicles from end-of-line (EOL) through PDI (Pre-Delivery Inspection), compound storage, and dealer allocation. Captures VIN, model/trim/color configuration, plant of manufacture, current compound or yard location, stock status (in-production, PDI-pending, PDI-complete, allocated, in-transit, delivered), hold codes, and aging days. Bridges manufacturing and logistics domains for vehicle order fulfillment.' .

ind:ServicePartsStock rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Service Parts Stock' ;
    rdfs:comment 'After-sales service parts inventory record tracking spare parts and accessories across the central parts distribution center (PDC), regional warehouses, and dealer parts rooms. Captures part number, supersession chain, current stock level by location, min/max replenishment levels, fill rate, backorder quantity, and obsolescence classification. Supports dealer parts ordering, warranty repair fulfillment, and TSB (Technical Service Bulletin) parts pre-positioning.' .

ind:Hold rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Hold' ;
    rdfs:comment 'Inventory hold and block record restricting the use or movement of specific stock due to quality holds, engineering change notices (ECN), regulatory non-conformance, supplier PPAP failures, or recall investigations. Captures hold type, affected SKU/batch/serial range, quantity blocked, hold reason code, initiating department, hold start date, expected release date, and disposition decision (use-as-is, rework, scrap, return-to-supplier). Supports APQP/PPAP compliance and quality containment actions.' .

ind:ReplenishmentOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Replenishment Order' ;
    rdfs:comment 'Internal replenishment order triggering stock movement from a supplying storage location (warehouse, supermarket, PDC) to a consuming location (line-side, assembly station, dealer parts room). Captures replenishment type (kanban, min-max, JIT pull, JIS sequence), trigger source, requested SKU and quantity, source and destination locations, priority, requested delivery time, and fulfillment status. Supports lean manufacturing pull systems and dealer parts replenishment cycles.' .

ind:SafetyStockPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Safety Stock Policy' ;
    rdfs:comment 'Safety stock and reorder point policy record defining the minimum stock buffer for each SKU at each plant/location to protect against demand variability and supply disruptions. Captures safety stock quantity, reorder point, maximum stock level, replenishment lead time, demand variability factor, service level target, review cycle, and last recalculation date. Drives MRP safety stock parameters and supports supply chain resilience planning.' .

ind:ApqpPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Apqp Plan' ;
    rdfs:comment 'Advanced Product Quality Planning master record governing the structured quality planning process for new vehicle programs and components. Tracks APQP phases (concept, design, process, validation, launch), milestone gates, responsible teams, and completion status per program/part. Aligns with IATF 16949 requirements and links to engineering change and SOP timelines.' .

ind:Fmea rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Fmea' ;
    rdfs:comment 'Failure Mode and Effects Analysis master record capturing potential failure modes, their effects, causes, current controls, severity/occurrence/detection ratings, and Risk Priority Numbers (RPN) for vehicle components, subsystems, and manufacturing processes. Supports both Design FMEA (DFMEA) and Process FMEA (PFMEA) per AIAG-VDA FMEA methodology. Tracks recommended actions and revised RPN after corrective actions.' .

ind:ControlPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Control Plan' ;
    rdfs:comment 'Quality control plan defining the process controls, inspection methods, measurement systems, reaction plans, and control characteristics for each manufacturing operation or assembly step. Links to PFMEA and inspection plans. Specifies sample sizes, frequencies, control methods (SPC, attribute, visual), and responsible functions per IATF 16949 requirements.' .

ind:InspectionPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Plan' ;
    rdfs:comment 'Detailed inspection plan specifying the characteristics to be measured, measurement methods, gauges/instruments, tolerances, sample sizes, and acceptance criteria for incoming material, in-process, and final vehicle inspections. Supports incoming material inspection (IQC), in-process quality gates, and PDI (Pre-Delivery Inspection). Linked to SAP QM inspection lots.' .

ind:InspectionLot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Lot' ;
    rdfs:comment 'Transactional record of a quality inspection event triggered for a batch of incoming materials, WIP assemblies, or finished vehicles. Captures lot origin (goods receipt, production order, delivery), inspection type, quantity inspected, inspection start/end timestamps, assigned inspector, and overall usage decision (accept, reject, conditional release). Sourced from SAP QM inspection lot management.' .

ind:InspectionResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Individual characteristic measurement result recorded during an inspection lot. Captures the measured value or attribute outcome, tolerance limits, pass/fail status, measurement instrument used, and inspector ID for each characteristic within an inspection plan. Supports SPC data collection and statistical analysis of process capability (Cp, Cpk).' .

ind:DefectRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Defect Record' ;
    rdfs:comment 'Operational record of a quality defect or non-conformance identified at any stage — incoming material, in-process assembly, final inspection, or field. Captures defect code, defect description, location on vehicle (zone/component), severity classification, detection method, quantity affected, containment action taken, and disposition (rework, scrap, use-as-is). Sourced from Apriso/Dassault MES quality control module.' .

ind:SpcChart rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Spc Chart' ;
    rdfs:comment 'Statistical Process Control chart master record defining the SPC monitoring configuration for a critical-to-quality (CTQ) characteristic at a specific process step. Specifies chart type (X-bar/R, X-bar/S, p-chart, c-chart), control limits (UCL, LCL), center line, subgroup size, sampling frequency, and out-of-control action plan (OCAP). Supports IATF 16949 SPC requirements.' .

ind:QualityPpapSubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Quality Ppap Submission' ;
    rdfs:comment 'Production Part Approval Process submission record for a supplier part or internally manufactured component. Tracks PPAP level (1-5), submission reason (new part, engineering change, tooling change), submission date, approval status, and the 18 PPAP elements status (design records, PFMEA, control plan, MSA, capability study, etc.). Supports IATF 16949 supplier quality management.' .

ind:Audit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Audit' ;
    rdfs:comment 'Quality system and process audit record capturing planned and unplanned audits conducted at plants, supplier facilities, or dealer service centers. Tracks audit type (system, process, product, layered process audit — LPA), audit scope, audit date, lead auditor, findings count by severity, overall audit score, and closure status. Supports IATF 16949 internal audit requirements and customer-specific requirements (CSR).' .

ind:AuditFinding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Audit Finding' ;
    rdfs:comment 'Individual finding or observation raised during a quality audit. Captures finding type (major non-conformance, minor non-conformance, observation, opportunity for improvement), clause reference (IATF 16949, ISO 9001, customer-specific), finding description, evidence, assigned owner, due date for corrective action, and closure verification status. Linked to the parent quality audit record.' .

ind:PdiInspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Pdi Inspection' ;
    rdfs:comment 'Pre-Delivery Inspection (PDI) record for a finished vehicle prior to handover to dealer or customer. Captures VIN, inspection date, plant or PDI center, inspector ID, checklist version, total defects found, defect categories (cosmetic, functional, safety), rework required flag, and final pass/fail disposition. Supports dealer network quality standards and customer satisfaction targets.' .

ind:SupplierQualityEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Supplier Quality Event' ;
    rdfs:comment 'Supplier quality incident or deviation event record raised when a supplier-delivered part or material fails incoming inspection or causes a production disruption. Captures supplier code, part number, delivery note reference, defect description, quantity affected, severity (critical, major, minor), containment action, supplier response due date, and resolution status. Supports supplier corrective action request (SCAR) workflow.' .

ind:Standard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Standard' ;
    rdfs:comment 'Reference master for quality standards, specifications, and regulatory requirements applicable to the business. Captures standard code (IATF 16949, ISO 9001, ISO 14001, FMVSS, ECE regulations), standard title, issuing body, version, effective date, expiry date, applicability scope (global, regional, plant-specific), and compliance status. Used to link quality plans, audits, and test results to governing requirements.' .

ind:Party rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Party' ;
    rdfs:comment 'SSOT master entity for all customer identities served by Automotive — retail buyers (B2C), fleet operators, corporate accounts, government entities, and dealer principals. Stores the unified identity record including party type (individual/organization), legal name, tax identification, registration number, preferred language, preferred currency, date of birth (for individuals), incorporation date (for organizations), industry classification (NAICS/SIC), credit rating, KYC status, GDPR consent flags, data residency region, source system (Salesforce Automotive Cloud party ID), onboarding channel, onboarding date, lifecycle status (prospect/active/inactive/churned), and last verified date. This is the anchor entity for all customer-domain relationships.' .

ind:Individual rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Individual' ;
    rdfs:comment 'B2C retail customer profile extending the party master for natural persons. Captures personal identity attributes: first name, middle name, last name, suffix, gender, marital status, employment status, occupation, annual income band, education level, driver license number, driver license state/country, driver license expiry, primary spoken language, nationality, country of residence, household_id (FK to household), loyalty tier, NPS score (latest), CLTV estimate, preferred contact method, marketing opt-in flags, and Salesforce Contact ID. Supports personalized marketing, loyalty management, and customer journey analytics for retail vehicle buyers.' .

ind:OrganizationAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Organization Account' ;
    rdfs:comment 'B2B customer profile for corporate accounts, fleet operators, government entities, and leasing companies. Extends the party master with organization-specific attributes: legal entity name, DBA name, parent company party_id (for corporate hierarchy), DUNS number, SIC/NAICS code, annual revenue, number of employees, fleet size, procurement contact name, accounts payable contact, credit limit, payment terms, preferred OEM programs, government entity type (federal/state/municipal), contract vehicle type (GSA/state contract), Salesforce Account ID, SAP customer number, and account tier (strategic/key/standard). Enables B2B fleet sales, government procurement, and corporate account management.' .

ind:ContactPoint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Contact Point' ;
    rdfs:comment 'Stores all contact information for a party (individual or organization) including email addresses, phone numbers, mailing addresses, and social media handles. Each record captures: contact point type (email/phone/address/social), contact point value, is_primary flag, is_verified flag, verification date, verification method, opt-in status, opt-out date, channel (voice/SMS/email/mail/push), preferred time zone, preferred contact hours, source system, and effective/expiry dates. Supports omnichannel communication, regulatory compliance (TCPA, CAN-SPAM, GDPR), and Salesforce Automotive Cloud contact synchronization.' .

ind:VehicleOwnership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Vehicle Ownership' ;
    rdfs:comment 'Tracks the ownership history of vehicles by customers — the authoritative record linking a customer (party) to a VIN. Captures: VIN, party_id (owner), ownership type (retail purchase/lease/fleet/government), acquisition date, acquisition channel (dealer/direct/auction/fleet), acquisition dealer code, purchase price, trade-in VIN, registration state/country, registration number, registration expiry, title number, title state, lien holder name, insurance carrier, insurance policy number, insurance expiry, odometer at acquisition, current odometer (last reported), is_primary_vehicle flag, disposition type (sold/traded/totaled/repossessed), disposition date, and disposition odometer. SSOT for customer-vehicle relationship; cross-references vehicle domain VIN master.' .

ind:LoyaltyMembership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Loyalty Membership' ;
    rdfs:comment 'Manages customer enrollment and status in Automotive loyalty programs (e.g., owner rewards, EV early adopter program, fleet loyalty). Captures: program_id, party_id, membership number, enrollment date, enrollment channel, current tier (bronze/silver/gold/platinum), tier qualification date, tier expiry date, points balance, lifetime points earned, points expiry date, redemption eligibility flag, referral code, referred_by party_id, preferred redemption category, program status (active/suspended/expired/cancelled), and Salesforce Loyalty Management program member ID. Enables tier-based benefits, points accrual/redemption, and retention marketing.' .

ind:Preference rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Preference' ;
    rdfs:comment 'Stores customer-declared and inferred preferences for communications, vehicle features, service scheduling, and digital experiences. Each record captures: party_id, preference category (communication/vehicle/service/digital/privacy), preference key (e.g., preferred_fuel_type, preferred_body_style, preferred_service_day, email_frequency), preference value, value data type (string/boolean/integer/list), source (self-declared/inferred/imported), confidence score, effective date, expiry date, and last updated timestamp. Supports personalized marketing, product recommendation engines, and connected vehicle feature configuration.' .

ind:NpsResponse rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Nps Response' ;
    rdfs:comment 'Captures Net Promoter Score survey responses from customers across all touchpoints in the automotive ownership journey. Records: party_id, VIN (if vehicle-specific), survey_id, survey type (transactional/relational), touchpoint (vehicle_purchase/service_visit/delivery/recall/roadside/connected_app), dealer code, nps_score (0-10), promoter category (promoter/passive/detractor), verbatim comment, survey channel (email/SMS/app/IVR), survey date, response date, follow-up required flag, follow-up status, case_id (if escalated), and Salesforce Survey Response ID. Feeds NPS KPI reporting and closed-loop customer recovery workflows.' .

ind:Case rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Case' ;
    rdfs:comment 'Customer service case record tracking complaints, inquiries, warranty claims, recall notifications, and roadside assistance requests raised by customers through any channel. Captures: party_id, VIN (if vehicle-related), case number, case type (complaint/inquiry/warranty_claim/recall/roadside/goodwill/lemon_law/regulatory), case category, case sub-category, subject, description, priority (P1-P4), status (new/in_progress/pending_customer/resolved/closed/escalated), opened date, SLA due date, resolved date, closed date, resolution code, resolution description, dealer code (if dealer-handled), assigned agent ID, escalation level, escalation reason, total handle time (minutes), customer satisfaction score (post-resolution), Salesforce Case ID, and Microsoft Dynamics 365 Case ID. SSOT for customer service operations.' .

ind:HomologationRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Homologation Record' ;
    rdfs:comment 'Master record for vehicle type approval and homologation certifications across global markets. Captures UNECE type approval numbers, FMVSS homologation status, Euro NCAP ratings, WLTP certification references, and jurisdiction-specific approval details for each vehicle model and variant. Serves as the authoritative SSOT for all regulatory type approvals required before a vehicle can be sold in a given market.' .

ind:RegulatorySubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Submission' ;
    rdfs:comment 'Transactional record for each formal regulatory submission made to a governing body (NHTSA, EPA, CARB, UNECE, Euro NCAP, DOT). Captures submission type (type approval application, certificate of conformity, recall notice, CAFE report, safety standard compliance report), submission date, regulatory body, submission reference number, status (submitted, acknowledged, approved, rejected, under review), and responsible compliance officer. Central audit trail for all outbound regulatory filings.' .

ind:RecallCampaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Recall Campaign' ;
    rdfs:comment 'Master record for NHTSA safety recall campaigns and OEM-initiated service campaigns. Captures NHTSA recall number, campaign type (safety recall, emissions recall, OEM voluntary service campaign), defect description, affected population (VIN range, model year, nameplate), remedy description, campaign open date, remedy availability date, and campaign closure status. Serves as the compliance SSOT for recall management, distinct from aftersales.recall_completion which tracks dealer-level execution.' .

ind:TestEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Test Event' ;
    rdfs:comment 'Transactional record capturing each physical compliance test event conducted for regulatory certification purposes. Covers emissions testing (WLTP, FTP-75, NEDC, RDE), crash safety testing (NCAP, FMVSS), noise testing (NVH/ECE R51), and fuel economy testing. Captures test date, test facility, test type, vehicle configuration tested, test result (pass/fail/conditional), measured values, and the certifying laboratory. Links to the homologation record or emissions certification being pursued.' .

ind:ComplianceTestResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Compliance Test Result' ;
    rdfs:comment 'Detailed test result record for each measured parameter within a compliance test event. Captures parameter name (CO2 g/km, NOx mg/km, crash deformation zone, noise dB), measured value, regulatory limit, pass/fail status, test phase (cold start, hot start, WLTP low/medium/high/extra-high), and measurement uncertainty. Enables granular traceability of test outcomes against specific regulatory thresholds for each parameter tested.' .

ind:RegulatoryRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'Reference master defining all applicable regulatory requirements and standards that Automotive must comply with across jurisdictions. Captures regulation name, issuing body (NHTSA, EPA, CARB, UNECE, IATF, ISO), regulation code (e.g., FMVSS 208, ECE R94, Euro 6d), effective date, applicability scope (market, vehicle category, powertrain type), compliance deadline, and current status (active, superseded, proposed). Serves as the regulatory obligation register.' .

ind:Jurisdiction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Reference master for regulatory jurisdictions in which Automotive operates and sells vehicles. Captures jurisdiction name, jurisdiction type (federal, state, national, supranational), country or region code, primary regulatory body, applicable emissions standard tier, applicable safety standard framework, and market entry requirements. Used to map vehicles and certifications to the correct regulatory regime for each sales market.' .

ind:Obligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Obligation' ;
    rdfs:comment 'Operational record linking a specific vehicle program or model year to its applicable regulatory requirements by jurisdiction. Captures the obligation status (pending, in-progress, certified, waived, non-compliant), target certification date, responsible engineering team, and associated homologation record or emissions certification. Enables compliance program managers to track which regulatory obligations are open, in-flight, or closed for each vehicle program.' .

ind:ZevCredit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Zev Credit' ;
    rdfs:comment 'Master record for Zero Emission Vehicle (ZEV) and greenhouse gas (GHG) compliance credits earned, purchased, transferred, or retired under CARB ZEV mandate and EPA GHG credit programs. Captures credit type (ZEV, TZEV, AT PZEV, GHG), model year, credit quantity, credit vintage, earning basis (vehicle sales volume, powertrain type), credit status (earned, banked, transferred, retired), and counterparty for credit transfers. Supports CARB ZEV mandate compliance and EPA GHG credit banking strategy.' .

ind:GlAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General Ledger (GL) account master record aligned with SAP FI chart of accounts. Defines each account in the corporate chart of accounts including account type (asset, liability, equity, revenue, expense), account group, P&L vs balance sheet classification, currency, tax category, and reconciliation account flags. SSOT for all GL account definitions used across FI/CO postings, IFRS/GAAP reporting, and SOX compliance controls.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Cost center master record representing an organizational unit to which manufacturing costs, labor, overhead, and indirect expenses are assigned. Aligned with SAP CO cost center accounting (CCA). Captures cost center hierarchy, responsible manager, plant assignment, profit center linkage, valid-from/to dates, currency, and cost center category (production, administration, R&D, sales). Supports EBITDA reporting and profitability analysis by plant, vehicle line, and region.' .

ind:ProfitCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Profit center master record representing a management accounting unit used to analyze profitability by vehicle line, plant, region, or business segment. Aligned with SAP CO-PCA (Profit Center Accounting). Captures profit center hierarchy, responsible manager, company code assignment, segment classification (EV, ICE, HEV, commercial), and reporting currency. Enables contribution margin and EBITDA analysis at granular business unit level.' .

ind:CompanyCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Legal entity and company code master record representing an independent accounting unit within the Automotive enterprise. Aligned with SAP FI company code configuration. Captures legal entity name, country of incorporation, fiscal year variant, chart of accounts assignment, local currency, functional currency, IFRS/GAAP reporting standard, tax jurisdiction, and intercompany settlement group. Supports multi-entity consolidation and intercompany eliminations.' .

ind:FiscalPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Fiscal period and fiscal year (FY) calendar reference master defining the financial reporting periods used across the enterprise. Captures fiscal year, period number, period name, start date, end date, period status (open, closed, locked), period type (regular, special/adjustment), and company code applicability. Governs FY close processes, period-end accruals, and IFRS/GAAP reporting windows. Aligned with SAP FI fiscal year variant configuration.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'General ledger journal entry header record capturing all financial postings in the SAP FI ledger. Represents the primary transactional record for every accounting document including goods issue postings, vendor invoice postings, customer payments, accruals, depreciation runs, intercompany settlements, and manual adjustments. Captures document type, posting date, fiscal year/period, company code, reference document, posting user, reversal indicator, and ledger group (IFRS vs local GAAP). SSOT for all GL postings.' .

ind:JournalEntryLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry Line' ;
    rdfs:comment 'Individual line item within a GL journal entry, representing a single debit or credit posting to a GL account. Captures GL account, debit/credit indicator, posting amount in transaction currency and company code currency, cost center, profit center, WBS element, plant, tax code, assignment field, and line item text. Supports detailed cost allocation, profitability analysis, and SOX audit trail requirements. Aligned with SAP FI line item table (BSEG).' .

ind:ArInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ar Invoice' ;
    rdfs:comment 'Accounts Receivable (AR) customer invoice record capturing outgoing invoices issued to dealers, fleet customers, and intercompany entities for vehicle sales, parts, and services. Aligned with SAP FI-AR and SD billing integration. Captures customer/dealer ID, invoice date, due date, payment terms, gross amount, tax amount, net amount, currency, billing document reference, vehicle line, MSRP vs net selling price, and collection status. Supports dealer billing reconciliation and revenue recognition.' .

ind:ArPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ar Payment' ;
    rdfs:comment 'Accounts Receivable incoming payment record capturing payments received from dealers, fleet accounts, and intercompany entities against AR invoices. Captures payment date, customer/dealer ID, payment method, amount received, currency, cleared invoice references, bank account, remittance advice reference, partial payment indicator, and cash application status. Supports dealer receivables management, DSO (Days Sales Outstanding) tracking, and cash flow forecasting.' .

ind:CapexRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Capex Request' ;
    rdfs:comment 'Capital Expenditure (CapEx) appropriation request record capturing investment proposals for manufacturing equipment, tooling, plant infrastructure, EV battery production lines, and R&D facilities. Captures project title, requesting plant/department, investment category (tooling, machinery, IT, facility, EV/autonomous R&D), estimated total cost, approved budget, actual spend to date, project start/end dates, approval workflow status, NPV/IRR justification, and WBS element linkage. Supports CapEx governance and FY budget planning.' .

ind:BudgetPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Budget Plan' ;
    rdfs:comment 'Annual and multi-year financial budget plan record capturing planned financial targets by cost center, profit center, GL account, and fiscal year. Supports FY budget planning, rolling forecast cycles, and variance analysis. Captures budget version (original, revised, forecast), budget type (opex, capex, headcount), planning period, planned amount, currency, approval status, and responsible controller. Aligned with SAP CO planning and SAP BPC (Business Planning and Consolidation) processes.' .

ind:FixedAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Fixed Asset' ;
    rdfs:comment 'Fixed asset master record for all capitalized assets including manufacturing machinery, production tooling, dies, stamping presses, paint shop equipment, EV battery assembly lines, plant buildings, and IT infrastructure. Aligned with SAP FI-AA (Asset Accounting). Captures asset class, asset description, acquisition date, acquisition cost, useful life, depreciation method (straight-line, declining balance), accumulated depreciation, net book value, plant assignment, cost center, and retirement date. Supports CapEx tracking and IFRS/GAAP asset disclosure.' .

ind:CurrencyRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Currency Rate' ;
    rdfs:comment 'Foreign exchange (FX) currency rate reference record capturing daily, monthly average, and period-end exchange rates used for multi-currency financial reporting and transaction conversion. Captures currency pair (from/to), rate type (spot, average, period-end, planning), valid date, exchange rate, rate source (ECB, Bloomberg, internal treasury), and company code applicability. Supports IFRS translation of foreign subsidiary financials, transaction currency conversion, and FX exposure reporting.' .

ind:WbsElement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'Work Breakdown Structure (WBS) element master record used for project-based cost tracking including CapEx projects, new model launch programs (SOP/EOP), EV/autonomous R&D programs, and plant expansion projects. Aligned with SAP PS (Project System). Captures WBS code, project definition, WBS level, responsible cost center, planned cost, actual cost, committed cost, project status, start/end dates, and investment program linkage. Enables granular CapEx spend tracking and R&D capitalization under IFRS IAS 38.' .

ind:LoadPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Load Plan' ;
    rdfs:comment 'Load planning record defining how finished vehicles are grouped and assigned to transport units (truck trailers, rail autoracks, RoRo vessel decks) for a given shipment or transport order. Captures load plan number, transport unit type, vehicle count, VIN assignments, weight/dimension constraints, loading sequence, special handling requirements (e.g., EV battery transport restrictions), and plan status. Supports transport utilization optimization and loading dock scheduling.' .

ind:CommodityGroup rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Commodity Group' ;
    rdfs:comment 'Master reference table for commodity_group. ' .

ind:Ownership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vehicle ;
    rdfs:label 'Ownership' ;
    rdfs:comment 'This association product represents the ownership relationship between a vehicle (vin_registry) and a party (customer). It captures acquisition and disposition dates, ownership type, and ownership number, tracking the history of which parties own which vehicles.. Existence Justification: A vehicle can be owned by multiple parties over its lifecycle (e.g., resale), and a party can own multiple vehicles simultaneously. The business actively records each ownership event with dates, type, and ownership number, and users query ownership history for warranty, service, recall, and resale analytics.' .

ind:PaymentPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment Plan' ;
    rdfs:comment 'Master reference table for payment_plan. Referenced by payment_plan_id.' .

ind:Project rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Project' ;
    rdfs:comment 'Master reference table for project. Referenced by related_project_id.' .

ind:Route rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Route' ;
    rdfs:comment 'Master reference table for route. Referenced by route_id.' .

ind:Routing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Routing' ;
    rdfs:comment 'Master reference table for routing. Referenced by routing_id.' .

ind:Characteristic rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Characteristic' ;
    rdfs:comment 'Master reference table for characteristic. Referenced by characteristic_id.' .

ind:TrimOptionAvailability rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vehicle ;
    rdfs:label 'Trim Option Availability' ;
    rdfs:comment 'This association product represents the catalog-level compatibility matrix between vehicle option packages and trim levels. It captures which option packages are orderable with which trim levels, whether they are standard or optional equipment, pricing uplifts, and effective date ranges. Each record defines one orderable combination used in dealer order configuration, window sticker generation, and MSRP calculation. This is distinct from vehicle_configuration (which represents a specific built vehicle) — this product represents the orderable catalog space managed by product planning.. Existence Justification: In automotive manufacturing, OEMs maintain an explicit catalog-level compatibility matrix defining which option packages can be ordered with which trim levels. A single option package (e.g., \'Technology Package\') is orderable across multiple trim levels (Base, XLT, Lariat) with different pricing and standard/optional status per trim. Conversely, each trim level has dozens to hundreds of available option packages. This matrix is actively managed by product planning teams and drives dealer order configuration, window sticker generation, and MSRP calculation.' .

ind:TsbPartRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Aftersales ;
    rdfs:label 'Tsb Part Requirement' ;
    rdfs:comment 'This association product represents the parts bill-of-materials specified in a Technical Service Bulletin. Each record links one TSB to one service part with attributes that define the part\'s role, quantity, and revision requirements for executing the repair procedure described in the bulletin. This is actively managed by OEM parts engineering and used by dealer parts departments for inventory pre-positioning.. Existence Justification: In automotive aftersales operations, Technical Service Bulletins specify a bill-of-materials (parts list) required to execute the repair procedure, and service parts are referenced across multiple TSBs as they apply to different symptoms, model years, or VIN ranges. OEM parts engineering actively manages this relationship as \'TSB Part Requirements\' or \'Repair Kit Definitions\' to enable dealer parts departments to pre-position inventory. The current model\'s denormalized STRING fields (tsb.required_parts, tsb.part_revision) are clear evidence that this M:N relationship has been collapsed into a single record and should be normalized.' .

ind:RoutingOperation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Routing Operation' ;
    rdfs:comment 'This association product represents the operational step between routing and work_center. It captures the assignment of a specific work center to a specific operation within a manufacturing routing. Each record links one routing to one work_center with operation-specific parameters that exist only in the context of this routing-work center assignment, such as operation sequence, cycle times, and setup requirements.. Existence Justification: In automotive manufacturing, a routing defines the complete manufacturing process for a product family, consisting of multiple sequential operations, each performed at a specific work center. One routing contains many operations across different work centers (e.g., stamping → welding → painting → assembly), and one work center participates in many different routings (e.g., a robotic welding station is used in SUV routing, truck routing, and sedan routing). The routing_operation is a standard business entity in SAP PP and MES systems, representing the assignment of a work center to a specific step in a routing with operation-specific parameters.' .

ind:TestRequirementCompliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Engineering ;
    rdfs:label 'Test Requirement Compliance' ;
    rdfs:comment 'This association product represents the compliance evidence mapping between validation tests and homologation requirements in the type-approval process. It captures the formal traceability required by regulatory authorities (TÜV, NHTSA, JAMA) documenting which test results satisfy which regulatory requirements. Each record links one validation test execution to one homologation requirement with compliance status, submission tracking, and regulatory approval metadata that exist only in the context of this compliance relationship.. Existence Justification: In automotive homologation, validation tests and regulatory requirements have a genuine many-to-many operational relationship. A single validation test (e.g., a crash test) can provide compliance evidence for multiple regulatory requirements across different markets (FMVSS 208, Euro NCAP frontal impact, China C-NCAP). Conversely, a single regulatory requirement (e.g., CO2 emissions limit) must be satisfied by multiple test protocols (WLTP, EPA FTP-75, CARB LEV III). Type approval authorities require explicit documentation of these mappings with submission tracking and approval status.' .

# --- Attribute Properties ---
ind:plantId rdf:type rdf:Property ;
    rdfs:label 'Plant Id' ;
    rdfs:comment 'Unique surrogate identifier for each manufacturing plant or assembly facility. Primary key for the plant master record, referenced across MES, SAP PP, and logistics domains.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:companyCodeId rdf:type rdf:Property ;
    rdfs:label 'Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: Each manufacturing plant operates under a legal entity (company code) for statutory financial reporting, intercompany transactions, and SAP FI/CO integration. Automotive OEMs always map plant-to-compa' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:jurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to compliance.jurisdiction. Business justification: Plant regulatory reporting requires knowing the jurisdiction (country/region) governing emissions and safety permits.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address of the plant facility. Used for logistics, regulatory filings, and official correspondence. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line for the plant facility (e.g., building number, gate, or suite). Supplements address_line1 for complete facility location identification.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agvEnabled rdf:type rdf:Property ;
    rdfs:label 'Agv Enabled' ;
    rdfs:comment 'Indicates whether the plant is equipped with Automated Guided Vehicle (AGV) systems for material transport on the shop floor. Used for automation capability classification and MES integration configuration.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:annualCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Annual Capacity Units' ;
    rdfs:comment 'Maximum number of vehicles or assemblies the plant is designed to produce per year under normal two-shift operations. Used for capacity planning, CapEx justification, and production scheduling in SAP PP.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality where the plant is physically located. Used for logistics planning, workforce commute analysis, and regulatory jurisdiction determination.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'The date on which the plant was officially commissioned and handed over for production operations. Distinct from SOP date; represents the physical readiness milestone. Used for asset lifecycle management and depreciation calculations in SAP AM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'SAP Controlling (CO) cost center code assigned to the plant for financial cost allocation, CapEx tracking, and R&D expenditure reporting. Used in management accounting and EBITDA analysis.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code indicating the country where the plant is physically located (e.g., \'USA\', \'DEU\', \'CHN\'). Used for regulatory compliance, CAFE reporting, and logistics routing.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the plant master record was first created in the system. Used for data lineage, audit trail, and record lifecycle management in the Databricks Silver Layer.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the local currency used in plant-level financial reporting and cost accounting (e.g., \'USD\', \'EUR\', \'CNY\'). Used in SAP FI/CO for cost center reporting and CapEx tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Daily Capacity Units' ;
    rdfs:comment 'Maximum number of vehicles or assemblies the plant can produce per day (Jobs Per Day - JPD). Derived from takt time and shift configuration. Used for daily production scheduling and MES throughput planning.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eopDate rdf:type rdf:Property ;
    rdfs:label 'Eop Date' ;
    rdfs:comment 'The official End of Production (EOP) date when the plant is scheduled to cease production of the current model or permanently close. Used for capacity planning, workforce transition, and asset disposal planning.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:epaFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Epa Facility Code' ;
    rdfs:comment 'EPA-assigned facility identifier for emissions and environmental compliance reporting. Required for CAFE (Corporate Average Fuel Economy) reporting and Clean Air Act compliance.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Floor Area Sqm' ;
    rdfs:comment 'Total manufacturing floor area of the plant in square meters. Used for facility planning, CapEx allocation, insurance valuation, and ISO 14001 environmental footprint reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iatf16949Certified rdf:type rdf:Property ;
    rdfs:label 'Iatf 16949 Certified' ;
    rdfs:comment 'Indicates whether the plant holds a current IATF 16949 automotive quality management system certification. Mandatory for OEM supplier qualification and customer-specific requirements compliance.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified' ;
    rdfs:comment 'Indicates whether the plant holds a current ISO 14001 Environmental Management System certification. Required for EPA compliance reporting and sustainability disclosures.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified' ;
    rdfs:comment 'Indicates whether the plant holds a current ISO 9001 Quality Management System certification. Required for supplier qualification and regulatory compliance reporting.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the plant in decimal degrees (WGS 84). Used for geospatial analytics, logistics network optimization, and supply chain mapping.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the plant in decimal degrees (WGS 84). Used for geospatial analytics, logistics network optimization, and supply chain mapping.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manager rdf:type rdf:Property ;
    rdfs:label 'Manager' ;
    rdfs:comment 'Full name of the plant manager or general manager responsible for overall plant operations. Used for escalation routing, regulatory correspondence, and organizational reporting. Not classified as PII as this is a business role reference.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesPlantCode rdf:type rdf:Property ;
    rdfs:label 'Mes Plant Code' ;
    rdfs:comment 'The plant identifier as registered in the Apriso/Dassault MES system. Used for cross-system reconciliation between SAP PP production orders and MES shop floor execution records. Enables traceability from ERP to shop floor.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelYearCurrent rdf:type rdf:Property ;
    rdfs:label 'Model Year Current' ;
    rdfs:comment 'The current Model Year (MY) of vehicles being produced at the plant (e.g., \'2025\'). Used for production scheduling, regulatory compliance submissions, and CAFE reporting alignment.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nhtsaFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Nhtsa Facility Code' ;
    rdfs:comment 'NHTSA-assigned facility identifier for the plant. Required for vehicle recall management, safety defect reporting, and Federal Motor Vehicle Safety Standards (FMVSS) compliance submissions.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfAssemblyLines rdf:type rdf:Property ;
    rdfs:label 'Number Of Assembly Lines' ;
    rdfs:comment 'Total count of active production or assembly lines within the plant. Used for capacity planning, MES line configuration, and production scheduling.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfShifts rdf:type rdf:Property ;
    rdfs:label 'Number Of Shifts' ;
    rdfs:comment 'Number of production shifts operated per day at the plant (typically 1, 2, or 3). Drives capacity calculations, workforce planning in SuccessFactors, and MES scheduling.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current lifecycle state of the plant. \'active\' indicates full production; \'idle\' indicates temporary suspension; \'ramp_up\' indicates pre-SOP commissioning phase; \'ramp_down\' indicates post-EOP wind-down; \'shutdown\' indicates planned or unplanned stoppage; \'decommissioned\' indicates permanently closed.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otaCapable rdf:type rdf:Property ;
    rdfs:label 'Ota Capable' ;
    rdfs:comment 'Indicates whether the plant has the infrastructure to perform OTA (Over-the-Air) software updates on vehicles during the final assembly or PDI (Pre-Delivery Inspection) process. Relevant for connected vehicle production.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary telephone number for the plant facility. Used for operational communications, emergency contact, and supplier/logistics coordination. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the plant within SAP S/4HANA and MES systems (e.g., \'DETF01\', \'USNA02\'). Used as the business key across ERP, MES, and logistics integrations. Maps to SAP Organizational Unit - Plant Code.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantName rdf:type rdf:Property ;
    rdfs:label 'Plant Name' ;
    rdfs:comment 'Official full name of the manufacturing plant or assembly facility (e.g., \'Detroit Final Assembly Plant No. 1\'). Used in reporting, regulatory submissions, and communications.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantType rdf:type rdf:Property ;
    rdfs:label 'Plant Type' ;
    rdfs:comment 'Categorical classification of the plant\'s primary manufacturing function. Values include stamping (metal forming), body_shop (body-in-white welding), paint (paint application), final_assembly (vehicle assembly), ckd (Completely Knocked Down assembly), skd (Semi Knocked Down assembly), powertrain (engine/transmission), logistics (parts distribution). [ENUM-REF-CANDIDATE: stamping|body_shop|paint|final_assembly|ckd|skd|powertrain|logistics — promote to reference product]' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the plant location. Used for logistics routing, tax jurisdiction assignment, and regulatory reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powertrainTypesProduced rdf:type rdf:Property ;
    rdfs:label 'Powertrain Types Produced' ;
    rdfs:comment 'Classification of powertrain technologies assembled or manufactured at this plant. ICE (Internal Combustion Engine), EV (Electric Vehicle), HEV (Hybrid Electric Vehicle), PHEV (Plug-in Hybrid Electric Vehicle), FCEV (Fuel Cell Electric Vehicle), or mixed. Used for EPA emissions compliance, CAFE reporting, and R&D investment tracking.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryVehicleSegment rdf:type rdf:Property ;
    rdfs:label 'Primary Vehicle Segment' ;
    rdfs:comment 'The primary vehicle segment produced at this plant. Values: car (passenger cars), truck (light/heavy trucks), suv (Sport Utility Vehicles), commercial_vehicle (vans/buses/heavy commercial), ev (Battery Electric Vehicle), hev (Hybrid Electric Vehicle - HEV), phev (Plug-in Hybrid Electric Vehicle - PHEV), mixed (multiple segments). Drives model year planning and regulatory compliance requirements. [ENUM-REF-CANDIDATE: car|truck|suv|commercial_vehicle|ev|hev|phev|mixed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Geographic or operational region in which the plant is located (e.g., \'North America\', \'Europe\', \'Asia Pacific\'). Used for regional production planning, capacity allocation, and management reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaEnabled rdf:type rdf:Property ;
    rdfs:label 'Scada Enabled' ;
    rdfs:comment 'Indicates whether the plant operates a SCADA (Supervisory Control and Data Acquisition) system for real-time monitoring and control of manufacturing processes, utilities, and equipment.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated or commonly used name for the plant used in dashboards, shop floor displays, and internal communications (e.g., \'Detroit FA1\').' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopDate rdf:type rdf:Property ;
    rdfs:label 'Sop Date' ;
    rdfs:comment 'The official Start of Production (SOP) date when the plant commenced or is scheduled to commence volume production. Critical milestone for capital planning, workforce ramp-up, and supplier readiness. Aligns with APQP phase-gate milestones.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative subdivision where the plant is located (e.g., \'Michigan\', \'Bavaria\', \'Ontario\'). Used for local regulatory compliance, tax jurisdiction, and workforce reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taktTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Takt Time Seconds' ;
    rdfs:comment 'The rate at which vehicles must be produced to meet customer demand, expressed in seconds per unit. Calculated as available production time divided by customer demand rate. Fundamental to JIS (Just-in-Sequence) scheduling and line balancing in MES.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the plant location (e.g., \'America/Detroit\', \'Europe/Berlin\'). Used for MES shift scheduling, production timestamp normalization, and cross-plant reporting in the Databricks lakehouse.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionRepresented rdf:type rdf:Property ;
    rdfs:label 'Union Represented' ;
    rdfs:comment 'Indicates whether the plant workforce is represented by a labor union. Impacts workforce planning, shift scheduling, overtime policies, and collective bargaining agreement compliance in SuccessFactors.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp when the plant master record was last modified. Used for change tracking, data synchronization between SAP S/4HANA and the Databricks lakehouse, and audit compliance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workforceHeadcount rdf:type rdf:Property ;
    rdfs:label 'Workforce Headcount' ;
    rdfs:comment 'Total number of employees (direct and indirect labor) currently employed at the plant. Used for workforce planning, capacity analysis, and regulatory headcount reporting in SuccessFactors.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionLineId rdf:type rdf:Property ;
    rdfs:label 'Production Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each production line record within the manufacturing data platform. Serves as the primary key for the production_line entity. Role: MASTER_RESOURCE.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionLine .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Line-level cost allocation report requires linking each production line to its finance cost center; experts expect a cost_center_id instead of the denormalized code.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:sapWorkCenterId rdf:type rdf:Property ;
    rdfs:label 'Sap Work Center Id' ;
    rdfs:comment 'The SAP S/4HANA PP (Production Planning) work center identifier corresponding to this production line. Enables direct linkage between the lakehouse production_line master and SAP production orders, capacity planning, and cost center assignments in SAP CO (Controlling).' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:vehicleProgramId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Program Id' ;
    rdfs:comment 'Foreign key linking to engineering.vehicle_program. Business justification: Line scheduling and line-to-program assignment use vehicle_program_id to match line capabilities with program requirements.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleProgram .

ind:wbsElementId rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Id' ;
    rdfs:comment 'Foreign key linking to finance.wbs_element. Business justification: Production line installation, retooling, and capacity expansion projects are tracked against WBS elements for CAPEX project controlling. Automotive OEMs create WBS elements for each line retooling or ' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:agvIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Agv Integration Enabled' ;
    rdfs:comment 'Indicates whether this production line is integrated with an AGV (Automated Guided Vehicle) system for automated material delivery, WIP (Work in Progress) transport, or carrier movement. True = AGV-integrated; False = manual or conventional conveyor-based material handling. Used for automation investment tracking and MES configuration.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Classification of the overall automation level of the production line: manual (predominantly human-operated), semi_automated (mix of manual and robotic operations), highly_automated (majority robotic with human oversight), or fully_automated (lights-out or near-lights-out operation). Used for workforce planning, CapEx investment analysis, and Industry 4.0 maturity assessments.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ckdSkdCapable rdf:type rdf:Property ;
    rdfs:label 'Ckd Skd Capable' ;
    rdfs:comment 'Indicates the assembly kit type this line is configured to process: CKD (Completely Knocked Down — full kit assembly from parts), SKD (Semi Knocked Down — partial pre-assembly), CBU (Completely Built Up — no kit assembly, line-off only), or multi (capable of multiple kit types). Relevant for export assembly plants and regulatory homologation.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conveyorType rdf:type rdf:Property ;
    rdfs:label 'Conveyor Type' ;
    rdfs:comment 'Type of conveyor or carrier system used to move vehicles or assemblies along this production line: overhead_conveyor (hanging carrier), floor_conveyor (ground-level chain/belt), skillet (moving platform for final assembly), agv_carrier (autonomous guided vehicle carrier), stationary (fixed-position assembly), or mixed (combination of types).' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentJph rdf:type rdf:Property ;
    rdfs:label 'Current Jph' ;
    rdfs:comment 'The current actual or most recently measured throughput rate of the production line in Jobs Per Hour (JPH), reflecting real-world performance after accounting for constraints, model mix, and current configuration. Used to compare against designed_jph for capacity gap analysis and production scheduling.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designedJph rdf:type rdf:Property ;
    rdfs:label 'Designed Jph' ;
    rdfs:comment 'The engineered design throughput capacity of the production line expressed in Jobs Per Hour (JPH) — the number of vehicle units or assemblies the line is designed to produce per hour under optimal conditions. This is the nameplate capacity used for capacity planning, takt time calculation, and OEE baseline. Maps to MEASUREMENT_OR_VALUE category for MASTER_RESOURCE role.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyConsumptionKwhPerUnit rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh Per Unit' ;
    rdfs:comment 'Average energy consumption of this production line in kilowatt-hours (kWh) per vehicle unit produced. Used for ISO 14001 environmental management reporting, carbon footprint calculation, energy efficiency benchmarking, and EPA/CARB manufacturing emissions compliance.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floorSpaceSqm rdf:type rdf:Property ;
    rdfs:label 'Floor Space Sqm' ;
    rdfs:comment 'Total floor space occupied by this production line in square meters, including the line footprint, buffer zones, and material staging areas. Used for facility capacity planning, real estate cost allocation, and plant layout optimization.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iatfAuditStatus rdf:type rdf:Property ;
    rdfs:label 'Iatf Audit Status' ;
    rdfs:comment 'Current IATF 16949 (International Automotive Task Force) quality management system audit status for this production line: compliant (no non-conformances), minor_nc (minor non-conformance identified), major_nc (major non-conformance — corrective action required), suspended (production suspended pending corrective action), or not_audited (not yet subject to IATF audit).' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jisEnabled rdf:type rdf:Property ;
    rdfs:label 'Jis Enabled' ;
    rdfs:comment 'Indicates whether this production line operates under JIS (Just-in-Sequence) material delivery sequencing, where parts are delivered to the line in the exact sequence of vehicle build order. True = JIS-enabled; False = standard JIT or batch delivery. Critical for supply chain integration and sequencing system configuration.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastIatfAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Iatf Audit Date' ;
    rdfs:comment 'Date of the most recent IATF 16949 quality management system audit conducted on this production line. Used for audit cycle management, corrective action tracking, and regulatory compliance reporting to OEM customers and certification bodies.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent planned preventive maintenance activity performed on this production line. Used for maintenance scheduling in SAP PM (Plant Maintenance), OEE (Overall Equipment Effectiveness) calculation, and IATF 16949 preventive maintenance compliance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineCode rdf:type rdf:Property ;
    rdfs:label 'Line Code' ;
    rdfs:comment 'Externally-known alphanumeric code that uniquely identifies the production line within the plant and across the enterprise (e.g., FA-01, BS-03, PT-02). Used as the business key in MES, SAP PP, and Apriso/Dassault shop-floor execution systems. Maps to BUSINESS_IDENTIFIER category for MASTER_RESOURCE role.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineLengthMeters rdf:type rdf:Property ;
    rdfs:label 'Line Length Meters' ;
    rdfs:comment 'Physical length of the production line in meters, measured from the first to the last station. Used for facility layout planning, AGV (Automated Guided Vehicle) path configuration, and ergonomic compliance assessments per plant engineering standards.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineName rdf:type rdf:Property ;
    rdfs:label 'Line Name' ;
    rdfs:comment 'Human-readable descriptive name of the production line (e.g., \'Final Assembly Line 1 – Truck Platform\', \'Body Shop Framing Line – SUV\'). Used in reporting dashboards, capacity planning, and operator interfaces. Maps to IDENTITY_LABEL category for MASTER_RESOURCE role.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current operational lifecycle status of the production line: active (running production), idle (scheduled downtime or no orders), maintenance (planned or unplanned maintenance), ramp_up (pre-SOP commissioning), ramp_down (approaching EOP), or decommissioned (permanently retired). Maps to LIFECYCLE_STATUS category for MASTER_RESOURCE role.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Categorical classification of the production line by manufacturing process area: stamping (metal forming), body_shop (welding/framing), paint (surface treatment), final_assembly (vehicle build), powertrain (engine/transmission), chassis (underbody), or trim (interior/exterior finishing). Maps to CLASSIFICATION_OR_TYPE category for MASTER_RESOURCE role. [ENUM-REF-CANDIDATE: stamping|body_shop|paint|final_assembly|powertrain|chassis|trim|subassembly|battery_pack|quality_gate — promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxVehicleWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Vehicle Weight Kg' ;
    rdfs:comment 'Maximum gross vehicle weight in kilograms that this production line\'s conveyor, tooling, and fixtures are rated to handle. Constrains which vehicle programs can be assigned to this line and is critical for structural safety compliance and tooling certification.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesLineCode rdf:type rdf:Property ;
    rdfs:label 'Mes Line Code' ;
    rdfs:comment 'The line identifier as registered in the Apriso/Dassault MES (Manufacturing Execution System) for shop floor execution, work order dispatch, and build traceability. Used for cross-system reconciliation between the lakehouse silver layer and the operational MES source system.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mixedModelCapable rdf:type rdf:Property ;
    rdfs:label 'Mixed Model Capable' ;
    rdfs:comment 'Indicates whether this production line is capable of producing multiple vehicle models or variants in a mixed sequence on the same line (mixed-model assembly). True = mixed-model capable; False = dedicated single-model line. Drives production scheduling complexity and sequencing logic in MES.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modelYearCapability rdf:type rdf:Property ;
    rdfs:label 'Model Year Capability' ;
    rdfs:comment 'The model year (MY) or range of model years that this production line is currently tooled and certified to produce (e.g., \'2024\' or \'2024-2026\'). Drives SOP (Start of Production) and EOP (End of Production) planning, tooling investment decisions, and homologation scheduling.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:comment 'Date of the next planned preventive maintenance activity scheduled for this production line. Drives maintenance work order creation in SAP PM, production scheduling adjustments, and downtime planning to minimize impact on JPH targets.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfStations rdf:type rdf:Property ;
    rdfs:label 'Number Of Stations' ;
    rdfs:comment 'Total count of individual work stations or assembly stations on this production line. Used for line balancing analysis, ergonomic assessments, and determining the number of operators required per shift. Key input for APQP (Advanced Product Quality Planning) and control plan development.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paintBoothType rdf:type rdf:Property ;
    rdfs:label 'Paint Booth Type' ;
    rdfs:comment 'Type of paint application system used on this line (applicable to paint shop lines): waterborne (water-based paint — lower VOC emissions), solventborne (solvent-based paint), powder_coat (electrostatic powder coating), or none (non-paint line). Drives EPA/CARB VOC (Volatile Organic Compound) emissions compliance reporting and environmental permit management.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plcSystemReference rdf:type rdf:Property ;
    rdfs:label 'Plc System Reference' ;
    rdfs:comment 'Identifier or name of the PLC (Programmable Logic Controller) system or network controlling this production line\'s automated equipment (e.g., \'Siemens S7-1500 Network A\', \'Allen-Bradley ControlLogix Zone 3\'). Used for maintenance management in SAP PM, SCADA integration, and cybersecurity asset inventory.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powertrainTypeCapability rdf:type rdf:Property ;
    rdfs:label 'Powertrain Type Capability' ;
    rdfs:comment 'The powertrain technology types this production line is capable of assembling: ICE (Internal Combustion Engine), HEV (Hybrid Electric Vehicle), PHEV (Plug-in Hybrid Electric Vehicle), BEV (Battery Electric Vehicle), FCEV (Fuel Cell Electric Vehicle), or multi (flexible line supporting multiple powertrain types). Critical for EV transition capacity planning and regulatory compliance with EPA/CARB emissions standards.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityGateCount rdf:type rdf:Property ;
    rdfs:label 'Quality Gate Count' ;
    rdfs:comment 'Number of quality inspection gates or checkpoints integrated into this production line (e.g., in-process inspection stations, end-of-line audit points). Used for quality planning per APQP (Advanced Product Quality Planning), control plan documentation, and IATF 16949 compliance audits.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:robotCount rdf:type rdf:Property ;
    rdfs:label 'Robot Count' ;
    rdfs:comment 'Total number of industrial robots (welding, painting, assembly, material handling) deployed on this production line. Used for maintenance planning in SAP PM, automation investment tracking, and Industry 4.0 KPI reporting.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Expiry Date' ;
    rdfs:comment 'Expiry date of the production line\'s current safety certification. Used to trigger renewal workflows, prevent operation of uncertified lines, and support regulatory audit readiness for OSHA, DOT, and IATF 16949 compliance.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Status' ;
    rdfs:comment 'Current status of the production line\'s safety certification and compliance with applicable occupational safety standards (e.g., OSHA, CE Machinery Directive, ISO 13849): certified (valid and current), expired (certification lapsed), pending_renewal (renewal in progress), or not_required (exempt from certification requirement).' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaSystemReference rdf:type rdf:Property ;
    rdfs:label 'Scada System Reference' ;
    rdfs:comment 'Identifier or name of the SCADA (Supervisory Control and Data Acquisition) system monitoring and controlling this production line (e.g., \'Ignition SCADA Plant2-Zone1\', \'Wonderware InTouch Line FA-01\'). Used for real-time production monitoring, alarm management, and integration with MES and ERP systems.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftConfiguration rdf:type rdf:Property ;
    rdfs:label 'Shift Configuration' ;
    rdfs:comment 'Current shift schedule configuration for the production line, indicating the number of operating shifts per day: 1_shift (single day shift), 2_shift (day and afternoon), 3_shift (continuous 24-hour), or 4_shift_rotating (rotating continental schedule). Drives capacity planning, workforce scheduling in SuccessFactors, and MRP calculations in SAP PP.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this production line master record was sourced: SAP_PP (SAP S/4HANA Production Planning), Apriso_MES (Apriso/Dassault Manufacturing Execution System), Teamcenter (Siemens Teamcenter PLM), Manual (manually entered), or SCADA (derived from SCADA system configuration). Used for data lineage and reconciliation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehiclePlatformCode rdf:type rdf:Property ;
    rdfs:label 'Vehicle Platform Code' ;
    rdfs:comment 'The vehicle platform or architecture code that this production line is primarily configured to build (e.g., \'F-150 Gen14\', \'GMT800\', \'MEB\'). A single line may support multiple model variants on the same platform. Used for PLM integration with Siemens Teamcenter and production scheduling.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weldGunCount rdf:type rdf:Property ;
    rdfs:label 'Weld Gun Count' ;
    rdfs:comment 'Total number of resistance spot weld guns (robotic and manual) deployed on this production line. Applicable primarily to body shop lines. Used for weld quality management per IATF 16949, preventive maintenance scheduling in SAP PM, and SPC (Statistical Process Control) monitoring of weld quality.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workCenterId rdf:type rdf:Property ;
    rdfs:label 'Work Center Id' ;
    rdfs:comment 'Unique surrogate identifier for the work center (station) record within the manufacturing data platform. Primary key for the work_center master entity.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Foreign key linking to finance.fixed_asset. Business justification: Work centers (robots, welding equipment, CNC machines) are capitalized as fixed assets. Linking work_center to fixed_asset enables asset lifecycle management, depreciation cost allocation to productio' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Work centers have associated lineside storage locations where components are staged for JIT consumption. This link enables shop floor logistics planning, AGV routing to work center supply points, and ' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:availableCapacityHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Hours Per Day' ;
    rdfs:comment 'Total available production hours per day for this work center, accounting for planned shift schedules and scheduled breaks. Used in SAP PP capacity requirements planning (CRP) and MES scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityCategory rdf:type rdf:Property ;
    rdfs:label 'Capacity Category' ;
    rdfs:comment 'Capacity classification of the work center: bottleneck (constraining throughput of the line), standard (normal capacity), buffer (excess capacity used to absorb variation), or flexible (can be redeployed across lines). Critical for Theory of Constraints analysis and production scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Seconds' ;
    rdfs:comment 'Standard cycle time in seconds for this work center to complete one unit of work. Used in production scheduling, capacity calculation, and bottleneck analysis. Represents the designed throughput rate per station.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date on which this work center was or is planned to be permanently decommissioned and removed from production service. Nullable for active stations. Used for asset lifecycle planning and capacity forecasting.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:energyConsumptionKw rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kw' ;
    rdfs:comment 'Rated energy consumption of this work center in kilowatts (kW) under standard operating conditions. Used for energy management, sustainability reporting, and ISO 14001 environmental compliance tracking.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBottleneck rdf:type rdf:Property ;
    rdfs:label 'Is Bottleneck' ;
    rdfs:comment 'Indicates whether this work center has been identified as a production bottleneck constraining overall line throughput. Bottleneck stations receive priority in capacity planning, maintenance scheduling, and continuous improvement initiatives.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isJisEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Jis Enabled' ;
    rdfs:comment 'Indicates whether this work center participates in JIS (Just-in-Sequence) production sequencing. When true, the MES enforces strict vehicle sequence delivery to this station to support mixed-model assembly.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQualityGate rdf:type rdf:Property ;
    rdfs:label 'Is Quality Gate' ;
    rdfs:comment 'Indicates whether this work center serves as a quality gate (inspection checkpoint) in the production flow. Quality gate stations require SPC (Statistical Process Control) data capture and may hold WIP pending quality approval.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborRatePerHour rdf:type rdf:Property ;
    rdfs:label 'Labor Rate Per Hour' ;
    rdfs:comment 'Standard direct labor cost rate per hour (in local currency) for this work center. Used in production order costing, standard cost roll-up, and labor efficiency variance reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date of the most recent calibration or measurement system verification performed on this work center\'s tooling and gauges. Required for IATF 16949 Clause 7.1.5 measurement system compliance.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this work center master record. Used for change tracking, data freshness monitoring, and incremental ETL processing in the Databricks lakehouse.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Textual description of the physical location of the work center within the plant (e.g., \'Building A, Bay 3, Row 5\'). Supports maintenance routing, safety inspections, and shop floor navigation.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:machineRatePerHour rdf:type rdf:Property ;
    rdfs:label 'Machine Rate Per Hour' ;
    rdfs:comment 'Standard machine cost rate per hour (in local currency) for this work center, used in production order costing, standard cost calculation, and variance analysis in SAP CO.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceStrategyCode rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy Code' ;
    rdfs:comment 'Maintenance strategy applied to this work center: preventive (scheduled interval-based), predictive (condition-monitoring-based), corrective (repair after failure), or condition_based (triggered by sensor thresholds). Drives SAP PM maintenance planning.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanTimeBetweenFailuresHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Failures Hours' ;
    rdfs:comment 'Standard mean time between failures (MTBF) in hours for this work center, representing the expected average operational time between unplanned breakdowns. Used in reliability analysis, maintenance planning, and OEE (Overall Equipment Effectiveness) benchmarking.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanTimeToRepairHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Repair Hours' ;
    rdfs:comment 'Standard mean time to repair (MTTR) in hours for this work center, representing the average time required to restore the station to operational status after a failure. Used in maintenance planning and availability calculations.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesWorkCenterCode rdf:type rdf:Property ;
    rdfs:label 'Mes Work Center Code' ;
    rdfs:comment 'Native work center identifier in the Apriso/Dassault MES system. Used for cross-system traceability between the lakehouse silver layer and the operational MES for shop floor execution and WIP (Work in Progress) tracking.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due Date' ;
    rdfs:comment 'Scheduled date for the next calibration or measurement system verification at this work center. Triggers maintenance work orders in SAP PM and quality alerts in the MES when approaching or overdue.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfWorkers rdf:type rdf:Property ;
    rdfs:label 'Number Of Workers' ;
    rdfs:comment 'Standard number of direct labor workers assigned to this work center per shift. Used for workforce planning, labor cost allocation, and ergonomic assessment.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overheadRatePercent rdf:type rdf:Property ;
    rdfs:label 'Overhead Rate Percent' ;
    rdfs:comment 'Manufacturing overhead absorption rate as a percentage applied to this work center\'s direct costs for product costing and standard cost calculation in SAP CO.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plcNodeCode rdf:type rdf:Property ;
    rdfs:label 'Plc Node Code' ;
    rdfs:comment 'Identifier of the PLC (Programmable Logic Controller) node associated with this work center in the shop floor control network. Used for real-time production control integration and SCADA data correlation.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processCategory rdf:type rdf:Property ;
    rdfs:label 'Process Category' ;
    rdfs:comment 'Manufacturing process category to which this work center belongs, reflecting the major shop segment (e.g., stamping, body shop, paint, final assembly, powertrain). Used for shop floor segmentation, capacity analysis, and APQP (Advanced Product Quality Planning) alignment. [ENUM-REF-CANDIDATE: stamping|body_shop|paint|final_assembly|powertrain|chassis|trim|quality_inspection|logistics — promote to reference product]' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLineCode rdf:type rdf:Property ;
    rdfs:label 'Production Line Code' ;
    rdfs:comment 'Code identifying the production line (e.g., stamping, body shop, paint, final assembly) to which this work center belongs. Supports JIS (Just-in-Sequence) scheduling and MES line-level reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapWorkCenterCode rdf:type rdf:Property ;
    rdfs:label 'Sap Work Center Code' ;
    rdfs:comment 'Native work center identifier in SAP S/4HANA PP module. Used for cross-system reconciliation between the lakehouse and SAP for production order routing, capacity planning, and cost center allocation.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaNodeCode rdf:type rdf:Property ;
    rdfs:label 'Scada Node Code' ;
    rdfs:comment 'Identifier of the SCADA (Supervisory Control and Data Acquisition) node associated with this work center. Enables real-time monitoring, alarm management, and production data acquisition from the shop floor.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Setup Time Minutes' ;
    rdfs:comment 'Standard setup/changeover time in minutes required to prepare this work center for a new production run or model variant. Used in SAP PP capacity planning and MES work order scheduling.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftModelCode rdf:type rdf:Property ;
    rdfs:label 'Shift Model Code' ;
    rdfs:comment 'Code referencing the shift schedule model assigned to this work center (e.g., 1-shift, 2-shift, 3-shift, weekend shift). Determines available production windows for capacity planning and MES scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardValueKey rdf:type rdf:Property ;
    rdfs:label 'Standard Value Key' ;
    rdfs:comment 'SAP PP standard value key (e.g., SAP1, SAP2) defining which standard values (setup, machine, labor, teardown times) are relevant for this work center in routing operations. Governs how production order times are calculated.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teardownTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Teardown Time Minutes' ;
    rdfs:comment 'Standard teardown/cleanup time in minutes required after completing a production run at this work center. Included in total station time calculations for capacity planning.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Work Center Category' ;
    rdfs:comment 'SAP PP work center category classifying the primary resource type: machine (machine-driven capacity), labor (labor-driven capacity), machine_labor (both machine and labor capacity), or external (subcontracted operation). Determines how capacity and costing are calculated in SAP.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterCode rdf:type rdf:Property ;
    rdfs:label 'Work Center Code' ;
    rdfs:comment 'Externally-known alphanumeric code that uniquely identifies the work center across MES, SAP PP, and SCADA systems. Used as the business key in cross-system integration (e.g., Apriso/Dassault MES work center identifier).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Work Center Description' ;
    rdfs:comment 'Detailed textual description of the work center\'s function, scope of operations, and any special capabilities or constraints relevant to production planning and scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterName rdf:type rdf:Property ;
    rdfs:label 'Work Center Name' ;
    rdfs:comment 'Human-readable name of the work center station (e.g., \'Body Framing Station 04\', \'Final Torque Assembly Line 2\'). Used in shop floor displays, MES dashboards, and production reporting.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Work Center Status' ;
    rdfs:comment 'Current lifecycle status of the work center: active (in production use), inactive (temporarily not in use), under_maintenance (scheduled or unscheduled maintenance), decommissioned (permanently retired), or planned (not yet commissioned). Drives MES scheduling eligibility and capacity planning.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterType rdf:type rdf:Property ;
    rdfs:label 'Work Center Type' ;
    rdfs:comment 'Classification of the work center by its operational mode: manual (human-operated), automated (machine-driven without robotics), robotic (robot arm/AGV-integrated), semi_automated (human-assisted automation), inspection (quality gate), or rework (defect correction station). Drives capacity planning and labor allocation.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionOrderId rdf:type rdf:Property ;
    rdfs:label 'Production Order Id' ;
    rdfs:comment 'Primary key for production_order' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Foreign key linking to billing.account. Business justification: Fleet and direct-customer production orders are tied to a billing account for invoice generation and credit management. Automotive OEM fleet order management requires linking the production order to t' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:configurationId rdf:type rdf:Property ;
    rdfs:label 'Configuration Id' ;
    rdfs:comment 'Reference to the vehicle configuration or variant being built under this production order. Links to the vehicle configuration master (model, trim, powertrain, options) managed in Siemens Teamcenter PLM or SAP Variant Configuration.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Configuration .

ind:customerPartyId rdf:type rdf:Property ;
    rdfs:label 'Customer Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Order-to-customer linkage required for order fulfillment, warranty, and recall reports; manufacturers need to know which party placed each production order.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:fiscalPeriodId rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Id' ;
    rdfs:comment 'Foreign key linking to finance.fiscal_period. Business justification: Production order cost settlement and variance reporting are tied to fiscal periods for period-end closing. Automotive OEMs run monthly production cost variance reports by fiscal period; the fiscal_per' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Production order cost posting uses a specific GL account; the order-to-GL link is required for the Production Order Cost Ledger report.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:homologationRecordId rdf:type rdf:Property ;
    rdfs:label 'Homologation Record Id' ;
    rdfs:comment 'Foreign key linking to compliance.homologation_record. Business justification: Production Order release process checks Homologation_Record to ensure model/year has regulatory approval before manufacturing starts.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HomologationRecord .

ind:productionBomId rdf:type rdf:Property ;
    rdfs:label 'Production Bom Id' ;
    rdfs:comment 'Reference to the Bill of Materials (BOM) version used for this production order. The BOM defines all components and sub-assemblies required to build the target material. Managed in SAP PP and Siemens Teamcenter PLM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionBom .

ind:productionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Production Schedule Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.production_schedule. Business justification: Production orders are released against a master production schedule (MPS). Adding production_schedule_id FK to production_order enables schedule adherence tracking — comparing planned quantities from ' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionSchedule .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Order-level profitability analysis (Order Profitability Statement) needs a profit_center FK to allocate revenue and cost.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:projectId rdf:type rdf:Property ;
    rdfs:label 'Project Id' ;
    rdfs:comment 'Foreign key linking to finance.project. Business justification: New model launch and pilot-series production orders are linked to finance projects for CAPEX tracking and project cost controlling. Automotive OEMs track pre-series and SOP ramp-up production costs ag' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to supply.supply_purchase_order. Business justification: Production scheduling aligns each production order with its originating purchase order to ensure material availability and OTD compliance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:routingId rdf:type rdf:Property ;
    rdfs:label 'Routing Id' ;
    rdfs:comment 'Reference to the production routing (task list / operation sequence) assigned to this order. The routing defines the sequence of manufacturing operations, work centers, and standard times. Maps to SAP PP Routing (PLNNR).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:shiftId rdf:type rdf:Property ;
    rdfs:label 'Shift Id' ;
    rdfs:comment 'Reference to the production shift (e.g., Day, Afternoon, Night) assigned to execute this order. Used for capacity planning, labor allocation, and shift-level production reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shift .

ind:skuMasterId rdf:type rdf:Property ;
    rdfs:label 'Sku Master Id' ;
    rdfs:comment 'Reference to the SAP Material Master (MATNR) representing the finished vehicle, sub-assembly, or component being produced. The primary product/material being manufactured under this order.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuMaster .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'The total actual cost incurred to execute this production order, including material consumption, labor, machine, and overhead costs as settled in SAP CO. Expressed in the plant\'s local currency. Used for cost variance analysis, profitability reporting, and CapEx/OpEx tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualFinishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Timestamp' ;
    rdfs:comment 'The precise date and time when all production activities for this order were completed and the final goods receipt was posted, as recorded by MES or SAP PP. Used for cycle time calculation, OTD (On-Time Delivery) measurement, and throughput analysis.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLaborHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Hours' ;
    rdfs:comment 'The total actual direct labor hours consumed during execution of this production order, as confirmed through SAP PP operation confirmations or MES time tracking. Used for labor efficiency analysis, variance reporting, and cost actuals in SAP CO.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMachineHours rdf:type rdf:Property ;
    rdfs:label 'Actual Machine Hours' ;
    rdfs:comment 'The total actual machine/equipment hours consumed during execution of this production order, as recorded by SCADA (Supervisory Control and Data Acquisition) systems or MES. Used for OEE analysis, machine utilization reporting, and cost variance calculation.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'The precise date and time when production activities for this order actually commenced on the shop floor, as recorded by the MES or confirmed by the first operation confirmation in SAP PP. Used for cycle time analysis and schedule adherence measurement.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assemblySequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Assembly Sequence Number' ;
    rdfs:comment 'The Just-in-Sequence (JIS) sequence number assigned to this production order, defining its position in the assembly line build sequence. Critical for JIS supply chain synchronization — ensures parts arrive at the line in the exact order vehicles are built. Managed by MES and communicated to tier-1 suppliers.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'The quantity of vehicles or sub-assemblies that have been confirmed as successfully produced and goods-receipted against this order. Maps to SAP PP confirmed yield quantity (WEMNG). Used for production performance and yield tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether this production order involves the use or production of hazardous materials (e.g., battery electrolytes for EV/HEV powertrains, paint solvents, chemical treatments). True = hazardous materials involved, requiring compliance with EPA, CARB, and ISO 14001 environmental management protocols.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mesOrderReference rdf:type rdf:Property ;
    rdfs:label 'Mes Order Reference' ;
    rdfs:comment 'Cross-reference identifier assigned by the Apriso/Dassault MES system for this production order. Used to correlate SAP PP orders with shop floor execution records in the MES for traceability and real-time production control.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelYear rdf:type rdf:Property ;
    rdfs:label 'Model Year' ;
    rdfs:comment 'The vehicle model year (MY) associated with the units being produced under this order. Critical for regulatory compliance (CAFE, EPA, NCAP), warranty tracking, and production program management. Typically a 4-digit year (e.g., 2025).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The business date on which the production order was created and issued in SAP PP. This is the principal business event date representing when the manufacturing work order was formally raised. Maps to SAP order creation date (ERDAT).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderDescription rdf:type rdf:Property ;
    rdfs:label 'Order Description' ;
    rdfs:comment 'Free-text description of the production order providing additional context about the manufacturing scope, special instructions, or engineering change notes. Used by shop floor supervisors and production planners for operational clarity.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the production order as assigned by SAP PP (Production Planning) or Apriso MES. This is the business-facing reference used on the shop floor, in MES screens, and in cross-system communication. Maps to SAP PP order number (AUFNR).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle state of the production order within the SAP PP and MES workflow. \'created\' = order created but not yet released to shop floor; \'released\' = released for execution; \'in_progress\' = active manufacturing underway; \'partially_confirmed\' = some operations confirmed; \'confirmed\' = all operations confirmed; \'technically_completed\' = TECO status in SAP — production complete, pending settlement; \'closed\' = fully settled and archived; \'cancelled\' = order voided. [ENUM-REF-CANDIDATE: created|released|in_progress|partially_confirmed|confirmed|technically_completed|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the production order indicating its manufacturing purpose. \'vehicle_build\' represents a full vehicle assembly order; \'sub_assembly\' covers component or module builds (e.g., powertrain, axle); \'rework\' covers defect correction orders; \'repair\' covers warranty or field return repairs; \'prototype\' covers R&D and pre-SOP (Start of Production) builds. Maps to SAP PP order type (AUART).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedFinishDate rdf:type rdf:Property ;
    rdfs:label 'Planned Finish Date' ;
    rdfs:comment 'The scheduled date on which all production activities for this order are planned to be completed. Used for delivery commitment, JIT (Just-in-Time) scheduling, and OTD (On-Time Delivery) performance tracking. Maps to SAP PP planned finish date (GLTRS).' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Planned Labor Hours' ;
    rdfs:comment 'The total planned direct labor hours required to execute this production order, derived from the routing standard times and target quantity. Used for capacity planning, workforce scheduling via SuccessFactors, and standard cost calculation in SAP CO.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMachineHours rdf:type rdf:Property ;
    rdfs:label 'Planned Machine Hours' ;
    rdfs:comment 'The total planned machine/equipment hours required to execute this production order, derived from routing standard machine times. Used for equipment capacity planning, OEE (Overall Equipment Effectiveness) baseline, and standard cost calculation.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'The scheduled date on which production activities for this order are planned to begin, as determined by MRP (Material Requirements Planning) or production scheduling. Maps to SAP PP planned start date (GSTRS).' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppapRequired rdf:type rdf:Property ;
    rdfs:label 'Ppap Required' ;
    rdfs:comment 'Indicates whether PPAP (Production Part Approval Process) approval is required before this production order can be released for full-volume production. Typically True for new part introductions, engineering changes, or supplier changes. Governed by IATF 16949 and AIAG PPAP standards.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Numeric priority level assigned to this production order for shop floor scheduling and sequencing. Lower values indicate higher priority. Used by MES and JIS (Just-in-Sequence) systems to determine execution order when multiple orders compete for the same resources.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionStage rdf:type rdf:Property ;
    rdfs:label 'Production Stage' ;
    rdfs:comment 'The manufacturing stage or shop area where this production order is executed. Reflects the physical production process: \'stamping\' = metal forming; \'body_shop\' = body-in-white welding; \'paint\' = surface coating; \'final_assembly\' = vehicle assembly; \'powertrain\' = engine/transmission build; \'trim_chassis\' = trim, chassis, and final fit.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'The date and time when the production order was formally released to the shop floor for execution. Release triggers material staging, capacity reservation, and MES order activation. Maps to SAP PP order release date/time.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reworkQuantity rdf:type rdf:Property ;
    rdfs:label 'Rework Quantity' ;
    rdfs:comment 'The quantity of units that required rework (non-conforming units corrected and returned to production flow) during execution of this order. Distinct from scrap — reworked units are salvaged. Used for quality cost analysis and APQP (Advanced Product Quality Planning) reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Scrap Quantity' ;
    rdfs:comment 'The quantity of units scrapped or rejected during production of this order due to quality defects or process failures. Used for PPM (Parts Per Million) defect rate calculation, scrap cost analysis, and FMEA (Failure Mode and Effects Analysis) reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopIndicator rdf:type rdf:Property ;
    rdfs:label 'Sop Indicator' ;
    rdfs:comment 'Indicates whether this production order is part of the SOP (Start of Production) launch phase for a new vehicle program. True = SOP launch order subject to enhanced quality monitoring and APQP controls; False = regular series production order.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'The planned standard cost to produce the target quantity under this order, calculated from the BOM (Bill of Materials) component costs and routing activity rates in SAP CO (Controlling). Expressed in the plant\'s local currency. Used for cost variance analysis and EBITDA reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetQuantity rdf:type rdf:Property ;
    rdfs:label 'Target Quantity' ;
    rdfs:comment 'The planned quantity of vehicles or sub-assemblies to be produced under this order, expressed in the base unit of measure (typically \'EA\' for each). Maps to SAP PP planned order quantity (GAMNG). Used for capacity planning and production scheduling.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Technical Completion Timestamp' ;
    rdfs:comment 'The date and time when the production order was set to Technically Completed (TECO) status in SAP PP, indicating all manufacturing operations are finished and the order is pending cost settlement. Distinct from actual_finish_timestamp which records the last physical operation.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'The base unit of measure for the target and confirmed quantities on this production order (e.g., EA = Each for vehicles, PC = Piece for components, SET for kits, KG for bulk materials). Maps to SAP base unit of measure (MEINS).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vinRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Vin Range End' ;
    rdfs:comment 'The last VIN (Vehicle Identification Number) in the sequential range assigned to units produced under this order. Together with vin_range_start, defines the complete set of vehicles traceable to this production order for recall, warranty, and homologation purposes.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vinRangeStart rdf:type rdf:Property ;
    rdfs:label 'Vin Range Start' ;
    rdfs:comment 'The first VIN (Vehicle Identification Number) in the sequential range assigned to units produced under this order. VINs are 17-character alphanumeric identifiers conforming to ISO 3779. Used for build traceability, recall management, and regulatory reporting to NHTSA.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipPostingFlag rdf:type rdf:Property ;
    rdfs:label 'Wip Posting Flag' ;
    rdfs:comment 'Indicates whether WIP (Work in Progress) costs have been calculated and posted to the financial ledger for this production order in the current period. True = WIP posted; False = WIP not yet posted. Used for period-end financial closing in SAP CO.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buildSequenceId rdf:type rdf:Property ;
    rdfs:label 'Build Sequence Id' ;
    rdfs:comment 'Unique surrogate identifier for the Just-in-Sequence (JIS) build sequence record in the Databricks Silver Layer. Primary key generated by the Apriso/Dassault MES sequencing module upon sequence creation.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BuildSequence .

ind:powertrainVariantId rdf:type rdf:Property ;
    rdfs:label 'Powertrain Variant Id' ;
    rdfs:comment 'Foreign key linking to vehicle.powertrain_variant. Business justification: Build sequencing drives JIS (Just-In-Sequence) powertrain call-offs to suppliers. The sequence must reference the specific powertrain_variant to trigger correct engine/transmission delivery timing. bu' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PowertrainVariant .

ind:primaryBuildConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Primary Build Configuration Id' ;
    rdfs:comment 'Reference to the vehicle configuration record defining the model, trim, powertrain, and option codes for the vehicle to be assembled at this sequence position.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Configuration .

ind:productionVariantId rdf:type rdf:Property ;
    rdfs:label 'Production Variant Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.production_variant. Business justification: Each JIS build sequence entry is for a specific production variant (option combination). The option_package_code and trim_level_code are variant attributes that are already mastered in production_vari' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionVariant .

ind:supplyDeliveryScheduleId rdf:type rdf:Property ;
    rdfs:label 'Supply Delivery Schedule Id' ;
    rdfs:comment 'Foreign key linking to supply.supply_delivery_schedule. Business justification: In JIS operations, the build sequence directly triggers supplier delivery schedules. The jis_call_off_timestamp on build_sequence confirms this operational dependency. Sequencing teams and supply plan' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplyDeliverySchedule .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time at which assembly of the vehicle at this sequence position was completed on the production line, as recorded by the MES. Null until assembly is complete.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assemblyStage rdf:type rdf:Property ;
    rdfs:label 'Assembly Stage' ;
    rdfs:comment 'Current or target assembly stage for this sequence position: \'stamping\' = metal forming; \'body_shop\' = body-in-white welding; \'paint\' = paint application; \'final_assembly\' = trim and chassis assembly; \'PDI\' = Pre-Delivery Inspection. Drives shop floor routing in the MES.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyStyleCode rdf:type rdf:Property ;
    rdfs:label 'Body Style Code' ;
    rdfs:comment 'Code identifying the body style of the vehicle (e.g., sedan, SUV, truck, coupe, van). Influences stamping and body shop routing within the production sequence.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildType rdf:type rdf:Property ;
    rdfs:label 'Build Type' ;
    rdfs:comment 'Classification of the vehicle build purpose: \'retail\' = customer-ordered retail unit; \'fleet\' = fleet customer order; \'stock\' = dealer stock build; \'pilot\' = pre-production pilot build; \'homologation\' = regulatory homologation unit; \'press\' = media/press fleet unit.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Order Number' ;
    rdfs:comment 'Sales order number from SAP SD or Salesforce Automotive Cloud associated with this build sequence position, if the vehicle is built to a specific customer or dealer order. Null for stock builds.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerCode rdf:type rdf:Property ;
    rdfs:label 'Dealer Code' ;
    rdfs:comment 'Unique identifier of the dealer for whom this vehicle is being built, if applicable. Sourced from the dealer master in CDK Global DMS or Salesforce Automotive Cloud. Null for unallocated stock builds.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationMarketCode rdf:type rdf:Property ;
    rdfs:label 'Destination Market Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code indicating the intended destination market for the vehicle. Determines homologation variant, regulatory compliance requirements (NHTSA, UNECE, CARB), and market-specific option content.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driveConfiguration rdf:type rdf:Property ;
    rdfs:label 'Drive Configuration' ;
    rdfs:comment 'Drivetrain configuration of the vehicle: FWD (Front-Wheel Drive), RWD (Rear-Wheel Drive), AWD (All-Wheel Drive), or 4WD (Four-Wheel Drive). Determines axle and driveshaft JIS call-off and assembly routing.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exteriorColorCode rdf:type rdf:Property ;
    rdfs:label 'Exterior Color Code' ;
    rdfs:comment 'Paint color code for the vehicle exterior as specified in the build sequence. Drives paint shop scheduling, batch sequencing for color changeover optimization, and JIS paint material call-off.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freezeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Freeze Timestamp' ;
    rdfs:comment 'Date and time at which the build sequence was frozen and locked for JIS supplier call-off. After this timestamp, sequence changes are restricted and require formal change control. Critical for JIS supplier synchronization.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interiorColorCode rdf:type rdf:Property ;
    rdfs:label 'Interior Color Code' ;
    rdfs:comment 'Interior trim and upholstery color code for the vehicle. Used for JIS seat and interior component call-off to tier-1 suppliers.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFrozen rdf:type rdf:Property ;
    rdfs:label 'Is Frozen' ;
    rdfs:comment 'Indicates whether the build sequence record has been frozen for JIS supplier call-off. When True, sequence changes are restricted and require formal change control approval. Directly linked to freeze_timestamp.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPriorityBuild rdf:type rdf:Property ;
    rdfs:label 'Is Priority Build' ;
    rdfs:comment 'Indicates whether this vehicle has been flagged as a priority build (e.g., executive order, critical dealer allocation, regulatory compliance unit). Priority builds may override standard JIS sequencing rules.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jisCallOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Jis Call Off Timestamp' ;
    rdfs:comment 'Date and time at which the JIS supplier call-off message was transmitted for this sequence position. Triggers sequenced part delivery from tier-1 JIS suppliers. Critical for supply chain synchronization and OTD measurement.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mesSequenceReference rdf:type rdf:Property ;
    rdfs:label 'Mes Sequence Reference' ;
    rdfs:comment 'Native sequence record identifier from the Apriso/Dassault MES sequencing module. Serves as the source system key for lineage and reconciliation between the Silver Layer and the operational MES.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedBuildDate rdf:type rdf:Property ;
    rdfs:label 'Planned Build Date' ;
    rdfs:comment 'Calendar date on which the vehicle at this sequence position is planned to be assembled. Used for JIS supplier call-off scheduling and production planning in SAP PP.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned End Timestamp' ;
    rdfs:comment 'Precise date and time at which assembly of the vehicle at this sequence position is planned to complete. Used for takt time validation and shift throughput planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Start Timestamp' ;
    rdfs:comment 'Precise date and time at which assembly of the vehicle at this sequence position is planned to begin on the production line. Drives JIS call-off timing and AGV dispatch scheduling.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:powertrainType rdf:type rdf:Property ;
    rdfs:label 'Powertrain Type' ;
    rdfs:comment 'Classification of the vehicle powertrain to be assembled: ICE (Internal Combustion Engine), HEV (Hybrid Electric Vehicle), PHEV (Plug-in Hybrid Electric Vehicle), BEV (Battery Electric Vehicle), or FCEV (Fuel Cell Electric Vehicle). Drives line routing, tooling selection, and regulatory compliance checks.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Flag' ;
    rdfs:comment 'Indicates whether this build sequence position has been placed on a quality hold, preventing progression to the next assembly stage. Triggered by MES quality gate failures or FMEA-driven stop conditions.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryVariantCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Variant Code' ;
    rdfs:comment 'Code identifying the regulatory homologation variant of the vehicle (e.g., US-NHTSA, EU-UNECE, CARB-ZEV). Ensures correct BOM variant selection for emissions, safety, and market-specific compliance requirements.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceChangeReason rdf:type rdf:Property ;
    rdfs:label 'Sequence Change Reason' ;
    rdfs:comment 'Free-text or coded reason for the most recent modification to this build sequence record (e.g., material shortage, quality hold, customer order change, line disruption). Required for change control audit trail under IATF 16949.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordered position number of this vehicle within the production run for the assigned line and shift. Drives JIS supplier call-off sequencing and AGV routing. Must be unique within a plant, line, shift, and planned build date combination.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sequenceRevisionNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Revision Number' ;
    rdfs:comment 'Incremental revision counter tracking how many times this build sequence record has been modified since initial creation. Supports audit trail and change control compliance under IATF 16949.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sequenceSetNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Set Number' ;
    rdfs:comment 'Externally-known identifier for the production sequence set or run to which this record belongs, as generated by the MES sequencing module. Used for JIS call-off batch identification and supplier communication.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceStatus rdf:type rdf:Property ;
    rdfs:label 'Sequence Status' ;
    rdfs:comment 'Current lifecycle state of the build sequence record within the MES workflow. \'planned\' = sequence created but not yet released to shop floor; \'released\' = released for production; \'in_progress\' = vehicle currently being assembled; \'completed\' = assembly finished; \'cancelled\' = sequence removed from run; \'on_hold\' = temporarily suspended pending resolution.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceType rdf:type rdf:Property ;
    rdfs:label 'Sequence Type' ;
    rdfs:comment 'Classification of the build sequence record indicating whether it is the original planned sequence, a revised sequence after change control, an emergency insertion, or a resequenced position due to line disruption.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmissionType rdf:type rdf:Property ;
    rdfs:label 'Transmission Type' ;
    rdfs:comment 'Type of transmission to be installed in the vehicle at this sequence position. Drives drivetrain component JIS call-off and assembly station routing.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleModelCode rdf:type rdf:Property ;
    rdfs:label 'Vehicle Model Code' ;
    rdfs:comment 'Alphanumeric code identifying the vehicle model (e.g., platform or nameplate code) to be assembled at this sequence position. Sourced from Teamcenter PLM product structure.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vin rdf:type rdf:Property ;
    rdfs:label 'Vin' ;
    rdfs:comment '17-character Vehicle Identification Number (VIN) assigned to the vehicle at this sequence position, conforming to ISO 3779 and NHTSA standards. May be pre-assigned at sequence creation or stamped during body shop operations. Critical for build traceability and regulatory compliance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleBuildId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Build Id' ;
    rdfs:comment 'Primary key for vehicle_build' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleBuild .

ind:bomId rdf:type rdf:Property ;
    rdfs:label 'Bom Id' ;
    rdfs:comment 'Foreign key linking to engineering.bom. Business justification: Vehicle build records must reference the exact engineering BOM revision used during assembly for quality traceability, recall investigations, and warranty analysis. Regulators and OEM quality systems ' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bom .

ind:buildStageId rdf:type rdf:Property ;
    rdfs:label 'Build Stage Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.build_stage. Business justification: Vehicle build references its current build stage; replace string column with FK to build_stage for normalization.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BuildStage .

ind:finishedVehicleStockId rdf:type rdf:Property ;
    rdfs:label 'Finished Vehicle Stock Id' ;
    rdfs:comment 'Foreign key linking to inventory.finished_vehicle_stock. Business justification: Vehicle build completion triggers creation of a finished vehicle stock record — this is the fundamental manufacturing-to-inventory handoff. Traceability from build record to finished goods stock is re' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinishedVehicleStock .

ind:inspectionLotId rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_lot. Business justification: End-of-line and PDI inspection lots are created per vehicle build (per VIN). IATF 16949 requires unit-level quality disposition traceability from vehicle build to its inspection lot and final quality ' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionLot .

ind:vehicleOrderId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Order Id' ;
    rdfs:comment 'Foreign key linking to sales.vehicle_order. Business justification: Enables Build ↔ Delivery scheduling; associates each built vehicle with the sales order it fulfills for handover and logistics planning.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleOrder .

ind:vinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Vin Registry Id' ;
    rdfs:comment 'Foreign key linking to vehicle.vin_registry. Business justification: VIN Registration Integration needed for warranty, recall, and regulatory reporting linking build record to VIN registry.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VinRegistry .

ind:batterySerialNumber rdf:type rdf:Property ;
    rdfs:label 'Battery Serial Number' ;
    rdfs:comment 'The unique serial number of the high-voltage traction battery pack installed in this vehicle (applicable to HEV, PHEV, BEV). Null for ICE vehicles. Critical for EV battery genealogy, warranty, and end-of-life regulatory compliance.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyShopEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Body Shop End Timestamp' ;
    rdfs:comment 'Actual timestamp when the body shop stage was completed and the body-in-white was released to the paint shop. Null if stage not yet completed.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bodyShopStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Body Shop Start Timestamp' ;
    rdfs:comment 'Actual timestamp when the vehicle body-in-white (BIW) entered the body shop for welding and assembly. Key milestone for build genealogy and stage cycle time tracking.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bodyStyle rdf:type rdf:Property ;
    rdfs:label 'Body Style' ;
    rdfs:comment 'The body style classification of the vehicle being built. Used for production line routing, tooling selection, and regulatory homologation grouping.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomVersion rdf:type rdf:Property ;
    rdfs:label 'Bom Version' ;
    rdfs:comment 'The specific BOM (Bill of Materials) version or engineering change level used to build this vehicle. Captured at build time for genealogy and recall traceability. Links to Siemens Teamcenter PLM BOM management.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Build End Timestamp' ;
    rdfs:comment 'Actual date and time when the vehicle build was completed at the final assembly stage and signed off for PDI (Pre-Delivery Inspection). Null if the build is still in progress. Used for cycle time, throughput, and SOP/EOP milestone tracking.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:buildStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Build Start Timestamp' ;
    rdfs:comment 'Actual date and time when the vehicle build process commenced at the first production stage (typically body-in-white or stamping entry). Principal business event timestamp for the build lifecycle. Used for cycle time calculation and OTD (On-Time Delivery) analysis.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:buildStatus rdf:type rdf:Property ;
    rdfs:label 'Build Status' ;
    rdfs:comment 'Current lifecycle status of the vehicle build record. Drives shop floor workflow, MES gating, and production reporting. \'on_hold\' indicates a quality or material hold; \'rework\' indicates a defect requiring corrective action before completion.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chassisEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Chassis End Timestamp' ;
    rdfs:comment 'Actual timestamp when the chassis assembly stage was completed. Null if stage not yet completed.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chassisStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Chassis Start Timestamp' ;
    rdfs:comment 'Actual timestamp when the vehicle entered the chassis assembly stage for powertrain marriage, suspension, and drivetrain installation.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:endOfLineTestResult rdf:type rdf:Property ;
    rdfs:label 'End Of Line Test Result' ;
    rdfs:comment 'Result of the automated end-of-line (EOL) functional test performed on the completed vehicle, covering powertrain, brakes, ADAS, and electrical systems. Distinct from quality_gate_status which covers visual/dimensional inspection.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Engine Serial Number' ;
    rdfs:comment 'The unique serial number of the engine unit installed in this vehicle during chassis assembly. Critical for powertrain genealogy, warranty traceability, and recall management.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalAssemblyEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Final Assembly End Timestamp' ;
    rdfs:comment 'Actual timestamp when the final assembly stage was completed and the vehicle was released for PDI (Pre-Delivery Inspection). Null if stage not yet completed.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:finalAssemblyStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Final Assembly Start Timestamp' ;
    rdfs:comment 'Actual timestamp when the vehicle entered the final assembly stage for fluids, wheels, glass, and end-of-line checks.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdFlag rdf:type rdf:Property ;
    rdfs:label 'Hold Flag' ;
    rdfs:comment 'Indicates whether this vehicle build is currently under a production hold (True = on hold). A hold may be triggered by a quality non-conformance, missing parts, engineering change, or safety concern. Drives MES gating to prevent further assembly until resolved.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'Coded reason for the production hold applied to this vehicle build (e.g., QUALITY_DEFECT, MISSING_PART, ECN_CHANGE, SAFETY_CONCERN). Null if hold_flag is False. [ENUM-REF-CANDIDATE: QUALITY_DEFECT|MISSING_PART|ECN_CHANGE|SAFETY_CONCERN|SUPPLIER_DEVIATION|TOOLING_FAILURE|OTHER — promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homologationMarket rdf:type rdf:Property ;
    rdfs:label 'Homologation Market' ;
    rdfs:comment 'The target regulatory market for which this vehicle is homologated and built (e.g., USA, DEU, GBR, CHN, AUS). Determines applicable safety, emissions, and labeling standards. Uses ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paintColorCode rdf:type rdf:Property ;
    rdfs:label 'Paint Color Code' ;
    rdfs:comment 'The manufacturer\'s paint color code applied to this vehicle during the paint stage (e.g., G1W – Super White, 040 – Classic White). Used for paint shop scheduling, color sequencing optimization, and customer order matching.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paintEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Paint End Timestamp' ;
    rdfs:comment 'Actual timestamp when the paint stage was completed and the vehicle body was released to the trim/general assembly line. Null if stage not yet completed.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paintStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Paint Start Timestamp' ;
    rdfs:comment 'Actual timestamp when the vehicle body entered the paint shop for priming, painting, and clear-coat application.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityGateStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Gate Status' ;
    rdfs:comment 'Result of the end-of-line quality gate inspection for this vehicle build. \'conditional_pass\' indicates the vehicle passed with minor deviations requiring dealer rectification. Drives release-to-shipping authorization.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkCount rdf:type rdf:Property ;
    rdfs:label 'Rework Count' ;
    rdfs:comment 'Number of rework operations performed on this vehicle build. A count greater than zero indicates quality issues encountered during assembly. Used for PPM (Parts Per Million) defect rate calculation and FMEA analysis.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reworkFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Flag' ;
    rdfs:comment 'Indicates whether this vehicle build has been flagged for rework due to a detected defect or non-conformance (True = rework required). Distinct from hold_flag; a vehicle can be in rework while not on hold.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledBuildDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Build Date' ;
    rdfs:comment 'The planned calendar date on which this vehicle was scheduled to be built per the production plan (MRP/MES schedule). Used to measure schedule adherence and production plan vs. actual variance.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sopFlag rdf:type rdf:Property ;
    rdfs:label 'Sop Flag' ;
    rdfs:comment 'Indicates whether this vehicle build is part of the official Start of Production (SOP) launch batch (True = SOP vehicle). SOP vehicles are subject to enhanced quality scrutiny and PPAP sign-off requirements.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stampingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Stamping End Timestamp' ;
    rdfs:comment 'Actual timestamp when the stamping stage was completed and the body panels were released to the body shop. Null if stage not yet completed.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stampingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Stamping Start Timestamp' ;
    rdfs:comment 'Actual timestamp when the vehicle body panels entered the stamping stage. Used for stage-level cycle time analysis and production flow monitoring.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transmissionSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Transmission Serial Number' ;
    rdfs:comment 'The unique serial number of the transmission unit installed in this vehicle. Used for drivetrain genealogy, warranty claims, and component-level recall traceability.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trimEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Trim End Timestamp' ;
    rdfs:comment 'Actual timestamp when the trim assembly stage was completed. Null if stage not yet completed.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trimStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Trim Start Timestamp' ;
    rdfs:comment 'Actual timestamp when the vehicle entered the trim assembly stage for interior fitting, electrical harness installation, and dashboard assembly.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:controlPlanId rdf:type rdf:Property ;
    rdfs:label 'Control Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.control_plan. Business justification: IATF 16949 requires each manufacturing stage to be governed by a control plan. Existing \'control_plan_code\' is denormalized. Proper FK to control_plan enables APQP/PPAP traceability from build stage t' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlPlan .

ind:designSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Design Specification Id' ;
    rdfs:comment 'Foreign key linking to engineering.design_specification. Business justification: IATF 16949 requires traceability from each build stage (body weld, paint, final assembly) to the governing engineering design specification defining process tolerances and quality criteria. Process en' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DesignSpecification .

ind:fmeaId rdf:type rdf:Property ;
    rdfs:label 'Fmea Id' ;
    rdfs:comment 'Foreign key linking to quality.fmea. Business justification: IATF 16949/APQP requires each manufacturing stage to have an associated Process FMEA (PFMEA). Existing \'fmea_reference_code\' is denormalized. Proper FK to fmea enables PFMEA-to-process-stage traceabil' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fmea .

ind:fmeaRecordId rdf:type rdf:Property ;
    rdfs:label 'Fmea Record Id' ;
    rdfs:comment 'Foreign key linking to engineering.fmea_record. Business justification: IATF 16949 mandates that each build stage be linked to its governing process FMEA record for risk management and audit traceability. fmea_reference_code is a denormalized string reference to fmea_reco' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FmeaRecord .

ind:inspectionPlanId rdf:type rdf:Property ;
    rdfs:label 'Inspection Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_plan. Business justification: Each build stage references an inspection plan defining what to inspect at that stage. Existing \'quality_inspection_plan_code\' is denormalized. Proper FK enables stage-level quality inspection plannin' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionPlan .

ind:applicableVehicleTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Vehicle Types' ;
    rdfs:comment 'Comma-separated list of vehicle body types or powertrain categories for which this build stage applies (e.g., Sedan, SUV, Truck, EV, HEV, PHEV, ICE, Commercial). Enables stage filtering in mixed-model assembly lines and supports model-specific production routing. [ENUM-REF-CANDIDATE: Sedan|SUV|Truck|EV|HEV|PHEV|ICE|Commercial|CKD|SKD — promote to reference product]' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bufferCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Buffer Capacity Units' ;
    rdfs:comment 'Maximum number of vehicle units that can be held in the buffer/queue between this build stage and the next stage. Defines the WIP (Work in Progress) inventory limit for line balancing and is used in production simulation and bottleneck analysis.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:co2EmissionKg rdf:type rdf:Property ;
    rdfs:label 'Co2 Emission Kg' ;
    rdfs:comment 'Standard CO2-equivalent emissions in kilograms per vehicle unit processed at this build stage. Supports EPA and CARB (California Air Resources Board) environmental compliance reporting, sustainability KPIs, and manufacturing carbon footprint tracking.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'The date from which this build stage definition record is valid and applicable for production use. Supports temporal versioning of the build stage master, enabling historical traceability of process changes and engineering change management.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'The date until which this build stage definition record is valid. Null indicates the record is currently active with no planned expiry. Used for managing engineering changes, process revisions, and model-year transitions in the build stage master.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:energyConsumptionKwh rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh' ;
    rdfs:comment 'Standard energy consumption in kilowatt-hours (kWh) per vehicle unit processed through this build stage. Used for manufacturing sustainability reporting, carbon footprint calculation, and ISO 14001 environmental management compliance. Particularly significant for paint ovens and E-Coat tanks.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatClassification rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classification' ;
    rdfs:comment 'Classification of hazardous materials present or used at this build stage per DOT and EPA regulations (e.g., paint solvents, E-Coat chemicals, welding fumes). Drives EHS (Environmental Health and Safety) compliance, PPE requirements, and ISO 14001 environmental management reporting.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iatfProcessCategory rdf:type rdf:Property ;
    rdfs:label 'Iatf Process Category' ;
    rdfs:comment 'IATF 16949 process category designation for this build stage: special-characteristic (processes producing special product/process characteristics requiring enhanced control), standard-process, critical-process (safety-critical per FMVSS), or monitoring-only (observation without active control). Drives audit scope and PPAP (Production Part Approval Process) requirements.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReworkEligible rdf:type rdf:Property ;
    rdfs:label 'Is Rework Eligible' ;
    rdfs:comment 'Indicates whether vehicles failing quality checks at this build stage are eligible for rework and re-entry into the production flow, as opposed to being routed to scrap or offline repair. Drives rework routing logic in MES and quality management workflows.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborHeadcountStandard rdf:type rdf:Property ;
    rdfs:label 'Labor Headcount Standard' ;
    rdfs:comment 'The standard number of direct labor operators assigned to this build stage per shift under normal production conditions. Used for workforce planning, capacity balancing, and labor cost standard costing in SAP S/4HANA CO.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Max Temperature C' ;
    rdfs:comment 'Maximum allowable ambient or process temperature in degrees Celsius for this build stage. Exceeding this threshold triggers a quality hold and SCADA alarm. Particularly relevant for paint curing ovens, E-Coat baths, and weld quality control.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesStageCode rdf:type rdf:Property ;
    rdfs:label 'Mes Stage Code' ;
    rdfs:comment 'The native stage identifier as defined in the Apriso/Dassault MES system. Used for cross-system reconciliation between the lakehouse silver layer and the operational MES, ensuring traceability of production events back to the source system of record.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Min Temperature C' ;
    rdfs:comment 'Minimum allowable ambient or process temperature in degrees Celsius for this build stage to operate within specification. Critical for paint shop, E-Coat, and adhesive curing stages where temperature directly affects product quality. Used in SPC (Statistical Process Control) monitoring.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelYearApplicability rdf:type rdf:Property ;
    rdfs:label 'Model Year Applicability' ;
    rdfs:comment 'Comma-separated list of MY (Model Year) designations for which this build stage definition is applicable (e.g., MY2024,MY2025) or ALL if applicable across all model years. Supports model-year-specific production routing and engineering change management.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantAreaCode rdf:type rdf:Property ;
    rdfs:label 'Plant Area Code' ;
    rdfs:comment 'Alphanumeric code identifying the specific plant area or shop within the manufacturing facility where this build stage is physically located (e.g., SH01 for Stamping Hall 1, BS02 for Body Shop 2). Aligns with SAP S/4HANA work center and plant layout master data.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plcProgramCode rdf:type rdf:Property ;
    rdfs:label 'Plc Program Code' ;
    rdfs:comment 'Identifier of the PLC (Programmable Logic Controller) program controlling the automated equipment at this build stage. Used for change management, version control of control programs, and traceability of equipment configuration changes per IATF 16949 requirements.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppmTarget rdf:type rdf:Property ;
    rdfs:label 'Ppm Target' ;
    rdfs:comment 'Target defect rate for this build stage expressed in PPM (Parts Per Million). Defines the quality performance benchmark used in IATF 16949 supplier and process quality reporting, SPC control limit setting, and continuous improvement initiatives.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precedingStageCode rdf:type rdf:Property ;
    rdfs:label 'Preceding Stage Code' ;
    rdfs:comment 'Stage code of the immediately preceding build stage in the standard production sequence. Defines the upstream dependency for production flow control, WIP (Work in Progress) tracking, and JIS (Just-in-Sequence) scheduling. Null for the first stage in the sequence.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processArea rdf:type rdf:Property ;
    rdfs:label 'Process Area' ;
    rdfs:comment 'The physical or functional manufacturing area where this build stage is executed (e.g., Stamping Plant, Body Shop, Paint Shop, General Assembly, Chassis Line, PDI Bay). Maps to plant layout zones and is used for capacity planning and SCADA (Supervisory Control and Data Acquisition) integration. [ENUM-REF-CANDIDATE: Stamping|Body Shop|Paint Shop|E-Coat|General Assembly|Chassis Line|Trim Line|PDI Bay|Quality Gate|Logistics — promote to reference product]' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyClassification rdf:type rdf:Property ;
    rdfs:label 'Safety Classification' ;
    rdfs:comment 'Safety risk classification of this build stage per DOT and OSHA standards: standard (routine operations), elevated-risk (requires additional PPE or safety protocols), critical-safety (safety-critical operations with mandatory sign-off), or restricted-access (limited to certified personnel only).' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapOperationCode rdf:type rdf:Property ;
    rdfs:label 'Sap Operation Code' ;
    rdfs:comment 'The SAP S/4HANA PP routing operation code corresponding to this build stage. Enables direct linkage between the build stage reference master and SAP production order routing operations for cost allocation, scheduling, and confirmation.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Sequence Order' ;
    rdfs:comment 'Integer defining the sequential position of this build stage within the overall vehicle assembly process flow. Used to enforce JIS (Just-in-Sequence) ordering, production line scheduling, and WIP (Work in Progress) traceability. Lower values indicate earlier stages.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Standard shift pattern under which this build stage operates: single (one shift per day), double (two shifts), triple (three shifts), or continuous (24/7 operation). Used for capacity planning, labor scheduling in SuccessFactors, and production throughput calculations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcEnabled rdf:type rdf:Property ;
    rdfs:label 'Spc Enabled' ;
    rdfs:comment 'Indicates whether SPC (Statistical Process Control) monitoring is active for this build stage. When true, process parameters are continuously monitored against control limits and deviations trigger automated alerts in the MES and SAP QM systems per IATF 16949 requirements.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stageCode rdf:type rdf:Property ;
    rdfs:label 'Stage Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the build stage within the manufacturing process (e.g., STAMP, BODY, ECOAT, PAINT, TRIM1, CHAS, TRIM2, FINAL, PDI). Used as the business key in MES (Manufacturing Execution System) integrations and production reporting.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageDescription rdf:type rdf:Property ;
    rdfs:label 'Stage Description' ;
    rdfs:comment 'Detailed narrative description of the manufacturing activities, operations, and objectives performed at this build stage. Provides context for production engineers, quality auditors, and training documentation. Sourced from PLM and MES configuration documentation.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageName rdf:type rdf:Property ;
    rdfs:label 'Stage Name' ;
    rdfs:comment 'Full descriptive name of the build stage as used in production planning and reporting (e.g., Stamping, Body Shop, E-Coat, Paint, Trim-1, Chassis, Trim-2, Final Assembly, PDI — Pre-Delivery Inspection). Displayed in MES dashboards and production schedules.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageStatus rdf:type rdf:Property ;
    rdfs:label 'Stage Status' ;
    rdfs:comment 'Current lifecycle status of the build stage definition: active (in production use), inactive (temporarily not in use), pilot (under validation/trial), suspended (halted due to quality or safety issue), or decommissioned (permanently retired from the process). Controls whether the stage is available for new production orders.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageType rdf:type rdf:Property ;
    rdfs:label 'Stage Type' ;
    rdfs:comment 'Categorical classification of the build stage by its primary manufacturing function: assembly (joining components), fabrication (forming/stamping metal), coating (E-Coat/paint application), inspection (quality gate checks), testing (functional/NVH testing), or logistics (material staging/sequencing).' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCycleTimeSec rdf:type rdf:Property ;
    rdfs:label 'Standard Cycle Time Sec' ;
    rdfs:comment 'The engineered standard cycle time for this build stage measured in seconds. Represents the designed takt-aligned duration for one vehicle unit to complete the stage under normal operating conditions. Used for production scheduling, OEE (Overall Equipment Effectiveness) calculation, and bottleneck analysis.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:succeedingStageCode rdf:type rdf:Property ;
    rdfs:label 'Succeeding Stage Code' ;
    rdfs:comment 'Stage code of the immediately succeeding build stage in the standard production sequence. Defines the downstream handoff point for production flow control and vehicle build traceability. Null for the final stage (PDI) in the sequence.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taktTimeSec rdf:type rdf:Property ;
    rdfs:label 'Takt Time Sec' ;
    rdfs:comment 'The customer-demand-driven takt time for this build stage in seconds, calculated as available production time divided by required production volume. Defines the rhythm of production and is used to balance line capacity and identify over/under-capacity stages.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shopFloorEventId rdf:type rdf:Property ;
    rdfs:label 'Shop Floor Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each shop floor event record generated by MES, PLC, or SCADA systems during production operations.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:characteristicId rdf:type rdf:Property ;
    rdfs:label 'Characteristic Id' ;
    rdfs:comment 'Foreign key linking to quality.characteristic. Business justification: Shop floor events capture measured_value against control limits — these measurements are for specific quality characteristics. Linking to characteristic enables proper SPC data traceability and charac' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Characteristic .

ind:defectRecordId rdf:type rdf:Property ;
    rdfs:label 'Defect Record Id' ;
    rdfs:comment 'Foreign key linking to quality.defect_record. Business justification: IATF 16949 MES traceability: shop floor events with quality_result=\'FAIL\' or fault_code directly generate defect records. Linking enables MES-to-quality defect traceability required for process audit ' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DefectRecord .

ind:agvUnitCode rdf:type rdf:Property ;
    rdfs:label 'Agv Unit Code' ;
    rdfs:comment 'Identifier of the AGV (Automated Guided Vehicle) unit involved in this event. Populated only for AGV arrival, departure, or fault events. Enables AGV fleet utilization and route efficiency analysis.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyArea rdf:type rdf:Property ;
    rdfs:label 'Assembly Area' ;
    rdfs:comment 'Major manufacturing area where the event occurred. Supports area-level OEE reporting and quality gate management across stamping, body shop, paint, and final assembly. [ENUM-REF-CANDIDATE: stamping|body_shop|paint_shop|final_assembly|powertrain|chassis|trim — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCategory rdf:type rdf:Property ;
    rdfs:label 'Event Category' ;
    rdfs:comment 'High-level grouping of the event type for reporting and analytics. Enables aggregated OEE loss categorization (availability, performance, quality) and safety incident tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Event Duration Seconds' ;
    rdfs:comment 'Duration of the shop floor event in seconds (e.g., station cycle time, weld duration, paint cure time). Principal quantitative measurement for cycle time analysis and OEE performance rate calculation.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventPayload rdf:type rdf:Property ;
    rdfs:label 'Event Payload' ;
    rdfs:comment 'Structured JSON string containing the full event-specific payload from the MES, PLC, or SCADA system. Stores additional context-specific parameters not captured in dedicated columns (e.g., weld schedule parameters, paint recipe ID, torque angle). Stored as STRING to comply with Silver layer no-complex-type constraint.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Event Source System' ;
    rdfs:comment 'Identifies the originating control system that generated this event (MES, PLC, SCADA, AGV controller, or manual entry). Critical for data lineage and root-cause analysis. [ENUM-REF-CANDIDATE: MES|PLC|SCADA|AGV|TPMS|OBD|MANUAL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle state of the shop floor event record. Indicates whether the event has been acknowledged, confirmed by the operator, placed on hold, or escalated for quality review.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Precise date and time (ISO 8601 with timezone offset) when the shop floor event occurred as recorded by the MES, PLC, or SCADA system. This is the principal real-world event time used for OEE calculation and production sequencing.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Discriminator classifying the kind of shop floor event. Drives downstream routing, OEE calculation, and quality gate logic. [ENUM-REF-CANDIDATE: station_entry|station_exit|torque_confirmation|weld_completion|paint_cure|agv_arrival|hold_trigger|alarm|inspection_pass|inspection_fail|rework_start|rework_complete — promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultCode rdf:type rdf:Property ;
    rdfs:label 'Fault Code' ;
    rdfs:comment 'Machine or process fault code generated by the PLC or SCADA system when an alarm or hold event occurs. Used for root-cause analysis, FMEA (Failure Mode and Effects Analysis) updates, and maintenance work order creation.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultDescription rdf:type rdf:Property ;
    rdfs:label 'Fault Description' ;
    rdfs:comment 'Human-readable description of the fault or alarm condition associated with this event. Populated from the PLC/SCADA alarm dictionary. Null for non-alarm events.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRework rdf:type rdf:Property ;
    rdfs:label 'Is Rework' ;
    rdfs:comment 'Indicates whether this event is associated with a rework operation (True) rather than a first-pass production operation (False). Used to calculate first-time quality (FTQ) and rework cost metrics.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWithinSpec rdf:type rdf:Property ;
    rdfs:label 'Is Within Spec' ;
    rdfs:comment 'Indicates whether the measured value falls within the defined process control limits (True) or represents an out-of-specification condition (False). Drives automatic quality hold triggers and PPM (Parts Per Million) defect rate calculation.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowerControlLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Control Limit' ;
    rdfs:comment 'Lower statistical process control limit for the measured value at this station. Used in SPC (Statistical Process Control) to detect process drift and trigger quality holds.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'Principal numeric measurement captured during the event (e.g., torque value in Nm, weld current in A, paint film thickness in µm, temperature in °C, pressure in bar). Null when the event type does not produce a measurement.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredValueUnit rdf:type rdf:Property ;
    rdfs:label 'Measured Value Unit' ;
    rdfs:comment 'Engineering unit of measure for the measured_value field (e.g., Nm for torque, A for weld current, µm for paint film thickness). Ensures dimensional correctness in SPC and quality analysis. [ENUM-REF-CANDIDATE: Nm|A|V|bar|°C|µm|mm|kg|kN|rpm|% — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesEventNumber rdf:type rdf:Property ;
    rdfs:label 'Mes Event Number' ;
    rdfs:comment 'Externally-known unique event reference number assigned by the Apriso/Dassault MES system. Used for cross-system traceability and audit correlation.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeLossCategory rdf:type rdf:Property ;
    rdfs:label 'Oee Loss Category' ;
    rdfs:comment 'Classifies this event\'s contribution to OEE (Overall Equipment Effectiveness) loss: availability loss (unplanned downtime), performance loss (speed reduction), quality loss (defects/rework), or no_loss (normal production). Enables direct OEE waterfall analysis per ISO 22400.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCycleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Planned Cycle Time Seconds' ;
    rdfs:comment 'Standard planned cycle time in seconds for this process step as defined in the SAP PP routing. Compared against event_duration_seconds to calculate performance rate for OEE.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processStepCode rdf:type rdf:Property ;
    rdfs:label 'Process Step Code' ;
    rdfs:comment 'Code identifying the specific manufacturing process step (e.g., STAMP-001, BODY-WELD-045, PAINT-CURE-010, ASSY-TORQUE-120) within the routing. Aligns with SAP PP routing operations.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programNumber rdf:type rdf:Property ;
    rdfs:label 'Program Number' ;
    rdfs:comment 'Version-controlled program number loaded on the PLC or robot controller at the time of this event. Critical for traceability of process parameter changes and engineering change management.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityResult rdf:type rdf:Property ;
    rdfs:label 'Quality Result' ;
    rdfs:comment 'Outcome of the quality check associated with this event. Determines whether the vehicle unit proceeds to the next station, requires rework, or is scrapped. Feeds into IATF 16949 quality records and PPM reporting.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkAttemptNumber rdf:type rdf:Property ;
    rdfs:label 'Rework Attempt Number' ;
    rdfs:comment 'Sequential count of rework attempts for this vehicle unit at this station. A value greater than 1 indicates repeated failures and triggers escalation per IATF 16949 nonconforming product procedures.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scrapCode rdf:type rdf:Property ;
    rdfs:label 'Scrap Code' ;
    rdfs:comment 'Coded reason for scrapping a component or vehicle unit at this event. Populated only when quality_result is \'scrap\'. Feeds into SAP CO scrap cost reporting and IATF 16949 quality records.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationCode rdf:type rdf:Property ;
    rdfs:label 'Station Code' ;
    rdfs:comment 'Unique code of the specific work station or assembly point within the production line where the event was triggered. Enables station-level cycle time and downtime analysis.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationName rdf:type rdf:Property ;
    rdfs:label 'Station Name' ;
    rdfs:comment 'Human-readable descriptive name of the work station (e.g., \'Underbody Weld Station 3\', \'E-Coat Oven Exit\', \'Engine Dress Final\'). Used in operator dashboards and quality reports.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperControlLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Control Limit' ;
    rdfs:comment 'Upper statistical process control limit for the measured value at this station. Used in SPC (Statistical Process Control) to detect process drift and trigger quality holds.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vinNumber rdf:type rdf:Property ;
    rdfs:label 'Vin Number' ;
    rdfs:comment '17-character Vehicle Identification Number of the vehicle unit being processed. Denormalized here for direct event-level traceability without requiring a join. Conforms to ISO 3779 and NHTSA 49 CFR Part 565.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPlanId rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Id' ;
    rdfs:comment 'Foreign key linking to finance.budget_plan. Business justification: Production volume schedules are the operational input to financial budget plans (revenue, COGS, material spend). Automotive S&OP process explicitly links production schedule to financial budget; this ' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetPlan .

ind:modelYearProgramId rdf:type rdf:Property ;
    rdfs:label 'Model Year Program Id' ;
    rdfs:comment 'Foreign key linking to vehicle.vehicle_model_year_program. Business justification: Annual production schedules are structured around model year programs — freeze horizons, SOP/EOP dates, and regulatory market allocations are all model-year-program-driven. This FK enables production ' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ModelYearProgram .

ind:msrpScheduleId rdf:type rdf:Property ;
    rdfs:label 'Msrp Schedule Id' ;
    rdfs:comment 'Foreign key linking to sales.msrp_schedule. Business justification: Production planning teams validate scheduled variants against active MSRP schedules before freezing production plans — ensuring only market-priced configurations are scheduled. This supports the S&OP ' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MsrpSchedule .

ind:schedulingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Scheduling Agreement Id' ;
    rdfs:comment 'Foreign key linking to supply.scheduling_agreement. Business justification: Production schedules release call-offs against scheduling agreements. The scheduling agreement defines contractual delivery rhythm and volumes; the production schedule triggers actual releases. S&OP a' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SchedulingAgreement .

ind:vehicleModelId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Model Id' ;
    rdfs:comment 'Reference to the vehicle model (e.g., sedan, SUV, truck, EV) being scheduled for production. Links to the vehicle master product record.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Model .

ind:actualQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity' ;
    rdfs:comment 'Actual number of vehicles produced and confirmed as good units by the MES (Manufacturing Execution System) during the schedule period. Populated upon schedule completion from Apriso/Dassault MES.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or employee identifier of the production planning manager who formally approved this schedule version for release to the shop floor. Required for IATF 16949 document control and audit trail.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Timestamp when the production schedule was formally approved for release. Marks the transition from \'draft\' to \'released\' status and triggers supplier call-off generation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assemblyProcessStage rdf:type rdf:Property ;
    rdfs:label 'Assembly Process Stage' ;
    rdfs:comment 'Manufacturing process stage covered by this schedule record. Reflects the major shop areas in automotive assembly: stamping (metal forming), body shop (welding/joining), paint (surface treatment), final assembly (powertrain/trim installation), or trim-chassis-final (TCF integrated line).' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCapacityHours rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Hours' ;
    rdfs:comment 'Total available production capacity in hours for this schedule period on the assigned production line, accounting for planned downtime, maintenance windows, and shift patterns.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildSequenceEnd rdf:type rdf:Property ;
    rdfs:label 'Build Sequence End' ;
    rdfs:comment 'Ending sequence number for the JIS (Just-in-Sequence) build order within this schedule period. Together with build_sequence_start defines the range of vehicle sequence numbers assigned to this schedule.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buildSequenceStart rdf:type rdf:Property ;
    rdfs:label 'Build Sequence Start' ;
    rdfs:comment 'Starting sequence number for the JIS (Just-in-Sequence) build order within this schedule period. Used by MES and AGV systems to sequence vehicle bodies through the production line in the correct order.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calloffTransmissionTime rdf:type rdf:Property ;
    rdfs:label 'Calloff Transmission Time' ;
    rdfs:comment 'Timestamp when supplier delivery call-offs were transmitted to the supply base for this production schedule. Used for OTD (On-Time Delivery) tracking and supplier performance measurement.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:capacityUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Pct' ;
    rdfs:comment 'Planned capacity utilization percentage for this schedule period, calculated as (confirmed_quantity × takt_time) / available_capacity_hours × 100. Stored as a planning input from SAP PP capacity leveling, not a derived KPI.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'Fiscal year (FY) to which this production schedule belongs. Used for financial planning, CapEx allocation, and EBITDA reporting alignment between production volumes and financial periods.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freezeHorizonDate rdf:type rdf:Property ;
    rdfs:label 'Freeze Horizon Date' ;
    rdfs:comment 'Date up to which the production schedule is frozen and cannot be changed without formal change control. Protects supplier call-offs and JIT/JIS delivery commitments within the frozen window.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'Total number of vehicles planned for production in this schedule period as determined by the MRP run. Represents the gross requirement before capacity and constraint adjustments.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMarket rdf:type rdf:Property ;
    rdfs:label 'Regulatory Market' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the primary regulatory market for which these vehicles are being produced. Determines applicable homologation standards (NHTSA/FMVSS for USA, UNECE for Europe, etc.), emissions certification (EPA, CARB, Euro 6), and CAFE compliance tracking. [ENUM-REF-CANDIDATE: USA|CAN|MEX|DEU|GBR|CHN|JPN|KOR|AUS|BRA — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleChangeReason rdf:type rdf:Property ;
    rdfs:label 'Schedule Change Reason' ;
    rdfs:comment 'Business reason code or description for the most recent schedule revision. Examples: material shortage, capacity constraint, demand change, quality hold, tooling failure, model mix adjustment. Required for change control audit trail per IATF 16949.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Date' ;
    rdfs:comment 'The principal planned production date (or start date of the weekly/monthly bucket) for this schedule record. Represents the real-world business event date when production is planned to occur.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleEndDate rdf:type rdf:Property ;
    rdfs:label 'Schedule End Date' ;
    rdfs:comment 'End date of the production schedule period. For daily schedules this equals schedule_date; for weekly/monthly buckets this marks the last day of the planning period.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleNotes rdf:type rdf:Property ;
    rdfs:label 'Schedule Notes' ;
    rdfs:comment 'Free-text field for production planners to record contextual notes, exceptions, or special instructions associated with this schedule record. Examples: tooling changeover notes, quality hold references, special customer order constraints.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the production schedule record, sourced from SAP PP (Production Planning). Used for cross-system reference and communication with supply chain and manufacturing teams.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle state of the production schedule record. \'draft\' = initial planning; \'released\' = approved for execution; \'frozen\' = within freeze horizon, no changes allowed; \'in_execution\' = active shop floor production; \'completed\' = all planned units built; \'cancelled\' = schedule voided.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Time granularity of the production schedule record. \'daily\' = day-level MPS; \'weekly\' = weekly bucket plan; \'monthly\' = monthly capacity plan. Determines the planning horizon and supplier call-off frequency.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Incremental version number of the production schedule. Each MRP (Material Requirements Planning) run or manual revision increments this counter, enabling version comparison and rollback analysis.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'Precise timestamp when production is scheduled to complete for this schedule record. Used for shift planning, takt time validation, and downstream logistics coordination.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Precise timestamp when production is scheduled to begin on the line for this schedule record. Used for JIS (Just-in-Sequence) sequencing, AGV routing, and supplier call-off timing.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supplierCalloffGenerated rdf:type rdf:Property ;
    rdfs:label 'Supplier Calloff Generated' ;
    rdfs:comment 'Boolean flag indicating whether supplier delivery call-offs (JIT/JIS delivery schedules) have been generated and transmitted to suppliers based on this production schedule. True = call-offs sent; False = pending call-off generation.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agvActive rdf:type rdf:Property ;
    rdfs:label 'Agv Active' ;
    rdfs:comment 'Indicates whether Automated Guided Vehicle (AGV) operations are active during this shift. Used for shop floor automation scheduling and safety protocol management in MES and SCADA integrations.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'Total scheduled break time in minutes for the shift (e.g., 30 minutes for a single meal break, 50 minutes for two breaks). Used to reconcile gross shift hours against planned production hours.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breakSchedule rdf:type rdf:Property ;
    rdfs:label 'Break Schedule' ;
    rdfs:comment 'Textual description of the break schedule for the shift, including break times and durations (e.g., \'10:00–10:15 AM rest break; 12:30–13:00 PM meal break\'). Supports workforce planning and ergonomic compliance documentation.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dayOfWeekMask rdf:type rdf:Property ;
    rdfs:label 'Day Of Week Mask' ;
    rdfs:comment 'Seven-character binary string (Mon–Sun) indicating which days of the week this shift runs (e.g., \'1111100\' = Monday to Friday, \'0000011\' = Saturday and Sunday). Used by MES and SAP PP for automated shift calendar generation.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Calendar date from which this shift definition becomes valid and available for production scheduling. Supports versioned shift master management and seasonal schedule changes.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:energyConsumptionTargetKwh rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Target Kwh' ;
    rdfs:comment 'Planned energy consumption target in kilowatt-hours for the shift. Used for energy efficiency monitoring, ISO 14001 environmental reporting, and CAFE/EPA compliance cost tracking.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Calendar date after which this shift definition is no longer valid for production scheduling. Null indicates an open-ended shift definition with no planned end. Supports model year changeovers and SOP/EOP transitions.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossShiftHours rdf:type rdf:Property ;
    rdfs:label 'Gross Shift Hours' ;
    rdfs:comment 'Total clock hours from shift start to shift end including all breaks and non-production time (e.g., 8.0 hours). Used to distinguish gross capacity from net available production time.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handoverDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Handover Duration Minutes' ;
    rdfs:comment 'Planned duration in minutes allocated for shift handover activities between outgoing and incoming crews (e.g., 15 minutes). Included in shift scheduling to ensure continuity of production and quality checks.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isTemplate rdf:type rdf:Property ;
    rdfs:label 'Is Template' ;
    rdfs:comment 'Indicates whether this shift record is a reusable template definition (True) rather than a plant/line-specific instantiation (False). Templates are used to standardise shift configurations across multiple plants and lines.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mesShiftCode rdf:type rdf:Property ;
    rdfs:label 'Mes Shift Code' ;
    rdfs:comment 'Native shift identifier in the Apriso/Dassault MES system used for shop floor execution and traceability. Enables cross-system reconciliation between the lakehouse silver layer and the MES source of record.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfBreaks rdf:type rdf:Property ;
    rdfs:label 'Number Of Breaks' ;
    rdfs:comment 'Count of distinct scheduled break periods within the shift (e.g., 2 for a morning rest break and a meal break). Used in ergonomic compliance reporting and workforce scheduling.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oeeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Target Percent' ;
    rdfs:comment 'Target OEE percentage for this shift, representing the combined availability, performance, and quality targets (e.g., 85.00%). Used as the benchmark for shift-level OEE reporting and continuous improvement initiatives.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeEligible rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible' ;
    rdfs:comment 'Indicates whether this shift definition is classified as an overtime shift, triggering premium pay calculations and overtime reporting in SAP HR and SuccessFactors payroll.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patternCode rdf:type rdf:Property ;
    rdfs:label 'Pattern Code' ;
    rdfs:comment 'Code referencing the rotating shift pattern or schedule template to which this shift belongs (e.g., 3SHIFT_ROTATING, 2SHIFT_FIXED, CONTINENTAL). Used for workforce rostering and long-term capacity planning.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndTime rdf:type rdf:Property ;
    rdfs:label 'Planned End Time' ;
    rdfs:comment 'Planned clock time at which the shift ends production activities. Combined with planned_start_time to derive gross shift duration for capacity and OEE calculations.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedProductionHours rdf:type rdf:Property ;
    rdfs:label 'Planned Production Hours' ;
    rdfs:comment 'Net planned production hours for the shift after deducting all scheduled breaks and non-production time (e.g., 7.5 hours for an 8-hour shift with 30-minute break). Core input for OEE denominator and capacity planning in SAP PP.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedStartTime rdf:type rdf:Property ;
    rdfs:label 'Planned Start Time' ;
    rdfs:comment 'Planned clock time at which the shift begins production activities (e.g., 2024-01-15T06:00:00.000+00:00). Used for production order scheduling, JIS sequencing, and workforce rostering.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:premiumPayRate rdf:type rdf:Property ;
    rdfs:label 'Premium Pay Rate' ;
    rdfs:comment 'Pay rate multiplier applied to base wages for this shift (e.g., 1.5000 for time-and-a-half overtime, 1.2500 for night shift differential). Used in payroll cost calculations and labour cost reporting. Classified confidential as it contains compensation data.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionModel rdf:type rdf:Property ;
    rdfs:label 'Production Model' ;
    rdfs:comment 'Shift operating model classification indicating the overall production schedule structure at the plant (e.g., single_shift, two_shift, three_shift, four_shift_continental). Drives capacity planning and workforce rostering strategy.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Indicates whether a mandatory quality inspection (e.g., PDI, SPC check, FMEA-driven inspection point) is required at the start or end of this shift. Drives SAP QM inspection lot creation and MES quality gate activation.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapShiftCode rdf:type rdf:Property ;
    rdfs:label 'Sap Shift Code' ;
    rdfs:comment 'Shift identifier as defined in SAP S/4HANA PP module (Schicht). Used for production order scheduling, capacity planning, and cross-system reconciliation with the ERP source of record.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaZoneCode rdf:type rdf:Property ;
    rdfs:label 'Scada Zone Code' ;
    rdfs:comment 'Code identifying the SCADA monitoring zone associated with this shift definition. Used to correlate shift-level production data with real-time SCADA telemetry for process control and quality monitoring.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the shift definition within the plant (e.g., DAY1, AFT2, NGT3, WKD1). Used as the business key in SAP PP and MES integrations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDescription rdf:type rdf:Property ;
    rdfs:label 'Shift Description' ;
    rdfs:comment 'Free-text description providing additional context about the shift definition, including special operating conditions, seasonal variations, or programme-specific notes (e.g., \'Reduced capacity shift during model year changeover\').' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftName rdf:type rdf:Property ;
    rdfs:label 'Shift Name' ;
    rdfs:comment 'Human-readable name of the shift (e.g., Day Shift, Afternoon Shift, Night Shift, Weekend Shift). Used in production scheduling dashboards, workforce planning reports, and OEE calculations.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftStatus rdf:type rdf:Property ;
    rdfs:label 'Shift Status' ;
    rdfs:comment 'Current lifecycle status of the shift definition. Active shifts are available for production order scheduling; inactive or suspended shifts are excluded from planning runs.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftType rdf:type rdf:Property ;
    rdfs:label 'Shift Type' ;
    rdfs:comment 'Classification of the shift by its operational period. Drives workforce planning, premium pay calculations, and production capacity modelling. [ENUM-REF-CANDIDATE: day|afternoon|night|weekend|overtime|shutdown — promote to reference product if additional types are required]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorRoleCode rdf:type rdf:Property ;
    rdfs:label 'Supervisor Role Code' ;
    rdfs:comment 'Code identifying the required supervisor role classification for this shift (e.g., PROD_SUPV, AREA_LEAD). Used for workforce planning and shift handover accountability. References the HR role catalogue in SuccessFactors.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTaktTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Target Takt Time Seconds' ;
    rdfs:comment 'Planned takt time in seconds per unit for this shift, calculated as net available production time divided by customer demand rate. Fundamental metric for line balancing and JIS sequencing in automotive assembly.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetUnitsPerShift rdf:type rdf:Property ;
    rdfs:label 'Target Units Per Shift' ;
    rdfs:comment 'Planned number of vehicle units (or assemblies) to be produced during this shift. Used as the production target for OEE performance ratio calculation and daily production reporting.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timezoneCode rdf:type rdf:Property ;
    rdfs:label 'Timezone Code' ;
    rdfs:comment 'IANA timezone identifier for the plant location where this shift operates (e.g., America/Detroit, Europe/Berlin). Ensures accurate timestamp interpretation for global multi-plant production scheduling and reporting.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workforceHeadcountTarget rdf:type rdf:Property ;
    rdfs:label 'Workforce Headcount Target' ;
    rdfs:comment 'Planned number of direct production workers required for this shift. Used for workforce planning, labour cost budgeting, and integration with SuccessFactors workforce scheduling.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downtimeEventId rdf:type rdf:Property ;
    rdfs:label 'Downtime Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each downtime event record in the manufacturing execution system. Primary key for the downtime_event data product.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inboundPartId rdf:type rdf:Property ;
    rdfs:label 'Inbound Part Id' ;
    rdfs:comment 'Foreign key linking to supply.inbound_part. Business justification: Supplier-caused downtime events must be traceable to the specific inbound part for supplier corrective action requests, scorecard impact calculation, and warranty cost recovery. This is a standard aut' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundPart .

ind:affectedProcessArea rdf:type rdf:Property ;
    rdfs:label 'Affected Process Area' ;
    rdfs:comment 'The manufacturing process area impacted by the downtime event. Reflects the major shop segments in automotive assembly: stamping (press shop), body shop (BIW - Body in White), paint shop, final assembly, powertrain assembly, chassis, trim, or general assembly. Used for plant-level downtime distribution analysis. [ENUM-REF-CANDIDATE: stamping|body_shop|paint|final_assembly|powertrain|chassis|trim|general_assembly — promote to reference product]' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCode rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Code' ;
    rdfs:comment 'Standardized code from the SAP PM activity type catalog describing the corrective action taken to resolve the downtime event (e.g., part replacement, lubrication, calibration, software reset, tooling adjustment). Supports FMEA corrective action tracking and spare parts consumption analysis.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeCategory rdf:type rdf:Property ;
    rdfs:label 'Downtime Category' ;
    rdfs:comment 'Primary classification of the downtime event type. \'mechanical_failure\' covers equipment breakdowns; \'tooling_change\' covers die/tool swap activities; \'material_shortage\' covers JIT/JIS supply disruptions; \'quality_hold\' covers production stops due to quality issues; \'scheduled_maintenance\' covers planned PM activities; \'changeover\' covers model or variant changeover activities. Drives OEE availability loss categorization.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeType rdf:type rdf:Property ;
    rdfs:label 'Downtime Type' ;
    rdfs:comment 'Indicates whether the downtime event was planned (scheduled maintenance, changeover, tooling change per production schedule) or unplanned (unexpected breakdown, quality hold, material shortage). Critical for separating planned vs. unplanned OEE availability losses.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total elapsed duration of the downtime event in minutes, calculated as the difference between end_timestamp and start_timestamp. Stored as a business field for direct use in OEE (Overall Equipment Effectiveness) availability calculations and SCADA-integrated downtime reporting. Null if the event has not yet ended.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'The exact date and time when the downtime event ended and production resumed, as recorded by the MES or SCADA system. Null if the event is still active. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Indicates the management escalation level reached during the downtime event based on duration thresholds or safety/quality triggers. \'none\' = resolved at operator level; \'supervisor\' = shift supervisor notified; \'manager\' = production manager engaged; \'plant_director\' = plant director escalation triggered. Supports escalation SLA compliance reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'The calendar date on which the downtime event started. Derived from start_timestamp for day-level partitioning, reporting, and trend analysis. Stored as a separate DATE field to support efficient date-range queries and daily OEE dashboard aggregations. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Free-text narrative description of the downtime event as entered by the operator, technician, or supervisor in the MES or SAP PM notification. Captures contextual details not covered by structured codes, such as observed symptoms, environmental conditions, or operator observations at the time of failure.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the downtime event, typically generated by the MES (Manufacturing Execution System) or SAP PM (Plant Maintenance) module. Format: DT-{YYYY}-{NNNNNN}. Used for cross-system referencing and shop floor communication.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureModeCode rdf:type rdf:Property ;
    rdfs:label 'Failure Mode Code' ;
    rdfs:comment 'Standardized code identifying the specific failure mode that caused the downtime event, aligned with the FMEA (Failure Mode and Effects Analysis) failure mode library. Examples: electrical fault, hydraulic leak, sensor failure, conveyor jam. Enables FMEA-driven root cause trending and PPAP (Production Part Approval Process) corrective action tracking.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultLocationCode rdf:type rdf:Property ;
    rdfs:label 'Fault Location Code' ;
    rdfs:comment 'SAP PM object part / location code identifying the specific component or sub-assembly on the equipment where the fault occurred (e.g., spindle, conveyor belt, welding gun tip, paint nozzle). Enables component-level failure frequency analysis and spare parts demand forecasting.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isQualityHoldTriggered rdf:type rdf:Property ;
    rdfs:label 'Is Quality Hold Triggered' ;
    rdfs:comment 'Indicates whether the downtime event triggered a quality hold on WIP (Work in Progress) or finished vehicle inventory. True = quality hold was activated; False = no quality hold. Links to SAP QM quality notification and SPC (Statistical Process Control) out-of-control action plans.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeatFailure rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Failure' ;
    rdfs:comment 'Indicates whether this downtime event is a recurrence of a previously recorded failure on the same equipment or work center within a defined lookback period (typically 30 days). True = repeat failure; False = first occurrence. Used to identify chronic equipment issues requiring escalated corrective action under IATF 16949 Section 10.2.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyRelated rdf:type rdf:Property ;
    rdfs:label 'Is Safety Related' ;
    rdfs:comment 'Indicates whether the downtime event involved a safety incident, near-miss, or safety-critical equipment failure (e.g., AGV collision, robot safety stop, lockout/tagout activation). True = safety-related; False = non-safety. Triggers mandatory safety reporting and OSHA/DOT compliance escalation workflows.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceCostLocal rdf:type rdf:Property ;
    rdfs:label 'Maintenance Cost Local' ;
    rdfs:comment 'Total direct maintenance cost incurred to resolve the downtime event, including labor, spare parts, and external service costs, expressed in the plant\'s local currency. Sourced from SAP PM actual cost settlement. Used for cost-of-downtime analysis and CapEx vs. OpEx maintenance budget reporting.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Number' ;
    rdfs:comment 'The SAP Plant Maintenance (PM) notification number (Meldungsnummer) created in SAP S/4HANA to formally record the maintenance request or breakdown notification associated with this downtime event. Enables traceability between the MES downtime record and the SAP PM work order lifecycle.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeAvailabilityLossPct rdf:type rdf:Property ;
    rdfs:label 'Oee Availability Loss Pct' ;
    rdfs:comment 'The percentage of scheduled production time lost due to this downtime event, calculated as (duration_minutes / scheduled_production_time_minutes) × 100. Represents the availability loss component of the OEE (Overall Equipment Effectiveness) metric for the affected work center during the event period. Stored as a business field for direct use in OEE dashboards.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionLossUnits rdf:type rdf:Property ;
    rdfs:label 'Production Loss Units' ;
    rdfs:comment 'Number of vehicle units or production units lost due to the downtime event, based on the planned production rate for the affected work center. Used to quantify the production order impact and schedule recovery requirements.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Free-text field capturing the maintenance technician\'s description of the actions taken to resolve the downtime event and restore production. Complements corrective_action_code with detailed narrative. Stored in the Silver layer for use in AI/ML-based predictive maintenance model training.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardized code identifying the confirmed root cause of the downtime event after investigation, aligned with the SAP PM cause code catalog. Distinct from failure_mode_code which captures the symptom; root_cause_code captures the underlying reason (e.g., inadequate lubrication, worn tooling, incorrect setup, supplier part defect).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaAlarmCode rdf:type rdf:Property ;
    rdfs:label 'Scada Alarm Code' ;
    rdfs:comment 'The alarm or fault code generated by the SCADA (Supervisory Control and Data Acquisition) or PLC (Programmable Logic Controller) system at the time the downtime event was triggered. Provides the raw machine-level signal that initiated the downtime record. Used for SCADA-integrated downtime reporting and automated event correlation.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sparePartsConsumed rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Consumed' ;
    rdfs:comment 'Indicates whether spare parts or materials were consumed from inventory to resolve the downtime event. True = spare parts were issued via SAP MM goods issue; False = no parts consumed (e.g., adjustment or reset only). Drives spare parts demand planning and MRP (Material Requirements Planning) replenishment.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'The exact date and time when the downtime event began, as recorded by the MES or SCADA system. This is the principal real-world event time used for duration calculation and shift-level reporting. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:timeToRepairMinutes rdf:type rdf:Property ;
    rdfs:label 'Time To Repair Minutes' ;
    rdfs:comment 'Elapsed time in minutes from when the maintenance team began active repair work to when the equipment was restored to operational status. Distinct from duration_minutes (total downtime) and time_to_respond_minutes (response lag). Core component of MTTR (Mean Time to Repair) KPI calculation.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeToRespondMinutes rdf:type rdf:Property ;
    rdfs:label 'Time To Respond Minutes' ;
    rdfs:comment 'Elapsed time in minutes between the downtime event start_timestamp and the time the responsible maintenance or production team acknowledged and began responding to the event. Key metric for maintenance response SLA (Service Level Agreement) compliance and MTTR (Mean Time to Repair) component analysis.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'The SAP PM maintenance work order number (Auftragsnummer) issued to address the downtime event. Distinct from the production order; this is the corrective or preventive maintenance order raised by the maintenance team in SAP PM.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apqpPlanId rdf:type rdf:Property ;
    rdfs:label 'Apqp Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.apqp_plan. Business justification: Production BOMs are released through APQP gates; ppap_status and apqp_phase on production_bom require traceability to the governing APQP plan. IATF 16949 APQP requires BOM-to-APQP-plan linkage for des' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApqpPlan .

ind:assemblyPartMasterId rdf:type rdf:Property ;
    rdfs:label 'Assembly Part Master Id' ;
    rdfs:comment 'Foreign key linking to engineering.part_master. Business justification: The production BOM header references the top-level assembly part (finished vehicle or major subassembly) in part_master — standard SAP MBOM pattern. Required for cost rollup, PPAP submission, and engi' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartMaster .

ind:modelId rdf:type rdf:Property ;
    rdfs:label 'Model Id' ;
    rdfs:comment 'Foreign key linking to vehicle.model. Business justification: BOM Management Report requires each BOM to be tied to a vehicle model to ensure correct component list per model.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Model .

ind:primaryProductionEbomReferenceBomId rdf:type rdf:Property ;
    rdfs:label 'Primary Production Ebom Reference Bom Id' ;
    rdfs:comment 'Reference identifier linking this manufacturing BOM (mBOM) to the originating engineering BOM (eBOM) in Siemens Teamcenter PLM or PTC Windchill. Enables traceability from shop floor execution back to the engineering design intent. The eBOM-to-mBOM transformation is managed via the PLM-SAP integration.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bom .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date on which this manufacturing BOM received formal approval from the designated authority. Precedes the release_date in the BOM lifecycle workflow. Required for IATF 16949 documented information control.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apqpPhase rdf:type rdf:Property ;
    rdfs:label 'Apqp Phase' ;
    rdfs:comment 'Current APQP phase associated with this BOM\'s program lifecycle. Phase 1=Plan and Define, Phase 2=Product Design and Development, Phase 3=Process Design and Development, Phase 4=Product and Process Validation, Phase 5=Launch/Feedback. Tracks BOM maturity relative to the program development gate.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyType rdf:type rdf:Property ;
    rdfs:label 'Assembly Type' ;
    rdfs:comment 'Indicates whether the vehicle is assembled as a Completely Built Unit (CBU), Completely Knocked Down (CKD) kit for overseas assembly, or Semi Knocked Down (SKD) kit. Determines the BOM structure, component packaging, and applicable customs/import regulations for the target market.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseQuantity rdf:type rdf:Property ;
    rdfs:label 'Base Quantity' ;
    rdfs:comment 'The base quantity of the header material for which the BOM component quantities are defined (e.g., 1 vehicle). All component quantities in the BOM are expressed relative to this base quantity. Corresponds to the SAP BOM header base quantity field.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the BOM base quantity (e.g., \'EA\' for each/vehicle, \'PC\' for piece, \'SET\' for set). Corresponds to the SAP material master base unit of measure. Ensures consistent quantity calculations during MRP explosion and production order processing. [ENUM-REF-CANDIDATE: EA|PC|KG|L|M|M2|M3|SET — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomAlternative rdf:type rdf:Property ;
    rdfs:label 'Bom Alternative' ;
    rdfs:comment 'SAP BOM alternative identifier (e.g., \'01\', \'02\') distinguishing multiple valid BOM configurations for the same material and plant. Supports variant BOMs for different production lines or regional configurations (e.g., LHD vs RHD, CKD vs SKD).' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomDescription rdf:type rdf:Property ;
    rdfs:label 'Bom Description' ;
    rdfs:comment 'Human-readable description of the manufacturing BOM, typically including the vehicle model, model year, plant, and key configuration attributes (e.g., \'2025 F-150 XLT 3.5L EcoBoost AWD – Detroit Assembly Plant – MY2025 Production BOM\'). Used for display in SAP, Teamcenter PLM, and reporting tools.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomLevel rdf:type rdf:Property ;
    rdfs:label 'Bom Level' ;
    rdfs:comment 'The maximum depth/level of the BOM hierarchy for this manufacturing BOM (e.g., 1 = single-level, 5 = five levels deep). Used to understand BOM complexity and to control multi-level BOM explosion in MRP and production scheduling.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle state of the manufacturing BOM. \'draft\' indicates the BOM is under engineering review. \'released\' means it has been authorized for production use. \'frozen\' indicates no further changes are permitted (e.g., during active production run). \'superseded\' means a newer BOM version has replaced it. \'obsolete\' means the BOM is no longer valid.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomType rdf:type rdf:Property ;
    rdfs:label 'Bom Type' ;
    rdfs:comment 'Classification of the BOM by its intended use in the manufacturing process. \'production\' is the standard mBOM used on the shop floor. \'phantom\' represents sub-assemblies that are not stocked. \'sales\' is used for variant configuration. \'spare_parts\' is for after-sales service. \'co_product\' is for by-products in manufacturing.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomUsage rdf:type rdf:Property ;
    rdfs:label 'Bom Usage' ;
    rdfs:comment 'SAP BOM usage indicator defining the organizational context in which the BOM is applied. \'production\' (SAP usage 1) is the standard for shop floor manufacturing. \'engineering\' (SAP usage 2) is for design/development. \'universal\' (SAP usage 3) applies across all usages. Determines which BOM is selected during MRP and production order processing.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Free-text description of the business reason for creating or modifying this BOM version (e.g., \'Cost reduction – substitute supplier for part X\', \'Regulatory compliance – CARB Tier 3 emission update\', \'Quality improvement – NVH fix per TSB-2024-001\'). Required for IATF 16949 change control documentation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentCount rdf:type rdf:Property ;
    rdfs:label 'Component Count' ;
    rdfs:comment 'Total number of distinct component line items (BOM positions) in this manufacturing BOM. Provides a quick indicator of BOM complexity and is used for completeness validation during BOM release. Does not include phantom sub-assembly components.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ecoNumber rdf:type rdf:Property ;
    rdfs:label 'Eco Number' ;
    rdfs:comment 'The Engineering Change Order (ECO) number that authorized the creation or last modification of this manufacturing BOM. Provides full traceability from the shop floor BOM back to the formal engineering change management process in Teamcenter PLM. Required for IATF 16949 change control compliance.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivityEndDate rdf:type rdf:Property ;
    rdfs:label 'Effectivity End Date' ;
    rdfs:comment 'The date after which this manufacturing BOM version is no longer valid for production use. Corresponds to the SAP BOM \'Valid To\' date. Null indicates the BOM is open-ended with no planned expiry. Used to manage BOM transitions during model year changeovers and End of Production (EOP).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivityStartDate rdf:type rdf:Property ;
    rdfs:label 'Effectivity Start Date' ;
    rdfs:comment 'The date from which this manufacturing BOM version becomes effective and valid for production use. Corresponds to the SAP BOM \'Valid From\' date. Used for date-effective BOM explosion in MRP and production order creation. Aligns with Start of Production (SOP) planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:homologationStatus rdf:type rdf:Property ;
    rdfs:label 'Homologation Status' ;
    rdfs:comment 'Status of the regulatory homologation (type approval) for the vehicle configuration defined by this BOM in the target regulatory market. \'approved\' is required before vehicles built to this BOM can be legally sold in the target market. Managed through the Regulatory Compliance and Homologation process.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConfigurable rdf:type rdf:Property ;
    rdfs:label 'Is Configurable' ;
    rdfs:comment 'Indicates whether this BOM uses SAP Variant Configuration (VC) to support multiple vehicle variants from a single configurable BOM structure. True = configurable BOM with characteristic-based component selection. False = fixed BOM for a single specific vehicle configuration.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPhantomAssembly rdf:type rdf:Property ;
    rdfs:label 'Is Phantom Assembly' ;
    rdfs:comment 'Indicates whether the header material of this BOM is a phantom assembly — a logical grouping of components that is not physically stocked or produced as a discrete unit. Phantom assemblies are \'exploded through\' during MRP and production order processing. Common for sub-assemblies in JIS manufacturing.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this manufacturing BOM record in the source system. Used to detect changes during incremental data loads into the Databricks Silver Layer and to support BOM change history auditing required by IATF 16949.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ppapStatus rdf:type rdf:Property ;
    rdfs:label 'Ppap Status' ;
    rdfs:comment 'Status of the Production Part Approval Process (PPAP) for the components in this BOM. PPAP is the AIAG/IATF 16949 process that verifies supplier components meet design and specification requirements before production launch. \'approved\' is required before the BOM can be released to production.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predecessorBomNumber rdf:type rdf:Property ;
    rdfs:label 'Predecessor Bom Number' ;
    rdfs:comment 'BOM number of the previous manufacturing BOM version that this BOM supersedes. Enables backward navigation in the BOM version chain for change impact analysis and quality investigations. Null for the initial BOM version.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMarketCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Market Code' ;
    rdfs:comment 'Code identifying the target regulatory market for which this BOM is homologated (e.g., \'US-FEDERAL\', \'US-CARB\', \'EU-EURO6\', \'JP-JC08\', \'CN-CHINA6\'). Determines applicable emissions standards (EPA, CARB, Euro 6, WLTP), safety regulations (NHTSA FMVSS, UNECE), and CAFE compliance requirements.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'The date on which this manufacturing BOM was formally released to production (status changed to \'released\'). Marks the point at which the BOM is authorized for use in production orders and MRP planning. Corresponds to the SAP BOM release date.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releasedBy rdf:type rdf:Property ;
    rdfs:label 'Released By' ;
    rdfs:comment 'User ID or employee identifier of the manufacturing engineer or release authority who formally released this BOM to production in SAP PP or Teamcenter PLM. Required for audit trail and change control compliance under IATF 16949.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionLevel rdf:type rdf:Property ;
    rdfs:label 'Revision Level' ;
    rdfs:comment 'Alphanumeric revision level of the BOM (e.g., \'A\', \'B\', \'C\' or \'01\', \'02\'). Used in conjunction with bom_version to track incremental changes within a version. Aligns with SAP BOM revision level and Teamcenter PLM revision management.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByBomNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Bom Number' ;
    rdfs:comment 'BOM number of the newer manufacturing BOM that has replaced this one (populated when bom_status = \'superseded\'). Enables forward navigation in the BOM version chain for traceability and historical analysis. Null when this is the current active BOM.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleConfigurationCode rdf:type rdf:Property ;
    rdfs:label 'Vehicle Configuration Code' ;
    rdfs:comment 'Code identifying the specific vehicle configuration (variant) for which this BOM is defined, including body style, drivetrain, trim level, and market variant (e.g., \'SUV-AWD-PREMIUM-NA\'). Used in SAP Variant Configuration (VC) to select the correct BOM components for a specific vehicle order.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomComponentId rdf:type rdf:Property ;
    rdfs:label 'Bom Component Id' ;
    rdfs:comment 'Unique surrogate identifier for a single line-item record within a manufacturing Bill of Materials (BOM). Serves as the primary key for this entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BomComponent .

ind:partMasterId rdf:type rdf:Property ;
    rdfs:label 'Part Master Id' ;
    rdfs:comment 'Foreign key linking to engineering.part_master. Business justification: BOM components need a direct link to part_master for detailed specs; part_number/description are denormalized and will be removed.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartMaster .

ind:alternatePartGroup rdf:type rdf:Property ;
    rdfs:label 'Alternate Part Group' ;
    rdfs:comment 'Code identifying the alternate item group to which this component belongs in the BOM. Components within the same alternate group are interchangeable. Used in SAP BOM alternative item management for production flexibility.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternatePartNumber rdf:type rdf:Property ;
    rdfs:label 'Alternate Part Number' ;
    rdfs:comment 'OEM part number of an approved alternate or substitute component that can be used in place of the primary part when the primary is unavailable. Supports supply chain continuity and JIT material substitution.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backflushIndicator rdf:type rdf:Property ;
    rdfs:label 'Backflush Indicator' ;
    rdfs:comment 'Indicates whether this component is backflushed (automatically goods-issued upon production order confirmation) rather than requiring a discrete goods movement transaction. True = backflush; False = manual goods issue required. Common for bulk and low-value components.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bulkMaterialIndicator rdf:type rdf:Property ;
    rdfs:label 'Bulk Material Indicator' ;
    rdfs:comment 'Flags this component as a bulk material (e.g., adhesives, lubricants, fasteners) that is issued to the production order without discrete picking or goods movement. Bulk materials are typically excluded from MRP individual requirements.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coProductIndicator rdf:type rdf:Property ;
    rdfs:label 'Co Product Indicator' ;
    rdfs:comment 'Flags this BOM item as a co-product or by-product that is produced alongside the primary output (e.g., stamping offcuts, recycled materials). Co-products receive a portion of the production order cost allocation.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commodityCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Code' ;
    rdfs:comment 'Procurement commodity classification code grouping this component into a spend category (e.g., \'ELEC-ECU\', \'BODY-STAMPING\', \'POWERTRAIN-EV-BATTERY\'). Used in supply chain management (SCM), RFQ processes, and supplier performance reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentStatus rdf:type rdf:Property ;
    rdfs:label 'Component Status' ;
    rdfs:comment 'Current lifecycle status of this BOM component line. \'superseded\' indicates the part has been replaced by an alternate; \'pending_approval\' indicates the component is awaiting PPAP (Production Part Approval Process) sign-off before use in production.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Classification of the BOM item indicating how it is sourced and consumed in the manufacturing process. \'phantom\' denotes a logical grouping with no physical stock; \'bulk_material\' denotes items issued without discrete picking. [ENUM-REF-CANDIDATE: raw_material|purchased_part|sub_assembly|phantom|co_product|bulk_material — promote to reference product]' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawingNumber rdf:type rdf:Property ;
    rdfs:label 'Drawing Number' ;
    rdfs:comment 'Reference to the CAD/CAE engineering drawing or 3D model document number associated with this component, as managed in CATIA/ENOVIA or PTC Windchill. Enables traceability from the manufacturing BOM back to the design definition.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawingRevision rdf:type rdf:Property ;
    rdfs:label 'Drawing Revision' ;
    rdfs:comment 'Revision level of the engineering drawing or CAD model applicable to this BOM component (e.g., \'A\', \'B\', \'01\'). Ensures the correct design revision is used in production and supports PPAP documentation.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineeringChangeNumber rdf:type rdf:Property ;
    rdfs:label 'Engineering Change Number' ;
    rdfs:comment 'Reference to the Engineering Change Notice (ECN) or Engineering Change Order (ECO) that introduced or last modified this BOM component line. Provides full traceability of design changes from PLM through to the manufacturing BOM.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaReference rdf:type rdf:Property ;
    rdfs:label 'Fmea Reference' ;
    rdfs:comment 'Document reference number for the Design FMEA (DFMEA) or Process FMEA (PFMEA) associated with this component. Supports APQP (Advanced Product Quality Planning) traceability and IATF 16949 risk management requirements.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Indicator' ;
    rdfs:comment 'Flags this component as containing hazardous materials subject to regulatory controls (e.g., lead, cadmium, hexavalent chromium under EU ELV Directive, or lithium battery cells under UN 38.3). Triggers special handling, storage, and disposal procedures.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installationSequence rdf:type rdf:Property ;
    rdfs:label 'Installation Sequence' ;
    rdfs:comment 'Numeric sequence defining the order in which this component is installed relative to other components at the same work center. Critical for JIS (Just-in-Sequence) material call-offs and shop floor assembly instruction generation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'SAP BOM item category code indicating how the component is managed in inventory and procurement (e.g., stock item \'L\', non-stock item \'N\', variable-size item \'R\'). Drives material requirements planning (MRP) and goods movement behavior.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadOffsetDays rdf:type rdf:Property ;
    rdfs:label 'Lead Offset Days' ;
    rdfs:comment 'Number of days before or after the parent order start date that this component must be available at the work center. Negative values indicate the component must arrive before the order start. Used in JIT/JIS scheduling and MRP net requirements calculation.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationNumber rdf:type rdf:Property ;
    rdfs:label 'Operation Number' ;
    rdfs:comment 'Four-digit SAP routing operation number to which this BOM component is assigned. Links the component to the specific assembly step in the production routing, enabling shop floor assembly instruction generation and MES work order sequencing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phantomAssemblyIndicator rdf:type rdf:Property ;
    rdfs:label 'Phantom Assembly Indicator' ;
    rdfs:comment 'Indicates whether this component is a phantom assembly — a logical grouping used for BOM structuring that has no physical stock or production order. MRP explodes through phantom assemblies to plan the underlying components directly.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityInAltGroup rdf:type rdf:Property ;
    rdfs:label 'Priority In Alt Group' ;
    rdfs:comment 'Numeric priority rank of this component within its alternate item group. Lower numbers indicate higher preference. MRP uses this priority to determine which alternate to consume first when multiple substitutes are available.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityPerVehicle rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Vehicle' ;
    rdfs:comment 'Number of units of this component required to build one complete vehicle or parent assembly. Supports fractional quantities for bulk materials (e.g., 0.5 litres of adhesive). Used in MRP material call-off calculations and JIT/JIS scheduling.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachSvhcIndicator rdf:type rdf:Property ;
    rdfs:label 'Reach Svhc Indicator' ;
    rdfs:comment 'Indicates whether this component contains a Substance of Very High Concern (SVHC) as defined under EU REACH Regulation (EC) No 1907/2006. Required for regulatory compliance reporting and customer disclosure obligations.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scrapFactorPct rdf:type rdf:Property ;
    rdfs:label 'Scrap Factor Pct' ;
    rdfs:comment 'Expected percentage of this component that will be scrapped during the manufacturing process, expressed as a decimal percentage (e.g., 2.5000 = 2.5%). Used to inflate the planned component quantity in MRP to account for anticipated process losses. Supports PPM (Parts Per Million) defect tracking.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Usage Probability Pct' ;
    rdfs:comment 'Probability (0–100%) that this component will actually be consumed in a given build, used for optional or variant-dependent components. Supports MRP planning for configurable vehicles where not every component is installed on every unit.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variantCondition rdf:type rdf:Property ;
    rdfs:label 'Variant Condition' ;
    rdfs:comment 'Boolean or characteristic-based condition expression that determines when this component is included in a configurable BOM (e.g., \'ENGINE_TYPE = V8 AND MARKET = USA\'). Used in SAP Variant Configuration and Teamcenter product configuration management.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleProgramCode rdf:type rdf:Property ;
    rdfs:label 'Vehicle Program Code' ;
    rdfs:comment 'Internal OEM code identifying the vehicle program or platform to which this BOM component applies (e.g., \'F150-GEN14\', \'EV-PLATFORM-X\'). Supports multi-platform BOM management and cross-program parts commonality analysis.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Net weight of a single unit of this component in kilograms. Used in vehicle weight calculations, CAFE (Corporate Average Fuel Economy) compliance modelling, NVH (Noise Vibration Harshness) analysis, and logistics planning.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Material Consumption Id' ;
    rdfs:comment 'Unique surrogate identifier for each material consumption (goods issue) transaction record on the shop floor. Primary key of this table.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assemblyStationCode rdf:type rdf:Property ;
    rdfs:label 'Assembly Station Code' ;
    rdfs:comment 'Code identifying the specific assembly station or line position (JIS – Just-in-Sequence station) where the material was consumed. More granular than work center; used for shop floor traceability.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Supplier or internal batch/lot number of the consumed material. Critical for traceability, recall management, and IATF 16949 batch traceability requirements. Nullable for non-batch-managed materials.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionStatus rdf:type rdf:Property ;
    rdfs:label 'Consumption Status' ;
    rdfs:comment 'Current lifecycle status of the material consumption record. \'posted\' = goods issue confirmed in SAP; \'reversed\' = goods issue reversed (movement type 262); \'blocked\' = held for quality review; \'pending\' = awaiting MES confirmation.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consumption Timestamp' ;
    rdfs:comment 'The precise date and time when the material was physically issued from stock and consumed at the work center on the shop floor. This is the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:costVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Amount' ;
    rdfs:comment 'Monetary value of the consumption variance (actual cost minus planned cost) in plant currency. Positive = cost overrun; negative = cost saving. Key metric for production cost variance reporting in SAP CO.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsMovementNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Number' ;
    rdfs:comment 'Externally visible SAP material document number generated when the goods issue (movement type 261) is posted. Serves as the business-facing transaction identifier traceable in SAP MM.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsMovementType rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Type' ;
    rdfs:comment 'SAP movement type code indicating the nature of the goods movement (e.g., 261 = goods issue to production order, 262 = reversal, 291 = goods issue to cost center). Drives inventory and cost accounting postings.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCostAmount rdf:type rdf:Property ;
    rdfs:label 'Material Cost Amount' ;
    rdfs:comment 'Standard cost value of the consumed material quantity at the time of goods issue, expressed in the plant currency. Calculated as quantity consumed × standard price from SAP Material Master. Feeds production cost accounting and variance reporting.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Mes Transaction Code' ;
    rdfs:comment 'Unique transaction identifier from the Apriso/Dassault MES system that triggered or confirmed this material consumption event. Enables cross-system reconciliation between MES shop floor execution and SAP MM goods movements.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalGoodsMovementNumber rdf:type rdf:Property ;
    rdfs:label 'Original Goods Movement Number' ;
    rdfs:comment 'Reference to the original SAP material document number that this record reverses. Populated only when reversal_indicator is True. Enables audit trail for reversed consumption transactions.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The accounting posting date for the goods issue in SAP, which may differ from the physical consumption timestamp. Used for period-end cost accounting and production variance reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityConsumed rdf:type rdf:Property ;
    rdfs:label 'Quantity Consumed' ;
    rdfs:comment 'Actual quantity of the material consumed (goods issued) against the production order. Expressed in the base unit of measure of the material. Core quantitative fact for this transaction.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'Difference between actual quantity consumed and planned BOM quantity (actual minus planned). Positive value indicates over-consumption; negative indicates under-consumption. Key input for production variance reporting and cost accounting.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this consumption record is a reversal (cancellation) of a previously posted goods issue. True = this is a reversal document; False = original consumption posting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scrapIndicator rdf:type rdf:Property ;
    rdfs:label 'Scrap Indicator' ;
    rdfs:comment 'Flag indicating whether the consumed material was scrapped (True) rather than incorporated into the vehicle assembly. Scrap consumption is tracked separately for waste reporting, IATF 16949 scrap analysis, and environmental compliance.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scrapReasonCode rdf:type rdf:Property ;
    rdfs:label 'Scrap Reason Code' ;
    rdfs:comment 'Coded reason for material scrap when scrap_indicator is True (e.g., \'DAMAGE\', \'DEFECT\', \'WRONG_PART\', \'PROCESS_LOSS\'). Used for scrap root cause analysis and PPM defect rate reporting. [ENUM-REF-CANDIDATE: DAMAGE|DEFECT|WRONG_PART|PROCESS_LOSS|HANDLING_ERROR|SUPPLIER_DEFECT|OTHER — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Individual serial number of the consumed component where serial number management is active (e.g., ECU, battery module, transmission). Enables unit-level traceability for safety-critical parts. Nullable for non-serialized materials.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Code identifying the operational system of record from which this consumption record originated (SAP_MM = SAP S/4HANA MM goods movement, MES_APRISO = Apriso/Dassault MES, SAP_PP = SAP Production Planning, MANUAL = manual entry). Supports data lineage in the lakehouse.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Number' ;
    rdfs:comment 'SAP vendor/supplier number of the supplier who provided the consumed material. Used for supplier-level consumption analysis, PPAP traceability, and supply chain variance reporting.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Quantity variance expressed as a percentage of the planned BOM quantity ((actual - planned) / planned × 100). Used for threshold-based alerting and PPM (Parts Per Million) defect rate analysis.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wipOrderSequence rdf:type rdf:Property ;
    rdfs:label 'Wip Order Sequence' ;
    rdfs:comment 'Sequential position of this consumption event within the production order\'s WIP (Work in Progress) processing sequence. Used for JIS (Just-in-Sequence) ordering analysis and shop floor flow traceability.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reworkOrderId rdf:type rdf:Property ;
    rdfs:label 'Rework Order Id' ;
    rdfs:comment 'Unique surrogate identifier for the rework order record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualReworkHours rdf:type rdf:Property ;
    rdfs:label 'Actual Rework Hours' ;
    rdfs:comment 'Actual labor hours consumed to complete the rework operation, recorded upon order completion in MES or SAP PM. Compared against planned hours for efficiency analysis and cost variance reporting.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomComponentNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Component Number' ;
    rdfs:comment 'The BOM (Bill of Materials) component or part number of the specific sub-assembly or component requiring rework. References the engineering BOM managed in Siemens Teamcenter or SAP MM.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionReference rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Reference' ;
    rdfs:comment 'Reference number or identifier of the corrective action (CAR) or 8D problem-solving report raised in response to this rework event. Links the rework order to the formal quality improvement process.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCode rdf:type rdf:Property ;
    rdfs:label 'Defect Code' ;
    rdfs:comment 'Standardized defect classification code identifying the type of nonconformance that triggered the rework order. Aligns with the plant defect code catalogue maintained in SAP QM or MES quality module.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Free-text narrative description of the defect or nonconformance identified during in-process quality inspection that initiated this rework order. Captured by the quality inspector or MES operator.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectLocationCode rdf:type rdf:Property ;
    rdfs:label 'Defect Location Code' ;
    rdfs:comment 'Standardized code identifying the physical location or zone on the vehicle or sub-assembly where the defect was found (e.g., body zone, paint zone, chassis area). Used for spatial defect analysis and NVH (Noise Vibration Harshness) correlation.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethodCode rdf:type rdf:Property ;
    rdfs:label 'Detection Method Code' ;
    rdfs:comment 'Code indicating the method by which the defect was detected prior to rework order creation (e.g., visual inspection, automated gauge check, functional test, quality audit, customer feedback). Supports FMEA (Failure Mode and Effects Analysis) detection ranking analysis.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Date and time when the nonconformance was originally detected during in-process quality inspection, triggering the creation of this rework order. The principal business event timestamp for this transaction.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'Final disposition decision for the nonconforming unit after rework evaluation. Repaired indicates successful correction; scrapped indicates the unit is unrecoverable; concession (use-as-is) indicates acceptance of the nonconformance with documented deviation; return to supplier applies to purchased components.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPointCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Point Code' ;
    rdfs:comment 'Code identifying the specific quality inspection checkpoint or gate (e.g., body-in-white audit, paint final audit, end-of-line check) at which the defect was detected and the rework order was initiated.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatoryHold rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Hold' ;
    rdfs:comment 'Indicates whether the vehicle or sub-assembly is placed on a regulatory hold pending rework completion and re-inspection. A regulatory hold prevents the unit from advancing to the next production stage or shipping.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineStoppageFlag rdf:type rdf:Property ;
    rdfs:label 'Line Stoppage Flag' ;
    rdfs:comment 'Indicates whether this rework event caused a production line stoppage (Andon pull or line stop). Used for OEE (Overall Equipment Effectiveness) impact analysis and production downtime reporting.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedReworkHours rdf:type rdf:Property ;
    rdfs:label 'Planned Rework Hours' ;
    rdfs:comment 'Estimated labor hours planned to complete the rework operation, as defined in the rework routing or standard repair time (SRT) catalogue. Used for capacity planning and cost estimation.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority assigned to the rework order to drive scheduling and resource allocation on the shop floor. Critical priority typically indicates a safety-related or regulatory nonconformance requiring immediate resolution.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Re Inspection Required' ;
    rdfs:comment 'Indicates whether a formal re-inspection is required after rework completion before the unit can be released to the next production stage or shipped. Mandatory for safety-related or regulatory nonconformances.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Re Inspection Result' ;
    rdfs:comment 'Outcome of the quality re-inspection performed after rework completion. Pass indicates the unit meets specification; fail triggers a secondary rework or scrap decision; conditional pass indicates acceptance with documented deviation.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkAttemptCount rdf:type rdf:Property ;
    rdfs:label 'Rework Attempt Count' ;
    rdfs:comment 'Number of rework attempts made on this unit or component for the same defect. Multiple rework attempts on the same unit indicate a chronic quality issue and may trigger escalation or scrap decision per quality policy.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reworkInstructionReference rdf:type rdf:Property ;
    rdfs:label 'Rework Instruction Reference' ;
    rdfs:comment 'Document number or reference to the approved rework instruction, repair standard, or Technical Service Bulletin (TSB) that governs the rework procedure. Ensures traceability to authorized repair methods.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkLaborCost rdf:type rdf:Property ;
    rdfs:label 'Rework Labor Cost' ;
    rdfs:comment 'Total internal labor cost incurred for the rework operation, calculated from actual rework hours and the applicable labor rate. Expressed in the plant\'s operating currency. Used for quality cost (Cost of Poor Quality - COPQ) reporting.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reworkMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Rework Material Cost' ;
    rdfs:comment 'Cost of replacement parts and materials consumed during the rework operation. Sourced from SAP MM goods issue postings against the rework order. Contributes to total Cost of Poor Quality (COPQ) calculation.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reworkOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Rework Order Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the rework order, typically generated by the MES (Manufacturing Execution System) or SAP QM module. Format: RWK-{PlantCode}-{Year}-{Sequence}.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Rework Order Status' ;
    rdfs:comment 'Current lifecycle status of the rework order within the shop floor execution workflow. Tracks progression from creation through completion or cancellation as managed in MES or SAP QM.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkType rdf:type rdf:Property ;
    rdfs:label 'Rework Type' ;
    rdfs:comment 'Classification of the rework operation method. Inline repair is performed on the moving assembly line; offline rework removes the unit from the line; teardown involves partial or full disassembly; subassembly rework targets a component before vehicle integration; cosmetic repair addresses surface or finish defects. [ENUM-REF-CANDIDATE: inline_repair|offline_rework|teardown|subassembly_rework|cosmetic_repair|field_return_rework — promote to reference product]' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Production Confirmation Id' ;
    rdfs:comment 'Unique surrogate identifier for the production confirmation record in the Databricks Silver Layer. Primary key for this entity. Entity Role: TRANSACTION_HEADER — represents a discrete business event (completion of a production order or partial operation) with a clear lifecycle.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversedConfirmationProductionConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Reversed Confirmation Production Confirmation Id' ;
    rdfs:comment 'Reference to the original production confirmation record that this entry reverses. Populated only when reversal_indicator is True. Enables audit trail reconstruction and net quantity calculation when reversals are present. Self-referencing within the production_confirmation product.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionConfirmation .

ind:activityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Activity Type Code' ;
    rdfs:comment 'SAP CO activity type (LSTAR) used to record the confirmed actual activities (setup, machine, labor) against the production order. Drives cost settlement rates and actual cost calculation in SAP CO-PC (Product Costing). Required for standard vs. actual cost variance analysis.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationEntryMode rdf:type rdf:Property ;
    rdfs:label 'Confirmation Entry Mode' ;
    rdfs:comment 'Method by which this production confirmation was entered into SAP PP. \'manual\' = entered by operator via CO11N; \'automatic\' = system-generated via PP-PI or SCADA integration; \'mes_interface\' = posted via Apriso/Dassault MES interface; \'backflush\' = automatic backflush confirmation triggered by goods issue. Used for data quality auditing and process automation tracking.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Externally-known alphanumeric confirmation number assigned by SAP PP (CO11N) at the time of posting. This is the business-facing identifier used in shop floor reporting, MES integration, and order settlement reconciliation. Maps to SAP field RUECK (Confirmation Number).' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'Current lifecycle status of the production confirmation record. \'created\' = confirmation entered but not yet posted; \'posted\' = successfully posted to SAP PP and inventory updated; \'reversed\' = confirmation reversed via CO13; \'cancelled\' = voided before posting; \'partial\' = partial quantity confirmed, order still open; \'final\' = final confirmation closing the production order.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'The principal real-world event timestamp recording when the production operation or order was confirmed as complete on the shop floor. This is the business event time (not the system posting time) and represents the actual completion moment. Maps to SAP PP fields BUDAT (posting date) + ISDD/ISDZ (actual execution date/time). Used for takt time analysis, shift output reporting, and production scheduling.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationType rdf:type rdf:Property ;
    rdfs:label 'Confirmation Type' ;
    rdfs:comment 'Classification of the confirmation indicating whether it is a partial confirmation (interim progress), final confirmation (order completion), automatic system-generated confirmation, milestone-based confirmation, or a reversal entry. Determines downstream SAP PP processing logic including order closure and goods receipt.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeDurationMin rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Min' ;
    rdfs:comment 'Total unplanned downtime duration recorded during this production confirmation period, in minutes. Captured from SCADA/PLC systems or MES downtime tracking. Used for OEE (Overall Equipment Effectiveness) availability calculation, maintenance planning, and production loss analysis.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Downtime Reason Code' ;
    rdfs:comment 'Coded reason for any downtime recorded during this confirmation period. Maps to the plant\'s downtime reason catalog (e.g., \'MECH\' = Mechanical Failure, \'MATL\' = Material Shortage, \'QUAL\' = Quality Hold, \'CHNG\' = Changeover). Used for root cause analysis, maintenance prioritization, and production loss reporting.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalConfirmationFlag rdf:type rdf:Property ;
    rdfs:label 'Final Confirmation Flag' ;
    rdfs:comment 'Indicates whether this confirmation is the final confirmation for the production order (SAP PP IEDD — Final Confirmation Indicator). When True, SAP PP automatically closes the production order, triggers goods receipt for the finished product, and initiates order settlement to CO (Controlling). Critical for order lifecycle management and inventory accuracy.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Posted Flag' ;
    rdfs:comment 'Indicates whether the automatic goods receipt (GR) to inventory has been successfully posted as a result of this production confirmation. True = inventory has been updated with the confirmed yield quantity. Used for inventory reconciliation and to identify confirmations where GR posting failed or is pending.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborTimeActualMin rdf:type rdf:Property ;
    rdfs:label 'Labor Time Actual Min' ;
    rdfs:comment 'Actual direct labor time consumed for this production operation, recorded in minutes. Maps to SAP PP activity type for labor (ISRLA — Actual Labor Time). Used for labor cost settlement to the production order, workforce productivity analysis, and standard vs. actual cost variance reporting.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborTimePlannedMin rdf:type rdf:Property ;
    rdfs:label 'Labor Time Planned Min' ;
    rdfs:comment 'Planned direct labor time for this operation as defined in the SAP PP routing, recorded in minutes. Baseline for labor efficiency variance analysis and standard cost calculation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:machineTimeActualMin rdf:type rdf:Property ;
    rdfs:label 'Machine Time Actual Min' ;
    rdfs:comment 'Actual machine runtime consumed for this production operation, recorded in minutes. Maps to SAP PP activity type for machine time (ISRÜT — Actual Machine Time). Core input for OEE calculation, takt time variance analysis, and capacity utilization reporting. Compared against planned machine time from the routing to identify bottlenecks.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:machineTimePlannedMin rdf:type rdf:Property ;
    rdfs:label 'Machine Time Planned Min' ;
    rdfs:comment 'Planned machine time for this operation as defined in the SAP PP routing, recorded in minutes. Baseline for actual vs. planned machine time variance analysis and takt time adherence reporting.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'SAP material number (MATNR) of the finished or semi-finished product being confirmed. Identifies the vehicle model, sub-assembly, or component produced in this confirmation. Essential for inventory goods receipt posting and BOM (Bill of Materials) reconciliation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesConfirmationReference rdf:type rdf:Property ;
    rdfs:label 'Mes Confirmation Reference' ;
    rdfs:comment 'The confirmation or transaction reference number from the Apriso/Dassault MES system that corresponds to this SAP PP production confirmation. Enables cross-system traceability between the MES shop floor execution record and the SAP ERP confirmation posting. Critical for audit trails and discrepancy resolution.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderSettlementStatus rdf:type rdf:Property ;
    rdfs:label 'Order Settlement Status' ;
    rdfs:comment 'Status of the SAP CO production order settlement triggered by this final confirmation. \'pending\' = settlement not yet executed; \'settled\' = actual costs fully settled to cost objects; \'partially_settled\' = partial settlement completed; \'not_required\' = non-final confirmation, settlement not applicable. Used for period-end closing and financial reporting.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTimeActualMin rdf:type rdf:Property ;
    rdfs:label 'Setup Time Actual Min' ;
    rdfs:comment 'Actual machine/workstation setup time consumed for this operation, recorded in minutes. Maps to SAP PP activity type for setup (ISRST — Actual Setup Time). Used for capacity planning, OEE (Overall Equipment Effectiveness) calculation, and comparison against planned setup time from the routing.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:setupTimePlannedMin rdf:type rdf:Property ;
    rdfs:label 'Setup Time Planned Min' ;
    rdfs:comment 'Planned setup time for this operation as defined in the SAP PP routing, recorded in minutes. Provides the baseline for actual vs. planned setup time variance analysis. Sourced from the routing master data at the time of production order creation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taktTimeActualSec rdf:type rdf:Property ;
    rdfs:label 'Takt Time Actual Sec' ;
    rdfs:comment 'Actual takt time achieved for this production confirmation, expressed in seconds per unit. Calculated as total operation time divided by yield quantity. Used for production line balancing, bottleneck identification, and comparison against the planned takt time to assess line efficiency. Key metric in JIS (Just-in-Sequence) production management.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teardownTimeActualMin rdf:type rdf:Property ;
    rdfs:label 'Teardown Time Actual Min' ;
    rdfs:comment 'Actual teardown/cleanup time consumed after the production operation, recorded in minutes. Maps to SAP PP activity type for teardown. Included in total operation time for accurate takt time and capacity utilization calculations. Relevant for paint booth cleaning, tooling changeover, and AGV (Automated Guided Vehicle) repositioning cycles.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Yield Quantity' ;
    rdfs:comment 'The confirmed good quantity (yield) produced in this confirmation, expressed in the base unit of measure of the material. Represents the number of units that passed quality inspection and are accepted into inventory. Maps to SAP PP field LMNGA (Yield Quantity). Core metric for production output reporting and OTD (On-Time Delivery) tracking.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityPlanId rdf:type rdf:Property ;
    rdfs:label 'Capacity Plan Id' ;
    rdfs:comment 'Unique surrogate identifier for each capacity plan record in the manufacturing domain. Primary key for the capacity_plan data product.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bottleneckWorkCenterId rdf:type rdf:Property ;
    rdfs:label 'Bottleneck Work Center Id' ;
    rdfs:comment 'Reference to the work center identified as the capacity bottleneck constraining overall line throughput during this planning period. Used to prioritize capacity improvement investments and focus S&OP constraint management.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:fleetContractId rdf:type rdf:Property ;
    rdfs:label 'Fleet Contract Id' ;
    rdfs:comment 'Foreign key linking to sales.fleet_contract. Business justification: Fleet contracts with large committed volumes are primary inputs to capacity planning. Automotive capacity planners must know which fleet contracts are driving capacity requirements to justify headcoun' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FleetContract .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the capacity plan was formally approved by the designated authority. Marks the transition from \'submitted\' to \'approved\' status in the S&OP governance process.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:availableHours rdf:type rdf:Property ;
    rdfs:label 'Available Hours' ;
    rdfs:comment 'Total scheduled production hours available in the planning period after accounting for planned downtime, shift breaks, and scheduled maintenance. Used in conjunction with rated_capacity_jph to compute rated capacity in units.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bottleneckConstraintDescription rdf:type rdf:Property ;
    rdfs:label 'Bottleneck Constraint Description' ;
    rdfs:comment 'Narrative description of the primary capacity constraint at the bottleneck work center (e.g., \'Paint oven cycle time limits throughput to 58 JPH\', \'Robotic welding cell maintenance window reduces available hours\'). Supports root cause analysis and CapEx justification.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityGapUnits rdf:type rdf:Property ;
    rdfs:label 'Capacity Gap Units' ;
    rdfs:comment 'Difference between planned_production_units and demonstrated_capacity_units, representing the capacity shortfall or surplus for the planning period. Positive value indicates a capacity gap requiring corrective action (overtime, additional shifts, CapEx); negative value indicates surplus capacity.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityPlanType rdf:type rdf:Property ;
    rdfs:label 'Capacity Plan Type' ;
    rdfs:comment 'Classification of the capacity planning methodology used. \'rough_cut\' (RCCP — Rough Cut Capacity Planning) for high-level S&OP; \'detailed\' for work-center-level CRP (Capacity Requirements Planning); \'constraint_based\' for Theory of Constraints analysis; \'what_if\' for scenario planning and CapEx evaluation.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Percent' ;
    rdfs:comment 'Planned capacity utilization rate expressed as a percentage, calculated as (planned_production_units / rated_capacity_units) × 100. Drives S&OP decisions on overtime, additional shifts, and capital investment. Target thresholds are typically 85–95% for automotive assembly.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexAmount rdf:type rdf:Property ;
    rdfs:label 'Capex Amount' ;
    rdfs:comment 'Estimated capital expenditure amount required to address the capacity gap identified in this plan. Expressed in the plant\'s operating currency. Used for CapEx budget submissions and investment approval processes.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexRequired rdf:type rdf:Property ;
    rdfs:label 'Capex Required' ;
    rdfs:comment 'Indicates whether this capacity plan identifies a requirement for capital investment (CapEx) to close a capacity gap (e.g., new tooling, additional robots, facility expansion). Triggers CapEx approval workflow in SAP FI/CO.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeoverHours rdf:type rdf:Property ;
    rdfs:label 'Changeover Hours' ;
    rdfs:comment 'Hours allocated for model changeovers, tooling changes, and line reconfigurations during the planning period. Relevant for mixed-model assembly lines producing multiple vehicle variants (e.g., ICE and BEV on the same line).' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyProductionTarget rdf:type rdf:Property ;
    rdfs:label 'Daily Production Target' ;
    rdfs:comment 'Planned number of vehicles to be produced per working day during the planning period, derived from planned_production_units / working_days. Used for daily MES scheduling and shift-level production targets.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demonstratedCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Demonstrated Capacity Units' ;
    rdfs:comment 'Actual production output achieved in a comparable prior period, used as the realistic baseline for capacity planning. Reflects real-world constraints such as quality losses, minor stoppages, and changeovers. Key input to APQP (Advanced Product Quality Planning) capacity studies.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountRequired rdf:type rdf:Property ;
    rdfs:label 'Headcount Required' ;
    rdfs:comment 'Total direct labor headcount required to execute the planned production volume during the planning period. Used for workforce planning, hiring decisions, and labor cost budgeting in SuccessFactors and SAP CO.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBottleneckConstrained rdf:type rdf:Property ;
    rdfs:label 'Is Bottleneck Constrained' ;
    rdfs:comment 'Indicates whether the capacity plan is constrained by a bottleneck work center that limits overall line throughput below the planned production target. When True, the bottleneck_work_center_id and bottleneck_constraint_description fields are populated.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'Last calendar date of the planning period covered by this capacity plan record. Together with plan_start_date, defines the planning window for capacity supply and demand balancing.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the capacity plan record, used in S&OP (Sales and Operations Planning) communications, SAP PP capacity planning transactions (CM01/CM21), and cross-functional reporting. Format: CP-{PLANT}-{YEAR}-{MONTH}-{SEQ}.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'First calendar date of the planning period covered by this capacity plan record. Used to align capacity supply with demand signals from S&OP and MRP (Material Requirements Planning) runs.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle state of the capacity plan record. \'draft\' indicates work-in-progress; \'submitted\' indicates pending approval; \'approved\' indicates sign-off by S&OP leadership; \'active\' indicates the operative plan driving production scheduling; \'superseded\' indicates replaced by a newer version; \'archived\' indicates historical record.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version identifier of the capacity plan, enabling management of multiple planning iterations (e.g., v1.0, v2.0) within the same planning period. Supports S&OP cycle versioning and plan-over-plan variance analysis.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Planned Downtime Hours' ;
    rdfs:comment 'Total planned downtime hours for the production line during the planning period, including scheduled maintenance, tooling changeovers, model changeovers, and planned shutdowns. Reduces available production hours from the theoretical maximum.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMaintenanceHours rdf:type rdf:Property ;
    rdfs:label 'Planned Maintenance Hours' ;
    rdfs:comment 'Subset of planned downtime hours specifically allocated to preventive and predictive maintenance activities on production equipment. Tracked separately from changeover downtime for maintenance KPI reporting and SAP PM integration.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedOvertimeHours rdf:type rdf:Property ;
    rdfs:label 'Planned Overtime Hours' ;
    rdfs:comment 'Total overtime hours planned for the production line during the planning period to meet production targets beyond standard shift capacity. Feeds into workforce cost planning and labor budget in SAP CO.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedProductionUnits rdf:type rdf:Property ;
    rdfs:label 'Planned Production Units' ;
    rdfs:comment 'Number of vehicles planned for production in the planning period as agreed in the S&OP process. Represents the demand signal that capacity must satisfy. Compared against rated and demonstrated capacity to identify gaps.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningPeriodType rdf:type rdf:Property ;
    rdfs:label 'Planning Period Type' ;
    rdfs:comment 'Granularity of the capacity planning horizon for this record. \'weekly\' supports short-term MES scheduling; \'monthly\' supports S&OP cycles; \'quarterly\' and \'annual\' support CapEx and strategic workforce planning.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningScenario rdf:type rdf:Property ;
    rdfs:label 'Planning Scenario' ;
    rdfs:comment 'Demand scenario underpinning this capacity plan. \'base\' reflects the consensus S&OP forecast; \'optimistic\' reflects upside demand; \'pessimistic\' reflects downside risk; \'stretch\' reflects maximum achievable output. Enables scenario comparison for executive decision-making.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratedCapacityJph rdf:type rdf:Property ;
    rdfs:label 'Rated Capacity Jph' ;
    rdfs:comment 'Theoretical maximum production rate expressed in Jobs Per Hour (JPH) for the production line under ideal conditions. Derived from takt time and line design specifications. Used as the baseline for capacity utilization calculations in S&OP.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratedCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Rated Capacity Units' ;
    rdfs:comment 'Theoretical maximum number of vehicles that can be produced in the planning period, calculated as rated_capacity_jph × available_hours. Represents the upper bound of production capacity for S&OP and CapEx planning.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sapCapacityPlanCode rdf:type rdf:Property ;
    rdfs:label 'Sap Capacity Plan Code' ;
    rdfs:comment 'Source system identifier for this capacity plan record in SAP S/4HANA PP (Production Planning) module, used for data lineage traceability and reconciliation between the lakehouse Silver layer and the operational ERP system.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workingDays rdf:type rdf:Property ;
    rdfs:label 'Working Days' ;
    rdfs:comment 'Number of scheduled working days in the planning period after excluding weekends, public holidays, and planned plant shutdowns. Used to compute daily production targets and available hours.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ecuSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Ecu Specification Id' ;
    rdfs:comment 'Foreign key linking to engineering.ecu_specification. Business justification: Each production variant requires a specific ECU specification governing software version, calibration dataset, and OTA capability for end-of-line programming and homologation. Manufacturing and softwa' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EcuSpecification .

ind:powertrainSpecId rdf:type rdf:Property ;
    rdfs:label 'Powertrain Spec Id' ;
    rdfs:comment 'Foreign key linking to engineering.powertrain_spec. Business justification: Each production variant is governed by a specific engineering powertrain_spec defining assembly parameters, emissions compliance, and PPAP requirements. Manufacturing engineers and APQP teams require ' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PowertrainSpec .

ind:priceConditionId rdf:type rdf:Property ;
    rdfs:label 'Price Condition Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_price_condition. Business justification: Variant-level pricing drives dealer invoice amounts and MSRP in automotive billing. Each production variant (trim, powertrain, options) maps to specific SAP SD price conditions used to generate the ve' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceCondition .

ind:trimLevelId rdf:type rdf:Property ;
    rdfs:label 'Trim Level Id' ;
    rdfs:comment 'Foreign key linking to vehicle.vehicle_trim_level. Business justification: Production variants are built to specific trim levels, driving component allocation, labor standards, and JIS sequencing. Manufacturing scheduling systems require the trim_level FK to determine correc' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrimLevel .

ind:adasLevel rdf:type rdf:Property ;
    rdfs:label 'Adas Level' ;
    rdfs:comment 'SAE J3016 automation level of the ADAS (Advanced Driver Assistance Systems) suite fitted to this production variant: L0 (no automation), L1 (driver assistance), L2 (partial automation), L2_PLUS (enhanced partial automation), L3 (conditional automation). Drives ECU (Electronic Control Unit) software configuration, OTA (Over-the-Air Update) eligibility, and UNECE UN R157 regulatory compliance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyComplexityScore rdf:type rdf:Property ;
    rdfs:label 'Assembly Complexity Score' ;
    rdfs:comment 'Numeric score (1–10) representing the relative assembly complexity of this production variant compared to the base variant on the same production line. Higher scores indicate more assembly operations, longer cycle times, or specialized tooling requirements. Used for JIS (Just-in-Sequence) sequencing optimization to balance line loading and avoid consecutive high-complexity builds.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batteryCapacityKwh rdf:type rdf:Property ;
    rdfs:label 'Battery Capacity Kwh' ;
    rdfs:comment 'Usable battery pack capacity in kilowatt-hours (kWh) for BEV, PHEV, and HEV variants. Null for pure ICE variants. Drives assembly sequencing for battery marriage station, WLTP (Worldwide Harmonised Light Vehicles Test Procedure) range certification, and EPA electric range labelling.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2EmissionGPerKm rdf:type rdf:Property ;
    rdfs:label 'Co2 Emission G Per Km' ;
    rdfs:comment 'Certified CO2 tailpipe emission in grams per kilometre (g/km) under WLTP or NEDC test cycle for this production variant. Used for EU CO2 fleet average compliance (Regulation (EU) 2019/631), CAFE (Corporate Average Fuel Economy) calculations, and vehicle taxation band classification in destination markets.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineDisplacementCc rdf:type rdf:Property ;
    rdfs:label 'Engine Displacement Cc' ;
    rdfs:comment 'Total engine displacement in cubic centimetres (cc) for ICE (Internal Combustion Engine) and HEV/PHEV variants. Null for BEV and FCEV variants. Used for regulatory classification under EPA, CARB, and UNECE emissions standards, and for CAFE (Corporate Average Fuel Economy) fleet averaging calculations.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engineeringChangeLevel rdf:type rdf:Property ;
    rdfs:label 'Engineering Change Level' ;
    rdfs:comment 'Current engineering change revision level for this production variant as managed in Siemens Teamcenter PLM or PTC Windchill (e.g., \'A\', \'B\', \'C1\', \'REV3\'). Tracks design maturity and ensures the correct BOM (Bill of Materials) version is applied during production. Incremented upon each approved engineering change notice (ECN).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelEconomyMpg rdf:type rdf:Property ;
    rdfs:label 'Fuel Economy Mpg' ;
    rdfs:comment 'EPA-certified combined fuel economy in miles per gallon (MPG) for ICE, HEV, and PHEV variants in NAFTA markets. Null for BEV/FCEV variants. Used for CAFE (Corporate Average Fuel Economy) fleet compliance reporting to EPA and consumer window sticker labelling under 49 CFR Part 575.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossVehicleWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Vehicle Weight Kg' ;
    rdfs:comment 'Gross Vehicle Weight Rating (GVWR) in kilograms for this production variant. Used for regulatory classification under DOT FMVSS, UNECE weight regulations, and CAFE (Corporate Average Fuel Economy) fleet averaging. Also drives chassis assembly torque specifications and suspension tuning parameters.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handOfDrive rdf:type rdf:Property ;
    rdfs:label 'Hand Of Drive' ;
    rdfs:comment 'Steering wheel position for this production variant: LHD (Left-Hand Drive) for markets such as USA, Germany; RHD (Right-Hand Drive) for markets such as UK, Japan, Australia. Determines instrument panel assembly variant, steering column routing, and body shop tooling configuration.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCkdEligible rdf:type rdf:Property ;
    rdfs:label 'Is Ckd Eligible' ;
    rdfs:comment 'Indicates whether this production variant can be produced as a CKD (Completely Knocked Down) kit for assembly at an overseas plant (True = CKD eligible). Drives export documentation, customs tariff classification, and overseas plant BOM (Bill of Materials) configuration in SAP MM.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isJisEligible rdf:type rdf:Property ;
    rdfs:label 'Is Jis Eligible' ;
    rdfs:comment 'Indicates whether this production variant is eligible for JIS (Just-in-Sequence) supplier call-off sequencing (True = JIS eligible). JIS-eligible variants require sequenced component delivery synchronized to the build sequence, impacting supplier logistics contracts and MES call-off trigger configuration.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLineCompatible rdf:type rdf:Property ;
    rdfs:label 'Is Line Compatible' ;
    rdfs:comment 'Indicates whether this production variant has been validated as feasible for assembly on the assigned production line (True = compatible, False = not compatible). Serves as the primary gate flag in MES (Manufacturing Execution System) build sequence feasibility validation and JIS (Just-in-Sequence) call-off authorization.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOtaCapable rdf:type rdf:Property ;
    rdfs:label 'Is Ota Capable' ;
    rdfs:comment 'Indicates whether this production variant supports OTA (Over-the-Air) software updates for ECU (Electronic Control Unit) and infotainment systems (True = OTA capable). Drives connected vehicle service provisioning in Geotab/Bosch IoT platform and UNECE UN R156 software update regulatory compliance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxConsecutiveBuilds rdf:type rdf:Property ;
    rdfs:label 'Max Consecutive Builds' ;
    rdfs:comment 'Maximum number of consecutive units of this production variant that can be scheduled back-to-back in the build sequence without violating line balancing or ergonomic constraints. Enforced by MES (Manufacturing Execution System) JIS (Just-in-Sequence) sequencing rules to prevent operator fatigue and tooling overload.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mesVariantReference rdf:type rdf:Property ;
    rdfs:label 'Mes Variant Reference' ;
    rdfs:comment 'Cross-reference identifier for this production variant in the Apriso/Dassault MES (Manufacturing Execution System). Used for real-time build sequence call-off, WIP (Work in Progress) tracking, and quality gate routing on the shop floor.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncapSafetyRating rdf:type rdf:Property ;
    rdfs:label 'Ncap Safety Rating' ;
    rdfs:comment 'Overall NCAP (New Car Assessment Programme) safety star rating achieved by this production variant (1 to 5 stars, or NOT_RATED if not yet assessed). Applicable to Euro NCAP, NHTSA NCAP, or ANCAP depending on destination market. Used for regulatory compliance reporting and marketing communications.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionPackageCode rdf:type rdf:Property ;
    rdfs:label 'Option Package Code' ;
    rdfs:comment 'Code identifying the bundled option package associated with this production variant (e.g., \'TECH_PKG\', \'SAFETY_PKG\', \'LUXURY_PKG\'). Maps to a specific set of BOM (Bill of Materials) components and assembly operations in Siemens Teamcenter PLM and SAP PP configurable material management.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paintProcessType rdf:type rdf:Property ;
    rdfs:label 'Paint Process Type' ;
    rdfs:comment 'Classification of the paint application process required for this production variant: STANDARD (solid colour), METALLIC, PEARL, MATTE, or TWO_TONE. Determines paint booth routing, cure cycle parameters, and paint material BOM (Bill of Materials) components in the body shop and paint shop assembly stages.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRegion rdf:type rdf:Property ;
    rdfs:label 'Regulatory Region' ;
    rdfs:comment 'Regulatory compliance region grouping for this production variant, used to apply the correct homologation ruleset: NAFTA (North America), EU (European Union), APAC (Asia-Pacific), LATAM (Latin America), MEA (Middle East & Africa), CHINA. Determines applicable NCAP (New Car Assessment Programme) standards, emissions regulations, and safety certification requirements.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardBuildHours rdf:type rdf:Property ;
    rdfs:label 'Standard Build Hours' ;
    rdfs:comment 'Standard labor hours required to complete the full assembly of this production variant from stamping through final assembly and PDI (Pre-Delivery Inspection). Used for production cost standard setting, workforce planning, and SAP CO (Controlling) cost object calculation.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teamcenterVariantCode rdf:type rdf:Property ;
    rdfs:label 'Teamcenter Variant Code' ;
    rdfs:comment 'Cross-reference identifier for this production variant in Siemens Teamcenter PLM (Product Lifecycle Management) variant configuration module. Enables traceability between the manufacturing master data record and the engineering variant definition in the PLM system of record.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:v2xCapable rdf:type rdf:Property ;
    rdfs:label 'V2x Capable' ;
    rdfs:comment 'Indicates whether this production variant is equipped with V2X (Vehicle-to-Everything) communication hardware (True = V2X capable). Drives telematics module assembly sequencing, spectrum licensing compliance, and connected mobility service activation in Geotab/Bosch IoT platform.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variantCode rdf:type rdf:Property ;
    rdfs:label 'Variant Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this production variant within the manufacturing system. Used as the primary business key in MES (Manufacturing Execution System), PLM (Product Lifecycle Management), and SAP PP (Production Planning) for variant identification and cross-system referencing. Sourced from Siemens Teamcenter PLM variant configuration.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantName rdf:type rdf:Property ;
    rdfs:label 'Variant Name' ;
    rdfs:comment 'Human-readable descriptive name of the production variant (e.g., \'F-Series SuperCrew 4x4 BEV Long Range\'). Used in build sequence planning, shop floor documentation, and JIS (Just-in-Sequence) scheduling displays.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantStatus rdf:type rdf:Property ;
    rdfs:label 'Variant Status' ;
    rdfs:comment 'Current lifecycle status of the production variant within the manufacturing master data: ACTIVE (currently buildable), PLANNED (approved for future SOP), INACTIVE (not currently scheduled), DISCONTINUED (past EOP), ON_HOLD (temporarily suspended pending engineering change or regulatory review). Drives MES build feasibility checks.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wltpRangeKm rdf:type rdf:Property ;
    rdfs:label 'Wltp Range Km' ;
    rdfs:comment 'Official WLTP (Worldwide Harmonised Light Vehicles Test Procedure) certified driving range in kilometres for BEV and PHEV variants. Null for ICE and HEV variants. Used for EU regulatory labelling, EPA range certification cross-reference, and consumer-facing range claims.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealershipId rdf:type rdf:Property ;
    rdfs:label 'Dealership Id' ;
    rdfs:comment 'Unique surrogate identifier for each dealer location in the OEM franchise network. Primary key for the dealership master record and the enterprise Single Source of Truth (SSOT) for dealer identity.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:paymentTermId rdf:type rdf:Property ;
    rdfs:label 'Payment Term Id' ;
    rdfs:comment 'Foreign key linking to billing.payment_term. Business justification: Required for billing: dealership default payment terms are needed for all invoices, enabling consistent net-due days and discount calculations per dealer.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTerm .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date on which the dealership was formally activated in the OEM dealer network and became eligible to receive vehicle allocations and participate in OEM programs.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adasCertified rdf:type rdf:Property ;
    rdfs:label 'Adas Certified' ;
    rdfs:comment 'Indicates whether the dealership is certified to perform Advanced Driver Assistance Systems (ADAS) calibration and repair. Required for servicing vehicles equipped with cameras, radar, and LiDAR-based safety systems.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdkDealerCode rdf:type rdf:Property ;
    rdfs:label 'Cdk Dealer Code' ;
    rdfs:comment 'Unique dealer identifier assigned within the CDK Global Dealer Management System (DMS). This is the integration key used for all data exchanges between the OEM lakehouse and the CDK DMS platform including inventory, F&I, and service scheduling feeds.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelClassification rdf:type rdf:Property ;
    rdfs:label 'Channel Classification' ;
    rdfs:comment 'Categorizes the dealer\'s primary sales channel model. Retail covers traditional showroom sales; fleet covers B2B volume sales; agency model covers OEM-set pricing arrangements; export covers cross-border sales points.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date on which the dealership was deactivated or terminated from the OEM dealer network. Nullable for currently active dealers. Used for franchise termination tracking and regulatory reporting.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealerStatus rdf:type rdf:Property ;
    rdfs:label 'Dealer Status' ;
    rdfs:comment 'Current lifecycle status of the dealership within the OEM franchise network. Controls eligibility for vehicle allocation, incentive programs, and DMS integration. [ENUM-REF-CANDIDATE: active|inactive|suspended|pending_approval|terminated|under_review — promote to reference product]' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerTier rdf:type rdf:Property ;
    rdfs:label 'Dealer Tier' ;
    rdfs:comment 'OEM-assigned performance tier classification for the dealership based on annual sales volume, customer satisfaction scores, and compliance metrics. Determines eligibility for premium vehicle allocations, co-op marketing funds, and incentive program tiers.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsGoLiveDate rdf:type rdf:Property ;
    rdfs:label 'Dms Go Live Date' ;
    rdfs:comment 'Date on which the CDK Global DMS integration for this dealership went live and began transmitting data to the OEM enterprise systems. Used for integration tenure tracking and data completeness assessments.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dmsIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Dms Integration Status' ;
    rdfs:comment 'Current status of the CDK Global DMS data integration feed for this dealership. Indicates whether real-time inventory, sales, and service data is flowing correctly into the OEM lakehouse.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evCertified rdf:type rdf:Property ;
    rdfs:label 'Ev Certified' ;
    rdfs:comment 'Indicates whether the dealership has completed OEM Electric Vehicle (EV) certification requirements including technician training, charging infrastructure installation, and EV-specific tooling. Required for allocation of BEV and PHEV models.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evChargerCount rdf:type rdf:Property ;
    rdfs:label 'Ev Charger Count' ;
    rdfs:comment 'Number of EV charging stations installed at the dealership for customer and demo vehicle use. Relevant for EV certification compliance and customer experience reporting.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:franchiseAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Number' ;
    rdfs:comment 'Reference number of the active franchise agreement between the OEM and the dealer entity. Used to link the dealership master record to the franchise agreement contract for legal and compliance purposes.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Expiry Date' ;
    rdfs:comment 'Date on which the current franchise agreement is scheduled to expire or must be renewed. Nullable for perpetual agreements. Triggers renewal workflow when within the notice period.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:franchiseStartDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Start Date' ;
    rdfs:comment 'Date on which the current franchise agreement between the OEM and the dealer became effective. Used for tenure calculations, renewal scheduling, and performance baseline setting.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:franchiseType rdf:type rdf:Property ;
    rdfs:label 'Franchise Type' ;
    rdfs:comment 'Classification of the dealer\'s franchise arrangement with the OEM. Distinguishes OEM-owned (captive) outlets from independent franchise dealers, authorized repairers, fleet-only points, used vehicle specialists, and satellite locations. [ENUM-REF-CANDIDATE: oem_owned|independent_franchise|authorized_repairer|fleet_only|used_vehicle_only|satellite — promote to reference product]' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full registered legal name of the dealer entity as recorded with the relevant state or national business registry. Used for franchise agreements, regulatory filings, and financial settlements.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotCapacity rdf:type rdf:Property ;
    rdfs:label 'Lot Capacity' ;
    rdfs:comment 'Maximum number of vehicles that can be stored on the dealer lot (outdoor inventory storage). Used for vehicle allocation limits, inventory aging analysis, and logistics planning.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketRegionCode rdf:type rdf:Property ;
    rdfs:label 'Market Region Code' ;
    rdfs:comment 'OEM-defined market region code to which this dealership belongs (e.g., NORTHEAST, MIDWEST, SOUTHWEST, WEST, SOUTHEAST). Used for territory management, regional incentive programs, and sales performance reporting.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newVehicleSalesCapacity rdf:type rdf:Property ;
    rdfs:label 'New Vehicle Sales Capacity' ;
    rdfs:comment 'OEM-assessed annual new vehicle sales capacity (unit count) for this dealership based on facility size, staffing, and market area. Used as the denominator for allocation planning and sales target setting.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oemBrandCodes rdf:type rdf:Property ;
    rdfs:label 'Oem Brand Codes' ;
    rdfs:comment 'Pipe-delimited list of OEM brand codes (e.g., BRAND_A|BRAND_B) that this dealership is franchised to sell and service. A single dealer point may hold multi-brand authorizations (e.g., passenger car and commercial vehicle brands).' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipGroupName rdf:type rdf:Property ;
    rdfs:label 'Ownership Group Name' ;
    rdfs:comment 'Name of the dealer group or automotive retail group that owns this dealership location (e.g., AutoNation, Penske, Lithia). Enables group-level performance aggregation, consolidated incentive calculations, and multi-point dealer management.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsWarehouseAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Parts Warehouse Area Sqm' ;
    rdfs:comment 'Total floor area in square metres of the dealership\'s parts storage facility. Used for parts inventory capacity planning, MRP replenishment calculations, and Just-in-Time (JIT) parts delivery scheduling.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdiCertified rdf:type rdf:Property ;
    rdfs:label 'Pdi Certified' ;
    rdfs:comment 'Indicates whether the dealership is certified to perform Pre-Delivery Inspection (PDI) on new vehicles prior to customer handover. PDI certification is required for new vehicle delivery authorization.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'Primary business email address for the dealership used for OEM communications, vehicle allocation notifications, incentive program updates, and Technical Service Bulletin (TSB) distribution.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'Main switchboard or primary contact telephone number for the dealership. Used for OEM-to-dealer communications, customer service escalations, and directory listings.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalContactEmail rdf:type rdf:Property ;
    rdfs:label 'Principal Contact Email' ;
    rdfs:comment 'Email address of the primary OEM relationship contact at the dealership. Used for franchise communications, incentive program notifications, and regulatory bulletin distribution.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalContactName rdf:type rdf:Property ;
    rdfs:label 'Principal Contact Name' ;
    rdfs:comment 'Full name of the primary OEM relationship contact at the dealership (typically the Dealer Principal or General Manager). Used for OEM communications, franchise agreement correspondence, and escalation routing.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when the dealership master record was first created in the enterprise data platform. Follows ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for data lineage, audit trail, and record age analysis.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the dealership master record in the enterprise data platform. Follows ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for change detection, data freshness monitoring, and audit compliance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:salesDistrictCode rdf:type rdf:Property ;
    rdfs:label 'Sales District Code' ;
    rdfs:comment 'OEM-defined sales district code representing the sub-regional territory assignment for this dealership. Used for district sales manager (DSM) alignment, vehicle allocation quotas, and performance benchmarking.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCustomerNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Number' ;
    rdfs:comment 'SAP S/4HANA customer master number (SD module) assigned to this dealership for vehicle order processing, invoicing, and financial settlement. Links dealership to SAP SD sales orders and FI accounts receivable.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceBayCount rdf:type rdf:Property ;
    rdfs:label 'Service Bay Count' ;
    rdfs:comment 'Total number of service bays available at the dealership for vehicle maintenance and repair operations. Used for after-sales capacity planning, warranty repair throughput analysis, and service scheduling optimization.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:showroomDisplayCapacity rdf:type rdf:Property ;
    rdfs:label 'Showroom Display Capacity' ;
    rdfs:comment 'Maximum number of vehicles that can be displayed simultaneously in the dealership showroom. Used for vehicle allocation planning, demo fleet sizing, and facility investment decisions.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'ISO 3166-2 state or province code for the dealership\'s physical location (e.g., CA, TX, NY, ON). Used for CAFE compliance reporting, CARB emissions zone classification, and state-level dealer franchise law compliance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingName rdf:type rdf:Property ;
    rdfs:label 'Trading Name' ;
    rdfs:comment 'The public-facing \'doing business as\' (DBA) name of the dealership as displayed to customers, on signage, and in marketing materials. May differ from the legal entity name.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usedVehicleSalesCapacity rdf:type rdf:Property ;
    rdfs:label 'Used Vehicle Sales Capacity' ;
    rdfs:comment 'OEM-assessed annual used vehicle sales capacity (unit count) for this dealership. Used for certified pre-owned (CPO) program eligibility and used vehicle allocation planning.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyAuthorized rdf:type rdf:Property ;
    rdfs:label 'Warranty Authorized' ;
    rdfs:comment 'Indicates whether the dealership is authorized to perform OEM warranty repairs and submit warranty claims. Drives warranty claim processing eligibility in SAP and CDK DMS.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Public-facing website URL for the dealership. Used for digital marketing integration, online inventory syndication, and customer-facing dealer locator services.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Id' ;
    rdfs:comment 'Unique identifier for the franchise agreement record. Primary key.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FranchiseAgreement .

ind:primaryFranchiseDealerDealershipId rdf:type rdf:Property ;
    rdfs:label 'Primary Franchise Dealer Dealership Id' ;
    rdfs:comment 'Reference to the dealer entity that is party to this franchise agreement.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:salesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_territory. Business justification: Franchise agreements define exclusive or priority territories that must align with OEM sales territory definitions. Critical for territory planning, allocation priority rules, quota assignment, and de' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTerritory .

ind:agreementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Agreement Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all financial terms in the franchise agreement (quotas, fees, investment requirements). Example: USD, EUR, JPY.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Agreement Document Url' ;
    rdfs:comment 'Secure URL or file path to the digitally stored franchise agreement contract document (PDF or scanned image).' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Human-readable name or title of the franchise agreement, typically including dealer name and location.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the franchise agreement. Format: FA-NNNNNNNN.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the franchise agreement: draft (being negotiated), pending approval (awaiting OEM sign-off), active (in force), suspended (temporarily inactive), terminated (ended before expiration), or expired (reached end date).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the franchise agreement based on its purpose: new franchise grant, renewal of existing agreement, amendment to terms, territory expansion, or termination agreement.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPriorityTier rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority Tier' ;
    rdfs:comment 'Priority tier for vehicle inventory allocation. Higher tiers receive preferential allocation of high-demand models and limited-production vehicles. Tier 1 = highest priority.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedNameplates rdf:type rdf:Property ;
    rdfs:label 'Authorized Nameplates' ;
    rdfs:comment 'Comma-separated list of vehicle nameplates (brands, model lines) that the dealer is authorized to sell under this franchise agreement. Examples: Sedan, SUV, Truck, EV (Electric Vehicle), HEV (Hybrid Electric Vehicle).' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedVehicleLines rdf:type rdf:Property ;
    rdfs:label 'Authorized Vehicle Lines' ;
    rdfs:comment 'Specific vehicle lines or series the dealer is authorized to sell, such as luxury, commercial, electric, or performance segments.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the franchise agreement automatically renews at expiration unless either party provides notice. True = auto-renews, False = requires explicit renewal.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certifiedPreOwnedAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Certified Pre Owned Authorized Flag' ;
    rdfs:comment 'Indicates whether the dealer is authorized to sell OEM-certified pre-owned vehicles under the manufacturer\'s CPO program. True = authorized, False = not authorized.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commercialFleetAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Commercial Fleet Authorized Flag' ;
    rdfs:comment 'Indicates whether the dealer is authorized to sell vehicles to commercial fleet customers and participate in fleet sales programs. True = authorized, False = not authorized.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSatisfactionTargetScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Target Score' ;
    rdfs:comment 'Minimum Net Promoter Score (NPS) or customer satisfaction score the dealer must achieve to maintain franchise agreement in good standing. Typically measured on a scale of 0-100.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealerSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Dealer Signatory Name' ;
    rdfs:comment 'Full name of the dealer authorized representative (typically dealer principal or owner) who signed the franchise agreement.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalRetailingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Retailing Required Flag' ;
    rdfs:comment 'Indicates whether the dealer must offer digital retailing capabilities (online sales, virtual showroom, e-commerce) as required by the franchise agreement. True = required, False = optional.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dmsIntegrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dms Integration Required Flag' ;
    rdfs:comment 'Indicates whether the dealer must integrate their DMS (Dealer Management System) with OEM systems for real-time inventory, sales, and service data sharing. True = required, False = optional.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evChargingInfrastructureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ev Charging Infrastructure Required Flag' ;
    rdfs:comment 'Indicates whether the dealer must install and maintain EV (Electric Vehicle) charging infrastructure at their facility as a condition of selling electric or hybrid vehicles. True = required, False = optional.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusiveTerritoryFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusive Territory Flag' ;
    rdfs:comment 'Indicates whether the dealer has exclusive rights to sell in the assigned territory. True = exclusive (no other dealers in territory), False = non-exclusive (shared territory).' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date when the franchise agreement is scheduled to end. Nullable for open-ended or perpetual agreements subject to performance review.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facilityInvestmentRequirementAmount rdf:type rdf:Property ;
    rdfs:label 'Facility Investment Requirement Amount' ;
    rdfs:comment 'Minimum capital expenditure (CapEx) the dealer must invest in facility improvements, showroom standards, service equipment, and infrastructure to meet OEM brand standards.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:franchiseTier rdf:type rdf:Property ;
    rdfs:label 'Franchise Tier' ;
    rdfs:comment 'Tier or level of the franchise agreement indicating dealer status, privileges, and performance expectations. Higher tiers typically receive preferential allocation and incentives.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction and governing law that applies to the franchise agreement, typically the state or country where the dealer operates or where the OEM is headquartered.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveProgramEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Program Eligibility Flag' ;
    rdfs:comment 'Indicates whether the dealer is eligible to participate in OEM dealer incentive programs, volume bonuses, and performance rewards. True = eligible, False = not eligible.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumSalesQuotaAnnual rdf:type rdf:Property ;
    rdfs:label 'Minimum Sales Quota Annual' ;
    rdfs:comment 'Minimum number of vehicle units the dealer must sell annually to maintain franchise agreement in good standing. Performance obligation defined in agreement.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumServiceCapacity rdf:type rdf:Property ;
    rdfs:label 'Minimum Service Capacity' ;
    rdfs:comment 'Minimum number of vehicles the dealer must be capable of servicing per month to meet franchise agreement service obligations.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate or not renew the franchise agreement. Typical values are 30, 60, 90, or 180 days.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oemSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Oem Signatory Name' ;
    rdfs:comment 'Full name of the OEM authorized representative who signed the franchise agreement on behalf of the manufacturer.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipModel rdf:type rdf:Property ;
    rdfs:label 'Ownership Model' ;
    rdfs:comment 'Classification of dealer ownership structure: OEM (Original Equipment Manufacturer) owned, independent franchise, joint venture, or corporate store.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsInventoryRequirementAmount rdf:type rdf:Property ;
    rdfs:label 'Parts Inventory Requirement Amount' ;
    rdfs:comment 'Minimum dollar value of OEM (Original Equipment Manufacturer) parts inventory the dealer must maintain at all times to meet franchise agreement obligations.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Performance Review Frequency' ;
    rdfs:comment 'Frequency at which the OEM conducts formal performance reviews of the dealer against franchise agreement obligations and performance metrics.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallServiceAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Service Authorized Flag' ;
    rdfs:comment 'Indicates whether the dealer is authorized to perform recall repairs and service campaigns issued by the OEM or NHTSA (National Highway Traffic Safety Administration). True = authorized, False = not authorized.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Date when the franchise agreement was last renewed or is scheduled for renewal review. Used for tracking renewal cycles.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Duration in months for each renewal period of the franchise agreement. Typical values are 12, 24, 36, or 60 months.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date when the franchise agreement was formally signed by both the dealer and OEM authorized representatives, making it legally binding.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Actual date when the franchise agreement was terminated, if applicable. Populated only for agreements that ended before their scheduled expiration.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Detailed explanation of why the franchise agreement was terminated early, including performance issues, dealer request, market consolidation, or regulatory compliance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryDescription rdf:type rdf:Property ;
    rdfs:label 'Territory Description' ;
    rdfs:comment 'Textual description of the geographic territory assigned to the dealer under this franchise agreement, including cities, counties, postal codes, or radius from dealer location.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryRadiusKm rdf:type rdf:Property ;
    rdfs:label 'Territory Radius Km' ;
    rdfs:comment 'Radius in kilometers from the dealer\'s primary location defining the franchise territory boundary, if territory is defined by radius rather than geographic boundaries.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Certification Required Flag' ;
    rdfs:comment 'Indicates whether dealer staff must complete OEM-mandated training and certification programs as a condition of the franchise agreement. True = required, False = optional.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyAdministrationAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Administration Authorized Flag' ;
    rdfs:comment 'Indicates whether the dealer is authorized to process and submit warranty claims on behalf of customers under OEM warranty programs. True = authorized, False = not authorized.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dealerTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Dealer Territory Id' ;
    rdfs:comment 'Unique identifier for the dealer territory assignment. Primary key.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDealerDealershipId rdf:type rdf:Property ;
    rdfs:label 'Primary Dealer Dealership Id' ;
    rdfs:comment 'Reference to the dealership that owns or is assigned this territory.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:allocationQuotaPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Quota Percentage' ;
    rdfs:comment 'Percentage of regional or national vehicle allocation assigned to this territory. Sum of all territory percentages within a region should equal 100.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cityList rdf:type rdf:Property ;
    rdfs:label 'City List' ;
    rdfs:comment 'Comma-separated list of cities or municipalities included in the territory coverage area.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveIntensityRating rdf:type rdf:Property ;
    rdfs:label 'Competitive Intensity Rating' ;
    rdfs:comment 'Assessment of competitive pressure within the territory based on number of competing brands, dealer density, and market saturation.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countyRegion rdf:type rdf:Property ;
    rdfs:label 'County Region' ;
    rdfs:comment 'County, district, or regional subdivision name within the state/province that defines part of the territory boundary.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsLastSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dms Last Sync Timestamp' ;
    rdfs:comment 'Timestamp of the last successful synchronization of territory data with the dealer\'s DMS (Dealer Management System). Used to monitor data freshness and integration health.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date when the territory assignment expires or is terminated. Null indicates an open-ended assignment.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date when the territory assignment becomes active and the dealer assumes responsibility for the defined area.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicBoundaryDescription rdf:type rdf:Property ;
    rdfs:label 'Geographic Boundary Description' ;
    rdfs:comment 'Textual description of territory boundaries using landmarks, highways, or natural features (e.g., \'North of I-40, East of Highway 101\').' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdCountEstimate rdf:type rdf:Property ;
    rdfs:label 'Household Count Estimate' ;
    rdfs:comment 'Estimated number of households within the territory. Used for market penetration analysis and vehicle allocation planning.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date when the territory assignment was last reviewed or audited by OEM (Original Equipment Manufacturer) management. Used to track compliance with periodic review requirements.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managerEmail rdf:type rdf:Property ;
    rdfs:label 'Manager Email' ;
    rdfs:comment 'Email address of the OEM (Original Equipment Manufacturer) territory manager. Used for dealer communications and escalations.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Name of the OEM (Original Equipment Manufacturer) regional or territory manager responsible for overseeing this territory and dealer relationship.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerPhone rdf:type rdf:Property ;
    rdfs:label 'Manager Phone' ;
    rdfs:comment 'Contact phone number for the OEM (Original Equipment Manufacturer) territory manager.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSegmentClassification rdf:type rdf:Property ;
    rdfs:label 'Market Segment Classification' ;
    rdfs:comment 'Classification of the territory market type based on population density and urbanization level. Influences vehicle mix allocation and marketing strategies.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationReason rdf:type rdf:Property ;
    rdfs:label 'Modification Reason' ;
    rdfs:comment 'Business justification for the most recent change to the territory assignment (e.g., market expansion, dealer consolidation, performance adjustment).' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next territory assignment review. Ensures regular evaluation of territory boundaries and dealer performance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overlapAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Overlap Allowed Flag' ;
    rdfs:comment 'Indicates whether this territory can overlap with other dealer territories. True allows shared coverage; False enforces exclusive boundaries.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overlapRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Overlap Rule Description' ;
    rdfs:comment 'Business rules governing how overlapping territories are managed, including priority rules, customer assignment logic, and conflict resolution procedures.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceBenchmarkGroup rdf:type rdf:Property ;
    rdfs:label 'Performance Benchmark Group' ;
    rdfs:comment 'Peer group or cohort used for dealer performance benchmarking. Territories with similar characteristics are grouped for fair comparison.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationEstimate rdf:type rdf:Property ;
    rdfs:label 'Population Estimate' ;
    rdfs:comment 'Estimated total population within the territory boundaries. Used for market sizing and dealer performance benchmarking.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postalCodeList rdf:type rdf:Property ;
    rdfs:label 'Postal Code List' ;
    rdfs:comment 'Comma-separated or range-based list of postal/zip codes included in the territory (e.g., \'90001-90099,91000\'). Used for precise geographic allocation.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAreaOfResponsibility rdf:type rdf:Property ;
    rdfs:label 'Primary Area Of Responsibility' ;
    rdfs:comment 'Geographic description of the core territory where the dealer has primary sales and service responsibility. May include city names, county boundaries, or regional descriptors.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesPotentialIndex rdf:type rdf:Property ;
    rdfs:label 'Sales Potential Index' ;
    rdfs:comment 'Numeric index representing the relative sales potential of the territory compared to a baseline (e.g., 100 = average, 150 = 50% above average). Used for vehicle allocation and quota setting.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialProgramNotes rdf:type rdf:Property ;
    rdfs:label 'Special Program Notes' ;
    rdfs:comment 'Free-text notes describing any special programs, pilot initiatives, or unique conditions applicable to this territory (e.g., EV (Electric Vehicle) launch market, rural incentive zone).' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the territory within the dealer network. Used for vehicle allocation and market planning.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Business-friendly name or description of the territory (e.g., \'Metro East Region\', \'Downtown District\').' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Status' ;
    rdfs:comment 'Current lifecycle status of the territory assignment. Active territories are operational; pending awaits approval; suspended is temporarily halted; terminated is closed.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of territory assignment model: exclusive (single dealer), shared (multiple dealers), open (no restrictions), primary (main responsibility), secondary (backup coverage), overlay (special program).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleAllocationPriority rdf:type rdf:Property ;
    rdfs:label 'Vehicle Allocation Priority' ;
    rdfs:comment 'Priority ranking for vehicle inventory allocation to this territory. Lower numbers indicate higher priority. Used during supply constraints.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Unique identifier for the dealer contact record. Primary key.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:contactDealerDealershipId rdf:type rdf:Property ;
    rdfs:label 'Contact Dealer Dealership Id' ;
    rdfs:comment 'Reference to the dealership where this contact is employed. Links to the dealer master record.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:contactDealershipId rdf:type rdf:Property ;
    rdfs:label 'Contact Dealership Id' ;
    rdfs:comment 'Reference to the dealership where this contact is employed. Links to the dealer master record.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether the contact is currently active and employed at the dealership. True if active; False if terminated, retired, or on extended leave.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'The date when the contact\'s current OEM certification expires and recertification is required. Null if certification is not required or not yet obtained.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'The current status of the contact\'s OEM certification or training requirements. Certified indicates all required certifications are current; in_progress indicates training underway; expired indicates recertification needed; not_required indicates role does not require certification; not_certified indicates certification required but not yet obtained.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Preference' ;
    rdfs:comment 'The contact\'s preferred method of communication for OEM notifications and updates. Options include email, phone, mobile, fax, or portal messaging.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactRole rdf:type rdf:Property ;
    rdfs:label 'Contact Role' ;
    rdfs:comment 'The functional role or position of the contact at the dealership. Includes dealer principal, general manager, sales manager, service manager, parts manager, and F&I (Finance and Insurance) manager.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'The name of the source system from which this dealer contact record originated. Typically CDK Global DMS (Dealer Management System), Salesforce Automotive Cloud, or other dealer management platforms.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerPortalAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Dealer Portal Access Flag' ;
    rdfs:comment 'Indicates whether the contact has been granted access to the OEM dealer portal for ordering, inventory management, warranty claims, and communications. True if access is granted; False if not.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'The department or functional area within the dealership where the contact works. Includes sales, service, parts, F&I (Finance and Insurance), administration, and management.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary business email address for the dealer contact. Used for OEM (Original Equipment Manufacturer) communications, training enrollment, and dealer portal access.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'The name of the person to contact in case of an emergency involving this dealer contact.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'The phone number of the emergency contact person for this dealer contact.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for the dealer contact, if still in use for document transmission.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'The given name of the dealer contact person.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'The date when the contact was hired or started employment at the dealership. Used to calculate tenure and eligibility for OEM programs.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'The official job title or designation of the contact at the dealership, which may differ from the standardized contact role.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'The preferred language for communications with the contact. Uses ISO 639-2 three-letter language codes (ENG=English, SPA=Spanish, FRE=French, GER=German, ITA=Italian, POR=Portuguese, CHI=Chinese, JPN=Japanese, KOR=Korean, ARA=Arabic). [ENUM-REF-CANDIDATE: ENG|SPA|FRE|GER|ITA|POR|CHI|JPN|KOR|ARA — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'The family name or surname of the dealer contact person.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Last Training Date' ;
    rdfs:comment 'The date when the contact last completed an OEM training course or certification program.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'The middle name or initial of the dealer contact person, if applicable.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile phone number for the dealer contact, used for urgent communications and field operations.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-form text field for additional notes, comments, or special instructions related to the dealer contact. May include communication preferences, special requirements, or historical context.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalLastLoginTimestamp rdf:type rdf:Property ;
    rdfs:label 'Portal Last Login Timestamp' ;
    rdfs:comment 'The date and time when the contact last logged into the OEM dealer portal. Used to monitor engagement and identify inactive users.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portalUserCode rdf:type rdf:Property ;
    rdfs:label 'Portal User Code' ;
    rdfs:comment 'The unique user identifier or login name for the contact in the OEM dealer portal system. Used for authentication and access management.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Flag' ;
    rdfs:comment 'Indicates whether this contact is the primary point of contact for their role at the dealership. True if primary; False if secondary or backup contact.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tenureYears rdf:type rdf:Property ;
    rdfs:label 'Tenure Years' ;
    rdfs:comment 'The number of years the contact has been employed at the dealership, calculated from hire date. Used for experience assessment and program eligibility.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationId rdf:type rdf:Property ;
    rdfs:label 'Certification Id' ;
    rdfs:comment 'Unique identifier for the dealer certification record. Primary key.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certification .

ind:certificationDealerDealershipId rdf:type rdf:Property ;
    rdfs:label 'Certification Dealer Dealership Id' ;
    rdfs:comment 'Reference to the dealership that holds this certification. Links to the dealer master record.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:certificationDealershipId rdf:type rdf:Property ;
    rdfs:label 'Certification Dealership Id' ;
    rdfs:comment 'Reference to the dealership that holds this certification. Links to the dealer master record.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:obligationId rdf:type rdf:Property ;
    rdfs:label 'Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_obligation. Business justification: Regulatory compliance requires each dealer certification to be linked to the specific compliance obligation it satisfies, enabling audit of certification against obligations.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:allocationEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Allocation Eligibility Flag' ;
    rdfs:comment 'Indicates whether this certification makes the dealer eligible for preferential vehicle allocation (e.g., EV-certified dealers receive priority allocation of electric vehicles).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:annualMaintenanceCostAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Maintenance Cost Amount' ;
    rdfs:comment 'Estimated annual cost to maintain this certification, including renewal fees, ongoing training, and audit costs. Expressed in the OEM\'s reporting currency.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditOutcome rdf:type rdf:Property ;
    rdfs:label 'Audit Outcome' ;
    rdfs:comment 'Result of the most recent audit (e.g., passed, passed with conditions, failed). Determines whether certification remains in good standing.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Required Flag' ;
    rdfs:comment 'Indicates whether the dealer must undergo periodic audits to maintain this certification.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditScore rdf:type rdf:Property ;
    rdfs:label 'Audit Score' ;
    rdfs:comment 'Numerical score or rating achieved in the most recent audit (e.g., 0-100 scale, or percentage). Reflects compliance quality and performance.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'Tier or grade of certification achieved by the dealer within a tiered program (e.g., Bronze, Silver, Gold, Platinum). Higher levels may unlock additional benefits.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'Full descriptive name of the certification program or credential (e.g., \'Electric Vehicle Sales and Service Certification\', \'Advanced Driver Assistance Systems Authorized Service Center\').' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Unique alphanumeric identifier assigned by the issuing body for this certification. Externally-known business identifier.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Category of certification awarded to the dealer. Defines the specialized capability or program enrollment (e.g., EV-certified dealer, ADAS service authorization, luxury brand certification).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStandard rdf:type rdf:Property ;
    rdfs:label 'Compliance Standard' ;
    rdfs:comment 'Name of the industry standard or regulatory framework this certification demonstrates compliance with (e.g., IATF 16949, ISO 9001, EPA emissions standards, NHTSA safety standards).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost incurred by the dealer to obtain this certification, including training, equipment, facility upgrades, and application fees. Expressed in the OEM\'s reporting currency.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentRequirements rdf:type rdf:Property ;
    rdfs:label 'Equipment Requirements' ;
    rdfs:comment 'Description of specialized tools, diagnostic equipment, or technology the dealer must possess for this certification (e.g., high-voltage battery diagnostic tools, ADAS radar calibration systems).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityRequirements rdf:type rdf:Property ;
    rdfs:label 'Facility Requirements' ;
    rdfs:comment 'Description of physical facility requirements the dealer must meet for this certification (e.g., dedicated EV charging bays, ADAS calibration equipment, climate-controlled service area).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Geographic coverage level of this certification (e.g., global, regional, national, state/provincial, local). Defines where the certification is recognized.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Eligibility Flag' ;
    rdfs:comment 'Indicates whether this certification qualifies the dealer for special incentive programs, rebates, or performance bonuses.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date when the certification was originally issued to the dealer. Marks the start of the certification validity period.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'Name of the organization or authority that issued the certification (e.g., OEM corporate, IATF, SAE International, regional OEM division).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBodyType rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Type' ;
    rdfs:comment 'Classification of the entity that issued the certification (e.g., OEM corporate, industry association, regulatory body, third-party auditor).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent audit conducted for this certification. Used to track audit compliance and schedule next audit.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'Date of the most recent renewal or recertification event. Tracks ongoing compliance and re-qualification.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumCertifiedTechnicians rdf:type rdf:Property ;
    rdfs:label 'Minimum Certified Technicians' ;
    rdfs:comment 'Minimum number of technicians who must hold individual certification credentials for the dealer to maintain this certification.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Date by which the next audit must be completed to maintain certification compliance.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextRenewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Due Date' ;
    rdfs:comment 'Date by which the dealer must complete renewal requirements to maintain active certification status. Used for proactive renewal management.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:personnelRequirements rdf:type rdf:Property ;
    rdfs:label 'Personnel Requirements' ;
    rdfs:comment 'Description of staffing requirements for this certification (e.g., minimum number of certified technicians, specific role qualifications, training credentials).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementDate rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Date' ;
    rdfs:comment 'Date when a previously suspended certification was reinstated to active status. Nullable if never suspended or not yet reinstated.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Months' ;
    rdfs:comment 'Number of months between required renewal cycles for this certification (e.g., 12 for annual, 24 for biennial, 36 for triennial).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'Date when the certification was permanently revoked. Nullable if never revoked.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Explanation of why the certification was permanently revoked, if applicable (e.g., serious compliance violations, fraudulent activity, repeated failures). Nullable if never revoked.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'Date when the certification was suspended. Nullable if never suspended.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Explanation of why the certification was suspended, if applicable (e.g., failed audit, non-compliance with training requirements, facility deficiencies). Nullable if never suspended.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date when the dealer completed the required training program for this certification. Nullable if training is not required or not yet completed.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether dealer personnel must complete specific training programs to obtain or maintain this certification.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehicleAllocationId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for each vehicle allocation record linking a specific vehicle unit or allocation batch from OEM manufacturing output to a dealership inventory pipeline.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleAllocation .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Vehicle allocations generate dealer invoices upon acceptance or delivery. Core wholesale invoicing process - allocation acceptance triggers billing to dealer for allocated vehicle inventory.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:logisticsDeliveryScheduleId rdf:type rdf:Property ;
    rdfs:label 'Logistics Delivery Schedule Id' ;
    rdfs:comment 'Foreign key linking to logistics.logistics_delivery_schedule. Business justification: Allocations feed delivery schedule planning for dealer-bound vehicles. Synchronizes allocation commitments with logistics delivery windows for dealer receiving capacity management and on-time delivery' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LogisticsDeliverySchedule .

ind:primaryVehicleDealerDealershipId rdf:type rdf:Property ;
    rdfs:label 'Primary Vehicle Dealer Dealership Id' ;
    rdfs:comment 'Reference to the dealership receiving this vehicle allocation. Links to the dealer master record in the dealer network.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:productionPlantId rdf:type rdf:Property ;
    rdfs:label 'Production Plant Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.plant. Business justification: Vehicle allocation is always sourced from a specific manufacturing plant, determining logistics routing, port-of-entry, and delivery lead times. OEM allocation-by-plant reporting is a standard dealer ' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Foreign key linking to logistics.shipment. Business justification: Allocations trigger shipment creation for vehicle transport from plant to dealer. Links allocation planning to logistics execution for delivery tracking and on-time delivery performance measurement.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:vehicleCompoundId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Compound Id' ;
    rdfs:comment 'Foreign key linking to logistics.vehicle_compound. Business justification: Vehicle allocations specify destination compounds for staging before dealer delivery. Allocation planning requires compound capacity visibility and location routing. Standard automotive distribution p' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleCompound .

ind:vehicleTransportOrderId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Transport Order Id' ;
    rdfs:comment 'Foreign key linking to logistics.vehicle_transport_order. Business justification: Allocations generate transport orders for vehicle movement from plant to dealer. Core allocation-to-transport order conversion process in automotive logistics planning and execution.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleTransportOrder .

ind:acceptanceDeadline rdf:type rdf:Property ;
    rdfs:label 'Acceptance Deadline' ;
    rdfs:comment 'Date by which the dealer must formally accept or reject this allocation. Failure to respond by this date may result in automatic acceptance or reallocation per OEM dealer agreement terms.' ;
    rdfs:domain ind:VehicleAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acceptanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acceptance Timestamp' ;
    rdfs:comment 'Exact timestamp when the dealer formally accepted this vehicle allocation via the dealer portal or DMS integration. Provides precise audit trail for dealer commitment.' ;
    rdfs:domain ind:VehicleAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:acceptedQuantity rdf:type rdf:Property ;
    rdfs:label 'Accepted Quantity' ;
    rdfs:comment 'Number of vehicle units formally accepted by the dealer from this allocation. May be less than allocated_quantity if the dealer partially accepts or rejects units.' ;
    rdfs:domain ind:VehicleAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Actual date the allocated vehicle(s) were physically delivered to and received by the dealership. Used for On-Time Delivery (OTD) performance measurement and dealer satisfaction tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Batch Number' ;
    rdfs:comment 'Identifier grouping multiple allocation records issued in the same OEM allocation run or production release cycle. Enables batch-level tracking, reporting, and dealer communication.' ;
    rdfs:domain ind:VehicleAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The business event date on which the OEM formally allocated the vehicle unit(s) to the dealership. Represents the principal real-world event time for this transaction.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Externally-known business identifier for this allocation transaction, used in dealer communications, DMS integration, and OEM-dealer correspondence. Format: ALLOC-{MY}-{sequence}.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationRuleCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Rule Code' ;
    rdfs:comment 'Code identifying the specific allocation rule or algorithm applied to determine this dealer\'s vehicle entitlement (e.g., turn-and-earn, market share, historical sales, regional quota). Drives transparency and auditability of allocation decisions.' ;
    rdfs:domain ind:VehicleAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle state of the vehicle allocation record. Tracks progression from OEM-initiated pending through dealer acceptance or rejection to final delivery confirmation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Classification of the allocation purpose: standard retail inventory, priority customer order fulfillment, constrained supply allocation, fleet customer, dealer demonstrator vehicle, or loaner vehicle program.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerInvoicePrice rdf:type rdf:Property ;
    rdfs:label 'Dealer Invoice Price' ;
    rdfs:comment 'The price at which the OEM invoices the dealer for the allocated vehicle, net of holdback and before dealer incentives. Represents the dealer\'s cost basis for inventory financing and margin calculation.' ;
    rdfs:domain ind:VehicleAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dms Reference Number' ;
    rdfs:comment 'The corresponding allocation or stock order reference number in the dealer\'s CDK Global Dealer Management System (DMS). Enables end-to-end reconciliation between OEM allocation records and dealer inventory systems.' ;
    rdfs:domain ind:VehicleAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'Estimated date the allocated vehicle(s) are expected to arrive at the dealership. Calculated based on production schedule, transport lead time, and PDI processing time. Communicated to dealers for inventory planning.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdCode rdf:type rdf:Property ;
    rdfs:label 'Hold Code' ;
    rdfs:comment 'Code indicating any active hold placed on the allocated vehicle(s) preventing retail sale (e.g., safety recall hold, quality hold, regulatory compliance hold, stop-sale order). Null when no hold is active. [ENUM-REF-CANDIDATE: safety_recall|quality_hold|regulatory|stop_sale|tsb_hold|other — promote to reference product]' ;
    rdfs:domain ind:VehicleAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Incentive Amount' ;
    rdfs:comment 'Monetary value of the dealer incentive or bonus applicable to this specific allocation record. Represents the financial benefit to the dealer for accepting and retailing this vehicle.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveProgramCode rdf:type rdf:Property ;
    rdfs:label 'Incentive Program Code' ;
    rdfs:comment 'Code identifying the OEM dealer incentive program applicable to this allocation (e.g., volume bonus, stair-step program, conquest incentive). Links to the dealer incentive program master for payout calculation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustomerOrder rdf:type rdf:Property ;
    rdfs:label 'Is Customer Order' ;
    rdfs:comment 'Indicates whether this allocation is fulfilling a specific retail customer order (sold order) rather than being allocated to dealer stock inventory. Drives order fulfillment priority and customer communication workflows.' ;
    rdfs:domain ind:VehicleAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:msrp rdf:type rdf:Property ;
    rdfs:label 'Msrp' ;
    rdfs:comment 'Manufacturer Suggested Retail Price (MSRP) for the allocated vehicle unit in the base transaction currency. Used for dealer invoice calculation, incentive program application, and consumer pricing guidance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdiCompleted rdf:type rdf:Property ;
    rdfs:label 'Pdi Completed' ;
    rdfs:comment 'Indicates whether the Pre-Delivery Inspection (PDI) has been completed for the allocated vehicle(s) at the dealership. Required before vehicle can be retailed to a customer.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pdiRequired rdf:type rdf:Property ;
    rdfs:label 'Pdi Required' ;
    rdfs:comment 'Indicates whether a Pre-Delivery Inspection (PDI) is required for the allocated vehicle(s) before retail handover. Drives dealer service scheduling and PDI cost recovery processes.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portOfEntryCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Entry Code' ;
    rdfs:comment 'Code identifying the port or processing compound through which imported or CKD/SKD vehicles pass before onward delivery to the dealer. Relevant for international allocation flows and customs compliance.' ;
    rdfs:domain ind:VehicleAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityTier rdf:type rdf:Property ;
    rdfs:label 'Priority Tier' ;
    rdfs:comment 'Dealer priority tier assigned for this allocation cycle, determining precedence when vehicle supply is constrained. Tier 1 dealers receive first allocation rights based on performance metrics, sales volume, or strategic importance.' ;
    rdfs:domain ind:VehicleAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'OEM regional zone code (e.g., NORTHEAST, SOUTHEAST, CENTRAL, WEST) grouping territories for macro-level allocation planning, regional incentive programs, and zone manager oversight.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating the dealer\'s reason for rejecting this allocation (e.g., excess inventory, wrong specification, cash flow constraints, market demand mismatch). Null when allocation is accepted. [ENUM-REF-CANDIDATE: excess_inventory|wrong_spec|cash_flow|demand_mismatch|facility_capacity|other — promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledProductionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Production Date' ;
    rdfs:comment 'Planned date on which the allocated vehicle unit(s) are scheduled to enter the production line. Derived from the Start of Production (SOP) schedule and used for delivery window planning.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Primary mode of transportation used to deliver the allocated vehicle(s) from the production plant or port of entry to the dealership. Drives logistics cost allocation and delivery lead time estimation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerInventoryId rdf:type rdf:Property ;
    rdfs:label 'Dealer Inventory Id' ;
    rdfs:comment 'Unique surrogate identifier for each dealer inventory record in the Silver Layer lakehouse. Primary key for this data product.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DealerInventory .

ind:primaryInventoryDealerDealershipId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Dealer Dealership Id' ;
    rdfs:comment 'Reference to the dealership that physically holds or is allocated this inventory unit. Sourced from CDK Global DMS dealer master.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'The dealer\'s total landed cost for this vehicle unit, including invoice price, transportation/destination charges, PDI costs, and any dealer-installed accessories. Used for gross profit calculation and inventory valuation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:askingPrice rdf:type rdf:Property ;
    rdfs:label 'Asking Price' ;
    rdfs:comment 'The dealer\'s current advertised or asking retail price for this vehicle unit. May differ from MSRP due to market adjustments, dealer markups, or promotional discounts. Updated dynamically based on market conditions and days-on-lot.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certifiedPreOwned rdf:type rdf:Property ;
    rdfs:label 'Certified Pre Owned' ;
    rdfs:comment 'Indicates whether this used vehicle unit has been certified under the OEM\'s Certified Pre-Owned (CPO) program, meeting specific age, mileage, inspection, and reconditioning standards. True = CPO certified; False = not CPO certified. CPO vehicles carry extended warranty coverage and premium pricing.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daysOnLot rdf:type rdf:Property ;
    rdfs:label 'Days On Lot' ;
    rdfs:comment 'The number of calendar days this vehicle unit has been physically present on the dealer\'s lot since the received date. A key inventory aging metric used to trigger price adjustments, incentive programs, and wholesale decisions. Aged inventory (typically >60 days) incurs floor plan interest costs.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dmsRecordReference rdf:type rdf:Property ;
    rdfs:label 'Dms Record Reference' ;
    rdfs:comment 'The source system record identifier from CDK Global DMS for this inventory unit. Used for data lineage, reconciliation, and incremental load processing between the DMS source and the Silver Layer lakehouse.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drivetrain rdf:type rdf:Property ;
    rdfs:label 'Drivetrain' ;
    rdfs:comment 'Drivetrain configuration of the vehicle: FWD (Front-Wheel Drive), RWD (Rear-Wheel Drive), AWD (All-Wheel Drive), or 4WD (Four-Wheel Drive). Key inventory search and customer preference attribute.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineDescription rdf:type rdf:Property ;
    rdfs:label 'Engine Description' ;
    rdfs:comment 'Descriptive label for the engine or powertrain configuration (e.g., \'2.5L 4-Cylinder\', \'3.5L V6 EcoBoost\', \'75 kWh Electric Motor\'). Supports customer consultation and technical service identification.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Date' ;
    rdfs:comment 'The estimated date the vehicle unit is expected to arrive at the dealership from the OEM or transport carrier. Relevant for in-transit inventory. Used for customer pre-order management and lot planning.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exteriorColorName rdf:type rdf:Property ;
    rdfs:label 'Exterior Color Name' ;
    rdfs:comment 'Human-readable marketing name of the exterior paint color (e.g., \'Sonic Gray Pearl\', \'Midnight Black Metallic\'). Used for customer-facing display and sales consultation.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorPlanDate rdf:type rdf:Property ;
    rdfs:label 'Floor Plan Date' ;
    rdfs:comment 'The date on which floor plan financing commenced for this vehicle unit. Used to calculate accrued floor plan interest costs and curtailment schedules. Null for vehicles not financed via floor plan.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:floorPlanLender rdf:type rdf:Property ;
    rdfs:label 'Floor Plan Lender' ;
    rdfs:comment 'Name of the financial institution providing floor plan (wholesale) financing for this vehicle unit (e.g., \'Ford Motor Credit\', \'Ally Financial\', \'Chase Auto Finance\'). Floor plan financing is the short-term credit line dealers use to fund vehicle inventory.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelEconomyCityMpg rdf:type rdf:Property ;
    rdfs:label 'Fuel Economy City Mpg' ;
    rdfs:comment 'EPA-rated city fuel economy for this vehicle configuration in miles per gallon (MPG), or MPGe for electric/hybrid vehicles. Required disclosure on the Monroney label and used for CAFE compliance reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelEconomyHighwayMpg rdf:type rdf:Property ;
    rdfs:label 'Fuel Economy Highway Mpg' ;
    rdfs:comment 'EPA-rated highway fuel economy for this vehicle configuration in miles per gallon (MPG), or MPGe for electric/hybrid vehicles. Required disclosure on the Monroney label and used for CAFE compliance reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inServiceDate rdf:type rdf:Property ;
    rdfs:label 'In Service Date' ;
    rdfs:comment 'The date the vehicle was placed into service (sold and delivered to a retail customer, or placed into demo/loaner service). Marks the start of the OEM warranty period. Null if the vehicle has not yet been placed in service.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interiorColorName rdf:type rdf:Property ;
    rdfs:label 'Interior Color Name' ;
    rdfs:comment 'Human-readable marketing name of the interior color and material (e.g., \'Black Leather\', \'Sandstone Cloth\'). Used for customer-facing display and sales consultation.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Current disposition status of the vehicle unit within the dealer inventory lifecycle. \'available\' = on-lot and saleable; \'sold\' = retail sale completed; \'demo\' = dealer demonstration unit; \'loaner\' = service loaner vehicle; \'in_transit\' = allocated but not yet physically received; \'reserved\' = held for a specific customer; \'wholesale\' = designated for wholesale/auction disposal. [ENUM-REF-CANDIDATE: available|sold|demo|loaner|in_transit|reserved|wholesale — promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryType rdf:type rdf:Property ;
    rdfs:label 'Inventory Type' ;
    rdfs:comment 'Classification of the vehicle unit by its condition and ownership history: \'new\' = new vehicle never titled; \'used\' = previously owned/titled vehicle; \'certified_pre_owned\' = OEM-certified used vehicle meeting specific age/mileage criteria; \'demo\' = dealer demonstration vehicle; \'loaner\' = service loaner vehicle. Governs applicable pricing, warranty, and financing programs.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoicePrice rdf:type rdf:Property ;
    rdfs:label 'Invoice Price' ;
    rdfs:comment 'The OEM invoice price charged to the dealer for this vehicle unit, representing the dealer\'s acquisition cost from the manufacturer before holdback, dealer cash, or other incentives. Confidential commercial pricing data.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPriceUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Price Update Date' ;
    rdfs:comment 'The date on which the asking price for this vehicle unit was most recently updated in the CDK Global DMS. Used to track pricing strategy cadence and ensure market-aligned pricing for aged inventory.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'The physical lot or storage location code within the dealership where this vehicle is parked (e.g., \'LOT-A-12\', \'SHOWROOM-3\', \'OVERFLOW-B\'). Used for lot management, vehicle locator, and PDI workflow routing within CDK Global DMS.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odometerReading rdf:type rdf:Property ;
    rdfs:label 'Odometer Reading' ;
    rdfs:comment 'Current odometer reading of the vehicle in miles at the time of inventory check-in or last update. Critical for used, demo, and loaner vehicles to determine CPO eligibility, warranty coverage, and pricing. For new vehicles, reflects delivery mileage.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pdiCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Pdi Completed Date' ;
    rdfs:comment 'The date on which the Pre-Delivery Inspection (PDI) was completed and signed off by the dealer\'s service technician. Null if PDI has not yet been performed.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallCampaignNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Campaign Number' ;
    rdfs:comment 'The NHTSA-assigned recall campaign number if this vehicle is subject to an active safety recall (e.g., \'23V-123\'). Null if no active recall. Used for recall remedy tracking and regulatory reporting.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallHold rdf:type rdf:Property ;
    rdfs:label 'Recall Hold' ;
    rdfs:comment 'Indicates whether this vehicle unit is subject to an active NHTSA safety recall that prevents retail sale or delivery until the recall remedy has been performed. True = vehicle is on recall hold and cannot be sold; False = no active recall hold. Critical for regulatory compliance and consumer safety.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'The date the vehicle unit was physically received and checked into the dealer\'s inventory from the OEM transport carrier or trade-in. Marks the start of the days-on-lot aging clock and floor plan financing period.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Indicates how the dealer acquired this vehicle unit: \'factory_order\' = ordered directly from OEM; \'dealer_trade\' = acquired via dealer-to-dealer trade; \'auction\' = purchased at wholesale auction; \'trade_in\' = accepted as customer trade-in; \'fleet_return\' = returned from fleet/rental program; \'lease_return\' = returned at end of lease term.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockNumber rdf:type rdf:Property ;
    rdfs:label 'Stock Number' ;
    rdfs:comment 'Dealer-assigned internal stock number used within the CDK Global DMS to identify and locate this vehicle on the lot. Unique within a dealership but not globally unique.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportStatus rdf:type rdf:Property ;
    rdfs:label 'Transport Status' ;
    rdfs:comment 'Current transportation status for vehicles in the delivery pipeline from OEM plant to dealership: \'not_shipped\' = awaiting dispatch from plant; \'in_transit\' = en route via carrier; \'delivered\' = arrived at dealer; \'rail\' = currently on rail transport; \'truck\' = currently on truck transport.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowStickerUrl rdf:type rdf:Property ;
    rdfs:label 'Window Sticker Url' ;
    rdfs:comment 'URL link to the digital Monroney window sticker (required by the Automobile Information Disclosure Act) for this vehicle unit, hosted by the OEM or a third-party service. Contains MSRP, standard equipment, options, fuel economy ratings, and safety information.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsInventoryId rdf:type rdf:Property ;
    rdfs:label 'Parts Inventory Id' ;
    rdfs:comment 'Unique surrogate identifier for each parts inventory record at the dealer location. Primary key for the dealer parts inventory entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartsInventory .

ind:changeId rdf:type rdf:Property ;
    rdfs:label 'Change Id' ;
    rdfs:comment 'Foreign key linking to engineering.change. Business justification: Engineering change orders trigger part supersessions that directly affect dealer parts inventory (superseding_part_number, superseded_by_date). Linking parts_inventory to the engineering change that c' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Change .

ind:primaryPartsDealerDealershipId rdf:type rdf:Property ;
    rdfs:label 'Primary Parts Dealer Dealership Id' ;
    rdfs:comment 'Reference to the dealer location where this parts inventory record is maintained. Links to the dealer master entity in the dealer domain.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:averageMonthlyDemand rdf:type rdf:Property ;
    rdfs:label 'Average Monthly Demand' ;
    rdfs:comment 'Rolling average monthly sales or usage quantity for this part at the dealer location, as calculated and stored by the CDK DMS parts analysis engine. Used for reorder point setting and stocking level optimization. Stored as a DMS-sourced field, not a lakehouse-computed metric.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'Physical storage bin, shelf, or rack location code within the dealer parts warehouse or stockroom where this part is stored. Used by parts staff for picking, receiving, and cycle counting. Managed within CDK Global DMS warehouse management.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coreChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Core Charge Amount' ;
    rdfs:comment 'The refundable deposit amount charged to the customer for the return of the old/used core part. Applicable only when is_core_part is true. Tracked separately in CDK DMS for core deposit liability accounting.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealerCostPrice rdf:type rdf:Property ;
    rdfs:label 'Dealer Cost Price' ;
    rdfs:comment 'The price at which the dealer procures this part from the OEM or authorized distributor, net of any dealer program discounts. Used for gross margin calculation and parts profitability analysis. Confidential commercial pricing data.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventorySnapshotDate rdf:type rdf:Property ;
    rdfs:label 'Inventory Snapshot Date' ;
    rdfs:comment 'The business date as of which this inventory record reflects the parts quantities and status. Represents the effective date of the CDK DMS data extract loaded into the Silver Layer. Enables point-in-time inventory reporting and trend analysis.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isCorePart rdf:type rdf:Property ;
    rdfs:label 'Is Core Part' ;
    rdfs:comment 'Indicates whether this part has a core charge associated with it, requiring the customer to return the old/used part (core) for a refund. Common for remanufactured parts such as alternators, starters, and brake calipers. Drives core deposit tracking in CDK DMS.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazardousMaterial rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous Material' ;
    rdfs:comment 'Indicates whether this part or fluid is classified as a hazardous material requiring special handling, storage, and disposal procedures under EPA, DOT, and OSHA regulations. Affects shipping documentation and storage bin assignment.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSerialized rdf:type rdf:Property ;
    rdfs:label 'Is Serialized' ;
    rdfs:comment 'Indicates whether individual units of this part are tracked by unique serial number for warranty, recall, and traceability purposes. Serialized parts (e.g., ECUs, airbag modules) require serial number capture at point of sale and installation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Count Date' ;
    rdfs:comment 'Date on which the most recent physical inventory count or cycle count was performed for this part at the dealer location. Used to assess inventory accuracy and schedule next count per IATF 16949 inventory control requirements.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Receipt Date' ;
    rdfs:comment 'Date on which the most recent stock receipt (goods receipt) was posted for this part at the dealer location. Used to assess inventory freshness, identify slow-moving stock, and support cycle count scheduling.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSaleDate rdf:type rdf:Property ;
    rdfs:label 'Last Sale Date' ;
    rdfs:comment 'Date on which this part was most recently sold or issued from the dealer\'s parts inventory, either over the parts counter or via a repair order. Key metric for identifying slow-moving and non-moving (dead stock) inventory.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Expected number of calendar days from purchase order placement to receipt of this part at the dealer location. Used to set reorder points and manage customer promise dates for back-ordered parts.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:listPrice rdf:type rdf:Property ;
    rdfs:label 'List Price' ;
    rdfs:comment 'OEM published list price for this part as defined in the official parts price book. Serves as the baseline for retail pricing and customer quotations at the parts counter. Updated periodically via OEM price file updates in CDK DMS.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lostSalesQuantity rdf:type rdf:Property ;
    rdfs:label 'Lost Sales Quantity' ;
    rdfs:comment 'Cumulative quantity of lost sales recorded for this part when a customer requested the part but it was not available in stock. Tracked in CDK DMS to support stocking level adjustments and identify demand not captured by sales history.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level' ;
    rdfs:comment 'Upper inventory limit for this part at the dealer location. Prevents over-stocking and excess capital tied up in slow-moving parts. Used in conjunction with reorder point for min-max inventory management in CDK DMS.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthsSupply rdf:type rdf:Property ;
    rdfs:label 'Months Supply' ;
    rdfs:comment 'Number of months the current on-hand quantity is expected to last based on the trailing average monthly demand. Sourced directly from CDK DMS parts analysis module. Used to identify overstocked and understocked parts for return-to-OEM decisions.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsClassification rdf:type rdf:Property ;
    rdfs:label 'Parts Classification' ;
    rdfs:comment 'High-level classification category of the part used for inventory segmentation, reporting, and stocking strategy. Categories include mechanical (engine, drivetrain, suspension), body (panels, glass, trim), electrical (ECU, sensors, wiring), accessories (OEM-approved add-ons), fluids, and consumables. [ENUM-REF-CANDIDATE: mechanical|body|electrical|accessories|fluids|consumables — promote to reference product]' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsGroupCode rdf:type rdf:Property ;
    rdfs:label 'Parts Group Code' ;
    rdfs:comment 'OEM-defined parts group or commodity code that further classifies the part within the parts classification hierarchy. Used for bulk ordering, supplier management, and warranty analysis. Aligns with SAP MM material group.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'Net quantity available for immediate sale or service fulfillment, calculated as quantity on hand minus quantity reserved. Represents the unreserved, physically present stock. Stored as a business field from CDK DMS to avoid real-time recalculation in reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Current physical quantity of the part available in the dealer\'s parts stockroom as recorded in the CDK DMS. Represents the actual counted or system-tracked stock level used for service fulfillment and parts counter sales.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityOnOrder rdf:type rdf:Property ;
    rdfs:label 'Quantity On Order' ;
    rdfs:comment 'Total quantity of this part currently on open purchase orders submitted to the OEM or aftermarket supplier but not yet received at the dealer. Used for demand planning and avoiding duplicate orders.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'Quantity of this part that has been reserved or allocated to open repair orders, customer back-orders, or service appointments but not yet consumed. Reduces available-to-promise quantity for new service requests.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Indicates whether this part is associated with an active NHTSA safety recall or OEM field action. Recall-flagged parts may have restricted sale or mandatory installation requirements. Supports compliance with NHTSA recall management obligations.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Minimum stock level threshold at which a replenishment order should be triggered for this part. When quantity on hand falls to or below this level, the DMS generates a replenishment recommendation. Set based on historical demand and lead time.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Quantity' ;
    rdfs:comment 'Standard order quantity to be placed when the reorder point is reached. Represents the economic order quantity (EOQ) or OEM-mandated minimum order quantity for this part at this dealer location.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retailPrice rdf:type rdf:Property ;
    rdfs:label 'Retail Price' ;
    rdfs:comment 'Dealer-set retail selling price for this part at the parts counter or in service repair orders. May differ from OEM list price based on dealer markup strategy, local market conditions, or promotional pricing.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Dealer-level Stock Keeping Unit (SKU) code used within the CDK Global DMS parts module for inventory tracking, bin management, and point-of-sale transactions. May differ from OEM part number when dealer applies local stocking codes.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Required storage condition for this part to maintain quality and safety compliance. Drives bin assignment and warehouse layout decisions. Flammable and hazardous parts require segregated storage per EPA and DOT regulations.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleModelApplicability rdf:type rdf:Property ;
    rdfs:label 'Vehicle Model Applicability' ;
    rdfs:comment 'Comma-separated list of vehicle model names or platform codes for which this part is applicable (e.g., F-150, Explorer, Mustang). Supports fitment verification at the parts counter and in service repair order creation.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyEligible rdf:type rdf:Property ;
    rdfs:label 'Warranty Eligible' ;
    rdfs:comment 'Indicates whether this part is eligible for OEM warranty claim submission when installed during a warranty repair. Non-warranty-eligible parts (e.g., customer-pay accessories) are excluded from warranty billing to the OEM.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Unique surrogate identifier for each dealer order record in the lakehouse silver layer. Primary key for the dealer_order data product.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:orderCustomerPartyId rdf:type rdf:Property ;
    rdfs:label 'Order Customer Party Id' ;
    rdfs:comment 'Reference to the retail customer for whom this order is placed. Populated for retail (customer-specific) orders; null for stock orders.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:orderDealerDealershipId rdf:type rdf:Property ;
    rdfs:label 'Order Dealer Dealership Id' ;
    rdfs:comment 'Reference to the dealership that placed this order. Links to the dealer master record in the dealer domain.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:orderDealershipId rdf:type rdf:Property ;
    rdfs:label 'Order Dealership Id' ;
    rdfs:comment 'Reference to the dealership that placed this order. Links to the dealer master record in the dealer domain.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:orderPartyId rdf:type rdf:Property ;
    rdfs:label 'Order Party Id' ;
    rdfs:comment 'Reference to the retail customer for whom this order is placed. Populated for retail (customer-specific) orders; null for stock orders.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'The actual date the vehicle departed the production plant or port for transit to the dealership. Used to measure logistics performance and update OTD tracking.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationPoolCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Pool Code' ;
    rdfs:comment 'Code identifying the vehicle allocation pool or program from which this order is fulfilled (e.g., regional allocation, fleet pool, dealer stock pool). Governs allocation rules and constraints.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Code identifying the reason for order cancellation (e.g., customer withdrawal, dealer over-allocation, duplicate order). Populated only when order_status is cancelled.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The OEM-confirmed delivery date communicated back to the dealer after production scheduling. May differ from the requested delivery date.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysLate rdf:type rdf:Property ;
    rdfs:label 'Days Late' ;
    rdfs:comment 'Number of calendar days the actual delivery date exceeded the confirmed delivery date. Zero or negative values indicate on-time or early delivery. Used for OTD variance analysis and dealer penalty calculations.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dealerInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Dealer Invoice Amount' ;
    rdfs:comment 'The wholesale invoice price charged by the OEM to the dealer for this vehicle order. Represents the net amount the dealer pays before any holdback or incentive adjustments.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmsOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Dms Order Number' ;
    rdfs:comment 'Order reference number assigned by the CDK Global Dealer Management System at the dealership level. Enables reconciliation between OEM and dealer systems.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedShipDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Ship Date' ;
    rdfs:comment 'The estimated date the vehicle is expected to depart the production plant or port for transit to the dealership. Used for logistics planning and dealer communication.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketCode rdf:type rdf:Property ;
    rdfs:label 'Market Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the market where the vehicle will be sold. Determines applicable regulatory standards (NHTSA, EPA, CARB, Euro NCAP, UNECE), homologation requirements, and pricing.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrpAmount rdf:type rdf:Property ;
    rdfs:label 'Msrp Amount' ;
    rdfs:comment 'The Manufacturer Suggested Retail Price (MSRP) for the fully configured vehicle as ordered, in the base currency. Represents the gross base amount before dealer adjustments, incentives, or taxes.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderSource rdf:type rdf:Property ;
    rdfs:label 'Order Source' ;
    rdfs:comment 'The channel or system through which the dealer order was submitted to the OEM: dealer portal, CDK Global DMS integration, EDI transmission, manual entry, or API.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otdFlag rdf:type rdf:Property ;
    rdfs:label 'Otd Flag' ;
    rdfs:comment 'Indicates whether the vehicle was delivered on or before the confirmed delivery date. True = delivered on time; False = delivered late. Core metric for OTD performance reporting and dealer satisfaction.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Priority classification assigned to the order for production scheduling and allocation purposes. Higher priority orders are scheduled earlier in the production sequence.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionWeek rdf:type rdf:Property ;
    rdfs:label 'Production Week' ;
    rdfs:comment 'ISO 8601 production week (e.g., 2025-W23) in which the vehicle is scheduled to be built. Used for production scheduling, capacity planning, and OTD tracking.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The date by which the dealer has requested the vehicle to be delivered to the dealership. Used for On-Time Delivery (OTD) target setting and production scheduling.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesRegionCode rdf:type rdf:Property ;
    rdfs:label 'Sales Region Code' ;
    rdfs:comment 'OEM sales region code associated with the ordering dealer. Used for regional sales performance reporting, allocation management, and incentive program eligibility.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSalesOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sales Order Number' ;
    rdfs:comment 'Externally-known SAP SD sales order number assigned by the OEM ERP system upon order confirmation. Used for cross-system traceability between the lakehouse and SAP S/4HANA.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'The logistics mode used to transport the vehicle from the production plant to the dealership: rail, truck (auto carrier), ocean vessel, or a combination.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailSaleId rdf:type rdf:Property ;
    rdfs:label 'Retail Sale Id' ;
    rdfs:comment 'Unique surrogate identifier for each retail vehicle sale transaction record in the dealer domain. Primary key for the retail_sale data product.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opportunityId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Id' ;
    rdfs:comment 'Foreign key linking to sales.opportunity. Business justification: Retail sale conversion analysis links the final sale back to the originating sales opportunity for win-loss tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:primaryRetailCustomerPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Retail Customer Party Id' ;
    rdfs:comment 'Reference to the retail customer (buyer) who purchased the vehicle. Links to the customer master record.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:primaryRetailDealerDealershipId rdf:type rdf:Property ;
    rdfs:label 'Primary Retail Dealer Dealership Id' ;
    rdfs:comment 'Reference to the dealership that executed the retail sale transaction. Links to the dealer master record in the dealer domain.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:apr rdf:type rdf:Property ;
    rdfs:label 'Apr' ;
    rdfs:comment 'The Annual Percentage Rate (APR) on the retail installment contract as disclosed to the customer under Regulation Z. Expressed as a decimal (e.g., 0.0699 for 6.99%). Null for cash and lease deals.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backEndGross rdf:type rdf:Property ;
    rdfs:label 'Back End Gross' ;
    rdfs:comment 'Gross profit earned from F&I products and dealer reserve on the financing (back-end), representing the total F&I department contribution to the deal. Key dealer profitability metric.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealNumber rdf:type rdf:Property ;
    rdfs:label 'Deal Number' ;
    rdfs:comment 'Externally-known alphanumeric deal reference number assigned by the CDK Global DMS F&I module at the time the deal is opened. Used for cross-referencing with dealer records, lender submissions, and OEM reporting.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealStatus rdf:type rdf:Property ;
    rdfs:label 'Deal Status' ;
    rdfs:comment 'Current lifecycle state of the retail sale deal. \'draft\' indicates deal is being structured; \'pending\' indicates awaiting lender funding approval; \'funded\' indicates lender has funded the deal; \'unwound\' indicates a previously funded deal that was reversed; \'cancelled\' indicates deal was voided before funding.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'The date the vehicle was physically delivered to the customer following Pre-Delivery Inspection (PDI). May differ from sale_date when delivery is deferred. Used for warranty start date determination and OEM retail reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total discount applied to the vehicle sale, calculated as MSRP minus sale price. Includes dealer discounts, OEM incentive discounts, and employee pricing adjustments. Used for dealer margin analysis and OEM incentive reconciliation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmsDealReference rdf:type rdf:Property ;
    rdfs:label 'Dms Deal Reference' ;
    rdfs:comment 'The native deal identifier assigned by the CDK Global DMS F&I module. Used for source system traceability, reconciliation, and integration with downstream OEM reporting and lender portals.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docFee rdf:type rdf:Property ;
    rdfs:label 'Doc Fee' ;
    rdfs:comment 'Dealer-charged documentation and processing fee included in the deal. Subject to state-level regulatory caps in many jurisdictions. Disclosed on the buyer\'s order.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downPayment rdf:type rdf:Property ;
    rdfs:label 'Down Payment' ;
    rdfs:comment 'Cash down payment made by the customer at the time of sale, excluding trade-in allowance. Reduces the amount financed. Used for deal structure analysis and lender submission.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiProductRevenue rdf:type rdf:Property ;
    rdfs:label 'Fi Product Revenue' ;
    rdfs:comment 'Total gross revenue generated from Finance and Insurance (F&I) aftermarket products sold as part of the deal, including extended service contracts, GAP insurance, paint protection, tire and wheel protection, and credit life/disability insurance.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financeAmount rdf:type rdf:Property ;
    rdfs:label 'Finance Amount' ;
    rdfs:comment 'The total amount financed by the customer under the retail installment contract, including vehicle price, F&I products, taxes, and fees, less down payment and trade-in allowance. Null for cash deals.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financingType rdf:type rdf:Property ;
    rdfs:label 'Financing Type' ;
    rdfs:comment 'The method by which the customer is financing the vehicle purchase. \'cash\' = outright purchase; \'retail_finance\' = retail installment contract through a lender; \'lease\' = closed-end consumer lease; \'balloon\' = balloon payment retail contract.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetSale rdf:type rdf:Property ;
    rdfs:label 'Fleet Sale' ;
    rdfs:comment 'Indicates whether the vehicle was sold as part of a fleet or commercial account transaction rather than a retail consumer sale. Fleet sales are tracked separately for CAFE compliance, OEM fleet incentive programs, and sales mix reporting.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frontEndGross rdf:type rdf:Property ;
    rdfs:label 'Front End Gross' ;
    rdfs:comment 'Gross profit earned on the vehicle sale itself (front-end), calculated as sale price minus dealer invoice cost and pack. Excludes F&I product revenue. Key dealer profitability metric reported in DMS and OEM dealer scorecards.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lenderName rdf:type rdf:Property ;
    rdfs:label 'Lender Name' ;
    rdfs:comment 'Name of the financial institution (captive finance company, bank, credit union) that approved and funded the retail installment contract or lease. Null for cash deals. Used for lender mix reporting and dealer reserve analysis.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loanTermMonths rdf:type rdf:Property ;
    rdfs:label 'Loan Term Months' ;
    rdfs:comment 'The contractual term of the retail installment contract expressed in months (e.g., 36, 48, 60, 72, 84). Used for lender mix analysis, payment affordability reporting, and portfolio risk assessment.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monthlyPayment rdf:type rdf:Property ;
    rdfs:label 'Monthly Payment' ;
    rdfs:comment 'The customer\'s contracted monthly payment amount under the retail installment contract or lease agreement. Used for affordability analysis and customer financial profiling.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oemIncentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Oem Incentive Amount' ;
    rdfs:comment 'Total value of OEM-funded customer incentives applied to the deal, including cash-back rebates, conquest bonuses, loyalty bonuses, and special program pricing. Sourced from OEM incentive program data and reconciled against dealer statements.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oemProgramCode rdf:type rdf:Property ;
    rdfs:label 'Oem Program Code' ;
    rdfs:comment 'OEM-assigned program code identifying the specific incentive or sales program under which the vehicle was sold (e.g., employee pricing, conquest, loyalty, fleet, rental). Used for OEM incentive claim submission and program performance reporting.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saleDate rdf:type rdf:Property ;
    rdfs:label 'Sale Date' ;
    rdfs:comment 'The calendar date on which the retail vehicle sale was consummated — i.e., the date the buyer signed the retail installment contract or cash purchase agreement. This is the principal business event date used for sales reporting, OEM incentive eligibility, and regulatory compliance.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salePrice rdf:type rdf:Property ;
    rdfs:label 'Sale Price' ;
    rdfs:comment 'The agreed-upon selling price of the vehicle as negotiated between the dealer and the customer, before trade-in allowance, taxes, and fees. This is the gross capitalized cost for lease deals or the selling price for retail finance and cash deals.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Sales Tax Amount' ;
    rdfs:comment 'State and local sales tax assessed on the vehicle sale transaction. Calculated based on the taxable selling price and the applicable jurisdiction tax rate. Used for tax remittance reporting and deal cost reconciliation.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeInAllowance rdf:type rdf:Property ;
    rdfs:label 'Trade In Allowance' ;
    rdfs:comment 'The agreed trade-in value credited to the customer for a vehicle traded in as part of the deal. Reduces the amount financed or cash due. Null if no trade-in vehicle was involved in the transaction.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeInPayoffAmount rdf:type rdf:Property ;
    rdfs:label 'Trade In Payoff Amount' ;
    rdfs:comment 'The outstanding loan or lease payoff balance on the customer\'s trade-in vehicle at the time of the deal. If payoff exceeds trade-in allowance, the difference (negative equity) is typically rolled into the new deal.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeInVin rdf:type rdf:Property ;
    rdfs:label 'Trade In Vin' ;
    rdfs:comment 'The 17-character VIN of the customer\'s trade-in vehicle, if applicable. Used for used vehicle inventory intake, auction disposition tracking, and trade-in equity analysis.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleCondition rdf:type rdf:Property ;
    rdfs:label 'Vehicle Condition' ;
    rdfs:comment 'Condition classification of the vehicle at point of sale. \'new\' indicates a new, untitled vehicle; \'used\' indicates a previously titled vehicle; \'certified_pre_owned\' indicates a manufacturer-certified pre-owned vehicle meeting OEM CPO program standards.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyStartDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Start Date' ;
    rdfs:comment 'The date on which the OEM new vehicle limited warranty period commences, typically aligned with the delivery_date or sale_date per OEM warranty policy. Used for warranty claim eligibility determination.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealerServiceAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Dealer Service Appointment Id' ;
    rdfs:comment 'Unique identifier for the dealer_service_appointment data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DealerServiceAppointment .

ind:aftersalesServiceAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Aftersales Service Appointment Id' ;
    rdfs:comment 'Foreign key linking to aftersales.service_appointment. Business justification: Business process: Dealer DMS schedules service appointments; aftersales processes them. Linking ensures appointment sync for parts, labor, and warranty tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AftersalesServiceAppointment .

ind:partyId rdf:type rdf:Property ;
    rdfs:label 'Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Service appointment scheduling needs to associate the customer (party) with the appointment for service history and follow-up.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:dealerRepairOrderId rdf:type rdf:Property ;
    rdfs:label 'Dealer Repair Order Id' ;
    rdfs:comment 'Unique identifier for the dealer_repair_order data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DealerRepairOrder .

ind:aftersalesRepairOrderId rdf:type rdf:Property ;
    rdfs:label 'Aftersales Repair Order Id' ;
    rdfs:comment 'Foreign key linking to aftersales.repair_order. Business justification: Process: Dealer creates a repair order in DMS; it must reference the central aftersales repair order for warranty validation and labor costing.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AftersalesRepairOrder .

ind:dealerIncentiveClaimId rdf:type rdf:Property ;
    rdfs:label 'Dealer Incentive Claim Id' ;
    rdfs:comment 'Unique system-generated identifier for each dealer incentive claim record. Primary key for the incentive_claim data product.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DealerIncentiveClaim .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to sales.campaign. Business justification: Dealer incentive claims are tied to specific OEM sales campaigns (volume bonuses, conquest programs, model-year-end pushes). Critical for incentive reconciliation, campaign ROI analysis, and dealer pr' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Foreign key linking to billing.payment. Business justification: Approved incentive claims result in payments to dealers. Core OEM-to-dealer financial settlement - tracks which payment settled each claim for reconciliation and audit.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:accrualPosted rdf:type rdf:Property ;
    rdfs:label 'Accrual Posted' ;
    rdfs:comment 'Indicates whether a financial accrual has been posted in SAP FI for this incentive claim liability. True = accrual posted; False = accrual not yet posted. Used for period-end financial close management and EBITDA reporting accuracy.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Net monetary adjustment applied by the OEM during claim review, representing the difference between claimed_amount and approved_amount. A negative value indicates a reduction; positive indicates an upward correction. Supports audit trail and dispute resolution.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Reason code explaining why the approved_amount differs from the claimed_amount. Populated by the OEM reviewer when an adjustment is applied. [ENUM-REF-CANDIDATE: ineligible_units|duplicate_claim|missing_evidence|calculation_error|program_cap_exceeded|other — promote to reference product]' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'Monetary amount approved by the OEM after review and validation of the dealer\'s claim. May differ from claimed_amount due to adjustments, disallowed units, or partial approvals. This is the amount committed for payment processing in SAP FI.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedUnits rdf:type rdf:Property ;
    rdfs:label 'Approved Units' ;
    rdfs:comment 'Number of vehicle units or qualifying transactions validated and approved by the OEM reviewer. May be less than claimed_units if some units are found ineligible during audit. Used to calculate the approved_amount for volume-based programs.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Externally visible, human-readable unique claim reference number assigned at submission. Used by dealers and OEM finance teams to track and reference the claim across systems including CDK Global DMS and SAP FI.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Claim Period End Date' ;
    rdfs:comment 'End date of the performance or sales period covered by this incentive claim. Defines the close of the measurement window. Together with claim_period_start_date, establishes the claim period boundary for audit and reconciliation.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Claim Period Start Date' ;
    rdfs:comment 'Start date of the performance or sales period covered by this incentive claim. Defines the beginning of the measurement window for which the dealer is claiming the incentive.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current workflow state of the incentive claim through the OEM review and payment lifecycle. Valid states: submitted (initial dealer submission), under_review (OEM audit in progress), approved (claim validated and approved for payment), rejected (claim denied), paid (payment disbursed via SAP FI), cancelled (withdrawn by dealer or voided by OEM).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Category of incentive claim being submitted, reflecting the nature of the OEM incentive program. [ENUM-REF-CANDIDATE: volume_bonus|retail_incentive|floor_plan|marketing_support|customer_satisfaction|parts_sales|service_absorption — promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimedAmount rdf:type rdf:Property ;
    rdfs:label 'Claimed Amount' ;
    rdfs:comment 'Gross monetary amount claimed by the dealer against the incentive program, expressed in the transaction currency. This is the dealer-submitted figure prior to OEM review and approval. Used for financial accrual and liability estimation.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimedMetricUnit rdf:type rdf:Property ;
    rdfs:label 'Claimed Metric Unit' ;
    rdfs:comment 'Unit of measure for the claimed_metric_value field, indicating how the performance metric is expressed (e.g., units for vehicle count, percentage for service absorption rate, score for NPS/CSI, amount for revenue-based claims).' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimedMetricValue rdf:type rdf:Property ;
    rdfs:label 'Claimed Metric Value' ;
    rdfs:comment 'The quantitative performance metric value being claimed by the dealer, applicable for non-unit-based programs such as customer satisfaction scores (NPS), service absorption rates, or parts sales amounts. Complements claimed_units for metric-driven incentive types.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimedUnits rdf:type rdf:Property ;
    rdfs:label 'Claimed Units' ;
    rdfs:comment 'Number of vehicle units or qualifying transactions the dealer is claiming against the incentive program for the claim period. Applicable for volume-based incentive programs such as volume bonus and retail incentive programs.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dealerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Dealer Contact Email' ;
    rdfs:comment 'Email address of the dealer representative responsible for this claim. Used for claim status notifications, evidence requests, and dispute correspondence. Classified as confidential PII per GDPR and applicable privacy regulations.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerContactName rdf:type rdf:Property ;
    rdfs:label 'Dealer Contact Name' ;
    rdfs:comment 'Name of the dealer-side representative who submitted or is responsible for this incentive claim. Used for communication, follow-up, and audit correspondence between OEM and dealer.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'Date on which the dealer formally raised a dispute against the OEM\'s claim decision. Populated only when dispute_flag is True. Used to track dispute aging and compliance with contractual dispute resolution timelines.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether the dealer has formally disputed the OEM\'s decision on this claim (e.g., disputed rejection or adjusted amount). True = claim is under dispute; False = no dispute raised. Triggers escalation workflow in Salesforce Automotive Cloud.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Notes' ;
    rdfs:comment 'Free-text notes documenting the outcome and resolution of a dealer dispute on this claim. Captures the agreed resolution, any revised approved amount, and the basis for the final decision. Supports audit trail and dealer relationship management.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsClaimReference rdf:type rdf:Property ;
    rdfs:label 'Dms Claim Reference' ;
    rdfs:comment 'Claim reference number as recorded in the dealer\'s CDK Global DMS system. Enables cross-system reconciliation between the OEM\'s incentive claim record and the dealer\'s own DMS records. Critical for audit and dispute resolution.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Ref' ;
    rdfs:comment 'Reference identifier or URL pointing to the supporting evidence package submitted by the dealer with the claim (e.g., sales invoices, PDI records, customer satisfaction survey results, parts purchase orders). Stored in the document management system linked from CDK Global DMS or Salesforce Automotive Cloud.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceVerified rdf:type rdf:Property ;
    rdfs:label 'Evidence Verified' ;
    rdfs:comment 'Indicates whether the OEM reviewer has verified the supporting evidence submitted with the claim. True = evidence reviewed and confirmed valid; False = evidence not yet verified or found insufficient. Used to gate claim approval workflow.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Actual monetary amount disbursed to the dealer for this claim. May differ from approved_amount due to netting, offsets, or partial payment arrangements. Populated upon payment confirmation from SAP FI.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Date on which the approved incentive amount was disbursed to the dealer\'s bank account. Populated upon payment confirmation from SAP FI. Used for cash flow reporting and dealer payment aging analysis.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programQuarter rdf:type rdf:Property ;
    rdfs:label 'Program Quarter' ;
    rdfs:comment 'Fiscal quarter of the OEM incentive program period covered by this claim (Q1–Q4). Used for quarterly accrual reporting, dealer performance benchmarking, and incentive budget variance analysis.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programYear rdf:type rdf:Property ;
    rdfs:label 'Program Year' ;
    rdfs:comment 'Fiscal or calendar year of the OEM incentive program under which this claim is filed. Used to segregate claims by annual program cycle for budget tracking, accrual management, and year-end financial close in SAP FI.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Free-text or coded explanation provided by the OEM reviewer when a claim is rejected (claim_status = rejected). Documents the specific grounds for denial to support dealer dispute resolution and compliance with IATF 16949 dealer management requirements.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date on which the OEM completed the review of the incentive claim and updated the claim_status to approved or rejected. Used for SLA tracking of claim processing turnaround time.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapFiDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Document Number' ;
    rdfs:comment 'SAP FI accounting document number generated when the incentive claim liability or payment is posted in the general ledger. Provides direct traceability between the incentive claim and the SAP FI financial posting for audit and reconciliation purposes.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Calendar date on which the dealer formally submitted the incentive claim to the OEM. This is the principal business event date for the claim lifecycle and is used for period-end cut-off and aging analysis.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:floorPlanId rdf:type rdf:Property ;
    rdfs:label 'Floor Plan Id' ;
    rdfs:comment 'Unique identifier for the floor plan financing record.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFloorDealerDealershipId rdf:type rdf:Property ;
    rdfs:label 'Primary Floor Dealer Dealership Id' ;
    rdfs:comment 'Reference to the dealer holding this floor plan financing arrangement.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Unique account number assigned by the financing institution to the dealer\'s floor plan credit facility.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agedInventoryFlag rdf:type rdf:Property ;
    rdfs:label 'Aged Inventory Flag' ;
    rdfs:comment 'Boolean indicator flagging vehicles that have exceeded the aging threshold defined in the floor plan agreement (typically 90, 120, or 180 days). True indicates aged inventory requiring attention.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agingThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Aging Threshold Days' ;
    rdfs:comment 'Number of days after which inventory is considered aged per the floor plan agreement terms. Triggers curtailment requirements or OEM assistance programs.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Result status of the most recent floor plan audit. Passed indicates compliance; failed indicates discrepancies; pending indicates audit in progress; not_required indicates no audit needed; exception indicates special circumstances.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLineAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Line Amount' ;
    rdfs:comment 'Total credit line amount approved by the financing institution for the dealer\'s floor plan facility. Represents the maximum borrowing capacity.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:curtailmentAmount rdf:type rdf:Property ;
    rdfs:label 'Curtailment Amount' ;
    rdfs:comment 'Required curtailment payment amount for aged inventory, typically a percentage of the original financed amount after a specified aging period (e.g., 90 or 120 days).' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:curtailmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Curtailment Due Date' ;
    rdfs:comment 'Scheduled date by which the dealer must make a curtailment payment (partial paydown) on aged inventory per the floor plan agreement terms.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:curtailmentPaidFlag rdf:type rdf:Property ;
    rdfs:label 'Curtailment Paid Flag' ;
    rdfs:comment 'Boolean indicator of whether the required curtailment payment has been made by the dealer. True indicates paid; False indicates outstanding.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dailyInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Daily Interest Amount' ;
    rdfs:comment 'Daily interest accrual amount calculated based on the outstanding balance and interest rate. Used for dealer financial health monitoring.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysInInventory rdf:type rdf:Property ;
    rdfs:label 'Days In Inventory' ;
    rdfs:comment 'Number of days the vehicle has been in dealer inventory under floor plan financing, calculated from financing start date to current date or sale date.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defaultDate rdf:type rdf:Property ;
    rdfs:label 'Default Date' ;
    rdfs:comment 'Date when the dealer was declared in default on floor plan obligations for this vehicle. Null if no default has occurred.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:defaultFlag rdf:type rdf:Property ;
    rdfs:label 'Default Flag' ;
    rdfs:comment 'Boolean indicator of whether the dealer has defaulted on floor plan payments for this vehicle. True indicates default; False indicates current status.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dmsFloorPlanReference rdf:type rdf:Property ;
    rdfs:label 'Dms Floor Plan Reference' ;
    rdfs:comment 'External identifier for this floor plan record in the dealer\'s DMS (e.g., CDK Global). Used for system integration and reconciliation.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financingEndDate rdf:type rdf:Property ;
    rdfs:label 'Financing End Date' ;
    rdfs:comment 'Date when floor plan financing for this vehicle unit was terminated, either through retail sale and payoff or other resolution.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financingInstitutionCode rdf:type rdf:Property ;
    rdfs:label 'Financing Institution Code' ;
    rdfs:comment 'Internal or industry-standard code identifying the financing institution for system integration and reporting.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financingInstitutionName rdf:type rdf:Property ;
    rdfs:label 'Financing Institution Name' ;
    rdfs:comment 'Name of the financial institution or captive finance company providing the floor plan credit line (e.g., OEM captive finance, third-party lender).' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financingStartDate rdf:type rdf:Property ;
    rdfs:label 'Financing Start Date' ;
    rdfs:comment 'Date when floor plan financing for this vehicle unit commenced. Typically the date the vehicle was received into dealer inventory and financed.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:floorPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Floor Plan Status' ;
    rdfs:comment 'Current lifecycle status of the floor plan financing record. Active indicates ongoing financing; paid_off indicates vehicle sold and financing settled; defaulted indicates payment failure; suspended indicates temporary hold; pending_audit indicates under review; curtailed indicates partial paydown required.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRatePct rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Pct' ;
    rdfs:comment 'Annual interest rate percentage charged by the financing institution on the outstanding floor plan balance for this vehicle.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'Scheduled date for the next floor plan audit. Used for audit planning and dealer notification.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oemAssistanceAmount rdf:type rdf:Property ;
    rdfs:label 'Oem Assistance Amount' ;
    rdfs:comment 'Dollar amount of OEM assistance provided for this floor plan record, such as interest rate buy-down or direct payment subsidy.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oemAssistanceProgramCode rdf:type rdf:Property ;
    rdfs:label 'Oem Assistance Program Code' ;
    rdfs:comment 'Code identifying any OEM floor plan assistance program applied to this vehicle (e.g., interest subsidy, extended aging allowance, special financing terms for slow-moving models).' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance Amount' ;
    rdfs:comment 'Current outstanding principal balance owed to the financing institution for this specific vehicle unit. Updated upon curtailment payments and final payoff.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payoffAmount rdf:type rdf:Property ;
    rdfs:label 'Payoff Amount' ;
    rdfs:comment 'Total amount paid to the financing institution to settle the floor plan obligation for this vehicle, including principal and accrued interest.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payoffDate rdf:type rdf:Property ;
    rdfs:label 'Payoff Date' ;
    rdfs:comment 'Date when the floor plan financing for this vehicle was fully paid off, typically upon retail sale or dealer buyout.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:perUnitFloorPlanCost rdf:type rdf:Property ;
    rdfs:label 'Per Unit Floor Plan Cost' ;
    rdfs:comment 'The financed amount for this individual vehicle unit, typically equal to dealer invoice or a percentage thereof. Basis for interest calculation.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'SAP financial document number associated with the floor plan financing transaction in the OEM\'s ERP system (SAP S/4HANA FI module).' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalInterestPaid rdf:type rdf:Property ;
    rdfs:label 'Total Interest Paid' ;
    rdfs:comment 'Cumulative interest amount paid to the financing institution over the life of the floor plan financing for this vehicle unit.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealerWarrantyClaimId rdf:type rdf:Property ;
    rdfs:label 'Dealer Warranty Claim Id' ;
    rdfs:comment 'Unique identifier for the dealer_warranty_claim data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DealerWarrantyClaim .

ind:aftersalesWarrantyClaimId rdf:type rdf:Property ;
    rdfs:label 'Aftersales Warranty Claim Id' ;
    rdfs:comment 'Foreign key linking to aftersales.warranty_claim. Business justification: Report: Dealer-submitted warranty claim reports need to point to the authoritative aftersales warranty claim record for audit and reimbursement.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AftersalesWarrantyClaim .

ind:recallCompletionId rdf:type rdf:Property ;
    rdfs:label 'Recall Completion Id' ;
    rdfs:comment 'Unique identifier for the recall completion record. Primary key for the recall completion transaction.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecallCompletion .

ind:primaryRecallCustomerPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Recall Customer Party Id' ;
    rdfs:comment 'Identifier of the customer who owns the vehicle at the time of recall completion.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:primaryRecallDealerDealershipId rdf:type rdf:Property ;
    rdfs:label 'Primary Recall Dealer Dealership Id' ;
    rdfs:comment 'Identifier of the dealer location that performed the recall remediation work.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:recallCampaignId rdf:type rdf:Property ;
    rdfs:label 'Recall Campaign Id' ;
    rdfs:comment 'Foreign key linking to compliance.recall_campaign. Business justification: Recall completions must reference the specific OEM recall campaign being remedied for warranty reimbursement claims, NHTSA reporting, campaign effectiveness tracking, and regulatory compliance verific' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecallCampaign .

ind:serviceCampaignId rdf:type rdf:Property ;
    rdfs:label 'Service Campaign Id' ;
    rdfs:comment 'Foreign key linking to aftersales.service_campaign. Business justification: Recall completions at dealers must reference the authoritative service campaign record for regulatory reporting (NHTSA/UNECE), remedy validation, and campaign performance tracking. Campaign defines re' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCampaign .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date when the recall remediation work was completed and the vehicle was returned to the customer. Used for NHTSA compliance reporting and OEM recall closure tracking.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionNumber rdf:type rdf:Property ;
    rdfs:label 'Completion Number' ;
    rdfs:comment 'Business identifier for the recall completion transaction, typically generated by the DMS or OEM recall management system.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Current status of the recall completion work. Completed indicates full remediation; incomplete or parts_pending indicate work not yet finished.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Precise date and time when the recall work was marked complete in the DMS system.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'Date when the customer was notified that the recall work was completed. Used for customer satisfaction tracking and communication audit.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Method' ;
    rdfs:comment 'Method used to notify the customer of recall completion: email, SMS, phone call, postal mail, or in-person at dealer.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Dms Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier from the CDK Global DMS system. Used for data lineage and reconciliation between DMS and OEM systems.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Amount' ;
    rdfs:comment 'Total labor cost for the recall work, calculated based on labor hours and dealer labor rate. Used for OEM reimbursement to dealer.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborHours rdf:type rdf:Property ;
    rdfs:label 'Labor Hours' ;
    rdfs:comment 'Total labor hours spent on the recall remediation work. Used for dealer reimbursement calculation and efficiency analysis.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nhtsaReportDate rdf:type rdf:Property ;
    rdfs:label 'Nhtsa Report Date' ;
    rdfs:comment 'Date when the recall completion was reported to NHTSA. Required for compliance tracking and audit trails.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nhtsaReportFlag rdf:type rdf:Property ;
    rdfs:label 'Nhtsa Report Flag' ;
    rdfs:comment 'Indicates whether this recall completion has been reported to NHTSA as required for safety recalls. True means reported; false means not yet reported or not required.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:odometerUnit rdf:type rdf:Property ;
    rdfs:label 'Odometer Unit' ;
    rdfs:comment 'Unit of measure for the odometer reading: km (kilometers) or mi (miles).' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsAmount rdf:type rdf:Property ;
    rdfs:label 'Parts Amount' ;
    rdfs:comment 'Total cost of parts used in the recall remediation. OEM reimburses dealer for parts at wholesale cost.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsQuantityList rdf:type rdf:Property ;
    rdfs:label 'Parts Quantity List' ;
    rdfs:comment 'Comma-separated or pipe-separated list of quantities corresponding to parts_used_list. Used for parts consumption analysis.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsUsedList rdf:type rdf:Property ;
    rdfs:label 'Parts Used List' ;
    rdfs:comment 'Comma-separated or pipe-separated list of part numbers used in the recall remediation. Used for parts consumption tracking and inventory replenishment.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postRepairInspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Post Repair Inspection Notes' ;
    rdfs:comment 'Technician notes from the post-repair inspection confirming that the recall remediation was successful and the vehicle is safe to operate.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preRepairInspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Pre Repair Inspection Notes' ;
    rdfs:comment 'Technician notes from the pre-repair inspection documenting the condition of the vehicle and the recall-related issue before remediation.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Quality Verification Date' ;
    rdfs:comment 'Date when the quality verification or audit of the recall work was performed.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityVerificationFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Verification Flag' ;
    rdfs:comment 'Indicates whether the recall work was subject to quality verification or audit by the dealer service manager or OEM field representative. True means verified; false means not verified.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityVerifierName rdf:type rdf:Property ;
    rdfs:label 'Quality Verifier Name' ;
    rdfs:comment 'Name of the person who performed the quality verification or audit of the recall work (typically service manager or OEM field representative).' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Claim Number' ;
    rdfs:comment 'Claim number submitted by the dealer to the OEM for reimbursement of recall work. Links to the OEM financial system for payment processing.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementPaidDate rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Paid Date' ;
    rdfs:comment 'Date when the OEM paid the dealer for the recall work. Used for dealer cash flow analysis and OEM financial reporting.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reimbursementStatus rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Status' ;
    rdfs:comment 'Status of the dealer reimbursement claim. Pending indicates claim submitted but not yet reviewed; approved means claim validated; paid means funds transferred to dealer.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remedyDescription rdf:type rdf:Property ;
    rdfs:label 'Remedy Description' ;
    rdfs:comment 'Detailed description of the remediation work performed to address the recall. Includes parts replaced, adjustments made, software updates applied, etc.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subletAmount rdf:type rdf:Property ;
    rdfs:label 'Sublet Amount' ;
    rdfs:comment 'Cost of any sublet or outsourced work required to complete the recall (e.g., specialized welding, paint work). Reimbursable by OEM if pre-approved.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicianCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Technician Certification Number' ;
    rdfs:comment 'Certification or license number of the technician. Some recalls require certified technicians to perform the work.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianName rdf:type rdf:Property ;
    rdfs:label 'Technician Name' ;
    rdfs:comment 'Full name of the technician who completed the recall work. Used for performance tracking and quality audits.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalReimbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Total Reimbursement Amount' ;
    rdfs:comment 'Total amount claimed by the dealer for reimbursement from the OEM, including labor, parts, and sublet costs.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Foreign key linking to logistics.carrier. Business justification: Invoice includes carrier charges; linking to carrier enables carrier performance reporting and compliance with freight cost audits.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:dealerStatementId rdf:type rdf:Property ;
    rdfs:label 'Dealer Statement Id' ;
    rdfs:comment 'Foreign key linking to billing.dealer_statement. Business justification: A dealer statement is a periodic summary of invoices issued to a dealer. Individual invoices belong to a dealer statement period. Adding dealer_statement_id to invoice enables grouping invoices by sta' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DealerStatement .

ind:invoiceCustomerPartyId rdf:type rdf:Property ;
    rdfs:label 'Invoice Customer Party Id' ;
    rdfs:comment 'Reference to the customer (dealer, retail buyer, fleet account, or corporate buyer) to whom this invoice is issued.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:invoiceDealerDealershipId rdf:type rdf:Property ;
    rdfs:label 'Invoice Dealer Dealership Id' ;
    rdfs:comment 'Reference to the dealer entity when the invoice is issued to a dealer for wholesale vehicle or parts transactions. Null for retail and fleet invoices.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:invoiceDealershipId rdf:type rdf:Property ;
    rdfs:label 'Invoice Dealership Id' ;
    rdfs:comment 'Reference to the dealer entity when the invoice is issued to a dealer for wholesale vehicle or parts transactions. Null for retail and fleet invoices.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:invoicePartyId rdf:type rdf:Property ;
    rdfs:label 'Invoice Party Id' ;
    rdfs:comment 'Reference to the customer (dealer, retail buyer, fleet account, or corporate buyer) to whom this invoice is issued.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:msrpPricingId rdf:type rdf:Property ;
    rdfs:label 'Msrp Pricing Id' ;
    rdfs:comment 'Foreign key linking to vehicle.msrp_pricing. Business justification: Automotive vehicle sale invoices are generated from the OEM MSRP pricing record — the invoice price basis, gas guzzler tax, EV tax credit eligibility, and destination charge all derive from the MSRP p' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MsrpPricing .

ind:rebateAgreementId rdf:type rdf:Property ;
    rdfs:label 'Rebate Agreement Id' ;
    rdfs:comment 'Foreign key linking to billing.rebate_agreement. Business justification: Rebate agreements generate credit invoices or settlement invoices when rebates are paid out. Linking invoice.rebate_agreement_id to rebate_agreement enables tracking which invoices (particularly credi' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RebateAgreement .

ind:repId rdf:type rdf:Property ;
    rdfs:label 'Rep Id' ;
    rdfs:comment 'Reference to the salesperson or account manager responsible for this sale, used for commission and performance tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:serviceContractId rdf:type rdf:Property ;
    rdfs:label 'Service Contract Id' ;
    rdfs:comment 'Foreign key linking to aftersales.service_contract. Business justification: REQUIRED: Service-contract billing generates periodic invoices; linking enables contract-level revenue and compliance tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceContract .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'First line of the billing address to which the invoice is sent.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Second line of the billing address (suite, building, department).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City of the billing address.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the billing address.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingEntityCode rdf:type rdf:Property ;
    rdfs:label 'Billing Entity Code' ;
    rdfs:comment 'Code identifying the legal entity or business unit issuing the invoice (e.g., regional sales company, parts distribution center, service center).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the billing address.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State or province of the billing address.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Description of the reason for invoice cancellation (order cancelled, billing error, duplicate invoice).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Timestamp when the invoice was cancelled, if applicable. Null for active invoices.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditMemoReference rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Reference' ;
    rdfs:comment 'Reference to a credit memo document number if this invoice has been partially or fully credited.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Description of the reason for dispute if the invoice status is disputed (pricing error, quantity mismatch, quality issue, delivery issue).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The date by which payment is expected per the agreed payment terms.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Fiscal period (month or quarter) within the fiscal year when the invoice was issued.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total invoice amount before taxes, discounts, and adjustments.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date the invoice was formally issued to the customer. Principal business event timestamp for the billing transaction.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Externally-known unique invoice document number issued to the customer. Business identifier for the invoice.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice in the billing and collection workflow.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice based on the customer segment and transaction nature (dealer wholesale, retail customer, fleet account, parts sale, service work, warranty claim).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrpBasedFlag rdf:type rdf:Property ;
    rdfs:label 'Msrp Based Flag' ;
    rdfs:comment 'Indicates whether the invoice pricing is based on MSRP (true) or negotiated/contracted pricing (false).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Final invoice amount payable after applying taxes, discounts, and all adjustments. This is the amount due from the customer.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Amount' ;
    rdfs:comment 'Remaining unpaid balance on the invoice (net_amount minus paid_amount).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The payment instrument or method expected or used for settling this invoice.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Date when the full or final payment was received for this invoice. Null if not yet fully paid.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sales Order Number' ;
    rdfs:comment 'Reference to the originating sales order or service order that this invoice bills for.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapBillingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Billing Document Number' ;
    rdfs:comment 'Reference to the SAP SD billing document number from which this invoice was generated. System of record identifier.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total tax amount applied to the invoice (sales tax, VAT, GST, etc.).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Unique identifier for the invoice line item. Primary key for the invoice_line product.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:goodwillAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Goodwill Adjustment Id' ;
    rdfs:comment 'Foreign key linking to aftersales.goodwill_adjustment. Business justification: Goodwill adjustments create credit memo invoice lines for customer satisfaction resolutions. Required for financial adjustment tracking, customer account reconciliation, and goodwill cost reporting in' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodwillAdjustment .

ind:orderLineId rdf:type rdf:Property ;
    rdfs:label 'Order Line Id' ;
    rdfs:comment 'Foreign key linking to sales.order_line. Business justification: Invoice lines itemize order lines (vehicle, accessories, options, delivery charges). Core billing detail: each invoiced item traces to ordered item for revenue recognition, warranty tracking, and orde' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:partsOrderId rdf:type rdf:Property ;
    rdfs:label 'Parts Order Id' ;
    rdfs:comment 'Foreign key linking to aftersales.aftersales_parts_order. Business justification: Parts orders generate invoice lines when parts are sold to dealers or service centers. Essential for wholesale parts billing, dealer statement generation, and parts revenue recognition.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartsOrder .

ind:partsReturnId rdf:type rdf:Property ;
    rdfs:label 'Parts Return Id' ;
    rdfs:comment 'Foreign key linking to aftersales.parts_return. Business justification: Parts returns generate credit memo invoice lines for returned inventory. Essential for returns processing, inventory adjustment, dealer credit management, and parts return financial reconciliation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartsReturn .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Foreign key linking to supply.supply_po_line. Business justification: Invoice line validation against PO line items is required for accurate cost allocation and audit; standard in automotive AP.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:repairOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Repair Order Line Id' ;
    rdfs:comment 'Foreign key linking to aftersales.repair_order_line. Business justification: REQUIRED: Each invoice line originates from a repair-order line; the link supports detailed cost-to-service analysis.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RepairOrderLine .

ind:serviceContractClaimId rdf:type rdf:Property ;
    rdfs:label 'Service Contract Claim Id' ;
    rdfs:comment 'Foreign key linking to aftersales.service_contract_claim. Business justification: REQUIRED: Claims under service contracts are billed; linking claim to invoice line enables claim settlement and audit.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceContractClaim .

ind:servicePartId rdf:type rdf:Property ;
    rdfs:label 'Service Part Id' ;
    rdfs:comment 'Foreign key linking to aftersales.service_part. Business justification: Service parts sold generate invoice line items with specific part pricing, cost, and margin tracking. Essential for parts revenue recognition, inventory valuation, and profitability analysis in afters' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServicePart .

ind:shipmentLegId rdf:type rdf:Property ;
    rdfs:label 'Shipment Leg Id' ;
    rdfs:comment 'Foreign key linking to logistics.shipment_leg. Business justification: Intermodal freight invoicing itemizes costs per leg (ocean, rail, trucking, port handling). Invoice lines must reference specific legs for cost allocation to business units, dispute resolution on leg-' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipmentLeg .

ind:taxCodeId rdf:type rdf:Property ;
    rdfs:label 'Tax Code Id' ;
    rdfs:comment 'Foreign key linking to billing.tax_code. Business justification: Invoice line tax details should reference the tax_code master; the tax rate can be derived, so the string code and rate columns are redundant.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxCode .

ind:trimOptionAvailabilityId rdf:type rdf:Property ;
    rdfs:label 'Trim Option Availability Id' ;
    rdfs:comment 'Foreign key linking to vehicle.vehicle_option_package. Business justification: Option packages (sunroof, towing, tech packages) are billed as discrete invoice line items in automotive dealer invoicing. Linking billing_invoice_line to vehicle_option_package enables option package' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrimOptionAvailability .

ind:billingDate rdf:type rdf:Property ;
    rdfs:label 'Billing Date' ;
    rdfs:comment 'Date when this line item was billed. Represents the accounting date for revenue recognition and the invoice document date.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Cost center responsible for this revenue line. Used for internal cost accounting and profitability analysis by organizational unit.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Number' ;
    rdfs:comment 'Reference to the delivery document that fulfilled this line. Links the billing to the physical shipment or service delivery event.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Discount expressed as a percentage of the unit price. Provides the rate of discount applied to calculate the discount_amount.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemCode rdf:type rdf:Property ;
    rdfs:label 'Item Code' ;
    rdfs:comment 'Universal item identifier for the billed product or service. May represent a vehicle model code, part number, labor operation code, accessory SKU (Stock Keeping Unit), or fee code depending on line_item_type.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Human-readable description of the billed item. Provides detailed text explaining the product, service, or charge represented by this line.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborOperationCode rdf:type rdf:Property ;
    rdfs:label 'Labor Operation Code' ;
    rdfs:comment 'Standardized labor operation code for service work. Identifies the specific repair or maintenance task performed. Populated only when line_item_type is labor.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemType rdf:type rdf:Property ;
    rdfs:label 'Line Item Type' ;
    rdfs:comment 'Classification of the invoice line item. Distinguishes between vehicle units, parts, labor operations, accessories, service fees, freight charges, warranty products, and insurance products. [ENUM-REF-CANDIDATE: vehicle|part|labor|accessory|fee|freight|warranty|insurance — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the invoice. Determines the ordering and display sequence of line items on the invoice document.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Total amount for this line item including all charges and taxes. Calculated as subtotal_amount + tax_amount. Represents the final billable amount for this line.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User identifier of the person or system that last modified this invoice line record. Supports audit trail and change tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this invoice line record was last modified. Tracks the most recent update to the record for audit and data quality purposes.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:negotiatedPrice rdf:type rdf:Property ;
    rdfs:label 'Negotiated Price' ;
    rdfs:comment 'Final negotiated price per unit after dealer or customer negotiations. May differ from MSRP (Manufacturer Suggested Retail Price) based on market conditions, promotions, or customer agreements.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Profit center for internal P&L (Profit and Loss) reporting. Enables profitability analysis by business segment, product line, or geographic region.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'Marketing promotion or incentive program code applied to this line. Tracks the specific promotional campaign that influenced the pricing or discount.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Quantity of items or units billed on this line. For vehicles typically 1, for parts the number of units, for labor the number of hours.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Category' ;
    rdfs:comment 'Revenue classification for financial reporting and analytics. Categorizes the line item into major revenue streams for P&L (Profit and Loss) reporting and business intelligence. [ENUM-REF-CANDIDATE: new_vehicle|used_vehicle|parts|service|warranty|finance|insurance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrderLineNumber rdf:type rdf:Property ;
    rdfs:label 'Sales Order Line Number' ;
    rdfs:comment 'Line number on the originating sales order. Provides traceability from the invoice line back to the specific sales order line item.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceDate rdf:type rdf:Property ;
    rdfs:label 'Service Date' ;
    rdfs:comment 'Date when the service or delivery occurred. For labor lines, the date the work was performed; for parts, the date the parts were delivered; for vehicles, the delivery date.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Line subtotal before taxes. Calculated as (quantity × unit_price) - discount_amount. Represents the net selling amount before tax.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Price per unit before discounts and taxes. Represents the base selling price for one unit of the item.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyCode rdf:type rdf:Property ;
    rdfs:label 'Warranty Code' ;
    rdfs:comment 'Warranty program code if this line represents warranty coverage. Identifies the specific warranty plan or extended service contract being billed.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User identifier of the person or system that created this invoice line record. Supports audit trail and accountability.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPartyId rdf:type rdf:Property ;
    rdfs:label 'Payment Party Id' ;
    rdfs:comment 'Identifier of the entity making the payment (dealer, retail customer, fleet operator, or corporate account).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:paymentPayerEntityPartyId rdf:type rdf:Property ;
    rdfs:label 'Payment Payer Entity Party Id' ;
    rdfs:comment 'Identifier of the entity making the payment (dealer, retail customer, fleet operator, or corporate account).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:paymentPlanId rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Id' ;
    rdfs:comment 'Foreign key linking to billing.payment_plan. Business justification: When a payment is made as an installment under a structured payment plan, the payment must reference the payment_plan it belongs to. This enables tracking of installment fulfillment, outstanding balan' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentPlan .

ind:receivableId rdf:type rdf:Property ;
    rdfs:label 'Receivable Id' ;
    rdfs:comment 'Foreign key linking to billing.receivable. Business justification: A payment directly reduces an open receivable. Linking payment.receivable_id to receivable enables direct AR management — tracking which receivable a payment closes or partially reduces, supporting du' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Receivable .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Gross monetary value of the payment received before any adjustments or fees.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'Portion of the payment amount that has been successfully applied to outstanding invoices or account balances.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Authorization code provided by the payment processor or bank confirming approval of the payment transaction.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Bank account number from which the payment originated. Masked or tokenized for security. Used for reconciliation and fraud prevention.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Reference Number' ;
    rdfs:comment 'Unique reference number assigned by the bank or financial institution for the payment transaction. Used for reconciliation and dispute resolution.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchReference rdf:type rdf:Property ;
    rdfs:label 'Batch Reference' ;
    rdfs:comment 'Identifier for the batch or group of payments processed together. Used for bulk payment processing and reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Interface or channel through which the payment was submitted. Distinguishes between online portal, mobile app, bank transfer, mail, and in-person payments. [ENUM-REF-CANDIDATE: online_portal|mobile_app|bank_transfer|mail|in_person|automated_system|dealer_system — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'Date when the payment was cleared and funds were confirmed as received in the company bank account.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'Username or identifier of the user or system that created the payment record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the payment amount (e.g., USD, EUR, JPY).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockboxNumber rdf:type rdf:Property ;
    rdfs:label 'Lockbox Number' ;
    rdfs:comment 'Identifier for the bank lockbox service used to receive and process the payment. Applicable for check and mail payments.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerEntityType rdf:type rdf:Property ;
    rdfs:label 'Payer Entity Type' ;
    rdfs:comment 'Classification of the entity making the payment. Distinguishes between dealer payments, retail customer payments, fleet operator payments, and corporate account payments.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Number' ;
    rdfs:comment 'Business-facing unique reference number for the payment transaction. Used for customer communication and reconciliation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle status of the payment. Tracks whether the payment is pending, cleared, returned, reversed, or cancelled. [ENUM-REF-CANDIDATE: pending|cleared|returned|reversed|cancelled|on_hold|partially_applied — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processor rdf:type rdf:Property ;
    rdfs:label 'Processor' ;
    rdfs:comment 'Name of the third-party payment processor or gateway used to process the payment (e.g., Stripe, PayPal, bank name).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date when the payment was reconciled with bank statements and confirmed in the accounting system.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status indicating whether the payment has been successfully reconciled with bank statements and accounting records.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceAdvice rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice' ;
    rdfs:comment 'Detailed remittance information provided by the payer indicating which invoices or charges this payment is intended to cover.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnDate rdf:type rdf:Property ;
    rdfs:label 'Return Date' ;
    rdfs:comment 'Date when the payment was returned or reversed by the bank or payment processor. Populated only when payment status is returned or reversed.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Code indicating the reason for payment return or reversal (e.g., insufficient funds, account closed, stop payment). Populated only when payment status is returned or reversed.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Bank routing number or SWIFT code for the payer financial institution. Used for wire transfers and ACH (Automated Clearing House) transactions.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapClearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Clearing Document Number' ;
    rdfs:comment 'Reference to the SAP FI clearing document that records the application of this payment to open invoices. Links payment to financial accounting records.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPaymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Payment Document Number' ;
    rdfs:comment 'Reference to the SAP FI payment document that records the receipt of this payment. Primary link to ERP (Enterprise Resource Planning) financial records.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsCode rdf:type rdf:Property ;
    rdfs:label 'Terms Code' ;
    rdfs:comment 'Code representing the payment terms under which this payment was made (e.g., net 30, net 60, immediate). Links to master payment terms reference.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the payment processor or gateway. Used for tracking and reconciliation with external systems.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Unapplied Amount' ;
    rdfs:comment 'Portion of the payment amount that remains unapplied and is held as credit on the payer account.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'Username or identifier of the user or system that last modified the payment record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentAllocationId rdf:type rdf:Property ;
    rdfs:label 'Payment Allocation Id' ;
    rdfs:comment 'Unique identifier for the payment allocation record. Primary key for the payment allocation entity.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'The monetary amount from the payment that is allocated to this specific invoice or invoice line. Represents the portion of the total payment applied to settle this receivable.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedAmountBaseCurrency rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount Base Currency' ;
    rdfs:comment 'The allocated amount converted to the company base currency using the exchange rate. Enables consolidated financial reporting and accounts receivable aging in a single currency.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to create the allocation. Automatic indicates system-matched allocation, manual indicates user-created allocation, system_proposed indicates system suggestion requiring approval, batch_clearing indicates mass clearing process.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPriority rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority' ;
    rdfs:comment 'Priority sequence for applying payment when multiple invoices are eligible. Lower numbers indicate higher priority. Used in automatic allocation rules and aging calculations.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Timestamp' ;
    rdfs:comment 'Precise date and time when the payment allocation was recorded in the system. Used for audit trail and transaction sequencing.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'SAP business area for segment reporting. Enables revenue and receivables analysis by business unit, product line, or geographic region.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'SAP FI clearing document number that records the open item clearing transaction. Links the payment allocation to the financial accounting clearing entry.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingStatus rdf:type rdf:Property ;
    rdfs:label 'Clearing Status' ;
    rdfs:comment 'Status of the open item clearing in SAP FI. Open indicates invoice not yet settled, cleared indicates fully settled, partially_cleared indicates partial payment applied, reset indicates clearing was reversed.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'SAP company code representing the legal entity receiving the payment. Enables multi-entity financial consolidation and statutory reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeIndicator rdf:type rdf:Property ;
    rdfs:label 'Dispute Indicator' ;
    rdfs:comment 'Flag indicating whether this allocation is under dispute. True indicates customer has contested the invoice or payment application.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Exchange rate applied when payment currency differs from invoice currency. Used for cross-currency allocation calculations and financial reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingInvoiceBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Invoice Balance' ;
    rdfs:comment 'The outstanding balance remaining on the invoice after this allocation is applied. Zero indicates full settlement. Used for open item management and accounts receivable aging.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'Date when the allocation was reversed. Null if allocation has not been reversed. Used for audit trail and accounts receivable reconciliation.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for allocation reversal. Examples include payment failure, incorrect allocation, duplicate payment, or customer dispute.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The effective date for cash flow and liquidity management. Represents when funds are actually available in the bank account.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Id' ;
    rdfs:comment 'Reference to the parent billing account for hierarchical account structures. Used for corporate accounts with multiple subsidiaries or dealer groups with multiple locations. Null for standalone accounts.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Legal or registered name of the billing party. For dealers, this is the dealership legal entity name. For retail customers, the individual or household name. For fleet/corporate, the company legal name.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the billing account. Active accounts can transact normally. Suspended accounts have temporary restrictions. Closed accounts are permanently terminated. Pending approval accounts await credit review. Blocked accounts cannot transact due to payment issues. Dormant accounts have no recent activity.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the billing account based on the nature of the billing party. Dealer accounts are for franchise dealerships, retail for individual consumers, fleet for commercial fleet operators, corporate for B2B accounts, government for public sector entities, and export for international distributors.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoPayEnrolledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enrolled Flag' ;
    rdfs:comment 'Indicates whether the account is enrolled in automatic payment processing. True when account has authorized automatic ACH, direct debit, or credit card charges for recurring invoices.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Email' ;
    rdfs:comment 'Email address of the primary billing contact person. Used for invoice inquiries, payment confirmations, and account correspondence.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactName rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Name' ;
    rdfs:comment 'Name of the primary billing contact person at the billing party organization. Accounts payable manager, controller, or designated billing representative.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactPhone rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Phone' ;
    rdfs:comment 'Primary phone number for the billing contact. Used for payment inquiries, dispute resolution, and collections communication.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the billing account was permanently closed. Null for active, suspended, or dormant accounts. Set when account status transitions to closed after final settlement.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consolidatedBillingFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidated Billing Flag' ;
    rdfs:comment 'Indicates whether this account receives consolidated invoices combining multiple transactions or sub-accounts into a single statement. Common for fleet and corporate accounts with multiple locations or cost centers.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditCheckDate rdf:type rdf:Property ;
    rdfs:label 'Credit Check Date' ;
    rdfs:comment 'Date of the most recent credit review or credit check performed for this account. Credit reviews are typically performed at account opening, annually, or when credit limit increase is requested.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Exposure Amount' ;
    rdfs:comment 'Current total outstanding receivables balance for this account, including open invoices and unbilled charges. Updated in near-real-time as transactions post. Compared against credit limit for credit control decisions.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum outstanding receivables balance allowed for this account before credit hold is triggered. Expressed in the account\'s base currency. Set by credit management based on creditworthiness assessment.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRatingCode rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Code' ;
    rdfs:comment 'Internal or external credit rating assigned to the billing party. AAA is highest creditworthiness, D is default, NR is not rated. Used for credit limit determination and risk management. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|CC|C|D|NR — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeCountYtd rdf:type rdf:Property ;
    rdfs:label 'Dispute Count Ytd' ;
    rdfs:comment 'Number of billing disputes or invoice challenges raised by this account in the current fiscal year. Used to identify problematic accounts and improve billing accuracy.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionChannelCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Code' ;
    rdfs:comment 'SAP distribution channel code indicating how products reach this account (e.g., direct sales, dealer network, fleet sales, export). Affects pricing and terms determination.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'SAP division code representing the product line or business unit (e.g., passenger vehicles, commercial vehicles, parts, service). Used for revenue segmentation and reporting.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsAccountCode rdf:type rdf:Property ;
    rdfs:label 'Dms Account Code' ;
    rdfs:comment 'External account identifier from the dealer management system (CDK Global DMS) for dealer accounts. Used to link billing account to dealer inventory, service, and F&I transactions. Null for non-dealer account types.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Dunning Block Flag' ;
    rdfs:comment 'Indicates whether automated dunning (collections) notices are blocked for this account. True when account is in dispute resolution, payment plan, or has special handling requirements.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning (collections) level for overdue accounts. Ranges from 0 (no overdue) to higher numbers indicating escalating collection actions. Drives automated dunning letter generation and collection workflow.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Invoice Delivery Method' ;
    rdfs:comment 'Preferred method for delivering invoices and statements to the billing party. Email for electronic delivery, postal mail for paper, EDI for automated B2B integration, portal for self-service access, fax for legacy systems.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Invoice Email Address' ;
    rdfs:comment 'Primary email address for electronic invoice and statement delivery. Used when invoice delivery method is email or as backup contact for portal notifications.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInvoiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Invoice Date' ;
    rdfs:comment 'Date of the most recent invoice issued to this account. Used to identify dormant accounts and track billing activity patterns.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'Amount of the most recent payment received from this account in the account\'s base currency. Used for payment pattern analysis and collections strategy.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent payment received from this account. Used for credit assessment, collections prioritization, and customer relationship management.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date when the billing account was first established and activated. Marks the beginning of the financial relationship.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethodPreference rdf:type rdf:Property ;
    rdfs:label 'Payment Method Preference' ;
    rdfs:comment 'Preferred payment method for this account. Wire transfer and ACH for electronic payments, check for paper payments, credit card for retail, direct debit for recurring charges, letter of credit for export accounts.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Payment Performance Score' ;
    rdfs:comment 'Calculated score (0-100) representing the account\'s payment timeliness and reliability. Based on historical payment patterns, days sales outstanding, and dispute frequency. Higher scores indicate better payment performance.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Standard payment terms code defining the due date calculation and discount conditions (e.g., NET30, NET60, 2/10NET30). Maps to SAP FI payment terms master data.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days from invoice date until payment is due. Derived from payment terms code but stored for reporting convenience.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Sales Organization Code' ;
    rdfs:comment 'SAP sales organization code responsible for this billing account. Defines the organizational unit for sales and distribution processes, pricing, and revenue recognition.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Registration Number' ;
    rdfs:comment 'Government-issued tax identification number for the billing party. Format varies by jurisdiction (e.g., EIN in USA, GST number in Canada, RFC in Mexico, VAT number in EU). Used for tax reporting and compliance.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Number' ;
    rdfs:comment 'VAT registration identifier for EU and other VAT jurisdictions. Required for cross-border invoicing and VAT reclaim. Format follows country-specific VAT ID structure.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Standard aging classification bucket based on days past due. Used for AR aging reports, bad debt provisioning, and collections prioritization.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current status of collection efforts for overdue receivables. Tracks progression through collections workflow from initial contact to legal action. [ENUM-REF-CANDIDATE: not_started|in_progress|on_hold|escalated|legal|resolved|abandoned — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Flag' ;
    rdfs:comment 'Boolean flag indicating whether the debtor account is on credit hold due to this or other overdue receivables. Credit hold blocks new orders and shipments.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerType rdf:type rdf:Property ;
    rdfs:label 'Customer Type' ;
    rdfs:comment 'Segment classification of the debtor. Distinguishes dealer network, retail consumers, fleet operators, government entities, rental companies, and leasing firms.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysPastDue rdf:type rdf:Property ;
    rdfs:label 'Days Past Due' ;
    rdfs:comment 'Number of calendar days the receivable is overdue. Calculated as current date minus due date for unpaid balances. Zero or negative for current receivables.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeReference rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference' ;
    rdfs:comment 'External reference number for the dispute case. Links to dispute resolution system or customer service ticket.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'General ledger account code where this receivable is posted. Typically an AR control account in the balance sheet.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date of the most recent contact attempt with the debtor regarding this receivable. Includes phone calls, emails, and letters.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date the most recent dunning notice was sent to the debtor. Used to calculate next dunning run eligibility and escalation timing.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDunningDate rdf:type rdf:Property ;
    rdfs:label 'Next Dunning Date' ;
    rdfs:comment 'Calculated date for the next dunning notice. Based on dunning frequency configuration and last dunning date.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalAmount rdf:type rdf:Property ;
    rdfs:label 'Original Amount' ;
    rdfs:comment 'Original gross amount of the receivable at invoice creation. Represents the initial debt obligation before any payments or adjustments.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Current unpaid balance remaining on the receivable. Calculated as original amount minus payments, credits, and adjustments. SSOT for AR aging reports.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Flag' ;
    rdfs:comment 'Boolean flag indicating whether the debtor is on an approved payment plan for this receivable. Payment plan receivables follow modified dunning rules.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Contractual payment terms governing the receivable. Defines the number of days until payment is due and any early payment discounts. [ENUM-REF-CANDIDATE: net_30|net_45|net_60|net_90|due_on_receipt|2_10_net_30|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivableNumber rdf:type rdf:Property ;
    rdfs:label 'Receivable Number' ;
    rdfs:comment 'Business-facing document number for the receivable item. Externally visible identifier used in collections correspondence and dunning letters.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivableStatus rdf:type rdf:Property ;
    rdfs:label 'Receivable Status' ;
    rdfs:comment 'Current lifecycle state of the receivable. Tracks progression from open through payment, dispute, collections, or write-off. [ENUM-REF-CANDIDATE: open|partially_paid|paid|disputed|written_off|under_collection|legal_action — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivableType rdf:type rdf:Property ;
    rdfs:label 'Receivable Type' ;
    rdfs:comment 'Classification of the receivable by business transaction type. Distinguishes vehicle sales, parts, service, warranty, fleet, incentive recovery, and finance charges. [ENUM-REF-CANDIDATE: vehicle_sale|parts_sale|service_charge|warranty_reimbursement|fleet_invoice|incentive_recovery|finance_charge — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRegion rdf:type rdf:Property ;
    rdfs:label 'Sales Region' ;
    rdfs:comment 'Geographic sales region where the transaction occurred. Used for regional revenue and collections performance analysis.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapFiCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Company Code' ;
    rdfs:comment 'SAP company code representing the legal entity that owns this receivable. Used for multi-entity consolidation and statutory reporting.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'Amount written off as bad debt. May differ from outstanding balance if partial recovery was achieved before write-off.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'Date the receivable was written off. Represents the accounting period when the bad debt expense was recognized.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffFlag rdf:type rdf:Property ;
    rdfs:label 'Write Off Flag' ;
    rdfs:comment 'Boolean flag indicating whether the receivable has been written off as uncollectible bad debt. Written-off receivables are removed from active AR aging.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:writeOffReason rdf:type rdf:Property ;
    rdfs:label 'Write Off Reason' ;
    rdfs:comment 'Reason code for the write-off decision. Documents the business justification for recognizing bad debt expense. [ENUM-REF-CANDIDATE: bankruptcy|insolvency|uncollectible|customer_closure|legal_settlement|small_balance|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerAccountId rdf:type rdf:Property ;
    rdfs:label 'Dealer Account Id' ;
    rdfs:comment 'Foreign key linking to billing.account. Business justification: Dealer statements are issued per dealer account; linking to the master account removes the redundant dealer_account_number column.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:agingBucket30DaysAmount rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket 30 Days Amount' ;
    rdfs:comment 'Portion of the closing balance that is 1-30 days past due.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingBucket60DaysAmount rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket 60 Days Amount' ;
    rdfs:comment 'Portion of the closing balance that is 31-60 days past due.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingBucket90DaysAmount rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket 90 Days Amount' ;
    rdfs:comment 'Portion of the closing balance that is 61-90 days past due.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingBucketCurrentAmount rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket Current Amount' ;
    rdfs:comment 'Portion of the closing balance that is current and not yet past due.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingBucketOver90DaysAmount rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket Over 90 Days Amount' ;
    rdfs:comment 'Portion of the closing balance that is more than 90 days past due.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCycleCode rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Code' ;
    rdfs:comment 'Code identifying the billing cycle or schedule under which this statement was generated.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdkStatementReference rdf:type rdf:Property ;
    rdfs:label 'Cdk Statement Reference' ;
    rdfs:comment 'External reference identifier from CDK Global DMS linking this statement to the dealer management system record.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Closing Balance Amount' ;
    rdfs:comment 'The outstanding balance at the end of the statement period, calculated as opening balance plus charges minus credits and payments.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeAmount rdf:type rdf:Property ;
    rdfs:label 'Dispute Amount' ;
    rdfs:comment 'The monetary amount under dispute by the dealer, if any.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:comment 'Code representing the reason for the dispute, such as pricing error, quantity discrepancy, or missing credit.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorplanFinancingFlag rdf:type rdf:Property ;
    rdfs:label 'Floorplan Financing Flag' ;
    rdfs:comment 'Indicates whether this statement includes floorplan financing charges or is relevant for floorplan reporting.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Opening Balance Amount' ;
    rdfs:comment 'The outstanding balance carried forward from the previous statement period.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The date by which the dealer is expected to remit payment for the closing balance.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementDate rdf:type rdf:Property ;
    rdfs:label 'Statement Date' ;
    rdfs:comment 'The date on which the statement was generated and issued to the dealer.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementNotes rdf:type rdf:Property ;
    rdfs:label 'Statement Notes' ;
    rdfs:comment 'Free-text field for additional notes, comments, or instructions related to this statement.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementNumber rdf:type rdf:Property ;
    rdfs:label 'Statement Number' ;
    rdfs:comment 'Unique business identifier for the dealer statement, externally visible and used for dealer reconciliation and reference.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period End Date' ;
    rdfs:comment 'The last date of the billing period covered by this statement.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period Start Date' ;
    rdfs:comment 'The first date of the billing period covered by this statement.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementStatus rdf:type rdf:Property ;
    rdfs:label 'Statement Status' ;
    rdfs:comment 'Current lifecycle status of the dealer statement indicating its processing stage.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementType rdf:type rdf:Property ;
    rdfs:label 'Statement Type' ;
    rdfs:comment 'Classification of the statement based on its frequency or purpose.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Total Adjustment Amount' ;
    rdfs:comment 'Sum of all manual adjustments applied to the dealer account during the statement period, including corrections and write-offs.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCreditMemoAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Memo Amount' ;
    rdfs:comment 'Sum of all credit memos issued to the dealer during the statement period, reducing the amount owed.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebitMemoAmount rdf:type rdf:Property ;
    rdfs:label 'Total Debit Memo Amount' ;
    rdfs:comment 'Sum of all debit memos issued to the dealer during the statement period, increasing the amount owed.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalIncentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Total Incentive Amount' ;
    rdfs:comment 'Sum of all dealer incentives, rebates, and promotional credits applied during the statement period.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Total Invoice Amount' ;
    rdfs:comment 'Sum of all invoices issued to the dealer during the statement period.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPartsSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Total Parts Sales Amount' ;
    rdfs:comment 'Sum of all parts sales invoices included in this statement period.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaymentReceivedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Received Amount' ;
    rdfs:comment 'Sum of all payments received from the dealer during the statement period.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalServiceChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Total Service Charges Amount' ;
    rdfs:comment 'Sum of all service and labor charges included in this statement period.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVehicleSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Total Vehicle Sales Amount' ;
    rdfs:comment 'Sum of all vehicle sales invoices included in this statement period.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWarrantyReimbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Total Warranty Reimbursement Amount' ;
    rdfs:comment 'Sum of all warranty claim reimbursements credited to the dealer during the statement period.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportRateId rdf:type rdf:Property ;
    rdfs:label 'Transport Rate Id' ;
    rdfs:comment 'Foreign key linking to logistics.transport_rate. Business justification: Billing price conditions for logistics services derive from contracted transport rates. Pricing procedures must reference transport rate master data to calculate invoice line amounts, apply fuel surch' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportRate .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether application of this pricing condition requires managerial or pricing authority approval before being applied to a billing transaction. True requires approval workflow.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculationType rdf:type rdf:Property ;
    rdfs:label 'Calculation Type' ;
    rdfs:comment 'Method used to calculate the condition value in the billing transaction. Defines whether the condition is applied as a fixed amount, percentage of base, quantity-dependent, or using a tiered/formula approach.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionClass rdf:type rdf:Property ;
    rdfs:label 'Condition Class' ;
    rdfs:comment 'High-level classification of the condition type grouping similar pricing elements together for reporting and analysis purposes.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionDescription rdf:type rdf:Property ;
    rdfs:label 'Condition Description' ;
    rdfs:comment 'Detailed textual description of the pricing condition, including its business purpose, applicability rules, and any special terms or restrictions. Provides context for pricing analysts and auditors.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionExclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Condition Exclusion Flag' ;
    rdfs:comment 'Indicates whether this condition is marked for exclusion from certain pricing scenarios or customer groups. True means the condition should be excluded under specific business rules.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Condition Record Number' ;
    rdfs:comment 'Business identifier for the pricing condition record, typically sourced from SAP SD condition record (KONP table). Used for external reference and traceability.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionStatus rdf:type rdf:Property ;
    rdfs:label 'Condition Status' ;
    rdfs:comment 'Current lifecycle status of the pricing condition record. Active conditions are available for use in billing; inactive, expired, or suspended conditions are not applied.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionStepNumber rdf:type rdf:Property ;
    rdfs:label 'Condition Step Number' ;
    rdfs:comment 'Sequence number within the pricing procedure that defines the order in which this condition is evaluated and applied during billing calculation.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionType rdf:type rdf:Property ;
    rdfs:label 'Condition Type' ;
    rdfs:comment 'Type of pricing condition applied to the billing transaction. Defines whether this is a base price (MSRP), negotiated price, discount, surcharge, tax, or other pricing element. Aligns with SAP SD condition types. [ENUM-REF-CANDIDATE: msrp|negotiated|fleet_discount|dealer_margin|volume_rebate|freight|pdi_charge|tax|surcharge|promotional_discount — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionUnit rdf:type rdf:Property ;
    rdfs:label 'Condition Unit' ;
    rdfs:comment 'Unit of measure for the condition value. Indicates whether the value is an absolute amount, a percentage, or a per-unit rate.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionValue rdf:type rdf:Property ;
    rdfs:label 'Condition Value' ;
    rdfs:comment 'Monetary or percentage value of the pricing condition. For absolute amounts, represents the price or adjustment in the condition currency. For percentage-based conditions, represents the rate (e.g., 5.5 for 5.5%).' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective End Timestamp' ;
    rdfs:comment 'Precise date and time when this pricing condition record version is superseded or becomes inactive in the lakehouse. Null indicates the current active version. Used for SCD Type 2 tracking.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Start Timestamp' ;
    rdfs:comment 'Precise date and time when this pricing condition record becomes effective in the lakehouse. Used for temporal queries and slowly changing dimension (SCD) Type 2 tracking.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isCurrentFlag rdf:type rdf:Property ;
    rdfs:label 'Is Current Flag' ;
    rdfs:comment 'Indicates whether this record represents the current active version of the pricing condition. True for the latest version, False for historical versions. Supports SCD Type 2 queries.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User ID or name of the person who last modified this pricing condition record. Supports change tracking and accountability.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manualOverrideAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Manual Override Allowed Flag' ;
    rdfs:comment 'Indicates whether sales or billing personnel are permitted to manually override this condition value during transaction processing. True allows manual adjustment, False enforces system-determined value.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingProcedureCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Procedure Code' ;
    rdfs:comment 'Reference to the SAP SD pricing procedure that governs the sequence and logic of condition application. Links this condition to the broader pricing determination framework.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapConditionTable rdf:type rdf:Property ;
    rdfs:label 'Sap Condition Table' ;
    rdfs:comment 'Name of the SAP SD condition table (e.g., A001, A002) from which this condition record is sourced. Provides traceability to the source system configuration.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapKonpRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Konp Record Number' ;
    rdfs:comment 'Reference to the SAP SD KONP table record number that stores the condition record master data. Enables direct linkage to the source system for audit and reconciliation.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapKonvCounter rdf:type rdf:Property ;
    rdfs:label 'Sap Konv Counter' ;
    rdfs:comment 'Reference to the SAP SD KONV table counter that tracks condition application instances in sales and billing documents. Used for transaction-level traceability.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleBasis rdf:type rdf:Property ;
    rdfs:label 'Scale Basis' ;
    rdfs:comment 'Basis for scale-based pricing conditions. Defines the dimension (quantity, value, weight, volume) used to determine tiered pricing or volume-based discounts.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleQuantityFrom rdf:type rdf:Property ;
    rdfs:label 'Scale Quantity From' ;
    rdfs:comment 'Lower bound of the scale range for tiered pricing conditions. Defines the minimum quantity or value at which this condition rate applies.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleQuantityTo rdf:type rdf:Property ;
    rdfs:label 'Scale Quantity To' ;
    rdfs:comment 'Upper bound of the scale range for tiered pricing conditions. Defines the maximum quantity or value at which this condition rate applies. Null indicates no upper limit.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'Start date from which this pricing condition becomes effective and can be applied to billing transactions. Part of the condition validity period.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'End date until which this pricing condition remains effective. Null indicates the condition is valid indefinitely. Part of the condition validity period.' ;
    rdfs:domain ind:PriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicableAccountTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Account Types' ;
    rdfs:comment 'Comma-separated list of billing account types to which this payment term applies (e.g., dealer, fleet, retail, corporate, OEM (Original Equipment Manufacturer)).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether finance or credit manager approval is required before this payment term can be assigned to a customer account.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoDunningEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Dunning Enabled' ;
    rdfs:comment 'Indicates whether automatic dunning (collection reminder) process is enabled for invoices using this payment term.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baselineDateRule rdf:type rdf:Property ;
    rdfs:label 'Baseline Date Rule' ;
    rdfs:comment 'Rule defining the baseline date from which net due days and discount days are calculated (invoice date, delivery date, end of month, or custom).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'Code identifying the business unit or division that owns and manages this payment term (e.g., DEALER, FLEET, PARTS).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Credit Check Required' ;
    rdfs:comment 'Indicates whether a credit check is required before this payment term can be assigned to a billing account.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountDays1 rdf:type rdf:Property ;
    rdfs:label 'Discount Days 1' ;
    rdfs:comment 'Number of days from invoice date within which discount percentage 1 applies.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountDays2 rdf:type rdf:Property ;
    rdfs:label 'Discount Days 2' ;
    rdfs:comment 'Number of days from invoice date within which discount percentage 2 applies (typically longer than discount days 1).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountPercentage1 rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage 1' ;
    rdfs:comment 'First early payment discount percentage offered if payment is made within discount days 1 (e.g., 2.00 for 2%).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountPercentage2 rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage 2' ;
    rdfs:comment 'Second early payment discount percentage offered if payment is made within discount days 2 (typically lower than discount 1).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixedDayOfMonth rdf:type rdf:Property ;
    rdfs:label 'Fixed Day Of Month' ;
    rdfs:comment 'If baseline date rule is custom, specifies a fixed day of the month for payment due date (e.g., 15 for the 15th of each month). Null if not applicable.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Value' ;
    rdfs:comment 'Maximum invoice or order value for which this payment term is applicable. Null if no maximum.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Value' ;
    rdfs:comment 'Minimum invoice or order value required for this payment term to be applicable. Null if no minimum.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netDueDays rdf:type rdf:Property ;
    rdfs:label 'Net Due Days' ;
    rdfs:comment 'Number of days from invoice date by which full payment is due without penalty.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentMethodRestriction rdf:type rdf:Property ;
    rdfs:label 'Payment Method Restriction' ;
    rdfs:comment 'Comma-separated list of allowed payment methods for this term (e.g., wire_transfer, check, ACH, credit_card). Empty if no restriction.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermCode rdf:type rdf:Property ;
    rdfs:label 'Payment Term Code' ;
    rdfs:comment 'Short alphanumeric code representing the payment term (e.g., NET30, 2/10N30, COD). Maps to SAP FI payment term key in table T052.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Term Description' ;
    rdfs:comment 'Detailed explanation of the payment term conditions, including discount and penalty clauses.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermName rdf:type rdf:Property ;
    rdfs:label 'Payment Term Name' ;
    rdfs:comment 'Full descriptive name of the payment term (e.g., Net 30 Days, 2% 10 Net 30, Cash on Delivery).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Term Status' ;
    rdfs:comment 'Current lifecycle status of the payment term: active (in use), inactive (not available for new assignments), deprecated (legacy term), or pending approval (awaiting finance approval).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Penalty Calculation Method' ;
    rdfs:comment 'Method used to calculate late payment penalties: daily accrual, monthly accrual, flat fee, or none.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyGraceDays rdf:type rdf:Property ;
    rdfs:label 'Penalty Grace Days' ;
    rdfs:comment 'Number of days after net due date before penalty charges begin to accrue.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyRate rdf:type rdf:Property ;
    rdfs:label 'Penalty Rate' ;
    rdfs:comment 'Late payment penalty rate applied after grace period expires, expressed as percentage per period (e.g., 1.5% per month).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapFiPaymentTermKey rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Payment Term Key' ;
    rdfs:comment 'Reference to the SAP FI payment term key in table T052 for ERP (Enterprise Resource Planning) integration and synchronization.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Number of active billing accounts or invoices currently using this payment term. Used for impact analysis before deprecation.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableTransactionTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Transaction Types' ;
    rdfs:comment 'Comma-separated list of transaction types to which this tax code applies. Examples: vehicle_sale, parts_sale, service_labor, warranty_repair, fleet_lease, export_sale, dealer_invoice, retail_invoice. Supports multi-transaction applicability.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'The method used to calculate the tax amount. Percentage for rate-based calculation, fixed_amount for flat fees, tiered for progressive rates based on value bands, formula_based for complex calculations (e.g., emissions-based environmental levies).' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionCertificateRequired rdf:type rdf:Property ;
    rdfs:label 'Exemption Certificate Required' ;
    rdfs:comment 'Indicates whether a tax exemption certificate must be on file to apply this code for exempt transactions. True if certificate is mandatory, False otherwise. Supports compliance with exemption documentation requirements.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDeductible rdf:type rdf:Property ;
    rdfs:label 'Is Deductible' ;
    rdfs:comment 'Indicates whether the tax is deductible as a business expense for income tax purposes. Relevant for excise duties and certain non-recoverable taxes.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecoverable rdf:type rdf:Property ;
    rdfs:label 'Is Recoverable' ;
    rdfs:comment 'Indicates whether the tax paid under this code can be recovered or reclaimed from the tax authority (e.g., input VAT). True for recoverable taxes, False for non-recoverable taxes.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Level' ;
    rdfs:comment 'The governmental or regional level at which this tax is levied. Federal for national taxes, state for US state or equivalent provincial taxes, local for city/county taxes, EU for European Union-wide directives, APAC for Asia-Pacific regional harmonized taxes, multi_jurisdiction for taxes spanning multiple levels.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Code' ;
    rdfs:comment 'The code or box number used when reporting this tax on statutory returns (e.g., VAT return box 1, GST return line 3A). Supports automated regulatory reporting and compliance.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reverseChargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Reverse Charge Applicable' ;
    rdfs:comment 'Indicates whether the reverse charge mechanism applies, where the customer rather than the supplier accounts for VAT. Common in B2B cross-border EU transactions and certain domestic supplies.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roundingPrecision rdf:type rdf:Property ;
    rdfs:label 'Rounding Precision' ;
    rdfs:comment 'The number of decimal places to which tax amounts are rounded (e.g., 2 for cents/pence, 0 for whole currency units). Supports multi-currency precision requirements.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roundingRule rdf:type rdf:Property ;
    rdfs:label 'Rounding Rule' ;
    rdfs:comment 'The rounding method applied to calculated tax amounts. Round_up for ceiling, round_down for floor, round_nearest for standard rounding, no_rounding for exact amounts. Ensures compliance with jurisdiction-specific rounding regulations.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapFiTaxCode rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Tax Code' ;
    rdfs:comment 'The corresponding tax code identifier in SAP FI module (table T007A, field MWSKZ). Typically 1-2 character alphanumeric. Enables integration and reconciliation between lakehouse and SAP ERP.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSdTaxCode rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Tax Code' ;
    rdfs:comment 'The corresponding tax code identifier in SAP SD module used in sales orders and billing documents. May differ from FI code in some implementations. Supports sales-specific tax determination.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Name' ;
    rdfs:comment 'The name of the governmental or regulatory body responsible for administering this tax. Examples: Internal Revenue Service (IRS), HM Revenue & Customs (HMRC), Goods and Services Tax Network (GSTN), California Department of Tax and Fee Administration.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAuthorityReference rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Reference' ;
    rdfs:comment 'The official reference number, code, or identifier assigned by the tax authority for this tax type or rate. Used for regulatory reporting and audit trail.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxBasis rdf:type rdf:Property ;
    rdfs:label 'Tax Basis' ;
    rdfs:comment 'The base amount on which the tax rate is applied. Net_amount for taxes on pre-tax subtotal, gross_amount for taxes on total including other taxes (cascading), MSRP (Manufacturer Suggested Retail Price) for luxury taxes, invoice_value for dealer invoices, customs_value for import duties.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'The accounting treatment category for this tax. Input_tax for recoverable VAT on purchases, output_tax for VAT charged on sales, withholding_tax for taxes deducted at source, reverse_charge for customer-remitted VAT, exempt for tax-exempt transactions, zero_rated for 0% taxable supplies.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCodeCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code Code' ;
    rdfs:comment 'The alphanumeric tax code identifier used in billing and invoicing systems. Maps to SAP FI/SD tax code field (MWSKZ). Examples: VAT_STD, GST_18, SALES_TX_CA, EXCISE_LUX.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCodeName rdf:type rdf:Property ;
    rdfs:label 'Tax Code Name' ;
    rdfs:comment 'Human-readable name or description of the tax code for display and reporting purposes.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Code Status' ;
    rdfs:comment 'Current lifecycle status of the tax code. Active for codes in use, inactive for retired codes, pending for codes awaiting regulatory approval, superseded for codes replaced by newer versions.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'The tax rate as a percentage (e.g., 19.0000 for 19% VAT, 5.5000 for 5.5% GST). Precision to four decimal places supports fine-grained rates. Used to calculate tax amount from taxable base.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'The category of tax represented by this code. VAT (Value Added Tax) for EU and similar jurisdictions, GST (Goods and Services Tax) for India/Australia/Canada, sales_tax for US state-level, excise for fuel/alcohol/tobacco duties, luxury_tax for high-value vehicles, environmental_levy for emissions-based charges.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxApplicable rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Applicable' ;
    rdfs:comment 'Indicates whether withholding tax provisions apply to transactions using this code. Relevant for cross-border payments and certain domestic transactions where tax is deducted at source.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:beneficiaryAccountId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Account Id' ;
    rdfs:comment 'Identifier of the dealer or fleet customer account that is the recipient of the rebate. Links to dealer or customer master data.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:regulatoryRequirementId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_requirement. Business justification: Rebate programs are tied to specific regulatory incentives; linking enables tracking of compliance-driven rebates.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryRequirement .

ind:accrualMethod rdf:type rdf:Property ;
    rdfs:label 'Accrual Method' ;
    rdfs:comment 'Method by which rebate amounts are calculated and accrued: periodic (monthly/quarterly calculation), milestone (triggered when target is reached), transaction_based (accrued per invoice).' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:achievedVolume rdf:type rdf:Property ;
    rdfs:label 'Achieved Volume' ;
    rdfs:comment 'Actual number of vehicle units sold or delivered under this agreement as of the last accrual calculation. Updated periodically based on billing transactions.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Approval workflow status for the rebate agreement: pending_approval (awaiting management sign-off), approved (authorized for execution), rejected (not approved).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryType rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Type' ;
    rdfs:comment 'Classification of the rebate recipient: dealer (franchise dealership), fleet_customer (commercial fleet operator), distributor (regional distributor), broker (third-party intermediary).' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference number or file path to the signed legal contract or agreement document supporting this rebate arrangement. Used for audit and compliance.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Description of the dispute or disagreement related to the rebate agreement terms, calculation, or settlement. Null if no dispute exists.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRetroactive rdf:type rdf:Property ;
    rdfs:label 'Is Retroactive' ;
    rdfs:comment 'Indicates whether the rebate agreement applies retroactively to transactions that occurred before the agreement effective start date. True if retroactive, False otherwise.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAccrualCalculationDate rdf:type rdf:Property ;
    rdfs:label 'Last Accrual Calculation Date' ;
    rdfs:comment 'Date when the rebate accrual amounts were last recalculated based on eligible transactions. Used to track data freshness and trigger next calculation cycle.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Last Settlement Date' ;
    rdfs:comment 'Date of the most recent rebate settlement payment or credit memo issuance. Null if no settlements have occurred.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Next Settlement Date' ;
    rdfs:comment 'Scheduled date for the next rebate settlement payment or credit memo generation. Null if agreement is settled or terminated.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rebateAmountPerUnit rdf:type rdf:Property ;
    rdfs:label 'Rebate Amount Per Unit' ;
    rdfs:comment 'Fixed rebate amount paid per vehicle unit sold. Used for flat-rate rebate structures. Null if percentage-based rebate is used.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateRatePercent rdf:type rdf:Property ;
    rdfs:label 'Rebate Rate Percent' ;
    rdfs:comment 'Percentage rate applied to eligible transaction amounts to calculate rebate accrual. Used for percentage-based rebate structures. Null if fixed amount rebate is used.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapRebateAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Rebate Agreement Number' ;
    rdfs:comment 'SAP SD rebate agreement reference number from transaction codes BO01 (create) or BO02 (change). Used for system integration and traceability.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Frequency' ;
    rdfs:comment 'Frequency at which accrued rebates are paid out to the beneficiary: monthly, quarterly, semi_annual, annual, or upon_completion (at agreement end).' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Current status of rebate settlement: not_started (no payments made), in_progress (settlement cycle active), partially_settled (some payments made), fully_settled (all accruals paid), disputed (settlement under review).' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetVolume rdf:type rdf:Property ;
    rdfs:label 'Target Volume' ;
    rdfs:comment 'Target number of vehicle units that must be sold or delivered to qualify for the rebate. Null for non-volume-based agreements.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAccruedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Accrued Amount' ;
    rdfs:comment 'Cumulative rebate amount accrued under this agreement as of the last calculation date. Represents the liability owed to the beneficiary.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSettledAmount rdf:type rdf:Property ;
    rdfs:label 'Total Settled Amount' ;
    rdfs:comment 'Cumulative rebate amount paid out to the beneficiary through credit memos or direct payments. Used to track settlement progress.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opportunityCustomerPartyId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Customer Party Id' ;
    rdfs:comment 'Reference to the prospect or customer associated with this opportunity.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:opportunityModelId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Model Id' ;
    rdfs:comment 'Foreign key linking to vehicle.model. Business justification: Opportunity tracking by model enables sales forecasting, market analysis, and model performance dashboards.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Model .

ind:opportunityPartyId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Party Id' ;
    rdfs:comment 'Reference to the prospect or customer associated with this opportunity.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:opportunityRepId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Rep Id' ;
    rdfs:comment 'Reference to the sales representative or account owner assigned to this opportunity.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:opportunitySalesRepresentativeRepId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Sales Representative Rep Id' ;
    rdfs:comment 'Reference to the sales representative or account owner assigned to this opportunity.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:opportunityVehicleModelId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Vehicle Model Id' ;
    rdfs:comment 'Reference to the specific vehicle configuration or model of interest for this opportunity.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Model .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'Actual date when the opportunity was closed (won or lost).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitorBrand rdf:type rdf:Property ;
    rdfs:label 'Competitor Brand' ;
    rdfs:comment 'Competitor brand or OEM that the customer is also considering, if known.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'Preferred delivery location or dealership for vehicle handover.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Value' ;
    rdfs:comment 'Estimated total deal value including vehicle price, options, accessories, and services.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Close Date' ;
    rdfs:comment 'Anticipated date when the opportunity is expected to close (either won or lost).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exteriorColor rdf:type rdf:Property ;
    rdfs:label 'Exterior Color' ;
    rdfs:comment 'Preferred exterior color for the vehicle.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetSize rdf:type rdf:Property ;
    rdfs:label 'Fleet Size' ;
    rdfs:comment 'Number of vehicles in the fleet opportunity, applicable for fleet and commercial sales.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interiorColor rdf:type rdf:Property ;
    rdfs:label 'Interior Color' ;
    rdfs:comment 'Preferred interior color or trim for the vehicle.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether the opportunity is currently active (open) or closed.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWon rdf:type rdf:Property ;
    rdfs:label 'Is Won' ;
    rdfs:comment 'Indicates whether the opportunity was closed as won (successful sale).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent sales activity or interaction related to this opportunity.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Original channel or source through which the opportunity was generated. [ENUM-REF-CANDIDATE: web|phone|email|walk_in|referral|event|advertising|social_media|partner — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Primary reason why the opportunity was lost, if applicable. [ENUM-REF-CANDIDATE: price|product_fit|competitor|timing|financing|no_response|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Next Follow Up Date' ;
    rdfs:comment 'Scheduled date for the next follow-up activity with the prospect.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Descriptive name of the opportunity, typically including prospect name and vehicle of interest.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityNumber rdf:type rdf:Property ;
    rdfs:label 'Opportunity Number' ;
    rdfs:comment 'Business-facing unique identifier for the opportunity, typically auto-generated and used in communications with dealers and sales teams.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityType rdf:type rdf:Property ;
    rdfs:label 'Opportunity Type' ;
    rdfs:comment 'Classification of the opportunity based on customer segment and purchase type.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probability rdf:type rdf:Property ;
    rdfs:label 'Probability' ;
    rdfs:comment 'Estimated probability of closing this opportunity successfully, expressed as a percentage (0-100).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quoteDate rdf:type rdf:Property ;
    rdfs:label 'Quote Date' ;
    rdfs:comment 'Date when the quote was generated, if applicable.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteGenerated rdf:type rdf:Property ;
    rdfs:label 'Quote Generated' ;
    rdfs:comment 'Indicates whether a formal quote has been generated for this opportunity.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesStage rdf:type rdf:Property ;
    rdfs:label 'Sales Stage' ;
    rdfs:comment 'Current stage of the opportunity in the sales pipeline, reflecting progression from initial contact through close. [ENUM-REF-CANDIDATE: lead|qualification|needs_analysis|test_drive|quote|negotiation|closed_won|closed_lost — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDriveCompleted rdf:type rdf:Property ;
    rdfs:label 'Test Drive Completed' ;
    rdfs:comment 'Indicates whether the prospect has completed a test drive for the vehicle of interest.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testDriveDate rdf:type rdf:Property ;
    rdfs:label 'Test Drive Date' ;
    rdfs:comment 'Date when the test drive was completed, if applicable.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradeInValue rdf:type rdf:Property ;
    rdfs:label 'Trade In Value' ;
    rdfs:comment 'Appraised value of the customer\'s trade-in vehicle, if applicable.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleConfiguration rdf:type rdf:Property ;
    rdfs:label 'Vehicle Configuration' ;
    rdfs:comment 'Detailed configuration of the vehicle including trim level, options, and packages.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winReason rdf:type rdf:Property ;
    rdfs:label 'Win Reason' ;
    rdfs:comment 'Primary reason why the opportunity was won, if applicable. [ENUM-REF-CANDIDATE: price|product_features|brand_loyalty|service|financing|relationship|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadId rdf:type rdf:Property ;
    rdfs:label 'Lead Id' ;
    rdfs:comment 'Unique identifier for the sales lead record. Primary key.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lead .

ind:convertedOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Converted Opportunity Id' ;
    rdfs:comment 'Identifier of the opportunity record created upon lead conversion. Null if not yet converted.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:leadAssignedDealerDealershipId rdf:type rdf:Property ;
    rdfs:label 'Lead Assigned Dealer Dealership Id' ;
    rdfs:comment 'Identifier of the dealership assigned to this lead for follow-up and conversion.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:leadAssignedOwnerRepId rdf:type rdf:Property ;
    rdfs:label 'Lead Assigned Owner Rep Id' ;
    rdfs:comment 'Identifier of the sales representative or dealer contact assigned to follow up on this lead.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:leadDealershipId rdf:type rdf:Property ;
    rdfs:label 'Lead Dealership Id' ;
    rdfs:comment 'Identifier of the dealership assigned to this lead for follow-up and conversion.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:leadRepId rdf:type rdf:Property ;
    rdfs:label 'Lead Rep Id' ;
    rdfs:comment 'Identifier of the sales representative or dealer contact assigned to follow up on this lead.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:companyName rdf:type rdf:Property ;
    rdfs:label 'Company Name' ;
    rdfs:comment 'Name of the organization or company associated with the lead, applicable for fleet sales or commercial vehicle inquiries.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedDate rdf:type rdf:Property ;
    rdfs:label 'Converted Date' ;
    rdfs:comment 'The date when the lead was converted into an opportunity. Null if not yet converted. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Budget Amount' ;
    rdfs:comment 'Estimated budget or price range the lead has indicated for the vehicle purchase.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financingInterest rdf:type rdf:Property ;
    rdfs:label 'Financing Interest' ;
    rdfs:comment 'Boolean flag indicating whether the lead is interested in financing or leasing options.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadNumber rdf:type rdf:Property ;
    rdfs:label 'Lead Number' ;
    rdfs:comment 'Human-readable business identifier for the lead, typically auto-generated by the CRM system. Format: LEAD-NNNNNNNN.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadStatus rdf:type rdf:Property ;
    rdfs:label 'Lead Status' ;
    rdfs:comment 'Current lifecycle status of the lead in the sales pipeline (new, contacted, qualified, unqualified, converted to opportunity, lost).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadType rdf:type rdf:Property ;
    rdfs:label 'Lead Type' ;
    rdfs:comment 'Classification of the lead based on buyer category: individual consumer, fleet buyer, commercial enterprise, or government entity.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lostReason rdf:type rdf:Property ;
    rdfs:label 'Lost Reason' ;
    rdfs:comment 'Reason why the lead was marked as lost (e.g., purchased from competitor, no longer interested, unresponsive).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelYearInterest rdf:type rdf:Property ;
    rdfs:label 'Model Year Interest' ;
    rdfs:comment 'The model year (MY) of the vehicle the lead is interested in purchasing.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInEmail rdf:type rdf:Property ;
    rdfs:label 'Opt In Email' ;
    rdfs:comment 'Boolean flag indicating whether the lead has opted in to receive email marketing communications.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInPhone rdf:type rdf:Property ;
    rdfs:label 'Opt In Phone' ;
    rdfs:comment 'Boolean flag indicating whether the lead has opted in to receive phone call communications.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInSms rdf:type rdf:Property ;
    rdfs:label 'Opt In Sms' ;
    rdfs:comment 'Boolean flag indicating whether the lead has opted in to receive SMS marketing communications.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purchaseTimeframe rdf:type rdf:Property ;
    rdfs:label 'Purchase Timeframe' ;
    rdfs:comment 'Expected timeframe within which the lead intends to make a purchase decision (immediate, within 30 days, within 90 days, within 6 months, or future/undecided).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationScore rdf:type rdf:Property ;
    rdfs:label 'Qualification Score' ;
    rdfs:comment 'Numeric score (0-100) representing the leads likelihood to convert, based on engagement, budget, authority, need, and timeline (BANT criteria).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rating rdf:type rdf:Property ;
    rdfs:label 'Rating' ;
    rdfs:comment 'Qualitative rating of the lead based on engagement and conversion potential: hot (high priority), warm (moderate interest), cold (low engagement).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'Name or identifier of the person or entity that referred this lead, if applicable.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streetAddress rdf:type rdf:Property ;
    rdfs:label 'Street Address' ;
    rdfs:comment 'Street address of the lead, used for delivery and service planning.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDriveRequested rdf:type rdf:Property ;
    rdfs:label 'Test Drive Requested' ;
    rdfs:comment 'Boolean flag indicating whether the lead has requested a test drive.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeInInterest rdf:type rdf:Property ;
    rdfs:label 'Trade In Interest' ;
    rdfs:comment 'Boolean flag indicating whether the lead has expressed interest in trading in an existing vehicle as part of the purchase.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unqualifiedReason rdf:type rdf:Property ;
    rdfs:label 'Unqualified Reason' ;
    rdfs:comment 'Reason why the lead was marked as unqualified (e.g., no budget, no authority, no need, incorrect contact information).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleInterestCategory rdf:type rdf:Property ;
    rdfs:label 'Vehicle Interest Category' ;
    rdfs:comment 'The powertrain category of vehicle the lead is interested in: ICE (Internal Combustion Engine), EV (Electric Vehicle), HEV (Hybrid Electric Vehicle), or PHEV (Plug-in Hybrid Electric Vehicle).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:webFormCode rdf:type rdf:Property ;
    rdfs:label 'Web Form Code' ;
    rdfs:comment 'Identifier of the web form or landing page through which the lead was captured, used for digital campaign attribution.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteId rdf:type rdf:Property ;
    rdfs:label 'Quote Id' ;
    rdfs:comment 'Primary key for quote' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:quoteCustomerPartyId rdf:type rdf:Property ;
    rdfs:label 'Quote Customer Party Id' ;
    rdfs:comment 'Reference to the customer or prospect receiving this quote. Links to customer master data in SAP or Salesforce Automotive Cloud.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:quoteDealerDealershipId rdf:type rdf:Property ;
    rdfs:label 'Quote Dealer Dealership Id' ;
    rdfs:comment 'Reference to the dealership or direct sales channel issuing the quote. Links to dealer master data in CDK Global DMS or SAP.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:quoteDealershipId rdf:type rdf:Property ;
    rdfs:label 'Quote Dealership Id' ;
    rdfs:comment 'Reference to the dealership or direct sales channel issuing the quote. Links to dealer master data in CDK Global DMS or SAP.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:quotePartyId rdf:type rdf:Property ;
    rdfs:label 'Quote Party Id' ;
    rdfs:comment 'Reference to the customer or prospect receiving this quote. Links to customer master data in SAP or Salesforce Automotive Cloud.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:quoteVehicleVinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Quote Vehicle Vin Registry Id' ;
    rdfs:comment 'Reference to the specific vehicle configuration being quoted. Links to vehicle master data including model, trim, powertrain, and options.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VinRegistry .

ind:quoteVinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Quote Vin Registry Id' ;
    rdfs:comment 'Reference to the specific vehicle configuration being quoted. Links to vehicle master data including model, trim, powertrain, and options.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VinRegistry .

ind:vehicleWarrantyId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Warranty Id' ;
    rdfs:comment 'Foreign key linking to aftersales.vehicle_warranty. Business justification: Quote generation systems check existing warranty coverage to calculate net customer pricing, determine what\'s warranty-covered vs. customer-paid, and present accurate out-of-pocket costs. Standard aut' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleWarranty .

ind:accessoriesTotal rdf:type rdf:Property ;
    rdfs:label 'Accessories Total' ;
    rdfs:comment 'Total value of dealer-installed accessories (e.g., floor mats, cargo organizers, protection packages). Separate from factory options.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aprRate rdf:type rdf:Property ;
    rdfs:label 'Apr Rate' ;
    rdfs:comment 'Annual percentage rate for financing if offered. Expressed as decimal (e.g., 0.0399 for 3.99% APR). Subject to credit approval.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Date when quote was converted to order. Used for sales cycle time analytics and conversion rate reporting.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:convertedToOrder rdf:type rdf:Property ;
    rdfs:label 'Converted To Order' ;
    rdfs:comment 'Indicates whether this quote was successfully converted to a customer order. True when customer accepts quote and order is created in SAP SD.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method by which customer will take delivery of vehicle. Dealer pickup is standard; home delivery, port pickup (for imports), and factory pickup (for premium brands) are alternatives.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCharge rdf:type rdf:Property ;
    rdfs:label 'Destination Charge' ;
    rdfs:comment 'Freight and delivery charge from manufacturing plant to dealer. Typically a fixed amount per vehicle set by OEM.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineCode rdf:type rdf:Property ;
    rdfs:label 'Engine Code' ;
    rdfs:comment 'Internal code identifying the specific engine or electric motor configuration. Used for parts ordering and service documentation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financingOffered rdf:type rdf:Property ;
    rdfs:label 'Financing Offered' ;
    rdfs:comment 'Indicates whether financing terms are included in this quote. True if quote includes loan or lease options, false for cash-only quotes.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financingTermMonths rdf:type rdf:Property ;
    rdfs:label 'Financing Term Months' ;
    rdfs:comment 'Length of financing term in months if financing_offered is true. Common terms: 36, 48, 60, 72, 84 months.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentiveTotal rdf:type rdf:Property ;
    rdfs:label 'Incentive Total' ;
    rdfs:comment 'Total value of manufacturer incentives, rebates, and discounts applied to this quote (e.g., loyalty bonus, conquest incentive, EV tax credit eligibility). Reduces net selling price.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseAnnualMileage rdf:type rdf:Property ;
    rdfs:label 'Lease Annual Mileage' ;
    rdfs:comment 'Annual mileage allowance for lease if offered. Common values: 10000, 12000, 15000 miles per year. Excess mileage incurs per-mile charges.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaseMonthlyPayment rdf:type rdf:Property ;
    rdfs:label 'Lease Monthly Payment' ;
    rdfs:comment 'Estimated monthly lease payment if lease is offered. Based on capitalized cost, residual value, money factor, and term.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseOffered rdf:type rdf:Property ;
    rdfs:label 'Lease Offered' ;
    rdfs:comment 'Indicates whether lease terms are included in this quote as an alternative to purchase financing.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseTermMonths rdf:type rdf:Property ;
    rdfs:label 'Lease Term Months' ;
    rdfs:comment 'Length of lease term in months if lease_offered is true. Common terms: 24, 36, 39, 48 months.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:msrpBase rdf:type rdf:Property ;
    rdfs:label 'Msrp Base' ;
    rdfs:comment 'Base MSRP for the vehicle model and trim before options, accessories, and destination charges. Published pricing from OEM.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Net Selling Price' ;
    rdfs:comment 'Final vehicle price after all incentives and trade-in allowance. Calculated as subtotal_amount - incentive_total - trade_in_allowance + trade_in_payoff. Base for tax calculation.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optionsTotal rdf:type rdf:Property ;
    rdfs:label 'Options Total' ;
    rdfs:comment 'Total value of factory-installed options and packages selected by customer (e.g., ADAS, premium audio, sunroof). Sum of individual option prices.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quoteNumber rdf:type rdf:Property ;
    rdfs:label 'Quote Number' ;
    rdfs:comment 'Externally visible business identifier for the quote, typically generated by SAP SD (VA21) or Salesforce Automotive Cloud. Used for customer communication and dealer reference.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteStatus rdf:type rdf:Property ;
    rdfs:label 'Quote Status' ;
    rdfs:comment 'Current lifecycle status of the quote. Tracks progression from draft through approval to conversion or expiry. [ENUM-REF-CANDIDATE: draft|submitted|approved|rejected|expired|converted|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteType rdf:type rdf:Property ;
    rdfs:label 'Quote Type' ;
    rdfs:comment 'Classification of quote by sales channel and vehicle delivery format. Retail for individual consumers, fleet for corporate bulk orders, CKD (Completely Knocked Down) and SKD (Semi Knocked Down) for export assembly, commercial for business vehicles, demo for demonstration units. [ENUM-REF-CANDIDATE: retail|fleet|ckd|skd|commercial|demo|export — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationFee rdf:type rdf:Property ;
    rdfs:label 'Registration Fee' ;
    rdfs:comment 'Government registration and title fees for the vehicle. Varies by state/province and vehicle type.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'Channel through which quote was generated. Dealer for franchise network, direct for OEM-owned stores, online for digital sales, fleet for corporate accounts, broker for third-party intermediaries.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmountDue rdf:type rdf:Property ;
    rdfs:label 'Total Amount Due' ;
    rdfs:comment 'Final total amount customer must pay. Calculated as net_selling_price + tax_amount + registration_fee + doc_fee. Used for financing calculation or cash payment.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeInPayoff rdf:type rdf:Property ;
    rdfs:label 'Trade In Payoff' ;
    rdfs:comment 'Outstanding loan balance on trade-in vehicle that must be paid off. If greater than trade_in_allowance, creates negative equity rolled into new financing.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trimLevel rdf:type rdf:Property ;
    rdfs:label 'Trim Level' ;
    rdfs:comment 'Trim or grade level of the vehicle (e.g., Base, Sport, Luxury, Premium). Determines standard equipment and base pricing.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of the quote. Increments when quote is revised with updated pricing, configuration, or terms. Supports quote revision history and audit trail.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteLineId rdf:type rdf:Property ;
    rdfs:label 'Quote Line Id' ;
    rdfs:comment 'Unique identifier for the quote line item. Primary key.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryQuoteVehicleVinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Primary Quote Vehicle Vin Registry Id' ;
    rdfs:comment 'Reference to the specific vehicle configuration being quoted. Applicable when line_type is vehicle. Links to the vehicle master for model, trim, and base specifications.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VinRegistry .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Current availability status of the line item. Indicates whether the product is in dealer inventory, allocated from manufacturer, requires build-to-order, is backordered, or has been discontinued.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionEligible rdf:type rdf:Property ;
    rdfs:label 'Commission Eligible' ;
    rdfs:comment 'Indicates whether this line item is eligible for sales representative commission. Certain line types (fees, trade-ins) may be excluded from commission calculations.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'Commission rate applied to this line item for sales representative compensation. Expressed as a decimal percentage. May vary by product type and sales program.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extendedPrice rdf:type rdf:Property ;
    rdfs:label 'Extended Price' ;
    rdfs:comment 'Line item subtotal before tax. Calculated as (unit_price * quantity) - discount_amount - incentive_amount. Represents the pre-tax line total.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveDescription rdf:type rdf:Property ;
    rdfs:label 'Incentive Description' ;
    rdfs:comment 'Human-readable description of the incentive applied. Provides customer-facing explanation of the incentive program, eligibility criteria, and value proposition.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTotal rdf:type rdf:Property ;
    rdfs:label 'Line Total' ;
    rdfs:comment 'Total amount for this line item including tax. Calculated as extended_price + tax_amount. Represents the final customer-facing line total.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginAmount rdf:type rdf:Property ;
    rdfs:label 'Margin Amount' ;
    rdfs:comment 'Gross margin for this line item. Calculated as extended_price - cost_amount. Used for profitability analysis and sales performance evaluation.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelCode rdf:type rdf:Property ;
    rdfs:label 'Model Code' ;
    rdfs:comment 'Manufacturer model code representing the configured vehicle variant. Includes base model, trim level, and factory option packages. Used for pricing and inventory lookup.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'Stock Keeping Unit (SKU) or product code for accessories, service packages, warranties, or other non-vehicle line items. Links to product master for pricing and availability.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Detailed description of the line item product or service. Includes accessory names, service package details, warranty coverage terms, or fee descriptions for customer clarity.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax jurisdiction code determining the applicable sales tax rate for this line item. Links to tax master for rate lookup and tax calculation rules.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'Sales tax rate applied to this line item, expressed as a decimal (e.g., 0.0825 for 8.25%). Used for tax calculation and compliance reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contactPointId rdf:type rdf:Property ;
    rdfs:label 'Contact Point Id' ;
    rdfs:comment 'Reference to the specific address where the vehicle will be delivered. Links to customer or dealer address master data.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContactPoint .

ind:primaryVehicleCustomerPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Vehicle Customer Party Id' ;
    rdfs:comment 'Reference to the customer who placed the vehicle order. Links to the customer master data.' ;
    rdfs:domain ind:VehicleOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:primaryVehicleRepId rdf:type rdf:Property ;
    rdfs:label 'Primary Vehicle Rep Id' ;
    rdfs:comment 'Reference to the sales representative or sales agent who handled the order. Used for commission calculation and performance tracking.' ;
    rdfs:domain ind:VehicleOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:primaryVehicleVinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Primary Vehicle Vin Registry Id' ;
    rdfs:comment 'Reference to the specific vehicle unit ordered. For stock orders, links to existing inventory. For build-to-order, links to the vehicle configuration that will be manufactured.' ;
    rdfs:domain ind:VehicleOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VinRegistry .

ind:buildWeek rdf:type rdf:Property ;
    rdfs:label 'Build Week' ;
    rdfs:comment 'Scheduled production week for the vehicle in ISO week format (YYYYWWW). Represents the planned Start of Production (SOP) week.' ;
    rdfs:domain ind:VehicleOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Date' ;
    rdfs:comment 'OEM-committed delivery date communicated to the customer. Represents the contractual delivery obligation.' ;
    rdfs:domain ind:VehicleOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Date' ;
    rdfs:comment 'Date when the order was confirmed by the OEM and accepted into the production schedule. Represents the commitment to fulfill the order.' ;
    rdfs:domain ind:VehicleOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Financing Reference Number' ;
    rdfs:comment 'External reference number for the financing or lease agreement associated with this vehicle order. Links to the financial institution contract.' ;
    rdfs:domain ind:VehicleOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Timestamp' ;
    rdfs:comment 'Precise timestamp when the vehicle order was captured in the system. Used for order sequencing and audit trail.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productionPlantCode rdf:type rdf:Property ;
    rdfs:label 'Production Plant Code' ;
    rdfs:comment 'Code identifying the manufacturing plant assigned to build this vehicle. Used for production scheduling and capacity planning.' ;
    rdfs:domain ind:VehicleOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellingPrice rdf:type rdf:Property ;
    rdfs:label 'Selling Price' ;
    rdfs:comment 'Final agreed selling price for the vehicle after all discounts, incentives, rebates, and negotiations. Represents the actual transaction price.' ;
    rdfs:domain ind:VehicleOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field for special handling instructions, customer requests, or delivery notes that require attention during order fulfillment.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Total amount payable by the customer including selling price, taxes, fees, and any additional charges minus trade-in value.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fleetContractLineId rdf:type rdf:Property ;
    rdfs:label 'Fleet Contract Line Id' ;
    rdfs:comment 'Foreign key linking to sales.fleet_contract_line. Business justification: Order lines fulfill specific fleet contract line allocations. While order_line already has fleet_contract_id for header-level association, adding fleet_contract_line_id enables granular fulfillment tr' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FleetContractLine .

ind:primaryOrderRepId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Rep Id' ;
    rdfs:comment 'Reference to the sales representative or sales agent who captured this order line. Used for commission calculation and performance tracking.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:primaryOrderTradeInVehicleVinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Trade In Vehicle Vin Registry Id' ;
    rdfs:comment 'Reference to the trade-in vehicle appraisal record if this order line includes a trade-in transaction. Null if no trade-in.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VinRegistry .

ind:tertiaryOrderVinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Order Vin Registry Id' ;
    rdfs:comment 'Reference to the specific vehicle master record when line_type is vehicle. Links to vehicle configuration and specifications.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VinRegistry .

ind:actualProductionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Production Date' ;
    rdfs:comment 'Actual date when vehicle production was completed. Populated from MES upon job completion.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fleetIndicator rdf:type rdf:Property ;
    rdfs:label 'Fleet Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this line item is part of a fleet or commercial vehicle order. True for fleet sales, False for retail sales.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'Net unit price after applying all discounts and incentives but before taxes and fees. Calculated as list_price minus discount_amount minus incentive_amount.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipDate rdf:type rdf:Property ;
    rdfs:label 'Ship Date' ;
    rdfs:comment 'Date when the line item was shipped from the manufacturing plant or distribution center to the dealer or customer.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incentiveProgramId rdf:type rdf:Property ;
    rdfs:label 'Incentive Program Id' ;
    rdfs:comment 'Unique identifier for the sales_incentive_program data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IncentiveProgram .

ind:salesIncentiveClaimId rdf:type rdf:Property ;
    rdfs:label 'Sales Incentive Claim Id' ;
    rdfs:comment 'Unique identifier for the sales_incentive_claim data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:SalesIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:organizationAccountId rdf:type rdf:Property ;
    rdfs:label 'Organization Account Id' ;
    rdfs:comment 'Reference to the fleet customer account that holds this contract. Links to the master fleet account entity.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrganizationAccount .

ind:primaryFleetCustomerPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Fleet Customer Party Id' ;
    rdfs:comment 'Reference to the primary customer entity associated with this fleet contract. May represent corporate buyer, government agency, or rental company.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:primaryFleetRepId rdf:type rdf:Property ;
    rdfs:label 'Primary Fleet Rep Id' ;
    rdfs:comment 'Reference to the sales representative or account manager responsible for this fleet contract. Typically a dedicated fleet sales specialist.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:annualMileageAllowance rdf:type rdf:Property ;
    rdfs:label 'Annual Mileage Allowance' ;
    rdfs:comment 'Maximum annual mileage allowed per vehicle under lease terms without excess mileage charges. Typical values range from 10,000 to 25,000 miles per year. Null for purchase contracts.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Approved By User Code' ;
    rdfs:comment 'Reference to the user who granted final approval for this fleet contract. Typically a sales director or VP of fleet sales.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Base Discount Percentage' ;
    rdfs:comment 'Base percentage discount off Manufacturer Suggested Retail Price (MSRP) granted to the fleet customer. Additional volume-based discounts may apply.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedVolume rdf:type rdf:Property ;
    rdfs:label 'Committed Volume' ;
    rdfs:comment 'Total number of vehicles the fleet customer has committed to purchase or lease under this contract. Used for volume-based pricing tier qualification.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractName rdf:type rdf:Property ;
    rdfs:label 'Contract Name' ;
    rdfs:comment 'Descriptive name or title of the fleet contract, typically including customer name and program identifier for easy reference.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known unique business identifier for the fleet contract, used in communications with fleet customers and internal systems. Format: FC-YYYYNNNN.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractSignedDate rdf:type rdf:Property ;
    rdfs:label 'Contract Signed Date' ;
    rdfs:comment 'Date when the fleet contract was formally signed by both parties. Marks the legal binding of the agreement.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle status of the fleet contract. Governs whether new orders can be placed and whether pricing and incentives are active. [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|expired|terminated|completed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Months' ;
    rdfs:comment 'Duration of the fleet contract expressed in months. Typical terms range from 12 to 60 months for corporate fleets.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the fleet contract based on customer segment and business model. Determines pricing rules, incentive eligibility, and delivery processes.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValueAmount rdf:type rdf:Property ;
    rdfs:label 'Contract Value Amount' ;
    rdfs:comment 'Total estimated monetary value of the fleet contract based on committed volume and agreed pricing. Expressed in contract currency.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveredVolume rdf:type rdf:Property ;
    rdfs:label 'Delivered Volume' ;
    rdfs:comment 'Cumulative count of vehicles delivered to the fleet customer under this contract to date. Updated upon each delivery completion.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryScheduleType rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Type' ;
    rdfs:comment 'Classification of how vehicles will be delivered over the contract term. Staggered and quarterly schedules are common for large fleet orders.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleModelYears rdf:type rdf:Property ;
    rdfs:label 'Eligible Model Years' ;
    rdfs:comment 'Comma-separated list of model years eligible for purchase under this contract. Typically current and next model year.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligiblePowertrainTypes rdf:type rdf:Property ;
    rdfs:label 'Eligible Powertrain Types' ;
    rdfs:comment 'Comma-separated list of powertrain types eligible under this contract. May include ICE (Internal Combustion Engine), HEV (Hybrid Electric Vehicle), PHEV (Plug-in Hybrid Electric Vehicle), EV (Electric Vehicle), or combinations.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governmentContractFlag rdf:type rdf:Property ;
    rdfs:label 'Government Contract Flag' ;
    rdfs:comment 'Indicates whether this is a government procurement contract subject to special regulations, reporting requirements, and compliance standards.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gsaScheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Gsa Schedule Number' ;
    rdfs:comment 'GSA schedule contract number for U.S. federal government fleet purchases. Null for non-government contracts.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Maintenance Included Flag' ;
    rdfs:comment 'Indicates whether scheduled maintenance services are included in the fleet contract pricing. Common for lease agreements and full-service fleet contracts.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Minimum number of vehicles that must be ordered in a single transaction to qualify for fleet contract pricing.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:multiLocationDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Location Delivery Flag' ;
    rdfs:comment 'Indicates whether vehicles under this contract will be delivered to multiple locations. True for national fleet accounts with regional distribution.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nationalFleetAccountFlag rdf:type rdf:Property ;
    rdfs:label 'National Fleet Account Flag' ;
    rdfs:comment 'Indicates whether this is a national fleet account with centralized purchasing and multi-region delivery. National accounts receive special pricing and dedicated account management.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryDeliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Primary Delivery Location' ;
    rdfs:comment 'Primary geographic location or facility where fleet vehicles will be delivered. May be a corporate headquarters, fleet depot, or distribution center.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingVolume rdf:type rdf:Property ;
    rdfs:label 'Remaining Volume' ;
    rdfs:comment 'Number of vehicles remaining to be delivered under the committed volume. Calculated as committed_volume minus delivered_volume.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Eligible Flag' ;
    rdfs:comment 'Indicates whether this fleet contract is eligible for renewal upon expiration. Based on customer performance, payment history, and strategic account status.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialTermsNotes rdf:type rdf:Property ;
    rdfs:label 'Special Terms Notes' ;
    rdfs:comment 'Free-text field capturing any special terms, conditions, or negotiated provisions unique to this fleet contract that are not captured in standard fields.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeTierDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Discount Percentage' ;
    rdfs:comment 'Additional discount percentage applied when cumulative volume reaches specified tier thresholds. Stacks on top of base discount.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyExtensionMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Extension Months' ;
    rdfs:comment 'Number of months beyond standard manufacturer warranty that are included in the fleet contract. Zero indicates standard warranty only.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFleetVehicleVinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Primary Fleet Vehicle Vin Registry Id' ;
    rdfs:comment 'Reference to the specific vehicle master record representing the nameplate and configuration allocated in this line.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VinRegistry .

ind:amendmentNotes rdf:type rdf:Property ;
    rdfs:label 'Amendment Notes' ;
    rdfs:comment 'Free-text notes documenting any amendments or changes made to this contract line after initial creation.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUserCode rdf:type rdf:Property ;
    rdfs:label 'Created By User Code' ;
    rdfs:comment 'The user ID of the person who created this contract line record. Audit trail for accountability.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End Date' ;
    rdfs:comment 'The latest date in the delivery window for vehicles under this contract line. Defines the end of the acceptable delivery period.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start Date' ;
    rdfs:comment 'The earliest date in the delivery window for vehicles under this contract line. Defines the beginning of the acceptable delivery period.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'The three-letter ISO 3166-1 alpha-3 country code for the destination market of vehicles in this line (e.g., USA, CAN, MEX).' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationRegion rdf:type rdf:Property ;
    rdfs:label 'Destination Region' ;
    rdfs:comment 'The geographic region or sales territory where vehicles in this line will be delivered (e.g., Northeast, Southwest, Pacific).' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetUseType rdf:type rdf:Property ;
    rdfs:label 'Fleet Use Type' ;
    rdfs:comment 'The intended use category for the fleet vehicles: commercial (business operations), rental (rental fleet), government (public sector), corporate (executive/employee), utility (service/maintenance), or emergency (police/fire/EMS).' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'The current fulfillment status of this contract line: pending (not yet started), in_production (vehicles being built), ready_for_delivery (built and awaiting shipment), partially_fulfilled (some units delivered), fully_fulfilled (all units delivered), or cancelled.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Code' ;
    rdfs:comment 'The user ID of the person who last modified this contract line record. Audit trail for accountability.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedProductionMonth rdf:type rdf:Property ;
    rdfs:label 'Planned Production Month' ;
    rdfs:comment 'The planned production month for vehicles in this line, in YYYY-MM format. Aligns with manufacturing scheduling and capacity planning.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityCommitted rdf:type rdf:Property ;
    rdfs:label 'Quantity Committed' ;
    rdfs:comment 'The total number of vehicle units committed under this contract line. Represents the contractual obligation for delivery.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityFulfilled rdf:type rdf:Property ;
    rdfs:label 'Quantity Fulfilled' ;
    rdfs:comment 'The number of vehicle units that have been delivered and fulfilled against this contract line to date.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityRemaining rdf:type rdf:Property ;
    rdfs:label 'Quantity Remaining' ;
    rdfs:comment 'The number of vehicle units still pending delivery under this contract line. Calculated as quantity_committed minus quantity_fulfilled.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting any special regulatory compliance requirements for vehicles in this line (e.g., CARB emissions, CAFE standards, safety certifications).' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialEquipmentCodes rdf:type rdf:Property ;
    rdfs:label 'Special Equipment Codes' ;
    rdfs:comment 'Comma-separated list of special equipment or option codes included in the vehicle configuration for this line (e.g., towing package, advanced safety features).' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLineValue rdf:type rdf:Property ;
    rdfs:label 'Total Line Value' ;
    rdfs:comment 'The total monetary value of this contract line, calculated as quantity_committed multiplied by unit_contracted_price.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitContractedPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Contracted Price' ;
    rdfs:comment 'The negotiated price per vehicle unit for this contract line. Represents the agreed-upon unit price before taxes and fees.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advertisingFee rdf:type rdf:Property ;
    rdfs:label 'Advertising Fee' ;
    rdfs:comment 'Regional or national advertising fee included in the MSRP to fund cooperative advertising programs. Disclosed separately on buyer\'s order.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseMsrp rdf:type rdf:Property ;
    rdfs:label 'Base Msrp' ;
    rdfs:comment 'The base MSRP for the vehicle configuration before destination charge, options, taxes, or fees. Expressed in the schedule currency.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cafeCreditValue rdf:type rdf:Property ;
    rdfs:label 'Cafe Credit Value' ;
    rdfs:comment 'CAFE credit or debit value for this vehicle configuration, used to calculate fleet-wide CAFE compliance. Positive for over-compliance, negative for under-compliance. Confidential regulatory data.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epaFuelEconomyCity rdf:type rdf:Property ;
    rdfs:label 'Epa Fuel Economy City' ;
    rdfs:comment 'EPA-certified city fuel economy rating in miles per gallon (MPG) for ICE/HEV/PHEV, or MPGe (miles per gallon equivalent) for BEV/FCEV. Used for CAFE compliance and consumer disclosure.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:epaFuelEconomyCombined rdf:type rdf:Property ;
    rdfs:label 'Epa Fuel Economy Combined' ;
    rdfs:comment 'EPA-certified combined fuel economy rating (55% city, 45% highway) in MPG or MPGe. Primary metric for CAFE and consumer comparison.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:epaFuelEconomyHighway rdf:type rdf:Property ;
    rdfs:label 'Epa Fuel Economy Highway' ;
    rdfs:comment 'EPA-certified highway fuel economy rating in miles per gallon (MPG) or MPGe. Used for CAFE compliance and consumer disclosure.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gasGuzzlerTax rdf:type rdf:Property ;
    rdfs:label 'Gas Guzzler Tax' ;
    rdfs:comment 'Federal gas guzzler tax applied to vehicles with EPA fuel economy below statutory thresholds. Zero if not applicable.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdbackAmount rdf:type rdf:Property ;
    rdfs:label 'Holdback Amount' ;
    rdfs:comment 'Manufacturer holdback amount paid to dealer after vehicle sale, typically 2-3% of MSRP. Used to support dealer cash flow and inventory financing. Confidential business data.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nameplate rdf:type rdf:Property ;
    rdfs:label 'Nameplate' ;
    rdfs:comment 'The vehicle nameplate or model name (e.g., Camry, F-150, Model 3). Denormalized for reporting convenience.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powertrainWarrantyMiles rdf:type rdf:Property ;
    rdfs:label 'Powertrain Warranty Miles' ;
    rdfs:comment 'Extended powertrain warranty duration in miles (e.g., 60,000 miles). Covers engine, transmission, drivetrain components.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:powertrainWarrantyMonths rdf:type rdf:Property ;
    rdfs:label 'Powertrain Warranty Months' ;
    rdfs:comment 'Extended powertrain warranty duration in months (e.g., 60 months / 5 years). Typically longer than bumper-to-bumper warranty.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'Date and time when this MSRP schedule was published to dealer systems and public-facing channels (website, configurator, dealer portals).' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalMsrp rdf:type rdf:Property ;
    rdfs:label 'Total Msrp' ;
    rdfs:comment 'Total MSRP including base price, destination charge, gas guzzler tax, and any mandatory fees. Excludes dealer-installed accessories and local taxes.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyMiles rdf:type rdf:Property ;
    rdfs:label 'Warranty Miles' ;
    rdfs:comment 'Standard manufacturer warranty duration in miles (e.g., 36,000 miles). Warranty expires at the earlier of months or miles threshold.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Months' ;
    rdfs:comment 'Standard manufacturer warranty duration in months (e.g., 36 months / 3 years). Used for warranty cost accrual and customer communication.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualQuotaRevenue rdf:type rdf:Property ;
    rdfs:label 'Annual Quota Revenue' ;
    rdfs:comment 'Annual revenue quota target for this territory in the base currency. Represents expected sales value including MSRP and incentives.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualQuotaUnits rdf:type rdf:Property ;
    rdfs:label 'Annual Quota Units' ;
    rdfs:comment 'Annual sales quota for this territory measured in vehicle units. Used for performance tracking and incentive calculation.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitiveIntensity rdf:type rdf:Property ;
    rdfs:label 'Competitive Intensity' ;
    rdfs:comment 'Assessment of competitive pressure in the territory based on number of competing brands, dealer density, and market share dynamics.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerCount rdf:type rdf:Property ;
    rdfs:label 'Dealer Count' ;
    rdfs:comment 'Number of authorized dealerships operating within this territory. Used for dealer network density analysis and coverage planning.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'Primary distribution channel used in this territory. Direct represents OEM-owned sales, dealer represents franchised network, fleet serves corporate buyers, online covers digital sales, and export handles international shipments.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:districtCode rdf:type rdf:Property ;
    rdfs:label 'District Code' ;
    rdfs:comment 'Code identifying the district within the region. Represents a mid-level geographic or organizational subdivision.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:districtName rdf:type rdf:Property ;
    rdfs:label 'District Name' ;
    rdfs:comment 'Name of the district (e.g., \'Northeast District\', \'Southern California District\').' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdCount rdf:type rdf:Property ;
    rdfs:label 'Household Count' ;
    rdfs:comment 'Number of households in the territory. Key metric for retail automotive market potential analysis.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'Primary language code for customer communication and marketing materials in this territory (e.g., en, es, fr, de, zh). Follows ISO 639-1 two-letter codes.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSegment rdf:type rdf:Property ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'Primary market segment focus for this territory. Determines product mix, pricing strategy, and customer targeting approach.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medianHouseholdIncome rdf:type rdf:Property ;
    rdfs:label 'Median Household Income' ;
    rdfs:comment 'Median household income in the territory. Used for market segmentation and product mix planning (luxury vs. mass market).' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelYearFocus rdf:type rdf:Property ;
    rdfs:label 'Model Year Focus' ;
    rdfs:comment 'Primary model year of vehicles being sold in this territory (e.g., MY2024, MY2025). Reflects inventory and product launch timing.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'User ID or name of the person who last modified this territory record. Supports accountability and audit requirements.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationCount rdf:type rdf:Property ;
    rdfs:label 'Population Count' ;
    rdfs:comment 'Total population within the territory boundaries. Used for market sizing and potential customer base estimation.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postalCodeRange rdf:type rdf:Property ;
    rdfs:label 'Postal Code Range' ;
    rdfs:comment 'Postal code or ZIP code ranges covered by this territory (e.g., \'90001-90099, 91001-91199\'). Used for geographic assignment of leads and customers.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Quota Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for quota and revenue targets (e.g., USD, EUR, CNY, JPY).' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionName rdf:type rdf:Property ;
    rdfs:label 'Region Name' ;
    rdfs:comment 'Name of the parent region (e.g., \'North America\', \'Western Europe\', \'Asia Pacific\').' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesManagerName rdf:type rdf:Property ;
    rdfs:label 'Sales Manager Name' ;
    rdfs:comment 'Full name of the sales manager assigned to this territory for quick reference and reporting.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Sales Office Code' ;
    rdfs:comment 'Code of the primary sales office serving this territory. Links to SAP SD sales organization structure.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleCategoryFocus rdf:type rdf:Property ;
    rdfs:label 'Vehicle Category Focus' ;
    rdfs:comment 'Primary vehicle categories sold in this territory (e.g., \'SUV, Truck\', \'Sedan, EV\', \'Commercial Vehicles\'). Reflects regional demand patterns and product strategy.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleRegistrationCount rdf:type rdf:Property ;
    rdfs:label 'Vehicle Registration Count' ;
    rdfs:comment 'Total number of registered vehicles in the territory. Indicates market saturation and replacement demand potential.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Code identifying the zone within the district. Represents the most granular level of the territory hierarchy.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneName rdf:type rdf:Property ;
    rdfs:label 'Zone Name' ;
    rdfs:comment 'Name of the zone (e.g., \'Manhattan Zone\', \'Orange County Zone\').' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeStatus rdf:type rdf:Property ;
    rdfs:label 'Active Status' ;
    rdfs:comment 'Indicates whether the sales representative is currently active and eligible for lead assignment and quota tracking. False indicates inactive (terminated, on leave, or transferred out of sales).' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionPlanCode rdf:type rdf:Property ;
    rdfs:label 'Commission Plan Code' ;
    rdfs:comment 'Identifier for the incentive compensation plan assigned to the representative. Links to commission structure, bonus tiers, and payout rules in the compensation management system.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmUserCode rdf:type rdf:Property ;
    rdfs:label 'Crm User Code' ;
    rdfs:comment 'User identifier in Salesforce Automotive Cloud. Used to link sales activities, opportunities, and customer interactions to this representative.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetAccountCount rdf:type rdf:Property ;
    rdfs:label 'Fleet Account Count' ;
    rdfs:comment 'Number of fleet or commercial accounts assigned to this representative. Applicable primarily to fleet account managers and national account executives.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languageProficiency rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency' ;
    rdfs:comment 'Comma-separated list of languages the representative is proficient in (e.g., English, Spanish, Mandarin). Used for customer matching and international account assignment.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeLocation rdf:type rdf:Property ;
    rdfs:label 'Office Location' ;
    rdfs:comment 'Primary office or branch location where the representative is based (e.g., Detroit HQ, Los Angeles Regional Office, Remote). Used for travel planning and regional coordination.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Current performance classification based on quota attainment, customer satisfaction (NPS), and other KPIs. Used for recognition programs, incentive multipliers, and career development planning.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSpecialization rdf:type rdf:Property ;
    rdfs:label 'Product Specialization' ;
    rdfs:comment 'Primary product line or vehicle segment specialization (e.g., Electric Vehicles, Commercial Trucks, Luxury Sedans, SUVs, Performance Vehicles). Used for lead routing and expert assignment in Salesforce Automotive Cloud.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaAmount rdf:type rdf:Property ;
    rdfs:label 'Quota Amount' ;
    rdfs:comment 'Annual or period-based sales quota target assigned to the representative, expressed in the base currency. Used for performance measurement and incentive compensation calculation.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaCurrency rdf:type rdf:Property ;
    rdfs:label 'Quota Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the quota amount (e.g., USD, EUR, JPY). Supports multi-currency sales operations.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaPeriod rdf:type rdf:Property ;
    rdfs:label 'Quota Period' ;
    rdfs:comment 'Time period over which the quota is measured (annual, quarterly, or monthly). Aligns with fiscal year and performance review cycles.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRole rdf:type rdf:Property ;
    rdfs:label 'Sales Role' ;
    rdfs:comment 'Functional sales role classification defining the representative\'s primary responsibility area. Retail field reps manage dealer relationships, fleet account managers handle commercial fleet sales, national account executives manage large enterprise accounts, export sales covers international markets, regional sales managers oversee territories, and dealer development focuses on dealer network expansion.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesStartDate rdf:type rdf:Property ;
    rdfs:label 'Sales Start Date' ;
    rdfs:comment 'Date the representative began their current sales role or territory assignment. May differ from hire_date if the employee transferred from another department or role.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workArrangement rdf:type rdf:Property ;
    rdfs:label 'Work Arrangement' ;
    rdfs:comment 'Primary work location arrangement. Field-based representatives spend majority of time visiting dealers or customers; office-based work from regional offices; hybrid split time; remote work from home.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaId rdf:type rdf:Property ;
    rdfs:label 'Quota Id' ;
    rdfs:comment 'Unique identifier for the sales quota record. Primary key.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assigneeRepId rdf:type rdf:Property ;
    rdfs:label 'Assignee Rep Id' ;
    rdfs:comment 'Foreign key reference to the entity assigned this quota. Interpretation depends on assignee_type: references sales_representative, dealership, territory, region, or team table.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:quotaRepId rdf:type rdf:Property ;
    rdfs:label 'Quota Rep Id' ;
    rdfs:comment 'Foreign key reference to the individual sales representative this quota is assigned to. Null if quota is not individual-specific.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:quotaSalesRepresentativeRepId rdf:type rdf:Property ;
    rdfs:label 'Quota Sales Representative Rep Id' ;
    rdfs:comment 'Foreign key reference to the individual sales representative this quota is assigned to. Null if quota is not individual-specific.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which the quota was approved by management. Null if not yet approved.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assigneeName rdf:type rdf:Property ;
    rdfs:label 'Assignee Name' ;
    rdfs:comment 'Human-readable name of the quota assignee (representative name, dealer name, territory name, etc.) for reporting and display purposes.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assigneeType rdf:type rdf:Property ;
    rdfs:label 'Assignee Type' ;
    rdfs:comment 'Type of entity to which the quota is assigned: sales_representative (individual salesperson), dealer (dealership entity), territory (geographic sales territory), region (multi-territory region), district (sales district), zone (sales zone), team (sales team). [ENUM-REF-CANDIDATE: sales_representative|dealer|territory|region|district|zone|team — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Month' ;
    rdfs:comment 'Fiscal month within the fiscal year (M01 through M12). Null if quota is quarterly or annual.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'Fiscal quarter within the fiscal year (Q1, Q2, Q3, Q4). Null if quota is annual or monthly.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveEligible rdf:type rdf:Property ;
    rdfs:label 'Incentive Eligible' ;
    rdfs:comment 'Boolean flag indicating whether achievement of this quota makes the assignee eligible for incentive compensation (True) or is a non-incentivized target (False).' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'End date of the quota performance period. Defines when quota measurement concludes.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'Start date of the quota performance period. Defines when quota measurement begins.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productLine rdf:type rdf:Property ;
    rdfs:label 'Product Line' ;
    rdfs:comment 'Specific product line or brand this quota applies to (e.g., premium brand, economy brand, commercial line). Null if quota applies to all product lines.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaName rdf:type rdf:Property ;
    rdfs:label 'Quota Name' ;
    rdfs:comment 'Descriptive name for the quota assignment, e.g., \'Q1 FY2024 Northeast Region EV Target\' or \'Annual MY2024 Fleet Sales Goal\'.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaNumber rdf:type rdf:Property ;
    rdfs:label 'Quota Number' ;
    rdfs:comment 'Human-readable business identifier for the quota assignment, typically following format QTA-YYYYNNNN.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaStatus rdf:type rdf:Property ;
    rdfs:label 'Quota Status' ;
    rdfs:comment 'Current lifecycle status of the quota: draft (under review), approved (management approved), active (in effect), suspended (temporarily paused), closed (period ended), cancelled (voided before completion).' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaType rdf:type rdf:Property ;
    rdfs:label 'Quota Type' ;
    rdfs:comment 'Classification of the quota by measurement type: unit_volume (vehicle units sold), revenue (dollar/currency target), ev_mix (Electric Vehicle penetration percentage), fleet_penetration (commercial fleet sales), market_share (regional market share target), model_mix (specific model line targets).' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Version number of the quota record, incremented each time the quota is revised or adjusted. Initial version is 1.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Business reason for the most recent revision to the quota (e.g., \'Market conditions adjustment\', \'Territory realignment\', \'Product launch delay\'). Null if no revisions have been made.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetUnit rdf:type rdf:Property ;
    rdfs:label 'Target Unit' ;
    rdfs:comment 'Unit of measure for the target_value: units (vehicle count), currency codes (USD, EUR, GBP, JPY, CNY), percentage (for mix/share targets), market_points (for market share basis points). [ENUM-REF-CANDIDATE: units|usd|eur|gbp|jpy|cny|percentage|market_points — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'Numeric target value for the quota. Interpretation depends on quota_type: unit count for unit_volume, currency amount for revenue, percentage for ev_mix or market_share.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdMinimum rdf:type rdf:Property ;
    rdfs:label 'Threshold Minimum' ;
    rdfs:comment 'Minimum performance threshold (as percentage of target_value or absolute value) required for any incentive payout or recognition. Null if no minimum threshold applies.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdStretch rdf:type rdf:Property ;
    rdfs:label 'Threshold Stretch' ;
    rdfs:comment 'Stretch performance threshold (as percentage of target_value or absolute value) that triggers maximum incentive payout or recognition. Null if no stretch threshold applies.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleSegment rdf:type rdf:Property ;
    rdfs:label 'Vehicle Segment' ;
    rdfs:comment 'Vehicle segment or category this quota applies to (e.g., sedan, SUV, truck, commercial, luxury). Null if quota applies to all segments. [ENUM-REF-CANDIDATE: sedan|suv|truck|crossover|van|commercial|luxury|compact|midsize — promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityId rdf:type rdf:Property ;
    rdfs:label 'Activity Id' ;
    rdfs:comment 'Unique identifier for the sales activity record. Primary key.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activityCustomerPartyId rdf:type rdf:Property ;
    rdfs:label 'Activity Customer Party Id' ;
    rdfs:comment 'Reference to the customer account associated with this sales activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:activityPartyId rdf:type rdf:Property ;
    rdfs:label 'Activity Party Id' ;
    rdfs:comment 'Reference to the customer account associated with this sales activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:activityRepId rdf:type rdf:Property ;
    rdfs:label 'Activity Rep Id' ;
    rdfs:comment 'Reference to the sales representative who performed or is responsible for this sales activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:activitySalesRepresentativeRepId rdf:type rdf:Property ;
    rdfs:label 'Activity Sales Representative Rep Id' ;
    rdfs:comment 'Reference to the sales representative who performed or is responsible for this sales activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:activityVehicleVinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Activity Vehicle Vin Registry Id' ;
    rdfs:comment 'Reference to the specific vehicle that was the subject of this sales activity, if applicable (e.g., test drive, demo).' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VinRegistry .

ind:activityVinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Activity Vin Registry Id' ;
    rdfs:comment 'Reference to the specific vehicle that was the subject of this sales activity, if applicable (e.g., test drive, demo).' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VinRegistry .

ind:caseId rdf:type rdf:Property ;
    rdfs:label 'Case Id' ;
    rdfs:comment 'Foreign key linking to customer.case. Business justification: Sales follow-up activities often reference open customer service cases (warranty concerns, delivery issues). CRM workflows require linking sales activities to case records for coordinated customer exp' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:activityDate rdf:type rdf:Property ;
    rdfs:label 'Activity Date' ;
    rdfs:comment 'The date on which the sales activity occurred or is scheduled to occur.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activityDescription rdf:type rdf:Property ;
    rdfs:label 'Activity Description' ;
    rdfs:comment 'Detailed description or notes about the sales activity, capturing key discussion points, customer feedback, and action items.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityNumber rdf:type rdf:Property ;
    rdfs:label 'Activity Number' ;
    rdfs:comment 'Business-facing unique identifier for the sales activity, typically system-generated in format ACT-########.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Status' ;
    rdfs:comment 'Current lifecycle status of the sales activity indicating whether it is scheduled, in progress, completed, cancelled, no-show, or rescheduled.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Classification of the sales activity indicating the nature of the interaction (call, email, test drive, demo, site visit, proposal presentation, follow-up, negotiation, or other). [ENUM-REF-CANDIDATE: call|email|meeting|test_drive|demo|site_visit|proposal_presentation|follow_up|negotiation|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorMentioned rdf:type rdf:Property ;
    rdfs:label 'Competitor Mentioned' ;
    rdfs:comment 'Name of any competitor brand or product mentioned by the customer during the sales activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSentiment rdf:type rdf:Property ;
    rdfs:label 'Customer Sentiment' ;
    rdfs:comment 'Qualitative assessment of the customer\'s sentiment or attitude during the sales activity (very positive, positive, neutral, negative, very negative).' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demoCompleted rdf:type rdf:Property ;
    rdfs:label 'Demo Completed' ;
    rdfs:comment 'Boolean flag indicating whether a product demonstration was completed as part of this sales activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDealValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Deal Value' ;
    rdfs:comment 'Estimated monetary value of the potential deal discussed or progressed during this sales activity, in the base currency.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCommercialVehicle rdf:type rdf:Property ;
    rdfs:label 'Is Commercial Vehicle' ;
    rdfs:comment 'Boolean flag indicating whether this sales activity involves a commercial vehicle.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFleetSale rdf:type rdf:Property ;
    rdfs:label 'Is Fleet Sale' ;
    rdfs:comment 'Boolean flag indicating whether this sales activity is related to a fleet sale opportunity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Physical or virtual location where the sales activity took place (e.g., dealership showroom, customer site, online).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Modified By User Code' ;
    rdfs:comment 'Reference to the user who last modified this sales activity record in the system.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAction rdf:type rdf:Property ;
    rdfs:label 'Next Action' ;
    rdfs:comment 'Description of the next planned action or follow-up step resulting from this sales activity.' ;
