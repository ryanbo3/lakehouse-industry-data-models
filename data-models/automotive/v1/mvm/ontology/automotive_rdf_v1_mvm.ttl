    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start' ;
    rdfs:comment 'First calendar day of the period covered by the scorecard.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluatorName rdf:type rdf:Property ;
    rdfs:label 'Evaluator Name' ;
    rdfs:comment 'Full name of the internal evaluator responsible for the scorecard.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otdPercentage rdf:type rdf:Property ;
    rdfs:label 'Otd Percentage' ;
    rdfs:comment 'Percentage of deliveries that arrived on or before the agreed delivery date.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallScore rdf:type rdf:Property ;
    rdfs:label 'Overall Score' ;
    rdfs:comment 'Aggregated weighted score combining all KPI values for the evaluation period.' ;
