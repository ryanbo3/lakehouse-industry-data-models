    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'Regulatory or quality standards the supplier must meet (e.g., IATF 16949, ISO 14001).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issue Timestamp' ;
    rdfs:comment 'Date-time when the RFQ was issued to suppliers.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:netPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Net Price Amount' ;
    rdfs:comment 'Net price after discounts, taxes, and fees.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programModelYear rdf:type rdf:Property ;
    rdfs:label 'Program Model Year' ;
    rdfs:comment 'Vehicle program or model year for which the part is required.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityEstimate rdf:type rdf:Property ;
    rdfs:label 'Quantity Estimate' ;
    rdfs:comment 'Projected annual volume the buyer expects to purchase.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the part must be delivered to the plant.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Last date on which suppliers may submit their quotations.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'Business-visible RFQ number assigned by the sourcing system.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqStatus rdf:type rdf:Property ;
    rdfs:label 'Rfq Status' ;
    rdfs:comment 'Current lifecycle state of the RFQ.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqType rdf:type rdf:Property ;
    rdfs:label 'Rfq Type' ;
    rdfs:comment 'Classification of the RFQ request.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Target Price Amount' ;
    rdfs:comment 'Maximum price the buyer is willing to pay for the quoted item (gross).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPriceCurrency rdf:type rdf:Property ;
    rdfs:label 'Target Price Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the target price.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolingDescription rdf:type rdf:Property ;
    rdfs:label 'Tooling Description' ;
    rdfs:comment 'Details of the tooling requirements, if any.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolingRequired rdf:type rdf:Property ;
    rdfs:label 'Tooling Required' ;
    rdfs:comment 'Indicates whether new tooling is needed for the part.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfqResponseId rdf:type rdf:Property ;
    rdfs:label 'Rfq Response Id' ;
    rdfs:comment 'System-generated unique identifier for the RFQ response record.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RfqResponse .

ind:amortizationTermMonths rdf:type rdf:Property ;
    rdfs:label 'Amortization Term Months' ;
    rdfs:comment 'Number of months over which the tooling cost is amortized.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityCommitment rdf:type rdf:Property ;
    rdfs:label 'Capacity Commitment' ;
    rdfs:comment 'Maximum production capacity the supplier commits to deliver per period.' ;
