ind:primaryPartMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Part Master Id' ;
    rdfs:comment 'Foreign key linking to engineering.part_master. Business justification: Service campaigns (recalls and non-safety campaigns) are triggered by specific part failures. Linking to the primary engineering part enables supplier recovery chargebacks, FMEA corrective action trac' ;
