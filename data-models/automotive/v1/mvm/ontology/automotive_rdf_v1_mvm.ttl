    rdfs:range xsd:decimal .

ind:responsivenessScore rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Score' ;
    rdfs:comment 'Score reflecting the supplier\'s responsiveness to inquiries and change requests.' ;
