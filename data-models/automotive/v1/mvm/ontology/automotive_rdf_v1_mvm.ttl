ind:auditedCarrierId rdf:type rdf:Property ;
    rdfs:label 'Audited Carrier Id' ;
    rdfs:comment 'Foreign key linking to logistics.carrier. Business justification: Quality system audits of carriers (IATF 16949 compliance, process audits, handling procedures) are mandatory in automotive supply chain. Business process: carrier quality certification and approval.' ;
    rdfs:domain ind:Audit ;
