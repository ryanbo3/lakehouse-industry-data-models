    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Status' ;
    rdfs:comment 'Result of the latest quality inspection for the stock batch.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockCategory rdf:type rdf:Property ;
    rdfs:label 'Stock Category' ;
    rdfs:comment 'Broad classification of the stock for reporting (e.g., raw material, finished good).' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Code' ;
    rdfs:comment 'Code of the primary supplier for the material.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unrestrictedStockQty rdf:type rdf:Property ;
    rdfs:label 'Unrestricted Stock Qty' ;
    rdfs:comment 'Quantity that is free for use or sale.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valuationAreaCode rdf:type rdf:Property ;
    rdfs:label 'Valuation Area Code' ;
    rdfs:comment 'Accounting valuation area for inventory valuation purposes.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationPrice rdf:type rdf:Property ;
    rdfs:label 'Valuation Price' ;
    rdfs:comment 'Monetary value per unit for the material based on the valuation type.' ;
    rdfs:domain ind:StockBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'Method used for inventory valuation.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryGoodsCustomerPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Goods Customer Party Id' ;
    rdfs:comment 'Identifier of the customer for goods issue movements.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:replenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Id' ;
    rdfs:comment 'Foreign key linking to inventory.replenishment_order. Business justification: Goods movements can be the physical inventory transaction that fulfills a replenishment order (e.g., a goods receipt posting that satisfies the replenishment demand). Adding replenishment_order_id FK ' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReplenishmentOrder .

ind:reversalOfMovementGoodsMovementId rdf:type rdf:Property ;
    rdfs:label 'Reversal Of Movement Goods Movement Id' ;
    rdfs:comment 'Identifier of the original goods movement that this record reverses.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsMovement .

ind:sourceStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Source Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Normalize source storage location reference; replace string with FK to storage_location' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:stockTransferOrderId rdf:type rdf:Property ;
    rdfs:label 'Stock Transfer Order Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_transfer_order. Business justification: Goods movements are the physical execution records generated when a stock transfer order is carried out. goods_movement has reference_document_number and reference_document_type (STRING) as denormaliz' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockTransferOrder .

ind:amountLocal rdf:type rdf:Property ;
    rdfs:label 'Amount Local' ;
    rdfs:comment 'Value of the movement in the plant\'s local currency.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountUsd rdf:type rdf:Property ;
    rdfs:label 'Amount Usd' ;
    rdfs:comment 'Value of the movement converted to US dollars for consolidated reporting.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseUom rdf:type rdf:Property ;
    rdfs:label 'Base Uom' ;
    rdfs:comment 'Unit of measure associated with the quantity field.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'Delivery document number for goods issue movements.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPlant rdf:type rdf:Property ;
    rdfs:label 'Destination Plant' ;
    rdfs:comment 'Plant receiving the material.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Location' ;
    rdfs:comment 'Storage location in the destination plant where the material is placed.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsMovementStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Status' ;
    rdfs:comment 'Current status of the goods movement record.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLotTracked rdf:type rdf:Property ;
    rdfs:label 'Is Lot Tracked' ;
    rdfs:comment 'True if the material is tracked by lot.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSerialTracked rdf:type rdf:Property ;
    rdfs:label 'Is Serial Tracked' ;
    rdfs:comment 'True if the material is tracked by serial number.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationZone rdf:type rdf:Property ;
    rdfs:label 'Location Zone' ;
    rdfs:comment 'Specific zone or area within the warehouse for the storage location.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementReason rdf:type rdf:Property ;
    rdfs:label 'Movement Reason' ;
    rdfs:comment 'Business reason prompting the inventory movement.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posting Timestamp' ;
    rdfs:comment 'Exact date and time when the movement was posted.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'Number of the source document that triggered the movement, such as purchase order or production order.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'Type of the reference document (Purchase Order, Production Order, Work Order, Delivery, Service Order).' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcePlant rdf:type rdf:Property ;
    rdfs:label 'Source Plant' ;
    rdfs:comment 'Plant where the material originated.' ;
