    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextActionDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Date' ;
    rdfs:comment 'The scheduled date for the next follow-up action or activity.' ;
