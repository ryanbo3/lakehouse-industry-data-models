    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Composite risk rating derived from financial, operational, and compliance factors.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scorecardNumber rdf:type rdf:Property ;
    rdfs:label 'Scorecard Number' ;
    rdfs:comment 'Human-readable identifier assigned to the scorecard, used for reporting and audit trails.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoringMethodologyVersion rdf:type rdf:Property ;
    rdfs:label 'Scoring Methodology Version' ;
    rdfs:comment 'Identifier of the scoring model version used for this evaluation.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierScorecardStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Scorecard Status' ;
    rdfs:comment 'Current state of the scorecard in its lifecycle.' ;
