ind:allocationIndividualId rdf:type rdf:Property ;
    rdfs:label 'Allocation Individual Id' ;
    rdfs:comment 'Foreign key linking to customer.individual. Business justification: Retail customers reserve vehicles during production or at completion before ownership transfer. Supports sold-order tracking, delivery coordination, and sales pipeline management. Distinct from vehicl' ;
