    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionsToSor rdf:type rdf:Property ;
    rdfs:label 'Exceptions To Sor' ;
    rdfs:comment 'Supplier-provided deviations or exceptions to the original SOR.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightIncluded rdf:type rdf:Property ;
    rdfs:label 'Freight Included' ;
    rdfs:comment 'True if freight costs are included in the total price.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreferredSupplier rdf:type rdf:Property ;
    rdfs:label 'Is Preferred Supplier' ;
    rdfs:comment 'Indicates whether the supplier is marked as a preferred source for this part.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotedCurrency rdf:type rdf:Property ;
    rdfs:label 'Quoted Currency' ;
    rdfs:comment 'ISO 4217 currency code of the quoted price.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotedQuantity rdf:type rdf:Property ;
    rdfs:label 'Quoted Quantity' ;
    rdfs:comment 'Quantity of items the supplier is quoting for.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Quoted Unit Price' ;
    rdfs:comment 'Price per unit quoted by the supplier.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Additional free-form comments from the supplier.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseNumber rdf:type rdf:Property ;
    rdfs:label 'Response Number' ;
    rdfs:comment 'External reference number assigned to the supplier\'s quotation response.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseSource rdf:type rdf:Property ;
    rdfs:label 'Response Source' ;
    rdfs:comment 'Channel through which the supplier submitted the quotation.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqResponseStatus rdf:type rdf:Property ;
    rdfs:label 'Rfq Response Status' ;
    rdfs:comment 'Current lifecycle status of the RFQ response.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Date and time when the supplier submitted the quotation.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:toolingCost rdf:type rdf:Property ;
    rdfs:label 'Tooling Cost' ;
    rdfs:comment 'One-time cost for tooling or molds required to produce the part.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'Last date on which the quoted terms are valid.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'First date on which the quoted terms are valid.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyType rdf:type rdf:Property ;
    rdfs:label 'Warranty Type' ;
    rdfs:comment 'Type of warranty provided.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Price Agreement Id' ;
    rdfs:comment 'Foreign key linking to supply.price_agreement. Business justification: Purchase orders are priced according to a formally agreed price agreement. Linking supply_purchase_order to price_agreement ensures commercial compliance — the PO price can be validated against the ag' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceAgreement .

ind:actualOtdPercent rdf:type rdf:Property ;
    rdfs:label 'Actual Otd Percent' ;
    rdfs:comment 'Measured on-time delivery performance for the agreement period.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPpm rdf:type rdf:Property ;
    rdfs:label 'Actual Ppm' ;
    rdfs:comment 'Measured defect rate for parts delivered under the agreement.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Approval Status' ;
    rdfs:comment 'Regulatory or quality compliance status of the agreement.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Compliance Document Ref' ;
    rdfs:comment 'Reference number of the attached compliance documentation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractScope rdf:type rdf:Property ;
    rdfs:label 'Contract Scope' ;
    rdfs:comment 'High-level description of the parts, services, or components covered.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractVersion rdf:type rdf:Property ;
    rdfs:label 'Contract Version' ;
    rdfs:comment 'Version identifier for the agreement when amendments are made.' ;
    rdfs:domain ind:SchedulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryRhythm rdf:type rdf:Property ;
    rdfs:label 'Delivery Rhythm' ;
    rdfs:comment 'Scheduled frequency of deliveries defined in the agreement.' ;
    rdfs:domain ind:SchedulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyTerminationAllowed rdf:type rdf:Property ;
    rdfs:label 'Early Termination Allowed' ;
    rdfs:comment 'Flag indicating whether the agreement can be terminated before the end date.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kanbanFlag rdf:type rdf:Property ;
    rdfs:label 'Kanban Flag' ;
    rdfs:comment 'Indicates whether the agreement uses a Kanban pull system for JIT deliveries.' ;
    rdfs:domain ind:SchedulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyClause rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause' ;
    rdfs:comment 'Text describing penalties for missed deliveries or quality breaches.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseHorizonWeeks rdf:type rdf:Property ;
    rdfs:label 'Release Horizon Weeks' ;
    rdfs:comment 'Number of weeks in advance that delivery forecasts must be submitted.' ;
    rdfs:domain ind:SchedulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Period Days' ;
    rdfs:comment 'Notice period required to exercise renewal option.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalOption rdf:type rdf:Property ;
    rdfs:label 'Renewal Option' ;
    rdfs:comment 'Indicates if the agreement includes an automatic renewal provision.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingAgreementDescription rdf:type rdf:Property ;
    rdfs:label 'Scheduling Agreement Description' ;
    rdfs:comment 'Free-text description of the purpose, scope and key terms of the agreement.' ;
    rdfs:domain ind:SchedulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Scheduling Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the scheduling agreement.' ;
    rdfs:domain ind:SchedulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetOtdPercent rdf:type rdf:Property ;
    rdfs:label 'Target Otd Percent' ;
    rdfs:comment 'Target percentage for on-time deliveries defined in the agreement.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPpm rdf:type rdf:Property ;
    rdfs:label 'Target Ppm' ;
    rdfs:comment 'Maximum allowable defect rate for supplied parts.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Period Days' ;
    rdfs:comment 'Number of days notice required to terminate the agreement early.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAnnualVolume rdf:type rdf:Property ;
    rdfs:label 'Total Annual Volume' ;
    rdfs:comment 'Planned total quantity of parts to be supplied over the contract year.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inboundShipmentId rdf:type rdf:Property ;
    rdfs:label 'Inbound Shipment Id' ;
    rdfs:comment 'Foreign key linking to supply.inbound_shipment. Business justification: A JIT/JIS delivery schedule line is fulfilled by a specific inbound shipment (ASN). Linking supply_delivery_schedule to inbound_shipment enables schedule-vs-actual delivery tracking, OTD calculation, ' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundShipment .

ind:supplyPpapSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Supply Ppap Submission Id' ;
    rdfs:comment 'Unique identifier for the supply_ppap_submission data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplyPpapSubmission .

ind:destinationVehicleCompoundId rdf:type rdf:Property ;
    rdfs:label 'Destination Vehicle Compound Id' ;
    rdfs:comment 'Foreign key linking to logistics.vehicle_compound. Business justification: JIT/JIS sequencing operations require inbound parts delivered to vehicle compounds adjacent to assembly plants for line-side staging before production consumption. Common in automotive for sequenced p' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleCompound .

ind:receivingPlantId rdf:type rdf:Property ;
    rdfs:label 'Receiving Plant Id' ;
    rdfs:comment 'Identifier of the OEM plant receiving the shipment.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:receivingStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Receiving Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Inbound shipments must specify receiving storage location for dock-to-stock process, bin allocation, and warehouse management. Enables automated goods receipt posting and inventory placement tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:asnNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Number' ;
    rdfs:comment 'Unique identifier supplied by the supplier to announce the shipment in advance.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerCount rdf:type rdf:Property ;
    rdfs:label 'Container Count' ;
    rdfs:comment 'Number of containers included in the shipment.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:departureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Departure Timestamp' ;
    rdfs:comment 'Date and time when the shipment left the supplier\'s dock.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hazardousClass rdf:type rdf:Property ;
    rdfs:label 'Hazardous Class' ;
    rdfs:comment 'Classification of hazardous material according to UN/ADR standards.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'International commercial term defining responsibility and cost allocation. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAT|DAP|DDP — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastStatusUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Status Update Timestamp' ;
    rdfs:comment 'Timestamp of the most recent change to the shipment status.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'Classification of the materials contained in the shipment.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modeOfTransport rdf:type rdf:Property ;
    rdfs:label 'Mode Of Transport' ;
    rdfs:comment 'Primary mode used to move the shipment from supplier to plant.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Count' ;
    rdfs:comment 'Number of pallets used to load the shipment.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Volume M3' ;
    rdfs:comment 'Aggregate volume of the shipment, expressed in cubic meters.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Aggregate weight of all items in the shipment, expressed in kilograms.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierScorecardId rdf:type rdf:Property ;
    rdfs:label 'Supplier Scorecard Id' ;
    rdfs:comment 'System-generated unique identifier for each supplier scorecard record.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierScorecard .

ind:complianceScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Score' ;
    rdfs:comment 'Score measuring adherence to regulatory and internal compliance requirements.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Free-text description of actions the supplier must take to address deficiencies.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Flag' ;
    rdfs:comment 'True when the supplier must undertake corrective actions.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryQuantityAccuracyPct rdf:type rdf:Property ;
    rdfs:label 'Delivery Quantity Accuracy Pct' ;
    rdfs:comment 'Ratio of delivered quantity to ordered quantity, expressed as a percent.' ;
    rdfs:domain ind:SupplierScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Date' ;
    rdfs:comment 'Exact timestamp when the scorecard was completed.' ;
    rdfs:domain ind:SupplierScorecard ;
