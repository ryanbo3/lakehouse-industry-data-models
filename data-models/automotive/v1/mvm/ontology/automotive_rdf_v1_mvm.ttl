    rdfs:range xsd:date .

ind:objectionRaised rdf:type rdf:Property ;
    rdfs:label 'Objection Raised' ;
    rdfs:comment 'Description of any objections or concerns raised by the customer during the sales activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectionResolved rdf:type rdf:Property ;
    rdfs:label 'Objection Resolved' ;
    rdfs:comment 'Boolean flag indicating whether the customer\'s objection was successfully resolved during the activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'The result or outcome of the sales activity indicating whether it was successful, unsuccessful, pending, no contact made, customer interested, not interested, or callback requested. [ENUM-REF-CANDIDATE: successful|unsuccessful|pending|no_contact|interested|not_interested|callback_requested — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotePresented rdf:type rdf:Property ;
    rdfs:label 'Quote Presented' ;
    rdfs:comment 'Boolean flag indicating whether a price quote or proposal was presented during this sales activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief subject or title of the sales activity describing the purpose or topic of the interaction.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualSpentAmount rdf:type rdf:Property ;
