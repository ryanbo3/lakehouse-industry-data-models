    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildDate rdf:type rdf:Property ;
    rdfs:label 'Build Date' ;
    rdfs:comment 'The calendar date when the vehicle completed final assembly and rolled off the production line. Captured from Manufacturing Execution System (MES).' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:checkDigit rdf:type rdf:Property ;
    rdfs:label 'Check Digit' ;
    rdfs:comment 'The 9th character of the VIN used to validate VIN authenticity through a mathematical algorithm. Required in North American markets. Value is 0-9 or X (representing 10).' ;
    rdfs:domain ind:VinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curbWeightKg rdf:type rdf:Property ;
    rdfs:label 'Curb Weight Kg' ;
    rdfs:comment 'The weight of the vehicle with standard equipment, full fluids, and a full tank of fuel, but without passengers or cargo. Measured in kilograms.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationMarket rdf:type rdf:Property ;
    rdfs:label 'Destination Market' ;
    rdfs:comment 'The intended sales and distribution market for this vehicle unit. May differ from homologation market for export vehicles. Three-letter ISO 3166-1 alpha-3 country code.' ;
    rdfs:domain ind:VinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionStandard rdf:type rdf:Property ;
    rdfs:label 'Emission Standard' ;
    rdfs:comment 'The regulatory emissions certification standard this vehicle complies with (e.g., EPA Tier 3, Euro 6d, China 6, BS VI). Defines allowable pollutant limits.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaCombinedMpg rdf:type rdf:Property ;
    rdfs:label 'Epa Combined Mpg' ;
    rdfs:comment 'The EPA-certified combined city/highway fuel economy rating in miles per gallon. Applicable to ICE, HEV, and PHEV vehicles sold in the United States.' ;
    rdfs:domain ind:VinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelTankCapacityLiters rdf:type rdf:Property ;
    rdfs:label 'Fuel Tank Capacity Liters' ;
    rdfs:comment 'The total volume capacity of the primary fuel tank in liters. For electric vehicles, this represents the battery capacity equivalent or is null.' ;
    rdfs:domain ind:VinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gvwrKg rdf:type rdf:Property ;
    rdfs:label 'Gvwr Kg' ;
    rdfs:comment 'The maximum allowable total weight of the vehicle including chassis, body, engine, fluids, passengers, and cargo, as certified by the manufacturer. Measured in kilograms.' ;
    rdfs:domain ind:VinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Line Off Timestamp' ;
