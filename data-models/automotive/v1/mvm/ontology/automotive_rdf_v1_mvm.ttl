    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityScore rdf:type rdf:Property ;
    rdfs:label 'Sustainability Score' ;
    rdfs:comment 'Score reflecting the supplier\'s environmental and sustainability initiatives.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionId rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Id' ;
    rdfs:comment 'Unique identifier for the supply_corrective_action data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inboundInspectionId rdf:type rdf:Property ;
    rdfs:label 'Inbound Inspection Id' ;
    rdfs:comment 'Foreign key linking to supply.inbound_inspection. Business justification: A corrective action is often triggered by a specific incoming inspection failure. Linking supply_corrective_action to inbound_inspection provides the quality evidence that initiated the SCAR, enabling' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundInspection .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Total number of defects identified in the inspected sample.' ;
    rdfs:domain ind:InboundInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectRatePpm rdf:type rdf:Property ;
    rdfs:label 'Defect Rate Ppm' ;
    rdfs:comment 'Defects per million units calculated for the inspected lot.' ;
    rdfs:domain ind:InboundInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectTypeCodes rdf:type rdf:Property ;
    rdfs:label 'Defect Type Codes' ;
    rdfs:comment 'Comma-separated list of defect classification codes (e.g., surface, dimensional, functional).' ;
    rdfs:domain ind:InboundInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLocation rdf:type rdf:Property ;
    rdfs:label 'Inspection Location' ;
    rdfs:comment 'Plant or line code where the inspection was carried out.' ;
    rdfs:domain ind:InboundInspection ;
