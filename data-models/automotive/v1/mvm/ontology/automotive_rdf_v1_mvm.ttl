ind:ecuCatalogDescription rdf:type rdf:Property ;
    rdfs:label 'Ecu Catalog Description' ;
    rdfs:comment 'Free-form description of the ECU, including key capabilities and notes.' ;
    rdfs:domain ind:EcuCatalog ;
    rdf:type owl:DatatypeProperty ;
