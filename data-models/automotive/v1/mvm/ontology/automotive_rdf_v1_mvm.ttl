    rdfs:range xsd:string .

ind:returnReasonCategory rdf:type rdf:Property ;
    rdfs:label 'Return Reason Category' ;
    rdfs:comment 'High-level category of the return reason.' ;
    rdfs:domain ind:PartsReturn ;
