    rdfs:range xsd:string .

ind:plantLocation rdf:type rdf:Property ;
    rdfs:label 'Plant Location' ;
    rdfs:comment 'Identifier of the manufacturing plant where the BOM will be used.' ;
    rdfs:domain ind:Automotive ;
