ind:bomEngineeringChangeOrderChangeId rdf:type rdf:Property ;
    rdfs:label 'Bom Engineering Change Order Change Id' ;
    rdfs:comment 'Identifier of the engineering change order linked to this BOM revision.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Change .

ind:bomCode rdf:type rdf:Property ;
    rdfs:label 'Bom Code' ;
    rdfs:comment 'Business identifier that uniquely identifies the BOM within a program.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomName rdf:type rdf:Property ;
    rdfs:label 'Bom Name' ;
    rdfs:comment 'Human-readable name of the engineering BOM.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Indicates whether the BOM is locked for further changes.' ;
    rdfs:domain ind:Automotive ;
