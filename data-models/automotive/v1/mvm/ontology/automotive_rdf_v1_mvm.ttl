    rdfs:range xsd:dateTime .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of units selected for inspection according to the sampling plan.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualPriceReductionCommitment rdf:type rdf:Property ;
    rdfs:label 'Annual Price Reduction Commitment' ;
    rdfs:comment 'Percentage reduction in price committed by the supplier each year.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceAdjustmentTrigger rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment Trigger' ;
    rdfs:comment 'Condition that can trigger a price change during the agreement (material index, foreign exchange, or none).' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceAgreementDescription rdf:type rdf:Property ;
    rdfs:label 'Price Agreement Description' ;
    rdfs:comment 'Free-form text describing the purpose, scope, and any special conditions of the agreement.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Price Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the price agreement.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolingAmortizationTerms rdf:type rdf:Property ;
    rdfs:label 'Tooling Amortization Terms' ;
    rdfs:comment 'Terms describing how tooling costs are amortized over the agreement period.' ;
    rdfs:domain ind:PriceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsSourceStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Parts Source Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Repair orders need to track which service center warehouse location parts are pulled from for accurate job costing, inventory depletion, and parts availability management. Enables service advisors to ' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:primaryAftersalesCustomerPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Aftersales Customer Party Id' ;
    rdfs:comment 'Identifier of the customer who owns the vehicle.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:primaryAftersalesDealerDealershipId rdf:type rdf:Property ;
    rdfs:label 'Primary Aftersales Dealer Dealership Id' ;
    rdfs:comment 'Identifier of the dealer/service center handling the repair.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:serviceCenterId rdf:type rdf:Property ;
    rdfs:label 'Service Center Id' ;
    rdfs:comment 'Identifier of the physical service location.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCenter .

ind:technicianId rdf:type rdf:Property ;
    rdfs:label 'Technician Id' ;
    rdfs:comment 'Identifier of the primary technician assigned to perform the work.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:vehicleOwnershipId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Ownership Id' ;
    rdfs:comment 'Foreign key linking to customer.vehicle_ownership. Business justification: Service order processing uses the ownership record to confirm warranty coverage and apply owner-specific service rules.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleOwnership .

ind:actualCompletionTime rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Time' ;
    rdfs:comment 'Actual date and time when the repair was completed.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:aftersalesRepairOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Aftersales Repair Order Status' ;
    rdfs:comment 'Current lifecycle status of the repair order.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Timestamp' ;
    rdfs:comment 'Date and time when the repair order was closed.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
