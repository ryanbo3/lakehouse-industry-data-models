    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprConsentSms rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Sms' ;
    rdfs:comment 'Indicates whether the party has consented to receive SMS communications under GDPR.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'Date the organization was legally formed.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:industryClassification rdf:type rdf:Property ;
    rdfs:label 'Industry Classification' ;
    rdfs:comment 'Standard industry code (NAICS or SIC) describing the party\'s primary business.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTaxExempt rdf:type rdf:Property ;
    rdfs:label 'Is Tax Exempt' ;
    rdfs:comment 'Indicates whether the party is exempt from sales tax.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Status' ;
    rdfs:comment 'Current status of KYC verification for the party.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'Date when the party\'s information was last validated against source data.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full legal name of the individual or organization as recorded for contracts and compliance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPromoterScore rdf:type rdf:Property ;
    rdfs:label 'Net Promoter Score' ;
    rdfs:comment 'Latest NPS rating captured for the party.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onboardingChannel rdf:type rdf:Property ;
    rdfs:label 'Onboarding Channel' ;
    rdfs:comment 'Channel through which the party was onboarded.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date the party was first created in the system.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partyType rdf:type rdf:Property ;
    rdfs:label 'Party Type' ;
    rdfs:comment 'Indicates whether the party is an individual customer or an organization (e.g., fleet operator, dealer).' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency' ;
    rdfs:comment 'ISO 4217 currency code the party prefers for billing and pricing.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-1 language code for the party\'s preferred communication language.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactMethod rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Method' ;
    rdfs:comment 'Method most frequently used to reach the party.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official registration number for an organization (e.g., corporate registration, dealer license).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptReason rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Reason' ;
    rdfs:comment 'Reason or code for tax exemption, if applicable.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Government-issued tax identifier (e.g., EIN, VAT) for the party.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Doing-business-as name or brand name used by the organization.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Party Relationship Id' ;
    rdfs:comment 'Surrogate primary key for the party relationship record.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fromPartyId rdf:type rdf:Property ;
    rdfs:label 'From Party Id' ;
    rdfs:comment 'Identifier of the source party in the relationship (e.g., parent company, household head, driver).' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:relationshipManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Customer Relationship Owner tracking records the employee overseeing a specific party-to-party relationship.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:toPartyId rdf:type rdf:Property ;
    rdfs:label 'To Party Id' ;
    rdfs:comment 'Identifier of the target party in the relationship (e.g., subsidiary, household member, authorized driver).' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'External contract or agreement identifier that governs the relationship, if applicable.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inverseRole rdf:type rdf:Property ;
    rdfs:label 'Inverse Role' ;
    rdfs:comment 'Corresponding role of the target party from its perspective.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLegalEntity rdf:type rdf:Property ;
    rdfs:label 'Is Legal Entity' ;
    rdfs:comment 'Flag indicating whether the relationship is recognized as a legal entity relationship (e.g., corporate ownership) rather than informal.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partyRelationshipDescription rdf:type rdf:Property ;
    rdfs:label 'Party Relationship Description' ;
    rdfs:comment 'Free-text notes or comments describing the nature of the relationship.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyRelationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Party Relationship Status' ;
    rdfs:comment 'Current lifecycle status of the relationship.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipRole rdf:type rdf:Property ;
    rdfs:label 'Relationship Role' ;
    rdfs:comment 'Role of the source party within this relationship (e.g., owner, contact, driver, guarantor).' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStrength rdf:type rdf:Property ;
    rdfs:label 'Relationship Strength' ;
    rdfs:comment 'Numeric rating (1-5) indicating the assessed strength or importance of the relationship.' ;
    rdfs:domain ind:PartyRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pdiRecordId rdf:type rdf:Property ;
    rdfs:label 'Pdi Record Id' ;
    rdfs:comment 'Unique system-generated identifier for the PDI record.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pdiTechnicianId rdf:type rdf:Property ;
    rdfs:label 'Pdi Technician Id' ;
    rdfs:comment 'Identifier of the technician who performed the inspection.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:connectedServicesActivated rdf:type rdf:Property ;
    rdfs:label 'Connected Services Activated' ;
    rdfs:comment 'True if connected vehicle services (e.g., telematics) were activated at delivery.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Customer Signature Date' ;
    rdfs:comment 'Date on which the customer signed the PDI acceptance form.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerWalkthroughCompleted rdf:type rdf:Property ;
    rdfs:label 'Customer Walkthrough Completed' ;
    rdfs:comment 'True if the dealer completed the customer walkthrough of vehicle features.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Official date the vehicle was handed over to the customer.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:floorMatCount rdf:type rdf:Property ;
    rdfs:label 'Floor Mat Count' ;
    rdfs:comment 'Count of floor mats provided with the vehicle.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionChecklistVersion rdf:type rdf:Property ;
    rdfs:label 'Inspection Checklist Version' ;
    rdfs:comment 'Version of the PDI checklist used during the inspection.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionItemsJson rdf:type rdf:Property ;
    rdfs:label 'Inspection Items Json' ;
    rdfs:comment 'JSON string capturing individual checklist item results and comments.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyCount rdf:type rdf:Property ;
    rdfs:label 'Key Count' ;
    rdfs:comment 'Count of vehicle keys handed over to the customer.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otaBaselineVersion rdf:type rdf:Property ;
    rdfs:label 'Ota Baseline Version' ;
    rdfs:comment 'Baseline over-the-air software version installed on the vehicle at delivery.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallPass rdf:type rdf:Property ;
    rdfs:label 'Overall Pass' ;
    rdfs:comment 'Flag indicating whether the vehicle passed the overall PDI (true) or failed (false).' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerManualProvided rdf:type rdf:Property ;
    rdfs:label 'Owner Manual Provided' ;
    rdfs:comment 'Indicates whether the owner’s manual was supplied to the customer.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pdiDate rdf:type rdf:Property ;
    rdfs:label 'Pdi Date' ;
    rdfs:comment 'Calendar date on which the PDI was conducted.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pdiNumber rdf:type rdf:Property ;
    rdfs:label 'Pdi Number' ;
    rdfs:comment 'Business identifier assigned to the PDI event, used for tracking and reference.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdiRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Pdi Record Status' ;
    rdfs:comment 'Current lifecycle status of the PDI record.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdiTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pdi Timestamp' ;
    rdfs:comment 'Exact timestamp when the PDI inspection was performed.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tpmsCalibrated rdf:type rdf:Property ;
    rdfs:label 'Tpms Calibrated' ;
    rdfs:comment 'Indicates whether the Tire Pressure Monitoring System was calibrated.' ;
    rdfs:domain ind:PdiRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataOriginSystem rdf:type rdf:Property ;
    rdfs:label 'Data Origin System' ;
    rdfs:comment 'Identifies the source system that supplied the preference record.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOptOut rdf:type rdf:Property ;
    rdfs:label 'Is Opt Out' ;
    rdfs:comment 'True if the customer has explicitly opted out of the indicated preference; otherwise false.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceCategory rdf:type rdf:Property ;
    rdfs:label 'Preference Category' ;
    rdfs:comment 'High-level grouping of the preference (e.g., communication, vehicle feature, service scheduling, digital experience, privacy).' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Current lifecycle state of the preference (e.g., active, inactive, expired, pending review).' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceValue rdf:type rdf:Property ;
    rdfs:label 'Preference Value' ;
    rdfs:comment 'The value assigned to the preference key; stored as text and interpreted according to value_data_type.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueDataType rdf:type rdf:Property ;
    rdfs:label 'Value Data Type' ;
    rdfs:comment 'Indicates the native data type of preference_value (e.g., string, boolean, integer, list).' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyRequestId rdf:type rdf:Property ;
    rdfs:label 'Privacy Request Id' ;
    rdfs:comment 'Unique system-generated identifier for the privacy request record.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handlingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Handling Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GDPR Request Handling requires linking each privacy request to the employee responsible for processing it.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date the request was fully processed and closed.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataDomainsAffected rdf:type rdf:Property ;
    rdfs:label 'Data Domains Affected' ;
    rdfs:comment 'JSON-encoded list of business data domains (e.g., vehicle, sales, after-sales) impacted by the request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentNotes rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Notes' ;
    rdfs:comment 'Free-form notes describing actions taken to satisfy the request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHighRisk rdf:type rdf:Property ;
    rdfs:label 'Is High Risk' ;
    rdfs:comment 'Indicates whether the request involves high-risk data (e.g., biometric, financial).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'Legal framework governing the request, such as GDPR, CCPA, PIPEDA, or LGPD.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Business identifier assigned to the request for tracking and reference.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current processing status of the request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Type of privacy right exercised by the subject (e.g., erasure, access, portability, rectification, restriction, opt-out).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'Channel through which the privacy request was received.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemsNotified rdf:type rdf:Property ;
    rdfs:label 'Systems Notified' ;
    rdfs:comment 'JSON-encoded list of source systems (e.g., SAP S/4HANA, Salesforce) that were informed of the request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Identifier of the employee or system that performed the identity verification.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentMembershipId rdf:type rdf:Property ;
    rdfs:label 'Segment Membership Id' ;
    rdfs:comment 'System-generated unique identifier for each segment membership record.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedBy rdf:type rdf:Property ;
    rdfs:label 'Assigned By' ;
    rdfs:comment 'Identifier of the user or system that performed the segment assignment.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'Date on which the customer was assigned to the segment.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isPrimarySegment rdf:type rdf:Property ;
    rdfs:label 'Is Primary Segment' ;
    rdfs:comment 'True if this segment is the primary segment for the customer; otherwise false.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:telematicsDeviceId rdf:type rdf:Property ;
    rdfs:label 'Telematics Device Id' ;
    rdfs:comment 'Foreign key linking to mobility.telematics_device. Business justification: Service and OTA update processes need to know which telematics device is installed on each owned vehicle.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TelematicsDevice .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'Source through which the vehicle was obtained.' ;
    rdfs:domain ind:VehicleOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionDealerCode rdf:type rdf:Property ;
    rdfs:label 'Acquisition Dealer Code' ;
    rdfs:comment 'Identifier of the dealer that facilitated the acquisition.' ;
    rdfs:domain ind:VehicleOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'Date the vehicle was disposed of (sold, traded, etc.).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionOdometer rdf:type rdf:Property ;
    rdfs:label 'Disposition Odometer' ;
    rdfs:comment 'Mileage recorded at the time of disposition.' ;
    rdfs:domain ind:VehicleOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionType rdf:type rdf:Property ;
    rdfs:label 'Disposition Type' ;
    rdfs:comment 'How the ownership relationship ended.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCarrier rdf:type rdf:Property ;
    rdfs:label 'Insurance Carrier' ;
    rdfs:comment 'Company providing the vehicle\'s insurance coverage.' ;
    rdfs:domain ind:VehicleOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpiry rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry' ;
    rdfs:comment 'Date the insurance coverage ends.' ;
    rdfs:domain ind:VehicleOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Identifier of the insurance policy covering the vehicle.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryVehicle rdf:type rdf:Property ;
    rdfs:label 'Is Primary Vehicle' ;
    rdfs:comment 'True if this vehicle is the primary vehicle for the customer household.' ;
    rdfs:domain ind:VehicleOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lienHolderName rdf:type rdf:Property ;
    rdfs:label 'Lien Holder Name' ;
    rdfs:comment 'Name of the financial institution or entity holding a lien on the vehicle.' ;
    rdfs:domain ind:VehicleOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odometerAtAcquisition rdf:type rdf:Property ;
    rdfs:label 'Odometer At Acquisition' ;
    rdfs:comment 'Vehicle mileage recorded at the time of acquisition.' ;
    rdfs:domain ind:VehicleOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownershipNumber rdf:type rdf:Property ;
    rdfs:label 'Ownership Number' ;
    rdfs:comment 'Business identifier for the ownership agreement between the customer and the manufacturer/dealer.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Classification of how the vehicle is held by the customer.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationCountry rdf:type rdf:Property ;
    rdfs:label 'Registration Country' ;
    rdfs:comment 'Three-letter country code of the registration jurisdiction.' ;
    rdfs:domain ind:VehicleOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationExpiry rdf:type rdf:Property ;
    rdfs:label 'Registration Expiry' ;
    rdfs:comment 'Date the vehicle registration expires.' ;
    rdfs:domain ind:VehicleOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:titleNumber rdf:type rdf:Property ;
    rdfs:label 'Title Number' ;
    rdfs:comment 'Legal document number proving ownership.' ;
    rdfs:domain ind:VehicleOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleState rdf:type rdf:Property ;
    rdfs:label 'Title State' ;
    rdfs:comment 'State that issued the title.' ;
    rdfs:domain ind:VehicleOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeInVin rdf:type rdf:Property ;
    rdfs:label 'Trade In Vin' ;
    rdfs:comment 'VIN of a vehicle traded in as part of the acquisition, if applicable.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleOwnershipStatus rdf:type rdf:Property ;
    rdfs:label 'Vehicle Ownership Status' ;
    rdfs:comment 'Current lifecycle state of the ownership record.' ;
    rdfs:domain ind:VehicleOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationRuleId rdf:type rdf:Property ;
    rdfs:label 'Allocation Rule Id' ;
    rdfs:comment 'Unique surrogate identifier for the vehicle allocation rule record in the dealer network management system.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByRuleAllocationRuleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rule Allocation Rule Id' ;
    rdfs:comment 'Reference to the allocation_rule_id of the newer rule that replaces this rule when it is superseded. Null if this rule has not been replaced. Enables rule lineage tracking across model year and program transitions.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationRule .

ind:allocationBasis rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis' ;
    rdfs:comment 'The primary metric or data source used to calculate each dealer\'s share of the total allocation pool under this rule. Retail sales uses prior-period retail units sold; wholesale_orders uses dealer order history; days_supply targets a specific inventory days-supply level; market_share uses regional market penetration; scorecard_rank uses the dealer performance scorecard ranking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationCycle rdf:type rdf:Property ;
    rdfs:label 'Allocation Cycle' ;
    rdfs:comment 'Frequency at which the allocation engine applies this rule to generate vehicle_allocation records. Determines the cadence of dealer inventory replenishment under this rule.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Calendar date on which this allocation rule received final approval and was authorized for activation in the allocation engine.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carryoverAllowed rdf:type rdf:Property ;
    rdfs:label 'Carryover Allowed' ;
    rdfs:comment 'Indicates whether unallocated units from a prior cycle can be carried over and added to the next cycle\'s pool under this rule. True enables carryover; False requires the pool to be reset each cycle.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictResolution rdf:type rdf:Property ;
    rdfs:label 'Conflict Resolution' ;
    rdfs:comment 'Method used by the allocation engine when this rule conflicts with another active rule for the same dealer and nameplate. Highest_priority applies the rule with the highest priority_weight; sum combines allocations; average takes the mean; manual flags for human review.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRuleRef rdf:type rdf:Property ;
    rdfs:label 'External Rule Ref' ;
    rdfs:comment 'The rule identifier or document reference as recorded in the originating source system (e.g., SAP condition record number, CDK rule ID). Enables cross-system reconciliation and traceability.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseType rdf:type rdf:Property ;
    rdfs:label 'Franchise Type' ;
    rdfs:comment 'Dealer franchise model to which this rule applies: OEM-owned (factory store), independent franchise, dual franchise (carrying multiple OEM brands), or \'all\' for rules spanning all franchise types.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lookbackPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Lookback Period Days' ;
    rdfs:comment 'Number of historical days used to calculate the allocation basis metric (e.g., 90 days of retail sales history). Defines the rolling window for performance-based and volume-based allocation calculations.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxAllocationUnits rdf:type rdf:Property ;
    rdfs:label 'Max Allocation Units' ;
    rdfs:comment 'Maximum number of vehicle units that can be allocated to a qualifying dealer under this rule per allocation cycle. Prevents over-concentration of inventory at high-volume dealers and supports equitable network distribution.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minAllocationUnits rdf:type rdf:Property ;
    rdfs:label 'Min Allocation Units' ;
    rdfs:comment 'Minimum number of vehicle units that must be allocated to a qualifying dealer under this rule per allocation cycle. Ensures floor-level inventory support for smaller dealers and contractual franchise minimums.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minCsiScore rdf:type rdf:Property ;
    rdfs:label 'Min Csi Score' ;
    rdfs:comment 'Minimum Customer Satisfaction Index (CSI) score a dealer must maintain to qualify for allocation under this rule. CSI is measured via OEM customer surveys post-purchase and post-service. Dealers below this threshold may be excluded or receive reduced allocation.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minScorecardScore rdf:type rdf:Property ;
    rdfs:label 'Min Scorecard Score' ;
    rdfs:comment 'Minimum dealer performance scorecard score required for a dealer to qualify for allocation under this rule. Used for performance-based rules to restrict allocation to dealers meeting OEM performance standards.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelMixTargetPct rdf:type rdf:Property ;
    rdfs:label 'Model Mix Target Pct' ;
    rdfs:comment 'Target percentage of the allocated units that should be of the specified nameplate or powertrain type within the dealer\'s total inventory mix. Used for model_mix rule types to enforce portfolio balance (e.g., 20% EV mix target).' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nameplateCode rdf:type rdf:Property ;
    rdfs:label 'Nameplate Code' ;
    rdfs:comment 'OEM-assigned code identifying the vehicle nameplate (model line) to which this allocation rule applies (e.g., F-150, Silverado, Camry, Model 3). Corresponds to the nameplate/model line in the PLM system.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Override Allowed' ;
    rdfs:comment 'Indicates whether authorized OEM personnel can manually override the allocation quantities generated by this rule for individual dealers. Supports exception handling for special dealer circumstances.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'SAP plant code identifying the manufacturing or assembly plant that is the source of vehicles allocated under this rule. Ties the allocation rule to a specific production source for supply chain planning.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityWeight rdf:type rdf:Property ;
    rdfs:label 'Priority Weight' ;
    rdfs:comment 'Numeric weighting factor (0.00–100.00) assigned to this rule when multiple allocation rules apply simultaneously. Higher weights cause the allocation engine to favor this rule over lower-weighted rules during conflict resolution.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the allocation rule, used in dealer communications, DMS integration, and allocation engine references (e.g., ALLOC-VOL-2024-001).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Free-text narrative description of the allocation rule\'s business purpose, special conditions, or exceptions. Provides context for allocation analysts and dealer network managers reviewing rule configurations.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable descriptive name for the allocation rule, used in reporting dashboards and dealer portal displays (e.g., \'Q1 2024 F-Series Volume Allocation - Northeast Region\').' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle state of the allocation rule. Draft rules are under review; active rules are used by the allocation engine; suspended rules are temporarily paused; expired rules have passed their effective end date; cancelled rules have been voided before activation.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classification of the allocation rule governing how vehicles are distributed. Volume-based uses historical sales volume; performance-based uses dealer scorecard metrics; geographic uses territory boundaries; model_mix enforces nameplate portfolio balance; incentive_based ties allocation to dealer incentive program participation; priority_based uses explicit dealer priority tiers. [ENUM-REF-CANDIDATE: volume_based|performance_based|geographic|model_mix|incentive_based|priority_based — promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackable rdf:type rdf:Property ;
    rdfs:label 'Stackable' ;
    rdfs:comment 'Indicates whether this allocation rule can be combined (stacked) with other active allocation rules for the same dealer, nameplate, and model year. Non-stackable rules are applied exclusively when triggered.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetDaysSupply rdf:type rdf:Property ;
    rdfs:label 'Target Days Supply' ;
    rdfs:comment 'Target inventory days-supply level that this allocation rule aims to achieve at qualifying dealers. Days supply = (current inventory units) / (average daily retail sales rate). Used when allocation_basis is \'days_supply\'.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPoolUnits rdf:type rdf:Property ;
    rdfs:label 'Total Pool Units' ;
    rdfs:comment 'Total number of vehicle units available in the allocation pool governed by this rule for the current allocation cycle. The allocation engine distributes these units across qualifying dealers according to the rule logic.' ;
    rdfs:domain ind:AllocationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Sub-regional distribution zone code within the sales region to which this rule applies. Zones represent finer geographic groupings of dealers used for allocation granularity below the region level.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csiSurveyId rdf:type rdf:Property ;
    rdfs:label 'Csi Survey Id' ;
    rdfs:comment 'Unique identifier for the CSI survey response record.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Identifier of the dealer order associated with this survey, if the survey is related to a sales transaction.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:repairOrderId rdf:type rdf:Property ;
    rdfs:label 'Repair Order Id' ;
    rdfs:comment 'Identifier of the repair order associated with this survey, if the survey is related to a service transaction.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:complaintCategory rdf:type rdf:Property ;
    rdfs:label 'Complaint Category' ;
    rdfs:comment 'Category code classifying the nature of the customer complaint if complaint_flag is True (e.g., service_quality, pricing, staff_behavior, facility_issue).' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintFlag rdf:type rdf:Property ;
    rdfs:label 'Complaint Flag' ;
    rdfs:comment 'Boolean indicator (True/False) whether the survey response contains a customer complaint requiring follow-up action.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daysToResponse rdf:type rdf:Property ;
    rdfs:label 'Days To Response' ;
    rdfs:comment 'Number of days between the customer interaction date and the survey completion date.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dealerPerformanceImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Dealer Performance Impact Flag' ;
    rdfs:comment 'Boolean indicator (True/False) whether this survey response will be included in the dealer\'s official performance scorecard and franchise compliance review.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryProcessScore rdf:type rdf:Property ;
    rdfs:label 'Delivery Process Score' ;
    rdfs:comment 'Customer satisfaction score for the vehicle delivery process, applicable to sales satisfaction surveys.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityCleanlinessScore rdf:type rdf:Property ;
    rdfs:label 'Facility Cleanliness Score' ;
    rdfs:comment 'Customer satisfaction score for the cleanliness and appearance of the dealership facility.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followUpCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Completed Flag' ;
    rdfs:comment 'Boolean indicator (True/False) whether the required follow-up action has been completed.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Completion Date' ;
    rdfs:comment 'Date when the follow-up action was completed, if applicable.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interactionDate rdf:type rdf:Property ;
    rdfs:label 'Interaction Date' ;
    rdfs:comment 'Date of the original customer interaction (sales delivery, service completion, etc.) that triggered this survey.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketCode rdf:type rdf:Property ;
    rdfs:label 'Market Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code identifying the geographic market where the survey was conducted.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsCategory rdf:type rdf:Property ;
    rdfs:label 'Nps Category' ;
    rdfs:comment 'Classification of the customer based on NPS score: promoter (9-10), passive (7-8), or detractor (0-6).' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oemProgramCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Oem Program Compliant Flag' ;
    rdfs:comment 'Boolean indicator (True/False) whether the survey response meets OEM CSI program compliance thresholds for dealer performance evaluation.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Overall Satisfaction Score' ;
    rdfs:comment 'Overall customer satisfaction score, typically on a scale (e.g., 1-5, 1-10, or 0-100) as defined by the OEM CSI program.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingTransparencyScore rdf:type rdf:Property ;
    rdfs:label 'Pricing Transparency Score' ;
    rdfs:comment 'Customer satisfaction score for the transparency and fairness of pricing communicated during the transaction.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:problemResolutionScore rdf:type rdf:Property ;
    rdfs:label 'Problem Resolution Score' ;
    rdfs:comment 'Customer satisfaction score for how effectively any issues or concerns were resolved.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseChannel rdf:type rdf:Property ;
    rdfs:label 'Response Channel' ;
    rdfs:comment 'Channel through which the customer submitted the survey response (email, phone, SMS, web portal, mobile app, postal mail, or in-person at dealership). [ENUM-REF-CANDIDATE: email|phone|sms|web|mobile_app|mail|in_person — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesConsultantScore rdf:type rdf:Property ;
    rdfs:label 'Sales Consultant Score' ;
    rdfs:comment 'Customer satisfaction score for the sales consultant interaction, applicable to sales satisfaction surveys.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sentimentCategory rdf:type rdf:Property ;
    rdfs:label 'Sentiment Category' ;
    rdfs:comment 'Categorical classification of the verbatim comment sentiment: positive, neutral, negative, or mixed.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentScore rdf:type rdf:Property ;
    rdfs:label 'Sentiment Score' ;
    rdfs:comment 'Automated sentiment analysis score derived from the verbatim comment, typically ranging from -1 (negative) to +1 (positive).' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceQualityScore rdf:type rdf:Property ;
    rdfs:label 'Service Quality Score' ;
    rdfs:comment 'Customer satisfaction score for the quality of service work performed, applicable to service satisfaction surveys.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceTimelinessScore rdf:type rdf:Property ;
    rdfs:label 'Service Timeliness Score' ;
    rdfs:comment 'Customer satisfaction score for the timeliness of service completion, applicable to service satisfaction surveys.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:staffCourtesyScore rdf:type rdf:Property ;
    rdfs:label 'Staff Courtesy Score' ;
    rdfs:comment 'Customer satisfaction score for the courtesy and professionalism of dealership staff.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Survey Completion Percentage' ;
    rdfs:comment 'Percentage of survey questions answered by the customer, indicating survey completion rate (0-100).' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Survey Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the language in which the survey was presented and completed.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyProgramCode rdf:type rdf:Property ;
    rdfs:label 'Survey Program Code' ;
    rdfs:comment 'Code identifying the specific OEM CSI survey program or campaign under which this survey was administered.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyStatus rdf:type rdf:Property ;
    rdfs:label 'Survey Status' ;
    rdfs:comment 'Status of the survey response: completed (fully answered), partial (incomplete), abandoned (started but not submitted), or invalid (failed validation).' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyTimestamp rdf:type rdf:Property ;
    rdfs:label 'Survey Timestamp' ;
    rdfs:comment 'Precise timestamp when the customer submitted the survey response.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:surveyVendorCode rdf:type rdf:Property ;
    rdfs:label 'Survey Vendor Code' ;
    rdfs:comment 'Code identifying the third-party vendor or platform that administered the survey (e.g., Medallia, Qualtrics, internal OEM system).' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleConditionScore rdf:type rdf:Property ;
    rdfs:label 'Vehicle Condition Score' ;
    rdfs:comment 'Customer satisfaction score for the condition of the vehicle at delivery or service completion.' ;
    rdfs:domain ind:CsiSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealerCertificationId rdf:type rdf:Property ;
    rdfs:label 'Dealer Certification Id' ;
    rdfs:comment 'Unique identifier for the dealer certification record. Primary key.' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Allocation Eligibility Flag' ;
    rdfs:comment 'Indicates whether this certification makes the dealer eligible for preferential vehicle allocation (e.g., EV-certified dealers receive priority allocation of electric vehicles).' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:annualMaintenanceCostAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Maintenance Cost Amount' ;
    rdfs:comment 'Estimated annual cost to maintain this certification, including renewal fees, ongoing training, and audit costs. Expressed in the OEM\'s reporting currency.' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditOutcome rdf:type rdf:Property ;
    rdfs:label 'Audit Outcome' ;
    rdfs:comment 'Result of the most recent audit (e.g., passed, passed with conditions, failed). Determines whether certification remains in good standing.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Required Flag' ;
    rdfs:comment 'Indicates whether the dealer must undergo periodic audits to maintain this certification.' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditScore rdf:type rdf:Property ;
    rdfs:label 'Audit Score' ;
    rdfs:comment 'Numerical score or rating achieved in the most recent audit (e.g., 0-100 scale, or percentage). Reflects compliance quality and performance.' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedVehicleLines rdf:type rdf:Property ;
    rdfs:label 'Authorized Vehicle Lines' ;
    rdfs:comment 'Comma-separated list of vehicle model lines or platforms the dealer is authorized to sell or service under this certification (e.g., \'Model S, Model X, Model 3\' for EV certification).' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'Full descriptive name of the certification program or credential (e.g., \'Electric Vehicle Sales and Service Certification\', \'Advanced Driver Assistance Systems Authorized Service Center\').' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost incurred by the dealer to obtain this certification, including training, equipment, facility upgrades, and application fees. Expressed in the OEM\'s reporting currency.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentRequirements rdf:type rdf:Property ;
    rdfs:label 'Equipment Requirements' ;
    rdfs:comment 'Description of specialized tools, diagnostic equipment, or technology the dealer must possess for this certification (e.g., high-voltage battery diagnostic tools, ADAS radar calibration systems).' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityRequirements rdf:type rdf:Property ;
    rdfs:label 'Facility Requirements' ;
    rdfs:comment 'Description of physical facility requirements the dealer must meet for this certification (e.g., dedicated EV charging bays, ADAS calibration equipment, climate-controlled service area).' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Eligibility Flag' ;
    rdfs:comment 'Indicates whether this certification qualifies the dealer for special incentive programs, rebates, or performance bonuses.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingBodyType rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Type' ;
    rdfs:comment 'Classification of the entity that issued the certification (e.g., OEM corporate, industry association, regulatory body, third-party auditor).' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'Date of the most recent renewal or recertification event. Tracks ongoing compliance and re-qualification.' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumCertifiedTechnicians rdf:type rdf:Property ;
    rdfs:label 'Minimum Certified Technicians' ;
    rdfs:comment 'Minimum number of technicians who must hold individual certification credentials for the dealer to maintain this certification.' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Date by which the next audit must be completed to maintain certification compliance.' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextRenewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Due Date' ;
    rdfs:comment 'Date by which the dealer must complete renewal requirements to maintain active certification status. Used for proactive renewal management.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:personnelRequirements rdf:type rdf:Property ;
    rdfs:label 'Personnel Requirements' ;
    rdfs:comment 'Description of staffing requirements for this certification (e.g., minimum number of certified technicians, specific role qualifications, training credentials).' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementDate rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Date' ;
    rdfs:comment 'Date when a previously suspended certification was reinstated to active status. Nullable if never suspended or not yet reinstated.' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Months' ;
    rdfs:comment 'Number of months between required renewal cycles for this certification (e.g., 12 for annual, 24 for biennial, 36 for triennial).' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'Date when the certification was permanently revoked. Nullable if never revoked.' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Explanation of why the certification was permanently revoked, if applicable (e.g., serious compliance violations, fraudulent activity, repeated failures). Nullable if never revoked.' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'Date when the certification was suspended. Nullable if never suspended.' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Explanation of why the certification was suspended, if applicable (e.g., failed audit, non-compliance with training requirements, facility deficiencies). Nullable if never suspended.' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date when the dealer completed the required training program for this certification. Nullable if training is not required or not yet completed.' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether dealer personnel must complete specific training programs to obtain or maintain this certification.' ;
    rdfs:domain ind:DealerCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Unique identifier for the dealer contact record. Primary key.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether the contact is currently active and employed at the dealership. True if active; False if terminated, retired, or on extended leave.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactRole rdf:type rdf:Property ;
    rdfs:label 'Contact Role' ;
    rdfs:comment 'The functional role or position of the contact at the dealership. Includes dealer principal, general manager, sales manager, service manager, parts manager, and F&I (Finance and Insurance) manager.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerPortalAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Dealer Portal Access Flag' ;
    rdfs:comment 'Indicates whether the contact has been granted access to the OEM dealer portal for ordering, inventory management, warranty claims, and communications. True if access is granted; False if not.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'The department or functional area within the dealership where the contact works. Includes sales, service, parts, F&I (Finance and Insurance), administration, and management.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'The name of the person to contact in case of an emergency involving this dealer contact.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'The phone number of the emergency contact person for this dealer contact.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for the dealer contact, if still in use for document transmission.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'The official job title or designation of the contact at the dealership, which may differ from the standardized contact role.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile phone number for the dealer contact, used for urgent communications and field operations.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalLastLoginTimestamp rdf:type rdf:Property ;
    rdfs:label 'Portal Last Login Timestamp' ;
    rdfs:comment 'The date and time when the contact last logged into the OEM dealer portal. Used to monitor engagement and identify inactive users.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portalUserCode rdf:type rdf:Property ;
    rdfs:label 'Portal User Code' ;
    rdfs:comment 'The unique user identifier or login name for the contact in the OEM dealer portal system. Used for authentication and access management.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Flag' ;
    rdfs:comment 'Indicates whether this contact is the primary point of contact for their role at the dealership. True if primary; False if secondary or backup contact.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tenureYears rdf:type rdf:Property ;
    rdfs:label 'Tenure Years' ;
    rdfs:comment 'The number of years the contact has been employed at the dealership, calculated from hire date. Used for experience assessment and program eligibility.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'The date when the contact\'s employment at the dealership ended. Null if the contact is still active.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealerInventoryId rdf:type rdf:Property ;
    rdfs:label 'Dealer Inventory Id' ;
    rdfs:comment 'Unique surrogate identifier for each dealer inventory record in the Silver Layer lakehouse. Primary key for this data product.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finishedVehicleStockId rdf:type rdf:Property ;
    rdfs:label 'Finished Vehicle Stock Id' ;
    rdfs:comment 'Foreign key linking to inventory.finished_vehicle_stock. Business justification: REQUIRED: Allocation traceability report needs to map each dealer inventory record to the originating finished-vehicle stock for compliance and recall tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinishedVehicleStock .

ind:vehicleBuildId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Build Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.vehicle_build. Business justification: Needed for Vehicle Traceability report, connecting each inventory record to its exact build record for warranty and recall actions.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleBuild .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'The dealer\'s total landed cost for this vehicle unit, including invoice price, transportation/destination charges, PDI costs, and any dealer-installed accessories. Used for gross profit calculation and inventory valuation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Order Number' ;
    rdfs:comment 'The OEM-assigned order or allocation number associated with this vehicle unit, linking the dealer inventory record back to the factory production order. Used for order tracking, allocation management, and OEM-dealer reconciliation.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:askingPrice rdf:type rdf:Property ;
    rdfs:label 'Asking Price' ;
    rdfs:comment 'The dealer\'s current advertised or asking retail price for this vehicle unit. May differ from MSRP due to market adjustments, dealer markups, or promotional discounts. Updated dynamically based on market conditions and days-on-lot.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certifiedPreOwned rdf:type rdf:Property ;
    rdfs:label 'Certified Pre Owned' ;
    rdfs:comment 'Indicates whether this used vehicle unit has been certified under the OEM\'s Certified Pre-Owned (CPO) program, meeting specific age, mileage, inspection, and reconditioning standards. True = CPO certified; False = not CPO certified. CPO vehicles carry extended warranty coverage and premium pricing.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daysOnLot rdf:type rdf:Property ;
    rdfs:label 'Days On Lot' ;
    rdfs:comment 'The number of calendar days this vehicle unit has been physically present on the dealer\'s lot since the received date. A key inventory aging metric used to trigger price adjustments, incentive programs, and wholesale decisions. Aged inventory (typically >60 days) incurs floor plan interest costs.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dmsRecordReference rdf:type rdf:Property ;
    rdfs:label 'Dms Record Reference' ;
    rdfs:comment 'The source system record identifier from CDK Global DMS for this inventory unit. Used for data lineage, reconciliation, and incremental load processing between the DMS source and the Silver Layer lakehouse.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineDescription rdf:type rdf:Property ;
    rdfs:label 'Engine Description' ;
    rdfs:comment 'Descriptive label for the engine or powertrain configuration (e.g., \'2.5L 4-Cylinder\', \'3.5L V6 EcoBoost\', \'75 kWh Electric Motor\'). Supports customer consultation and technical service identification.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Date' ;
    rdfs:comment 'The estimated date the vehicle unit is expected to arrive at the dealership from the OEM or transport carrier. Relevant for in-transit inventory. Used for customer pre-order management and lot planning.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exteriorColorCode rdf:type rdf:Property ;
    rdfs:label 'Exterior Color Code' ;
    rdfs:comment 'OEM-assigned paint/exterior color code for this vehicle unit (e.g., \'NH-883P\' for Sonic Gray Pearl). Used for inventory search, customer matching, and lot locator functions within CDK Global DMS.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exteriorColorName rdf:type rdf:Property ;
    rdfs:label 'Exterior Color Name' ;
    rdfs:comment 'Human-readable marketing name of the exterior paint color (e.g., \'Sonic Gray Pearl\', \'Midnight Black Metallic\'). Used for customer-facing display and sales consultation.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorPlanDate rdf:type rdf:Property ;
    rdfs:label 'Floor Plan Date' ;
    rdfs:comment 'The date on which floor plan financing commenced for this vehicle unit. Used to calculate accrued floor plan interest costs and curtailment schedules. Null for vehicles not financed via floor plan.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:floorPlanLender rdf:type rdf:Property ;
    rdfs:label 'Floor Plan Lender' ;
    rdfs:comment 'Name of the financial institution providing floor plan (wholesale) financing for this vehicle unit (e.g., \'Ford Motor Credit\', \'Ally Financial\', \'Chase Auto Finance\'). Floor plan financing is the short-term credit line dealers use to fund vehicle inventory.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelEconomyCityMpg rdf:type rdf:Property ;
    rdfs:label 'Fuel Economy City Mpg' ;
    rdfs:comment 'EPA-rated city fuel economy for this vehicle configuration in miles per gallon (MPG), or MPGe for electric/hybrid vehicles. Required disclosure on the Monroney label and used for CAFE compliance reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelEconomyHighwayMpg rdf:type rdf:Property ;
    rdfs:label 'Fuel Economy Highway Mpg' ;
    rdfs:comment 'EPA-rated highway fuel economy for this vehicle configuration in miles per gallon (MPG), or MPGe for electric/hybrid vehicles. Required disclosure on the Monroney label and used for CAFE compliance reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inServiceDate rdf:type rdf:Property ;
    rdfs:label 'In Service Date' ;
    rdfs:comment 'The date the vehicle was placed into service (sold and delivered to a retail customer, or placed into demo/loaner service). Marks the start of the OEM warranty period. Null if the vehicle has not yet been placed in service.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interiorColorCode rdf:type rdf:Property ;
    rdfs:label 'Interior Color Code' ;
    rdfs:comment 'OEM-assigned interior color/trim code for this vehicle unit (e.g., \'BK\' for Black). Used for inventory matching and customer preference alignment.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interiorColorName rdf:type rdf:Property ;
    rdfs:label 'Interior Color Name' ;
    rdfs:comment 'Human-readable marketing name of the interior color and material (e.g., \'Black Leather\', \'Sandstone Cloth\'). Used for customer-facing display and sales consultation.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryType rdf:type rdf:Property ;
    rdfs:label 'Inventory Type' ;
    rdfs:comment 'Classification of the vehicle unit by its condition and ownership history: \'new\' = new vehicle never titled; \'used\' = previously owned/titled vehicle; \'certified_pre_owned\' = OEM-certified used vehicle meeting specific age/mileage criteria; \'demo\' = dealer demonstration vehicle; \'loaner\' = service loaner vehicle. Governs applicable pricing, warranty, and financing programs.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoicePrice rdf:type rdf:Property ;
    rdfs:label 'Invoice Price' ;
    rdfs:comment 'The OEM invoice price charged to the dealer for this vehicle unit, representing the dealer\'s acquisition cost from the manufacturer before holdback, dealer cash, or other incentives. Confidential commercial pricing data.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPriceUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Price Update Date' ;
    rdfs:comment 'The date on which the asking price for this vehicle unit was most recently updated in the CDK Global DMS. Used to track pricing strategy cadence and ensure market-aligned pricing for aged inventory.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:odometerReading rdf:type rdf:Property ;
    rdfs:label 'Odometer Reading' ;
    rdfs:comment 'Current odometer reading of the vehicle in miles at the time of inventory check-in or last update. Critical for used, demo, and loaner vehicles to determine CPO eligibility, warranty coverage, and pricing. For new vehicles, reflects delivery mileage.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pdiCompleted rdf:type rdf:Property ;
    rdfs:label 'Pdi Completed' ;
    rdfs:comment 'Indicates whether the Pre-Delivery Inspection (PDI) has been completed for this vehicle unit. PDI is a mandatory dealer quality check performed before vehicle delivery to a customer, verifying all systems, fluids, and accessories meet OEM standards. True = PDI completed; False = PDI pending.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pdiCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Pdi Completed Date' ;
    rdfs:comment 'The date on which the Pre-Delivery Inspection (PDI) was completed and signed off by the dealer\'s service technician. Null if PDI has not yet been performed.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallCampaignNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Campaign Number' ;
    rdfs:comment 'The NHTSA-assigned recall campaign number if this vehicle is subject to an active safety recall (e.g., \'23V-123\'). Null if no active recall. Used for recall remedy tracking and regulatory reporting.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallHold rdf:type rdf:Property ;
    rdfs:label 'Recall Hold' ;
    rdfs:comment 'Indicates whether this vehicle unit is subject to an active NHTSA safety recall that prevents retail sale or delivery until the recall remedy has been performed. True = vehicle is on recall hold and cannot be sold; False = no active recall hold. Critical for regulatory compliance and consumer safety.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Indicates how the dealer acquired this vehicle unit: \'factory_order\' = ordered directly from OEM; \'dealer_trade\' = acquired via dealer-to-dealer trade; \'auction\' = purchased at wholesale auction; \'trade_in\' = accepted as customer trade-in; \'fleet_return\' = returned from fleet/rental program; \'lease_return\' = returned at end of lease term.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockNumber rdf:type rdf:Property ;
    rdfs:label 'Stock Number' ;
    rdfs:comment 'Dealer-assigned internal stock number used within the CDK Global DMS to identify and locate this vehicle on the lot. Unique within a dealership but not globally unique.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportStatus rdf:type rdf:Property ;
    rdfs:label 'Transport Status' ;
    rdfs:comment 'Current transportation status for vehicles in the delivery pipeline from OEM plant to dealership: \'not_shipped\' = awaiting dispatch from plant; \'in_transit\' = en route via carrier; \'delivered\' = arrived at dealer; \'rail\' = currently on rail transport; \'truck\' = currently on truck transport.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowStickerUrl rdf:type rdf:Property ;
    rdfs:label 'Window Sticker Url' ;
    rdfs:comment 'URL link to the digital Monroney window sticker (required by the Automobile Information Disclosure Act) for this vehicle unit, hosted by the OEM or a third-party service. Contains MSRP, standard equipment, options, fuel economy ratings, and safety information.' ;
    rdfs:domain ind:DealerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'The actual date the vehicle departed the production plant or port for transit to the dealership. Used to measure logistics performance and update OTD tracking.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationPoolCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Pool Code' ;
    rdfs:comment 'Code identifying the vehicle allocation pool or program from which this order is fulfilled (e.g., regional allocation, fleet pool, dealer stock pool). Governs allocation rules and constraints.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Code identifying the reason for order cancellation (e.g., customer withdrawal, dealer over-allocation, duplicate order). Populated only when order_status is cancelled.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The OEM-confirmed delivery date communicated back to the dealer after production scheduling. May differ from the requested delivery date.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysLate rdf:type rdf:Property ;
    rdfs:label 'Days Late' ;
    rdfs:comment 'Number of calendar days the actual delivery date exceeded the confirmed delivery date. Zero or negative values indicate on-time or early delivery. Used for OTD variance analysis and dealer penalty calculations.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dealerInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Dealer Invoice Amount' ;
    rdfs:comment 'The wholesale invoice price charged by the OEM to the dealer for this vehicle order. Represents the net amount the dealer pays before any holdback or incentive adjustments.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmsOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Dms Order Number' ;
    rdfs:comment 'Order reference number assigned by the CDK Global Dealer Management System at the dealership level. Enables reconciliation between OEM and dealer systems.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedShipDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Ship Date' ;
    rdfs:comment 'The estimated date the vehicle is expected to depart the production plant or port for transit to the dealership. Used for logistics planning and dealer communication.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'Code indicating the reason an order has been placed on hold, such as parts shortage, regulatory hold, credit hold, or customer change request. Null when order is not on hold.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homologationVariant rdf:type rdf:Property ;
    rdfs:label 'Homologation Variant' ;
    rdfs:comment 'The regulatory homologation variant code specifying market-specific compliance configurations (e.g., US-spec, EU-spec, CARB-spec). Ensures the vehicle meets applicable NHTSA, EPA, UNECE, or CARB standards for the destination market.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Incentive Amount' ;
    rdfs:comment 'Total OEM incentive or discount amount applied to this order, including dealer cash, consumer cash, and program incentives. Reduces the effective dealer cost.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msrpAmount rdf:type rdf:Property ;
    rdfs:label 'Msrp Amount' ;
    rdfs:comment 'The Manufacturer Suggested Retail Price (MSRP) for the fully configured vehicle as ordered, in the base currency. Represents the gross base amount before dealer adjustments, incentives, or taxes.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The calendar date on which the dealer submitted the order to the OEM. This is the principal business event date for the order transaction.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderSource rdf:type rdf:Property ;
    rdfs:label 'Order Source' ;
    rdfs:comment 'The channel or system through which the dealer order was submitted to the OEM: dealer portal, CDK Global DMS integration, EDI transmission, manual entry, or API.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otdFlag rdf:type rdf:Property ;
    rdfs:label 'Otd Flag' ;
    rdfs:comment 'Indicates whether the vehicle was delivered on or before the confirmed delivery date. True = delivered on time; False = delivered late. Core metric for OTD performance reporting and dealer satisfaction.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pdiRequired rdf:type rdf:Property ;
    rdfs:label 'Pdi Required' ;
    rdfs:comment 'Indicates whether a Pre-Delivery Inspection (PDI) is required before the vehicle is handed over to the customer. True = PDI mandatory; False = PDI not required.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Priority classification assigned to the order for production scheduling and allocation purposes. Higher priority orders are scheduled earlier in the production sequence.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionPlantCode rdf:type rdf:Property ;
    rdfs:label 'Production Plant Code' ;
    rdfs:comment 'SAP plant code identifying the manufacturing facility assigned to produce the vehicle for this order. Determined during production scheduling.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionWeek rdf:type rdf:Property ;
    rdfs:label 'Production Week' ;
    rdfs:comment 'ISO 8601 production week (e.g., 2025-W23) in which the vehicle is scheduled to be built. Used for production scheduling, capacity planning, and OTD tracking.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSalesOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sales Order Number' ;
    rdfs:comment 'Externally-known SAP SD sales order number assigned by the OEM ERP system upon order confirmation. Used for cross-system traceability between the lakehouse and SAP S/4HANA.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionId rdf:type rdf:Property ;
    rdfs:label 'Region Id' ;
    rdfs:comment 'Unique identifier for the dealer region. Primary key for the dealer region entity.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Region .

ind:allocationQuotaPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Quota Percentage' ;
    rdfs:comment 'Percentage of total OEM production allocated to this region. Sum of all region percentages equals 100%. Used for production planning and dealer inventory distribution.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cityList rdf:type rdf:Property ;
    rdfs:label 'City List' ;
    rdfs:comment 'Comma-separated list of major cities included in this dealer region for reference and marketing purposes.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveIntensityRating rdf:type rdf:Property ;
    rdfs:label 'Competitive Intensity Rating' ;
    rdfs:comment 'Assessment of competitive pressure from other OEMs in this region. Influences incentive programs and marketing investment.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countyRegionList rdf:type rdf:Property ;
    rdfs:label 'County Region List' ;
    rdfs:comment 'Comma-separated list of county or regional administrative divisions included in this dealer region for granular territory definition.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerCount rdf:type rdf:Property ;
    rdfs:label 'Dealer Count' ;
    rdfs:comment 'Total number of active dealerships assigned to this region. Used for capacity planning and regional performance benchmarking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:districtCode rdf:type rdf:Property ;
    rdfs:label 'District Code' ;
    rdfs:comment 'Code identifying the district within the region. Districts are sub-regional organizational units that group dealerships for field management.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:districtName rdf:type rdf:Property ;
    rdfs:label 'District Name' ;
    rdfs:comment 'Full name of the district within the region.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Dms Integration Status' ;
    rdfs:comment 'Status of integration between this region and the CDK Global DMS. Active indicates successful data synchronization; error indicates integration issues requiring attention.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsLastSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dms Last Sync Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful data synchronization between this region and the CDK Global DMS. Used for monitoring integration health.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:geographicBoundaryDescription rdf:type rdf:Property ;
    rdfs:label 'Geographic Boundary Description' ;
    rdfs:comment 'Textual description of the geographic boundaries defining this region (e.g., bordered by Interstate 5 to the west, state line to the east). Used when precise coordinates are not available.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdCountEstimate rdf:type rdf:Property ;
    rdfs:label 'Household Count Estimate' ;
    rdfs:comment 'Estimated number of households within the region. Used for market penetration and vehicle ownership forecasting.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentiveProgramEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Program Eligibility Flag' ;
    rdfs:comment 'Indicates whether dealers in this region are eligible for special OEM incentive programs. True if eligible, false otherwise.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketSegmentClassification rdf:type rdf:Property ;
    rdfs:label 'Market Segment Classification' ;
    rdfs:comment 'Classification of the regions primary market segment based on population density and economic characteristics. Influences product mix and marketing strategy.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationReason rdf:type rdf:Property ;
    rdfs:label 'Modification Reason' ;
    rdfs:comment 'Business justification for the most recent change to this regions configuration (e.g., market consolidation, dealer network expansion, territory realignment).' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceBenchmarkGroup rdf:type rdf:Property ;
    rdfs:label 'Performance Benchmark Group' ;
    rdfs:comment 'Code identifying the peer group used for performance benchmarking. Regions in the same group are compared for scorecard evaluation.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationEstimate rdf:type rdf:Property ;
    rdfs:label 'Population Estimate' ;
    rdfs:comment 'Estimated total population within the geographic boundaries of this region. Used for market sizing and sales potential analysis.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postalCodeRange rdf:type rdf:Property ;
    rdfs:label 'Postal Code Range' ;
    rdfs:comment 'Description of postal code ranges covered by this region (e.g., 90000-93999 for Southern California). Used for territory assignment and customer routing.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionName rdf:type rdf:Property ;
    rdfs:label 'Region Name' ;
    rdfs:comment 'Full business name of the dealer region (e.g., Northeast Region, California Coastal, Mid-Atlantic).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionStatus rdf:type rdf:Property ;
    rdfs:label 'Region Status' ;
    rdfs:comment 'Current lifecycle status of the dealer region. Active regions are operational; inactive regions are temporarily suspended; pending regions are being established; consolidating regions are merging with others; dissolved regions have been permanently closed.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionType rdf:type rdf:Property ;
    rdfs:label 'Region Type' ;
    rdfs:comment 'Classification of the region based on organizational structure: geographic (physical territory), market (customer segment focus), strategic (special initiative), or operational (functional alignment).' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Regional Manager Email' ;
    rdfs:comment 'Primary email address of the regional manager for business communication and escalation.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalManagerName rdf:type rdf:Property ;
    rdfs:label 'Regional Manager Name' ;
    rdfs:comment 'Full name of the regional manager assigned to oversee dealer performance, allocation, and field operations in this region.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalManagerPhone rdf:type rdf:Property ;
    rdfs:label 'Regional Manager Phone' ;
    rdfs:comment 'Primary phone number of the regional manager for dealer support and escalation.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesPotentialIndex rdf:type rdf:Property ;
    rdfs:label 'Sales Potential Index' ;
    rdfs:comment 'Indexed score (0-100) representing the relative sales potential of this region compared to national average. Used for allocation planning and performance benchmarking.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesforceRegionCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Region Code' ;
    rdfs:comment 'External identifier for this region in the Salesforce Automotive Cloud system. Used for cross-system reconciliation and dealer portal integration.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSalesOrgCode rdf:type rdf:Property ;
    rdfs:label 'Sap Sales Org Code' ;
    rdfs:comment 'SAP S/4HANA sales organization code mapped to this dealer region. Used for order processing, billing, and financial reporting integration.' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialProgramNotes rdf:type rdf:Property ;
    rdfs:label 'Special Program Notes' ;
    rdfs:comment 'Free-text notes describing any special programs, initiatives, or considerations applicable to this region (e.g., EV infrastructure pilot, fleet sales focus).' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvinceList rdf:type rdf:Property ;
    rdfs:label 'State Province List' ;
    rdfs:comment 'Comma-separated list of state or province codes covered by this region (e.g., CA,NV,AZ for a Western US region).' ;
    rdfs:domain ind:Region ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleAllocationPriority rdf:type rdf:Property ;
    rdfs:label 'Vehicle Allocation Priority' ;
    rdfs:comment 'Priority ranking (1=highest) for vehicle allocation to this region during supply constraints. Based on market size, strategic importance, and historical performance.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zoneName rdf:type rdf:Property ;
    rdfs:label 'Zone Name' ;
    rdfs:comment 'Full name of the parent zone (e.g., Eastern Zone, Western Zone, Central Zone).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Dealer Territory Id' ;
    rdfs:comment 'Unique identifier for the dealer territory assignment. Primary key.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:franchiseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Id' ;
    rdfs:comment 'Reference to the franchise agreement that governs this territory assignment. Links territory rights to contractual terms.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FranchiseAgreement .

ind:countyRegion rdf:type rdf:Property ;
    rdfs:label 'County Region' ;
    rdfs:comment 'County, district, or regional subdivision name within the state/province that defines part of the territory boundary.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerEmail rdf:type rdf:Property ;
    rdfs:label 'Manager Email' ;
    rdfs:comment 'Email address of the OEM (Original Equipment Manufacturer) territory manager. Used for dealer communications and escalations.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Name of the OEM (Original Equipment Manufacturer) regional or territory manager responsible for overseeing this territory and dealer relationship.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerPhone rdf:type rdf:Property ;
    rdfs:label 'Manager Phone' ;
    rdfs:comment 'Contact phone number for the OEM (Original Equipment Manufacturer) territory manager.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overlapAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Overlap Allowed Flag' ;
    rdfs:comment 'Indicates whether this territory can overlap with other dealer territories. True allows shared coverage; False enforces exclusive boundaries.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overlapRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Overlap Rule Description' ;
    rdfs:comment 'Business rules governing how overlapping territories are managed, including priority rules, customer assignment logic, and conflict resolution procedures.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCodeList rdf:type rdf:Property ;
    rdfs:label 'Postal Code List' ;
    rdfs:comment 'Comma-separated or range-based list of postal/zip codes included in the territory (e.g., \'90001-90099,91000\'). Used for precise geographic allocation.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAreaOfResponsibility rdf:type rdf:Property ;
    rdfs:label 'Primary Area Of Responsibility' ;
    rdfs:comment 'Geographic description of the core territory where the dealer has primary sales and service responsibility. May include city names, county boundaries, or regional descriptors.' ;
    rdfs:domain ind:DealerTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'Two or three-letter code for the state, province, or administrative region (e.g., CA, TX, ON).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the territory within the dealer network. Used for vehicle allocation and market planning.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Business-friendly name or description of the territory (e.g., \'Metro East Region\', \'Downtown District\').' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Status' ;
    rdfs:comment 'Current lifecycle status of the territory assignment. Active territories are operational; pending awaits approval; suspended is temporarily halted; terminated is closed.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of territory assignment model: exclusive (single dealer), shared (multiple dealers), open (no restrictions), primary (main responsibility), secondary (backup coverage), overlay (special program).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeId rdf:type rdf:Property ;
    rdfs:label 'Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: Financial consolidation reports require each dealership to be assigned to a legal company code for statutory reporting; dealers know their company code.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:adasCertified rdf:type rdf:Property ;
    rdfs:label 'Adas Certified' ;
    rdfs:comment 'Indicates whether the dealership is certified to perform Advanced Driver Assistance Systems (ADAS) calibration and repair. Required for servicing vehicles equipped with cameras, radar, and LiDAR-based safety systems.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdkDealerCode rdf:type rdf:Property ;
    rdfs:label 'Cdk Dealer Code' ;
    rdfs:comment 'Unique dealer identifier assigned within the CDK Global Dealer Management System (DMS). This is the integration key used for all data exchanges between the OEM lakehouse and the CDK DMS platform including inventory, F&I, and service scheduling feeds.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelClassification rdf:type rdf:Property ;
    rdfs:label 'Channel Classification' ;
    rdfs:comment 'Categorizes the dealer\'s primary sales channel model. Retail covers traditional showroom sales; fleet covers B2B volume sales; agency model covers OEM-set pricing arrangements; export covers cross-border sales points.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date on which the dealership was deactivated or terminated from the OEM dealer network. Nullable for currently active dealers. Used for franchise termination tracking and regulatory reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealerStatus rdf:type rdf:Property ;
    rdfs:label 'Dealer Status' ;
    rdfs:comment 'Current lifecycle status of the dealership within the OEM franchise network. Controls eligibility for vehicle allocation, incentive programs, and DMS integration. [ENUM-REF-CANDIDATE: active|inactive|suspended|pending_approval|terminated|under_review — promote to reference product]' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsGoLiveDate rdf:type rdf:Property ;
    rdfs:label 'Dms Go Live Date' ;
    rdfs:comment 'Date on which the CDK Global DMS integration for this dealership went live and began transmitting data to the OEM enterprise systems. Used for integration tenure tracking and data completeness assessments.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evChargerCount rdf:type rdf:Property ;
    rdfs:label 'Ev Charger Count' ;
    rdfs:comment 'Number of EV charging stations installed at the dealership for customer and demo vehicle use. Relevant for EV certification compliance and customer experience reporting.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:franchiseAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Number' ;
    rdfs:comment 'Reference number of the active franchise agreement between the OEM and the dealer entity. Used to link the dealership master record to the franchise agreement contract for legal and compliance purposes.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Expiry Date' ;
    rdfs:comment 'Date on which the current franchise agreement is scheduled to expire or must be renewed. Nullable for perpetual agreements. Triggers renewal workflow when within the notice period.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:franchiseStartDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Start Date' ;
    rdfs:comment 'Date on which the current franchise agreement between the OEM and the dealer became effective. Used for tenure calculations, renewal scheduling, and performance baseline setting.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotCapacity rdf:type rdf:Property ;
    rdfs:label 'Lot Capacity' ;
    rdfs:comment 'Maximum number of vehicles that can be stored on the dealer lot (outdoor inventory storage). Used for vehicle allocation limits, inventory aging analysis, and logistics planning.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketRegionCode rdf:type rdf:Property ;
    rdfs:label 'Market Region Code' ;
    rdfs:comment 'OEM-defined market region code to which this dealership belongs (e.g., NORTHEAST, MIDWEST, SOUTHWEST, WEST, SOUTHEAST). Used for territory management, regional incentive programs, and sales performance reporting.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newVehicleSalesCapacity rdf:type rdf:Property ;
    rdfs:label 'New Vehicle Sales Capacity' ;
    rdfs:comment 'OEM-assessed annual new vehicle sales capacity (unit count) for this dealership based on facility size, staffing, and market area. Used as the denominator for allocation planning and sales target setting.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oemBrandCodes rdf:type rdf:Property ;
    rdfs:label 'Oem Brand Codes' ;
    rdfs:comment 'Pipe-delimited list of OEM brand codes (e.g., BRAND_A|BRAND_B) that this dealership is franchised to sell and service. A single dealer point may hold multi-brand authorizations (e.g., passenger car and commercial vehicle brands).' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipGroupName rdf:type rdf:Property ;
    rdfs:label 'Ownership Group Name' ;
    rdfs:comment 'Name of the dealer group or automotive retail group that owns this dealership location (e.g., AutoNation, Penske, Lithia). Enables group-level performance aggregation, consolidated incentive calculations, and multi-point dealer management.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsWarehouseAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Parts Warehouse Area Sqm' ;
    rdfs:comment 'Total floor area in square metres of the dealership\'s parts storage facility. Used for parts inventory capacity planning, MRP replenishment calculations, and Just-in-Time (JIT) parts delivery scheduling.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdiCertified rdf:type rdf:Property ;
    rdfs:label 'Pdi Certified' ;
    rdfs:comment 'Indicates whether the dealership is certified to perform Pre-Delivery Inspection (PDI) on new vehicles prior to customer handover. PDI certification is required for new vehicle delivery authorization.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:principalContactEmail rdf:type rdf:Property ;
    rdfs:label 'Principal Contact Email' ;
    rdfs:comment 'Email address of the primary OEM relationship contact at the dealership. Used for franchise communications, incentive program notifications, and regulatory bulletin distribution.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalContactName rdf:type rdf:Property ;
    rdfs:label 'Principal Contact Name' ;
    rdfs:comment 'Full name of the primary OEM relationship contact at the dealership (typically the Dealer Principal or General Manager). Used for OEM communications, franchise agreement correspondence, and escalation routing.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesDistrictCode rdf:type rdf:Property ;
    rdfs:label 'Sales District Code' ;
    rdfs:comment 'OEM-defined sales district code representing the sub-regional territory assignment for this dealership. Used for district sales manager (DSM) alignment, vehicle allocation quotas, and performance benchmarking.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:showroomDisplayCapacity rdf:type rdf:Property ;
    rdfs:label 'Showroom Display Capacity' ;
    rdfs:comment 'Maximum number of vehicles that can be displayed simultaneously in the dealership showroom. Used for vehicle allocation planning, demo fleet sizing, and facility investment decisions.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradingName rdf:type rdf:Property ;
    rdfs:label 'Trading Name' ;
    rdfs:comment 'The public-facing \'doing business as\' (DBA) name of the dealership as displayed to customers, on signage, and in marketing materials. May differ from the legal entity name.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usedVehicleSalesCapacity rdf:type rdf:Property ;
    rdfs:label 'Used Vehicle Sales Capacity' ;
    rdfs:comment 'OEM-assessed annual used vehicle sales capacity (unit count) for this dealership. Used for certified pre-owned (CPO) program eligibility and used vehicle allocation planning.' ;
    rdfs:domain ind:Dealership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Public-facing website URL for the dealership. Used for digital marketing integration, online inventory syndication, and customer-facing dealer locator services.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demoVehicleId rdf:type rdf:Property ;
    rdfs:label 'Demo Vehicle Id' ;
    rdfs:comment 'Unique identifier for the demo vehicle record. Primary key.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDemoEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Demo Employee Id' ;
    rdfs:comment 'Identifier of the salesperson to whom this demo vehicle is assigned.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accidentCount rdf:type rdf:Property ;
    rdfs:label 'Accident Count' ;
    rdfs:comment 'Number of reported accidents or incidents involving this demo vehicle during the demo period.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedSalespersonName rdf:type rdf:Property ;
    rdfs:label 'Assigned Salesperson Name' ;
    rdfs:comment 'Full name of the salesperson or sales manager assigned to this demo vehicle.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentOdometerKm rdf:type rdf:Property ;
    rdfs:label 'Current Odometer Km' ;
    rdfs:comment 'Most recent odometer reading in kilometers for the demo vehicle.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demoDesignationDate rdf:type rdf:Property ;
    rdfs:label 'Demo Designation Date' ;
    rdfs:comment 'Date when the vehicle was officially designated as a demo unit.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:demoEndDate rdf:type rdf:Property ;
    rdfs:label 'Demo End Date' ;
    rdfs:comment 'Scheduled or actual date when the demo vehicle program period ends or ended.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:demoPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Demo Period Months' ;
    rdfs:comment 'Duration of the demo vehicle program assignment in months.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demoStartDate rdf:type rdf:Property ;
    rdfs:label 'Demo Start Date' ;
    rdfs:comment 'Date when the demo vehicle program period began for this unit.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:demoStatus rdf:type rdf:Property ;
    rdfs:label 'Demo Status' ;
    rdfs:comment 'Current lifecycle status of the demo vehicle program assignment.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demoUsageType rdf:type rdf:Property ;
    rdfs:label 'Demo Usage Type' ;
    rdfs:comment 'Primary usage type for this demo vehicle.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorPlanInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Floor Plan Interest Amount' ;
    rdfs:comment 'Total floor plan interest cost incurred by the dealer for this demo vehicle during the demo period.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mileageOverageKm rdf:type rdf:Property ;
    rdfs:label 'Mileage Overage Km' ;
    rdfs:comment 'Calculated mileage overage in kilometers beyond the allowance, if any.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:odometerAtDesignationKm rdf:type rdf:Property ;
    rdfs:label 'Odometer At Designation Km' ;
    rdfs:comment 'Odometer reading in kilometers when the vehicle was designated as a demo unit.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oemProgramCode rdf:type rdf:Property ;
    rdfs:label 'Oem Program Code' ;
    rdfs:comment 'OEM-assigned program code for the demo vehicle program under which this vehicle is registered.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdiCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Pdi Completed Flag' ;
    rdfs:comment 'Indicates whether Pre-Delivery Inspection was completed for this demo vehicle.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pdiCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Pdi Completion Date' ;
    rdfs:comment 'Date when Pre-Delivery Inspection was completed.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallCampaignNumbers rdf:type rdf:Property ;
    rdfs:label 'Recall Campaign Numbers' ;
    rdfs:comment 'Comma-separated list of recall campaign numbers applicable to this demo vehicle.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salePriceAmount rdf:type rdf:Property ;
    rdfs:label 'Sale Price Amount' ;
    rdfs:comment 'Actual sale price if the demo vehicle was converted to a used vehicle sale.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceRecordCount rdf:type rdf:Property ;
    rdfs:label 'Service Record Count' ;
    rdfs:comment 'Total number of service or maintenance records for this demo vehicle during the demo period.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testDriveCount rdf:type rdf:Property ;
    rdfs:label 'Test Drive Count' ;
    rdfs:comment 'Total number of customer test drives conducted with this demo vehicle.' ;
    rdfs:domain ind:DemoVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dmsIntegrationLogId rdf:type rdf:Property ;
    rdfs:label 'Dms Integration Log Id' ;
    rdfs:comment 'Unique identifier for each DMS integration event log entry. Primary key for the integration log table.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Authentication Method' ;
    rdfs:comment 'Authentication mechanism used to verify dealer DMS identity and authorize data access during synchronization.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessImpactSeverity rdf:type rdf:Property ;
    rdfs:label 'Business Impact Severity' ;
    rdfs:comment 'Assessment of business impact severity if this sync event failed. Critical failures affect customer-facing operations; low impact affects reporting only.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Compression Enabled Flag' ;
    rdfs:comment 'Indicates whether data compression was enabled for this synchronization event to optimize bandwidth usage.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataFreshnessLagMinutes rdf:type rdf:Property ;
    rdfs:label 'Data Freshness Lag Minutes' ;
    rdfs:comment 'Time difference in minutes between when data was last updated in the OEM system and when it was synchronized to the dealer DMS. Key metric for monitoring data currency.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dealerName rdf:type rdf:Property ;
    rdfs:label 'Dealer Name' ;
    rdfs:comment 'Legal business name of the dealership. Denormalized for reporting convenience and to support historical tracking if dealer names change.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Dms Endpoint Url' ;
    rdfs:comment 'The specific CDK Global DMS API endpoint URL used for this synchronization event. Identifies the dealer system instance and integration point.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Dms Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier generated by the CDK Global DMS for this sync event. Used for end-to-end traceability and support escalation.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsVersion rdf:type rdf:Property ;
    rdfs:label 'Dms Version' ;
    rdfs:comment 'Version number of the CDK Global DMS software running at the dealership. Used to track compatibility and feature availability.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionProtocol rdf:type rdf:Property ;
    rdfs:label 'Encryption Protocol' ;
    rdfs:comment 'Security protocol used to encrypt data during transmission between OEM platform and dealer DMS. Ensures data confidentiality and integrity.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCategory rdf:type rdf:Property ;
    rdfs:label 'Error Category' ;
    rdfs:comment 'Classification of the error type encountered during synchronization. Used for root cause analysis and troubleshooting dealer connectivity issues.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Detailed error message or description returned by the DMS or integration middleware. Provides technical details for troubleshooting failed sync events.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Indicates whether this failed sync event requires escalation to dealer support or OEM integration team for manual intervention.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when this sync failure was escalated to support teams. Null if no escalation occurred or sync succeeded.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:integrationBatchReference rdf:type rdf:Property ;
    rdfs:label 'Integration Batch Reference' ;
    rdfs:comment 'Unique batch identifier assigned to group related synchronization events. Used to correlate multiple sync operations within a single integration cycle.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxRetryAttempts rdf:type rdf:Property ;
    rdfs:label 'Max Retry Attempts' ;
    rdfs:comment 'Maximum number of retry attempts configured for this sync event type before escalation or manual intervention is required.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextRetryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Retry Timestamp' ;
    rdfs:comment 'Scheduled date and time for the next automatic retry attempt if the current sync failed. Null if no retry is scheduled or sync succeeded.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:oemTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Oem Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier generated by the OEM integration platform for this sync event. Used for internal traceability and audit.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payloadSizeKb rdf:type rdf:Property ;
    rdfs:label 'Payload Size Kb' ;
    rdfs:comment 'Size of the data payload transmitted during this sync event measured in kilobytes. Used to monitor bandwidth utilization and identify large transfers.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordCountFailed rdf:type rdf:Property ;
    rdfs:label 'Record Count Failed' ;
    rdfs:comment 'Number of records that failed to synchronize due to validation errors, connectivity issues, or data quality problems.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordCountReceived rdf:type rdf:Property ;
    rdfs:label 'Record Count Received' ;
    rdfs:comment 'Total number of records successfully received and acknowledged by the dealer DMS. Used to validate completeness of data transfer.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordCountSent rdf:type rdf:Property ;
    rdfs:label 'Record Count Sent' ;
    rdfs:comment 'Total number of records transmitted from the OEM platform to the dealer DMS during this sync event. Applicable for push operations.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when a failed sync event was resolved and data synchronization completed successfully. Used to calculate mean time to resolution.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retryAttemptNumber rdf:type rdf:Property ;
    rdfs:label 'Retry Attempt Number' ;
    rdfs:comment 'Sequential number indicating which retry attempt this represents for a failed synchronization. Zero indicates the initial attempt.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Indicates whether this synchronization event met the defined SLA target for duration and success rate. Used for dealer performance scorecards.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Target Duration Seconds' ;
    rdfs:comment 'Target synchronization duration in seconds as defined in the dealer integration SLA. Used to measure performance against contractual commitments.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:syncDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Sync Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from sync initiation to completion or failure. Used to monitor DMS performance and identify slow connections.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:syncEventType rdf:type rdf:Property ;
    rdfs:label 'Sync Event Type' ;
    rdfs:comment 'Type of data synchronization event between OEM platform and CDK Global DMS. Indicates the direction and nature of data flow (push from OEM or pull from dealer).' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syncStatus rdf:type rdf:Property ;
    rdfs:label 'Sync Status' ;
    rdfs:comment 'Current status of the synchronization event indicating whether data transfer completed successfully, partially succeeded, or failed.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sync Timestamp' ;
    rdfs:comment 'Date and time when the synchronization event was initiated. This is the principal business event timestamp for the integration log entry.' ;
    rdfs:domain ind:DmsIntegrationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:facilityStandardId rdf:type rdf:Property ;
    rdfs:label 'Facility Standard Id' ;
    rdfs:comment 'Unique identifier for the facility standard compliance record. Primary key for this entity.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assessor Employee Id' ;
    rdfs:comment 'Employee identifier for the OEM assessor. Links to HR system for auditor qualification tracking.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocationEligibilityImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Allocation Eligibility Impact Flag' ;
    rdfs:comment 'Indicates whether non-compliance with this facility standard affects the dealer\'s vehicle allocation eligibility. True = may reduce allocation, False = no allocation impact.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'Date when the facility standards assessment was conducted. Primary business event timestamp for this compliance record.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'Methodology used to conduct the facility standards assessment. On_site = physical inspection, remote = video/virtual tour, hybrid = combination, photographic_evidence = dealer-submitted photos reviewed by OEM, self_assessment = dealer self-evaluation with OEM verification.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Business identifier for the facility standards assessment. Unique reference number used in communications and reporting.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReportUrl rdf:type rdf:Property ;
    rdfs:label 'Assessment Report Url' ;
    rdfs:comment 'Link to the detailed facility standards assessment report document stored in the document management system. Contains photos, detailed findings, and recommendations.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Purpose and context of the facility standards assessment. Initial = new dealer onboarding, annual = scheduled yearly review, renewal = franchise renewal evaluation, spot_check = unscheduled compliance verification, post_remediation = follow-up after deficiency correction, franchise_application = pre-approval assessment.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Assessor Certification Number' ;
    rdfs:comment 'Professional certification number of the assessor, demonstrating qualification to conduct facility standards audits.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Full name of the OEM representative or third-party auditor who conducted the facility standards assessment.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDeficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Critical Deficiency Count' ;
    rdfs:comment 'Number of critical deficiencies identified. Critical deficiencies are those that pose safety risks, violate regulatory requirements, or severely impact brand image.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dealerResponseNotes rdf:type rdf:Property ;
    rdfs:label 'Dealer Response Notes' ;
    rdfs:comment 'Dealer\'s formal response to the assessment findings, including planned remediation actions, timelines, and any disputes or clarifications.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Deficiency Count' ;
    rdfs:comment 'Total number of deficiency items identified during the assessment. Includes all severity levels (critical, major, minor).' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deficiencyDescription rdf:type rdf:Property ;
    rdfs:label 'Deficiency Description' ;
    rdfs:comment 'Detailed narrative description of all deficiency items identified during the assessment. Includes specific observations, locations, and non-compliance details.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Investment Amount' ;
    rdfs:comment 'Estimated cost for the dealer to achieve full compliance with this facility standard. Used for facility investment planning and franchise renewal negotiations.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:franchiseRenewalImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Franchise Renewal Impact Flag' ;
    rdfs:comment 'Indicates whether this facility standard assessment result will be considered in the next franchise renewal decision. True = impacts renewal, False = informational only.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incentiveEligibilityImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Eligibility Impact Flag' ;
    rdfs:comment 'Indicates whether non-compliance with this facility standard affects the dealer\'s eligibility for OEM incentive programs. True = may disqualify from incentives, False = no incentive impact.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:majorDeficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Major Deficiency Count' ;
    rdfs:comment 'Number of major deficiencies identified. Major deficiencies significantly impact customer experience or operational efficiency but are not safety-critical.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorDeficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Minor Deficiency Count' ;
    rdfs:comment 'Number of minor deficiencies identified. Minor deficiencies are cosmetic or procedural issues with minimal business impact.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due Date' ;
    rdfs:comment 'Scheduled date for the next facility standards assessment. Frequency determined by standard type, compliance history, and franchise agreement terms.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oemReviewerNotes rdf:type rdf:Property ;
    rdfs:label 'Oem Reviewer Notes' ;
    rdfs:comment 'Internal OEM notes regarding the assessment, remediation progress, or special considerations. Used for franchise management and dealer relationship tracking.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingThresholdScore rdf:type rdf:Property ;
    rdfs:label 'Passing Threshold Score' ;
    rdfs:comment 'Minimum compliance score required to achieve compliant status for this standard type. Threshold may vary by standard category and dealer tier.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:photographicEvidenceUrl rdf:type rdf:Property ;
    rdfs:label 'Photographic Evidence Url' ;
    rdfs:comment 'Link to photographic documentation of facility conditions at time of assessment. Used for compliance verification and historical tracking.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completion Date' ;
    rdfs:comment 'Date when all required corrective actions were completed by the dealer. Verified through post-remediation assessment or photographic evidence.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationDeadline rdf:type rdf:Property ;
    rdfs:label 'Remediation Deadline' ;
    rdfs:comment 'Date by which all identified deficiencies must be corrected. Failure to meet this deadline may result in franchise penalties or suspension.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Remediation Required Flag' ;
    rdfs:comment 'Indicates whether corrective action is required to address identified deficiencies. True = remediation mandatory, False = no action required or waived.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current state of corrective action for identified deficiencies. Tracks progress from identification through verification of completion.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Verification Date' ;
    rdfs:comment 'Date when OEM verified that remediation actions were completed satisfactorily. May involve on-site re-inspection or remote verification.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standardCategory rdf:type rdf:Property ;
    rdfs:label 'Standard Category' ;
    rdfs:comment 'High-level grouping of the facility standard type for reporting and analysis purposes.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardType rdf:type rdf:Property ;
    rdfs:label 'Standard Type' ;
    rdfs:comment 'Category of facility standard being assessed. CI = Corporate Identity (brand visual standards), signage (exterior/interior signage compliance), showroom (sales floor layout and presentation), service_drive (service reception area standards), ev_charging (Electric Vehicle charging infrastructure), parts_department (parts storage and display), body_shop (collision repair facility standards), customer_lounge (waiting area amenities), digital_experience (digital tools and kiosks). [ENUM-REF-CANDIDATE: CI|signage|showroom|service_drive|ev_charging|parts_department|body_shop|customer_lounge|digital_experience — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiry Date' ;
    rdfs:comment 'Date when the granted waiver expires and full compliance is required. Null indicates permanent waiver.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted Flag' ;
    rdfs:comment 'Indicates whether the OEM granted a waiver or exemption for this facility standard. True = waiver approved, False = no waiver.' ;
    rdfs:domain ind:FacilityStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:floorPlanId rdf:type rdf:Property ;
    rdfs:label 'Floor Plan Id' ;
    rdfs:comment 'Unique identifier for the floor plan financing record.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agedInventoryFlag rdf:type rdf:Property ;
    rdfs:label 'Aged Inventory Flag' ;
    rdfs:comment 'Boolean indicator flagging vehicles that have exceeded the aging threshold defined in the floor plan agreement (typically 90, 120, or 180 days). True indicates aged inventory requiring attention.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agingThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Aging Threshold Days' ;
    rdfs:comment 'Number of days after which inventory is considered aged per the floor plan agreement terms. Triggers curtailment requirements or OEM assistance programs.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Result status of the most recent floor plan audit. Passed indicates compliance; failed indicates discrepancies; pending indicates audit in progress; not_required indicates no audit needed; exception indicates special circumstances.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLineAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Line Amount' ;
    rdfs:comment 'Total credit line amount approved by the financing institution for the dealer\'s floor plan facility. Represents the maximum borrowing capacity.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:curtailmentAmount rdf:type rdf:Property ;
    rdfs:label 'Curtailment Amount' ;
    rdfs:comment 'Required curtailment payment amount for aged inventory, typically a percentage of the original financed amount after a specified aging period (e.g., 90 or 120 days).' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:curtailmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Curtailment Due Date' ;
    rdfs:comment 'Scheduled date by which the dealer must make a curtailment payment (partial paydown) on aged inventory per the floor plan agreement terms.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:curtailmentPaidFlag rdf:type rdf:Property ;
    rdfs:label 'Curtailment Paid Flag' ;
    rdfs:comment 'Boolean indicator of whether the required curtailment payment has been made by the dealer. True indicates paid; False indicates outstanding.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dailyInterestAmount rdf:type rdf:Property ;
    rdfs:label 'Daily Interest Amount' ;
    rdfs:comment 'Daily interest accrual amount calculated based on the outstanding balance and interest rate. Used for dealer financial health monitoring.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysInInventory rdf:type rdf:Property ;
    rdfs:label 'Days In Inventory' ;
    rdfs:comment 'Number of days the vehicle has been in dealer inventory under floor plan financing, calculated from financing start date to current date or sale date.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defaultDate rdf:type rdf:Property ;
    rdfs:label 'Default Date' ;
    rdfs:comment 'Date when the dealer was declared in default on floor plan obligations for this vehicle. Null if no default has occurred.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:defaultFlag rdf:type rdf:Property ;
    rdfs:label 'Default Flag' ;
    rdfs:comment 'Boolean indicator of whether the dealer has defaulted on floor plan payments for this vehicle. True indicates default; False indicates current status.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dmsFloorPlanReference rdf:type rdf:Property ;
    rdfs:label 'Dms Floor Plan Reference' ;
    rdfs:comment 'External identifier for this floor plan record in the dealer\'s DMS (e.g., CDK Global). Used for system integration and reconciliation.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financingEndDate rdf:type rdf:Property ;
    rdfs:label 'Financing End Date' ;
    rdfs:comment 'Date when floor plan financing for this vehicle unit was terminated, either through retail sale and payoff or other resolution.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financingInstitutionCode rdf:type rdf:Property ;
    rdfs:label 'Financing Institution Code' ;
    rdfs:comment 'Internal or industry-standard code identifying the financing institution for system integration and reporting.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financingInstitutionName rdf:type rdf:Property ;
    rdfs:label 'Financing Institution Name' ;
    rdfs:comment 'Name of the financial institution or captive finance company providing the floor plan credit line (e.g., OEM captive finance, third-party lender).' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financingStartDate rdf:type rdf:Property ;
    rdfs:label 'Financing Start Date' ;
    rdfs:comment 'Date when floor plan financing for this vehicle unit commenced. Typically the date the vehicle was received into dealer inventory and financed.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:floorPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Floor Plan Status' ;
    rdfs:comment 'Current lifecycle status of the floor plan financing record. Active indicates ongoing financing; paid_off indicates vehicle sold and financing settled; defaulted indicates payment failure; suspended indicates temporary hold; pending_audit indicates under review; curtailed indicates partial paydown required.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRatePct rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Pct' ;
    rdfs:comment 'Annual interest rate percentage charged by the financing institution on the outstanding floor plan balance for this vehicle.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'Scheduled date for the next floor plan audit. Used for audit planning and dealer notification.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oemAssistanceAmount rdf:type rdf:Property ;
    rdfs:label 'Oem Assistance Amount' ;
    rdfs:comment 'Dollar amount of OEM assistance provided for this floor plan record, such as interest rate buy-down or direct payment subsidy.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oemAssistanceProgramCode rdf:type rdf:Property ;
    rdfs:label 'Oem Assistance Program Code' ;
    rdfs:comment 'Code identifying any OEM floor plan assistance program applied to this vehicle (e.g., interest subsidy, extended aging allowance, special financing terms for slow-moving models).' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance Amount' ;
    rdfs:comment 'Current outstanding principal balance owed to the financing institution for this specific vehicle unit. Updated upon curtailment payments and final payoff.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payoffAmount rdf:type rdf:Property ;
    rdfs:label 'Payoff Amount' ;
    rdfs:comment 'Total amount paid to the financing institution to settle the floor plan obligation for this vehicle, including principal and accrued interest.' ;
    rdfs:domain ind:Dealer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payoffDate rdf:type rdf:Property ;
    rdfs:label 'Payoff Date' ;
    rdfs:comment 'Date when the floor plan financing for this vehicle was fully paid off, typically upon retail sale or dealer buyout.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:perUnitFloorPlanCost rdf:type rdf:Property ;
    rdfs:label 'Per Unit Floor Plan Cost' ;
    rdfs:comment 'The financed amount for this individual vehicle unit, typically equal to dealer invoice or a percentage thereof. Basis for interest calculation.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInterestPaid rdf:type rdf:Property ;
    rdfs:label 'Total Interest Paid' ;
    rdfs:comment 'Cumulative interest amount paid to the financing institution over the life of the floor plan financing for this vehicle unit.' ;
    rdfs:domain ind:FloorPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Agreement Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all financial terms in the franchise agreement (quotas, fees, investment requirements). Example: USD, EUR, JPY.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Agreement Document Url' ;
    rdfs:comment 'Secure URL or file path to the digitally stored franchise agreement contract document (PDF or scanned image).' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Human-readable name or title of the franchise agreement, typically including dealer name and location.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPriorityTier rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority Tier' ;
    rdfs:comment 'Priority tier for vehicle inventory allocation. Higher tiers receive preferential allocation of high-demand models and limited-production vehicles. Tier 1 = highest priority.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedNameplates rdf:type rdf:Property ;
    rdfs:label 'Authorized Nameplates' ;
    rdfs:comment 'Comma-separated list of vehicle nameplates (brands, model lines) that the dealer is authorized to sell under this franchise agreement. Examples: Sedan, SUV, Truck, EV (Electric Vehicle), HEV (Hybrid Electric Vehicle).' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the franchise agreement automatically renews at expiration unless either party provides notice. True = auto-renews, False = requires explicit renewal.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certifiedPreOwnedAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Certified Pre Owned Authorized Flag' ;
    rdfs:comment 'Indicates whether the dealer is authorized to sell OEM-certified pre-owned vehicles under the manufacturer\'s CPO program. True = authorized, False = not authorized.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commercialFleetAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Commercial Fleet Authorized Flag' ;
    rdfs:comment 'Indicates whether the dealer is authorized to sell vehicles to commercial fleet customers and participate in fleet sales programs. True = authorized, False = not authorized.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSatisfactionTargetScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Target Score' ;
    rdfs:comment 'Minimum Net Promoter Score (NPS) or customer satisfaction score the dealer must achieve to maintain franchise agreement in good standing. Typically measured on a scale of 0-100.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealerSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Dealer Signatory Name' ;
    rdfs:comment 'Full name of the dealer authorized representative (typically dealer principal or owner) who signed the franchise agreement.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalRetailingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Retailing Required Flag' ;
    rdfs:comment 'Indicates whether the dealer must offer digital retailing capabilities (online sales, virtual showroom, e-commerce) as required by the franchise agreement. True = required, False = optional.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dmsIntegrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dms Integration Required Flag' ;
    rdfs:comment 'Indicates whether the dealer must integrate their DMS (Dealer Management System) with OEM systems for real-time inventory, sales, and service data sharing. True = required, False = optional.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evChargingInfrastructureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ev Charging Infrastructure Required Flag' ;
    rdfs:comment 'Indicates whether the dealer must install and maintain EV (Electric Vehicle) charging infrastructure at their facility as a condition of selling electric or hybrid vehicles. True = required, False = optional.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusiveTerritoryFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusive Territory Flag' ;
    rdfs:comment 'Indicates whether the dealer has exclusive rights to sell in the assigned territory. True = exclusive (no other dealers in territory), False = non-exclusive (shared territory).' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityInvestmentRequirementAmount rdf:type rdf:Property ;
    rdfs:label 'Facility Investment Requirement Amount' ;
    rdfs:comment 'Minimum capital expenditure (CapEx) the dealer must invest in facility improvements, showroom standards, service equipment, and infrastructure to meet OEM brand standards.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:franchiseTier rdf:type rdf:Property ;
    rdfs:label 'Franchise Tier' ;
    rdfs:comment 'Tier or level of the franchise agreement indicating dealer status, privileges, and performance expectations. Higher tiers typically receive preferential allocation and incentives.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction and governing law that applies to the franchise agreement, typically the state or country where the dealer operates or where the OEM is headquartered.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumSalesQuotaAnnual rdf:type rdf:Property ;
    rdfs:label 'Minimum Sales Quota Annual' ;
    rdfs:comment 'Minimum number of vehicle units the dealer must sell annually to maintain franchise agreement in good standing. Performance obligation defined in agreement.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumServiceCapacity rdf:type rdf:Property ;
    rdfs:label 'Minimum Service Capacity' ;
    rdfs:comment 'Minimum number of vehicles the dealer must be capable of servicing per month to meet franchise agreement service obligations.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate or not renew the franchise agreement. Typical values are 30, 60, 90, or 180 days.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oemSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Oem Signatory Name' ;
    rdfs:comment 'Full name of the OEM authorized representative who signed the franchise agreement on behalf of the manufacturer.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipModel rdf:type rdf:Property ;
    rdfs:label 'Ownership Model' ;
    rdfs:comment 'Classification of dealer ownership structure: OEM (Original Equipment Manufacturer) owned, independent franchise, joint venture, or corporate store.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsInventoryRequirementAmount rdf:type rdf:Property ;
    rdfs:label 'Parts Inventory Requirement Amount' ;
    rdfs:comment 'Minimum dollar value of OEM (Original Equipment Manufacturer) parts inventory the dealer must maintain at all times to meet franchise agreement obligations.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Performance Review Frequency' ;
    rdfs:comment 'Frequency at which the OEM conducts formal performance reviews of the dealer against franchise agreement obligations and performance metrics.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallServiceAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Service Authorized Flag' ;
    rdfs:comment 'Indicates whether the dealer is authorized to perform recall repairs and service campaigns issued by the OEM or NHTSA (National Highway Traffic Safety Administration). True = authorized, False = not authorized.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Duration in months for each renewal period of the franchise agreement. Typical values are 12, 24, 36, or 60 months.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date when the franchise agreement was formally signed by both the dealer and OEM authorized representatives, making it legally binding.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:territoryDescription rdf:type rdf:Property ;
    rdfs:label 'Territory Description' ;
    rdfs:comment 'Textual description of the geographic territory assigned to the dealer under this franchise agreement, including cities, counties, postal codes, or radius from dealer location.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryRadiusKm rdf:type rdf:Property ;
    rdfs:label 'Territory Radius Km' ;
    rdfs:comment 'Radius in kilometers from the dealer\'s primary location defining the franchise territory boundary, if territory is defined by radius rather than geographic boundaries.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Certification Required Flag' ;
    rdfs:comment 'Indicates whether dealer staff must complete OEM-mandated training and certification programs as a condition of the franchise agreement. True = required, False = optional.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyAdministrationAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Administration Authorized Flag' ;
    rdfs:comment 'Indicates whether the dealer is authorized to process and submit warranty claims on behalf of customers under OEM warranty programs. True = authorized, False = not authorized.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dealerIncentiveClaimId rdf:type rdf:Property ;
    rdfs:label 'Dealer Incentive Claim Id' ;
    rdfs:comment 'Unique system-generated identifier for each dealer incentive claim record. Primary key for the incentive_claim data product.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Employee Id' ;
    rdfs:comment 'Employee identifier of the OEM staff member who reviewed and approved or rejected the claim. Supports audit trail, segregation of duties compliance, and workload reporting for the dealer incentive operations team.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accrualPosted rdf:type rdf:Property ;
    rdfs:label 'Accrual Posted' ;
    rdfs:comment 'Indicates whether a financial accrual has been posted in SAP FI for this incentive claim liability. True = accrual posted; False = accrual not yet posted. Used for period-end financial close management and EBITDA reporting accuracy.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Reason code explaining why the approved_amount differs from the claimed_amount. Populated by the OEM reviewer when an adjustment is applied. [ENUM-REF-CANDIDATE: ineligible_units|duplicate_claim|missing_evidence|calculation_error|program_cap_exceeded|other — promote to reference product]' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedUnits rdf:type rdf:Property ;
    rdfs:label 'Approved Units' ;
    rdfs:comment 'Number of vehicle units or qualifying transactions validated and approved by the OEM reviewer. May be less than claimed_units if some units are found ineligible during audit. Used to calculate the approved_amount for volume-based programs.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Claim Period End Date' ;
    rdfs:comment 'End date of the performance or sales period covered by this incentive claim. Defines the close of the measurement window. Together with claim_period_start_date, establishes the claim period boundary for audit and reconciliation.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Claim Period Start Date' ;
    rdfs:comment 'Start date of the performance or sales period covered by this incentive claim. Defines the beginning of the measurement window for which the dealer is claiming the incentive.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimedAmount rdf:type rdf:Property ;
    rdfs:label 'Claimed Amount' ;
    rdfs:comment 'Gross monetary amount claimed by the dealer against the incentive program, expressed in the transaction currency. This is the dealer-submitted figure prior to OEM review and approval. Used for financial accrual and liability estimation.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimedMetricUnit rdf:type rdf:Property ;
    rdfs:label 'Claimed Metric Unit' ;
    rdfs:comment 'Unit of measure for the claimed_metric_value field, indicating how the performance metric is expressed (e.g., units for vehicle count, percentage for service absorption rate, score for NPS/CSI, amount for revenue-based claims).' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimedMetricValue rdf:type rdf:Property ;
    rdfs:label 'Claimed Metric Value' ;
    rdfs:comment 'The quantitative performance metric value being claimed by the dealer, applicable for non-unit-based programs such as customer satisfaction scores (NPS), service absorption rates, or parts sales amounts. Complements claimed_units for metric-driven incentive types.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimedUnits rdf:type rdf:Property ;
    rdfs:label 'Claimed Units' ;
    rdfs:comment 'Number of vehicle units or qualifying transactions the dealer is claiming against the incentive program for the claim period. Applicable for volume-based incentive programs such as volume bonus and retail incentive programs.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'SAP CO cost center code to which the incentive payout is charged. Used for internal cost allocation and management accounting of dealer incentive expenditure by brand, region, or program type.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Dealer Contact Email' ;
    rdfs:comment 'Email address of the dealer representative responsible for this claim. Used for claim status notifications, evidence requests, and dispute correspondence. Classified as confidential PII per GDPR and applicable privacy regulations.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerContactName rdf:type rdf:Property ;
    rdfs:label 'Dealer Contact Name' ;
    rdfs:comment 'Name of the dealer-side representative who submitted or is responsible for this incentive claim. Used for communication, follow-up, and audit correspondence between OEM and dealer.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Notes' ;
    rdfs:comment 'Free-text notes documenting the outcome and resolution of a dealer dispute on this claim. Captures the agreed resolution, any revised approved amount, and the basis for the final decision. Supports audit trail and dealer relationship management.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsClaimReference rdf:type rdf:Property ;
    rdfs:label 'Dms Claim Reference' ;
    rdfs:comment 'Claim reference number as recorded in the dealer\'s CDK Global DMS system. Enables cross-system reconciliation between the OEM\'s incentive claim record and the dealer\'s own DMS records. Critical for audit and dispute resolution.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Ref' ;
    rdfs:comment 'Reference identifier or URL pointing to the supporting evidence package submitted by the dealer with the claim (e.g., sales invoices, PDI records, customer satisfaction survey results, parts purchase orders). Stored in the document management system linked from CDK Global DMS or Salesforce Automotive Cloud.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceVerified rdf:type rdf:Property ;
    rdfs:label 'Evidence Verified' ;
    rdfs:comment 'Indicates whether the OEM reviewer has verified the supporting evidence submitted with the claim. True = evidence reviewed and confirmed valid; False = evidence not yet verified or found insufficient. Used to gate claim approval workflow.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'SAP FI payment document number or bank transfer reference assigned when the approved claim is paid. Links the incentive claim to the corresponding financial transaction in SAP FI Accounts Payable for reconciliation and audit.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programQuarter rdf:type rdf:Property ;
    rdfs:label 'Program Quarter' ;
    rdfs:comment 'Fiscal quarter of the OEM incentive program period covered by this claim (Q1–Q4). Used for quarterly accrual reporting, dealer performance benchmarking, and incentive budget variance analysis.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programYear rdf:type rdf:Property ;
    rdfs:label 'Program Year' ;
    rdfs:comment 'Fiscal or calendar year of the OEM incentive program under which this claim is filed. Used to segregate claims by annual program cycle for budget tracking, accrual management, and year-end financial close in SAP FI.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date on which the OEM completed the review of the incentive claim and updated the claim_status to approved or rejected. Used for SLA tracking of claim processing turnaround time.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleLineCode rdf:type rdf:Property ;
    rdfs:label 'Vehicle Line Code' ;
    rdfs:comment 'OEM product line or nameplate code identifying the vehicle model family associated with this claim (e.g., F-150, Silverado, Model 3). Used to segment incentive claims by vehicle line for program performance analysis and brand-level reporting.' ;
    rdfs:domain ind:DealerIncentiveClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:announcementDate rdf:type rdf:Property ;
    rdfs:label 'Announcement Date' ;
    rdfs:comment 'Date on which the incentive program was formally announced to the dealer network via the dealer portal or official OEM communications. Precedes effective_start_date to allow dealer preparation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealerTierEligibility rdf:type rdf:Property ;
    rdfs:label 'Dealer Tier Eligibility' ;
    rdfs:comment 'Specifies which dealer performance tier classification is eligible to participate in this program. Platinum/Gold/Silver/Bronze tiers are OEM-assigned based on prior-year sales volume and CSI scores. \'All\' indicates no tier restriction.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerTypeEligibility rdf:type rdf:Property ;
    rdfs:label 'Dealer Type Eligibility' ;
    rdfs:comment 'Restricts program participation to specific dealer ownership models: franchise dealers, OEM-owned stores, or independent dealers. \'All\' applies to both OEM-owned and independent franchise dealer models.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsProgramReference rdf:type rdf:Property ;
    rdfs:label 'Dms Program Reference' ;
    rdfs:comment 'The corresponding program identifier as recorded in CDK Global DMS used by dealer locations. Enables reconciliation between OEM master incentive records and dealer-side DMS reporting.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleDealerCount rdf:type rdf:Property ;
    rdfs:label 'Eligible Dealer Count' ;
    rdfs:comment 'Number of dealer locations determined to be eligible for participation in this incentive program at the time of program launch. Used for budget planning and program reach analysis by OEM sales operations.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibleNameplates rdf:type rdf:Property ;
    rdfs:label 'Eligible Nameplates' ;
    rdfs:comment 'Pipe-delimited list of vehicle nameplates (brand/model lines) eligible for this incentive program (e.g., \'F-150|Mustang Mach-E|Explorer\'). Null if program applies to all nameplates. Managed in Salesforce Automotive Cloud vehicle catalog.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligiblePowertrainTypes rdf:type rdf:Property ;
    rdfs:label 'Eligible Powertrain Types' ;
    rdfs:comment 'Powertrain technology types eligible for this program. ICE (Internal Combustion Engine), EV (Electric Vehicle), HEV (Hybrid Electric Vehicle), PHEV (Plug-in Hybrid Electric Vehicle), or all. Critical for EV adoption incentive programs aligned with CAFE and EPA compliance targets.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorPlanRatePct rdf:type rdf:Property ;
    rdfs:label 'Floor Plan Rate Pct' ;
    rdfs:comment 'For floor plan assistance programs, the percentage of dealer inventory financing cost subsidized by the OEM. Expressed as an annual percentage rate (APR) subsidy. Null for non-floor-plan program types.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxPayoutAmount rdf:type rdf:Property ;
    rdfs:label 'Max Payout Amount' ;
    rdfs:comment 'The maximum total monetary payout a single dealer can earn under this incentive program during the measurement period. Acts as a cap to control OEM financial exposure. Null if no cap is defined.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPeriodType rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Type' ;
    rdfs:comment 'Defines the cadence over which dealer performance is measured for incentive qualification. Monthly and quarterly are most common for volume bonuses; annual for loyalty programs; custom for special campaigns.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minDealerTenureMonths rdf:type rdf:Property ;
    rdfs:label 'Min Dealer Tenure Months' ;
    rdfs:comment 'Minimum number of months a dealer must have been an active franchisee to be eligible for this program. Ensures new dealers meet a baseline operational maturity requirement.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oemProgramSponsor rdf:type rdf:Property ;
    rdfs:label 'Oem Program Sponsor' ;
    rdfs:comment 'Name or organizational unit of the OEM department sponsoring and funding this incentive program (e.g., \'North America Sales Operations\', \'EV Business Unit\', \'Truck Division\'). Used for internal cost allocation.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payoutDate rdf:type rdf:Property ;
    rdfs:label 'Payout Date' ;
    rdfs:comment 'Scheduled calendar date on which OEM processes and disburses earned incentive payments to qualifying dealers. May differ from effective_end_date due to reconciliation periods.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payoutStructureType rdf:type rdf:Property ;
    rdfs:label 'Payout Structure Type' ;
    rdfs:comment 'Defines how the incentive payout is calculated. Flat bonus: fixed dollar amount per tier. Per unit: dollar amount multiplied by units sold. Percentage of MSRP (Manufacturer Suggested Retail Price): payout as a percentage of vehicle MSRP. Percentage of invoice: payout as a percentage of dealer invoice price.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMetric rdf:type rdf:Property ;
    rdfs:label 'Performance Metric' ;
    rdfs:comment 'The primary KPI used to measure dealer performance for this incentive program. Units sold for volume bonuses; NPS (Net Promoter Score) or CSAT score for satisfaction bonuses; EV units sold for EV adoption programs; PDI (Pre-Delivery Inspection) compliance rate for quality programs. [ENUM-REF-CANDIDATE: units_sold|nps_score|csat_score|ev_units_sold|market_share_pct|pdi_compliance_rate|revenue|floor_plan_days — promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Detailed narrative description of the program objectives, eligibility rules, and payout mechanics as communicated to the dealer network. Sourced from OEM regional sales operations documentation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programManagerName rdf:type rdf:Property ;
    rdfs:label 'Program Manager Name' ;
    rdfs:comment 'Full name of the OEM regional sales operations manager responsible for administering this incentive program. Used for dealer escalation and program governance.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the incentive program structure. Volume bonus rewards unit sales thresholds; stair-step provides escalating payouts per tier; CSAT bonus rewards customer satisfaction scores; EV adoption incentivizes electric vehicle sales; floor plan assistance subsidizes dealer inventory financing costs; market representation rewards geographic coverage. [ENUM-REF-CANDIDATE: volume_bonus|stair_step|csat_bonus|ev_adoption|floor_plan_assistance|market_representation|loyalty_retention|conquest — promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresPdiCompliance rdf:type rdf:Property ;
    rdfs:label 'Requires Pdi Compliance' ;
    rdfs:comment 'Indicates whether the dealer must maintain a minimum PDI (Pre-Delivery Inspection) compliance rate as a prerequisite for incentive eligibility. True enforces PDI compliance gating; False means PDI compliance is not a condition.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresTrainingCertification rdf:type rdf:Property ;
    rdfs:label 'Requires Training Certification' ;
    rdfs:comment 'Indicates whether dealer sales or service staff must hold current OEM-mandated training certifications (e.g., EV product training, ADAS certification) as an eligibility prerequisite for this program.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retroactiveFlag rdf:type rdf:Property ;
    rdfs:label 'Retroactive Flag' ;
    rdfs:comment 'Indicates whether the stair-step payout structure applies retroactively to all units sold once a higher tier is achieved (True), or only incrementally to units sold above each threshold (False). Critical for stair-step program financial modeling.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesforceProgramReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Program Reference' ;
    rdfs:comment 'The Salesforce Automotive Cloud record ID for this incentive program. Enables bi-directional synchronization between the Databricks Silver Layer and Salesforce CRM for dealer portal visibility.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackableFlag rdf:type rdf:Property ;
    rdfs:label 'Stackable Flag' ;
    rdfs:comment 'Indicates whether this incentive program can be combined (stacked) with other concurrent OEM incentive programs for the same dealer and vehicle. True allows stacking; False means the program is mutually exclusive with other programs.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsVersion rdf:type rdf:Property ;
    rdfs:label 'Terms Version' ;
    rdfs:comment 'Version identifier of the program terms and conditions document (e.g., \'v1.0\', \'v2.1\'). Tracks amendments to program rules and ensures dealers are evaluated against the correct version of terms.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier1PayoutAmount rdf:type rdf:Property ;
    rdfs:label 'Tier1 Payout Amount' ;
    rdfs:comment 'Monetary payout amount (in program currency) awarded to dealers achieving Tier 1 performance threshold. May represent a flat bonus or per-unit amount depending on payout_structure_type.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier1Threshold rdf:type rdf:Property ;
    rdfs:label 'Tier1 Threshold' ;
    rdfs:comment 'Minimum performance metric value a dealer must achieve to qualify for Tier 1 (entry-level) payout. Units depend on performance_metric (e.g., number of vehicles sold, NPS score points).' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2PayoutAmount rdf:type rdf:Property ;
    rdfs:label 'Tier2 Payout Amount' ;
    rdfs:comment 'Monetary payout amount (in program currency) awarded to dealers achieving Tier 2 performance threshold. Null if program has fewer than 2 tiers.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2Threshold rdf:type rdf:Property ;
    rdfs:label 'Tier2 Threshold' ;
    rdfs:comment 'Minimum performance metric value a dealer must achieve to qualify for Tier 2 payout. Must be greater than tier1_threshold. Null if program has fewer than 2 tiers.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier3PayoutAmount rdf:type rdf:Property ;
    rdfs:label 'Tier3 Payout Amount' ;
    rdfs:comment 'Monetary payout amount (in program currency) awarded to dealers achieving Tier 3 performance threshold. Null if program has fewer than 3 tiers.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier3Threshold rdf:type rdf:Property ;
    rdfs:label 'Tier3 Threshold' ;
    rdfs:comment 'Minimum performance metric value a dealer must achieve to qualify for Tier 3 payout. Must be greater than tier2_threshold. Null if program has fewer than 3 tiers.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierCount rdf:type rdf:Property ;
    rdfs:label 'Tier Count' ;
    rdfs:comment 'Number of performance tiers defined within this incentive program (e.g., 3 for Bronze/Silver/Gold, 5 for stair-step programs). Determines the granularity of the payout structure.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalProgramBudget rdf:type rdf:Property ;
    rdfs:label 'Total Program Budget' ;
    rdfs:comment 'Total OEM-allocated budget for this incentive program across all participating dealers. Used by OEM regional sales operations for financial planning and CapEx/OpEx tracking in SAP S/4HANA CO.' ;
    rdfs:domain ind:DealerIncentiveProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsInventoryId rdf:type rdf:Property ;
    rdfs:label 'Parts Inventory Id' ;
    rdfs:comment 'Unique surrogate identifier for each parts inventory record at the dealer location. Primary key for the dealer parts inventory entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageMonthlyDemand rdf:type rdf:Property ;
    rdfs:label 'Average Monthly Demand' ;
    rdfs:comment 'Rolling average monthly sales or usage quantity for this part at the dealer location, as calculated and stored by the CDK DMS parts analysis engine. Used for reorder point setting and stocking level optimization. Stored as a DMS-sourced field, not a lakehouse-computed metric.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'Physical storage bin, shelf, or rack location code within the dealer parts warehouse or stockroom where this part is stored. Used by parts staff for picking, receiving, and cycle counting. Managed within CDK Global DMS warehouse management.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coreChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Core Charge Amount' ;
    rdfs:comment 'The refundable deposit amount charged to the customer for the return of the old/used core part. Applicable only when is_core_part is true. Tracked separately in CDK DMS for core deposit liability accounting.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealerCostPrice rdf:type rdf:Property ;
    rdfs:label 'Dealer Cost Price' ;
    rdfs:comment 'The price at which the dealer procures this part from the OEM or authorized distributor, net of any dealer program discounts. Used for gross margin calculation and parts profitability analysis. Confidential commercial pricing data.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventorySnapshotDate rdf:type rdf:Property ;
    rdfs:label 'Inventory Snapshot Date' ;
    rdfs:comment 'The business date as of which this inventory record reflects the parts quantities and status. Represents the effective date of the CDK DMS data extract loaded into the Silver Layer. Enables point-in-time inventory reporting and trend analysis.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isCorePart rdf:type rdf:Property ;
    rdfs:label 'Is Core Part' ;
    rdfs:comment 'Indicates whether this part has a core charge associated with it, requiring the customer to return the old/used part (core) for a refund. Common for remanufactured parts such as alternators, starters, and brake calipers. Drives core deposit tracking in CDK DMS.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazardousMaterial rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous Material' ;
    rdfs:comment 'Indicates whether this part or fluid is classified as a hazardous material requiring special handling, storage, and disposal procedures under EPA, DOT, and OSHA regulations. Affects shipping documentation and storage bin assignment.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSerialized rdf:type rdf:Property ;
    rdfs:label 'Is Serialized' ;
    rdfs:comment 'Indicates whether individual units of this part are tracked by unique serial number for warranty, recall, and traceability purposes. Serialized parts (e.g., ECUs, airbag modules) require serial number capture at point of sale and installation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Count Date' ;
    rdfs:comment 'Date on which the most recent physical inventory count or cycle count was performed for this part at the dealer location. Used to assess inventory accuracy and schedule next count per IATF 16949 inventory control requirements.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Receipt Date' ;
    rdfs:comment 'Date on which the most recent stock receipt (goods receipt) was posted for this part at the dealer location. Used to assess inventory freshness, identify slow-moving stock, and support cycle count scheduling.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSaleDate rdf:type rdf:Property ;
    rdfs:label 'Last Sale Date' ;
    rdfs:comment 'Date on which this part was most recently sold or issued from the dealer\'s parts inventory, either over the parts counter or via a repair order. Key metric for identifying slow-moving and non-moving (dead stock) inventory.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lostSalesQuantity rdf:type rdf:Property ;
    rdfs:label 'Lost Sales Quantity' ;
    rdfs:comment 'Cumulative quantity of lost sales recorded for this part when a customer requested the part but it was not available in stock. Tracked in CDK DMS to support stocking level adjustments and identify demand not captured by sales history.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level' ;
    rdfs:comment 'Upper inventory limit for this part at the dealer location. Prevents over-stocking and excess capital tied up in slow-moving parts. Used in conjunction with reorder point for min-max inventory management in CDK DMS.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelYearApplicability rdf:type rdf:Property ;
    rdfs:label 'Model Year Applicability' ;
    rdfs:comment 'The vehicle Model Year (MY) range for which this part is applicable, expressed as a single year (e.g., 2022) or a range (e.g., 2019-2024). Used by parts counter staff to verify fitment and avoid incorrect part installation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthsSupply rdf:type rdf:Property ;
    rdfs:label 'Months Supply' ;
    rdfs:comment 'Number of months the current on-hand quantity is expected to last based on the trailing average monthly demand. Sourced directly from CDK DMS parts analysis module. Used to identify overstocked and understocked parts for return-to-OEM decisions.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsClassification rdf:type rdf:Property ;
    rdfs:label 'Parts Classification' ;
    rdfs:comment 'High-level classification category of the part used for inventory segmentation, reporting, and stocking strategy. Categories include mechanical (engine, drivetrain, suspension), body (panels, glass, trim), electrical (ECU, sensors, wiring), accessories (OEM-approved add-ons), fluids, and consumables. [ENUM-REF-CANDIDATE: mechanical|body|electrical|accessories|fluids|consumables — promote to reference product]' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsGroupCode rdf:type rdf:Property ;
    rdfs:label 'Parts Group Code' ;
    rdfs:comment 'OEM-defined parts group or commodity code that further classifies the part within the parts classification hierarchy. Used for bulk ordering, supplier management, and warranty analysis. Aligns with SAP MM material group.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'Net quantity available for immediate sale or service fulfillment, calculated as quantity on hand minus quantity reserved. Represents the unreserved, physically present stock. Stored as a business field from CDK DMS to avoid real-time recalculation in reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Current physical quantity of the part available in the dealer\'s parts stockroom as recorded in the CDK DMS. Represents the actual counted or system-tracked stock level used for service fulfillment and parts counter sales.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityOnOrder rdf:type rdf:Property ;
    rdfs:label 'Quantity On Order' ;
    rdfs:comment 'Total quantity of this part currently on open purchase orders submitted to the OEM or aftermarket supplier but not yet received at the dealer. Used for demand planning and avoiding duplicate orders.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'Quantity of this part that has been reserved or allocated to open repair orders, customer back-orders, or service appointments but not yet consumed. Reduces available-to-promise quantity for new service requests.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Minimum stock level threshold at which a replenishment order should be triggered for this part. When quantity on hand falls to or below this level, the DMS generates a replenishment recommendation. Set based on historical demand and lead time.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Quantity' ;
    rdfs:comment 'Standard order quantity to be placed when the reorder point is reached. Represents the economic order quantity (EOQ) or OEM-mandated minimum order quantity for this part at this dealer location.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailPrice rdf:type rdf:Property ;
    rdfs:label 'Retail Price' ;
    rdfs:comment 'Dealer-set retail selling price for this part at the parts counter or in service repair orders. May differ from OEM list price based on dealer markup strategy, local market conditions, or promotional pricing.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Dealer-level Stock Keeping Unit (SKU) code used within the CDK Global DMS parts module for inventory tracking, bin management, and point-of-sale transactions. May differ from OEM part number when dealer applies local stocking codes.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Required storage condition for this part to maintain quality and safety compliance. Drives bin assignment and warehouse layout decisions. Flammable and hazardous parts require segregated storage per EPA and DOT regulations.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByDate rdf:type rdf:Property ;
    rdfs:label 'Superseded By Date' ;
    rdfs:comment 'The date on which this part number was officially superseded by the superseding part number as communicated by the OEM. Used to manage transition inventory and inform service advisors of part number changes.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supersedingPartNumber rdf:type rdf:Property ;
    rdfs:label 'Superseding Part Number' ;
    rdfs:comment 'The OEM part number that replaces this part when it has been superseded. Populated when inventory_status is \'superseded\'. Enables the parts counter to automatically redirect orders to the current valid part number. Part of the supersession chain managed in the OEM parts catalog.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleModelApplicability rdf:type rdf:Property ;
    rdfs:label 'Vehicle Model Applicability' ;
    rdfs:comment 'Comma-separated list of vehicle model names or platform codes for which this part is applicable (e.g., F-150, Explorer, Mustang). Supports fitment verification at the parts counter and in service repair order creation.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyEligible rdf:type rdf:Property ;
    rdfs:label 'Warranty Eligible' ;
    rdfs:comment 'Indicates whether this part is eligible for OEM warranty claim submission when installed during a warranty repair. Non-warranty-eligible parts (e.g., customer-pay accessories) are excluded from warranty billing to the OEM.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceScorecardId rdf:type rdf:Property ;
    rdfs:label 'Performance Scorecard Id' ;
    rdfs:comment 'Unique identifier for the dealer performance scorecard record.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compositeScore rdf:type rdf:Property ;
    rdfs:label 'Composite Score' ;
    rdfs:comment 'The overall weighted composite performance score combining all KPI categories (sales, service, parts, customer satisfaction, facility standards) used for franchise compliance and incentive eligibility.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compositeScoreBenchmark rdf:type rdf:Property ;
    rdfs:label 'Composite Score Benchmark' ;
    rdfs:comment 'The minimum composite score required for franchise compliance and incentive program eligibility.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csiBenchmark rdf:type rdf:Property ;
    rdfs:label 'Csi Benchmark' ;
    rdfs:comment 'The target or industry benchmark CSI score the dealer is expected to meet or exceed.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csiScore rdf:type rdf:Property ;
    rdfs:label 'Csi Score' ;
    rdfs:comment 'The Customer Satisfaction Index score measuring overall customer satisfaction with sales and service experience, typically on a scale of 0-100 or 0-1000 depending on OEM methodology.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysSupply rdf:type rdf:Property ;
    rdfs:label 'Days Supply' ;
    rdfs:comment 'The average number of days of inventory on hand at the dealer based on current sales rate.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dmsIntegrationSource rdf:type rdf:Property ;
    rdfs:label 'Dms Integration Source' ;
    rdfs:comment 'The Dealer Management System from which raw performance data was extracted for this scorecard.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityStandardsScore rdf:type rdf:Property ;
    rdfs:label 'Facility Standards Score' ;
    rdfs:comment 'The score measuring dealer compliance with OEM facility image and standards requirements (showroom, service bays, signage, etc.).' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter (1-4) to which this scorecard period belongs, if applicable.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Franchise Compliance Status' ;
    rdfs:comment 'The dealer\'s franchise agreement compliance status based on this scorecard\'s performance results.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryTurnRate rdf:type rdf:Property ;
    rdfs:label 'Inventory Turn Rate' ;
    rdfs:comment 'The number of times the dealer\'s new vehicle inventory was sold and replaced during the scorecard period, calculated as sales divided by average inventory.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketSharePct rdf:type rdf:Property ;
    rdfs:label 'Market Share Pct' ;
    rdfs:comment 'The dealer\'s share of total new vehicle sales in their assigned territory or market area during the scorecard period.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newVehicleSalesActual rdf:type rdf:Property ;
    rdfs:label 'New Vehicle Sales Actual' ;
    rdfs:comment 'The actual number of new vehicles sold by the dealer during the scorecard period.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newVehicleSalesAttainmentPct rdf:type rdf:Property ;
    rdfs:label 'New Vehicle Sales Attainment Pct' ;
    rdfs:comment 'The percentage of the new vehicle sales objective achieved by the dealer (actual/objective * 100).' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newVehicleSalesObjective rdf:type rdf:Property ;
    rdfs:label 'New Vehicle Sales Objective' ;
    rdfs:comment 'The target number of new vehicles the dealer was expected to sell during the scorecard period.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsBenchmark rdf:type rdf:Property ;
    rdfs:label 'Nps Benchmark' ;
    rdfs:comment 'The target or industry benchmark NPS score the dealer is expected to meet or exceed.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsFillRatePct rdf:type rdf:Property ;
    rdfs:label 'Parts Fill Rate Pct' ;
    rdfs:comment 'The percentage of parts orders fulfilled from dealer inventory without backorder during the scorecard period.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsRevenueActual rdf:type rdf:Property ;
    rdfs:label 'Parts Revenue Actual' ;
    rdfs:comment 'The actual parts department revenue generated during the scorecard period.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsRevenueObjective rdf:type rdf:Property ;
    rdfs:label 'Parts Revenue Objective' ;
    rdfs:comment 'The target parts department revenue for the scorecard period.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'The performance tier classification assigned to the dealer based on composite score and key metrics.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'The frequency of the scorecard evaluation period.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'The date this scorecard was officially published and communicated to the dealer.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'The name of the OEM regional manager or analyst who reviewed and approved this scorecard.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Scorecard Period End Date' ;
    rdfs:comment 'The last day of the evaluation period covered by this scorecard.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scorecardPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Scorecard Period Start Date' ;
    rdfs:comment 'The first day of the evaluation period covered by this scorecard (monthly or quarterly).' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scorecardStatus rdf:type rdf:Property ;
    rdfs:label 'Scorecard Status' ;
    rdfs:comment 'The current status of this scorecard record in its lifecycle.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAbsorptionRatePct rdf:type rdf:Property ;
    rdfs:label 'Service Absorption Rate Pct' ;
    rdfs:comment 'The percentage of fixed operations expenses covered by service and parts gross profit, a key profitability metric for dealer operations.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceRevenueActual rdf:type rdf:Property ;
    rdfs:label 'Service Revenue Actual' ;
    rdfs:comment 'The actual service department revenue generated during the scorecard period.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceRevenueObjective rdf:type rdf:Property ;
    rdfs:label 'Service Revenue Objective' ;
    rdfs:comment 'The target service department revenue for the scorecard period.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingCompliancePct rdf:type rdf:Property ;
    rdfs:label 'Training Compliance Pct' ;
    rdfs:comment 'The percentage of required OEM training programs completed by dealer staff during the scorecard period.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usedVehicleSalesActual rdf:type rdf:Property ;
    rdfs:label 'Used Vehicle Sales Actual' ;
    rdfs:comment 'The actual number of used vehicles sold by the dealer during the scorecard period.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usedVehicleSalesAttainmentPct rdf:type rdf:Property ;
    rdfs:label 'Used Vehicle Sales Attainment Pct' ;
    rdfs:comment 'The percentage of the used vehicle sales objective achieved by the dealer.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usedVehicleSalesObjective rdf:type rdf:Property ;
    rdfs:label 'Used Vehicle Sales Objective' ;
    rdfs:comment 'The target number of used vehicles the dealer was expected to sell during the scorecard period.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyClaimApprovalRatePct rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Approval Rate Pct' ;
    rdfs:comment 'The percentage of warranty claims submitted by the dealer that were approved by the OEM during the scorecard period.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallCompletionId rdf:type rdf:Property ;
    rdfs:label 'Recall Completion Id' ;
    rdfs:comment 'Unique identifier for the recall completion record. Primary key for the recall completion transaction.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicianEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Technician Employee Id' ;
    rdfs:comment 'Employee identifier of the technician who performed the recall remediation work. Used for quality tracking and reimbursement validation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:completionNumber rdf:type rdf:Property ;
    rdfs:label 'Completion Number' ;
    rdfs:comment 'Business identifier for the recall completion transaction, typically generated by the DMS or OEM recall management system.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Current status of the recall completion work. Completed indicates full remediation; incomplete or parts_pending indicate work not yet finished.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Precise date and time when the recall work was marked complete in the DMS system.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'Date when the customer was notified that the recall work was completed. Used for customer satisfaction tracking and communication audit.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Method' ;
    rdfs:comment 'Method used to notify the customer of recall completion: email, SMS, phone call, postal mail, or in-person at dealer.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nameplate rdf:type rdf:Property ;
    rdfs:label 'Nameplate' ;
    rdfs:comment 'Brand or nameplate of the vehicle (e.g., F-150, Camry, Silverado). Used to segment recall completion rates by product line.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nhtsaReportDate rdf:type rdf:Property ;
    rdfs:label 'Nhtsa Report Date' ;
    rdfs:comment 'Date when the recall completion was reported to NHTSA. Required for compliance tracking and audit trails.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nhtsaReportFlag rdf:type rdf:Property ;
    rdfs:label 'Nhtsa Report Flag' ;
    rdfs:comment 'Indicates whether this recall completion has been reported to NHTSA as required for safety recalls. True means reported; false means not yet reported or not required.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:odometerUnit rdf:type rdf:Property ;
    rdfs:label 'Odometer Unit' ;
    rdfs:comment 'Unit of measure for the odometer reading: km (kilometers) or mi (miles).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsQuantityList rdf:type rdf:Property ;
    rdfs:label 'Parts Quantity List' ;
    rdfs:comment 'Comma-separated or pipe-separated list of quantities corresponding to parts_used_list. Used for parts consumption analysis.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsUsedList rdf:type rdf:Property ;
    rdfs:label 'Parts Used List' ;
    rdfs:comment 'Comma-separated or pipe-separated list of part numbers used in the recall remediation. Used for parts consumption tracking and inventory replenishment.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postRepairInspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Post Repair Inspection Notes' ;
    rdfs:comment 'Technician notes from the post-repair inspection confirming that the recall remediation was successful and the vehicle is safe to operate.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preRepairInspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Pre Repair Inspection Notes' ;
    rdfs:comment 'Technician notes from the pre-repair inspection documenting the condition of the vehicle and the recall-related issue before remediation.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Quality Verification Date' ;
    rdfs:comment 'Date when the quality verification or audit of the recall work was performed.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityVerificationFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Verification Flag' ;
    rdfs:comment 'Indicates whether the recall work was subject to quality verification or audit by the dealer service manager or OEM field representative. True means verified; false means not verified.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityVerifierName rdf:type rdf:Property ;
    rdfs:label 'Quality Verifier Name' ;
    rdfs:comment 'Name of the person who performed the quality verification or audit of the recall work (typically service manager or OEM field representative).' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Claim Number' ;
    rdfs:comment 'Claim number submitted by the dealer to the OEM for reimbursement of recall work. Links to the OEM financial system for payment processing.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementPaidDate rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Paid Date' ;
    rdfs:comment 'Date when the OEM paid the dealer for the recall work. Used for dealer cash flow analysis and OEM financial reporting.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reimbursementStatus rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Status' ;
    rdfs:comment 'Status of the dealer reimbursement claim. Pending indicates claim submitted but not yet reviewed; approved means claim validated; paid means funds transferred to dealer.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subletAmount rdf:type rdf:Property ;
    rdfs:label 'Sublet Amount' ;
    rdfs:comment 'Cost of any sublet or outsourced work required to complete the recall (e.g., specialized welding, paint work). Reimbursable by OEM if pre-approved.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicianCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Technician Certification Number' ;
    rdfs:comment 'Certification or license number of the technician. Some recalls require certified technicians to perform the work.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianName rdf:type rdf:Property ;
    rdfs:label 'Technician Name' ;
    rdfs:comment 'Full name of the technician who completed the recall work. Used for performance tracking and quality audits.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalReimbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Total Reimbursement Amount' ;
    rdfs:comment 'Total amount claimed by the dealer for reimbursement from the OEM, including labor, parts, and sublet costs.' ;
    rdfs:domain ind:RecallCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retailSaleId rdf:type rdf:Property ;
    rdfs:label 'Retail Sale Id' ;
    rdfs:comment 'Unique surrogate identifier for each retail vehicle sale transaction record in the dealer domain. Primary key for the retail_sale data product.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opportunityId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Id' ;
    rdfs:comment 'Foreign key linking to sales.opportunity. Business justification: Retail sale conversion analysis links the final sale back to the originating sales opportunity for win-loss tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:salespersonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Salesperson Employee Id' ;
    rdfs:comment 'Reference to the dealership salesperson (finance and insurance associate or sales consultant) who managed and closed the retail deal.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:apr rdf:type rdf:Property ;
    rdfs:label 'Apr' ;
    rdfs:comment 'The Annual Percentage Rate (APR) on the retail installment contract as disclosed to the customer under Regulation Z. Expressed as a decimal (e.g., 0.0699 for 6.99%). Null for cash and lease deals.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backEndGross rdf:type rdf:Property ;
    rdfs:label 'Back End Gross' ;
    rdfs:comment 'Gross profit earned from F&I products and dealer reserve on the financing (back-end), representing the total F&I department contribution to the deal. Key dealer profitability metric.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealNumber rdf:type rdf:Property ;
    rdfs:label 'Deal Number' ;
    rdfs:comment 'Externally-known alphanumeric deal reference number assigned by the CDK Global DMS F&I module at the time the deal is opened. Used for cross-referencing with dealer records, lender submissions, and OEM reporting.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealStatus rdf:type rdf:Property ;
    rdfs:label 'Deal Status' ;
    rdfs:comment 'Current lifecycle state of the retail sale deal. \'draft\' indicates deal is being structured; \'pending\' indicates awaiting lender funding approval; \'funded\' indicates lender has funded the deal; \'unwound\' indicates a previously funded deal that was reversed; \'cancelled\' indicates deal was voided before funding.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsDealReference rdf:type rdf:Property ;
    rdfs:label 'Dms Deal Reference' ;
    rdfs:comment 'The native deal identifier assigned by the CDK Global DMS F&I module. Used for source system traceability, reconciliation, and integration with downstream OEM reporting and lender portals.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docFee rdf:type rdf:Property ;
    rdfs:label 'Doc Fee' ;
    rdfs:comment 'Dealer-charged documentation and processing fee included in the deal. Subject to state-level regulatory caps in many jurisdictions. Disclosed on the buyer\'s order.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downPayment rdf:type rdf:Property ;
    rdfs:label 'Down Payment' ;
    rdfs:comment 'Cash down payment made by the customer at the time of sale, excluding trade-in allowance. Reduces the amount financed. Used for deal structure analysis and lender submission.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiProductRevenue rdf:type rdf:Property ;
    rdfs:label 'Fi Product Revenue' ;
    rdfs:comment 'Total gross revenue generated from Finance and Insurance (F&I) aftermarket products sold as part of the deal, including extended service contracts, GAP insurance, paint protection, tire and wheel protection, and credit life/disability insurance.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financeAmount rdf:type rdf:Property ;
    rdfs:label 'Finance Amount' ;
    rdfs:comment 'The total amount financed by the customer under the retail installment contract, including vehicle price, F&I products, taxes, and fees, less down payment and trade-in allowance. Null for cash deals.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financingType rdf:type rdf:Property ;
    rdfs:label 'Financing Type' ;
    rdfs:comment 'The method by which the customer is financing the vehicle purchase. \'cash\' = outright purchase; \'retail_finance\' = retail installment contract through a lender; \'lease\' = closed-end consumer lease; \'balloon\' = balloon payment retail contract.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetSale rdf:type rdf:Property ;
    rdfs:label 'Fleet Sale' ;
    rdfs:comment 'Indicates whether the vehicle was sold as part of a fleet or commercial account transaction rather than a retail consumer sale. Fleet sales are tracked separately for CAFE compliance, OEM fleet incentive programs, and sales mix reporting.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frontEndGross rdf:type rdf:Property ;
    rdfs:label 'Front End Gross' ;
    rdfs:comment 'Gross profit earned on the vehicle sale itself (front-end), calculated as sale price minus dealer invoice cost and pack. Excludes F&I product revenue. Key dealer profitability metric reported in DMS and OEM dealer scorecards.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lenderName rdf:type rdf:Property ;
    rdfs:label 'Lender Name' ;
    rdfs:comment 'Name of the financial institution (captive finance company, bank, credit union) that approved and funded the retail installment contract or lease. Null for cash deals. Used for lender mix reporting and dealer reserve analysis.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loanTermMonths rdf:type rdf:Property ;
    rdfs:label 'Loan Term Months' ;
    rdfs:comment 'The contractual term of the retail installment contract expressed in months (e.g., 36, 48, 60, 72, 84). Used for lender mix analysis, payment affordability reporting, and portfolio risk assessment.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monthlyPayment rdf:type rdf:Property ;
    rdfs:label 'Monthly Payment' ;
    rdfs:comment 'The customer\'s contracted monthly payment amount under the retail installment contract or lease agreement. Used for affordability analysis and customer financial profiling.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oemIncentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Oem Incentive Amount' ;
    rdfs:comment 'Total value of OEM-funded customer incentives applied to the deal, including cash-back rebates, conquest bonuses, loyalty bonuses, and special program pricing. Sourced from OEM incentive program data and reconciled against dealer statements.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saleDate rdf:type rdf:Property ;
    rdfs:label 'Sale Date' ;
    rdfs:comment 'The calendar date on which the retail vehicle sale was consummated — i.e., the date the buyer signed the retail installment contract or cash purchase agreement. This is the principal business event date used for sales reporting, OEM incentive eligibility, and regulatory compliance.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salePrice rdf:type rdf:Property ;
    rdfs:label 'Sale Price' ;
    rdfs:comment 'The agreed-upon selling price of the vehicle as negotiated between the dealer and the customer, before trade-in allowance, taxes, and fees. This is the gross capitalized cost for lease deals or the selling price for retail finance and cash deals.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Sales Tax Amount' ;
    rdfs:comment 'State and local sales tax assessed on the vehicle sale transaction. Calculated based on the taxable selling price and the applicable jurisdiction tax rate. Used for tax remittance reporting and deal cost reconciliation.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeInAllowance rdf:type rdf:Property ;
    rdfs:label 'Trade In Allowance' ;
    rdfs:comment 'The agreed trade-in value credited to the customer for a vehicle traded in as part of the deal. Reduces the amount financed or cash due. Null if no trade-in vehicle was involved in the transaction.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeInPayoffAmount rdf:type rdf:Property ;
    rdfs:label 'Trade In Payoff Amount' ;
    rdfs:comment 'The outstanding loan or lease payoff balance on the customer\'s trade-in vehicle at the time of the deal. If payoff exceeds trade-in allowance, the difference (negative equity) is typically rolled into the new deal.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleCondition rdf:type rdf:Property ;
    rdfs:label 'Vehicle Condition' ;
    rdfs:comment 'Condition classification of the vehicle at point of sale. \'new\' indicates a new, untitled vehicle; \'used\' indicates a previously titled vehicle; \'certified_pre_owned\' indicates a manufacturer-certified pre-owned vehicle meeting OEM CPO program standards.' ;
    rdfs:domain ind:RetailSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCapacityId rdf:type rdf:Property ;
    rdfs:label 'Service Capacity Id' ;
    rdfs:comment 'Unique identifier for the service capacity configuration record. Primary key.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aTechHeadcount rdf:type rdf:Property ;
    rdfs:label 'A Tech Headcount' ;
    rdfs:comment 'Number of A-level (master) technicians certified for complex diagnostics, ECU (Electronic Control Unit) programming, and advanced repair work.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adasCertifiedTechCount rdf:type rdf:Property ;
    rdfs:label 'Adas Certified Tech Count' ;
    rdfs:comment 'Number of technicians certified for ADAS calibration, sensor diagnostics, and autonomous driving system service.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adasServiceBays rdf:type rdf:Property ;
    rdfs:label 'Adas Service Bays' ;
    rdfs:comment 'Number of service bays equipped with ADAS (Advanced Driver Assistance Systems) calibration equipment for sensor alignment and diagnostic work.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availableLaborHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Available Labor Hours Per Day' ;
    rdfs:comment 'Total productive labor hours available per day across all technicians, calculated as (technician headcount × hours per shift × efficiency factor). Used for service appointment scheduling and capacity utilization analysis.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgRoCycleTimeHours rdf:type rdf:Property ;
    rdfs:label 'Avg Ro Cycle Time Hours' ;
    rdfs:comment 'Average time in hours from RO (Repair Order) open to close. Used for scheduling optimization and capacity planning.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bTechHeadcount rdf:type rdf:Property ;
    rdfs:label 'B Tech Headcount' ;
    rdfs:comment 'Number of B-level (journeyman) technicians certified for general maintenance and standard repair operations.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bodyShopBays rdf:type rdf:Property ;
    rdfs:label 'Body Shop Bays' ;
    rdfs:comment 'Number of service bays designated for collision repair, body work, and paint operations.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bodyShopTechCount rdf:type rdf:Property ;
    rdfs:label 'Body Shop Tech Count' ;
    rdfs:comment 'Number of technicians certified for collision repair, body work, and paint operations.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cTechHeadcount rdf:type rdf:Property ;
    rdfs:label 'C Tech Headcount' ;
    rdfs:comment 'Number of C-level (apprentice) technicians performing basic maintenance tasks and assisting senior technicians.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityConfigCode rdf:type rdf:Property ;
    rdfs:label 'Capacity Config Code' ;
    rdfs:comment 'Business identifier for the service capacity configuration, typically used in DMS (Dealer Management System) integration and capacity planning reports.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityNotes rdf:type rdf:Property ;
    rdfs:label 'Capacity Notes' ;
    rdfs:comment 'Free-text notes regarding capacity constraints, planned expansions, seasonal adjustments, or special considerations for service scheduling.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityStatus rdf:type rdf:Property ;
    rdfs:label 'Capacity Status' ;
    rdfs:comment 'Current operational status of the service capacity configuration. Active indicates normal operations, seasonal indicates temporary capacity adjustments, reduced/expanded indicate capacity changes, under_review indicates pending capacity assessment.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentCapacityUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Current Capacity Utilization Pct' ;
    rdfs:comment 'Current utilization rate of service capacity expressed as a percentage. Calculated as (actual labor hours used / available labor hours) × 100. Used for capacity planning and scheduling optimization.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerPayCapacityPct rdf:type rdf:Property ;
    rdfs:label 'Customer Pay Capacity Pct' ;
    rdfs:comment 'Percentage of total service capacity allocated for customer pay (non-warranty) repair orders. Typically 60-70% of total capacity.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diagnosticEquipmentLevel rdf:type rdf:Property ;
    rdfs:label 'Diagnostic Equipment Level' ;
    rdfs:comment 'Classification of diagnostic equipment capability. Basic: OBD scanners. Standard: factory scan tools. Advanced: ECU programming and ADAS calibration. Premium: full factory diagnostic suite with remote technical assistance.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsCapacityRecordReference rdf:type rdf:Property ;
    rdfs:label 'Dms Capacity Record Reference' ;
    rdfs:comment 'External identifier for this capacity configuration in the source DMS system. Used for data lineage and integration reconciliation.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsSystemCode rdf:type rdf:Property ;
    rdfs:label 'Dms System Code' ;
    rdfs:comment 'Code identifying the DMS platform used by the dealer for service scheduling and capacity management. Primary integration point for capacity data synchronization.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evCertifiedTechCount rdf:type rdf:Property ;
    rdfs:label 'Ev Certified Tech Count' ;
    rdfs:comment 'Number of technicians holding OEM (Original Equipment Manufacturer) certification for EV, HEV, and PHEV high-voltage system service and repair.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evServiceBays rdf:type rdf:Property ;
    rdfs:label 'Ev Service Bays' ;
    rdfs:comment 'Number of service bays equipped and certified for EV (Electric Vehicle), HEV (Hybrid Electric Vehicle), and PHEV (Plug-in Hybrid Electric Vehicle) service work.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expressServiceBays rdf:type rdf:Property ;
    rdfs:label 'Express Service Bays' ;
    rdfs:comment 'Number of service bays designated for quick service operations such as oil changes, tire rotations, and PDI (Pre-Delivery Inspection).' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:generalServiceBays rdf:type rdf:Property ;
    rdfs:label 'General Service Bays' ;
    rdfs:comment 'Number of service bays designated for general maintenance and repair work on ICE (Internal Combustion Engine) vehicles.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hasMobileServiceCapability rdf:type rdf:Property ;
    rdfs:label 'Has Mobile Service Capability' ;
    rdfs:comment 'Indicates whether the dealer offers mobile service capability for on-site customer vehicle service and OTA updates.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hoursPerShift rdf:type rdf:Property ;
    rdfs:label 'Hours Per Shift' ;
    rdfs:comment 'Standard duration of each work shift in hours, typically 8.0 or 10.0 hours.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalCapacityPct rdf:type rdf:Property ;
    rdfs:label 'Internal Capacity Pct' ;
    rdfs:comment 'Percentage of total service capacity allocated for internal work including PDI (Pre-Delivery Inspection), loaner maintenance, and dealer-owned vehicle service. Typically 10-15% of total capacity.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCapacityReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Capacity Review Date' ;
    rdfs:comment 'Date of the most recent capacity assessment and configuration review. Used for capacity planning governance and audit trails.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loanerFleetUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Loaner Fleet Utilization Pct' ;
    rdfs:comment 'Current utilization rate of the loaner fleet expressed as a percentage. Calculated as (loaners in use / total loaner fleet size) × 100.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxDailyAppointments rdf:type rdf:Property ;
    rdfs:label 'Max Daily Appointments' ;
    rdfs:comment 'Maximum number of service appointments that can be scheduled per day based on bay capacity, technician availability, and average repair order duration.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobileServiceTechnicianCount rdf:type rdf:Property ;
    rdfs:label 'Mobile Service Technician Count' ;
    rdfs:comment 'Number of technicians dedicated to mobile service operations. Null if mobile service is not offered.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextCapacityReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Capacity Review Date' ;
    rdfs:comment 'Scheduled date for the next capacity assessment and configuration review. Typically quarterly or semi-annually.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingDaysPerWeek rdf:type rdf:Property ;
    rdfs:label 'Operating Days Per Week' ;
    rdfs:comment 'Number of days per week the service department operates. Typically 5 or 6 days for most dealers.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partsInventoryCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Parts Inventory Capacity Sqft' ;
    rdfs:comment 'Total square footage of parts storage capacity at the dealer service location. Used for parts inventory planning and JIT (Just-in-Time) delivery optimization.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftsPerDay rdf:type rdf:Property ;
    rdfs:label 'Shifts Per Day' ;
    rdfs:comment 'Number of work shifts operated per day (1 for single shift, 2 for double shift operations).' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialtyCertifications rdf:type rdf:Property ;
    rdfs:label 'Specialty Certifications' ;
    rdfs:comment 'Comma-separated list of specialty certifications held by the service department, such as EV, ADAS, body shop, OBD (On-Board Diagnostics), TPMS (Tire Pressure Monitoring System), OTA (Over-the-Air Update) programming. Used for service capability assessment and customer routing.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCapacityUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Target Capacity Utilization Pct' ;
    rdfs:comment 'Target utilization rate for optimal service department performance, typically 80-85%. Used for capacity planning and performance scorecards.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalServiceBays rdf:type rdf:Property ;
    rdfs:label 'Total Service Bays' ;
    rdfs:comment 'Total number of physical service bays available at the dealer service department for vehicle maintenance and repair work.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTechnicianHeadcount rdf:type rdf:Property ;
    rdfs:label 'Total Technician Headcount' ;
    rdfs:comment 'Total number of certified technicians employed at the dealer service department across all skill levels.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyWorkCapacityPct rdf:type rdf:Property ;
    rdfs:label 'Warranty Work Capacity Pct' ;
    rdfs:comment 'Percentage of total service capacity allocated for warranty and recall work. Typically 20-30% of total capacity.' ;
    rdfs:domain ind:ServiceCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usedVehicleAppraisalId rdf:type rdf:Property ;
    rdfs:label 'Used Vehicle Appraisal Id' ;
    rdfs:comment 'Unique identifier for the used vehicle appraisal record. Primary key for this entity.' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appraiserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Appraiser Employee Id' ;
    rdfs:comment 'Employee identifier of the dealership staff member who conducted the appraisal.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accidentHistoryFlag rdf:type rdf:Property ;
    rdfs:label 'Accident History Flag' ;
    rdfs:comment 'Indicates whether the vehicle has a reported accident history based on vehicle history report or customer disclosure.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appraisalDate rdf:type rdf:Property ;
    rdfs:label 'Appraisal Date' ;
    rdfs:comment 'Date when the vehicle appraisal was conducted at the dealership.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appraisalNumber rdf:type rdf:Property ;
    rdfs:label 'Appraisal Number' ;
    rdfs:comment 'Unique business identifier for the appraisal transaction, typically generated by the DMS (Dealer Management System) or appraisal tool.' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appraisalSourceChannel rdf:type rdf:Property ;
    rdfs:label 'Appraisal Source Channel' ;
    rdfs:comment 'Channel through which the appraisal was initiated: walk_in (customer walked into dealership), appointment (scheduled appraisal), online_submission (customer submitted online), phone_inquiry (customer called), service_drive (initiated during service visit).' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appraisalStatus rdf:type rdf:Property ;
    rdfs:label 'Appraisal Status' ;
    rdfs:comment 'Current lifecycle status of the appraisal: pending (in progress), completed (appraisal finished), accepted (customer accepted trade-in offer), declined (customer declined offer), expired (offer validity period lapsed).' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appraisalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Appraisal Timestamp' ;
    rdfs:comment 'Precise date and time when the appraisal was completed, including time zone information.' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appraisalToolUsed rdf:type rdf:Property ;
    rdfs:label 'Appraisal Tool Used' ;
    rdfs:comment 'Third-party valuation tool or system used to determine vehicle value: Manheim MMR (Manheim Market Report), Black Book, KBB (Kelley Blue Book), NADA (National Automobile Dealers Association), Galves, or internal proprietary tool.' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appraisedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Appraised Value Amount' ;
    rdfs:comment 'Final appraised value determined by the dealer after considering market value, vehicle condition, and local market factors.' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appraiserName rdf:type rdf:Property ;
    rdfs:label 'Appraiser Name' ;
    rdfs:comment 'Full name of the dealership employee who performed the appraisal.' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerRequestedAmount rdf:type rdf:Property ;
    rdfs:label 'Customer Requested Amount' ;
    rdfs:comment 'Trade-in value amount initially requested or expected by the customer, if disclosed during appraisal.' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'Final decision on the disposition of the appraised vehicle: accepted_trade (customer accepted trade-in offer), declined_trade (customer declined offer), wholesale (vehicle to be sent to auction), retail_inventory (vehicle to be added to dealer used inventory), pending (decision not yet made).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityAmount rdf:type rdf:Property ;
    rdfs:label 'Equity Amount' ;
    rdfs:comment 'Calculated equity in the vehicle (appraised value minus payoff amount). Positive equity means the vehicle is worth more than owed; negative equity means the customer owes more than the vehicle is worth.' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exteriorConditionNotes rdf:type rdf:Property ;
    rdfs:label 'Exterior Condition Notes' ;
    rdfs:comment 'Detailed notes on the exterior condition, including paint quality, body damage, dents, scratches, rust, and glass condition.' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interiorConditionNotes rdf:type rdf:Property ;
    rdfs:label 'Interior Condition Notes' ;
    rdfs:comment 'Detailed notes on the interior condition, including upholstery wear, dashboard condition, electronics functionality, and cleanliness.' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedDealNumber rdf:type rdf:Property ;
    rdfs:label 'Linked Deal Number' ;
    rdfs:comment 'Deal or sales transaction number in the DMS (Dealer Management System) if this appraisal was linked to a new or used vehicle purchase.' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketValueAmount rdf:type rdf:Property ;
    rdfs:label 'Market Value Amount' ;
    rdfs:comment 'Estimated market value of the vehicle based on the appraisal tool, representing the fair market price for retail or wholesale.' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mechanicalConditionNotes rdf:type rdf:Property ;
    rdfs:label 'Mechanical Condition Notes' ;
    rdfs:comment 'Detailed notes on the mechanical condition of the vehicle, including engine, transmission, brakes, suspension, and other systems.' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Offer Expiration Date' ;
    rdfs:comment 'Date when the trade-in offer expires and is no longer valid, typically 3-7 days from appraisal date.' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconditioningCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Reconditioning Cost Estimate' ;
    rdfs:comment 'Estimated cost to recondition the vehicle for resale, including repairs, detailing, and PDI (Pre-Delivery Inspection) work.' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retailEstimateAmount rdf:type rdf:Property ;
    rdfs:label 'Retail Estimate Amount' ;
    rdfs:comment 'Estimated retail asking price if the vehicle were to be added to dealer used vehicle inventory.' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceRecordsAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Service Records Available Flag' ;
    rdfs:comment 'Indicates whether the customer provided documented service and maintenance records for the vehicle.' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tireCondition rdf:type rdf:Property ;
    rdfs:label 'Tire Condition' ;
    rdfs:comment 'Assessment of tire condition and remaining tread life: excellent (like new), good (adequate tread), fair (moderate wear), poor (low tread), replacement_needed (below safe threshold).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleStatus rdf:type rdf:Property ;
    rdfs:label 'Title Status' ;
    rdfs:comment 'Legal title status of the vehicle: clean (no issues), salvage (total loss), rebuilt (repaired salvage), lemon (manufacturer buyback), flood (flood damage), hail (hail damage).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeInAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Trade In Allowance Amount' ;
    rdfs:comment 'Trade-in allowance amount offered to the customer, which may differ from appraised value due to negotiation or deal structuring in F&I (Finance and Insurance) process.' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wholesaleEstimateAmount rdf:type rdf:Property ;
    rdfs:label 'Wholesale Estimate Amount' ;
    rdfs:comment 'Estimated wholesale auction value if the vehicle were to be sent to wholesale rather than retailed.' ;
    rdfs:domain ind:UsedVehicleAppraisal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleAllocationId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for each vehicle allocation record linking a specific vehicle unit or allocation batch from OEM manufacturing output to a dealership inventory pipeline.' ;
    rdfs:domain ind:VehicleAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptanceDeadline rdf:type rdf:Property ;
    rdfs:label 'Acceptance Deadline' ;
    rdfs:comment 'Date by which the dealer must formally accept or reject this allocation. Failure to respond by this date may result in automatic acceptance or reallocation per OEM dealer agreement terms.' ;
    rdfs:domain ind:VehicleAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acceptanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acceptance Timestamp' ;
    rdfs:comment 'Exact timestamp when the dealer formally accepted this vehicle allocation via the dealer portal or DMS integration. Provides precise audit trail for dealer commitment.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:acceptedQuantity rdf:type rdf:Property ;
    rdfs:label 'Accepted Quantity' ;
    rdfs:comment 'Number of vehicle units formally accepted by the dealer from this allocation. May be less than allocated_quantity if the dealer partially accepts or rejects units.' ;
    rdfs:domain ind:VehicleAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Batch Number' ;
    rdfs:comment 'Identifier grouping multiple allocation records issued in the same OEM allocation run or production release cycle. Enables batch-level tracking, reporting, and dealer communication.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationRuleCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Rule Code' ;
    rdfs:comment 'Code identifying the specific allocation rule or algorithm applied to determine this dealer\'s vehicle entitlement (e.g., turn-and-earn, market share, historical sales, regional quota). Drives transparency and auditability of allocation decisions.' ;
    rdfs:domain ind:VehicleAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerInvoicePrice rdf:type rdf:Property ;
    rdfs:label 'Dealer Invoice Price' ;
    rdfs:comment 'The price at which the OEM invoices the dealer for the allocated vehicle, net of holdback and before dealer incentives. Represents the dealer\'s cost basis for inventory financing and margin calculation.' ;
    rdfs:domain ind:VehicleAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dms Reference Number' ;
    rdfs:comment 'The corresponding allocation or stock order reference number in the dealer\'s CDK Global Dealer Management System (DMS). Enables end-to-end reconciliation between OEM allocation records and dealer inventory systems.' ;
    rdfs:domain ind:VehicleAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'Estimated date the allocated vehicle(s) are expected to arrive at the dealership. Calculated based on production schedule, transport lead time, and PDI processing time. Communicated to dealers for inventory planning.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdCode rdf:type rdf:Property ;
    rdfs:label 'Hold Code' ;
    rdfs:comment 'Code indicating any active hold placed on the allocated vehicle(s) preventing retail sale (e.g., safety recall hold, quality hold, regulatory compliance hold, stop-sale order). Null when no hold is active. [ENUM-REF-CANDIDATE: safety_recall|quality_hold|regulatory|stop_sale|tsb_hold|other — promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveProgramCode rdf:type rdf:Property ;
    rdfs:label 'Incentive Program Code' ;
    rdfs:comment 'Code identifying the OEM dealer incentive program applicable to this allocation (e.g., volume bonus, stair-step program, conquest incentive). Links to the dealer incentive program master for payout calculation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCustomerOrder rdf:type rdf:Property ;
    rdfs:label 'Is Customer Order' ;
    rdfs:comment 'Indicates whether this allocation is fulfilling a specific retail customer order (sold order) rather than being allocated to dealer stock inventory. Drives order fulfillment priority and customer communication workflows.' ;
    rdfs:domain ind:VehicleAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portOfEntryCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Entry Code' ;
    rdfs:comment 'Code identifying the port or processing compound through which imported or CKD/SKD vehicles pass before onward delivery to the dealer. Relevant for international allocation flows and customs compliance.' ;
    rdfs:domain ind:VehicleAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityTier rdf:type rdf:Property ;
    rdfs:label 'Priority Tier' ;
    rdfs:comment 'Dealer priority tier assigned for this allocation cycle, determining precedence when vehicle supply is constrained. Tier 1 dealers receive first allocation rights based on performance metrics, sales volume, or strategic importance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledProductionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Production Date' ;
    rdfs:comment 'Planned date on which the allocated vehicle unit(s) are scheduled to enter the production line. Derived from the Start of Production (SOP) schedule and used for delivery window planning.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Primary mode of transportation used to deliver the allocated vehicle(s) from the production plant or port of entry to the dealership. Drives logistics cost allocation and delivery lead time estimation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cadModelId rdf:type rdf:Property ;
    rdfs:label 'Cad Model Id' ;
    rdfs:comment 'Unique surrogate key for each CAD model record.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cad Employee Id' ;
    rdfs:comment 'Surrogate key of the engineer responsible for the model.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assemblyName rdf:type rdf:Property ;
    rdfs:label 'Assembly Name' ;
    rdfs:comment 'Name of the parent assembly if the model is a sub-component.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cadModelName rdf:type rdf:Property ;
    rdfs:label 'Cad Model Name' ;
    rdfs:comment 'Human-readable name of the CAD model as shown in the engineering portal.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cadModelStatus rdf:type rdf:Property ;
    rdfs:label 'Cad Model Status' ;
    rdfs:comment 'Current lifecycle status of the model within the PLM system.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceIso26262Level rdf:type rdf:Property ;
    rdfs:label 'Compliance Iso26262 Level' ;
    rdfs:comment 'Functional safety classification of the component according to ISO 26262.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationContext rdf:type rdf:Property ;
    rdfs:label 'Configuration Context' ;
    rdfs:comment 'Contextual configuration (e.g., default, sport, luxury) for which the model variant is defined.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinateSystem rdf:type rdf:Property ;
    rdfs:label 'Coordinate System' ;
    rdfs:comment 'Reference coordinate system (e.g., right-hand, left-hand) applied to the model.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Design Approval Status' ;
    rdfs:comment 'Current approval state of the design.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designChangeDate rdf:type rdf:Property ;
    rdfs:label 'Design Change Date' ;
    rdfs:comment 'Date when the most recent engineering change was applied.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designChangeNumber rdf:type rdf:Property ;
    rdfs:label 'Design Change Number' ;
    rdfs:comment 'Identifier of the engineering change order (ECO/ECN) that last modified the model.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Design Release Date' ;
    rdfs:comment 'Official date when the design was released for manufacturing.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:digitalTwinReady rdf:type rdf:Property ;
    rdfs:label 'Digital Twin Ready' ;
    rdfs:comment 'True if the model meets criteria for inclusion in a digital twin.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'File name of the CAD geometry (including extension).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'Repository location or network path where the CAD file is stored.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geometryUnits rdf:type rdf:Property ;
    rdfs:label 'Geometry Units' ;
    rdfs:comment 'Unit of measure used for the model\'s geometry coordinates.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDigitalMockupIncluded rdf:type rdf:Property ;
    rdfs:label 'Is Digital Mockup Included' ;
    rdfs:comment 'True if the model is part of a Digital Mock-Up (DMU) package.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPublishedDate rdf:type rdf:Property ;
    rdfs:label 'Last Published Date' ;
    rdfs:comment 'Date when the model was last released to downstream teams or systems.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maturityLevel rdf:type rdf:Property ;
    rdfs:label 'Maturity Level' ;
    rdfs:comment 'Indicates how mature the model is within the product development lifecycle.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelType rdf:type rdf:Property ;
    rdfs:label 'Model Type' ;
    rdfs:comment 'Classification of the CAD geometry type.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Status of regulatory sign-off (e.g., NHTSA, EPA) for the model.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedVehicleVariant rdf:type rdf:Property ;
    rdfs:label 'Related Vehicle Variant' ;
    rdfs:comment 'Specific vehicle variant (e.g., sport, hybrid) that the model supports.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revision rdf:type rdf:Property ;
    rdfs:label 'Revision' ;
    rdfs:comment 'Revision identifier (e.g., A, B, C) used for minor changes within a version.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:simulationReady rdf:type rdf:Property ;
    rdfs:label 'Simulation Ready' ;
    rdfs:comment 'True if the model is prepared for CAE simulations (e.g., meshed, cleaned).' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toolVersion rdf:type rdf:Property ;
    rdfs:label 'Tool Version' ;
    rdfs:comment 'Version of the CAD application (e.g., CATIA V5R30) used to author the model.' ;
    rdfs:domain ind:CadModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehiclePlatform rdf:type rdf:Property ;
    rdfs:label 'Vehicle Platform' ;
    rdfs:comment 'Platform identifier (e.g., MQB, CMF) associated with the model.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caeSimulationId rdf:type rdf:Property ;
    rdfs:label 'Cae Simulation Id' ;
    rdfs:comment 'Unique surrogate key for the CAE simulation record.' ;
    rdfs:domain ind:CaeSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Analyst Employee Id' ;
    rdfs:comment 'Identifier of the engineering analyst who initiated or owned the simulation.' ;
    rdfs:domain ind:CaeSimulation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:partMasterId rdf:type rdf:Property ;
    rdfs:label 'Part Part Master Id' ;
    rdfs:comment 'Identifier of the part or assembly that the simulation analyzes.' ;
    rdfs:domain ind:Engineering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartMaster .

ind:analystName rdf:type rdf:Property ;
    rdfs:label 'Analyst Name' ;
    rdfs:comment 'Full name of the analyst responsible for the simulation.' ;
    rdfs:domain ind:CaeSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boundaryConditions rdf:type rdf:Property ;
    rdfs:label 'Boundary Conditions' ;
    rdfs:comment 'Structured description of boundary conditions (e.g., constraints, supports) used in the simulation.' ;
    rdfs:domain ind:CaeSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convergenceCriteria rdf:type rdf:Property ;
    rdfs:label 'Convergence Criteria' ;
    rdfs:comment 'Criteria used to determine simulation convergence (e.g., residual threshold).' ;
    rdfs:domain ind:CaeSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpuTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Cpu Time Seconds' ;
    rdfs:comment 'Total CPU processing time consumed by the simulation.' ;
    rdfs:domain ind:CaeSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadCase rdf:type rdf:Property ;
    rdfs:label 'Load Case' ;
    rdfs:comment 'Description of the load case applied in the simulation.' ;
    rdfs:domain ind:CaeSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memoryUsageMb rdf:type rdf:Property ;
    rdfs:label 'Memory Usage Mb' ;
    rdfs:comment 'Peak memory usage of the simulation process in megabytes.' ;
    rdfs:domain ind:CaeSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meshElementCount rdf:type rdf:Property ;
    rdfs:label 'Mesh Element Count' ;
    rdfs:comment 'Total number of finite elements in the simulation mesh.' ;
    rdfs:domain ind:CaeSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:meshQualityScore rdf:type rdf:Property ;
    rdfs:label 'Mesh Quality Score' ;
    rdfs:comment 'Quality rating of the mesh (higher is better).' ;
    rdfs:domain ind:CaeSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resultMetricName rdf:type rdf:Property ;
    rdfs:label 'Result Metric Name' ;
    rdfs:comment 'Name of the primary result metric produced by the simulation (e.g., Max Stress).' ;
    rdfs:domain ind:CaeSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultMetricUnit rdf:type rdf:Property ;
    rdfs:label 'Result Metric Unit' ;
    rdfs:comment 'Unit of measure for the primary result metric.' ;
    rdfs:domain ind:CaeSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultMetricValue rdf:type rdf:Property ;
    rdfs:label 'Result Metric Value' ;
    rdfs:comment 'Numeric value of the primary result metric.' ;
    rdfs:domain ind:CaeSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resultOutcome rdf:type rdf:Property ;
    rdfs:label 'Result Outcome' ;
    rdfs:comment 'Pass/fail determination of the simulation against target criteria.' ;
    rdfs:domain ind:CaeSimulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Run Duration Seconds' ;
