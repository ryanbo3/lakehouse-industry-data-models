    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:price rdf:type rdf:Property ;
    rdfs:label 'Price' ;
    rdfs:comment 'Base price of the service before taxes or discounts.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provider rdf:type rdf:Property ;
    rdfs:label 'Provider' ;
    rdfs:comment 'Internal business unit or external partner delivering the service.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
