    rdfs:comment 'First calendar day of the period for which reliability metrics are calculated.' ;
    rdfs:domain ind:EquipmentReliability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalDowntimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Downtime Minutes' ;
    rdfs:comment 'Cumulative minutes the equipment was non-operational due to failures or planned maintenance within the reporting period.' ;
