    rdfs:comment 'Comma-separated list of action codes suggested by the diagnostic engine (e.g., repair steps, software patches).' ;
    rdfs:domain ind:RemoteDiagnosticSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteDiagnosticSessionStatus rdf:type rdf:Property ;
    rdfs:label 'Remote Diagnostic Session Status' ;
    rdfs:comment 'Current processing state of the remote diagnostic session.' ;
    rdfs:domain ind:RemoteDiagnosticSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionCode rdf:type rdf:Property ;
    rdfs:label 'Session Code' ;
    rdfs:comment 'External reference code for the diagnostic session, used in service logs and customer communications.' ;
    rdfs:domain ind:RemoteDiagnosticSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Timestamp' ;
    rdfs:comment 'Exact time the remote diagnostic session was started.' ;
    rdfs:domain ind:RemoteDiagnosticSession ;
    rdf:type owl:DatatypeProperty ;
