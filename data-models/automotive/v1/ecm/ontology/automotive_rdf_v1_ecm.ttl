    rdfs:comment 'Identifier of a recall campaign linked to this repair.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecallCampaign .

ind:serviceAdvisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Service Advisor Employee Id' ;
    rdfs:comment 'Identifier of the service advisor who created the repair order.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:technicianId rdf:type rdf:Property ;
    rdfs:label 'Technician Id' ;
    rdfs:comment 'Identifier of the primary technician assigned to perform the work.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Technician .

ind:vehicleOrderId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Order Id' ;
    rdfs:comment 'Foreign key linking to sales.vehicle_order. Business justification: Required for warranty eligibility and service cost attribution; repair orders must reference the original vehicle order to verify coverage and allocate service revenue.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleOrder .

ind:vehicleOwnershipId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Ownership Id' ;
    rdfs:comment 'Foreign key linking to customer.vehicle_ownership. Business justification: Service order processing uses the ownership record to confirm warranty coverage and apply owner-specific service rules.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleOwnership .

ind:actualCompletionTime rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Time' ;
    rdfs:comment 'Actual date and time when the repair was completed.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:aftersalesRepairOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Aftersales Repair Order Status' ;
    rdfs:comment 'Current lifecycle status of the repair order.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Appointment Arrival Timestamp' ;
    rdfs:comment 'Timestamp when the vehicle arrived at the service center.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Appointment Departure Timestamp' ;
    rdfs:comment 'Timestamp when the vehicle left the service center.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentScheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Appointment Scheduled Timestamp' ;
    rdfs:comment 'Date and time when the service appointment was scheduled.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Timestamp' ;
    rdfs:comment 'Date and time when the repair order was closed.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerFeedbackScore rdf:type rdf:Property ;
    rdfs:label 'Customer Feedback Score' ;
    rdfs:comment 'Numeric rating (1-5) provided by the customer after service.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerSignatureFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Signature Flag' ;
    rdfs:comment 'Indicates whether the customer signed off on the repair order.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diagnosticCode rdf:type rdf:Property ;
    rdfs:label 'Diagnostic Code' ;
    rdfs:comment 'Standard OBD diagnostic code recorded during service.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEstimate rdf:type rdf:Property ;
    rdfs:label 'Is Estimate' ;
    rdfs:comment 'Indicates whether the record is an estimate prior to work being performed.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborRatePerHour rdf:type rdf:Property ;
    rdfs:label 'Labor Rate Per Hour' ;
    rdfs:comment 'Standard labor rate applied per hour.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborTotalCost rdf:type rdf:Property ;
    rdfs:label 'Labor Total Cost' ;
    rdfs:comment 'Total cost of labor before taxes and discounts.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborTotalHours rdf:type rdf:Property ;
    rdfs:label 'Labor Total Hours' ;
    rdfs:comment 'Total labor hours recorded for the repair order.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mileageAtService rdf:type rdf:Property ;
    rdfs:label 'Mileage At Service' ;
    rdfs:comment 'Vehicle odometer reading at the time of service.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Final amount after tax and discount.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openTimestamp rdf:type rdf:Property ;
    rdfs:label 'Open Timestamp' ;
    rdfs:comment 'Date and time when the repair order was opened.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partsTotalCost rdf:type rdf:Property ;
    rdfs:label 'Parts Total Cost' ;
    rdfs:comment 'Total cost of parts consumed before taxes and discounts.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Method used by the customer to settle the repair order.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current status of the payment for the repair order.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedCompletionTime rdf:type rdf:Property ;
    rdfs:label 'Promised Completion Time' ;
    rdfs:comment 'Scheduled date and time promised to the customer for repair completion.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:roNumber rdf:type rdf:Property ;
    rdfs:label 'Ro Number' ;
    rdfs:comment 'External repair order number assigned by the service center.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCenterRegion rdf:type rdf:Property ;
    rdfs:label 'Service Center Region' ;
    rdfs:comment 'Geographic region where the service center is located.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceNotes rdf:type rdf:Property ;
    rdfs:label 'Service Notes' ;
    rdfs:comment 'Free-text notes entered by service advisor describing work performed.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePriority rdf:type rdf:Property ;
    rdfs:label 'Service Priority' ;
    rdfs:comment 'Priority level assigned to the repair order.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianNotes rdf:type rdf:Property ;
    rdfs:label 'Technician Notes' ;
    rdfs:comment 'Free-text notes entered by the technician during repair.' ;
    rdfs:domain ind:AftersalesRepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Number' ;
    rdfs:comment 'Reference number for the warranty claim associated with this repair.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyType rdf:type rdf:Property ;
    rdfs:label 'Warranty Type' ;
    rdfs:comment 'Type of warranty covering the repair.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Repair Order Line Id' ;
    rdfs:comment 'System-generated unique identifier for the repair order line.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RepairOrderLine .

ind:aftersalesServiceAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Aftersales Service Appointment Id' ;
    rdfs:comment 'Identifier of the service appointment linked to this line.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AftersalesServiceAppointment .

ind:aftersalesWarrantyClaimId rdf:type rdf:Property ;
    rdfs:label 'Aftersales Warranty Claim Id' ;
    rdfs:comment 'Identifier of the warranty claim associated with this line, if applicable.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AftersalesWarrantyClaim .

ind:batchRecordId rdf:type rdf:Property ;
    rdfs:label 'Batch Record Id' ;
    rdfs:comment 'Foreign key linking to inventory.batch_record. Business justification: REQUIRED: When batch-controlled parts are used in service, the batch_record must be recorded for quality and recall traceability.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRecord .

ind:inboundPartId rdf:type rdf:Property ;
    rdfs:label 'Inbound Part Id' ;
    rdfs:comment 'Foreign key linking to supply.inbound_part. Business justification: REQUIRED: Parts Traceability Report for warranty investigations needs to link each repair line to the inbound part record it originated from.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundPart .

ind:inboundShipmentId rdf:type rdf:Property ;
    rdfs:label 'Inbound Shipment Id' ;
    rdfs:comment 'Foreign key linking to supply.inbound_shipment. Business justification: REQUIRED: Repair Order Shipment Tracking report ties repaired parts to the specific inbound shipment they arrived on for logistics audit.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundShipment .

ind:serializedUnitId rdf:type rdf:Property ;
    rdfs:label 'Serialized Unit Id' ;
    rdfs:comment 'Foreign key linking to inventory.serialized_unit. Business justification: REQUIRED: Serialized components (e.g., battery modules) installed during repair need a FK to the serialized_unit for warranty and service history.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SerializedUnit .

ind:skuMasterId rdf:type rdf:Property ;
    rdfs:label 'Sku Master Id' ;
    rdfs:comment 'Foreign key linking to inventory.sku_master. Business justification: REQUIRED: Parts used in a repair order line must be tracked against the inventory SKU master for cost, stock deduction, and compliance reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuMaster .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: REQUIRED: Service parts are issued from a specific warehouse bin; linking to storage_location enables inventory location traceability for service.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:subletVendorId rdf:type rdf:Property ;
    rdfs:label 'Sublet Vendor Id' ;
    rdfs:comment 'Identifier of the external vendor performing the sublet work.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:actualTechnicianHours rdf:type rdf:Property ;
    rdfs:label 'Actual Technician Hours' ;
    rdfs:comment 'Actual labor hours logged by the technician for this line.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:causeComplaint rdf:type rdf:Property ;
    rdfs:label 'Cause Complaint' ;
    rdfs:comment 'Narrative describing the customer complaint or issue that initiated the service.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correction rdf:type rdf:Property ;
    rdfs:label 'Correction' ;
    rdfs:comment 'Narrative describing the corrective action taken to resolve the complaint.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborRate rdf:type rdf:Property ;
    rdfs:label 'Labor Rate' ;
    rdfs:comment 'Hourly labor rate applied to the technician for this operation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborSkillLevel rdf:type rdf:Property ;
    rdfs:label 'Labor Skill Level' ;
    rdfs:comment 'Skill level required for the technician to perform the operation.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborTimeStandard rdf:type rdf:Property ;
    rdfs:label 'Labor Time Standard' ;
    rdfs:comment 'Flat-rate standard labor time in hours for the operation code.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Flag' ;
    rdfs:comment 'True if overtime rates were applied to this labor line.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Multiplier' ;
    rdfs:comment 'Multiplier applied to the labor_rate when overtime_flag is true (e.g., 1.5).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partPrice rdf:type rdf:Property ;
    rdfs:label 'Part Price' ;
    rdfs:comment 'Standard price per unit of the part at the time of service.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partQuantity rdf:type rdf:Property ;
    rdfs:label 'Part Quantity' ;
    rdfs:comment 'Quantity of the part used for this line.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsUsedFlag rdf:type rdf:Property ;
    rdfs:label 'Parts Used Flag' ;
    rdfs:comment 'Indicates whether any parts were consumed on this line.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subletCost rdf:type rdf:Property ;
    rdfs:label 'Sublet Cost' ;
    rdfs:comment 'Total cost charged by the sublet vendor for this line.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subletFlag rdf:type rdf:Property ;
    rdfs:label 'Sublet Flag' ;
    rdfs:comment 'True if the work was performed by an external subcontractor.' ;
    rdfs:domain ind:RepairOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Timestamp when the service work was completed.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Timestamp when the vehicle actually entered service.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:aftersalesServiceAppointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Aftersales Service Appointment Status' ;
    rdfs:comment 'Current lifecycle status of the appointment.' ;
    rdfs:domain ind:AftersalesServiceAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentNumber rdf:type rdf:Property ;
    rdfs:label 'Appointment Number' ;
    rdfs:comment 'Business identifier assigned to the service appointment, used in dealer and customer communications.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentSource rdf:type rdf:Property ;
    rdfs:label 'Appointment Source' ;
    rdfs:comment 'Origin channel through which the appointment was booked.' ;
    rdfs:domain ind:AftersalesServiceAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bayNumber rdf:type rdf:Property ;
    rdfs:label 'Bay Number' ;
    rdfs:comment 'Identifier of the service bay where the vehicle will be serviced.' ;
    rdfs:domain ind:AftersalesServiceAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check In Timestamp' ;
    rdfs:comment 'Timestamp when the customer checked in at the service center.' ;
    rdfs:domain ind:AftersalesServiceAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'Current confirmation state of the appointment.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Planned length of the service appointment in minutes.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Gross Amount' ;
    rdfs:comment 'Projected total charge before taxes and discounts.' ;
    rdfs:domain ind:AftersalesServiceAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedNetAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Net Amount' ;
    rdfs:comment 'Projected total charge after taxes and discounts.' ;
    rdfs:domain ind:AftersalesServiceAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Tax Amount' ;
    rdfs:comment 'Projected tax component of the service charge.' ;
    rdfs:domain ind:AftersalesServiceAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Identifier of the invoice generated for the service appointment.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFirstTimeCustomer rdf:type rdf:Property ;
    rdfs:label 'Is First Time Customer' ;
    rdfs:comment 'True if this is the customer\'s first service appointment with the dealer.' ;
    rdfs:domain ind:AftersalesServiceAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeatService rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Service' ;
    rdfs:comment 'True if the vehicle has previously received the same service type.' ;
    rdfs:domain ind:AftersalesServiceAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborTimeActualMinutes rdf:type rdf:Property ;
    rdfs:label 'Labor Time Actual Minutes' ;
    rdfs:comment 'Actual labor minutes recorded for the service.' ;
    rdfs:domain ind:AftersalesServiceAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:noShowFlag rdf:type rdf:Property ;
    rdfs:label 'No Show Flag' ;
    rdfs:comment 'Indicates whether the customer failed to appear for the scheduled appointment.' ;
    rdfs:domain ind:AftersalesServiceAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partsActualAmount rdf:type rdf:Property ;
    rdfs:label 'Parts Actual Amount' ;
    rdfs:comment 'Total cost of parts actually used during service.' ;
    rdfs:domain ind:AftersalesServiceAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'True if the appointment is part of a manufacturer recall campaign.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredPartsFlag rdf:type rdf:Property ;
    rdfs:label 'Required Parts Flag' ;
    rdfs:comment 'Indicates whether specific parts must be ordered before the appointment.' ;
    rdfs:domain ind:AftersalesServiceAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Timestamp' ;
    rdfs:comment 'Planned date and time when the service is to start.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'Higher-level grouping of the service (e.g., oil change, brake service, battery replacement).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalActualAmount rdf:type rdf:Property ;
    rdfs:label 'Total Actual Amount' ;
    rdfs:comment 'Final charge for the appointment after labor, parts, taxes, and discounts.' ;
    rdfs:domain ind:AftersalesServiceAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportationOption rdf:type rdf:Property ;
    rdfs:label 'Transportation Option' ;
    rdfs:comment 'Customer transportation provision during service.' ;
    rdfs:domain ind:AftersalesServiceAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleMileage rdf:type rdf:Property ;
    rdfs:label 'Vehicle Mileage' ;
    rdfs:comment 'Odometer reading at the time of service appointment.' ;
    rdfs:domain ind:AftersalesServiceAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_campaign. Business justification: Service campaigns are often launched from sales campaigns; linking tracks campaign effectiveness and regulatory reporting across domains.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:vehicleProgramId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Program Id' ;
    rdfs:comment 'Foreign key linking to engineering.vehicle_program. Business justification: Service campaigns are planned per vehicle program; linking enables program-level impact analysis and regulatory reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleProgram .

ind:affectedModelYearEnd rdf:type rdf:Property ;
    rdfs:label 'Affected Model Year End' ;
    rdfs:comment 'Last model year in the range of vehicles covered.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedModelYearStart rdf:type rdf:Property ;
    rdfs:label 'Affected Model Year Start' ;
    rdfs:comment 'First model year in the range of vehicles covered.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedVinPopulation rdf:type rdf:Property ;
    rdfs:label 'Affected Vin Population' ;
    rdfs:comment 'Estimated count of VINs that fall within the campaign scope.' ;
    rdfs:domain ind:ServiceCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Campaign Cost Estimate' ;
    rdfs:comment 'Projected total cost to execute the campaign (currency assumed USD).' ;
    rdfs:domain ind:ServiceCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignNotes rdf:type rdf:Property ;
    rdfs:label 'Campaign Notes' ;
    rdfs:comment 'Free-form notes or comments from campaign managers.' ;
    rdfs:domain ind:ServiceCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignPriority rdf:type rdf:Property ;
    rdfs:label 'Campaign Priority' ;
    rdfs:comment 'Priority level for resource allocation and scheduling.' ;
    rdfs:domain ind:ServiceCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignRegion rdf:type rdf:Property ;
    rdfs:label 'Campaign Region' ;
    rdfs:comment 'Primary geographic region(s) affected; uses ISO-3 country codes.' ;
    rdfs:domain ind:ServiceCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle status of the campaign.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the campaign: safety recall, emissions recall, customer satisfaction program, or technical service bulletin action.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Flag' ;
    rdfs:comment 'True if the campaign is a voluntary customer-satisfaction program.' ;
    rdfs:domain ind:ServiceCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date when the campaign is closed or no longer applicable (nullable).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date when the campaign becomes effective for affected vehicles.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsRecallFlag rdf:type rdf:Property ;
    rdfs:label 'Emissions Recall Flag' ;
    rdfs:comment 'True if the campaign addresses emissions compliance.' ;
    rdfs:domain ind:ServiceCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedRepairTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Repair Time Minutes' ;
    rdfs:comment 'Average time, in minutes, required to complete the repair per vehicle.' ;
    rdfs:domain ind:ServiceCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nhtsaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Nhtsa Compliance Flag' ;
    rdfs:comment 'Indicates whether the campaign meets NHTSA requirements.' ;
    rdfs:domain ind:ServiceCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partsCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Parts Cost Estimate' ;
    rdfs:comment 'Estimated cost of parts required for the campaign.' ;
    rdfs:domain ind:ServiceCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsRequired rdf:type rdf:Property ;
    rdfs:label 'Parts Required' ;
    rdfs:comment 'Comma-separated list of part numbers needed to perform the remedy.' ;
    rdfs:domain ind:ServiceCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Date' ;
    rdfs:comment 'Date on which the campaign was reported to the regulator.' ;
    rdfs:domain ind:ServiceCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportingStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Status' ;
    rdfs:comment 'Current status of the campaign\'s regulatory filing with NHTSA/UNECE.' ;
    rdfs:domain ind:ServiceCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remedyDescription rdf:type rdf:Property ;
    rdfs:label 'Remedy Description' ;
    rdfs:comment 'Detailed description of the repair or corrective action required.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRecallFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Recall Flag' ;
    rdfs:comment 'True if the campaign is a safety-related recall.' ;
    rdfs:domain ind:ServiceCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalServiceBulletinFlag rdf:type rdf:Property ;
    rdfs:label 'Technical Service Bulletin Flag' ;
    rdfs:comment 'True if the campaign originates from a TSB.' ;
    rdfs:domain ind:ServiceCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uneceComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Unece Compliance Flag' ;
    rdfs:comment 'Indicates whether the campaign meets UNECE regulations.' ;
    rdfs:domain ind:ServiceCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Impact Flag' ;
    rdfs:comment 'Indicates whether the campaign affects warranty coverage.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:functionalLocationId rdf:type rdf:Property ;
    rdfs:label 'Functional Location Id' ;
    rdfs:comment 'Foreign key linking to asset.functional_location. Business justification: Facility Management report links each service center to its functional location for maintenance planning and OEE aggregation, a standard practice in automotive manufacturing.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunctionalLocation .

ind:geofenceId rdf:type rdf:Property ;
    rdfs:label 'Geofence Id' ;
    rdfs:comment 'Foreign key linking to mobility.geofence. Business justification: Service Center Geofence defines the service area for mobile service teams and is used in routing and compliance reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Geofence .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Links each service center to its manager employee for operational oversight and manager performance reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:plantId rdf:type rdf:Property ;
    rdfs:label 'Plant Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.plant. Business justification: Service Center performance dashboard aggregates service metrics by originating plant for warranty and recall analysis.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:adasCalibrationAuthorized rdf:type rdf:Property ;
    rdfs:label 'Adas Calibration Authorized' ;
    rdfs:comment 'Indicates whether the center can calibrate Advanced Driver Assistance Systems.' ;
    rdfs:domain ind:ServiceCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address of the service center.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address information (suite, floor, etc.).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Authorization Level' ;
    rdfs:comment 'Combined classification of services the center is authorized to perform.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageServiceTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Service Time Minutes' ;
    rdfs:comment 'Mean duration from service order start to completion, expressed in minutes.' ;
    rdfs:domain ind:ServiceCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City where the service center is located.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collisionAuthorized rdf:type rdf:Property ;
    rdfs:label 'Collision Authorized' ;
    rdfs:comment 'Indicates whether the center is certified to perform collision repairs.' ;
    rdfs:domain ind:ServiceCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:country rdf:type rdf:Property ;
    rdfs:label 'Country' ;
    rdfs:comment 'Three-letter ISO country code.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dskInstanceCode rdf:type rdf:Property ;
    rdfs:label 'Dsk Instance Code' ;
    rdfs:comment 'Identifier of the CDK Global DMS instance that manages this service center.' ;
    rdfs:domain ind:ServiceCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evCertified rdf:type rdf:Property ;
    rdfs:label 'Ev Certified' ;
    rdfs:comment 'Indicates whether the center is qualified to service electric vehicles.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iatfCertified rdf:type rdf:Property ;
    rdfs:label 'Iatf Certified' ;
    rdfs:comment 'Indicates compliance with IATF 16949 quality management standards.' ;
    rdfs:domain ind:ServiceCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryCenter rdf:type rdf:Property ;
    rdfs:label 'Is Primary Center' ;
    rdfs:comment 'Indicates if this center is the primary hub for its dealer group.' ;
    rdfs:domain ind:ServiceCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso9001 Certified' ;
    rdfs:comment 'Indicates compliance with ISO 9001 quality management standards.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date when the most recent compliance audit was performed.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Latitude coordinate of the service center location.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loanerFleetSize rdf:type rdf:Property ;
    rdfs:label 'Loaner Fleet Size' ;
    rdfs:comment 'Number of loaner vehicles maintained for customer use.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Longitude coordinate of the service center location.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:market rdf:type rdf:Property ;
    rdfs:label 'Market' ;
    rdfs:comment 'Market segment served (e.g., premium, mass-market, commercial).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkStatus rdf:type rdf:Property ;
    rdfs:label 'Network Status' ;
    rdfs:comment 'Current participation status of the center in the OEM service network.' ;
    rdfs:domain ind:ServiceCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard weekly operating hours (e.g., Mon-Fri 08:00-18:00).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallAuthorized rdf:type rdf:Property ;
    rdfs:label 'Recall Authorized' ;
    rdfs:comment 'Indicates whether the center can execute manufacturer recall campaigns.' ;
    rdfs:domain ind:ServiceCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status' ;
    rdfs:comment 'Current status of the center\'s compliance with automotive regulations.' ;
    rdfs:domain ind:ServiceCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceBayCount rdf:type rdf:Property ;
    rdfs:label 'Service Bay Count' ;
    rdfs:comment 'Total count of service bays available for vehicle work.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceCenterCode rdf:type rdf:Property ;
    rdfs:label 'Service Center Code' ;
    rdfs:comment 'External business code used to reference the service center in dealer and OEM systems.' ;
    rdfs:domain ind:ServiceCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCenterName rdf:type rdf:Property ;
    rdfs:label 'Service Center Name' ;
    rdfs:comment 'Human-readable name of the authorized service center.' ;
    rdfs:domain ind:ServiceCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCenterType rdf:type rdf:Property ;
    rdfs:label 'Service Center Type' ;
    rdfs:comment 'Category of the service center based on ownership and relationship to OEM.' ;
    rdfs:domain ind:ServiceCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceOrdersProcessed rdf:type rdf:Property ;
    rdfs:label 'Service Orders Processed' ;
    rdfs:comment 'Cumulative count of service orders completed at the center.' ;
    rdfs:domain ind:ServiceCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:state rdf:type rdf:Property ;
    rdfs:label 'State' ;
    rdfs:comment 'State or province abbreviation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianHeadcount rdf:type rdf:Property ;
    rdfs:label 'Technician Headcount' ;
    rdfs:comment 'Number of technicians employed at the service center.' ;
    rdfs:domain ind:ServiceCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyAuthorized rdf:type rdf:Property ;
    rdfs:label 'Warranty Authorized' ;
    rdfs:comment 'Indicates whether the center can perform warranty repairs.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyClaimsProcessed rdf:type rdf:Property ;
    rdfs:label 'Warranty Claims Processed' ;
    rdfs:comment 'Cumulative count of warranty claims handled by the center.' ;
    rdfs:domain ind:ServiceCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceContractId rdf:type rdf:Property ;
    rdfs:label 'Service Contract Id' ;
    rdfs:comment 'System-generated unique identifier for the service contract record.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceContract .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Foreign key linking to sales.sales_contract. Business justification: Service contracts extend the original sales contract; linking enables contract profitability analysis and compliance reporting across sales and aftersales.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:primaryServiceDealershipId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Dealership Id' ;
    rdfs:comment 'Identifier of the dealer that sold the service contract to the customer.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:serviceId rdf:type rdf:Property ;
    rdfs:label 'Service Id' ;
    rdfs:comment 'Foreign key linking to mobility.mobility_service. Business justification: OEM bundles connectivity services into service contracts; tracking which mobility service is included per contract is required for billing and compliance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Service .

ind:supplierContractId rdf:type rdf:Property ;
    rdfs:label 'Supplier Contract Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_contract. Business justification: Required for Service Contract Cost Allocation Report linking each service contract to its underlying supplier contract for cost tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierContract .

ind:transferToDealerDealershipId rdf:type rdf:Property ;
    rdfs:label 'Transfer To Dealer Dealership Id' ;
    rdfs:comment 'Identifier of the dealer that received the transferred contract.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:warrantyPolicyId rdf:type rdf:Property ;
    rdfs:label 'Warranty Policy Id' ;
    rdfs:comment 'Foreign key linking to aftersales.warranty_policy. Business justification: A service contract defines coverage based on a warranty policy; linking to warranty_policy enables consistent policy lookup and eliminates redundant policy attributes in service_contract.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarrantyPolicy .

ind:administratorCode rdf:type rdf:Property ;
    rdfs:label 'Administrator Code' ;
    rdfs:comment 'Identifier of the entity (OEM or third-party) that administers the contract.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date on which the contract was formally cancelled, if applicable.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Free-text reason provided for contract cancellation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimCount rdf:type rdf:Property ;
    rdfs:label 'Claim Count' ;
    rdfs:comment 'Total number of service claims submitted under this contract.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractDescription rdf:type rdf:Property ;
    rdfs:label 'Contract Description' ;
    rdfs:comment 'Free-text description of the contract terms and conditions.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Category of coverage provided by the service contract.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageMileageLimit rdf:type rdf:Property ;
    rdfs:label 'Coverage Mileage Limit' ;
    rdfs:comment 'Maximum mileage (kilometres) covered under the contract.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount' ;
    rdfs:comment 'Fixed amount the customer must pay per claim before the contract pays.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRefundable rdf:type rdf:Property ;
    rdfs:label 'Is Refundable' ;
    rdfs:comment 'Indicates whether the contract value is refundable upon early termination.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTransferable rdf:type rdf:Property ;
    rdfs:label 'Is Transferable' ;
    rdfs:comment 'Indicates whether the contract may be transferred to another dealer or owner.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastClaimDate rdf:type rdf:Property ;
    rdfs:label 'Last Claim Date' ;
    rdfs:comment 'Date of the most recent claim filed against the contract.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mileageUsed rdf:type rdf:Property ;
    rdfs:label 'Mileage Used' ;
    rdfs:comment 'Total mileage recorded on the vehicle while the contract was active.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netContractValue rdf:type rdf:Property ;
    rdfs:label 'Net Contract Value' ;
    rdfs:comment 'Final contract value after applying discounts and taxes.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermCode rdf:type rdf:Property ;
    rdfs:label 'Payment Term Code' ;
    rdfs:comment 'Standard payment term applied to the contract invoice.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'True if the contract complies with all applicable automotive regulatory requirements.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Scheduled date for contract renewal if renewal_option is not \'none\'.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalOption rdf:type rdf:Property ;
    rdfs:label 'Renewal Option' ;
    rdfs:comment 'Policy for contract renewal: automatic, manual, or none.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceContractStatus rdf:type rdf:Property ;
    rdfs:label 'Service Contract Status' ;
    rdfs:comment 'Current lifecycle state of the service contract.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'Gross monetary value of the contract at the time of sale.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Date' ;
    rdfs:comment 'Date when the contract ownership was transferred to another dealer or party.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceContractClaimId rdf:type rdf:Property ;
    rdfs:label 'Service Contract Claim Id' ;
    rdfs:comment 'System-generated unique identifier for the service contract claim record.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceContractClaim .

ind:claimSubmittedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Claim Submitted By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Tracks which employee submitted each service contract claim for audit and performance metrics.' ;
    rdfs:domain ind:ServiceContractClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustedAmount rdf:type rdf:Property ;
    rdfs:label 'Adjusted Amount' ;
    rdfs:comment 'Amount of monetary adjustment applied to the approved claim.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimAdjustedFlag rdf:type rdf:Property ;
    rdfs:label 'Claim Adjusted Flag' ;
    rdfs:comment 'Indicates whether the claim amount has been adjusted after initial approval.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimAdjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Claim Adjustment Reason' ;
    rdfs:comment 'Reason provided for any monetary adjustment to the claim.' ;
    rdfs:domain ind:ServiceContractClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimCategory rdf:type rdf:Property ;
    rdfs:label 'Claim Category' ;
    rdfs:comment 'High-level classification of the claim type.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimClosureDate rdf:type rdf:Property ;
    rdfs:label 'Claim Closure Date' ;
    rdfs:comment 'Date when the claim was closed or paid.' ;
    rdfs:domain ind:ServiceContractClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Claim Created Timestamp' ;
    rdfs:comment 'Timestamp when the claim record was first created in the system.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:claimEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Claim Effective Date' ;
    rdfs:comment 'Date on which the claim becomes effective for processing.' ;
    rdfs:domain ind:ServiceContractClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimLineItemCount rdf:type rdf:Property ;
    rdfs:label 'Claim Line Item Count' ;
    rdfs:comment 'Number of individual line items (parts, labor, etc.) associated with the claim.' ;
    rdfs:domain ind:ServiceContractClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'External reference number assigned to the claim by the service contract system.' ;
