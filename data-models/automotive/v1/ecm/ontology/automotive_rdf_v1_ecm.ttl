    rdfs:comment 'Condition of the vehicle at handover: new, used, reconditioned, or damaged.' ;
    rdfs:domain ind:VehicleHandover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Handover Fee Amount' ;
    rdfs:comment 'Gross fee charged for the handover service.' ;
