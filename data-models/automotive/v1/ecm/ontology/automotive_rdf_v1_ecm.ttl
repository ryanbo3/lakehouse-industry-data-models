ind:recallType rdf:type rdf:Property ;
    rdfs:label 'Recall Type' ;
    rdfs:comment 'Category of the recall or campaign.' ;
    rdfs:domain ind:CampaignVin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remedyCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Remedy Completion Date' ;
    rdfs:comment 'Date when the remedy was completed.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remedyStatus rdf:type rdf:Property ;
    rdfs:label 'Remedy Status' ;
    rdfs:comment 'Current status of the remedy execution.' ;
    rdfs:domain ind:CampaignVin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledServiceDate rdf:type rdf:Property ;
