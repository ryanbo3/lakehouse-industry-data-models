# --- Attribute Properties ---
ind:campaignVinId rdf:type rdf:Property ;
    rdfs:label 'Campaign Vin Id' ;
    rdfs:comment 'Surrogate primary key for the campaign VIN association record.' ;
    rdfs:domain ind:CampaignVin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceCampaignId rdf:type rdf:Property ;
    rdfs:label 'Service Campaign Id' ;
    rdfs:comment 'Foreign key linking to aftersales.service_campaign. Business justification: Campaign VIN records need to be linked to the parent service campaign for proper campaign tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCampaign .

ind:vinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Vin Registry Id' ;
    rdfs:comment 'Foreign key linking to vehicle.vin_registry. Business justification: Associates vehicles with recall or service campaigns, enabling campaign effectiveness reporting and regulatory compliance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VinRegistry .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Code identifying the service campaign or recall.' ;
    rdfs:domain ind:CampaignVin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignDescription rdf:type rdf:Property ;
    rdfs:label 'Campaign Description' ;
    rdfs:comment 'Brief description of the campaign purpose and remedy.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'Regulatory compliance deadline for completing the remedy.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Regulatory compliance status for the vehicle.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the campaign VIN record was created.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dealerCode rdf:type rdf:Property ;
    rdfs:label 'Dealer Code' ;
    rdfs:comment 'Identifier of the dealer where remedy was performed.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCritical rdf:type rdf:Property ;
    rdfs:label 'Is Critical' ;
    rdfs:comment 'Flag indicating if the campaign is classified as critical safety.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborRateUsdPerHour rdf:type rdf:Property ;
    rdfs:label 'Labor Rate Usd Per Hour' ;
    rdfs:comment 'Labor rate applied for the remedy in USD per hour.' ;
    rdfs:domain ind:CampaignVin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborTimeHours rdf:type rdf:Property ;
    rdfs:label 'Labor Time Hours' ;
    rdfs:comment 'Labor time recorded for the remedy in hours.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastServiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Service Date' ;
    rdfs:comment 'Date of the most recent service performed on the vehicle.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text notes entered by the service technician.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date when the vehicle was notified about the campaign.' ;
