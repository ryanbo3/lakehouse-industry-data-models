    rdfs:range xsd:string .

ind:dtcCategory rdf:type rdf:Property ;
    rdfs:label 'Dtc Category' ;
    rdfs:comment 'High-level functional area the DTC belongs to.' ;
    rdfs:domain ind:AftersalesDtcEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dtcCode rdf:type rdf:Property ;
    rdfs:label 'Dtc Code' ;
