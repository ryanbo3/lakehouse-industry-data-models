ind:commandType rdf:type rdf:Property ;
    rdfs:label 'Command Type' ;
    rdfs:comment 'Category of command sent to the vehicle (e.g., remote start, lock/unlock, climate pre-conditioning, horn/lights, charge scheduling, speed limit set).' ;
    rdfs:domain ind:RemoteCommand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Date-time when the command was successfully delivered to the vehicle\'s telematics unit.' ;
