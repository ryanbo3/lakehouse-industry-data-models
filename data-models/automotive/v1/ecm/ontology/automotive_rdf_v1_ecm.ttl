ind:designSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Design Specification Id' ;
    rdfs:comment 'Foreign key linking to engineering.design_specification. Business justification: Technical Service Bulletins are issued based on design specifications; the link provides traceability for compliance audits.' ;
