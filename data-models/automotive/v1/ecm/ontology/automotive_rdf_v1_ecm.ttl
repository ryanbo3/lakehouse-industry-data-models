ind:paymentTriggerType rdf:type rdf:Property ;
    rdfs:label 'Payment Trigger Type' ;
    rdfs:comment 'Mechanism that triggers incentive payment (e.g., volume threshold).' ;
    rdfs:domain ind:DealerIncentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBudget rdf:type rdf:Property ;
    rdfs:label 'Total Budget' ;
    rdfs:comment 'Maximum total monetary budget allocated for the program.' ;
