ind:documentLanguage rdf:type rdf:Property ;
    rdfs:label 'Document Language' ;
    rdfs:comment 'Language key of the document (e.g., EN, DE).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'Type of exchange rate (e.g., M – average, G – spot).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'True if the entry is part of an intercompany transaction.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAdjustment rdf:type rdf:Property ;
    rdfs:label 'Is Adjustment' ;
    rdfs:comment 'Indicates whether the entry is an adjusting entry (e.g., accrual).' ;
