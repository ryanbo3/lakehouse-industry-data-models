    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isManualEntry rdf:type rdf:Property ;
    rdfs:label 'Is Manual Entry' ;
    rdfs:comment 'True if the entry was entered manually rather than by automated process.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTestEntry rdf:type rdf:Property ;
    rdfs:label 'Is Test Entry' ;
    rdfs:comment 'True if the entry is a test or simulation record.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:journalEntryStatus rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Status' ;
    rdfs:comment 'Current processing status of the journal entry.' ;
    rdfs:domain ind:JournalEntry ;
