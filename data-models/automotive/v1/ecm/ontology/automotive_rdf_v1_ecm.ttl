    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBudgeted rdf:type rdf:Property ;
    rdfs:label 'Is Budgeted' ;
    rdfs:comment 'True if the account has an associated budget for the fiscal year.' ;
    rdfs:domain ind:GlAccount ;
