ind:dtcRelatedPartNumber rdf:type rdf:Property ;
    rdfs:label 'Dtc Related Part Number' ;
    rdfs:comment 'Part number of the component replaced or inspected for the DTC.' ;
    rdfs:domain ind:AftersalesDtcEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dtcResolutionCode rdf:type rdf:Property ;
