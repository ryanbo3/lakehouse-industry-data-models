ind:measurementRangeMax rdf:type rdf:Property ;
    rdfs:label 'Measurement Range Max' ;
    rdfs:comment 'Maximum measurable value of the gauge according to its specification.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementRangeMin rdf:type rdf:Property ;
    rdfs:label 'Measurement Range Min' ;
    rdfs:comment 'Minimum measurable value of the gauge according to its specification.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'Scheduled date for the next required calibration of the gauge.' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:associatedFmeaId rdf:type rdf:Property ;
    rdfs:label 'Associated Fmea Id' ;
    rdfs:comment 'Link to the Process FMEA that this control plan supports.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fmea .

ind:associatedPfmeaFmeaId rdf:type rdf:Property ;
    rdfs:label 'Associated Pfmea Fmea Id' ;
    rdfs:comment 'Link to the Process FMEA that this control plan supports.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fmea .

ind:primaryControlInspectionPlanId rdf:type rdf:Property ;
    rdfs:label 'Primary Control Inspection Plan Id' ;
    rdfs:comment 'Link to the detailed inspection plan referenced by this control plan.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionPlan .

ind:changeControlNumber rdf:type rdf:Property ;
    rdfs:label 'Change Control Number' ;
    rdfs:comment 'Reference number for the change control record associated with this plan.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMethod rdf:type rdf:Property ;
    rdfs:label 'Control Method' ;
    rdfs:comment 'Statistical or inspection method used to control the characteristic.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlPlanDescription rdf:type rdf:Property ;
    rdfs:label 'Control Plan Description' ;
    rdfs:comment 'Free-text description of the purpose, scope, and key characteristics of the control plan.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Unit of measure for the control characteristic (e.g., mm, psi). [ENUM-REF-CANDIDATE: mm|cm|inch|mm2|g|kg|psi|kpa|percent — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactionPlan rdf:type rdf:Property ;
    rdfs:label 'Reaction Plan' ;
    rdfs:comment 'Defined corrective actions if a measurement falls outside specification limits.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleFrequency rdf:type rdf:Property ;
    rdfs:label 'Sample Frequency' ;
    rdfs:comment 'Frequency at which sampling is performed.' ;
    rdfs:domain ind:ControlPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of units inspected per sampling event as defined by the plan.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'Desired nominal value for the controlled characteristic.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedSystem rdf:type rdf:Property ;
    rdfs:label 'Affected System' ;
    rdfs:comment 'Vehicle system or subsystem impacted by the defect.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedZone rdf:type rdf:Property ;
    rdfs:label 'Affected Zone' ;
    rdfs:comment 'Physical zone of the vehicle where the defect occurs.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableStage rdf:type rdf:Property ;
    rdfs:label 'Applicable Stage' ;
    rdfs:comment 'Process stage(s) where the defect can be recorded.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether a corrective action is mandatory for this defect.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Estimate' ;
    rdfs:comment 'Estimated financial impact of the defect per occurrence.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectCodeCategory rdf:type rdf:Property ;
    rdfs:label 'Defect Code Category' ;
    rdfs:comment 'High-level classification of the defect type.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCodeCode rdf:type rdf:Property ;
    rdfs:label 'Defect Code Code' ;
    rdfs:comment 'Standardized alphanumeric identifier for the defect (e.g., D001).' ;
