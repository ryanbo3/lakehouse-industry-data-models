    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverTimestamp rdf:type rdf:Property ;
    rdfs:label 'Handover Timestamp' ;
    rdfs:comment 'Exact date and time when the handover event occurred.' ;
    rdfs:domain ind:VehicleHandover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:handoverType rdf:type rdf:Property ;
    rdfs:label 'Handover Type' ;
    rdfs:comment 'Classification of the handover scenario: dealer stock, retail customer, export, or import.' ;
    rdfs:domain ind:VehicleHandover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdiReference rdf:type rdf:Property ;
    rdfs:label 'Pdi Reference' ;
    rdfs:comment 'Reference identifier linking to the Pre-Delivery Inspection record.' ;
    rdfs:domain ind:VehicleHandover ;
    rdf:type owl:DatatypeProperty ;
