    rdfs:comment 'Current processing state of the tooling order.' ;
    rdfs:domain ind:ToolingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolingType rdf:type rdf:Property ;
    rdfs:label 'Tooling Type' ;
    rdfs:comment 'Category of tooling requested (e.g., die, mold, jig).' ;
    rdfs:domain ind:ToolingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tryoutScheduleDate rdf:type rdf:Property ;
    rdfs:label 'Tryout Schedule Date' ;
    rdfs:comment 'Planned date for the first production tryout of the tooling.' ;
    rdfs:domain ind:ToolingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bodyStyleId rdf:type rdf:Property ;
    rdfs:label 'Body Style Id' ;
    rdfs:comment 'Unique identifier for the body style definition. Primary key for the body style reference catalog.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BodyStyle .

ind:aerodynamicProfile rdf:type rdf:Property ;
    rdfs:label 'Aerodynamic Profile' ;
    rdfs:comment 'Classification of the body styles aerodynamic characteristics. Influences fuel economy, NVH performance, and powertrain calibration. Used in CFD analysis and performance modeling.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bedLengthInches rdf:type rdf:Property ;
    rdfs:label 'Bed Length Inches' ;
    rdfs:comment 'Length of the cargo bed for pickup truck body styles, measured in inches. Critical specification for commercial and fleet customers. Null for non-pickup body styles.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bedType rdf:type rdf:Property ;
    rdfs:label 'Bed Type' ;
    rdfs:comment 'Classification of pickup truck bed length category. Used in SKU construction and customer filtering. Set to not_applicable for non-pickup body styles.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyStructureType rdf:type rdf:Property ;
    rdfs:label 'Body Structure Type' ;
    rdfs:comment 'Fundamental structural architecture of the vehicle body (unibody vs body-on-frame). Determines manufacturing process, crash performance, NVH characteristics, and platform engineering decisions.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyStyleCategory rdf:type rdf:Property ;
    rdfs:label 'Body Style Category' ;
    rdfs:comment 'High-level body style classification grouping similar configurations. Used for portfolio analysis, market segmentation, and regulatory reporting aggregation. [ENUM-REF-CANDIDATE: sedan|coupe|hatchback|wagon|suv|crossover|pickup|van|convertible|roadster — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyStyleDescription rdf:type rdf:Property ;
    rdfs:label 'Body Style Description' ;
    rdfs:comment 'Detailed description of the body style including design characteristics, intended use case, and distinguishing features. Supports product marketing and customer education.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyStyleName rdf:type rdf:Property ;
    rdfs:label 'Body Style Name' ;
    rdfs:comment 'Human-readable name of the body style (e.g., 2-Door Coupe, 4-Door Sedan, Crew Cab Pickup, Extended Cab, SUV 3-Row, Cargo Van). Used in marketing materials, dealer systems, and customer-facing documentation.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyStyleStatus rdf:type rdf:Property ;
    rdfs:label 'Body Style Status' ;
    rdfs:comment 'Current lifecycle status of the body style definition. Active indicates current production availability. Used for SKU validation and order management system filtering.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabConfiguration rdf:type rdf:Property ;
    rdfs:label 'Cab Configuration' ;
    rdfs:comment 'Pickup truck cab style classification (regular cab, extended cab, crew cab, mega cab). Determines seating capacity and interior space. Set to not_applicable for non-pickup body styles.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoVolumeCubicFeet rdf:type rdf:Property ;
    rdfs:label 'Cargo Volume Cubic Feet' ;
    rdfs:comment 'Total cargo volume capacity in cubic feet for North American market specifications. Derived from liters but maintained separately for regional marketing and regulatory requirements.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoVolumeLiters rdf:type rdf:Property ;
    rdfs:label 'Cargo Volume Liters' ;
    rdfs:comment 'Total cargo volume capacity in liters measured according to SAE standards. Critical specification for commercial vehicles, SUVs, and vans. Used in competitive analysis and customer decision-making.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveSet rdf:type rdf:Property ;
    rdfs:label 'Competitive Set' ;
    rdfs:comment 'List of primary competitor vehicles that this body style competes against in the market. Used for benchmarking, feature parity analysis, and pricing strategy.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doorCount rdf:type rdf:Property ;
    rdfs:label 'Door Count' ;
    rdfs:comment 'Number of passenger doors on the vehicle body style. Critical for regulatory classification, insurance rating, and customer preference filtering. Excludes trunk/hatch/tailgate.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endModelYear rdf:type rdf:Property ;
    rdfs:label 'End Model Year' ;
    rdfs:comment 'Final model year this body style was available. Null for current production body styles. Used for EOP planning and service parts forecasting.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:generation rdf:type rdf:Property ;
    rdfs:label 'Generation' ;
    rdfs:comment 'Generation or version identifier for the body style design. Tracks major redesigns and facelifts. Used in parts interchangeability analysis and service documentation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundClearanceCategory rdf:type rdf:Property ;
    rdfs:label 'Ground Clearance Category' ;
    rdfs:comment 'Classification of ride height and ground clearance relative to segment norms. Impacts off-road capability, entry/exit ergonomics, and suspension tuning.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homologationClass rdf:type rdf:Property ;
    rdfs:label 'Homologation Class' ;
    rdfs:comment 'Regulatory vehicle classification code used for type approval and homologation processes. Varies by jurisdiction (UNECE, EPA, CARB). Critical for compliance and market entry.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCommercialVehicle rdf:type rdf:Property ;
    rdfs:label 'Is Commercial Vehicle' ;
    rdfs:comment 'Indicates whether this body style is classified as a commercial vehicle for regulatory, tax, and fleet sales purposes. Impacts CAFE exemptions and depreciation schedules.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLightTruck rdf:type rdf:Property ;
    rdfs:label 'Is Light Truck' ;
    rdfs:comment 'Indicates whether this body style is classified as a light truck for CAFE and EPA emissions standards. Impacts fuel economy requirements and regulatory compliance strategy.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPassengerVehicle rdf:type rdf:Property ;
    rdfs:label 'Is Passenger Vehicle' ;
    rdfs:comment 'Indicates whether this body style is classified as a passenger vehicle for regulatory and safety standard purposes. Determines applicable FMVSS requirements.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingComplexityScore rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Complexity Score' ;
    rdfs:comment 'Relative complexity rating (1-10 scale) for manufacturing this body style. Considers stamping complexity, welding operations, assembly sequence, and quality control requirements. Used in capacity planning and cost estimation.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketAvailability rdf:type rdf:Property ;
    rdfs:label 'Market Availability' ;
    rdfs:comment 'Geographic market regions where this body style is available for sale. Supports regional product portfolio management and market-specific homologation tracking. [ENUM-REF-CANDIDATE: global|north_america|europe|asia_pacific|china|latin_america|middle_east|africa — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrpBaseUsd rdf:type rdf:Property ;
    rdfs:label 'Msrp Base Usd' ;
    rdfs:comment 'Base MSRP for this body style in US dollars, excluding options, packages, and destination charges. Used for pricing strategy, competitive analysis, and dealer quoting systems. Confidential business data.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ncapBodyType rdf:type rdf:Property ;
    rdfs:label 'Ncap Body Type' ;
    rdfs:comment 'Body type classification used in NCAP safety testing and rating protocols. Determines applicable crash test procedures and rating methodology.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformCode rdf:type rdf:Property ;
    rdfs:label 'Platform Code' ;
    rdfs:comment 'Engineering platform identifier that this body style is built upon. Links to platform architecture, shared components, and engineering BOM. Critical for PLM integration and variant management.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roofType rdf:type rdf:Property ;
    rdfs:label 'Roof Type' ;
    rdfs:comment 'Classification of the roof structure and configuration. Impacts aerodynamics, structural engineering, manufacturing complexity, and customer appeal. Critical for BOM planning and option package definition. [ENUM-REF-CANDIDATE: fixed|convertible|targa|t-top|removable_panel|sunroof|panoramic — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatingCapacity rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity' ;
    rdfs:comment 'Maximum number of passenger seating positions designed into the body style. Used for regulatory compliance (CAFE standards), safety rating (NCAP), and customer filtering in configurators.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatingRowCount rdf:type rdf:Property ;
    rdfs:label 'Seating Row Count' ;
    rdfs:comment 'Number of seating rows in the body style (e.g., 2-row, 3-row). Important for SUV and crossover segmentation and customer preference analysis.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skuPrefix rdf:type rdf:Property ;
    rdfs:label 'Sku Prefix' ;
    rdfs:comment 'Standard prefix used in SKU construction for vehicles with this body style. Ensures consistent SKU formatting across order management, inventory, and dealer systems.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startModelYear rdf:type rdf:Property ;
    rdfs:label 'Start Model Year' ;
    rdfs:comment 'First model year this body style was introduced into production. Used for historical analysis, parts supersession, and product lifecycle tracking.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Target Customer Segment' ;
    rdfs:comment 'Primary customer demographic or psychographic segment this body style is designed to appeal to. Used in marketing strategy, feature prioritization, and portfolio positioning.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wheelbaseCategory rdf:type rdf:Property ;
    rdfs:label 'Wheelbase Category' ;
    rdfs:comment 'Classification of wheelbase length relative to the nameplate family. Impacts ride quality, cargo capacity, and maneuverability. Used in platform engineering and variant planning.' ;
    rdfs:domain ind:BodyStyle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomHeaderId rdf:type rdf:Property ;
    rdfs:label 'Bom Header Id' ;
    rdfs:comment 'Unique identifier for the BOM header record. Primary key for the commercial product-level BOM structure.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BomHeader .

ind:alternativeBomGroup rdf:type rdf:Property ;
    rdfs:label 'Alternative Bom Group' ;
    rdfs:comment 'Grouping identifier for alternative BOM configurations that serve the same functional purpose but differ in sourcing, supplier, or regional requirements. Supports supply chain flexibility and dual-sourcing strategies.' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationProfile rdf:type rdf:Property ;
    rdfs:label 'Configuration Profile' ;
    rdfs:comment 'A coded representation of the option and feature set included in this BOM. Used for variant configuration in SAP SD, dealer ordering systems (DMS), and customer configurators.' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectivityPackage rdf:type rdf:Property ;
    rdfs:label 'Connectivity Package' ;
    rdfs:comment 'The level of connected vehicle and telematics capability included in this BOM. Basic = 4G LTE; Premium = 5G with cloud services; V2X = Vehicle-to-Everything communication for smart city integration.' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'The date from which this BOM version becomes valid and applicable for production, sales configuration, and order fulfillment. Aligns with model year start or mid-year product refresh timing.' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'The date until which this BOM version remains valid. Nullable for open-ended BOMs. Used to manage model year transitions, End of Production (EOP), and product phase-out scenarios.' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engineeringReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Engineering Release Date' ;
    rdfs:comment 'The date on which the engineering design for this BOM was formally released from the Product Lifecycle Management (PLM) system (Teamcenter, Windchill) to manufacturing. Marks the transition from design to production readiness.' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotSizeMinimum rdf:type rdf:Property ;
    rdfs:label 'Lot Size Minimum' ;
    rdfs:comment 'The minimum production batch quantity for which this BOM is economically viable. Drives production scheduling, changeover planning, and capacity utilization in Manufacturing Execution Systems (MES).' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:msrpBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Msrp Base Amount' ;
    rdfs:comment 'The baseline MSRP for this BOM configuration before options, packages, and destination charges. Used for dealer pricing, customer quotations, and competitive positioning. Currency is USD unless otherwise specified in market-specific price books.' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyCertificationLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Level' ;
    rdfs:comment 'The crash test rating achieved by this BOM configuration from New Car Assessment Programme (NCAP) testing. Influences marketing claims, insurance premiums, and regulatory compliance in target markets.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Amount' ;
    rdfs:comment 'The planned manufacturing cost for this BOM at standard production volumes. Includes material, labor, and overhead. Used for margin analysis, make-vs-buy decisions, and financial planning. Currency is USD unless otherwise specified.' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAssemblyWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Assembly Weight Kg' ;
    rdfs:comment 'The cumulative weight of all components in this BOM, expressed in kilograms. Critical for vehicle curb weight calculation, Corporate Average Fuel Economy (CAFE) compliance, and freight logistics planning.' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalComponentCount rdf:type rdf:Property ;
    rdfs:label 'Total Component Count' ;
    rdfs:comment 'The total number of distinct component line items (BOM components) included in this BOM structure. Used for complexity assessment, supply chain planning, and Material Requirements Planning (MRP).' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vinPattern rdf:type rdf:Property ;
    rdfs:label 'Vin Pattern' ;
    rdfs:comment 'The VIN prefix or pattern template associated with this BOM configuration. Positions 1-11 of the VIN encode manufacturer, plant, model, and body style. Supports VIN decoding and vehicle domain linkage.' ;
    rdfs:domain ind:BomHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyProgramCode rdf:type rdf:Property ;
    rdfs:label 'Warranty Program Code' ;
    rdfs:comment 'The standard warranty coverage program applicable to this BOM configuration. Links to warranty claim processing, service bulletin distribution, and Total Cost of Ownership (TCO) calculations.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogPublicationId rdf:type rdf:Property ;
    rdfs:label 'Catalog Publication Id' ;
    rdfs:comment 'Unique identifier for the catalog publication event. Primary key.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogPublication .

ind:catalogVersionId rdf:type rdf:Property ;
    rdfs:label 'Catalog Version Id' ;
    rdfs:comment 'Reference to the specific catalog version being published. Links to the catalog version master.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogVersion .

ind:primaryCatalogEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Catalog Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that executed the publication event. Used for audit trail and accountability.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByPublicationCatalogPublicationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Publication Catalog Publication Id' ;
    rdfs:comment 'Reference to the newer publication that replaces this one, if applicable. Supports publication version chain tracking.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogPublication .

ind:approvedByUserName rdf:type rdf:Property ;
    rdfs:label 'Approved By User Name' ;
    rdfs:comment 'Full name of the approver for human-readable audit trail.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionConfirmationFlag rdf:type rdf:Property ;
    rdfs:label 'Distribution Confirmation Flag' ;
    rdfs:comment 'Indicates whether the target system has confirmed successful receipt and processing of the published catalog. True if confirmed, False if pending or failed.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionConfirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Distribution Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the target system confirmed successful receipt of the catalog publication. Nullable if confirmation is pending or not received.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distributionRetryCount rdf:type rdf:Property ;
    rdfs:label 'Distribution Retry Count' ;
    rdfs:comment 'Number of times the system attempted to distribute this catalog publication to the target system. Used for monitoring distribution reliability and troubleshooting failures.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileChecksum rdf:type rdf:Property ;
    rdfs:label 'File Checksum' ;
    rdfs:comment 'Cryptographic hash (e.g., MD5, SHA-256) of the published catalog file to ensure data integrity during transmission and detect corruption.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDistributionError rdf:type rdf:Property ;
    rdfs:label 'Last Distribution Error' ;
    rdfs:comment 'Error message or code from the most recent failed distribution attempt, if applicable. Supports troubleshooting and root cause analysis.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nameplateCount rdf:type rdf:Property ;
    rdfs:label 'Nameplate Count' ;
    rdfs:comment 'Number of distinct nameplates (vehicle model lines) included in this catalog publication. Supports publication scope tracking.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicationFormat rdf:type rdf:Property ;
    rdfs:label 'Publication Format' ;
    rdfs:comment 'Technical file or data format of the published catalog: Extensible Markup Language (XML), JavaScript Object Notation (JSON), Comma-Separated Values (CSV), Portable Document Format (PDF), Excel spreadsheet, Electronic Data Interchange (EDI) X12, EDIFACT, or proprietary format. [ENUM-REF-CANDIDATE: xml|json|csv|pdf|excel|edi_x12|edifact|proprietary — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationNotes rdf:type rdf:Property ;
    rdfs:label 'Publication Notes' ;
    rdfs:comment 'Free-text notes or comments about the publication event, including special instructions, known issues, or distribution details.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationNumber rdf:type rdf:Property ;
    rdfs:label 'Publication Number' ;
    rdfs:comment 'Business identifier for the publication event, formatted as PUB-YYYYMMDD-XXXXXX for external reference and audit trail.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationStatus rdf:type rdf:Property ;
    rdfs:label 'Publication Status' ;
    rdfs:comment 'Current lifecycle state of the publication: draft (in preparation), approved (ready for release), published (actively distributed), recalled (withdrawn due to error), superseded (replaced by newer version), or archived (historical record).' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationType rdf:type rdf:Property ;
    rdfs:label 'Publication Type' ;
    rdfs:comment 'Category of publication indicating the target audience: dealer ordering systems (DMS), consumer configurators, regulatory filings (NHTSA/EPA), internal sales tools, supplier portals, or fleet management systems.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedByUserName rdf:type rdf:Property ;
    rdfs:label 'Published By User Name' ;
    rdfs:comment 'Full name of the user who published the catalog, for human-readable audit trail and reporting.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallReason rdf:type rdf:Property ;
    rdfs:label 'Recall Reason' ;
    rdfs:comment 'Explanation for why the catalog publication was recalled or withdrawn, if applicable. Captures business justification for publication reversal.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recall Timestamp' ;
    rdfs:comment 'Date and time when the catalog publication was recalled or withdrawn. Part of the publication lifecycle audit trail.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordCount rdf:type rdf:Property ;
    rdfs:label 'Record Count' ;
    rdfs:comment 'Total number of catalog records (e.g., Stock Keeping Units (SKUs), configurations, options) included in this publication. Used for validation and reconciliation.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryFilingDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Date' ;
    rdfs:comment 'Date when the catalog was submitted to regulatory authorities, if applicable. Supports compliance audit trail.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Reference' ;
    rdfs:comment 'Reference number or identifier for the associated regulatory filing submission, if applicable. Links catalog publication to compliance documentation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required Flag' ;
    rdfs:comment 'Indicates whether this catalog publication requires submission to regulatory authorities (e.g., National Highway Traffic Safety Administration (NHTSA), Environmental Protection Agency (EPA), California Air Resources Board (CARB)). True if regulatory filing is required.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetChannel rdf:type rdf:Property ;
    rdfs:label 'Target Channel' ;
    rdfs:comment 'Distribution channel or interface through which the catalog is published: Dealer Management System (DMS), web configurator, mobile application, Application Programming Interface (API), File Transfer Protocol (FTP), Electronic Data Interchange (EDI), regulatory portal, or dealer portal. [ENUM-REF-CANDIDATE: dms|web_configurator|mobile_app|api|ftp|edi|regulatory_portal|dealer_portal — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCountryCode rdf:type rdf:Property ;
    rdfs:label 'Target Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the specific country market of this publication (e.g., USA, CAN, DEU, JPN). Supports country-specific catalog requirements and regulatory compliance.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSystem rdf:type rdf:Property ;
    rdfs:label 'Target System' ;
    rdfs:comment 'Name or identifier of the downstream system receiving this publication (e.g., CDK Global DMS, Salesforce Automotive Cloud, dealer portal, consumer configurator web application, NHTSA filing system).' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trimCount rdf:type rdf:Property ;
    rdfs:label 'Trim Count' ;
    rdfs:comment 'Number of distinct trim levels included in this catalog publication. Supports publication scope tracking and validation.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationErrorCount rdf:type rdf:Property ;
    rdfs:label 'Validation Error Count' ;
    rdfs:comment 'Number of validation errors detected during pre-publication quality checks. Zero indicates clean publication.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationWarningCount rdf:type rdf:Property ;
    rdfs:label 'Validation Warning Count' ;
    rdfs:comment 'Number of validation warnings (non-critical issues) detected during pre-publication quality checks.' ;
    rdfs:domain ind:CatalogPublication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:colorOptionId rdf:type rdf:Property ;
    rdfs:label 'Color Option Id' ;
    rdfs:comment 'Unique identifier for the color option. Primary key for the color option catalog.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ColorOption .

ind:colorAvailabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Color Availability Status' ;
    rdfs:comment 'Current lifecycle status of the color option. Controls visibility in configurators, order acceptance, and production scheduling. Phase-out colors may have restricted order windows.' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorCode rdf:type rdf:Property ;
    rdfs:label 'Color Code' ;
    rdfs:comment 'Manufacturer-assigned alphanumeric code uniquely identifying the color option. Used in Bill of Materials (BOM), production scheduling, and order management systems. Examples: WP9, B3Q, NH731P.' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorDescription rdf:type rdf:Property ;
    rdfs:label 'Color Description' ;
    rdfs:comment 'Detailed marketing description of the color option including visual characteristics, finish effects, and brand positioning. Used in sales literature, website content, and dealer training materials.' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorDurabilityRating rdf:type rdf:Property ;
    rdfs:label 'Color Durability Rating' ;
    rdfs:comment 'Qualitative assessment of color fade resistance and durability based on accelerated weathering tests. Influences warranty terms and customer expectations for long-term appearance retention.' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorFamily rdf:type rdf:Property ;
    rdfs:label 'Color Family' ;
    rdfs:comment 'Broad color category grouping for reporting, inventory management, and market analysis. Enables aggregation of similar colors across model years and nameplates. [ENUM-REF-CANDIDATE: white|black|gray|silver|red|blue|green|brown|beige|yellow|orange|other — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorImageUrl rdf:type rdf:Property ;
    rdfs:label 'Color Image Url' ;
    rdfs:comment 'Uniform Resource Locator (URL) to the digital asset management system hosting the color swatch or vehicle image in this color. Used in online configurators, mobile apps, and dealer portals.' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorMatchTolerance rdf:type rdf:Property ;
    rdfs:label 'Color Match Tolerance' ;
    rdfs:comment 'Acceptable color variation tolerance expressed in Delta E (ΔE) units or manufacturer-specific scale. Used in quality control, paint booth calibration, and supplier acceptance criteria.' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorName rdf:type rdf:Property ;
    rdfs:label 'Color Name' ;
    rdfs:comment 'Marketing name of the color option as presented to customers and dealers. Examples: Arctic White, Midnight Black, Crimson Red, Graphite Metallic.' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorType rdf:type rdf:Property ;
    rdfs:label 'Color Type' ;
    rdfs:comment 'Classification indicating whether the color option applies to exterior paint, interior trim/upholstery, or both. Determines applicability in vehicle configuration.' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Flag' ;
    rdfs:comment 'Indicates whether this color option meets all applicable environmental regulations including Volatile Organic Compound (VOC) limits, REACH, and RoHS directives. Required for regulatory reporting and market certification.' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:historicalSalesVolume rdf:type rdf:Property ;
    rdfs:label 'Historical Sales Volume' ;
    rdfs:comment 'Cumulative number of vehicles sold with this color option across all model years and nameplates. Used for demand forecasting, inventory planning, and portfolio optimization. Confidential business metric.' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interiorMaterialType rdf:type rdf:Property ;
    rdfs:label 'Interior Material Type' ;
    rdfs:comment 'Material composition for interior color options. Applicable only when color_type is interior or both. Drives Bill of Materials (BOM) component selection and supplier sourcing. [ENUM-REF-CANDIDATE: cloth|leather|synthetic_leather|premium_leather|alcantara|vinyl|suede|not_applicable — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Marketing Priority Rank' ;
    rdfs:comment 'Relative priority ranking for marketing and promotional activities. Lower numbers indicate higher priority. Used to determine featured colors in advertising, configurator defaults, and showroom displays.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:msrpUpliftAmount rdf:type rdf:Property ;
    rdfs:label 'Msrp Uplift Amount' ;
    rdfs:comment 'Additional charge in base currency for selecting this color option above the standard color. Zero for no-charge colors. Used in pricing configuration and dealer quotation systems.' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageCompatibility rdf:type rdf:Property ;
    rdfs:label 'Package Compatibility' ;
    rdfs:comment 'Comma-separated list of option package codes that are compatible or required with this color option. Supports complex configuration dependencies and upsell strategies.' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paintCodeSupplier rdf:type rdf:Property ;
    rdfs:label 'Paint Code Supplier' ;
    rdfs:comment 'Supplier-specific paint code or formula reference used in procurement and quality control. Links to supplier master data and Production Part Approval Process (PPAP) documentation.' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paintTechnology rdf:type rdf:Property ;
    rdfs:label 'Paint Technology' ;
    rdfs:comment 'Paint finish technology and application method. Impacts manufacturing process complexity, cost, and visual appearance. Tri-coat and multi-stage finishes require additional production steps.' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionCostDelta rdf:type rdf:Property ;
    rdfs:label 'Production Cost Delta' ;
    rdfs:comment 'Incremental manufacturing cost for this color option compared to base color. Used in margin analysis, Total Cost of Ownership (TCO) calculations, and profitability reporting. Confidential business data.' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regionalAvailability rdf:type rdf:Property ;
    rdfs:label 'Regional Availability' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes or region codes where this color option is offered. Supports market-specific color strategies and regulatory compliance. Example: USA,CAN,MEX or EMEA.' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Special Order Flag' ;
    rdfs:comment 'Indicates whether this color option requires special order processing with extended lead times. True for low-volume or custom colors not stocked in standard production flow.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:touchUpPaintAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Touch Up Paint Available Flag' ;
    rdfs:comment 'Indicates whether touch-up paint kits are available through after-sales parts channels for this color option. Supports service operations and customer self-repair.' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trimLevelCompatibility rdf:type rdf:Property ;
    rdfs:label 'Trim Level Compatibility' ;
    rdfs:comment 'Comma-separated list of trim level codes or names for which this color option is available. Enforces configuration rules in order management and prevents invalid SKU (Stock Keeping Unit) combinations.' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vocContentGramsPerLiter rdf:type rdf:Property ;
    rdfs:label 'Voc Content Grams Per Liter' ;
    rdfs:comment 'Volatile Organic Compound content measured in grams per liter for paint formulation. Required for Environmental Protection Agency (EPA) and California Air Resources Board (CARB) compliance reporting.' ;
    rdfs:domain ind:ColorOption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featureContentId rdf:type rdf:Property ;
    rdfs:label 'Feature Content Id' ;
    rdfs:comment 'Unique identifier for the feature content record. Primary key.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aftersalesTrimLevelId rdf:type rdf:Property ;
    rdfs:label 'Aftersales Trim Level Id' ;
    rdfs:comment 'Foreign key linking to product.trim_level. Business justification: Feature content is defined per trim level; linking provides a proper hierarchy and removes any need for duplicate trim identifiers in feature_content.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AftersalesTrimLevel .

ind:availabilityType rdf:type rdf:Property ;
    rdfs:label 'Availability Type' ;
    rdfs:comment 'Indicates whether the feature is included as standard equipment, available as a standalone option, only available within a package, or not available for a given trim or market.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentSourceCode rdf:type rdf:Property ;
    rdfs:label 'Content Source Code' ;
    rdfs:comment 'Unique identifier of this feature content record in the source system, used for traceability and data lineage.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Content Source System' ;
    rdfs:comment 'Name of the source system from which this feature content record originates, such as PLM (Product Lifecycle Management), PIM (Product Information Management), or marketing content management system.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerDemandScore rdf:type rdf:Property ;
    rdfs:label 'Customer Demand Score' ;
    rdfs:comment 'Quantitative score (0-100) representing customer demand or take-rate for this feature based on market research, configurator analytics, and sales data. Used for product planning and inventory optimization.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealerCostImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Dealer Cost Impact Amount' ;
    rdfs:comment 'The incremental dealer invoice cost when this feature is included. Used for dealer margin calculations and incentive program design.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ecuDependencyFlag rdf:type rdf:Property ;
    rdfs:label 'Ecu Dependency Flag' ;
    rdfs:comment 'Boolean flag indicating whether this feature requires specific ECU (Electronic Control Unit) hardware or software configuration. Used for manufacturing planning and service diagnostics.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:featureCategory rdf:type rdf:Property ;
    rdfs:label 'Feature Category' ;
    rdfs:comment 'High-level classification of the feature grouping for marketing segmentation and consumer navigation. Categories align with consumer decision-making patterns.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureDescriptionLong rdf:type rdf:Property ;
    rdfs:label 'Feature Description Long' ;
    rdfs:comment 'Comprehensive consumer-facing description of the feature including benefits, technical highlights, and usage scenarios. Used in brochures, website detail pages, and dealer training materials.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureDescriptionShort rdf:type rdf:Property ;
    rdfs:label 'Feature Description Short' ;
    rdfs:comment 'Brief consumer-facing description of the feature, typically 50-100 characters, used in configurator tooltips and mobile applications.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureStatus rdf:type rdf:Property ;
    rdfs:label 'Feature Status' ;
    rdfs:comment 'Current lifecycle status of the feature content record. Active features are available for configuration; discontinued features are retained for historical reference; pending features are awaiting approval; under_review features are being evaluated for changes.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureSubcategory rdf:type rdf:Property ;
    rdfs:label 'Feature Subcategory' ;
    rdfs:comment 'Detailed sub-classification within the feature category for granular filtering and reporting (e.g., within safety: active safety, passive safety, driver assistance).' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelEconomyImpactPercent rdf:type rdf:Property ;
    rdfs:label 'Fuel Economy Impact Percent' ;
    rdfs:comment 'The estimated percentage impact on fuel economy (positive or negative) when this feature is included. Used for EPA fuel economy label calculations and CAFE compliance.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installationTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Installation Time Minutes' ;
    rdfs:comment 'Standard time in minutes required to install this feature on the production line. Used for manufacturing capacity planning and line balancing in MES (Manufacturing Execution System).' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAdasFeature rdf:type rdf:Property ;
    rdfs:label 'Is Adas Feature' ;
    rdfs:comment 'Boolean flag indicating whether this feature is classified as an ADAS (Advanced Driver Assistance Systems) technology, such as adaptive cruise control, lane keeping assist, or automated emergency braking.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEvSpecific rdf:type rdf:Property ;
    rdfs:label 'Is Ev Specific' ;
    rdfs:comment 'Boolean flag indicating whether this feature is specific to electric vehicle (EV) or plug-in hybrid electric vehicle (PHEV) powertrains, such as regenerative braking display, charging port, or battery thermal management.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHevSpecific rdf:type rdf:Property ;
    rdfs:label 'Is Hev Specific' ;
    rdfs:comment 'Boolean flag indicating whether this feature is specific to hybrid electric vehicle (HEV) powertrains, such as hybrid system display, EV mode selector, or hybrid battery cooling.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryMandated rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Mandated' ;
    rdfs:comment 'Boolean flag indicating whether this feature is mandated by regulatory requirements such as NHTSA Federal Motor Vehicle Safety Standards (FMVSS), EPA emissions standards, or regional safety regulations (e.g., backup camera, tire pressure monitoring system).' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketAvailabilityRegion rdf:type rdf:Property ;
    rdfs:label 'Market Availability Region' ;
    rdfs:comment 'Geographic region or market where this feature is available, using standardized region codes (e.g., NAM for North America, EUR for Europe, CHN for China). Multiple regions may be pipe-separated.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelYearDiscontinued rdf:type rdf:Property ;
    rdfs:label 'Model Year Discontinued' ;
    rdfs:comment 'The model year (MY) when this feature was discontinued or phased out. Null if the feature is still active in the current lineup.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modelYearIntroduced rdf:type rdf:Property ;
    rdfs:label 'Model Year Introduced' ;
    rdfs:comment 'The model year (MY) when this feature was first introduced into the product lineup. Used for product evolution tracking and historical analysis.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:msrpCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Msrp Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the MSRP impact amount (e.g., USD, EUR, JPY).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrpImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Msrp Impact Amount' ;
    rdfs:comment 'The incremental MSRP (Manufacturer Suggested Retail Price) value added when this feature is included as an option. Zero for standard features. Used for pricing calculations and configurator display.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otaUpdateableFlag rdf:type rdf:Property ;
    rdfs:label 'Ota Updateable Flag' ;
    rdfs:comment 'Boolean flag indicating whether this feature can be enabled, updated, or modified via OTA (Over-the-Air) software updates post-production.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyRatingImpact rdf:type rdf:Property ;
    rdfs:label 'Safety Rating Impact' ;
    rdfs:comment 'Indicates the level of impact this feature has on vehicle safety ratings such as NCAP (New Car Assessment Programme) star ratings or IIHS Top Safety Pick awards.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyLevel rdf:type rdf:Property ;
    rdfs:label 'Technology Level' ;
    rdfs:comment 'Classification of the feature\'s technology sophistication level, used for market positioning and trim-level differentiation strategies.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExtensionMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Extension Months' ;
    rdfs:comment 'Number of additional warranty months provided specifically for this feature beyond the base vehicle warranty. Zero if no extension applies.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightImpactKg rdf:type rdf:Property ;
    rdfs:label 'Weight Impact Kg' ;
    rdfs:comment 'The incremental vehicle weight in kilograms added by this feature. Used for CAFE (Corporate Average Fuel Economy) calculations, performance modeling, and engineering analysis.' ;
    rdfs:domain ind:FeatureContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fleetSpecId rdf:type rdf:Property ;
    rdfs:label 'Fleet Spec Id' ;
    rdfs:comment 'Unique identifier for the fleet specification record. Primary key.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fleetCustomerCustomerFleetAccountId rdf:type rdf:Property ;
    rdfs:label 'Fleet Customer Customer Fleet Account Id' ;
    rdfs:comment 'Reference to the fleet customer organization that this specification was negotiated for. Links to customer master data and account management.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerFleetAccount .

ind:actualVolumeYtd rdf:type rdf:Property ;
    rdfs:label 'Actual Volume Ytd' ;
    rdfs:comment 'Actual number of units ordered or delivered under this fleet specification in the current fiscal year. Used to track performance against volume commitments.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualVolumeCommitment rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Commitment' ;
    rdfs:comment 'Number of units the fleet customer has committed to purchase annually under this specification. Drives production planning and supplier commitments.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedOptionPackages rdf:type rdf:Property ;
    rdfs:label 'Approved Option Packages' ;
    rdfs:comment 'Comma-separated list of option package codes that are pre-approved for inclusion in this fleet specification. May include safety, technology, or utility packages negotiated at fleet pricing.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTrimLevels rdf:type rdf:Property ;
    rdfs:label 'Approved Trim Levels' ;
    rdfs:comment 'Comma-separated list of trim level codes that are approved for this fleet specification. Defines the range of configurations available to the fleet customer.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Lead Time Days' ;
    rdfs:comment 'Committed lead time in days from order placement to vehicle delivery for this fleet specification. Service level commitment tied to production scheduling and logistics.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryLocationCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Code' ;
    rdfs:comment 'Code identifying the primary delivery location or distribution center for vehicles under this fleet specification. May reference a fleet customer facility or a designated delivery hub.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Fleet Customer Segment' ;
    rdfs:comment 'Classification of the fleet customer type. Determines applicable pricing structures, compliance requirements, and service level agreements.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Fleet Discount Percentage' ;
    rdfs:comment 'Negotiated discount percentage applied to the base MSRP for fleet orders. Confidential commercial term tied to volume commitments and customer segment.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fleetMsrpBase rdf:type rdf:Property ;
    rdfs:label 'Fleet Msrp Base' ;
    rdfs:comment 'Base MSRP for the fleet specification before discounts and volume adjustments. Represents the starting price point for fleet negotiations.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fleetNetPrice rdf:type rdf:Property ;
    rdfs:label 'Fleet Net Price' ;
    rdfs:comment 'Final negotiated net price per unit after all discounts and adjustments. Confidential commercial term used for fleet order processing.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fleetPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Fleet Priority Rank' ;
    rdfs:comment 'Priority ranking for production scheduling and allocation when demand exceeds capacity. Higher priority fleet specs receive preferential treatment in build sequence planning.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fleetSpecCode rdf:type rdf:Property ;
    rdfs:label 'Fleet Spec Code' ;
    rdfs:comment 'Business identifier for the fleet specification, used in contracts and ordering systems. Unique alphanumeric code assigned to each negotiated fleet configuration.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homologationRegion rdf:type rdf:Property ;
    rdfs:label 'Homologation Region' ;
    rdfs:comment 'Three-letter ISO country code or region code indicating the regulatory homologation region for vehicles under this fleet specification. Determines emissions, safety, and certification requirements.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User ID or username of the person who last modified this fleet specification record. Audit trail for change accountability.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Maximum number of units that can be ordered under this fleet specification within the contract period. Caps exposure and production allocation.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Price Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for all pricing fields in this fleet specification.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryUseCase rdf:type rdf:Property ;
    rdfs:label 'Primary Use Case' ;
    rdfs:comment 'Description of the primary operational use case for vehicles under this fleet specification. Examples: patrol vehicles, delivery vans, executive transport, utility service trucks.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceContractIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Service Contract Included Flag' ;
    rdfs:comment 'Indicates whether a prepaid service or maintenance contract is included as part of this fleet specification. Common for government and corporate fleet agreements.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Spec Approval Status' ;
    rdfs:comment 'Current lifecycle status of the fleet specification. Controls whether the spec can be used for order entry and production planning. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|expired|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specNotes rdf:type rdf:Property ;
    rdfs:label 'Spec Notes' ;
    rdfs:comment 'Free-text field for additional notes, special instructions, or clarifications related to this fleet specification. May include operational guidance, customer preferences, or exception handling procedures.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialEquipmentRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Equipment Requirements' ;
    rdfs:comment 'Description of any special equipment, upfitting, or modifications required for this fleet specification beyond standard options. May include emergency lighting, cargo racks, communication systems, or specialized tooling.' ;
    rdfs:domain ind:FleetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homologationVariantId rdf:type rdf:Property ;
    rdfs:label 'Homologation Variant Id' ;
    rdfs:comment 'Unique identifier for the homologation variant record. Primary key.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HomologationVariant .

ind:bomImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Bom Impact Flag' ;
    rdfs:comment 'Indicates whether this homologation variant requires changes to the base SKU Bill of Materials. True if BOM modifications are needed, False if only calibration or documentation changes are required.' ;
    rdfs:domain ind:HomologationVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cafeComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Cafe Compliance Flag' ;
    rdfs:comment 'Indicates whether this homologation variant is certified for CAFE (Corporate Average Fuel Economy) compliance in the United States market. Applicable to US market variants only.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costDeltaAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Delta Amount' ;
    rdfs:comment 'Incremental cost associated with implementing this homologation variant compared to the base SKU, including parts, labor, testing, and certification fees. Expressed in the currency specified in cost_delta_currency.' ;
    rdfs:domain ind:HomologationVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costDeltaCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Delta Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the cost_delta_amount field.' ;
    rdfs:domain ind:HomologationVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsStandardTarget rdf:type rdf:Property ;
    rdfs:label 'Emissions Standard Target' ;
    rdfs:comment 'Specific emissions standard or tier that this homologation variant is designed to meet, such as Euro 6d, EPA Tier 3, CARB LEV III, or China 6b.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationDescription rdf:type rdf:Property ;
    rdfs:label 'Modification Description' ;
    rdfs:comment 'Detailed description of the technical modifications, component changes, or configuration adjustments required to meet the target market regulatory requirements. May reference specific parts, calibrations, or design changes.' ;
    rdfs:domain ind:HomologationVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationType rdf:type rdf:Property ;
    rdfs:label 'Modification Type' ;
    rdfs:comment 'High-level classification of the type of modification required for homologation compliance, such as hardware changes, software updates, calibration adjustments, documentation updates, labeling changes, or additional testing.' ;
    rdfs:domain ind:HomologationVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncapRating rdf:type rdf:Property ;
    rdfs:label 'Ncap Rating' ;
    rdfs:comment 'Safety rating achieved by this homologation variant under the applicable NCAP (New Car Assessment Programme) testing protocol, such as Euro NCAP, US NCAP, or ANCAP. Typically expressed as a star rating or score.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otaCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Ota Capable Flag' ;
    rdfs:comment 'Indicates whether this homologation variant includes OTA (Over-the-Air) update capability for software and firmware updates. Relevant for regulatory compliance with evolving software update requirements.' ;
    rdfs:domain ind:HomologationVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryCategory rdf:type rdf:Property ;
    rdfs:label 'Regulatory Category' ;
    rdfs:comment 'Classification of the primary regulatory domain this variant addresses, such as safety standards, emissions controls, environmental compliance, or fuel economy requirements. [ENUM-REF-CANDIDATE: Safety|Emissions|Environmental|Fuel Economy|Crash Test|Lighting|Braking|Occupant Protection — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStandard rdf:type rdf:Property ;
    rdfs:label 'Regulatory Standard' ;
    rdfs:comment 'Primary regulatory standard or framework that this homologation variant must comply with. Examples include UNECE (United Nations Economic Commission for Europe), FMVSS (Federal Motor Vehicle Safety Standards), ADR (Australian Design Rules), CARB (California Air Resources Board). [ENUM-REF-CANDIDATE: UNECE|FMVSS|ADR|CARB|EPA|Euro NCAP|IATF 16949|ISO 14001 — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether this homologation approval requires periodic renewal or re-certification. True if renewal is mandated by the regulatory authority, False if approval is perpetual or tied to model year.' ;
    rdfs:domain ind:HomologationVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleEngineer rdf:type rdf:Property ;
    rdfs:label 'Responsible Engineer' ;
    rdfs:comment 'Name of the engineer or technical specialist responsible for managing the homologation process and regulatory compliance for this variant.' ;
    rdfs:domain ind:HomologationVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarketCode rdf:type rdf:Property ;
    rdfs:label 'Target Market Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country code representing the target market or jurisdiction for which this homologation variant is certified.' ;
    rdfs:domain ind:HomologationVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReportReference rdf:type rdf:Property ;
    rdfs:label 'Test Report Reference' ;
    rdfs:comment 'Reference number or identifier for the official test report(s) submitted as part of the homologation application. Links to laboratory test results, crash test data, emissions testing, or other certification evidence.' ;
    rdfs:domain ind:HomologationVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingLaboratory rdf:type rdf:Property ;
    rdfs:label 'Testing Laboratory' ;
    rdfs:comment 'Name of the accredited testing laboratory or technical service that conducted the homologation testing and issued the test reports.' ;
    rdfs:domain ind:HomologationVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wltpCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Wltp Certified Flag' ;
    rdfs:comment 'Indicates whether this homologation variant has been tested and certified under the WLTP (Worldwide Harmonised Light Vehicles Test Procedure) standard for fuel consumption and emissions.' ;
    rdfs:domain ind:HomologationVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketAvailabilityId rdf:type rdf:Property ;
    rdfs:label 'Market Availability Id' ;
    rdfs:comment 'Unique identifier for the market availability record. Primary key for the market availability entity.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketAvailability .

ind:allocationConstraintFlag rdf:type rdf:Property ;
    rdfs:label 'Allocation Constraint Flag' ;
    rdfs:comment 'Indicates whether this product configuration is subject to allocation constraints or supply limitations in the target market. True indicates constrained supply requiring allocation management.' ;
    rdfs:domain ind:MarketAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assemblyMode rdf:type rdf:Property ;
    rdfs:label 'Assembly Mode' ;
    rdfs:comment 'The assembly and import mode for this product configuration. CBU (Completely Built Up) indicates fully assembled import, CKD (Completely Knocked Down) indicates full disassembly for local assembly, and SKD (Semi Knocked Down) indicates partial disassembly for local assembly. Impacts duty rates and local content requirements.' ;
    rdfs:domain ind:MarketAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerOrderingCode rdf:type rdf:Property ;
    rdfs:label 'Dealer Ordering Code' ;
    rdfs:comment 'The code used by dealers in the Dealer Management System (DMS) to order this specific product configuration. May differ from internal SKU codes for legacy system compatibility.' ;
    rdfs:domain ind:MarketAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Destination Charge Amount' ;
    rdfs:comment 'The freight and delivery charge from the manufacturing plant or port to the dealer in the target market. Typically added to MSRP for total customer pricing.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evBatteryWarrantyMonths rdf:type rdf:Property ;
    rdfs:label 'Ev Battery Warranty Months' ;
    rdfs:comment 'The duration of the manufacturer\'s battery warranty coverage for electric or hybrid vehicles in the target market, expressed in months. Null for non-electrified vehicles.' ;
    rdfs:domain ind:MarketAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelEconomyRating rdf:type rdf:Property ;
    rdfs:label 'Fuel Economy Rating' ;
    rdfs:comment 'The official fuel economy or energy efficiency rating for this product configuration in the target market, expressed in the local standard unit (MPG, L/100km, kWh/100km). Based on standardized test procedures.' ;
    rdfs:domain ind:MarketAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelEconomyUnit rdf:type rdf:Property ;
    rdfs:label 'Fuel Economy Unit' ;
    rdfs:comment 'The unit of measure for the fuel economy rating. MPG (miles per gallon) used in US, L/100km (liters per 100 kilometers) used in Europe and Asia, kWh/100km (kilowatt-hours per 100 kilometers) used for electric vehicles.' ;
    rdfs:domain ind:MarketAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governmentIncentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Government Incentive Amount' ;
    rdfs:comment 'The value of government incentives (tax credits, rebates, grants) available for this product configuration in the target market. Commonly applies to electric vehicles and fuel-efficient vehicles. Null if no government incentive available.' ;
    rdfs:domain ind:MarketAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:homologationApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Homologation Approval Date' ;
    rdfs:comment 'The date when regulatory type-approval was granted for this product configuration in the target market. Critical for compliance tracking and market entry timing.' ;
    rdfs:domain ind:MarketAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:homologationApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Homologation Approval Status' ;
    rdfs:comment 'The regulatory type-approval status for this product configuration in the target market. Approved indicates certification complete, pending indicates under review, rejected indicates failed certification, not-required indicates no certification needed, and expired indicates certification lapsed.' ;
    rdfs:domain ind:MarketAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homologationCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Homologation Certificate Number' ;
    rdfs:comment 'The official type-approval or certification number issued by the regulatory authority for this product configuration in the target market. Required for legal sale in regulated markets.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homologationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Homologation Expiry Date' ;
    rdfs:comment 'The date when the regulatory type-approval expires and must be renewed. Null indicates no expiration or perpetual approval.' ;
    rdfs:domain ind:MarketAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:importDutyClassification rdf:type rdf:Property ;
    rdfs:label 'Import Duty Classification' ;
    rdfs:comment 'The Harmonized System (HS) tariff code or customs classification for this product configuration when imported into the target market. Used for duty calculation and customs clearance.' ;
    rdfs:domain ind:MarketAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importDutyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Import Duty Rate Percent' ;
    rdfs:comment 'The applicable import duty or tariff rate as a percentage of the customs value for this product configuration in the target market. Used for landed cost calculation.' ;
    rdfs:domain ind:MarketAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Eligible Flag' ;
    rdfs:comment 'Indicates whether this product configuration is eligible for manufacturer or government incentives in the target market. True indicates eligibility for rebates, tax credits, or promotional programs.' ;
    rdfs:domain ind:MarketAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localContentPercent rdf:type rdf:Property ;
    rdfs:label 'Local Content Percent' ;
    rdfs:comment 'The percentage of the product value that is sourced or manufactured locally in the target market. Used for trade agreement compliance and preferential duty qualification.' ;
    rdfs:domain ind:MarketAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderingPriority rdf:type rdf:Property ;
    rdfs:label 'Ordering Priority' ;
    rdfs:comment 'The priority ranking for order allocation and production scheduling for this product configuration in the target market. Lower numbers indicate higher priority. Used when demand exceeds supply.' ;
    rdfs:domain ind:MarketAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:powertrainWarrantyMonths rdf:type rdf:Property ;
    rdfs:label 'Powertrain Warranty Months' ;
    rdfs:comment 'The duration of the manufacturer\'s powertrain warranty coverage (engine, transmission, drivetrain) for this product configuration in the target market, expressed in months. Typically longer than basic warranty.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preDeliveryInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Delivery Inspection Required Flag' ;
    rdfs:comment 'Indicates whether a formal pre-delivery inspection is required before customer delivery for this product configuration in the target market. True indicates PDI is mandatory per OEM or regulatory requirements.' ;
    rdfs:domain ind:MarketAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'The source system that created or last updated this market availability record. SAP-SD indicates SAP Sales and Distribution, PLM indicates Product Lifecycle Management system, DMS indicates Dealer Management System, pricing-engine indicates automated pricing system, manual indicates manual data entry.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyMileage rdf:type rdf:Property ;
    rdfs:label 'Warranty Mileage' ;
    rdfs:comment 'The mileage limit of the manufacturer\'s basic warranty coverage for this product configuration in the target market. Warranty expires at the earlier of warranty_months or warranty_mileage.' ;
    rdfs:domain ind:MarketAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Months' ;
    rdfs:comment 'The duration of the manufacturer\'s basic warranty coverage for this product configuration in the target market, expressed in months. Represents the bumper-to-bumper or comprehensive warranty period.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'The date when this product configuration was or will be withdrawn from sale in the specified market and channel. Represents the End of Production (EOP) date for market availability. Null indicates ongoing availability.' ;
    rdfs:domain ind:MarketAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryPlantId rdf:type rdf:Property ;
    rdfs:label 'Primary Plant Id' ;
    rdfs:comment 'Reference to the primary manufacturing plant assigned to produce vehicles for this model year program.' ;
    rdfs:domain ind:AftersalesModelYearProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:programManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Manager Employee Id' ;
    rdfs:comment 'Reference to the employee responsible for overall program execution, budget, and milestone delivery.' ;
    rdfs:domain ind:AftersalesModelYearProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualProductionVolume rdf:type rdf:Property ;
    rdfs:label 'Actual Production Volume' ;
    rdfs:comment 'Cumulative number of units actually produced to date for this model year program. Updated as production progresses.' ;
    rdfs:domain ind:AftersalesModelYearProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomComplexityScore rdf:type rdf:Property ;
    rdfs:label 'Bom Complexity Score' ;
    rdfs:comment 'Calculated score representing the complexity of the BOM for this model year program, based on part count, variant count, and engineering change frequency.' ;
    rdfs:domain ind:AftersalesModelYearProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cafeTarget rdf:type rdf:Property ;
    rdfs:label 'Cafe Target' ;
    rdfs:comment 'Target CAFE rating (miles per gallon or equivalent) for this model year program to meet regulatory compliance in the United States.' ;
    rdfs:domain ind:AftersalesModelYearProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:connectedServicesEnabled rdf:type rdf:Property ;
    rdfs:label 'Connected Services Enabled' ;
    rdfs:comment 'Indicates whether this model year program includes connected vehicle services (telematics, OTA updates, V2X communication, remote diagnostics).' ;
    rdfs:domain ind:AftersalesModelYearProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epaRatingTarget rdf:type rdf:Property ;
    rdfs:label 'Epa Rating Target' ;
    rdfs:comment 'Target EPA fuel economy or emissions rating for this model year program to meet U.S. environmental compliance and consumer labeling requirements.' ;
    rdfs:domain ind:AftersalesModelYearProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fmeaCompleted rdf:type rdf:Property ;
    rdfs:label 'Fmea Completed' ;
    rdfs:comment 'Indicates whether FMEA has been completed for this model year program as part of APQP quality planning.' ;
    rdfs:domain ind:AftersalesModelYearProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:msrpCurrency rdf:type rdf:Property ;
    rdfs:label 'Msrp Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the MSRP targets (e.g., USD, EUR, JPY).' ;
    rdfs:domain ind:AftersalesModelYearProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncapTargetRating rdf:type rdf:Property ;
    rdfs:label 'Ncap Target Rating' ;
    rdfs:comment 'Target safety rating (1 to 5 stars) for this model year program under applicable NCAP testing (Euro NCAP, NHTSA, etc.). Influences marketing and regulatory compliance.' ;
    rdfs:domain ind:AftersalesModelYearProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Program Budget Amount' ;
    rdfs:comment 'Total allocated budget for this model year program, including CapEx for tooling, engineering, validation, and launch costs. Excludes variable production costs.' ;
    rdfs:domain ind:AftersalesModelYearProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programBudgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Program Budget Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the program budget amount (e.g., USD, EUR, JPY).' ;
    rdfs:domain ind:AftersalesModelYearProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programPhase rdf:type rdf:Property ;
    rdfs:label 'Program Phase' ;
    rdfs:comment 'Current lifecycle phase of the model year program. Concept: initial planning; Development: engineering and design; Validation: PPAP and testing; Launch: SOP preparation; Production: active manufacturing; Runout: approaching EOP; Discontinued: post-EOP. [ENUM-REF-CANDIDATE: concept|development|validation|launch|production|runout|discontinued — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programPriority rdf:type rdf:Property ;
    rdfs:label 'Program Priority' ;
    rdfs:comment 'Strategic priority level assigned to this model year program for resource allocation, executive attention, and portfolio management.' ;
    rdfs:domain ind:AftersalesModelYearProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierCount rdf:type rdf:Property ;
    rdfs:label 'Supplier Count' ;
    rdfs:comment 'Number of unique suppliers engaged to provide parts and components for this model year program. Used for supply chain complexity assessment.' ;
    rdfs:domain ind:AftersalesModelYearProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetMsrpMax rdf:type rdf:Property ;
    rdfs:label 'Target Msrp Max' ;
    rdfs:comment 'Maximum MSRP target for the fully-loaded configuration of this model year program. Defines the upper bound of the pricing envelope.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMsrpMin rdf:type rdf:Property ;
    rdfs:label 'Target Msrp Min' ;
    rdfs:comment 'Minimum MSRP target for the base configuration of this model year program. Used for pricing strategy and competitive positioning.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toolingInvestment rdf:type rdf:Property ;
    rdfs:label 'Tooling Investment' ;
    rdfs:comment 'Total investment in tooling (dies, molds, fixtures, jigs) required for this model year program. Subset of CapEx.' ;
    rdfs:domain ind:AftersalesModelYearProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wltpTarget rdf:type rdf:Property ;
    rdfs:label 'Wltp Target' ;
    rdfs:comment 'Target WLTP fuel consumption or CO2 emissions rating for this model year program to meet regulatory compliance in markets using WLTP standards.' ;
    rdfs:domain ind:AftersalesModelYearProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msrpPriceBookId rdf:type rdf:Property ;
    rdfs:label 'Msrp Price Book Id' ;
    rdfs:comment 'Unique identifier for the MSRP price book. Primary key.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MsrpPriceBook .

ind:supersededByPriceBookMsrpPriceBookId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Price Book Msrp Price Book Id' ;
    rdfs:comment 'Reference to the price book that replaces this one when status transitions to superseded. Nullable if not yet superseded.' ;
    rdfs:domain ind:MsrpPriceBook ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MsrpPriceBook .

ind:dealerAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Dealer Access Level' ;
    rdfs:comment 'Access control level defining which dealer tiers or internal users can view and use this price book.' ;
    rdfs:domain ind:MsrpPriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationChargeIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Destination Charge Included Flag' ;
    rdfs:comment 'Indicates whether destination and delivery charges are included in the MSRP prices within this book.' ;
    rdfs:domain ind:MsrpPriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:msrpPriceBookStatus rdf:type rdf:Property ;
    rdfs:label 'Msrp Price Book Status' ;
    rdfs:comment 'Current lifecycle status of the price book governing its availability for dealer ordering and consumer communications.' ;
    rdfs:domain ind:MsrpPriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookCode rdf:type rdf:Property ;
    rdfs:label 'Price Book Code' ;
    rdfs:comment 'Externally-known unique business identifier for the price book, used in dealer ordering systems and OEM communications.' ;
    rdfs:domain ind:MsrpPriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookName rdf:type rdf:Property ;
    rdfs:label 'Price Book Name' ;
    rdfs:comment 'Human-readable name of the price book, typically including model year and market designation.' ;
    rdfs:domain ind:MsrpPriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookType rdf:type rdf:Property ;
    rdfs:label 'Price Book Type' ;
    rdfs:comment 'Classification of the price book by customer segment or channel (e.g., standard retail, fleet, government, export).' ;
    rdfs:domain ind:MsrpPriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListCategory rdf:type rdf:Property ;
    rdfs:label 'Price List Category' ;
    rdfs:comment 'Category of pricing entries contained in this book (e.g., base vehicle, options, packages, accessories, destination charges).' ;
    rdfs:domain ind:MsrpPriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting compliance with pricing disclosure regulations such as NHTSA labeling requirements or EPA fuel economy disclosures.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrpPriceEntryId rdf:type rdf:Property ;
    rdfs:label 'Msrp Price Entry Id' ;
    rdfs:comment 'Unique identifier for the MSRP price entry record. Primary key for the price entry entity.' ;
    rdfs:domain ind:MsrpPriceEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advertisingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Advertising Fee Amount' ;
    rdfs:comment 'Mandatory regional or national advertising fee charged to the dealer and passed through to the customer. Supports cooperative advertising programs and brand marketing initiatives.' ;
    rdfs:domain ind:MsrpPriceEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseMsrpAmount rdf:type rdf:Property ;
    rdfs:label 'Base Msrp Amount' ;
    rdfs:comment 'The base MSRP amount for the SKU or option before any additional charges, taxes, or adjustments. Represents the manufacturer\'s suggested retail price in the price book currency.' ;
    rdfs:domain ind:MsrpPriceEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employeePricingAmount rdf:type rdf:Property ;
    rdfs:label 'Employee Pricing Amount' ;
    rdfs:comment 'Special pricing available to manufacturer employees, retirees, and eligible family members. Confidential pricing tier typically below dealer invoice. Null if no employee program applies.' ;
    rdfs:domain ind:MsrpPriceEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fleetEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fleet Eligible Flag' ;
    rdfs:comment 'Indicates whether this SKU or option is available for fleet sales programs at this price point. Fleet pricing may differ from retail MSRP. True if eligible for fleet programs, false otherwise.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gasGuzzlerTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Gas Guzzler Tax Amount' ;
    rdfs:comment 'Federal excise tax applied to vehicles that do not meet EPA fuel economy standards. Applicable only to passenger cars (not trucks or SUVs) with combined fuel economy below the statutory threshold. Zero for compliant vehicles.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governmentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Government Eligible Flag' ;
    rdfs:comment 'Indicates whether this SKU or option is available for government or municipal fleet purchases under special pricing programs. True if eligible for government sales, false otherwise.' ;
    rdfs:domain ind:MsrpPriceEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdbackPercentage rdf:type rdf:Property ;
    rdfs:label 'Holdback Percentage' ;
    rdfs:comment 'Percentage of MSRP or invoice that the manufacturer retains and later rebates to the dealer. Confidential dealer incentive mechanism. Typically ranges from 1% to 3% of MSRP.' ;
    rdfs:domain ind:MsrpPriceEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:luxuryTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Luxury Tax Amount' ;
    rdfs:comment 'Additional tax or surcharge applied to high-value vehicles exceeding a statutory price threshold. Jurisdiction-specific; may be zero in regions without luxury vehicle taxation.' ;
    rdfs:domain ind:MsrpPriceEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeReason rdf:type rdf:Property ;
    rdfs:label 'Price Change Reason' ;
    rdfs:comment 'Business reason or trigger for the price entry or price change. Supports audit trail and pricing strategy analysis. [ENUM-REF-CANDIDATE: initial_launch|model_year_change|cost_adjustment|competitive_response|incentive_program|regulatory_compliance|currency_adjustment|supply_constraint — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MsrpPriceEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceProtectionFlag rdf:type rdf:Property ;
    rdfs:label 'Price Protection Flag' ;
    rdfs:comment 'Indicates whether this price entry is covered by a price protection program that compensates dealers for inventory devaluation due to mid-year price reductions. True if protected, false otherwise.' ;
    rdfs:domain ind:MsrpPriceEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceStatus rdf:type rdf:Property ;
    rdfs:label 'Price Status' ;
    rdfs:comment 'Current lifecycle status of the price entry. Tracks the approval and activation workflow from initial draft through active use to eventual expiration or withdrawal.' ;
    rdfs:domain ind:MsrpPriceEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Classification of the price entry indicating what is being priced. Distinguishes between base vehicle MSRP, individual options, bundled packages, dealer-installed accessories, mandatory destination charges, and regional pricing adjustments. [ENUM-REF-CANDIDATE: base_vehicle|option|package|accessory|destination_charge|regional_adjustment|port_installed_option — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorMsrpAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Msrp Amount' ;
    rdfs:comment 'The previous total MSRP amount before the current price change. Used for price change tracking, competitive analysis, and dealer communication. Null for initial price entries.' ;
    rdfs:domain ind:MsrpPriceEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Flag' ;
    rdfs:comment 'Indicates whether this price entry is part of a limited-time promotional pricing program. True for promotional pricing, false for standard pricing.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierPricingAmount rdf:type rdf:Property ;
    rdfs:label 'Supplier Pricing Amount' ;
    rdfs:comment 'Special pricing available to employees of the manufacturer\'s supplier partners. Confidential pricing tier used as a supplier relationship benefit. Null if no supplier program applies.' ;
    rdfs:domain ind:MsrpPriceEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMsrpAmount rdf:type rdf:Property ;
    rdfs:label 'Total Msrp Amount' ;
    rdfs:comment 'The total MSRP including base price, destination charge, gas guzzler tax, luxury tax, and any other mandatory manufacturer charges. This is the price displayed on the Monroney window sticker.' ;
    rdfs:domain ind:MsrpPriceEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryAssemblyPlantId rdf:type rdf:Property ;
    rdfs:label 'Primary Assembly Plant Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.plant. Business justification: REQUIRED: Assign primary assembly plant for each nameplate; production planners need this for plant-level capacity and allocation.' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:productManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Product Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Product Manager role must be linked to an employee for accountability in nameplate strategy and performance dashboards.' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bodyStylePrimary rdf:type rdf:Property ;
    rdfs:label 'Body Style Primary' ;
    rdfs:comment 'Primary body style configuration for this nameplate (e.g., 4-door sedan, 2-door coupe, crew cab pickup, extended wheelbase van). Multiple body styles may exist within a nameplate; this represents the flagship or most common configuration.' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
    rdfs:comment 'Code representing the brand or marque under which this nameplate is marketed (e.g., FORD, CHEV, TOYOTA, LEXUS).' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cafeCategory rdf:type rdf:Property ;
    rdfs:label 'Cafe Category' ;
    rdfs:comment 'CAFE regulatory category for fuel economy compliance: passenger car, light truck, or exempt. Used for EPA and NHTSA reporting.' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectivityCapability rdf:type rdf:Property ;
    rdfs:label 'Connectivity Capability' ;
    rdfs:comment 'Level of connected vehicle capability: none (no connectivity), basic (telematics only), advanced (OTA updates, cloud services), v2x (Vehicle-to-Everything communication).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designLanguageTheme rdf:type rdf:Property ;
    rdfs:label 'Design Language Theme' ;
    rdfs:comment 'Name or description of the design language or styling theme applied to this nameplate (e.g., \'Kodo Soul of Motion\', \'Sensual Purity\', \'Bold American Truck\'). Used for design continuity and brand identity.' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eopQuarter rdf:type rdf:Property ;
    rdfs:label 'Eop Quarter' ;
    rdfs:comment 'Fiscal quarter within the EOP year when production ceased or is planned to cease (Q1, Q2, Q3, Q4). Null if eop_year is null.' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eopYear rdf:type rdf:Property ;
    rdfs:label 'Eop Year' ;
    rdfs:comment 'Calendar year when this nameplate ceased or is planned to cease production. Null for active nameplates with no planned discontinuation.' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:globalAvailabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Global Availability Flag' ;
    rdfs:comment 'Indicates whether this nameplate is available globally (true) or limited to specific regional markets (false).' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heritageLineage rdf:type rdf:Property ;
    rdfs:label 'Heritage Lineage' ;
    rdfs:comment 'Textual description of the nameplate\'s heritage and generational lineage (e.g., \'Successor to Model T, 14th generation\'). Used for brand storytelling and historical tracking.' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homologationMarkets rdf:type rdf:Property ;
    rdfs:label 'Homologation Markets' ;
    rdfs:comment 'Comma-separated list of regulatory markets for which this nameplate has received or is pursuing homologation approval (e.g., USA, EUR, CHN, JPN). Used for compliance tracking.' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketPositioningTier rdf:type rdf:Property ;
    rdfs:label 'Market Positioning Tier' ;
    rdfs:comment 'Strategic market positioning tier indicating the target customer segment and price point (entry-level, mainstream, premium, luxury, performance).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingTagline rdf:type rdf:Property ;
    rdfs:label 'Marketing Tagline' ;
    rdfs:comment 'Primary marketing tagline or slogan associated with this nameplate (e.g., \'Built Ford Tough\', \'The Ultimate Driving Machine\'). Used for brand consistency across campaigns.' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'User ID or name of the person who last modified this nameplate record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nameplateName rdf:type rdf:Property ;
    rdfs:label 'Nameplate Name' ;
    rdfs:comment 'Commercial brand name of the vehicle nameplate as marketed to consumers (e.g., F-150, Camry, Silverado, Mustang Mach-E).' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncapRatingTarget rdf:type rdf:Property ;
    rdfs:label 'Ncap Rating Target' ;
    rdfs:comment 'Target safety rating for this nameplate under applicable NCAP programs (e.g., 5-star Euro NCAP, 5-star NHTSA). Used for safety engineering and marketing.' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otaUpdateEnabled rdf:type rdf:Property ;
    rdfs:label 'Ota Update Enabled' ;
    rdfs:comment 'Indicates whether this nameplate supports over-the-air software updates for ECU firmware, infotainment, and vehicle systems (true/false).' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:powertrainFamily rdf:type rdf:Property ;
    rdfs:label 'Powertrain Family' ;
    rdfs:comment 'Primary powertrain technology family for this nameplate: ICE (Internal Combustion Engine), HEV (Hybrid Electric Vehicle), PHEV (Plug-in Hybrid Electric Vehicle), BEV (Battery Electric Vehicle), FCEV (Fuel Cell Electric Vehicle).' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predecessorNameplateCode rdf:type rdf:Property ;
    rdfs:label 'Predecessor Nameplate Code' ;
    rdfs:comment 'Nameplate code of the direct predecessor model that this nameplate replaced or evolved from. Null for entirely new nameplates with no predecessor.' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalScope rdf:type rdf:Property ;
    rdfs:label 'Regional Scope' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes or regional market codes where this nameplate is available (e.g., USA,CAN,MEX for North America; EUR for Europe). Null if global_availability_flag is true.' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClass rdf:type rdf:Property ;
    rdfs:label 'Regulatory Class' ;
    rdfs:comment 'Regulatory classification for emissions, safety, and fuel economy standards (e.g., passenger car, light truck, medium-duty vehicle). Varies by jurisdiction (NHTSA, EPA, CARB, UNECE).' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatingCapacityRange rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity Range' ;
    rdfs:comment 'Range of seating capacity across all configurations of this nameplate (e.g., \'5\', \'5-7\', \'2-3\'). Format: single number or range (min-max).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopQuarter rdf:type rdf:Property ;
    rdfs:label 'Sop Quarter' ;
    rdfs:comment 'Fiscal quarter within the SOP year when production commenced (Q1, Q2, Q3, Q4).' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopYear rdf:type rdf:Property ;
    rdfs:label 'Sop Year' ;
    rdfs:comment 'Calendar year when this nameplate first entered production. Used for heritage tracking and program planning.' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetAnnualVolume rdf:type rdf:Property ;
    rdfs:label 'Target Annual Volume' ;
    rdfs:comment 'Planned annual production volume (units) for this nameplate at steady-state production. Used for capacity planning and supply chain forecasting.' ;
    rdfs:domain ind:Nameplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optionConstraintId rdf:type rdf:Property ;
    rdfs:label 'Option Constraint Id' ;
    rdfs:comment 'Unique identifier for the option constraint rule. Primary key.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aftersalesOptionPackageId rdf:type rdf:Property ;
    rdfs:label 'Aftersales Option Package Id' ;
    rdfs:comment 'Reference to the option or package that triggers this constraint rule. The \'if\' side of the constraint logic.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AftersalesOptionPackage .

ind:primaryAftersalesOptionPackageId rdf:type rdf:Property ;
    rdfs:label 'Primary Aftersales Option Package Id' ;
    rdfs:comment 'Reference to the option or package that triggers this constraint rule. The \'if\' side of the constraint logic.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AftersalesOptionPackage .

ind:targetOptionAftersalesOptionPackageId rdf:type rdf:Property ;
    rdfs:label 'Target Option Aftersales Option Package Id' ;
    rdfs:comment 'Reference to the option or package that is affected by this constraint rule. The \'then\' side of the constraint logic.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AftersalesOptionPackage .

ind:targetOptionOptionPackageAftersalesOptionPackageId rdf:type rdf:Property ;
    rdfs:label 'Target Option Option Package Aftersales Option Package Id' ;
    rdfs:comment 'Reference to the option or package that is affected by this constraint rule. The \'then\' side of the constraint logic.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AftersalesOptionPackage .

ind:appliesToFleet rdf:type rdf:Property ;
    rdfs:label 'Applies To Fleet' ;
    rdfs:comment 'Indicates whether this constraint applies to fleet orders. Some constraints are relaxed or different for high-volume fleet customers.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToRetail rdf:type rdf:Property ;
    rdfs:label 'Applies To Retail' ;
    rdfs:comment 'Indicates whether this constraint applies to retail customer orders through dealer networks.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bomImpact rdf:type rdf:Property ;
    rdfs:label 'Bom Impact' ;
    rdfs:comment 'Indicates the severity of Bill of Materials changes triggered by this constraint. Critical impacts may require PPAP or APQP review.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Change Request Number' ;
    rdfs:comment 'Reference to the Engineering Change Request or Product Change Notice that authorized the creation or modification of this constraint.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configuratorDisplayOrder rdf:type rdf:Property ;
    rdfs:label 'Configurator Display Order' ;
    rdfs:comment 'Numeric sequence controlling the order in which constraint messages are displayed in consumer and dealer configurators.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:constraintCode rdf:type rdf:Property ;
    rdfs:label 'Constraint Code' ;
    rdfs:comment 'Business-readable code identifying this constraint rule, often used in dealer ordering systems and configurators.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintDescription rdf:type rdf:Property ;
    rdfs:label 'Constraint Description' ;
    rdfs:comment 'Detailed business explanation of why this constraint exists, including engineering, regulatory, or commercial rationale.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintPriority rdf:type rdf:Property ;
    rdfs:label 'Constraint Priority' ;
    rdfs:comment 'Numeric priority for resolving conflicts when multiple constraints apply to the same option combination. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:constraintSource rdf:type rdf:Property ;
    rdfs:label 'Constraint Source' ;
    rdfs:comment 'The business function or domain that originated this constraint rule (e.g., engineering for technical incompatibility, regulatory for compliance, commercial for pricing strategy).' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintStatus rdf:type rdf:Property ;
    rdfs:label 'Constraint Status' ;
    rdfs:comment 'Current lifecycle status of the constraint rule. Active constraints are enforced in ordering systems; inactive/deprecated constraints are retained for historical reference.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintType rdf:type rdf:Property ;
    rdfs:label 'Constraint Type' ;
    rdfs:comment 'The type of constraint relationship: requires (source option mandates target), excludes (source option prohibits target), includes (source option automatically bundles target), upgrades (source option supersedes target), replaces (source option substitutes target), prerequisite (target requires source to be selected first).' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHardConstraint rdf:type rdf:Property ;
    rdfs:label 'Is Hard Constraint' ;
    rdfs:comment 'Indicates whether this is a hard constraint (cannot be violated under any circumstances) or a soft constraint (generates warning but can be overridden).' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeImpactDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Impact Days' ;
    rdfs:comment 'The number of additional production days required when this constraint is triggered, impacting On-Time Delivery (OTD) commitments.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:msrpImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Msrp Impact Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the MSRP impact amount.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideApprovalLevel rdf:type rdf:Property ;
    rdfs:label 'Override Approval Level' ;
    rdfs:comment 'The minimum authorization level required to override this constraint, if override_allowed is true.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierConstraint rdf:type rdf:Property ;
    rdfs:label 'Supplier Constraint' ;
    rdfs:comment 'Indicates whether this constraint is driven by supplier capacity, tooling, or material availability limitations.' ;
    rdfs:domain ind:OptionConstraint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attachmentRatePercent rdf:type rdf:Property ;
    rdfs:label 'Attachment Rate Percent' ;
    rdfs:comment 'Historical attachment rate percentage indicating how often this option package is selected when available. Used for demand forecasting and production planning.' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableMarkets rdf:type rdf:Property ;
    rdfs:label 'Available Markets' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes or market region codes where this option package is available for sale. Supports regional product portfolio management.' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableModelYears rdf:type rdf:Property ;
    rdfs:label 'Available Model Years' ;
    rdfs:comment 'Comma-separated list of model years (MY) for which this option package is available. Supports multi-year planning and phase-in/phase-out management.' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableTrimLevels rdf:type rdf:Property ;
    rdfs:label 'Available Trim Levels' ;
    rdfs:comment 'Comma-separated list of trim level codes where this option package can be ordered. Defines the commercial availability matrix by vehicle configuration.' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentDescription rdf:type rdf:Property ;
    rdfs:label 'Content Description' ;
    rdfs:comment 'Detailed description of all features, components, and equipment included in this option package. Used for customer communication, sales training, and regulatory disclosure.' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerCostAmount rdf:type rdf:Property ;
    rdfs:label 'Dealer Cost Amount' ;
    rdfs:comment 'Wholesale cost to the dealer for this option package. Used for dealer margin calculations and incentive program eligibility. Business-confidential pricing data.' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date when this option package was or will be removed from the orderable catalog. Corresponds to End of Production (EOP) or phase-out date. Null if still active.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emissionsImpactGramsCo2Km rdf:type rdf:Property ;
    rdfs:label 'Emissions Impact Grams Co2 Km' ;
    rdfs:comment 'Incremental CO2 emissions impact of this option package in grams per kilometer under WLTP test cycle. Used for CAFE and emissions compliance reporting.' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excludesPackageCodes rdf:type rdf:Property ;
    rdfs:label 'Excludes Package Codes' ;
    rdfs:comment 'Comma-separated list of package codes that cannot be selected if this package is chosen. Enforces mutual exclusivity constraints in the vehicle configuration logic.' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:includedInPackageCodes rdf:type rdf:Property ;
    rdfs:label 'Included In Package Codes' ;
    rdfs:comment 'Comma-separated list of higher-level package codes that already include this package as a component. Prevents duplicate ordering and pricing.' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationLocation rdf:type rdf:Property ;
    rdfs:label 'Installation Location' ;
    rdfs:comment 'Designated location where this option package is installed: factory (during main assembly line production), port (at port facility before delivery), dealer (at dealership after delivery).' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:introductionDate rdf:type rdf:Property ;
    rdfs:label 'Introduction Date' ;
    rdfs:comment 'Date when this option package was first made available for customer ordering. Corresponds to Start of Production (SOP) or commercial launch date.' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isOrderable rdf:type rdf:Property ;
    rdfs:label 'Is Orderable' ;
    rdfs:comment 'Indicates whether this option package is currently available for customer ordering. May be false due to supply constraints, regulatory holds, or lifecycle status.' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVisibleToCustomer rdf:type rdf:Property ;
    rdfs:label 'Is Visible To Customer' ;
    rdfs:comment 'Indicates whether this option package should be displayed in customer-facing configurators and marketing materials. May be hidden for dealer-only or internal packages.' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingDescription rdf:type rdf:Property ;
    rdfs:label 'Marketing Description' ;
    rdfs:comment 'Customer-facing marketing copy highlighting the benefits and value proposition of this option package. Used in brochures, websites, and configurators.' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCategory rdf:type rdf:Property ;
    rdfs:label 'Package Category' ;
    rdfs:comment 'High-level functional category grouping for the option package used for catalog organization and customer navigation. [ENUM-REF-CANDIDATE: exterior|interior|technology|safety|performance|comfort|convenience|appearance — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCode rdf:type rdf:Property ;
    rdfs:label 'Package Code' ;
    rdfs:comment 'Manufacturer-assigned alphanumeric code uniquely identifying this option package in the commercial catalog (e.g., TECH01, TOW-PKG, PREM-AUD). Used in ordering systems, dealer management systems, and customer-facing configurators.' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageName rdf:type rdf:Property ;
    rdfs:label 'Package Name' ;
    rdfs:comment 'Marketing name of the option package as presented to customers and dealers (e.g., Technology Package, Towing Package, Premium Audio System).' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Classification of the option package: group (bundle of multiple features), standalone (single feature option), accessory (aftermarket add-on), dealer_installed (installed at dealership), port_installed (installed at port before delivery).' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionFeasibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Production Feasibility Status' ;
    rdfs:comment 'Current manufacturing feasibility status indicating whether the option package can be produced given current supply chain, capacity, and tooling constraints.' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresPackageCodes rdf:type rdf:Property ;
    rdfs:label 'Requires Package Codes' ;
    rdfs:comment 'Comma-separated list of package codes that must be selected before this package can be ordered. Enforces prerequisite dependencies in the vehicle configuration logic.' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRank rdf:type rdf:Property ;
    rdfs:label 'Sales Rank' ;
    rdfs:comment 'Relative sales popularity ranking of this option package compared to other packages in the same category. Used for inventory planning and marketing prioritization.' ;
    rdfs:domain ind:AftersalesOptionPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderGuideId rdf:type rdf:Property ;
    rdfs:label 'Order Guide Id' ;
    rdfs:comment 'Unique identifier for the dealer order guide. Primary key for the order guide entity.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this order guide record. Used for accountability and audit trail purposes.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryOrderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Employee Id' ;
    rdfs:comment 'Identifier of the user who approved this order guide for publication. Typically a product manager or sales director with authority to release order guides.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByOrderGuideId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Order Guide Id' ;
    rdfs:comment 'Reference to the order guide that supersedes this one. Used to track order guide version history and guide dealers to the current version.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderGuide .

ind:tertiaryOrderLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Order Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this order guide record. Used for accountability and audit trail purposes.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baseMsrpMax rdf:type rdf:Property ;
    rdfs:label 'Base Msrp Max' ;
    rdfs:comment 'The maximum base MSRP across all orderable configurations in this order guide. Excludes options and packages. Used for pricing range communication.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseMsrpMin rdf:type rdf:Property ;
    rdfs:label 'Base Msrp Min' ;
    rdfs:comment 'The minimum base MSRP across all orderable configurations in this order guide. Excludes options and packages. Used for pricing range communication.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildToStockFlag rdf:type rdf:Property ;
    rdfs:label 'Build To Stock Flag' ;
    rdfs:comment 'Indicates whether vehicles in this order guide are built to stock (for dealer inventory) versus build to order (for specific customer orders).' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:colorOptionCount rdf:type rdf:Property ;
    rdfs:label 'Color Option Count' ;
    rdfs:comment 'The total number of exterior and interior color combinations available in this order guide. Used for configuration complexity tracking.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dealerInvoiceDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Dealer Invoice Discount Percentage' ;
    rdfs:comment 'The standard discount percentage from MSRP to dealer invoice price for vehicles in this order guide. Confidential dealer pricing information.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveProgramEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Program Eligible Flag' ;
    rdfs:comment 'Indicates whether vehicles ordered through this order guide are eligible for manufacturer incentive programs (rebates, financing offers, lease programs).' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeDaysMax rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days Max' ;
    rdfs:comment 'The maximum number of days from order placement to vehicle delivery for the slowest configuration in this order guide. Used for dealer planning.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadTimeDaysMin rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days Min' ;
    rdfs:comment 'The minimum number of days from order placement to vehicle delivery for the fastest configuration in this order guide. Used for dealer planning.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optionPackageCount rdf:type rdf:Property ;
    rdfs:label 'Option Package Count' ;
    rdfs:comment 'The total number of option packages available in this order guide. Packages bundle multiple options together for simplified ordering.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderBankCloseDate rdf:type rdf:Property ;
    rdfs:label 'Order Bank Close Date' ;
    rdfs:comment 'The date when the order bank closes and dealers can no longer submit new orders for vehicles in this order guide. Used for production planning cutoff.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderBankOpenDate rdf:type rdf:Property ;
    rdfs:label 'Order Bank Open Date' ;
    rdfs:comment 'The date when the order bank opens and dealers can begin submitting orders for vehicles in this order guide. May differ from effective start date.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderGuideCode rdf:type rdf:Property ;
    rdfs:label 'Order Guide Code' ;
    rdfs:comment 'Business identifier for the order guide. Externally-known code used by dealers and sales channels to reference this specific order guide version.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderGuideDescription rdf:type rdf:Property ;
    rdfs:label 'Order Guide Description' ;
    rdfs:comment 'Detailed description of the order guide including key features, target market, ordering instructions, and any special conditions or restrictions.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderGuideName rdf:type rdf:Property ;
    rdfs:label 'Order Guide Name' ;
    rdfs:comment 'Descriptive name of the order guide, typically including nameplate, model year, and market information for easy identification by dealers.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderGuideStatus rdf:type rdf:Property ;
    rdfs:label 'Order Guide Status' ;
    rdfs:comment 'Current lifecycle status of the order guide. Controls whether dealers can place orders and whether the guide is visible in dealer systems. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|superseded|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderableSkuCount rdf:type rdf:Property ;
    rdfs:label 'Orderable Sku Count' ;
    rdfs:comment 'The total number of unique SKUs (trim level and option combinations) that are orderable through this order guide. Used for complexity tracking.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderingInstructionsUrl rdf:type rdf:Property ;
    rdfs:label 'Ordering Instructions Url' ;
    rdfs:comment 'URL link to detailed ordering instructions, configuration rules, and dealer resources for this order guide. Hosted on dealer portal.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialOrderAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Special Order Allowed Flag' ;
    rdfs:comment 'Indicates whether dealers can place special orders for non-standard configurations not explicitly listed in the order guide. Requires additional approval.' ;
    rdfs:domain ind:OrderGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:powertrainConfigId rdf:type rdf:Property ;
    rdfs:label 'Powertrain Config Id' ;
    rdfs:comment 'Unique identifier for the powertrain configuration. Primary key for this product.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PowertrainConfig .

ind:batteryChemistry rdf:type rdf:Property ;
    rdfs:label 'Battery Chemistry' ;
    rdfs:comment 'Chemical composition of the battery pack for electric and hybrid powertrains. \'none\' for pure ICE vehicles.' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cafeCreditValue rdf:type rdf:Property ;
    rdfs:label 'Cafe Credit Value' ;
    rdfs:comment 'CAFE credit multiplier or value assigned to this powertrain configuration for fleet average fuel economy compliance calculations. Higher for electric and alternative fuel vehicles.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargingCapability rdf:type rdf:Property ;
    rdfs:label 'Charging Capability' ;
    rdfs:comment 'Maximum charging capability supported by the powertrain for electric and plug-in hybrid vehicles. \'none\' for pure ICE and non-plug-in hybrids.' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2EmissionsGKm rdf:type rdf:Property ;
    rdfs:label 'Co2 Emissions G Km' ;
    rdfs:comment 'Certified carbon dioxide emissions in grams per kilometer under WLTP or NEDC test cycle. Zero for pure electric vehicles. Used for regulatory compliance and CAFE calculations.' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:combinedHorsepower rdf:type rdf:Property ;
    rdfs:label 'Combined Horsepower' ;
    rdfs:comment 'Total system horsepower combining ICE and electric motor output at peak performance. For hybrids, represents maximum combined output, not sum of individual components.' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:combinedTorqueNm rdf:type rdf:Property ;
    rdfs:label 'Combined Torque Nm' ;
    rdfs:comment 'Total system torque in Newton-meters combining ICE and electric motor output. For hybrids, represents maximum combined torque available to the drivetrain.' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dealerInvoiceCostUsd rdf:type rdf:Property ;
    rdfs:label 'Dealer Invoice Cost Usd' ;
    rdfs:comment 'Dealer invoice cost for this powertrain configuration in US dollars. Used for dealer margin calculations and incentive programs.' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drivetrainLayout rdf:type rdf:Property ;
    rdfs:label 'Drivetrain Layout' ;
    rdfs:comment 'Drive wheel configuration. FWD=Front-Wheel Drive, RWD=Rear-Wheel Drive, AWD=All-Wheel Drive (full-time or automatic), 4WD=Four-Wheel Drive (part-time, driver-selectable).' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electricMotorPosition rdf:type rdf:Property ;
    rdfs:label 'Electric Motor Position' ;
    rdfs:comment 'Physical location of electric motor(s) in the vehicle architecture. \'integrated\' indicates motor integrated with transmission. \'none\' for pure ICE.' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electricMotorType rdf:type rdf:Property ;
    rdfs:label 'Electric Motor Type' ;
    rdfs:comment 'Configuration of electric motors in the powertrain. Applicable to HEV, PHEV, BEV, and MHEV. \'none\' for pure ICE powertrains.' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineConfiguration rdf:type rdf:Property ;
    rdfs:label 'Engine Configuration' ;
    rdfs:comment 'Physical arrangement of engine cylinders (inline, V-type, flat/boxer, rotary, W-type). Null for pure electric and fuel cell powertrains.' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineDisplacementLiters rdf:type rdf:Property ;
    rdfs:label 'Engine Displacement Liters' ;
    rdfs:comment 'Total swept volume of all engine cylinders in liters. Null for pure BEV and FCEV powertrains without an ICE component.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epaCityMpg rdf:type rdf:Property ;
    rdfs:label 'Epa City Mpg' ;
    rdfs:comment 'EPA-certified city fuel economy rating in miles per gallon. For electric vehicles, this represents MPGe (miles per gallon equivalent). Null if EPA rating not applicable.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaCombinedMpg rdf:type rdf:Property ;
    rdfs:label 'Epa Combined Mpg' ;
    rdfs:comment 'EPA-certified combined (55% city, 45% highway) fuel economy rating in miles per gallon. For electric vehicles, this represents MPGe. Null if EPA rating not applicable.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaElectricRangeMiles rdf:type rdf:Property ;
    rdfs:label 'Epa Electric Range Miles' ;
    rdfs:comment 'EPA-certified all-electric driving range in miles for BEV and PHEV powertrains before ICE engagement or recharge required. Null for pure ICE and HEV.' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:epaHighwayMpg rdf:type rdf:Property ;
    rdfs:label 'Epa Highway Mpg' ;
    rdfs:comment 'EPA-certified highway fuel economy rating in miles per gallon. For electric vehicles, this represents MPGe. Null if EPA rating not applicable.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingCostUsd rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Cost Usd' ;
    rdfs:comment 'Standard manufacturing cost for this powertrain configuration in US dollars. Used for margin analysis and profitability reporting.' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxChargingPowerKw rdf:type rdf:Property ;
    rdfs:label 'Max Charging Power Kw' ;
    rdfs:comment 'Maximum DC fast charging power acceptance rate in kilowatts for electric and plug-in hybrid vehicles. Null for pure ICE and non-plug-in hybrids.' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payloadCapacityLbs rdf:type rdf:Property ;
    rdfs:label 'Payload Capacity Lbs' ;
    rdfs:comment 'Maximum cargo and passenger weight capacity in pounds for this powertrain configuration. Critical for commercial and truck applications.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:powertrainCode rdf:type rdf:Property ;
    rdfs:label 'Powertrain Code' ;
    rdfs:comment 'Manufacturer-assigned alphanumeric code uniquely identifying this powertrain configuration across all nameplates and model years. Used in ordering systems, BOMs, and production planning.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powertrainConfigStatus rdf:type rdf:Property ;
    rdfs:label 'Powertrain Config Status' ;
    rdfs:comment 'Current lifecycle status of this powertrain configuration in the product catalog. Active=currently orderable, Discontinued=no longer available, Planned=future introduction, Phase-out=being discontinued.' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powertrainName rdf:type rdf:Property ;
    rdfs:label 'Powertrain Name' ;
    rdfs:comment 'Customer-facing marketing name for the powertrain configuration (e.g., \'EcoBoost 2.0L Turbo\', \'PowerMax V8\', \'e-Drive Electric\').' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:towingCapacityLbs rdf:type rdf:Property ;
    rdfs:label 'Towing Capacity Lbs' ;
    rdfs:comment 'Maximum trailer weight rating in pounds that can be safely towed with this powertrain configuration when properly equipped.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transmissionSpeeds rdf:type rdf:Property ;
    rdfs:label 'Transmission Speeds' ;
    rdfs:comment 'Number of forward gear ratios in the transmission. Null for CVT and single-speed transmissions.' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyBatteryMiles rdf:type rdf:Property ;
    rdfs:label 'Warranty Battery Miles' ;
    rdfs:comment 'Battery pack warranty coverage mileage limit for electric and plug-in hybrid powertrains. Null for pure ICE vehicles.' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyBatteryMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Battery Months' ;
    rdfs:comment 'Battery pack warranty coverage period in months for electric and plug-in hybrid powertrains. Null for pure ICE vehicles.' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyPowertrainMiles rdf:type rdf:Property ;
    rdfs:label 'Warranty Powertrain Miles' ;
    rdfs:comment 'Standard powertrain warranty coverage mileage limit offered with this configuration. Warranty expires at earlier of months or miles.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyPowertrainMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Powertrain Months' ;
    rdfs:comment 'Standard powertrain warranty coverage period in months offered with this configuration.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wltpCityRangeKm rdf:type rdf:Property ;
    rdfs:label 'Wltp City Range Km' ;
    rdfs:comment 'WLTP-certified city driving range in kilometers for electric vehicles. Null if WLTP not applicable.' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wltpCombinedRangeKm rdf:type rdf:Property ;
    rdfs:label 'Wltp Combined Range Km' ;
    rdfs:comment 'WLTP-certified combined driving range in kilometers for electric vehicles (BEV, PHEV electric-only mode). Used for European and international markets. Null if WLTP not applicable.' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zeroToSixtySeconds rdf:type rdf:Property ;
    rdfs:label 'Zero To Sixty Seconds' ;
    rdfs:comment 'Manufacturer-tested acceleration time from 0 to 60 mph in seconds. Key performance metric for marketing and competitive positioning.' ;
    rdfs:domain ind:PowertrainConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Product Lifecycle Event Id' ;
    rdfs:comment 'Unique identifier for the product lifecycle event record. Primary key for this entity.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedEntityCode rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Code' ;
    rdfs:comment 'Business code or identifier of the affected entity (e.g., nameplate code, program code, SKU code) for human-readable reference and reporting.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedEntityReference rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Reference' ;
    rdfs:comment 'Identifier of the specific product entity affected by this event. References the primary key of the entity type specified in affected_entity_type.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedEntityType rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Type' ;
    rdfs:comment 'Type of product entity affected by this lifecycle event (e.g., nameplate, model year program, SKU, trim level, platform, powertrain).' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:announcementType rdf:type rdf:Property ;
    rdfs:label 'Announcement Type' ;
    rdfs:comment 'Classification of the event announcement scope: internal (company-only), public (press release), regulatory (mandatory filing), or confidential (restricted distribution).' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerCommunicationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Communication Required Flag' ;
    rdfs:comment 'Indicates whether direct customer communication or notification is required for this lifecycle event (e.g., for recalls, service campaigns, or discontinuations affecting existing owners).' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dealerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Dealer Notification Date' ;
    rdfs:comment 'Date when dealers were notified of this lifecycle event.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealerNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dealer Notification Required Flag' ;
    rdfs:comment 'Indicates whether dealer network notification is required for this lifecycle event.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Standardized code identifying the type of lifecycle event (e.g., PROG_APPR, DSGN_FRZ, SOP, JOB1, MCR_ANN, EOP, DISC).' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated or actual financial impact of this lifecycle event in the specified currency (e.g., CapEx investment for SOP, cost savings from EOP, write-off for discontinuation).' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the financial impact amount (e.g., USD, EUR, JPY).' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactLevel rdf:type rdf:Property ;
    rdfs:label 'Impact Level' ;
    rdfs:comment 'Business impact level of this lifecycle event on operations, supply chain, sales, and customer commitments.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newState rdf:type rdf:Property ;
    rdfs:label 'New State' ;
    rdfs:comment 'The lifecycle state or phase of the affected entity after this event (e.g., approved, frozen, in-production, discontinued). Represents the state transition resulting from this event.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressReleaseReference rdf:type rdf:Property ;
    rdfs:label 'Press Release Reference' ;
    rdfs:comment 'Reference number, URL, or document identifier for the associated press release or public announcement, if applicable.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorState rdf:type rdf:Property ;
    rdfs:label 'Prior State' ;
    rdfs:comment 'The lifecycle state or phase of the affected entity immediately before this event occurred (e.g., concept, development, pre-production, production, phase-out).' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionVolumeImpact rdf:type rdf:Property ;
    rdfs:label 'Production Volume Impact' ;
    rdfs:comment 'Estimated change in production volume (units) resulting from this lifecycle event. Positive for ramp-up events, negative for phase-out or discontinuation.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierImpactCount rdf:type rdf:Property ;
    rdfs:label 'Supplier Impact Count' ;
    rdfs:comment 'Number of suppliers affected by this lifecycle event (e.g., new suppliers onboarded for SOP, suppliers phased out for EOP).' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggeringAuthority rdf:type rdf:Property ;
    rdfs:label 'Triggering Authority' ;
    rdfs:comment 'Name or identifier of the person, role, or organizational unit that authorized or triggered this lifecycle event (e.g., Chief Product Officer, Program Manager, Executive Committee).' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringAuthorityReference rdf:type rdf:Property ;
    rdfs:label 'Triggering Authority Reference' ;
    rdfs:comment 'System identifier for the person or role that authorized this event, linking to employee or role master data.' ;
    rdfs:domain ind:ProductLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceDays rdf:type rdf:Property ;
    rdfs:label 'Variance Days' ;
    rdfs:comment 'Number of days between planned and actual event dates. Positive values indicate delay; negative values indicate early completion.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productSegmentId rdf:type rdf:Property ;
    rdfs:label 'Product Segment Id' ;
    rdfs:comment 'Unique identifier for the vehicle market segment. Primary key.' ;
    rdfs:domain ind:ProductSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentSegmentProductSegmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Segment Product Segment Id' ;
    rdfs:comment 'Reference to the parent segment in the hierarchy. Null for top-level segments.' ;
    rdfs:domain ind:ProductSegment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductSegment .

ind:adasLevelRange rdf:type rdf:Property ;
    rdfs:label 'Adas Level Range' ;
    rdfs:comment 'Range of SAE automation levels typically offered in this segment (e.g., L0-L2, L2-L3), following SAE J3016 standard.' ;
    rdfs:domain ind:ProductSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualSalesVolumeTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Sales Volume Target' ;
    rdfs:comment 'Target annual sales volume across all nameplates in this segment, used for capacity planning and market share analysis.' ;
    rdfs:domain ind:ProductSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cafeFleetCategory rdf:type rdf:Property ;
    rdfs:label 'Cafe Fleet Category' ;
    rdfs:comment 'CAFE fleet category for fuel economy averaging and compliance (e.g., passenger car, light truck, medium-duty, heavy-duty, exempt).' ;
    rdfs:domain ind:ProductSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoVolumeRangeCuFt rdf:type rdf:Property ;
    rdfs:label 'Cargo Volume Range Cu Ft' ;
    rdfs:comment 'Typical cargo volume range for vehicles in this segment, measured in cubic feet (e.g., 10-20, 30-50).' ;
    rdfs:domain ind:ProductSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveSetDefinition rdf:type rdf:Property ;
    rdfs:label 'Competitive Set Definition' ;
    rdfs:comment 'Description of the competitive set for this segment, listing key competitor nameplates and brands used for benchmarking and market share analysis.' ;
    rdfs:domain ind:ProductSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homologationRegions rdf:type rdf:Property ;
    rdfs:label 'Homologation Regions' ;
    rdfs:comment 'Comma-separated list of regions where this segment is homologated and available for sale (e.g., USA, CAN, MEX, EUR, CHN, JPN, AUS).' ;
    rdfs:domain ind:ProductSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Code' ;
    rdfs:comment 'Additional industry-standard classification code from bodies such as UNECE, EPA, or regional automotive authorities.' ;
    rdfs:domain ind:ProductSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketShareTargetPct rdf:type rdf:Property ;
    rdfs:label 'Market Share Target Pct' ;
    rdfs:comment 'Target market share percentage for this segment within the total addressable market.' ;
    rdfs:domain ind:ProductSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ncapRatingApplicability rdf:type rdf:Property ;
    rdfs:label 'Ncap Rating Applicability' ;
    rdfs:comment 'Applicable NCAP rating program for safety assessment in this segment (e.g., Euro NCAP, US NCAP, China NCAP, Latin NCAP, ASEAN NCAP).' ;
    rdfs:domain ind:ProductSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powertrainCategory rdf:type rdf:Property ;
    rdfs:label 'Powertrain Category' ;
    rdfs:comment 'Primary powertrain type associated with this segment: ICE (Internal Combustion Engine), HEV (Hybrid Electric Vehicle), PHEV (Plug-in Hybrid Electric Vehicle), BEV (Battery Electric Vehicle), FCEV (Fuel Cell Electric Vehicle), or Hybrid.' ;
    rdfs:domain ind:ProductSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceRangeMaxUsd rdf:type rdf:Property ;
    rdfs:label 'Price Range Max Usd' ;
    rdfs:comment 'Maximum Manufacturer Suggested Retail Price (MSRP) for vehicles in this segment, in USD.' ;
    rdfs:domain ind:ProductSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceRangeMinUsd rdf:type rdf:Property ;
    rdfs:label 'Price Range Min Usd' ;
    rdfs:comment 'Minimum Manufacturer Suggested Retail Price (MSRP) for vehicles in this segment, in USD.' ;
    rdfs:domain ind:ProductSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saeClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Sae Classification Code' ;
    rdfs:comment 'SAE International standard classification code for vehicle type and segment (e.g., J1979, J2735 vehicle class codes).' ;
    rdfs:domain ind:ProductSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed description of the market segment, including typical characteristics, target customer profile, and competitive positioning.' ;
    rdfs:domain ind:ProductSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPriority rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority' ;
    rdfs:comment 'Strategic priority level assigned to this segment for investment and resource allocation decisions.' ;
    rdfs:domain ind:ProductSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCustomerProfile rdf:type rdf:Property ;
    rdfs:label 'Target Customer Profile' ;
    rdfs:comment 'Description of the primary target customer demographic and psychographic profile for this segment (e.g., young families, urban professionals, fleet operators).' ;
    rdfs:domain ind:ProductSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Program Milestone Id' ;
    rdfs:comment 'Unique identifier for the program milestone record. Primary key for the program milestone entity.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:predecessorMilestoneProgramMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Milestone Program Milestone Id' ;
    rdfs:comment 'Reference to the immediately preceding milestone that must be achieved before this milestone can begin. Null for the first milestone in the program sequence. Enables critical path analysis.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramMilestone .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Approved baseline date after program approval or re-baseline. Used as the official target for performance measurement and variance calculation.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Impact Amount' ;
    rdfs:comment 'Estimated financial impact (in base currency) if this milestone is delayed. Used for prioritization and executive escalation. Null if no quantified impact.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalPathFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Path Flag' ;
    rdfs:comment 'Indicates whether this milestone is on the program critical path. True if any delay to this milestone will delay the overall program SOP date. Used for prioritization and risk management.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliverableCompletedCount rdf:type rdf:Property ;
    rdfs:label 'Deliverable Completed Count' ;
    rdfs:comment 'Number of deliverables that have been completed and approved. Used to calculate completion_percentage and assess readiness for gate review.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliverableCount rdf:type rdf:Property ;
    rdfs:label 'Deliverable Count' ;
    rdfs:comment 'Number of formal deliverables (documents, approvals, test results) required to achieve this milestone. Used to track completion progress.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalDependencyDescription rdf:type rdf:Property ;
    rdfs:label 'External Dependency Description' ;
    rdfs:comment 'Description of external dependencies, including supplier names, partner organizations, or regulatory agencies. Null if external_dependency_flag is false.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalDependencyFlag rdf:type rdf:Property ;
    rdfs:label 'External Dependency Flag' ;
    rdfs:comment 'Indicates whether this milestone depends on external parties (suppliers, partners, regulatory agencies) for completion. True if external coordination required, false if fully internal.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'Current forecast date for milestone achievement based on latest program status. Updated regularly during program reviews. Null if milestone already achieved.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gateReviewComments rdf:type rdf:Property ;
    rdfs:label 'Gate Review Comments' ;
    rdfs:comment 'Executive comments, conditions, or action items resulting from the gate review meeting. Captures key decisions and follow-up requirements.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateReviewDate rdf:type rdf:Property ;
    rdfs:label 'Gate Review Date' ;
    rdfs:comment 'Date the formal gate review meeting was held. Null if gate_review_required is false or review not yet conducted.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gateReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Gate Review Required' ;
    rdfs:comment 'Indicates whether a formal gate review (executive approval meeting) is required before this milestone can be marked as achieved. True for major program gates (e.g., Program Approval, SOP), false for intermediate checkpoints.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Mitigation Plan' ;
    rdfs:comment 'Action plan to address identified risks and recover schedule. Includes specific actions, owners, and target dates. Null if risk_level is low.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Indicates whether this milestone is driven by regulatory or homologation requirements (e.g., NHTSA, EPA, Euro NCAP, WLTP certification). True for regulatory gates, false for internal program milestones.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleFunction rdf:type rdf:Property ;
    rdfs:label 'Responsible Function' ;
    rdfs:comment 'Primary functional organization accountable for achieving this milestone: engineering (design/CAE), manufacturing (plant readiness), quality (PPAP/APQP), supply_chain (supplier readiness), regulatory (homologation), commercial (launch), program_management (gate reviews). [ENUM-REF-CANDIDATE: engineering|manufacturing|quality|supply_chain|regulatory|commercial|program_management — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed description of risks, issues, or blockers that may prevent timely achievement of this milestone. Updated during program status reviews.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Reference to the executive who approved the milestone waiver. Links to workforce/employee master data. Null if milestone not waived.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waiverApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved Date' ;
    rdfs:comment 'Date the milestone waiver was formally approved. Null if milestone not waived.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cargoVolumeCuFt rdf:type rdf:Property ;
    rdfs:label 'Cargo Volume Cu Ft' ;
    rdfs:comment 'The cargo area volume in cubic feet behind the rear seats.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:curbWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Curb Weight Lbs' ;
    rdfs:comment 'The vehicle weight in pounds without passengers or cargo, but with all fluids and standard equipment.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drivetrainType rdf:type rdf:Property ;
    rdfs:label 'Drivetrain Type' ;
    rdfs:comment 'The drivetrain configuration: FWD (Front-Wheel Drive), RWD (Rear-Wheel Drive), AWD (All-Wheel Drive), or 4WD (Four-Wheel Drive).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electricRangeMiles rdf:type rdf:Property ;
    rdfs:label 'Electric Range Miles' ;
    rdfs:comment 'The EPA-certified all-electric driving range in miles for BEV and PHEV configurations. Null for non-electric powertrains.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gvwrLbs rdf:type rdf:Property ;
    rdfs:label 'Gvwr Lbs' ;
    rdfs:comment 'The maximum allowable total weight of the vehicle including passengers, cargo, and fluids, in pounds.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:horsepower rdf:type rdf:Property ;
    rdfs:label 'Horsepower' ;
    rdfs:comment 'The maximum engine or motor power output in horsepower.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoicePriceAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Price Amount' ;
    rdfs:comment 'The dealer invoice price for this SKU configuration, representing the base cost to the dealer before incentives.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketDestinationCode rdf:type rdf:Property ;
    rdfs:label 'Market Destination Code' ;
    rdfs:comment 'The ISO country or regional market code indicating the regulatory and specification destination for this SKU (e.g., USA, CAN, EUR, CHN).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionPackageCodes rdf:type rdf:Property ;
    rdfs:label 'Option Package Codes' ;
    rdfs:comment 'Comma-separated list of option package codes included in this SKU configuration (e.g., technology package, premium audio, towing package).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderableEndDate rdf:type rdf:Property ;
    rdfs:label 'Orderable End Date' ;
    rdfs:comment 'The date when this SKU will no longer be available for new customer orders. Null for active SKUs with no planned end date.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderableStartDate rdf:type rdf:Property ;
    rdfs:label 'Orderable Start Date' ;
    rdfs:comment 'The date when this SKU became or will become available for customer orders.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:torqueLbFt rdf:type rdf:Property ;
    rdfs:label 'Torque Lb Ft' ;
    rdfs:comment 'The maximum engine or motor torque output in pound-feet.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transmissionSpeedCount rdf:type rdf:Property ;
    rdfs:label 'Transmission Speed Count' ;
    rdfs:comment 'The number of forward gears in the transmission (e.g., 6, 8, 10). Null for CVT and single-speed electric drivetrains.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wheelbaseInches rdf:type rdf:Property ;
    rdfs:label 'Wheelbase Inches' ;
    rdfs:comment 'The distance between the front and rear axle centerlines in inches.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availabilityRegions rdf:type rdf:Property ;
    rdfs:label 'Availability Regions' ;
    rdfs:comment 'Comma-separated list of geographic regions or markets where this trim level is available for sale (e.g., USA, CAN, MEX, EUR, CHN). Detailed region-to-trim mappings maintained in separate association tables.' ;
    rdfs:domain ind:AftersalesTrimLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFleetEligible rdf:type rdf:Property ;
    rdfs:label 'Is Fleet Eligible' ;
    rdfs:comment 'Indicates whether this trim level is available for fleet and commercial sales programs.' ;
    rdfs:domain ind:AftersalesTrimLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSpecialEdition rdf:type rdf:Property ;
    rdfs:label 'Is Special Edition' ;
    rdfs:comment 'Indicates whether this trim level is a limited or special edition with unique features, badging, or production volume constraints.' ;
    rdfs:domain ind:AftersalesTrimLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketSegment rdf:type rdf:Property ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'The target market segment for this trim level, indicating the positioning strategy and customer demographic focus. [ENUM-REF-CANDIDATE: entry|mid|premium|luxury|performance|commercial|fleet — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrpBasePrice rdf:type rdf:Property ;
    rdfs:label 'Msrp Base Price' ;
    rdfs:comment 'The manufacturer\'s suggested retail price for this trim level in the base configuration, excluding options, packages, destination charges, and taxes. Expressed in the home currency.' ;
    rdfs:domain ind:AftersalesTrimLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ncapOverallRating rdf:type rdf:Property ;
    rdfs:label 'Ncap Overall Rating' ;
    rdfs:comment 'Overall safety rating from NCAP testing (1-5 stars). May vary by market (NHTSA, Euro NCAP, etc.).' ;
    rdfs:domain ind:AftersalesTrimLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionStatus rdf:type rdf:Property ;
    rdfs:label 'Production Status' ;
    rdfs:comment 'Current production lifecycle status of this trim level: planned (not yet in production), pre_production (tooling and validation), active (in production), discontinued (no longer produced but still sold), or end_of_life (fully retired).' ;
    rdfs:domain ind:AftersalesTrimLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardFeaturesSummary rdf:type rdf:Property ;
    rdfs:label 'Standard Features Summary' ;
    rdfs:comment 'High-level summary of the standard features included in this trim level (e.g., engine type, transmission, infotainment system, safety features). Detailed feature-to-trim mappings are maintained in separate association tables.' ;
    rdfs:domain ind:AftersalesTrimLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trimCode rdf:type rdf:Property ;
    rdfs:label 'Trim Code' ;
    rdfs:comment 'The internal alphanumeric code uniquely identifying this trim level within the nameplate and model year. Used in manufacturing, ordering, and dealer systems.' ;
    rdfs:domain ind:AftersalesTrimLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trimDescription rdf:type rdf:Property ;
    rdfs:label 'Trim Description' ;
    rdfs:comment 'Detailed description of the trim level, including key features, positioning, and target customer segment. Used for marketing materials and dealer training.' ;
    rdfs:domain ind:AftersalesTrimLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trimName rdf:type rdf:Property ;
    rdfs:label 'Trim Name' ;
    rdfs:comment 'The commercial marketing name of the trim level (e.g., Base, XL, XLT, Lariat, Platinum, Limited, King Ranch, Raptor). This is the customer-facing designation.' ;
    rdfs:domain ind:AftersalesTrimLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trimRank rdf:type rdf:Property ;
    rdfs:label 'Trim Rank' ;
    rdfs:comment 'Ordinal ranking of this trim level within the nameplate hierarchy, where lower numbers indicate entry-level trims and higher numbers indicate premium trims. Used for sorting and comparison.' ;
    rdfs:domain ind:AftersalesTrimLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyBasicMiles rdf:type rdf:Property ;
    rdfs:label 'Warranty Basic Miles' ;
    rdfs:comment 'Mileage limit of the basic bumper-to-bumper warranty in miles for this trim level.' ;
    rdfs:domain ind:AftersalesTrimLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyBasicMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Basic Months' ;
    rdfs:comment 'Duration of the basic bumper-to-bumper warranty in months for this trim level.' ;
    rdfs:domain ind:AftersalesTrimLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualPpm rdf:type rdf:Property ;
    rdfs:label 'Actual Ppm' ;
    rdfs:comment 'Measured parts-per-million defect rate observed after validation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Release Date' ;
    rdfs:comment 'Actual date when the product was released to production.' ;
    rdfs:domain ind:ApqpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:classificationType rdf:type rdf:Property ;
    rdfs:label 'Classification Type' ;
    rdfs:comment 'Category of the APQP plan based on product scope.' ;
    rdfs:domain ind:ApqpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationLink rdf:type rdf:Property ;
    rdfs:label 'Documentation Link' ;
    rdfs:comment 'URL or path to the primary APQP documentation repository.' ;
    rdfs:domain ind:ApqpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Gate Completion Date' ;
    rdfs:comment 'Actual date when the milestone gate was completed.' ;
    rdfs:domain ind:ApqpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gateDueDate rdf:type rdf:Property ;
    rdfs:label 'Gate Due Date' ;
    rdfs:comment 'Planned due date for the milestone gate.' ;
    rdfs:domain ind:ApqpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gateStatus rdf:type rdf:Property ;
    rdfs:label 'Gate Status' ;
    rdfs:comment 'Current status of the milestone gate.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneGate rdf:type rdf:Property ;
    rdfs:label 'Milestone Gate' ;
    rdfs:comment 'Specific APQP milestone gate associated with the plan.' ;
    rdfs:domain ind:ApqpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Name of the internal owner or manager of the APQP plan.' ;
    rdfs:domain ind:ApqpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityGoalPpm rdf:type rdf:Property ;
    rdfs:label 'Quality Goal Ppm' ;
    rdfs:comment 'Target parts-per-million defect rate defined for the APQP plan.' ;
    rdfs:domain ind:ApqpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Date' ;
    rdfs:comment 'Date when the risk assessment for the APQP plan was performed.' ;
    rdfs:domain ind:ApqpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetPpm rdf:type rdf:Property ;
    rdfs:label 'Target Ppm' ;
    rdfs:comment 'Planned PPM level to achieve during the APQP process.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Target Release Date' ;
    rdfs:comment 'Planned date for the product release associated with the APQP plan.' ;
    rdfs:domain ind:ApqpPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationEventId rdf:type rdf:Property ;
    rdfs:label 'Calibration Event Id' ;
    rdfs:comment 'Unique identifier for the calibration event record.' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gaugeMasterId rdf:type rdf:Property ;
    rdfs:label 'Gauge Gauge Master Id' ;
    rdfs:comment 'Identifier of the gauge or measurement instrument being calibrated.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GaugeMaster .

ind:gaugeMasterId rdf:type rdf:Property ;
    rdfs:label 'Gauge Master Id' ;
    rdfs:comment 'Identifier of the gauge or measurement instrument being calibrated.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GaugeMaster .

ind:asFoundValue rdf:type rdf:Property ;
    rdfs:label 'As Found Value' ;
    rdfs:comment 'Measured value of the gauge before any adjustment.' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asLeftValue rdf:type rdf:Property ;
    rdfs:label 'As Left Value' ;
    rdfs:comment 'Measured value of the gauge after adjustment (post-calibration).' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationEventStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Event Status' ;
    rdfs:comment 'Overall lifecycle status of the calibration event.' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationLab rdf:type rdf:Property ;
    rdfs:label 'Calibration Lab' ;
    rdfs:comment 'Name of the internal or external laboratory that performed the calibration.' ;
    rdfs:domain ind:CalibrationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calibration Timestamp' ;
    rdfs:comment 'Exact date and time when the calibration activity was performed.' ;
