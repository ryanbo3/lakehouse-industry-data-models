ind:equipmentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Serial Number' ;
    rdfs:comment 'Manufacturer supplied serial number of the equipment.' ;
    rdfs:domain ind:WarrantyClaimEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTag rdf:type rdf:Property ;
    rdfs:label 'Equipment Tag' ;
    rdfs:comment 'Plant asset tag or barcode assigned to the equipment.' ;
    rdfs:domain ind:WarrantyClaimEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority assigned to the claim for handling.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairActionDescription rdf:type rdf:Property ;
    rdfs:label 'Repair Action Description' ;
    rdfs:comment 'Detailed description of the repair or replacement work performed.' ;
    rdfs:domain ind:WarrantyClaimEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairDecision rdf:type rdf:Property ;
    rdfs:label 'Repair Decision' ;
