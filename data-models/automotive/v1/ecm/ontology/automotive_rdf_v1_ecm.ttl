ind:financialPeriodCloseId rdf:type rdf:Property ;
    rdfs:label 'Financial Period Close Id' ;
    rdfs:comment 'System-generated unique identifier for each financial period close record.' ;
    rdfs:domain ind:FinancialPeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockingIssueDescription rdf:type rdf:Property ;
    rdfs:label 'Blocking Issue Description' ;
    rdfs:comment 'Text describing any issue that prevented the task from progressing.' ;
