ind:dispatcherEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dispatcher Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Dispatch planning process assigns a dispatcher employee to each transport order for tracking and accountability.' ;
    rdfs:domain ind:VehicleTransportOrder ;
    rdf:type owl:ObjectProperty ;
