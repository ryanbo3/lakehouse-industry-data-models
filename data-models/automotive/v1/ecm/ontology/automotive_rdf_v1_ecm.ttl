    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End' ;
    rdfs:comment 'Last calendar day of the period for which reliability metrics are calculated.' ;
