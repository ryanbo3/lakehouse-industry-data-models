ind:handoverNumber rdf:type rdf:Property ;
    rdfs:label 'Handover Number' ;
    rdfs:comment 'Business-assigned handover reference number used for tracking and communication.' ;
    rdfs:domain ind:VehicleHandover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverStatus rdf:type rdf:Property ;
    rdfs:label 'Handover Status' ;
    rdfs:comment 'Current processing status of the handover record.' ;
