    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Event Timestamp' ;
    rdfs:comment 'Timestamp of the primary event that marks the execution of the close task.' ;
