    rdfs:comment 'List of compatible telematics devices or platforms (e.g., Bosch, Geotab).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityRules rdf:type rdf:Property ;
