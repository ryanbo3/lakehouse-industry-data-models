ind:rateValue rdf:type rdf:Property ;
    rdfs:label 'Rate Value' ;
    rdfs:comment 'Numeric exchange rate value expressed as the amount of target currency per one unit of source currency.' ;
    rdfs:domain ind:CurrencyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'Start date of the period during which the rate is valid.' ;
    rdfs:domain ind:CurrencyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validTo rdf:type rdf:Property ;
    rdfs:label 'Valid To' ;
    rdfs:comment 'End date of the period during which the rate is valid; null if open-ended.' ;
    rdfs:domain ind:CurrencyRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dealerIncentiveId rdf:type rdf:Property ;
    rdfs:label 'Dealer Incentive Id' ;
    rdfs:comment 'Unique surrogate key for the dealer incentive record.' ;
    rdfs:domain ind:DealerIncentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountingPeriod rdf:type rdf:Property ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'Fiscal period (e.g., FY2025) to which the incentive expense is allocated.' ;
