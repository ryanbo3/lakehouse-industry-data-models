ind:loadPlanId rdf:type rdf:Property ;
    rdfs:label 'Load Plan Id' ;
    rdfs:comment 'Identifier of the load planning record associated with this transport order.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoadPlan .

ind:carrierContact rdf:type rdf:Property ;
    rdfs:label 'Carrier Contact' ;
    rdfs:comment 'Primary phone number for the carrier\'s dispatch desk.' ;
    rdfs:domain ind:VehicleTransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedPickupDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Pickup Date' ;
    rdfs:comment 'Date the carrier confirmed for vehicle pickup.' ;
    rdfs:domain ind:VehicleTransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customsDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Number' ;
    rdfs:comment 'Identifier of the customs declaration for cross-border shipments.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionCo2Kg rdf:type rdf:Property ;
    rdfs:label 'Emission Co2 Kg' ;
    rdfs:comment 'Estimated CO₂ emissions for the shipment based on distance and vehicle type.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Flag' ;
    rdfs:comment 'Indicates whether the shipment was delivered within the agreed on-time window.' ;
    rdfs:domain ind:VehicleTransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Created Timestamp' ;
    rdfs:comment 'Timestamp when the transport order was initially created in the system.' ;
    rdfs:domain ind:VehicleTransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originCompound rdf:type rdf:Property ;
    rdfs:label 'Origin Compound' ;
    rdfs:comment 'Name of the storage yard or compound where vehicles are staged before pickup.' ;
    rdfs:domain ind:VehicleTransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedPickupDate rdf:type rdf:Property ;
    rdfs:label 'Requested Pickup Date' ;
    rdfs:comment 'Date the shipper requested the carrier to pick up the vehicles.' ;
    rdfs:domain ind:VehicleTransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingInstructions rdf:type rdf:Property ;
    rdfs:label 'Shipping Instructions' ;
    rdfs:comment 'Special handling or routing instructions for the carrier.' ;
    rdfs:domain ind:VehicleTransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportCostGross rdf:type rdf:Property ;
    rdfs:label 'Transport Cost Gross' ;
    rdfs:comment 'Total gross cost charged by the carrier before taxes and discounts.' ;
    rdfs:domain ind:VehicleTransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportCostNet rdf:type rdf:Property ;
    rdfs:label 'Transport Cost Net' ;
    rdfs:comment 'Net amount payable to the carrier after taxes and discounts.' ;
    rdfs:domain ind:VehicleTransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportCostTax rdf:type rdf:Property ;
    rdfs:label 'Transport Cost Tax' ;
    rdfs:comment 'Tax component of the transport cost.' ;
    rdfs:domain ind:VehicleTransportOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vesselVoyageId rdf:type rdf:Property ;
    rdfs:label 'Vessel Voyage Id' ;
    rdfs:comment 'System-generated unique identifier for the vessel voyage record.' ;
    rdfs:domain ind:VesselVoyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:captainEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Captain Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Voyage management tracks the captain (employee) assigned to each vessel voyage for safety and regulatory reporting.' ;
    rdfs:domain ind:VesselVoyage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:shippingLineId rdf:type rdf:Property ;
    rdfs:label 'Shipping Line Id' ;
    rdfs:comment 'Unique identifier of the shipping line operating the vessel.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShippingLine .

ind:availableCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Units' ;
    rdfs:comment 'Remaining vehicle capacity after bookings (capacity minus booked units).' ;
    rdfs:domain ind:VesselVoyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookedUnits rdf:type rdf:Property ;
    rdfs:label 'Booked Units' ;
    rdfs:comment 'Number of vehicle units already booked for the voyage.' ;
    rdfs:domain ind:VesselVoyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationPortCode rdf:type rdf:Property ;
    rdfs:label 'Destination Port Code' ;
    rdfs:comment 'Three-letter UN/LOCODE of the port where the voyage terminates.' ;
    rdfs:domain ind:VesselVoyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imoNumber rdf:type rdf:Property ;
    rdfs:label 'Imo Number' ;
    rdfs:comment 'Seven-digit unique identifier for the vessel as defined by IMO conventions.' ;
    rdfs:domain ind:VesselVoyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originPortCode rdf:type rdf:Property ;
    rdfs:label 'Origin Port Code' ;
    rdfs:comment 'Three-letter UN/LOCODE of the port where the voyage originates.' ;
    rdfs:domain ind:VesselVoyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Vessel Capacity Units' ;
    rdfs:comment 'Maximum number of vehicles the vessel can transport on this voyage.' ;
    rdfs:domain ind:VesselVoyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voyageStatus rdf:type rdf:Property ;
    rdfs:label 'Voyage Status' ;
    rdfs:comment 'Current operational status of the voyage.' ;
    rdfs:domain ind:VesselVoyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voyageStatusReason rdf:type rdf:Property ;
    rdfs:label 'Voyage Status Reason' ;
    rdfs:comment 'Free-text explanation for the current voyage status, e.g., weather delay, mechanical issue.' ;
    rdfs:domain ind:VesselVoyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voyageType rdf:type rdf:Property ;
    rdfs:label 'Voyage Type' ;
    rdfs:comment 'Category of vessel operation, such as Roll-On/Roll-Off (RoRo) or container.' ;
    rdfs:domain ind:VesselVoyage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftId rdf:type rdf:Property ;
    rdfs:label 'Shift Id' ;
    rdfs:comment 'Reference to the production shift during which this AGV movement occurred. Enables shift-level fleet utilization reporting, throughput analysis, and comparison of AGV performance across shifts.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shift .

ind:agvControllerCode rdf:type rdf:Property ;
    rdfs:label 'Agv Controller Code' ;
    rdfs:comment 'Identifier of the AGV fleet management controller or traffic management system (e.g., a specific SCADA or AGV supervisor node) that dispatched and managed this movement. Supports multi-controller fleet architectures and fault isolation.' ;
    rdfs:domain ind:AgvMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agvUnitCode rdf:type rdf:Property ;
    rdfs:label 'Agv Unit Code' ;
    rdfs:comment 'The unique physical identifier assigned to the AGV unit performing the movement. Used for fleet management, maintenance scheduling, and utilization tracking per individual vehicle.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyStage rdf:type rdf:Property ;
    rdfs:label 'Assembly Stage' ;
    rdfs:comment 'The manufacturing assembly stage to which this AGV movement is associated (e.g., stamping, body shop, paint, trim, chassis, final assembly). Enables stage-level material flow analysis and supports multi-stage production traceability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageSpeedMps rdf:type rdf:Property ;
    rdfs:label 'Average Speed Mps' ;
    rdfs:comment 'The average travel speed of the AGV in metres per second during this movement. Used to identify speed anomalies, assess compliance with shop floor speed limits, and support throughput optimization.' ;
    rdfs:domain ind:AgvMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batteryLevelEndPct rdf:type rdf:Property ;
    rdfs:label 'Battery Level End Pct' ;
    rdfs:comment 'The AGV battery state of charge as a percentage at the time the movement task ended. Combined with battery_level_start_pct to calculate energy consumption per movement and model battery degradation over time.' ;
    rdfs:domain ind:AgvMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batteryLevelStartPct rdf:type rdf:Property ;
    rdfs:label 'Battery Level Start Pct' ;
    rdfs:comment 'The AGV battery state of charge as a percentage at the time the movement task began. Used for fleet energy management, charge scheduling optimization, and identifying movements that may have been impacted by low battery conditions.' ;
    rdfs:domain ind:AgvMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationLocationName rdf:type rdf:Property ;
    rdfs:label 'Destination Location Name' ;
    rdfs:comment 'Human-readable descriptive name of the destination location (e.g., \'Final Assembly Line 2 Station 14\', \'Trim Shop Sequencing Buffer\'). Supports operational dashboards and exception reporting.' ;
    rdfs:domain ind:AgvMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceTravelledM rdf:type rdf:Property ;
    rdfs:label 'Distance Travelled M' ;
    rdfs:comment 'The total distance in metres travelled by the AGV during this movement event, as reported by the AGV\'s odometry or navigation system. Used for fleet utilization reporting, energy consumption modelling, and route efficiency analysis.' ;
    rdfs:domain ind:AgvMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:faultCode rdf:type rdf:Property ;
    rdfs:label 'Fault Code' ;
    rdfs:comment 'The fault or exception code reported by the AGV or fleet controller during this movement (e.g., obstacle detected, navigation error, battery low, load sensor failure). Null if no fault occurred. Used for predictive maintenance, FMEA (Failure Mode and Effects Analysis), and fleet reliability reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultDescription rdf:type rdf:Property ;
    rdfs:label 'Fault Description' ;
    rdfs:comment 'Human-readable description of the fault or exception that occurred during this movement. Provides operational context for maintenance technicians and MES operators beyond the structured fault_code.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fault Timestamp' ;
    rdfs:comment 'The precise date and time when the fault or exception was detected during this AGV movement. Null if no fault occurred. Used for mean time between failures (MTBF) calculation and maintenance response time analysis.' ;
    rdfs:domain ind:AgvMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isManualOverride rdf:type rdf:Property ;
    rdfs:label 'Is Manual Override' ;
    rdfs:comment 'Indicates whether this AGV movement was manually overridden or initiated by a human operator rather than being fully automated by the MES or AGV fleet controller (True = manual override, False = fully automated). Used for automation rate reporting and exception analysis.' ;
    rdfs:domain ind:AgvMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jisCallOffFlag rdf:type rdf:Property ;
    rdfs:label 'Jis Call Off Flag' ;
    rdfs:comment 'Indicates whether this AGV movement was triggered by a JIS (Just-in-Sequence) call-off signal from the assembly line (True = JIS-triggered, False = standard replenishment or non-sequenced movement). Critical for sequencing compliance reporting and line-feed performance analysis.' ;
    rdfs:domain ind:AgvMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mesTaskCode rdf:type rdf:Property ;
    rdfs:label 'Mes Task Code' ;
    rdfs:comment 'The unique task or dispatch identifier assigned by the MES (Manufacturing Execution System) — specifically Apriso/Dassault — to this AGV movement instruction. Used for cross-system reconciliation between the AGV fleet controller and the MES shop floor execution layer.' ;
    rdfs:domain ind:AgvMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Movement End Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) when the AGV completed or terminated the movement task. Null if the movement is still in progress. Used with movement_start_timestamp to derive actual cycle time.' ;
    rdfs:domain ind:AgvMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:movementStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Movement Start Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) when the AGV began executing the movement task. Used for cycle time calculation, throughput analysis, and JIS (Just-in-Sequence) compliance verification.' ;
    rdfs:domain ind:AgvMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle state of the AGV movement event. Tracks whether the movement is actively executing, successfully completed, aborted due to an obstacle, faulted due to a system error, or cancelled by the MES scheduler.' ;
    rdfs:domain ind:AgvMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocationName rdf:type rdf:Property ;
    rdfs:label 'Origin Location Name' ;
    rdfs:comment 'Human-readable descriptive name of the origin location (e.g., \'Body Shop Buffer Lane 3\', \'Paint Shop Entry Conveyor\', \'Stamping Parts Supermarket\'). Supports operational reporting and shop floor visualization dashboards.' ;
    rdfs:domain ind:AgvMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityTransported rdf:type rdf:Property ;
    rdfs:label 'Quantity Transported' ;
    rdfs:comment 'The number of parts, units, or assemblies carried by the AGV in this movement. Used for material flow volume reporting, inventory reconciliation, and JIT (Just-in-Time) delivery quantity verification.' ;
    rdfs:domain ind:AgvMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routeDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Route Deviation Flag' ;
    rdfs:comment 'Indicates whether the AGV deviated from its assigned route during this movement (True = deviation occurred, False = route followed as planned). Deviations may indicate obstacles, dynamic re-routing, or system faults requiring investigation.' ;
    rdfs:domain ind:AgvMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturingBomComponentId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Bom Component Id' ;
    rdfs:comment 'Unique surrogate identifier for a single line-item record within a manufacturing Bill of Materials (BOM). Serves as the primary key for this entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:ManufacturingBomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredVendorId rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Id' ;
    rdfs:comment 'Reference to the preferred or primary approved supplier for this component. Used in MRP source determination and JIT call-off scheduling to identify the default supply source.' ;
    rdfs:domain ind:ManufacturingBomComponent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:productionBomId rdf:type rdf:Property ;
    rdfs:label 'Production Bom Id' ;
    rdfs:comment 'Reference to the parent BOM header to which this component line-item belongs. Links the component to its governing vehicle or sub-assembly BOM structure.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionBom .

ind:alternatePartGroup rdf:type rdf:Property ;
    rdfs:label 'Alternate Part Group' ;
    rdfs:comment 'Code identifying the alternate item group to which this component belongs in the BOM. Components within the same alternate group are interchangeable. Used in SAP BOM alternative item management for production flexibility.' ;
    rdfs:domain ind:ManufacturingBomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternatePartNumber rdf:type rdf:Property ;
    rdfs:label 'Alternate Part Number' ;
    rdfs:comment 'OEM part number of an approved alternate or substitute component that can be used in place of the primary part when the primary is unavailable. Supports supply chain continuity and JIT material substitution.' ;
    rdfs:domain ind:ManufacturingBomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backflushIndicator rdf:type rdf:Property ;
    rdfs:label 'Backflush Indicator' ;
    rdfs:comment 'Indicates whether this component is backflushed (automatically goods-issued upon production order confirmation) rather than requiring a discrete goods movement transaction. True = backflush; False = manual goods issue required. Common for bulk and low-value components.' ;
    rdfs:domain ind:ManufacturingBomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bomLevel rdf:type rdf:Property ;
    rdfs:label 'Bom Level' ;
    rdfs:comment 'Hierarchical depth of this component within the multi-level BOM structure. Level 0 is the finished vehicle; level 1 is a major assembly; deeper levels represent sub-assemblies and individual parts. Used for BOM explosion and cost rollup.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bulkMaterialIndicator rdf:type rdf:Property ;
    rdfs:label 'Bulk Material Indicator' ;
    rdfs:comment 'Flags this component as a bulk material (e.g., adhesives, lubricants, fasteners) that is issued to the production order without discrete picking or goods movement. Bulk materials are typically excluded from MRP individual requirements.' ;
    rdfs:domain ind:ManufacturingBomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coProductIndicator rdf:type rdf:Property ;
    rdfs:label 'Co Product Indicator' ;
    rdfs:comment 'Flags this BOM item as a co-product or by-product that is produced alongside the primary output (e.g., stamping offcuts, recycled materials). Co-products receive a portion of the production order cost allocation.' ;
    rdfs:domain ind:ManufacturingBomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commodityCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Code' ;
    rdfs:comment 'Procurement commodity classification code grouping this component into a spend category (e.g., \'ELEC-ECU\', \'BODY-STAMPING\', \'POWERTRAIN-EV-BATTERY\'). Used in supply chain management (SCM), RFQ processes, and supplier performance reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentStatus rdf:type rdf:Property ;
    rdfs:label 'Component Status' ;
    rdfs:comment 'Current lifecycle status of this BOM component line. \'superseded\' indicates the part has been replaced by an alternate; \'pending_approval\' indicates the component is awaiting PPAP (Production Part Approval Process) sign-off before use in production.' ;
    rdfs:domain ind:ManufacturingBomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawingRevision rdf:type rdf:Property ;
    rdfs:label 'Drawing Revision' ;
    rdfs:comment 'Revision level of the engineering drawing or CAD model applicable to this BOM component (e.g., \'A\', \'B\', \'01\'). Ensures the correct design revision is used in production and supports PPAP documentation.' ;
    rdfs:domain ind:ManufacturingBomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivityEndDate rdf:type rdf:Property ;
    rdfs:label 'Effectivity End Date' ;
    rdfs:comment 'Date after which this BOM component line is no longer valid and should be excluded from production builds. Null indicates an open-ended validity. Supports EOP (End of Production) transitions and engineering change cutover.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivityStartDate rdf:type rdf:Property ;
    rdfs:label 'Effectivity Start Date' ;
    rdfs:comment 'Date from which this BOM component line is valid and should be included in production builds. Supports engineering change management and model year (MY) transitions. Components before this date are not called off.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engineeringChangeNumber rdf:type rdf:Property ;
    rdfs:label 'Engineering Change Number' ;
    rdfs:comment 'Reference to the Engineering Change Notice (ECN) or Engineering Change Order (ECO) that introduced or last modified this BOM component line. Provides full traceability of design changes from PLM through to the manufacturing BOM.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaReference rdf:type rdf:Property ;
    rdfs:label 'Fmea Reference' ;
    rdfs:comment 'Document reference number for the Design FMEA (DFMEA) or Process FMEA (PFMEA) associated with this component. Supports APQP (Advanced Product Quality Planning) traceability and IATF 16949 risk management requirements.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Indicator' ;
    rdfs:comment 'Flags this component as containing hazardous materials subject to regulatory controls (e.g., lead, cadmium, hexavalent chromium under EU ELV Directive, or lithium battery cells under UN 38.3). Triggers special handling, storage, and disposal procedures.' ;
    rdfs:domain ind:ManufacturingBomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installationSequence rdf:type rdf:Property ;
    rdfs:label 'Installation Sequence' ;
    rdfs:comment 'Numeric sequence defining the order in which this component is installed relative to other components at the same work center. Critical for JIS (Just-in-Sequence) material call-offs and shop floor assembly instruction generation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'SAP BOM item category code indicating how the component is managed in inventory and procurement (e.g., stock item \'L\', non-stock item \'N\', variable-size item \'R\'). Drives material requirements planning (MRP) and goods movement behavior.' ;
    rdfs:domain ind:ManufacturingBomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadOffsetDays rdf:type rdf:Property ;
    rdfs:label 'Lead Offset Days' ;
    rdfs:comment 'Number of days before or after the parent order start date that this component must be available at the work center. Negative values indicate the component must arrive before the order start. Used in JIT/JIS scheduling and MRP net requirements calculation.' ;
    rdfs:domain ind:ManufacturingBomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationNumber rdf:type rdf:Property ;
    rdfs:label 'Operation Number' ;
    rdfs:comment 'Four-digit SAP routing operation number to which this BOM component is assigned. Links the component to the specific assembly step in the production routing, enabling shop floor assembly instruction generation and MES work order sequencing.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phantomAssemblyIndicator rdf:type rdf:Property ;
    rdfs:label 'Phantom Assembly Indicator' ;
    rdfs:comment 'Indicates whether this component is a phantom assembly — a logical grouping used for BOM structuring that has no physical stock or production order. MRP explodes through phantom assemblies to plan the underlying components directly.' ;
    rdfs:domain ind:ManufacturingBomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityInAltGroup rdf:type rdf:Property ;
    rdfs:label 'Priority In Alt Group' ;
    rdfs:comment 'Numeric priority rank of this component within its alternate item group. Lower numbers indicate higher preference. MRP uses this priority to determine which alternate to consume first when multiple substitutes are available.' ;
    rdfs:domain ind:ManufacturingBomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityPerVehicle rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Vehicle' ;
    rdfs:comment 'Number of units of this component required to build one complete vehicle or parent assembly. Supports fractional quantities for bulk materials (e.g., 0.5 litres of adhesive). Used in MRP material call-off calculations and JIT/JIS scheduling.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reachSvhcIndicator rdf:type rdf:Property ;
    rdfs:label 'Reach Svhc Indicator' ;
    rdfs:comment 'Indicates whether this component contains a Substance of Very High Concern (SVHC) as defined under EU REACH Regulation (EC) No 1907/2006. Required for regulatory compliance reporting and customer disclosure obligations.' ;
    rdfs:domain ind:ManufacturingBomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scrapFactorPct rdf:type rdf:Property ;
    rdfs:label 'Scrap Factor Pct' ;
    rdfs:comment 'Expected percentage of this component that will be scrapped during the manufacturing process, expressed as a decimal percentage (e.g., 2.5000 = 2.5%). Used to inflate the planned component quantity in MRP to account for anticipated process losses. Supports PPM (Parts Per Million) defect tracking.' ;
    rdfs:domain ind:ManufacturingBomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Standard cost per unit of this component in the plant currency, as maintained in the SAP material master cost estimate. Used in production order cost rollup, BOM cost analysis, and EBITDA reporting. Classified confidential as it contains sensitive pricing data.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Usage Probability Pct' ;
    rdfs:comment 'Probability (0–100%) that this component will actually be consumed in a given build, used for optional or variant-dependent components. Supports MRP planning for configurable vehicles where not every component is installed on every unit.' ;
    rdfs:domain ind:ManufacturingBomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variantCondition rdf:type rdf:Property ;
    rdfs:label 'Variant Condition' ;
    rdfs:comment 'Boolean or characteristic-based condition expression that determines when this component is included in a configurable BOM (e.g., \'ENGINE_TYPE = V8 AND MARKET = USA\'). Used in SAP Variant Configuration and Teamcenter product configuration management.' ;
    rdfs:domain ind:ManufacturingBomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleProgramCode rdf:type rdf:Property ;
    rdfs:label 'Vehicle Program Code' ;
    rdfs:comment 'Internal OEM code identifying the vehicle program or platform to which this BOM component applies (e.g., \'F150-GEN14\', \'EV-PLATFORM-X\'). Supports multi-platform BOM management and cross-program parts commonality analysis.' ;
    rdfs:domain ind:ManufacturingBomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildSequenceId rdf:type rdf:Property ;
    rdfs:label 'Build Sequence Id' ;
    rdfs:comment 'Unique surrogate identifier for the Just-in-Sequence (JIS) build sequence record in the Databricks Silver Layer. Primary key generated by the Apriso/Dassault MES sequencing module upon sequence creation.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:configurationId rdf:type rdf:Property ;
    rdfs:label 'Configuration Id' ;
    rdfs:comment 'Reference to the vehicle configuration record defining the model, trim, powertrain, and option codes for the vehicle to be assembled at this sequence position.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Configuration .

ind:vehicleConfigConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Config Configuration Id' ;
    rdfs:comment 'Reference to the vehicle configuration record defining the model, trim, powertrain, and option codes for the vehicle to be assembled at this sequence position.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Configuration .

ind:bodyStyleCode rdf:type rdf:Property ;
    rdfs:label 'Body Style Code' ;
    rdfs:comment 'Code identifying the body style of the vehicle (e.g., sedan, SUV, truck, coupe, van). Influences stamping and body shop routing within the production sequence.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildType rdf:type rdf:Property ;
    rdfs:label 'Build Type' ;
    rdfs:comment 'Classification of the vehicle build purpose: \'retail\' = customer-ordered retail unit; \'fleet\' = fleet customer order; \'stock\' = dealer stock build; \'pilot\' = pre-production pilot build; \'homologation\' = regulatory homologation unit; \'press\' = media/press fleet unit.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Order Number' ;
    rdfs:comment 'Sales order number from SAP SD or Salesforce Automotive Cloud associated with this build sequence position, if the vehicle is built to a specific customer or dealer order. Null for stock builds.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationMarketCode rdf:type rdf:Property ;
    rdfs:label 'Destination Market Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code indicating the intended destination market for the vehicle. Determines homologation variant, regulatory compliance requirements (NHTSA, UNECE, CARB), and market-specific option content.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driveConfiguration rdf:type rdf:Property ;
    rdfs:label 'Drive Configuration' ;
    rdfs:comment 'Drivetrain configuration of the vehicle: FWD (Front-Wheel Drive), RWD (Rear-Wheel Drive), AWD (All-Wheel Drive), or 4WD (Four-Wheel Drive). Determines axle and driveshaft JIS call-off and assembly routing.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freezeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Freeze Timestamp' ;
    rdfs:comment 'Date and time at which the build sequence was frozen and locked for JIS supplier call-off. After this timestamp, sequence changes are restricted and require formal change control. Critical for JIS supplier synchronization.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isFrozen rdf:type rdf:Property ;
    rdfs:label 'Is Frozen' ;
    rdfs:comment 'Indicates whether the build sequence record has been frozen for JIS supplier call-off. When True, sequence changes are restricted and require formal change control approval. Directly linked to freeze_timestamp.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPriorityBuild rdf:type rdf:Property ;
    rdfs:label 'Is Priority Build' ;
    rdfs:comment 'Indicates whether this vehicle has been flagged as a priority build (e.g., executive order, critical dealer allocation, regulatory compliance unit). Priority builds may override standard JIS sequencing rules.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jisCallOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Jis Call Off Timestamp' ;
    rdfs:comment 'Date and time at which the JIS supplier call-off message was transmitted for this sequence position. Triggers sequenced part delivery from tier-1 JIS suppliers. Critical for supply chain synchronization and OTD measurement.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mesSequenceReference rdf:type rdf:Property ;
    rdfs:label 'Mes Sequence Reference' ;
    rdfs:comment 'Native sequence record identifier from the Apriso/Dassault MES sequencing module. Serves as the source system key for lineage and reconciliation between the Silver Layer and the operational MES.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionPackageCode rdf:type rdf:Property ;
    rdfs:label 'Option Package Code' ;
    rdfs:comment 'Code representing the bundled option package (e.g., technology package, towing package, safety package) selected for the vehicle. Determines additional BOM components and JIS call-off requirements.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedBuildDate rdf:type rdf:Property ;
    rdfs:label 'Planned Build Date' ;
    rdfs:comment 'Calendar date on which the vehicle at this sequence position is planned to be assembled. Used for JIS supplier call-off scheduling and production planning in SAP PP.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Flag' ;
    rdfs:comment 'Indicates whether this build sequence position has been placed on a quality hold, preventing progression to the next assembly stage. Triggered by MES quality gate failures or FMEA-driven stop conditions.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryVariantCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Variant Code' ;
    rdfs:comment 'Code identifying the regulatory homologation variant of the vehicle (e.g., US-NHTSA, EU-UNECE, CARB-ZEV). Ensures correct BOM variant selection for emissions, safety, and market-specific compliance requirements.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceChangeReason rdf:type rdf:Property ;
    rdfs:label 'Sequence Change Reason' ;
    rdfs:comment 'Free-text or coded reason for the most recent modification to this build sequence record (e.g., material shortage, quality hold, customer order change, line disruption). Required for change control audit trail under IATF 16949.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordered position number of this vehicle within the production run for the assigned line and shift. Drives JIS supplier call-off sequencing and AGV routing. Must be unique within a plant, line, shift, and planned build date combination.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sequenceRevisionNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Revision Number' ;
    rdfs:comment 'Incremental revision counter tracking how many times this build sequence record has been modified since initial creation. Supports audit trail and change control compliance under IATF 16949.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sequenceSetNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Set Number' ;
    rdfs:comment 'Externally-known identifier for the production sequence set or run to which this record belongs, as generated by the MES sequencing module. Used for JIS call-off batch identification and supplier communication.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceStatus rdf:type rdf:Property ;
    rdfs:label 'Sequence Status' ;
    rdfs:comment 'Current lifecycle state of the build sequence record within the MES workflow. \'planned\' = sequence created but not yet released to shop floor; \'released\' = released for production; \'in_progress\' = vehicle currently being assembled; \'completed\' = assembly finished; \'cancelled\' = sequence removed from run; \'on_hold\' = temporarily suspended pending resolution.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceType rdf:type rdf:Property ;
    rdfs:label 'Sequence Type' ;
    rdfs:comment 'Classification of the build sequence record indicating whether it is the original planned sequence, a revised sequence after change control, an emergency insertion, or a resequenced position due to line disruption.' ;
    rdfs:domain ind:BuildSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taktTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Takt Time Seconds' ;
    rdfs:comment 'Planned takt time in seconds allocated for assembly of the vehicle at this sequence position. Derived from the line rate and used for production pacing, WIP tracking, and OTD performance measurement.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trimLevelCode rdf:type rdf:Property ;
    rdfs:label 'Trim Level Code' ;
    rdfs:comment 'Code identifying the trim or grade level of the vehicle (e.g., base, mid, premium, sport). Determines option content, BOM variant, and JIS part call-off requirements.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildStageId rdf:type rdf:Property ;
    rdfs:label 'Build Stage Id' ;
    rdfs:comment 'Unique surrogate identifier for each build stage record in the vehicle manufacturing process. Primary key for the build_stage reference master. [REFERENCE_LOOKUP role — canonical_skip_reason: This entity is a reference master defining standard build stages; per-role minimums for REFERENCE_LOOKUP are exempt, but all meaningful business attributes are still included for completeness.]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BuildStage .

ind:supervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: REQUIRED: Each build stage is overseen by a supervisor employee; needed for accountability and shift handover reports.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agvEnabled rdf:type rdf:Property ;
    rdfs:label 'Agv Enabled' ;
    rdfs:comment 'Indicates whether AGV (Automated Guided Vehicle) systems are deployed at this build stage for material transport, vehicle body movement, or component sequencing. Drives AGV routing configuration and integration with SCADA and MES systems.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableVehicleTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Vehicle Types' ;
    rdfs:comment 'Comma-separated list of vehicle body types or powertrain categories for which this build stage applies (e.g., Sedan, SUV, Truck, EV, HEV, PHEV, ICE, Commercial). Enables stage filtering in mixed-model assembly lines and supports model-specific production routing. [ENUM-REF-CANDIDATE: Sedan|SUV|Truck|EV|HEV|PHEV|ICE|Commercial|CKD|SKD — promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Classification of the degree of automation at this build stage: manual (operator-driven), semi-automated (operator-assisted machinery), fully-automated (machine-driven with minimal operator oversight), or robotic (AGV/robot-cell driven). Informs CapEx planning, maintenance scheduling, and OEE benchmarking.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bufferCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Buffer Capacity Units' ;
    rdfs:comment 'Maximum number of vehicle units that can be held in the buffer/queue between this build stage and the next stage. Defines the WIP (Work in Progress) inventory limit for line balancing and is used in production simulation and bottleneck analysis.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:co2EmissionKg rdf:type rdf:Property ;
    rdfs:label 'Co2 Emission Kg' ;
    rdfs:comment 'Standard CO2-equivalent emissions in kilograms per vehicle unit processed at this build stage. Supports EPA and CARB (California Air Resources Board) environmental compliance reporting, sustainability KPIs, and manufacturing carbon footprint tracking.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlPlanCode rdf:type rdf:Property ;
    rdfs:label 'Control Plan Code' ;
    rdfs:comment 'Reference code of the APQP (Advanced Product Quality Planning) control plan document governing quality control activities at this build stage. Specifies product/process characteristics, control methods, and reaction plans for out-of-control conditions per IATF 16949.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Fmea Reference Code' ;
    rdfs:comment 'Reference identifier linking this build stage to its corresponding FMEA (Failure Mode and Effects Analysis) document. Ensures traceability between the process stage definition and its risk assessment per IATF 16949 and APQP (Advanced Product Quality Planning) requirements.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatClassification rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classification' ;
    rdfs:comment 'Classification of hazardous materials present or used at this build stage per DOT and EPA regulations (e.g., paint solvents, E-Coat chemicals, welding fumes). Drives EHS (Environmental Health and Safety) compliance, PPE requirements, and ISO 14001 environmental management reporting.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iatfProcessCategory rdf:type rdf:Property ;
    rdfs:label 'Iatf Process Category' ;
    rdfs:comment 'IATF 16949 process category designation for this build stage: special-characteristic (processes producing special product/process characteristics requiring enhanced control), standard-process, critical-process (safety-critical per FMVSS), or monitoring-only (observation without active control). Drives audit scope and PPAP (Production Part Approval Process) requirements.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isQualityGate rdf:type rdf:Property ;
    rdfs:label 'Is Quality Gate' ;
    rdfs:comment 'Indicates whether this build stage is designated as a quality gate checkpoint where vehicles must pass defined quality criteria before advancing to the next stage. Quality gates are mandatory hold points per IATF 16949 and APQP (Advanced Product Quality Planning) requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReworkEligible rdf:type rdf:Property ;
    rdfs:label 'Is Rework Eligible' ;
    rdfs:comment 'Indicates whether vehicles failing quality checks at this build stage are eligible for rework and re-entry into the production flow, as opposed to being routed to scrap or offline repair. Drives rework routing logic in MES and quality management workflows.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborHeadcountStandard rdf:type rdf:Property ;
    rdfs:label 'Labor Headcount Standard' ;
    rdfs:comment 'The standard number of direct labor operators assigned to this build stage per shift under normal production conditions. Used for workforce planning, capacity balancing, and labor cost standard costing in SAP S/4HANA CO.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Max Temperature C' ;
    rdfs:comment 'Maximum allowable ambient or process temperature in degrees Celsius for this build stage. Exceeding this threshold triggers a quality hold and SCADA alarm. Particularly relevant for paint curing ovens, E-Coat baths, and weld quality control.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesStageCode rdf:type rdf:Property ;
    rdfs:label 'Mes Stage Code' ;
    rdfs:comment 'The native stage identifier as defined in the Apriso/Dassault MES system. Used for cross-system reconciliation between the lakehouse silver layer and the operational MES, ensuring traceability of production events back to the source system of record.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Min Temperature C' ;
    rdfs:comment 'Minimum allowable ambient or process temperature in degrees Celsius for this build stage to operate within specification. Critical for paint shop, E-Coat, and adhesive curing stages where temperature directly affects product quality. Used in SPC (Statistical Process Control) monitoring.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantAreaCode rdf:type rdf:Property ;
    rdfs:label 'Plant Area Code' ;
    rdfs:comment 'Alphanumeric code identifying the specific plant area or shop within the manufacturing facility where this build stage is physically located (e.g., SH01 for Stamping Hall 1, BS02 for Body Shop 2). Aligns with SAP S/4HANA work center and plant layout master data.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plcProgramCode rdf:type rdf:Property ;
    rdfs:label 'Plc Program Code' ;
    rdfs:comment 'Identifier of the PLC (Programmable Logic Controller) program controlling the automated equipment at this build stage. Used for change management, version control of control programs, and traceability of equipment configuration changes per IATF 16949 requirements.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppmTarget rdf:type rdf:Property ;
    rdfs:label 'Ppm Target' ;
    rdfs:comment 'Target defect rate for this build stage expressed in PPM (Parts Per Million). Defines the quality performance benchmark used in IATF 16949 supplier and process quality reporting, SPC control limit setting, and continuous improvement initiatives.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precedingStageCode rdf:type rdf:Property ;
    rdfs:label 'Preceding Stage Code' ;
    rdfs:comment 'Stage code of the immediately preceding build stage in the standard production sequence. Defines the upstream dependency for production flow control, WIP (Work in Progress) tracking, and JIS (Just-in-Sequence) scheduling. Null for the first stage in the sequence.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processArea rdf:type rdf:Property ;
    rdfs:label 'Process Area' ;
    rdfs:comment 'The physical or functional manufacturing area where this build stage is executed (e.g., Stamping Plant, Body Shop, Paint Shop, General Assembly, Chassis Line, PDI Bay). Maps to plant layout zones and is used for capacity planning and SCADA (Supervisory Control and Data Acquisition) integration. [ENUM-REF-CANDIDATE: Stamping|Body Shop|Paint Shop|E-Coat|General Assembly|Chassis Line|Trim Line|PDI Bay|Quality Gate|Logistics — promote to reference product]' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionPlanCode rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Plan Code' ;
    rdfs:comment 'Reference code of the SAP QM (Quality Management) inspection plan associated with this build stage. Defines the inspection characteristics, sampling procedures, and acceptance criteria applied during quality gate checks. Linked to FMEA (Failure Mode and Effects Analysis) and APQP documentation.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyClassification rdf:type rdf:Property ;
    rdfs:label 'Safety Classification' ;
    rdfs:comment 'Safety risk classification of this build stage per DOT and OSHA standards: standard (routine operations), elevated-risk (requires additional PPE or safety protocols), critical-safety (safety-critical operations with mandatory sign-off), or restricted-access (limited to certified personnel only).' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapOperationCode rdf:type rdf:Property ;
    rdfs:label 'Sap Operation Code' ;
    rdfs:comment 'The SAP S/4HANA PP routing operation code corresponding to this build stage. Enables direct linkage between the build stage reference master and SAP production order routing operations for cost allocation, scheduling, and confirmation.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Sequence Order' ;
    rdfs:comment 'Integer defining the sequential position of this build stage within the overall vehicle assembly process flow. Used to enforce JIS (Just-in-Sequence) ordering, production line scheduling, and WIP (Work in Progress) traceability. Lower values indicate earlier stages.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spcEnabled rdf:type rdf:Property ;
    rdfs:label 'Spc Enabled' ;
    rdfs:comment 'Indicates whether SPC (Statistical Process Control) monitoring is active for this build stage. When true, process parameters are continuously monitored against control limits and deviations trigger automated alerts in the MES and SAP QM systems per IATF 16949 requirements.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stageCode rdf:type rdf:Property ;
    rdfs:label 'Stage Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the build stage within the manufacturing process (e.g., STAMP, BODY, ECOAT, PAINT, TRIM1, CHAS, TRIM2, FINAL, PDI). Used as the business key in MES (Manufacturing Execution System) integrations and production reporting.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageDescription rdf:type rdf:Property ;
    rdfs:label 'Stage Description' ;
    rdfs:comment 'Detailed narrative description of the manufacturing activities, operations, and objectives performed at this build stage. Provides context for production engineers, quality auditors, and training documentation. Sourced from PLM and MES configuration documentation.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageName rdf:type rdf:Property ;
    rdfs:label 'Stage Name' ;
    rdfs:comment 'Full descriptive name of the build stage as used in production planning and reporting (e.g., Stamping, Body Shop, E-Coat, Paint, Trim-1, Chassis, Trim-2, Final Assembly, PDI — Pre-Delivery Inspection). Displayed in MES dashboards and production schedules.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageStatus rdf:type rdf:Property ;
    rdfs:label 'Stage Status' ;
    rdfs:comment 'Current lifecycle status of the build stage definition: active (in production use), inactive (temporarily not in use), pilot (under validation/trial), suspended (halted due to quality or safety issue), or decommissioned (permanently retired from the process). Controls whether the stage is available for new production orders.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageType rdf:type rdf:Property ;
    rdfs:label 'Stage Type' ;
    rdfs:comment 'Categorical classification of the build stage by its primary manufacturing function: assembly (joining components), fabrication (forming/stamping metal), coating (E-Coat/paint application), inspection (quality gate checks), testing (functional/NVH testing), or logistics (material staging/sequencing).' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCycleTimeSec rdf:type rdf:Property ;
    rdfs:label 'Standard Cycle Time Sec' ;
    rdfs:comment 'The engineered standard cycle time for this build stage measured in seconds. Represents the designed takt-aligned duration for one vehicle unit to complete the stage under normal operating conditions. Used for production scheduling, OEE (Overall Equipment Effectiveness) calculation, and bottleneck analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:succeedingStageCode rdf:type rdf:Property ;
    rdfs:label 'Succeeding Stage Code' ;
    rdfs:comment 'Stage code of the immediately succeeding build stage in the standard production sequence. Defines the downstream handoff point for production flow control and vehicle build traceability. Null for the final stage (PDI) in the sequence.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taktTimeSec rdf:type rdf:Property ;
    rdfs:label 'Takt Time Sec' ;
    rdfs:comment 'The customer-demand-driven takt time for this build stage in seconds, calculated as available production time divided by required production volume. Defines the rhythm of production and is used to balance line capacity and identify over/under-capacity stages.' ;
    rdfs:domain ind:BuildStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityPlanId rdf:type rdf:Property ;
    rdfs:label 'Capacity Plan Id' ;
    rdfs:comment 'Unique surrogate identifier for each capacity plan record in the manufacturing domain. Primary key for the capacity_plan data product.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bottleneckWorkCenterId rdf:type rdf:Property ;
    rdfs:label 'Bottleneck Work Center Id' ;
    rdfs:comment 'Reference to the work center identified as the capacity bottleneck constraining overall line throughput during this planning period. Used to prioritize capacity improvement investments and focus S&OP constraint management.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:planOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Plan Owner Employee Id' ;
    rdfs:comment 'Reference to the manufacturing or industrial engineering employee responsible for maintaining and updating this capacity plan. Supports accountability tracking in S&OP governance.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:availableHours rdf:type rdf:Property ;
    rdfs:label 'Available Hours' ;
    rdfs:comment 'Total scheduled production hours available in the planning period after accounting for planned downtime, shift breaks, and scheduled maintenance. Used in conjunction with rated_capacity_jph to compute rated capacity in units.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bottleneckConstraintDescription rdf:type rdf:Property ;
    rdfs:label 'Bottleneck Constraint Description' ;
    rdfs:comment 'Narrative description of the primary capacity constraint at the bottleneck work center (e.g., \'Paint oven cycle time limits throughput to 58 JPH\', \'Robotic welding cell maintenance window reduces available hours\'). Supports root cause analysis and CapEx justification.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityGapUnits rdf:type rdf:Property ;
    rdfs:label 'Capacity Gap Units' ;
    rdfs:comment 'Difference between planned_production_units and demonstrated_capacity_units, representing the capacity shortfall or surplus for the planning period. Positive value indicates a capacity gap requiring corrective action (overtime, additional shifts, CapEx); negative value indicates surplus capacity.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityPlanType rdf:type rdf:Property ;
    rdfs:label 'Capacity Plan Type' ;
    rdfs:comment 'Classification of the capacity planning methodology used. \'rough_cut\' (RCCP — Rough Cut Capacity Planning) for high-level S&OP; \'detailed\' for work-center-level CRP (Capacity Requirements Planning); \'constraint_based\' for Theory of Constraints analysis; \'what_if\' for scenario planning and CapEx evaluation.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Percent' ;
    rdfs:comment 'Planned capacity utilization rate expressed as a percentage, calculated as (planned_production_units / rated_capacity_units) × 100. Drives S&OP decisions on overtime, additional shifts, and capital investment. Target thresholds are typically 85–95% for automotive assembly.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexAmount rdf:type rdf:Property ;
    rdfs:label 'Capex Amount' ;
    rdfs:comment 'Estimated capital expenditure amount required to address the capacity gap identified in this plan. Expressed in the plant\'s operating currency. Used for CapEx budget submissions and investment approval processes.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexRequired rdf:type rdf:Property ;
    rdfs:label 'Capex Required' ;
    rdfs:comment 'Indicates whether this capacity plan identifies a requirement for capital investment (CapEx) to close a capacity gap (e.g., new tooling, additional robots, facility expansion). Triggers CapEx approval workflow in SAP FI/CO.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeoverHours rdf:type rdf:Property ;
    rdfs:label 'Changeover Hours' ;
    rdfs:comment 'Hours allocated for model changeovers, tooling changes, and line reconfigurations during the planning period. Relevant for mixed-model assembly lines producing multiple vehicle variants (e.g., ICE and BEV on the same line).' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyProductionTarget rdf:type rdf:Property ;
    rdfs:label 'Daily Production Target' ;
    rdfs:comment 'Planned number of vehicles to be produced per working day during the planning period, derived from planned_production_units / working_days. Used for daily MES scheduling and shift-level production targets.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demonstratedCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Demonstrated Capacity Units' ;
    rdfs:comment 'Actual production output achieved in a comparable prior period, used as the realistic baseline for capacity planning. Reflects real-world constraints such as quality losses, minor stoppages, and changeovers. Key input to APQP (Advanced Product Quality Planning) capacity studies.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountRequired rdf:type rdf:Property ;
    rdfs:label 'Headcount Required' ;
    rdfs:comment 'Total direct labor headcount required to execute the planned production volume during the planning period. Used for workforce planning, hiring decisions, and labor cost budgeting in SuccessFactors and SAP CO.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBottleneckConstrained rdf:type rdf:Property ;
    rdfs:label 'Is Bottleneck Constrained' ;
    rdfs:comment 'Indicates whether the capacity plan is constrained by a bottleneck work center that limits overall line throughput below the planned production target. When True, the bottleneck_work_center_id and bottleneck_constraint_description fields are populated.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfShifts rdf:type rdf:Property ;
    rdfs:label 'Number Of Shifts' ;
    rdfs:comment 'Number of production shifts planned per working day for this capacity plan (e.g., 1, 2, or 3 shifts). Directly determines available production hours and total capacity for the planning period.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'Last calendar date of the planning period covered by this capacity plan record. Together with plan_start_date, defines the planning window for capacity supply and demand balancing.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'First calendar date of the planning period covered by this capacity plan record. Used to align capacity supply with demand signals from S&OP and MRP (Material Requirements Planning) runs.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle state of the capacity plan record. \'draft\' indicates work-in-progress; \'submitted\' indicates pending approval; \'approved\' indicates sign-off by S&OP leadership; \'active\' indicates the operative plan driving production scheduling; \'superseded\' indicates replaced by a newer version; \'archived\' indicates historical record.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version identifier of the capacity plan, enabling management of multiple planning iterations (e.g., v1.0, v2.0) within the same planning period. Supports S&OP cycle versioning and plan-over-plan variance analysis.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Planned Downtime Hours' ;
    rdfs:comment 'Total planned downtime hours for the production line during the planning period, including scheduled maintenance, tooling changeovers, model changeovers, and planned shutdowns. Reduces available production hours from the theoretical maximum.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMaintenanceHours rdf:type rdf:Property ;
    rdfs:label 'Planned Maintenance Hours' ;
    rdfs:comment 'Subset of planned downtime hours specifically allocated to preventive and predictive maintenance activities on production equipment. Tracked separately from changeover downtime for maintenance KPI reporting and SAP PM integration.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedOvertimeHours rdf:type rdf:Property ;
    rdfs:label 'Planned Overtime Hours' ;
    rdfs:comment 'Total overtime hours planned for the production line during the planning period to meet production targets beyond standard shift capacity. Feeds into workforce cost planning and labor budget in SAP CO.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedProductionUnits rdf:type rdf:Property ;
    rdfs:label 'Planned Production Units' ;
    rdfs:comment 'Number of vehicles planned for production in the planning period as agreed in the S&OP process. Represents the demand signal that capacity must satisfy. Compared against rated and demonstrated capacity to identify gaps.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningPeriodType rdf:type rdf:Property ;
    rdfs:label 'Planning Period Type' ;
    rdfs:comment 'Granularity of the capacity planning horizon for this record. \'weekly\' supports short-term MES scheduling; \'monthly\' supports S&OP cycles; \'quarterly\' and \'annual\' support CapEx and strategic workforce planning.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratedCapacityJph rdf:type rdf:Property ;
    rdfs:label 'Rated Capacity Jph' ;
    rdfs:comment 'Theoretical maximum production rate expressed in Jobs Per Hour (JPH) for the production line under ideal conditions. Derived from takt time and line design specifications. Used as the baseline for capacity utilization calculations in S&OP.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratedCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Rated Capacity Units' ;
    rdfs:comment 'Theoretical maximum number of vehicles that can be produced in the planning period, calculated as rated_capacity_jph × available_hours. Represents the upper bound of production capacity for S&OP and CapEx planning.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sapCapacityPlanCode rdf:type rdf:Property ;
    rdfs:label 'Sap Capacity Plan Code' ;
    rdfs:comment 'Source system identifier for this capacity plan record in SAP S/4HANA PP (Production Planning) module, used for data lineage traceability and reconciliation between the lakehouse Silver layer and the operational ERP system.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workingDays rdf:type rdf:Property ;
    rdfs:label 'Working Days' ;
    rdfs:comment 'Number of scheduled working days in the planning period after excluding weekends, public holidays, and planned plant shutdowns. Used to compute daily production targets and available hours.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeoverId rdf:type rdf:Property ;
    rdfs:label 'Changeover Id' ;
    rdfs:comment 'Unique surrogate identifier for each production line changeover event record in the manufacturing execution system.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Minutes' ;
    rdfs:comment 'Actual elapsed time in minutes from changeover start to completion. Core metric for SMED (Single-Minute Exchange of Die) analysis and OEE (Overall Equipment Effectiveness) calculations.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agvInterventionRequired rdf:type rdf:Property ;
    rdfs:label 'Agv Intervention Required' ;
    rdfs:comment 'Indicates whether AGV (Automated Guided Vehicle) systems were required to transport tooling, fixtures, or materials as part of the changeover process. Supports AGV utilization and changeover logistics analysis.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeoverNumber rdf:type rdf:Property ;
    rdfs:label 'Changeover Number' ;
    rdfs:comment 'Externally-known business identifier for the changeover event, used in MES (Manufacturing Execution System) and shop floor documentation. Format: CO-{PLANT}-{YYYYMMDD}-{SEQ}.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeoverStatus rdf:type rdf:Property ;
    rdfs:label 'Changeover Status' ;
    rdfs:comment 'Current lifecycle state of the changeover event as tracked in the MES (Manufacturing Execution System). Drives shop floor workflow and reporting.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeoverType rdf:type rdf:Property ;
    rdfs:label 'Changeover Type' ;
    rdfs:comment 'Classification of the changeover event indicating the nature of the switch on the production line. [ENUM-REF-CANDIDATE: model_mix_change|color_change|tooling_swap|line_retooling|powertrain_variant|body_style_change — promote to reference product]' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayReasonCode rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Code' ;
    rdfs:comment 'Standardized code capturing the primary reason for any variance between planned and actual changeover duration. Used for root cause analysis in SMED (Single-Minute Exchange of Die) and continuous improvement programs.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalElementsDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'External Elements Duration Minutes' ;
    rdfs:comment 'Total time in minutes spent on external changeover activities that can be performed while the production line is still running (e.g., pre-staging tooling). Core SMED (Single-Minute Exchange of Die) metric for optimization.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstGoodUnitTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Good Unit Timestamp' ;
    rdfs:comment 'Timestamp when the first conforming vehicle unit passed quality inspection after the changeover was completed. Marks the effective end of production loss and resumption of normal throughput.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fromBodyStyleCode rdf:type rdf:Property ;
    rdfs:label 'From Body Style Code' ;
    rdfs:comment 'Body style classification of the vehicle being produced before the changeover (e.g., sedan, SUV, truck). Used to categorize body style changeover events.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fromExteriorColorCode rdf:type rdf:Property ;
    rdfs:label 'From Exterior Color Code' ;
    rdfs:comment 'Paint color code of the vehicle being produced before the changeover. Relevant for color change changeover events in the paint shop.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fromPowertrainType rdf:type rdf:Property ;
    rdfs:label 'From Powertrain Type' ;
    rdfs:comment 'Powertrain variant being produced before the changeover. ICE (Internal Combustion Engine), HEV (Hybrid Electric Vehicle), PHEV (Plug-in Hybrid Electric Vehicle), BEV (Battery Electric Vehicle), FCEV (Fuel Cell Electric Vehicle).' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fromVehicleModelCode rdf:type rdf:Property ;
    rdfs:label 'From Vehicle Model Code' ;
    rdfs:comment 'Vehicle model code of the product being produced on the line immediately before the changeover. Identifies the outgoing model in a model mix change scenario.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalElementsDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Internal Elements Duration Minutes' ;
    rdfs:comment 'Total time in minutes spent on internal changeover activities that require the production line to be stopped (e.g., die removal, fixture swap). Core SMED (Single-Minute Exchange of Die) metric for identifying conversion opportunities.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isPlanned rdf:type rdf:Property ;
    rdfs:label 'Is Planned' ;
    rdfs:comment 'Indicates whether the changeover was a scheduled/planned event (True) or an unplanned/emergency changeover triggered by a quality issue, equipment failure, or urgent customer order change (False).' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSmedTarget rdf:type rdf:Property ;
    rdfs:label 'Is Smed Target' ;
    rdfs:comment 'Flags whether this changeover event is designated as a target for SMED (Single-Minute Exchange of Die) improvement analysis. Enables filtering of changeover records for lean manufacturing improvement programs.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineVerificationDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Line Verification Duration Minutes' ;
    rdfs:comment 'Time in minutes spent on post-changeover line verification, first-off inspection, and quality gate checks before resuming full production. Supports APQP (Advanced Product Quality Planning) and PPAP (Production Part Approval Process) compliance.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mesChangeoverReference rdf:type rdf:Property ;
    rdfs:label 'Mes Changeover Reference' ;
    rdfs:comment 'Native changeover event identifier from the Apriso/Dassault MES (Manufacturing Execution System). Enables traceability and reconciliation between the lakehouse silver layer and the operational MES source system.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Minutes' ;
    rdfs:comment 'Planned duration of the changeover in minutes as defined in the production schedule. Baseline for SMED (Single-Minute Exchange of Die) improvement tracking.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionLossUnits rdf:type rdf:Property ;
    rdfs:label 'Production Loss Units' ;
    rdfs:comment 'Number of vehicle units not produced due to the changeover downtime. Calculated as the difference between potential production capacity and actual output during the changeover window. Key metric for OEE (Overall Equipment Effectiveness) and capacity planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityGatePassed rdf:type rdf:Property ;
    rdfs:label 'Quality Gate Passed' ;
    rdfs:comment 'Indicates whether the post-changeover quality gate inspection was passed (True) before resuming full production. A False value indicates the line was held pending rework or re-inspection per IATF 16949 quality control requirements.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapOrderReference rdf:type rdf:Property ;
    rdfs:label 'Sap Order Reference' ;
    rdfs:comment 'Reference to the SAP S/4HANA production order number associated with the post-changeover production run. Enables cost allocation and production confirmation reconciliation in SAP PP (Production Planning).' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapUnitsDuringChangeover rdf:type rdf:Property ;
    rdfs:label 'Scrap Units During Changeover' ;
    rdfs:comment 'Number of vehicle units scrapped or rejected during the changeover transition period before the first good unit was produced. Contributes to quality loss calculation in OEE (Overall Equipment Effectiveness).' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toBodyStyleCode rdf:type rdf:Property ;
    rdfs:label 'To Body Style Code' ;
    rdfs:comment 'Body style classification of the vehicle to be produced after the changeover (e.g., sedan, SUV, truck). Used to categorize body style changeover events.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toExteriorColorCode rdf:type rdf:Property ;
    rdfs:label 'To Exterior Color Code' ;
    rdfs:comment 'Paint color code of the vehicle to be produced after the changeover. Relevant for color change changeover events in the paint shop.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toPowertrainType rdf:type rdf:Property ;
    rdfs:label 'To Powertrain Type' ;
    rdfs:comment 'Powertrain variant to be produced after the changeover. ICE (Internal Combustion Engine), HEV (Hybrid Electric Vehicle), PHEV (Plug-in Hybrid Electric Vehicle), BEV (Battery Electric Vehicle), FCEV (Fuel Cell Electric Vehicle).' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toVehicleModelCode rdf:type rdf:Property ;
    rdfs:label 'To Vehicle Model Code' ;
    rdfs:comment 'Vehicle model code of the product to be produced on the line immediately after the changeover. Identifies the incoming model in a model mix change scenario.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolingChangeRequired rdf:type rdf:Property ;
    rdfs:label 'Tooling Change Required' ;
    rdfs:comment 'Indicates whether the changeover required a physical tooling swap or die change (True) or was a parameter/program-only changeover (False). Drives tooling logistics planning and SMED (Single-Minute Exchange of Die) categorization.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toolingSetupDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Tooling Setup Duration Minutes' ;
    rdfs:comment 'Time in minutes required specifically for tooling installation, adjustment, and verification during the changeover. Subset of internal changeover elements used for tooling-specific SMED analysis.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Variance Minutes' ;
    rdfs:comment 'Difference in minutes between actual and planned changeover duration (actual_duration_minutes minus planned_duration_minutes). Positive value indicates overrun; negative indicates early completion. Key SMED (Single-Minute Exchange of Die) performance indicator.' ;
    rdfs:domain ind:Changeover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downtimeEventId rdf:type rdf:Property ;
    rdfs:label 'Downtime Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each downtime event record in the manufacturing execution system. Primary key for the downtime_event data product.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedProcessArea rdf:type rdf:Property ;
    rdfs:label 'Affected Process Area' ;
    rdfs:comment 'The manufacturing process area impacted by the downtime event. Reflects the major shop segments in automotive assembly: stamping (press shop), body shop (BIW - Body in White), paint shop, final assembly, powertrain assembly, chassis, trim, or general assembly. Used for plant-level downtime distribution analysis. [ENUM-REF-CANDIDATE: stamping|body_shop|paint|final_assembly|powertrain|chassis|trim|general_assembly — promote to reference product]' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCode rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Code' ;
    rdfs:comment 'Standardized code from the SAP PM activity type catalog describing the corrective action taken to resolve the downtime event (e.g., part replacement, lubrication, calibration, software reset, tooling adjustment). Supports FMEA corrective action tracking and spare parts consumption analysis.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeType rdf:type rdf:Property ;
    rdfs:label 'Downtime Type' ;
    rdfs:comment 'Indicates whether the downtime event was planned (scheduled maintenance, changeover, tooling change per production schedule) or unplanned (unexpected breakdown, quality hold, material shortage). Critical for separating planned vs. unplanned OEE availability losses.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'The calendar date on which the downtime event started. Derived from start_timestamp for day-level partitioning, reporting, and trend analysis. Stored as a separate DATE field to support efficient date-range queries and daily OEE dashboard aggregations. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Free-text narrative description of the downtime event as entered by the operator, technician, or supervisor in the MES or SAP PM notification. Captures contextual details not covered by structured codes, such as observed symptoms, environmental conditions, or operator observations at the time of failure.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the downtime event, typically generated by the MES (Manufacturing Execution System) or SAP PM (Plant Maintenance) module. Format: DT-{YYYY}-{NNNNNN}. Used for cross-system referencing and shop floor communication.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle status of the downtime event record. \'open\' indicates the event is active and unresolved; \'in_progress\' indicates a repair or corrective action is underway; \'resolved\' indicates the root cause has been addressed; \'closed\' indicates the event is fully documented and closed; \'cancelled\' indicates the event was logged in error.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureModeCode rdf:type rdf:Property ;
    rdfs:label 'Failure Mode Code' ;
    rdfs:comment 'Standardized code identifying the specific failure mode that caused the downtime event, aligned with the FMEA (Failure Mode and Effects Analysis) failure mode library. Examples: electrical fault, hydraulic leak, sensor failure, conveyor jam. Enables FMEA-driven root cause trending and PPAP (Production Part Approval Process) corrective action tracking.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultLocationCode rdf:type rdf:Property ;
    rdfs:label 'Fault Location Code' ;
    rdfs:comment 'SAP PM object part / location code identifying the specific component or sub-assembly on the equipment where the fault occurred (e.g., spindle, conveyor belt, welding gun tip, paint nozzle). Enables component-level failure frequency analysis and spare parts demand forecasting.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isQualityHoldTriggered rdf:type rdf:Property ;
    rdfs:label 'Is Quality Hold Triggered' ;
    rdfs:comment 'Indicates whether the downtime event triggered a quality hold on WIP (Work in Progress) or finished vehicle inventory. True = quality hold was activated; False = no quality hold. Links to SAP QM quality notification and SPC (Statistical Process Control) out-of-control action plans.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeatFailure rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Failure' ;
    rdfs:comment 'Indicates whether this downtime event is a recurrence of a previously recorded failure on the same equipment or work center within a defined lookback period (typically 30 days). True = repeat failure; False = first occurrence. Used to identify chronic equipment issues requiring escalated corrective action under IATF 16949 Section 10.2.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyRelated rdf:type rdf:Property ;
    rdfs:label 'Is Safety Related' ;
    rdfs:comment 'Indicates whether the downtime event involved a safety incident, near-miss, or safety-critical equipment failure (e.g., AGV collision, robot safety stop, lockout/tagout activation). True = safety-related; False = non-safety. Triggers mandatory safety reporting and OSHA/DOT compliance escalation workflows.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceCostLocal rdf:type rdf:Property ;
    rdfs:label 'Maintenance Cost Local' ;
    rdfs:comment 'Total direct maintenance cost incurred to resolve the downtime event, including labor, spare parts, and external service costs, expressed in the plant\'s local currency. Sourced from SAP PM actual cost settlement. Used for cost-of-downtime analysis and CapEx vs. OpEx maintenance budget reporting.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeAvailabilityLossPct rdf:type rdf:Property ;
    rdfs:label 'Oee Availability Loss Pct' ;
    rdfs:comment 'The percentage of scheduled production time lost due to this downtime event, calculated as (duration_minutes / scheduled_production_time_minutes) × 100. Represents the availability loss component of the OEE (Overall Equipment Effectiveness) metric for the affected work center during the event period. Stored as a business field for direct use in OEE dashboards.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scadaAlarmCode rdf:type rdf:Property ;
    rdfs:label 'Scada Alarm Code' ;
    rdfs:comment 'The alarm or fault code generated by the SCADA (Supervisory Control and Data Acquisition) or PLC (Programmable Logic Controller) system at the time the downtime event was triggered. Provides the raw machine-level signal that initiated the downtime record. Used for SCADA-integrated downtime reporting and automated event correlation.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'The production shift during which the downtime event occurred (e.g., shift_1 = day shift, shift_2 = afternoon shift, shift_3 = night shift, weekend = weekend shift). Used for shift-level OEE analysis and workforce accountability reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sparePartsConsumed rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Consumed' ;
    rdfs:comment 'Indicates whether spare parts or materials were consumed from inventory to resolve the downtime event. True = spare parts were issued via SAP MM goods issue; False = no parts consumed (e.g., adjustment or reset only). Drives spare parts demand planning and MRP (Material Requirements Planning) replenishment.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeToRepairMinutes rdf:type rdf:Property ;
    rdfs:label 'Time To Repair Minutes' ;
    rdfs:comment 'Elapsed time in minutes from when the maintenance team began active repair work to when the equipment was restored to operational status. Distinct from duration_minutes (total downtime) and time_to_respond_minutes (response lag). Core component of MTTR (Mean Time to Repair) KPI calculation.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeToRespondMinutes rdf:type rdf:Property ;
    rdfs:label 'Time To Respond Minutes' ;
    rdfs:comment 'Elapsed time in minutes between the downtime event start_timestamp and the time the responsible maintenance or production team acknowledged and began responding to the event. Key metric for maintenance response SLA (Service Level Agreement) compliance and MTTR (Mean Time to Repair) component analysis.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'The SAP PM maintenance work order number (Auftragsnummer) issued to address the downtime event. Distinct from the production order; this is the corrective or preventive maintenance order raised by the maintenance team in SAP PM.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Material Consumption Id' ;
    rdfs:comment 'Unique surrogate identifier for each material consumption (goods issue) transaction record on the shop floor. Primary key of this table.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confirmedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Confirmed By Employee Id' ;
    rdfs:comment 'Employee ID of the shop floor operator or MES user who confirmed or posted the material consumption. Used for accountability, audit trail, and operator-level quality traceability per IATF 16949.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assemblyStationCode rdf:type rdf:Property ;
    rdfs:label 'Assembly Station Code' ;
    rdfs:comment 'Code identifying the specific assembly station or line position (JIS – Just-in-Sequence station) where the material was consumed. More granular than work center; used for shop floor traceability.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomItemNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Item Number' ;
    rdfs:comment 'The BOM line item number identifying the specific component position within the production BOM. Links the consumption record back to the engineering BOM structure in Siemens Teamcenter PLM.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionStatus rdf:type rdf:Property ;
    rdfs:label 'Consumption Status' ;
    rdfs:comment 'Current lifecycle status of the material consumption record. \'posted\' = goods issue confirmed in SAP; \'reversed\' = goods issue reversed (movement type 262); \'blocked\' = held for quality review; \'pending\' = awaiting MES confirmation.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consumption Timestamp' ;
    rdfs:comment 'The precise date and time when the material was physically issued from stock and consumed at the work center on the shop floor. This is the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:goodsMovementNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Number' ;
    rdfs:comment 'Externally visible SAP material document number generated when the goods issue (movement type 261) is posted. Serves as the business-facing transaction identifier traceable in SAP MM.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCostAmount rdf:type rdf:Property ;
    rdfs:label 'Material Cost Amount' ;
    rdfs:comment 'Standard cost value of the consumed material quantity at the time of goods issue, expressed in the plant currency. Calculated as quantity consumed × standard price from SAP Material Master. Feeds production cost accounting and variance reporting.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Mes Transaction Code' ;
    rdfs:comment 'Unique transaction identifier from the Apriso/Dassault MES system that triggered or confirmed this material consumption event. Enables cross-system reconciliation between MES shop floor execution and SAP MM goods movements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalGoodsMovementNumber rdf:type rdf:Property ;
    rdfs:label 'Original Goods Movement Number' ;
    rdfs:comment 'Reference to the original SAP material document number that this record reverses. Populated only when reversal_indicator is True. Enables audit trail for reversed consumption transactions.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLineCode rdf:type rdf:Property ;
    rdfs:label 'Production Line Code' ;
    rdfs:comment 'Code identifying the production line (e.g., \'LINE-A\', \'TRIM-2\', \'PAINT-EAST\') where the material was consumed. Used for line-level consumption analysis and capacity planning.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionLot rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Lot' ;
    rdfs:comment 'SAP QM inspection lot number associated with the consumed material batch, if the material is subject to incoming or in-process quality inspection. Links consumption to quality results for IATF 16949 traceability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityConsumed rdf:type rdf:Property ;
    rdfs:label 'Quantity Consumed' ;
    rdfs:comment 'Actual quantity of the material consumed (goods issued) against the production order. Expressed in the base unit of measure of the material. Core quantitative fact for this transaction.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'Difference between actual quantity consumed and planned BOM quantity (actual minus planned). Positive value indicates over-consumption; negative indicates under-consumption. Key input for production variance reporting and cost accounting.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scrapIndicator rdf:type rdf:Property ;
    rdfs:label 'Scrap Indicator' ;
    rdfs:comment 'Flag indicating whether the consumed material was scrapped (True) rather than incorporated into the vehicle assembly. Scrap consumption is tracked separately for waste reporting, IATF 16949 scrap analysis, and environmental compliance.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scrapReasonCode rdf:type rdf:Property ;
    rdfs:label 'Scrap Reason Code' ;
    rdfs:comment 'Coded reason for material scrap when scrap_indicator is True (e.g., \'DAMAGE\', \'DEFECT\', \'WRONG_PART\', \'PROCESS_LOSS\'). Used for scrap root cause analysis and PPM defect rate reporting. [ENUM-REF-CANDIDATE: DAMAGE|DEFECT|WRONG_PART|PROCESS_LOSS|HANDLING_ERROR|SUPPLIER_DEFECT|OTHER — promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Number' ;
    rdfs:comment 'SAP vendor/supplier number of the supplier who provided the consumed material. Used for supplier-level consumption analysis, PPAP traceability, and supply chain variance reporting.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipOrderSequence rdf:type rdf:Property ;
    rdfs:label 'Wip Order Sequence' ;
    rdfs:comment 'Sequential position of this consumption event within the production order\'s WIP (Work in Progress) processing sequence. Used for JIS (Just-in-Sequence) ordering analysis and shop floor flow traceability.' ;
    rdfs:domain ind:MaterialConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Annual Capacity Units' ;
    rdfs:comment 'Maximum number of vehicles or assemblies the plant is designed to produce per year under normal two-shift operations. Used for capacity planning, CapEx justification, and production scheduling in SAP PP.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dailyCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Daily Capacity Units' ;
    rdfs:comment 'Maximum number of vehicles or assemblies the plant can produce per day (Jobs Per Day - JPD). Derived from takt time and shift configuration. Used for daily production scheduling and MES throughput planning.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:epaFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Epa Facility Code' ;
    rdfs:comment 'EPA-assigned facility identifier for emissions and environmental compliance reporting. Required for CAFE (Corporate Average Fuel Economy) reporting and Clean Air Act compliance.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Floor Area Sqm' ;
    rdfs:comment 'Total manufacturing floor area of the plant in square meters. Used for facility planning, CapEx allocation, insurance valuation, and ISO 14001 environmental footprint reporting.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iatf16949Certified rdf:type rdf:Property ;
    rdfs:label 'Iatf 16949 Certified' ;
    rdfs:comment 'Indicates whether the plant holds a current IATF 16949 automotive quality management system certification. Mandatory for OEM supplier qualification and customer-specific requirements compliance.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified' ;
    rdfs:comment 'Indicates whether the plant holds a current ISO 14001 Environmental Management System certification. Required for EPA compliance reporting and sustainability disclosures.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified' ;
    rdfs:comment 'Indicates whether the plant holds a current ISO 9001 Quality Management System certification. Required for supplier qualification and regulatory compliance reporting.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manager rdf:type rdf:Property ;
    rdfs:label 'Manager' ;
    rdfs:comment 'Full name of the plant manager or general manager responsible for overall plant operations. Used for escalation routing, regulatory correspondence, and organizational reporting. Not classified as PII as this is a business role reference.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesPlantCode rdf:type rdf:Property ;
    rdfs:label 'Mes Plant Code' ;
    rdfs:comment 'The plant identifier as registered in the Apriso/Dassault MES system. Used for cross-system reconciliation between SAP PP production orders and MES shop floor execution records. Enables traceability from ERP to shop floor.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelYearCurrent rdf:type rdf:Property ;
    rdfs:label 'Model Year Current' ;
    rdfs:comment 'The current Model Year (MY) of vehicles being produced at the plant (e.g., \'2025\'). Used for production scheduling, regulatory compliance submissions, and CAFE reporting alignment.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nhtsaFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Nhtsa Facility Code' ;
    rdfs:comment 'NHTSA-assigned facility identifier for the plant. Required for vehicle recall management, safety defect reporting, and Federal Motor Vehicle Safety Standards (FMVSS) compliance submissions.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfAssemblyLines rdf:type rdf:Property ;
    rdfs:label 'Number Of Assembly Lines' ;
    rdfs:comment 'Total count of active production or assembly lines within the plant. Used for capacity planning, MES line configuration, and production scheduling.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current lifecycle state of the plant. \'active\' indicates full production; \'idle\' indicates temporary suspension; \'ramp_up\' indicates pre-SOP commissioning phase; \'ramp_down\' indicates post-EOP wind-down; \'shutdown\' indicates planned or unplanned stoppage; \'decommissioned\' indicates permanently closed.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otaCapable rdf:type rdf:Property ;
    rdfs:label 'Ota Capable' ;
    rdfs:comment 'Indicates whether the plant has the infrastructure to perform OTA (Over-the-Air) software updates on vehicles during the final assembly or PDI (Pre-Delivery Inspection) process. Relevant for connected vehicle production.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plantName rdf:type rdf:Property ;
    rdfs:label 'Plant Name' ;
    rdfs:comment 'Official full name of the manufacturing plant or assembly facility (e.g., \'Detroit Final Assembly Plant No. 1\'). Used in reporting, regulatory submissions, and communications.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantType rdf:type rdf:Property ;
    rdfs:label 'Plant Type' ;
    rdfs:comment 'Categorical classification of the plant\'s primary manufacturing function. Values include stamping (metal forming), body_shop (body-in-white welding), paint (paint application), final_assembly (vehicle assembly), ckd (Completely Knocked Down assembly), skd (Semi Knocked Down assembly), powertrain (engine/transmission), logistics (parts distribution). [ENUM-REF-CANDIDATE: stamping|body_shop|paint|final_assembly|ckd|skd|powertrain|logistics — promote to reference product]' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powertrainTypesProduced rdf:type rdf:Property ;
    rdfs:label 'Powertrain Types Produced' ;
    rdfs:comment 'Classification of powertrain technologies assembled or manufactured at this plant. ICE (Internal Combustion Engine), EV (Electric Vehicle), HEV (Hybrid Electric Vehicle), PHEV (Plug-in Hybrid Electric Vehicle), FCEV (Fuel Cell Electric Vehicle), or mixed. Used for EPA emissions compliance, CAFE reporting, and R&D investment tracking.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryVehicleSegment rdf:type rdf:Property ;
    rdfs:label 'Primary Vehicle Segment' ;
    rdfs:comment 'The primary vehicle segment produced at this plant. Values: car (passenger cars), truck (light/heavy trucks), suv (Sport Utility Vehicles), commercial_vehicle (vans/buses/heavy commercial), ev (Battery Electric Vehicle), hev (Hybrid Electric Vehicle - HEV), phev (Plug-in Hybrid Electric Vehicle - PHEV), mixed (multiple segments). Drives model year planning and regulatory compliance requirements. [ENUM-REF-CANDIDATE: car|truck|suv|commercial_vehicle|ev|hev|phev|mixed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaEnabled rdf:type rdf:Property ;
    rdfs:label 'Scada Enabled' ;
    rdfs:comment 'Indicates whether the plant operates a SCADA (Supervisory Control and Data Acquisition) system for real-time monitoring and control of manufacturing processes, utilities, and equipment.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the plant location (e.g., \'America/Detroit\', \'Europe/Berlin\'). Used for MES shift scheduling, production timestamp normalization, and cross-plant reporting in the Databricks lakehouse.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionRepresented rdf:type rdf:Property ;
    rdfs:label 'Union Represented' ;
    rdfs:comment 'Indicates whether the plant workforce is represented by a labor union. Impacts workforce planning, shift scheduling, overtime policies, and collective bargaining agreement compliance in SuccessFactors.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workforceHeadcount rdf:type rdf:Property ;
    rdfs:label 'Workforce Headcount' ;
    rdfs:comment 'Total number of employees (direct and indirect labor) currently employed at the plant. Used for workforce planning, capacity analysis, and regulatory headcount reporting in SuccessFactors.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processParameterId rdf:type rdf:Property ;
    rdfs:label 'Process Parameter Id' ;
    rdfs:comment 'Unique surrogate identifier for each process parameter reading record captured from PLC/SCADA systems during manufacturing operations.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toolToolingRegistryId rdf:type rdf:Property ;
    rdfs:label 'Tool Tooling Registry Id' ;
    rdfs:comment 'Identifier of the specific tool or fixture used during the operation (e.g., torque bit ID, weld electrode ID, press die ID). Distinct from equipment_id; a single machine may use multiple interchangeable tools.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ToolingRegistry .

ind:controlPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Control Plan Number' ;
    rdfs:comment 'Reference number of the APQP Control Plan that defines the monitoring requirements, specification limits, and reaction plan for this process parameter. Links process execution to the approved quality plan.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlPlanRevision rdf:type rdf:Property ;
    rdfs:label 'Control Plan Revision' ;
    rdfs:comment 'Revision level of the control plan in effect at the time of this parameter reading. Ensures traceability to the correct engineering specification version.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'Method by which this process parameter reading was collected: \'automatic\' = fully automated PLC/SCADA capture with no operator intervention; \'semi_automatic\' = automated measurement with operator confirmation; \'manual\' = operator-entered value.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationFromNominal rdf:type rdf:Property ;
    rdfs:label 'Deviation From Nominal' ;
    rdfs:comment 'Calculated difference between the measured value and the nominal (target) value (measured_value minus nominal_value). Positive values indicate above-nominal readings; negative values indicate below-nominal. Stored as a raw field to support SPC trend analysis without requiring a join.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gaugeCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Gauge Calibration Due Date' ;
    rdfs:comment 'Date by which the measurement instrument or gauge used for this reading is due for recalibration. Readings taken after the calibration due date may be flagged as suspect for quality audit purposes.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isOutOfControl rdf:type rdf:Property ;
    rdfs:label 'Is Out Of Control' ;
    rdfs:comment 'Indicates whether this reading triggered an SPC out-of-control signal based on Western Electric or Nelson rules applied to the control chart. True = out-of-control signal detected; False = in statistical control. Distinct from pass_fail_status which checks specification limits.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowerControlLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Control Limit' ;
    rdfs:comment 'Statistical Lower Control Limit (LCL) for this process parameter as defined by SPC methodology. Readings below this value indicate the process is out of statistical control.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerSpecLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Spec Limit' ;
    rdfs:comment 'Engineering Lower Specification Limit (LSL) for this process parameter as defined in the control plan or engineering drawing. Readings below LSL result in a non-conformance. Distinct from LCL which is a statistical control boundary.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementSystemCode rdf:type rdf:Property ;
    rdfs:label 'Measurement System Code' ;
    rdfs:comment 'Identifier of the measurement system (gauge, sensor, or instrument) used to capture this reading. Supports Measurement System Analysis (MSA) / Gauge R&R traceability per AIAG MSA manual.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominalValue rdf:type rdf:Property ;
    rdfs:label 'Nominal Value' ;
    rdfs:comment 'The engineering-specified nominal or target value for this process parameter as defined in the control plan. Used as the centre line for SPC charting and deviation calculation.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonConformanceNumber rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Number' ;
    rdfs:comment 'Reference number of the Non-Conformance Report (NCR) raised in the quality management system (SAP QM) when this parameter reading resulted in a fail disposition. Null when pass_fail_status is \'pass\'.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterType rdf:type rdf:Property ;
    rdfs:label 'Parameter Type' ;
    rdfs:comment 'Classification of the process parameter by its physical or process nature. Drives SPC charting rules and control limit interpretation. [ENUM-REF-CANDIDATE: weld_current|weld_time|torque|paint_film_thickness|oven_temperature|press_force|adhesive_bead_width|coolant_pressure|cure_time|voltage|current|speed|flow_rate|humidity — promote to reference product]' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plcTagCode rdf:type rdf:Property ;
    rdfs:label 'Plc Tag Code' ;
    rdfs:comment 'Unique tag identifier from the Programmable Logic Controller (PLC) or SCADA system that is the source of this parameter reading. Enables traceability back to the originating control system data point.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactionPlanTriggered rdf:type rdf:Property ;
    rdfs:label 'Reaction Plan Triggered' ;
    rdfs:comment 'Indicates whether the control plan reaction plan was triggered as a result of this parameter reading (True = reaction plan activated due to out-of-spec or out-of-control condition). Supports IATF 16949 audit evidence.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Number' ;
    rdfs:comment 'Sequential sample number within the SPC subgroup or sampling plan for this parameter at this work center. Used to construct X-bar/R charts and other SPC control charts.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scadaSystemCode rdf:type rdf:Property ;
    rdfs:label 'Scada System Code' ;
    rdfs:comment 'Identifier of the SCADA system instance that collected and transmitted this process parameter reading to the MES/data platform.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spcRuleViolated rdf:type rdf:Property ;
    rdfs:label 'Spc Rule Violated' ;
    rdfs:comment 'Identifies the specific SPC detection rule that was violated when is_out_of_control is True (e.g., \'RULE_1_BEYOND_3SIGMA\', \'RULE_2_NINE_CONSECUTIVE\', \'RULE_3_SIX_TRENDING\'). Null when no rule is violated.' ;
    rdfs:domain ind:ProcessParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subgroupNumber rdf:type rdf:Property ;
    rdfs:label 'Subgroup Number' ;
    rdfs:comment 'Identifier of the SPC rational subgroup to which this reading belongs. Subgroups are used to calculate control limits and assess process variation in X-bar/R or X-bar/S charts.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperControlLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Control Limit' ;
    rdfs:comment 'Statistical Upper Control Limit (UCL) for this process parameter as defined by SPC methodology. Readings above this value indicate the process is out of statistical control.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upperSpecLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Spec Limit' ;
    rdfs:comment 'Engineering Upper Specification Limit (USL) for this process parameter as defined in the control plan or engineering drawing. Readings above USL result in a non-conformance. Distinct from UCL which is a statistical control boundary.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebomReferenceBomId rdf:type rdf:Property ;
    rdfs:label 'Ebom Reference Bom Id' ;
    rdfs:comment 'Reference identifier linking this manufacturing BOM (mBOM) to the originating engineering BOM (eBOM) in Siemens Teamcenter PLM or PTC Windchill. Enables traceability from shop floor execution back to the engineering design intent. The eBOM-to-mBOM transformation is managed via the PLM-SAP integration.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bom .

ind:apqpPhase rdf:type rdf:Property ;
    rdfs:label 'Apqp Phase' ;
    rdfs:comment 'Current APQP phase associated with this BOM\'s program lifecycle. Phase 1=Plan and Define, Phase 2=Product Design and Development, Phase 3=Process Design and Development, Phase 4=Product and Process Validation, Phase 5=Launch/Feedback. Tracks BOM maturity relative to the program development gate.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyType rdf:type rdf:Property ;
    rdfs:label 'Assembly Type' ;
    rdfs:comment 'Indicates whether the vehicle is assembled as a Completely Built Unit (CBU), Completely Knocked Down (CKD) kit for overseas assembly, or Semi Knocked Down (SKD) kit. Determines the BOM structure, component packaging, and applicable customs/import regulations for the target market.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseQuantity rdf:type rdf:Property ;
    rdfs:label 'Base Quantity' ;
    rdfs:comment 'The base quantity of the header material for which the BOM component quantities are defined (e.g., 1 vehicle). All component quantities in the BOM are expressed relative to this base quantity. Corresponds to the SAP BOM header base quantity field.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the BOM base quantity (e.g., \'EA\' for each/vehicle, \'PC\' for piece, \'SET\' for set). Corresponds to the SAP material master base unit of measure. Ensures consistent quantity calculations during MRP explosion and production order processing. [ENUM-REF-CANDIDATE: EA|PC|KG|L|M|M2|M3|SET — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomAlternative rdf:type rdf:Property ;
    rdfs:label 'Bom Alternative' ;
    rdfs:comment 'SAP BOM alternative identifier (e.g., \'01\', \'02\') distinguishing multiple valid BOM configurations for the same material and plant. Supports variant BOMs for different production lines or regional configurations (e.g., LHD vs RHD, CKD vs SKD).' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle state of the manufacturing BOM. \'draft\' indicates the BOM is under engineering review. \'released\' means it has been authorized for production use. \'frozen\' indicates no further changes are permitted (e.g., during active production run). \'superseded\' means a newer BOM version has replaced it. \'obsolete\' means the BOM is no longer valid.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomUsage rdf:type rdf:Property ;
    rdfs:label 'Bom Usage' ;
    rdfs:comment 'SAP BOM usage indicator defining the organizational context in which the BOM is applied. \'production\' (SAP usage 1) is the standard for shop floor manufacturing. \'engineering\' (SAP usage 2) is for design/development. \'universal\' (SAP usage 3) applies across all usages. Determines which BOM is selected during MRP and production order processing.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentCount rdf:type rdf:Property ;
    rdfs:label 'Component Count' ;
    rdfs:comment 'Total number of distinct component line items (BOM positions) in this manufacturing BOM. Provides a quick indicator of BOM complexity and is used for completeness validation during BOM release. Does not include phantom sub-assembly components.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ecoNumber rdf:type rdf:Property ;
    rdfs:label 'Eco Number' ;
    rdfs:comment 'The Engineering Change Order (ECO) number that authorized the creation or last modification of this manufacturing BOM. Provides full traceability from the shop floor BOM back to the formal engineering change management process in Teamcenter PLM. Required for IATF 16949 change control compliance.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConfigurable rdf:type rdf:Property ;
    rdfs:label 'Is Configurable' ;
    rdfs:comment 'Indicates whether this BOM uses SAP Variant Configuration (VC) to support multiple vehicle variants from a single configurable BOM structure. True = configurable BOM with characteristic-based component selection. False = fixed BOM for a single specific vehicle configuration.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPhantomAssembly rdf:type rdf:Property ;
    rdfs:label 'Is Phantom Assembly' ;
    rdfs:comment 'Indicates whether the header material of this BOM is a phantom assembly — a logical grouping of components that is not physically stocked or produced as a discrete unit. Phantom assemblies are \'exploded through\' during MRP and production order processing. Common for sub-assemblies in JIS manufacturing.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predecessorBomNumber rdf:type rdf:Property ;
    rdfs:label 'Predecessor Bom Number' ;
    rdfs:comment 'BOM number of the previous manufacturing BOM version that this BOM supersedes. Enables backward navigation in the BOM version chain for change impact analysis and quality investigations. Null for the initial BOM version.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMarketCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Market Code' ;
    rdfs:comment 'Code identifying the target regulatory market for which this BOM is homologated (e.g., \'US-FEDERAL\', \'US-CARB\', \'EU-EURO6\', \'JP-JC08\', \'CN-CHINA6\'). Determines applicable emissions standards (EPA, CARB, Euro 6, WLTP), safety regulations (NHTSA FMVSS, UNECE), and CAFE compliance requirements.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedBy rdf:type rdf:Property ;
    rdfs:label 'Released By' ;
    rdfs:comment 'User ID or employee identifier of the manufacturing engineer or release authority who formally released this BOM to production in SAP PP or Teamcenter PLM. Required for audit trail and change control compliance under IATF 16949.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByBomNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Bom Number' ;
    rdfs:comment 'BOM number of the newer manufacturing BOM that has replaced this one (populated when bom_status = \'superseded\'). Enables forward navigation in the BOM version chain for traceability and historical analysis. Null when this is the current active BOM.' ;
    rdfs:domain ind:ProductionBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleConfigurationCode rdf:type rdf:Property ;
    rdfs:label 'Vehicle Configuration Code' ;
    rdfs:comment 'Code identifying the specific vehicle configuration (variant) for which this BOM is defined, including body style, drivetrain, trim level, and market variant (e.g., \'SUV-AWD-PREMIUM-NA\'). Used in SAP Variant Configuration (VC) to select the correct BOM components for a specific vehicle order.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Production Confirmation Id' ;
    rdfs:comment 'Unique surrogate identifier for the production confirmation record in the Databricks Silver Layer. Primary key for this entity. Entity Role: TRANSACTION_HEADER — represents a discrete business event (completion of a production order or partial operation) with a clear lifecycle.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversedConfirmationProductionConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Reversed Confirmation Production Confirmation Id' ;
    rdfs:comment 'Reference to the original production confirmation record that this entry reverses. Populated only when reversal_indicator is True. Enables audit trail reconstruction and net quantity calculation when reversals are present. Self-referencing within the production_confirmation product.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionConfirmation .

ind:activityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Activity Type Code' ;
    rdfs:comment 'SAP CO activity type (LSTAR) used to record the confirmed actual activities (setup, machine, labor) against the production order. Drives cost settlement rates and actual cost calculation in SAP CO-PC (Product Costing). Required for standard vs. actual cost variance analysis.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationEntryMode rdf:type rdf:Property ;
    rdfs:label 'Confirmation Entry Mode' ;
    rdfs:comment 'Method by which this production confirmation was entered into SAP PP. \'manual\' = entered by operator via CO11N; \'automatic\' = system-generated via PP-PI or SCADA integration; \'mes_interface\' = posted via Apriso/Dassault MES interface; \'backflush\' = automatic backflush confirmation triggered by goods issue. Used for data quality auditing and process automation tracking.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Externally-known alphanumeric confirmation number assigned by SAP PP (CO11N) at the time of posting. This is the business-facing identifier used in shop floor reporting, MES integration, and order settlement reconciliation. Maps to SAP field RUECK (Confirmation Number).' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'The principal real-world event timestamp recording when the production operation or order was confirmed as complete on the shop floor. This is the business event time (not the system posting time) and represents the actual completion moment. Maps to SAP PP fields BUDAT (posting date) + ISDD/ISDZ (actual execution date/time). Used for takt time analysis, shift output reporting, and production scheduling.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationType rdf:type rdf:Property ;
    rdfs:label 'Confirmation Type' ;
    rdfs:comment 'Classification of the confirmation indicating whether it is a partial confirmation (interim progress), final confirmation (order completion), automatic system-generated confirmation, milestone-based confirmation, or a reversal entry. Determines downstream SAP PP processing logic including order closure and goods receipt.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeDurationMin rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Min' ;
    rdfs:comment 'Total unplanned downtime duration recorded during this production confirmation period, in minutes. Captured from SCADA/PLC systems or MES downtime tracking. Used for OEE (Overall Equipment Effectiveness) availability calculation, maintenance planning, and production loss analysis.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalConfirmationFlag rdf:type rdf:Property ;
    rdfs:label 'Final Confirmation Flag' ;
    rdfs:comment 'Indicates whether this confirmation is the final confirmation for the production order (SAP PP IEDD — Final Confirmation Indicator). When True, SAP PP automatically closes the production order, triggers goods receipt for the finished product, and initiates order settlement to CO (Controlling). Critical for order lifecycle management and inventory accuracy.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Posted Flag' ;
    rdfs:comment 'Indicates whether the automatic goods receipt (GR) to inventory has been successfully posted as a result of this production confirmation. True = inventory has been updated with the confirmed yield quantity. Used for inventory reconciliation and to identify confirmations where GR posting failed or is pending.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborTimeActualMin rdf:type rdf:Property ;
    rdfs:label 'Labor Time Actual Min' ;
    rdfs:comment 'Actual direct labor time consumed for this production operation, recorded in minutes. Maps to SAP PP activity type for labor (ISRLA — Actual Labor Time). Used for labor cost settlement to the production order, workforce productivity analysis, and standard vs. actual cost variance reporting.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborTimePlannedMin rdf:type rdf:Property ;
    rdfs:label 'Labor Time Planned Min' ;
    rdfs:comment 'Planned direct labor time for this operation as defined in the SAP PP routing, recorded in minutes. Baseline for labor efficiency variance analysis and standard cost calculation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:machineTimeActualMin rdf:type rdf:Property ;
    rdfs:label 'Machine Time Actual Min' ;
    rdfs:comment 'Actual machine runtime consumed for this production operation, recorded in minutes. Maps to SAP PP activity type for machine time (ISRÜT — Actual Machine Time). Core input for OEE calculation, takt time variance analysis, and capacity utilization reporting. Compared against planned machine time from the routing to identify bottlenecks.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:machineTimePlannedMin rdf:type rdf:Property ;
    rdfs:label 'Machine Time Planned Min' ;
    rdfs:comment 'Planned machine time for this operation as defined in the SAP PP routing, recorded in minutes. Baseline for actual vs. planned machine time variance analysis and takt time adherence reporting.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesConfirmationReference rdf:type rdf:Property ;
    rdfs:label 'Mes Confirmation Reference' ;
    rdfs:comment 'The confirmation or transaction reference number from the Apriso/Dassault MES system that corresponds to this SAP PP production confirmation. Enables cross-system traceability between the MES shop floor execution record and the SAP ERP confirmation posting. Critical for audit trails and discrepancy resolution.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderSettlementStatus rdf:type rdf:Property ;
    rdfs:label 'Order Settlement Status' ;
    rdfs:comment 'Status of the SAP CO production order settlement triggered by this final confirmation. \'pending\' = settlement not yet executed; \'settled\' = actual costs fully settled to cost objects; \'partially_settled\' = partial settlement completed; \'not_required\' = non-final confirmation, settlement not applicable. Used for period-end closing and financial reporting.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Production Order Number' ;
    rdfs:comment 'SAP PP production order number (AUFNR) to which this confirmation is posted. Links the confirmation to the originating manufacturing order for order settlement, cost collection, and goods receipt triggering. Retained as a business attribute for direct shop floor reporting without requiring a join.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkQuantity rdf:type rdf:Property ;
    rdfs:label 'Rework Quantity' ;
    rdfs:comment 'The quantity of units requiring rework (reprocessing to meet specification) identified during this confirmation. Distinct from scrap (which is permanently rejected). Used for quality cost analysis, rework labor tracking, and process capability assessment per APQP (Advanced Product Quality Planning) requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:setupTimeActualMin rdf:type rdf:Property ;
    rdfs:label 'Setup Time Actual Min' ;
    rdfs:comment 'Actual machine/workstation setup time consumed for this operation, recorded in minutes. Maps to SAP PP activity type for setup (ISRST — Actual Setup Time). Used for capacity planning, OEE (Overall Equipment Effectiveness) calculation, and comparison against planned setup time from the routing.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:setupTimePlannedMin rdf:type rdf:Property ;
    rdfs:label 'Setup Time Planned Min' ;
    rdfs:comment 'Planned setup time for this operation as defined in the SAP PP routing, recorded in minutes. Provides the baseline for actual vs. planned setup time variance analysis. Sourced from the routing master data at the time of production order creation.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'SAP storage location (LGORT) to which the confirmed yield quantity is posted as a goods receipt. Identifies the physical inventory location within the plant (e.g., finished goods area, WIP buffer, sequencing area). Required for inventory management and JIS (Just-in-Sequence) delivery coordination.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taktTimeActualSec rdf:type rdf:Property ;
    rdfs:label 'Takt Time Actual Sec' ;
    rdfs:comment 'Actual takt time achieved for this production confirmation, expressed in seconds per unit. Calculated as total operation time divided by yield quantity. Used for production line balancing, bottleneck identification, and comparison against the planned takt time to assess line efficiency. Key metric in JIS (Just-in-Sequence) production management.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teardownTimeActualMin rdf:type rdf:Property ;
    rdfs:label 'Teardown Time Actual Min' ;
    rdfs:comment 'Actual teardown/cleanup time consumed after the production operation, recorded in minutes. Maps to SAP PP activity type for teardown. Included in total operation time for accurate takt time and capacity utilization calculations. Relevant for paint booth cleaning, tooling changeover, and AGV (Automated Guided Vehicle) repositioning cycles.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Yield Quantity' ;
    rdfs:comment 'The confirmed good quantity (yield) produced in this confirmation, expressed in the base unit of measure of the material. Represents the number of units that passed quality inspection and are accepted into inventory. Maps to SAP PP field LMNGA (Yield Quantity). Core metric for production output reporting and OTD (On-Time Delivery) tracking.' ;
    rdfs:domain ind:ProductionConfirmation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Line Manager Employee Id' ;
    rdfs:comment 'Employee identifier of the production line manager or area manager responsible for this line\'s operations, quality, and safety performance. References the SuccessFactors HR system employee record. Used for accountability assignment, escalation routing, and workforce reporting.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sapWorkCenterId rdf:type rdf:Property ;
    rdfs:label 'Sap Work Center Id' ;
    rdfs:comment 'The SAP S/4HANA PP (Production Planning) work center identifier corresponding to this production line. Enables direct linkage between the lakehouse production_line master and SAP production orders, capacity planning, and cost center assignments in SAP CO (Controlling).' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:agvIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Agv Integration Enabled' ;
    rdfs:comment 'Indicates whether this production line is integrated with an AGV (Automated Guided Vehicle) system for automated material delivery, WIP (Work in Progress) transport, or carrier movement. True = AGV-integrated; False = manual or conventional conveyor-based material handling. Used for automation investment tracking and MES configuration.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ckdSkdCapable rdf:type rdf:Property ;
    rdfs:label 'Ckd Skd Capable' ;
    rdfs:comment 'Indicates the assembly kit type this line is configured to process: CKD (Completely Knocked Down — full kit assembly from parts), SKD (Semi Knocked Down — partial pre-assembly), CBU (Completely Built Up — no kit assembly, line-off only), or multi (capable of multiple kit types). Relevant for export assembly plants and regulatory homologation.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conveyorType rdf:type rdf:Property ;
    rdfs:label 'Conveyor Type' ;
    rdfs:comment 'Type of conveyor or carrier system used to move vehicles or assemblies along this production line: overhead_conveyor (hanging carrier), floor_conveyor (ground-level chain/belt), skillet (moving platform for final assembly), agv_carrier (autonomous guided vehicle carrier), stationary (fixed-position assembly), or mixed (combination of types).' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentJph rdf:type rdf:Property ;
    rdfs:label 'Current Jph' ;
    rdfs:comment 'The current actual or most recently measured throughput rate of the production line in Jobs Per Hour (JPH), reflecting real-world performance after accounting for constraints, model mix, and current configuration. Used to compare against designed_jph for capacity gap analysis and production scheduling.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designedJph rdf:type rdf:Property ;
    rdfs:label 'Designed Jph' ;
    rdfs:comment 'The engineered design throughput capacity of the production line expressed in Jobs Per Hour (JPH) — the number of vehicle units or assemblies the line is designed to produce per hour under optimal conditions. This is the nameplate capacity used for capacity planning, takt time calculation, and OEE baseline. Maps to MEASUREMENT_OR_VALUE category for MASTER_RESOURCE role.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyConsumptionKwhPerUnit rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh Per Unit' ;
    rdfs:comment 'Average energy consumption of this production line in kilowatt-hours (kWh) per vehicle unit produced. Used for ISO 14001 environmental management reporting, carbon footprint calculation, energy efficiency benchmarking, and EPA/CARB manufacturing emissions compliance.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floorSpaceSqm rdf:type rdf:Property ;
    rdfs:label 'Floor Space Sqm' ;
    rdfs:comment 'Total floor space occupied by this production line in square meters, including the line footprint, buffer zones, and material staging areas. Used for facility capacity planning, real estate cost allocation, and plant layout optimization.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iatfAuditStatus rdf:type rdf:Property ;
    rdfs:label 'Iatf Audit Status' ;
    rdfs:comment 'Current IATF 16949 (International Automotive Task Force) quality management system audit status for this production line: compliant (no non-conformances), minor_nc (minor non-conformance identified), major_nc (major non-conformance — corrective action required), suspended (production suspended pending corrective action), or not_audited (not yet subject to IATF audit).' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jisEnabled rdf:type rdf:Property ;
    rdfs:label 'Jis Enabled' ;
    rdfs:comment 'Indicates whether this production line operates under JIS (Just-in-Sequence) material delivery sequencing, where parts are delivered to the line in the exact sequence of vehicle build order. True = JIS-enabled; False = standard JIT or batch delivery. Critical for supply chain integration and sequencing system configuration.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastIatfAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Iatf Audit Date' ;
    rdfs:comment 'Date of the most recent IATF 16949 quality management system audit conducted on this production line. Used for audit cycle management, corrective action tracking, and regulatory compliance reporting to OEM customers and certification bodies.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineCode rdf:type rdf:Property ;
    rdfs:label 'Line Code' ;
    rdfs:comment 'Externally-known alphanumeric code that uniquely identifies the production line within the plant and across the enterprise (e.g., FA-01, BS-03, PT-02). Used as the business key in MES, SAP PP, and Apriso/Dassault shop-floor execution systems. Maps to BUSINESS_IDENTIFIER category for MASTER_RESOURCE role.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineLengthMeters rdf:type rdf:Property ;
    rdfs:label 'Line Length Meters' ;
    rdfs:comment 'Physical length of the production line in meters, measured from the first to the last station. Used for facility layout planning, AGV (Automated Guided Vehicle) path configuration, and ergonomic compliance assessments per plant engineering standards.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineName rdf:type rdf:Property ;
    rdfs:label 'Line Name' ;
    rdfs:comment 'Human-readable descriptive name of the production line (e.g., \'Final Assembly Line 1 – Truck Platform\', \'Body Shop Framing Line – SUV\'). Used in reporting dashboards, capacity planning, and operator interfaces. Maps to IDENTITY_LABEL category for MASTER_RESOURCE role.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Categorical classification of the production line by manufacturing process area: stamping (metal forming), body_shop (welding/framing), paint (surface treatment), final_assembly (vehicle build), powertrain (engine/transmission), chassis (underbody), or trim (interior/exterior finishing). Maps to CLASSIFICATION_OR_TYPE category for MASTER_RESOURCE role. [ENUM-REF-CANDIDATE: stamping|body_shop|paint|final_assembly|powertrain|chassis|trim|subassembly|battery_pack|quality_gate — promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxVehicleWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Vehicle Weight Kg' ;
    rdfs:comment 'Maximum gross vehicle weight in kilograms that this production line\'s conveyor, tooling, and fixtures are rated to handle. Constrains which vehicle programs can be assigned to this line and is critical for structural safety compliance and tooling certification.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesLineCode rdf:type rdf:Property ;
    rdfs:label 'Mes Line Code' ;
    rdfs:comment 'The line identifier as registered in the Apriso/Dassault MES (Manufacturing Execution System) for shop floor execution, work order dispatch, and build traceability. Used for cross-system reconciliation between the lakehouse silver layer and the operational MES source system.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mixedModelCapable rdf:type rdf:Property ;
    rdfs:label 'Mixed Model Capable' ;
    rdfs:comment 'Indicates whether this production line is capable of producing multiple vehicle models or variants in a mixed sequence on the same line (mixed-model assembly). True = mixed-model capable; False = dedicated single-model line. Drives production scheduling complexity and sequencing logic in MES.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modelYearCapability rdf:type rdf:Property ;
    rdfs:label 'Model Year Capability' ;
    rdfs:comment 'The model year (MY) or range of model years that this production line is currently tooled and certified to produce (e.g., \'2024\' or \'2024-2026\'). Drives SOP (Start of Production) and EOP (End of Production) planning, tooling investment decisions, and homologation scheduling.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfStations rdf:type rdf:Property ;
    rdfs:label 'Number Of Stations' ;
    rdfs:comment 'Total count of individual work stations or assembly stations on this production line. Used for line balancing analysis, ergonomic assessments, and determining the number of operators required per shift. Key input for APQP (Advanced Product Quality Planning) and control plan development.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paintBoothType rdf:type rdf:Property ;
    rdfs:label 'Paint Booth Type' ;
    rdfs:comment 'Type of paint application system used on this line (applicable to paint shop lines): waterborne (water-based paint — lower VOC emissions), solventborne (solvent-based paint), powder_coat (electrostatic powder coating), or none (non-paint line). Drives EPA/CARB VOC (Volatile Organic Compound) emissions compliance reporting and environmental permit management.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plcSystemReference rdf:type rdf:Property ;
    rdfs:label 'Plc System Reference' ;
    rdfs:comment 'Identifier or name of the PLC (Programmable Logic Controller) system or network controlling this production line\'s automated equipment (e.g., \'Siemens S7-1500 Network A\', \'Allen-Bradley ControlLogix Zone 3\'). Used for maintenance management in SAP PM, SCADA integration, and cybersecurity asset inventory.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powertrainTypeCapability rdf:type rdf:Property ;
    rdfs:label 'Powertrain Type Capability' ;
    rdfs:comment 'The powertrain technology types this production line is capable of assembling: ICE (Internal Combustion Engine), HEV (Hybrid Electric Vehicle), PHEV (Plug-in Hybrid Electric Vehicle), BEV (Battery Electric Vehicle), FCEV (Fuel Cell Electric Vehicle), or multi (flexible line supporting multiple powertrain types). Critical for EV transition capacity planning and regulatory compliance with EPA/CARB emissions standards.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityGateCount rdf:type rdf:Property ;
    rdfs:label 'Quality Gate Count' ;
    rdfs:comment 'Number of quality inspection gates or checkpoints integrated into this production line (e.g., in-process inspection stations, end-of-line audit points). Used for quality planning per APQP (Advanced Product Quality Planning), control plan documentation, and IATF 16949 compliance audits.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:robotCount rdf:type rdf:Property ;
    rdfs:label 'Robot Count' ;
    rdfs:comment 'Total number of industrial robots (welding, painting, assembly, material handling) deployed on this production line. Used for maintenance planning in SAP PM, automation investment tracking, and Industry 4.0 KPI reporting.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Expiry Date' ;
    rdfs:comment 'Expiry date of the production line\'s current safety certification. Used to trigger renewal workflows, prevent operation of uncertified lines, and support regulatory audit readiness for OSHA, DOT, and IATF 16949 compliance.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scadaSystemReference rdf:type rdf:Property ;
    rdfs:label 'Scada System Reference' ;
    rdfs:comment 'Identifier or name of the SCADA (Supervisory Control and Data Acquisition) system monitoring and controlling this production line (e.g., \'Ignition SCADA Plant2-Zone1\', \'Wonderware InTouch Line FA-01\'). Used for real-time production monitoring, alarm management, and integration with MES and ERP systems.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftConfiguration rdf:type rdf:Property ;
    rdfs:label 'Shift Configuration' ;
    rdfs:comment 'Current shift schedule configuration for the production line, indicating the number of operating shifts per day: 1_shift (single day shift), 2_shift (day and afternoon), 3_shift (continuous 24-hour), or 4_shift_rotating (rotating continental schedule). Drives capacity planning, workforce scheduling in SuccessFactors, and MRP calculations in SAP PP.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehiclePlatformCode rdf:type rdf:Property ;
    rdfs:label 'Vehicle Platform Code' ;
    rdfs:comment 'The vehicle platform or architecture code that this production line is primarily configured to build (e.g., \'F-150 Gen14\', \'GMT800\', \'MEB\'). A single line may support multiple model variants on the same platform. Used for PLM integration with Siemens Teamcenter and production scheduling.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weldGunCount rdf:type rdf:Property ;
    rdfs:label 'Weld Gun Count' ;
    rdfs:comment 'Total number of resistance spot weld guns (robotic and manual) deployed on this production line. Applicable primarily to body shop lines. Used for weld quality management per IATF 16949, preventive maintenance scheduling in SAP PM, and SPC (Statistical Process Control) monitoring of weld quality.' ;
    rdfs:domain ind:ProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobilityFleetAccountId rdf:type rdf:Property ;
    rdfs:label 'Mobility Fleet Account Id' ;
    rdfs:comment 'Foreign key linking to mobility.mobility_fleet_account. Business justification: Required for fleet sales processing: link production order to the purchasing fleet account for order tracking, invoicing, and delivery coordination.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MobilityFleetAccount .

ind:quoteId rdf:type rdf:Property ;
    rdfs:label 'Quote Id' ;
    rdfs:comment 'Foreign key linking to sales.quote. Business justification: Provides Quote-to-Production traceability for financial and compliance reporting; links the quote that was accepted to the resulting production order.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quote .

ind:routingId rdf:type rdf:Property ;
    rdfs:label 'Routing Id' ;
    rdfs:comment 'Reference to the production routing (task list / operation sequence) assigned to this order. The routing defines the sequence of manufacturing operations, work centers, and standard times. Maps to SAP PP Routing (PLNNR).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Routing .

ind:actualLaborHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Hours' ;
    rdfs:comment 'The total actual direct labor hours consumed during execution of this production order, as confirmed through SAP PP operation confirmations or MES time tracking. Used for labor efficiency analysis, variance reporting, and cost actuals in SAP CO.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMachineHours rdf:type rdf:Property ;
    rdfs:label 'Actual Machine Hours' ;
    rdfs:comment 'The total actual machine/equipment hours consumed during execution of this production order, as recorded by SCADA (Supervisory Control and Data Acquisition) systems or MES. Used for OEE analysis, machine utilization reporting, and cost variance calculation.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assemblySequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Assembly Sequence Number' ;
    rdfs:comment 'The Just-in-Sequence (JIS) sequence number assigned to this production order, defining its position in the assembly line build sequence. Critical for JIS supply chain synchronization — ensures parts arrive at the line in the exact order vehicles are built. Managed by MES and communicated to tier-1 suppliers.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesOrderReference rdf:type rdf:Property ;
    rdfs:label 'Mes Order Reference' ;
    rdfs:comment 'Cross-reference identifier assigned by the Apriso/Dassault MES system for this production order. Used to correlate SAP PP orders with shop floor execution records in the MES for traceability and real-time production control.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDescription rdf:type rdf:Property ;
    rdfs:label 'Order Description' ;
    rdfs:comment 'Free-text description of the production order providing additional context about the manufacturing scope, special instructions, or engineering change notes. Used by shop floor supervisors and production planners for operational clarity.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Planned Labor Hours' ;
    rdfs:comment 'The total planned direct labor hours required to execute this production order, derived from the routing standard times and target quantity. Used for capacity planning, workforce scheduling via SuccessFactors, and standard cost calculation in SAP CO.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMachineHours rdf:type rdf:Property ;
    rdfs:label 'Planned Machine Hours' ;
    rdfs:comment 'The total planned machine/equipment hours required to execute this production order, derived from routing standard machine times. Used for equipment capacity planning, OEE (Overall Equipment Effectiveness) baseline, and standard cost calculation.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppapRequired rdf:type rdf:Property ;
    rdfs:label 'Ppap Required' ;
    rdfs:comment 'Indicates whether PPAP (Production Part Approval Process) approval is required before this production order can be released for full-volume production. Typically True for new part introductions, engineering changes, or supplier changes. Governed by IATF 16949 and AIAG PPAP standards.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionStage rdf:type rdf:Property ;
    rdfs:label 'Production Stage' ;
    rdfs:comment 'The manufacturing stage or shop area where this production order is executed. Reflects the physical production process: \'stamping\' = metal forming; \'body_shop\' = body-in-white welding; \'paint\' = surface coating; \'final_assembly\' = vehicle assembly; \'powertrain\' = engine/transmission build; \'trim_chassis\' = trim, chassis, and final fit.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopIndicator rdf:type rdf:Property ;
    rdfs:label 'Sop Indicator' ;
    rdfs:comment 'Indicates whether this production order is part of the SOP (Start of Production) launch phase for a new vehicle program. True = SOP launch order subject to enhanced quality monitoring and APQP controls; False = regular series production order.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetQuantity rdf:type rdf:Property ;
    rdfs:label 'Target Quantity' ;
    rdfs:comment 'The planned quantity of vehicles or sub-assemblies to be produced under this order, expressed in the base unit of measure (typically \'EA\' for each). Maps to SAP PP planned order quantity (GAMNG). Used for capacity planning and production scheduling.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Technical Completion Timestamp' ;
    rdfs:comment 'The date and time when the production order was set to Technically Completed (TECO) status in SAP PP, indicating all manufacturing operations are finished and the order is pending cost settlement. Distinct from actual_finish_timestamp which records the last physical operation.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:wipPostingFlag rdf:type rdf:Property ;
    rdfs:label 'Wip Posting Flag' ;
    rdfs:comment 'Indicates whether WIP (Work in Progress) costs have been calculated and posted to the financial ledger for this production order in the current period. True = WIP posted; False = WIP not yet posted. Used for period-end financial closing in SAP CO.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Production Schedule Id' ;
    rdfs:comment 'Unique surrogate identifier for the master production schedule (MPS) record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mrpRunId rdf:type rdf:Property ;
    rdfs:label 'Mrp Run Id' ;
    rdfs:comment 'Reference to the SAP MRP (Material Requirements Planning) run that generated or last updated this production schedule. Enables traceability of schedule origin and supports re-planning analysis.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Run .

ind:actualQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity' ;
    rdfs:comment 'Actual number of vehicles produced and confirmed as good units by the MES (Manufacturing Execution System) during the schedule period. Populated upon schedule completion from Apriso/Dassault MES.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assemblyProcessStage rdf:type rdf:Property ;
    rdfs:label 'Assembly Process Stage' ;
    rdfs:comment 'Manufacturing process stage covered by this schedule record. Reflects the major shop areas in automotive assembly: stamping (metal forming), body shop (welding/joining), paint (surface treatment), final assembly (powertrain/trim installation), or trim-chassis-final (TCF integrated line).' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCapacityHours rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Hours' ;
    rdfs:comment 'Total available production capacity in hours for this schedule period on the assigned production line, accounting for planned downtime, maintenance windows, and shift patterns.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildSequenceEnd rdf:type rdf:Property ;
    rdfs:label 'Build Sequence End' ;
    rdfs:comment 'Ending sequence number for the JIS (Just-in-Sequence) build order within this schedule period. Together with build_sequence_start defines the range of vehicle sequence numbers assigned to this schedule.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buildSequenceStart rdf:type rdf:Property ;
    rdfs:label 'Build Sequence Start' ;
    rdfs:comment 'Starting sequence number for the JIS (Just-in-Sequence) build order within this schedule period. Used by MES and AGV systems to sequence vehicle bodies through the production line in the correct order.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calloffTransmissionTime rdf:type rdf:Property ;
    rdfs:label 'Calloff Transmission Time' ;
    rdfs:comment 'Timestamp when supplier delivery call-offs were transmitted to the supply base for this production schedule. Used for OTD (On-Time Delivery) tracking and supplier performance measurement.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freezeHorizonDate rdf:type rdf:Property ;
    rdfs:label 'Freeze Horizon Date' ;
    rdfs:comment 'Date up to which the production schedule is frozen and cannot be changed without formal change control. Protects supplier call-offs and JIT/JIS delivery commitments within the frozen window.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryMarket rdf:type rdf:Property ;
    rdfs:label 'Regulatory Market' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the primary regulatory market for which these vehicles are being produced. Determines applicable homologation standards (NHTSA/FMVSS for USA, UNECE for Europe, etc.), emissions certification (EPA, CARB, Euro 6), and CAFE compliance tracking. [ENUM-REF-CANDIDATE: USA|CAN|MEX|DEU|GBR|CHN|JPN|KOR|AUS|BRA — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleChangeReason rdf:type rdf:Property ;
    rdfs:label 'Schedule Change Reason' ;
    rdfs:comment 'Business reason code or description for the most recent schedule revision. Examples: material shortage, capacity constraint, demand change, quality hold, tooling failure, model mix adjustment. Required for change control audit trail per IATF 16949.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Date' ;
    rdfs:comment 'The principal planned production date (or start date of the weekly/monthly bucket) for this schedule record. Represents the real-world business event date when production is planned to occur.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleEndDate rdf:type rdf:Property ;
    rdfs:label 'Schedule End Date' ;
    rdfs:comment 'End date of the production schedule period. For daily schedules this equals schedule_date; for weekly/monthly buckets this marks the last day of the planning period.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleNotes rdf:type rdf:Property ;
    rdfs:label 'Schedule Notes' ;
    rdfs:comment 'Free-text field for production planners to record contextual notes, exceptions, or special instructions associated with this schedule record. Examples: tooling changeover notes, quality hold references, special customer order constraints.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle state of the production schedule record. \'draft\' = initial planning; \'released\' = approved for execution; \'frozen\' = within freeze horizon, no changes allowed; \'in_execution\' = active shop floor production; \'completed\' = all planned units built; \'cancelled\' = schedule voided.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Incremental version number of the production schedule. Each MRP (Material Requirements Planning) run or manual revision increments this counter, enabling version comparison and rollback analysis.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'Precise timestamp when production is scheduled to complete for this schedule record. Used for shift planning, takt time validation, and downstream logistics coordination.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Precise timestamp when production is scheduled to begin on the line for this schedule record. Used for JIS (Just-in-Sequence) sequencing, AGV routing, and supplier call-off timing.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supplierCalloffGenerated rdf:type rdf:Property ;
    rdfs:label 'Supplier Calloff Generated' ;
    rdfs:comment 'Boolean flag indicating whether supplier delivery call-offs (JIT/JIS delivery schedules) have been generated and transmitted to suppliers based on this production schedule. True = call-offs sent; False = pending call-off generation.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionVariantId rdf:type rdf:Property ;
    rdfs:label 'Production Variant Id' ;
    rdfs:comment 'Primary key for production_variant' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adasLevel rdf:type rdf:Property ;
    rdfs:label 'Adas Level' ;
    rdfs:comment 'SAE J3016 automation level of the ADAS (Advanced Driver Assistance Systems) suite fitted to this production variant: L0 (no automation), L1 (driver assistance), L2 (partial automation), L2_PLUS (enhanced partial automation), L3 (conditional automation). Drives ECU (Electronic Control Unit) software configuration, OTA (Over-the-Air Update) eligibility, and UNECE UN R157 regulatory compliance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyComplexityScore rdf:type rdf:Property ;
    rdfs:label 'Assembly Complexity Score' ;
    rdfs:comment 'Numeric score (1–10) representing the relative assembly complexity of this production variant compared to the base variant on the same production line. Higher scores indicate more assembly operations, longer cycle times, or specialized tooling requirements. Used for JIS (Just-in-Sequence) sequencing optimization to balance line loading and avoid consecutive high-complexity builds.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:co2EmissionGPerKm rdf:type rdf:Property ;
    rdfs:label 'Co2 Emission G Per Km' ;
    rdfs:comment 'Certified CO2 tailpipe emission in grams per kilometre (g/km) under WLTP or NEDC test cycle for this production variant. Used for EU CO2 fleet average compliance (Regulation (EU) 2019/631), CAFE (Corporate Average Fuel Economy) calculations, and vehicle taxation band classification in destination markets.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineDisplacementCc rdf:type rdf:Property ;
    rdfs:label 'Engine Displacement Cc' ;
    rdfs:comment 'Total engine displacement in cubic centimetres (cc) for ICE (Internal Combustion Engine) and HEV/PHEV variants. Null for BEV and FCEV variants. Used for regulatory classification under EPA, CARB, and UNECE emissions standards, and for CAFE (Corporate Average Fuel Economy) fleet averaging calculations.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engineeringChangeLevel rdf:type rdf:Property ;
    rdfs:label 'Engineering Change Level' ;
    rdfs:comment 'Current engineering change revision level for this production variant as managed in Siemens Teamcenter PLM or PTC Windchill (e.g., \'A\', \'B\', \'C1\', \'REV3\'). Tracks design maturity and ensures the correct BOM (Bill of Materials) version is applied during production. Incremented upon each approved engineering change notice (ECN).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelEconomyMpg rdf:type rdf:Property ;
    rdfs:label 'Fuel Economy Mpg' ;
    rdfs:comment 'EPA-certified combined fuel economy in miles per gallon (MPG) for ICE, HEV, and PHEV variants in NAFTA markets. Null for BEV/FCEV variants. Used for CAFE (Corporate Average Fuel Economy) fleet compliance reporting to EPA and consumer window sticker labelling under 49 CFR Part 575.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossVehicleWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Vehicle Weight Kg' ;
    rdfs:comment 'Gross Vehicle Weight Rating (GVWR) in kilograms for this production variant. Used for regulatory classification under DOT FMVSS, UNECE weight regulations, and CAFE (Corporate Average Fuel Economy) fleet averaging. Also drives chassis assembly torque specifications and suspension tuning parameters.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handOfDrive rdf:type rdf:Property ;
    rdfs:label 'Hand Of Drive' ;
    rdfs:comment 'Steering wheel position for this production variant: LHD (Left-Hand Drive) for markets such as USA, Germany; RHD (Right-Hand Drive) for markets such as UK, Japan, Australia. Determines instrument panel assembly variant, steering column routing, and body shop tooling configuration.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCkdEligible rdf:type rdf:Property ;
    rdfs:label 'Is Ckd Eligible' ;
    rdfs:comment 'Indicates whether this production variant can be produced as a CKD (Completely Knocked Down) kit for assembly at an overseas plant (True = CKD eligible). Drives export documentation, customs tariff classification, and overseas plant BOM (Bill of Materials) configuration in SAP MM.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isJisEligible rdf:type rdf:Property ;
    rdfs:label 'Is Jis Eligible' ;
    rdfs:comment 'Indicates whether this production variant is eligible for JIS (Just-in-Sequence) supplier call-off sequencing (True = JIS eligible). JIS-eligible variants require sequenced component delivery synchronized to the build sequence, impacting supplier logistics contracts and MES call-off trigger configuration.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLineCompatible rdf:type rdf:Property ;
    rdfs:label 'Is Line Compatible' ;
    rdfs:comment 'Indicates whether this production variant has been validated as feasible for assembly on the assigned production line (True = compatible, False = not compatible). Serves as the primary gate flag in MES (Manufacturing Execution System) build sequence feasibility validation and JIS (Just-in-Sequence) call-off authorization.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxConsecutiveBuilds rdf:type rdf:Property ;
    rdfs:label 'Max Consecutive Builds' ;
    rdfs:comment 'Maximum number of consecutive units of this production variant that can be scheduled back-to-back in the build sequence without violating line balancing or ergonomic constraints. Enforced by MES (Manufacturing Execution System) JIS (Just-in-Sequence) sequencing rules to prevent operator fatigue and tooling overload.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mesVariantReference rdf:type rdf:Property ;
    rdfs:label 'Mes Variant Reference' ;
    rdfs:comment 'Cross-reference identifier for this production variant in the Apriso/Dassault MES (Manufacturing Execution System). Used for real-time build sequence call-off, WIP (Work in Progress) tracking, and quality gate routing on the shop floor.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncapSafetyRating rdf:type rdf:Property ;
    rdfs:label 'Ncap Safety Rating' ;
    rdfs:comment 'Overall NCAP (New Car Assessment Programme) safety star rating achieved by this production variant (1 to 5 stars, or NOT_RATED if not yet assessed). Applicable to Euro NCAP, NHTSA NCAP, or ANCAP depending on destination market. Used for regulatory compliance reporting and marketing communications.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paintProcessType rdf:type rdf:Property ;
    rdfs:label 'Paint Process Type' ;
    rdfs:comment 'Classification of the paint application process required for this production variant: STANDARD (solid colour), METALLIC, PEARL, MATTE, or TWO_TONE. Determines paint booth routing, cure cycle parameters, and paint material BOM (Bill of Materials) components in the body shop and paint shop assembly stages.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRegion rdf:type rdf:Property ;
    rdfs:label 'Regulatory Region' ;
    rdfs:comment 'Regulatory compliance region grouping for this production variant, used to apply the correct homologation ruleset: NAFTA (North America), EU (European Union), APAC (Asia-Pacific), LATAM (Latin America), MEA (Middle East & Africa), CHINA. Determines applicable NCAP (New Car Assessment Programme) standards, emissions regulations, and safety certification requirements.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Material Number' ;
    rdfs:comment 'SAP S/4HANA material master number (MM module) corresponding to this production variant\'s configurable material (KMAT). Used for MRP (Material Requirements Planning), production order creation in SAP PP, and cost object controlling in SAP CO.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardBuildHours rdf:type rdf:Property ;
    rdfs:label 'Standard Build Hours' ;
    rdfs:comment 'Standard labor hours required to complete the full assembly of this production variant from stamping through final assembly and PDI (Pre-Delivery Inspection). Used for production cost standard setting, workforce planning, and SAP CO (Controlling) cost object calculation.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teamcenterVariantCode rdf:type rdf:Property ;
    rdfs:label 'Teamcenter Variant Code' ;
    rdfs:comment 'Cross-reference identifier for this production variant in Siemens Teamcenter PLM (Product Lifecycle Management) variant configuration module. Enables traceability between the manufacturing master data record and the engineering variant definition in the PLM system of record.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:v2xCapable rdf:type rdf:Property ;
    rdfs:label 'V2x Capable' ;
    rdfs:comment 'Indicates whether this production variant is equipped with V2X (Vehicle-to-Everything) communication hardware (True = V2X capable). Drives telematics module assembly sequencing, spectrum licensing compliance, and connected mobility service activation in Geotab/Bosch IoT platform.' ;
    rdfs:domain ind:ProductionVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variantCode rdf:type rdf:Property ;
    rdfs:label 'Variant Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this production variant within the manufacturing system. Used as the primary business key in MES (Manufacturing Execution System), PLM (Product Lifecycle Management), and SAP PP (Production Planning) for variant identification and cross-system referencing. Sourced from Siemens Teamcenter PLM variant configuration.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantName rdf:type rdf:Property ;
    rdfs:label 'Variant Name' ;
    rdfs:comment 'Human-readable descriptive name of the production variant (e.g., \'F-Series SuperCrew 4x4 BEV Long Range\'). Used in build sequence planning, shop floor documentation, and JIS (Just-in-Sequence) scheduling displays.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantStatus rdf:type rdf:Property ;
    rdfs:label 'Variant Status' ;
    rdfs:comment 'Current lifecycle status of the production variant within the manufacturing master data: ACTIVE (currently buildable), PLANNED (approved for future SOP), INACTIVE (not currently scheduled), DISCONTINUED (past EOP), ON_HOLD (temporarily suspended pending engineering change or regulatory review). Drives MES build feasibility checks.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkOrderId rdf:type rdf:Property ;
    rdfs:label 'Rework Order Id' ;
    rdfs:comment 'Unique surrogate identifier for the rework order record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualReworkHours rdf:type rdf:Property ;
    rdfs:label 'Actual Rework Hours' ;
    rdfs:comment 'Actual labor hours consumed to complete the rework operation, recorded upon order completion in MES or SAP PM. Compared against planned hours for efficiency analysis and cost variance reporting.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assemblyStageCode rdf:type rdf:Property ;
    rdfs:label 'Assembly Stage Code' ;
    rdfs:comment 'Code representing the specific assembly stage or station within the production line where the nonconformance was detected (e.g., body framing, paint primer, trim line, chassis marriage). Supports JIS (Just-in-Sequence) traceability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomComponentNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Component Number' ;
    rdfs:comment 'The BOM (Bill of Materials) component or part number of the specific sub-assembly or component requiring rework. References the engineering BOM managed in Siemens Teamcenter or SAP MM.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCode rdf:type rdf:Property ;
    rdfs:label 'Defect Code' ;
    rdfs:comment 'Standardized defect classification code identifying the type of nonconformance that triggered the rework order. Aligns with the plant defect code catalogue maintained in SAP QM or MES quality module.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectLocationCode rdf:type rdf:Property ;
    rdfs:label 'Defect Location Code' ;
    rdfs:comment 'Standardized code identifying the physical location or zone on the vehicle or sub-assembly where the defect was found (e.g., body zone, paint zone, chassis area). Used for spatial defect analysis and NVH (Noise Vibration Harshness) correlation.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethodCode rdf:type rdf:Property ;
    rdfs:label 'Detection Method Code' ;
    rdfs:comment 'Code indicating the method by which the defect was detected prior to rework order creation (e.g., visual inspection, automated gauge check, functional test, quality audit, customer feedback). Supports FMEA (Failure Mode and Effects Analysis) detection ranking analysis.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Date and time when the nonconformance was originally detected during in-process quality inspection, triggering the creation of this rework order. The principal business event timestamp for this transaction.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'Final disposition decision for the nonconforming unit after rework evaluation. Repaired indicates successful correction; scrapped indicates the unit is unrecoverable; concession (use-as-is) indicates acceptance of the nonconformance with documented deviation; return to supplier applies to purchased components.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPointCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Point Code' ;
    rdfs:comment 'Code identifying the specific quality inspection checkpoint or gate (e.g., body-in-white audit, paint final audit, end-of-line check) at which the defect was detected and the rework order was initiated.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatoryHold rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Hold' ;
    rdfs:comment 'Indicates whether the vehicle or sub-assembly is placed on a regulatory hold pending rework completion and re-inspection. A regulatory hold prevents the unit from advancing to the next production stage or shipping.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineStoppageFlag rdf:type rdf:Property ;
    rdfs:label 'Line Stoppage Flag' ;
    rdfs:comment 'Indicates whether this rework event caused a production line stoppage (Andon pull or line stop). Used for OEE (Overall Equipment Effectiveness) impact analysis and production downtime reporting.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedReworkHours rdf:type rdf:Property ;
    rdfs:label 'Planned Rework Hours' ;
    rdfs:comment 'Estimated labor hours planned to complete the rework operation, as defined in the rework routing or standard repair time (SRT) catalogue. Used for capacity planning and cost estimation.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Re Inspection Required' ;
    rdfs:comment 'Indicates whether a formal re-inspection is required after rework completion before the unit can be released to the next production stage or shipped. Mandatory for safety-related or regulatory nonconformances.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Re Inspection Result' ;
    rdfs:comment 'Outcome of the quality re-inspection performed after rework completion. Pass indicates the unit meets specification; fail triggers a secondary rework or scrap decision; conditional pass indicates acceptance with documented deviation.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkAttemptCount rdf:type rdf:Property ;
    rdfs:label 'Rework Attempt Count' ;
    rdfs:comment 'Number of rework attempts made on this unit or component for the same defect. Multiple rework attempts on the same unit indicate a chronic quality issue and may trigger escalation or scrap decision per quality policy.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reworkInstructionReference rdf:type rdf:Property ;
    rdfs:label 'Rework Instruction Reference' ;
    rdfs:comment 'Document number or reference to the approved rework instruction, repair standard, or Technical Service Bulletin (TSB) that governs the rework procedure. Ensures traceability to authorized repair methods.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkLaborCost rdf:type rdf:Property ;
    rdfs:label 'Rework Labor Cost' ;
    rdfs:comment 'Total internal labor cost incurred for the rework operation, calculated from actual rework hours and the applicable labor rate. Expressed in the plant\'s operating currency. Used for quality cost (Cost of Poor Quality - COPQ) reporting.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reworkMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Rework Material Cost' ;
    rdfs:comment 'Cost of replacement parts and materials consumed during the rework operation. Sourced from SAP MM goods issue postings against the rework order. Contributes to total Cost of Poor Quality (COPQ) calculation.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reworkOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Rework Order Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the rework order, typically generated by the MES (Manufacturing Execution System) or SAP QM module. Format: RWK-{PlantCode}-{Year}-{Sequence}.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Rework Order Status' ;
    rdfs:comment 'Current lifecycle status of the rework order within the shop floor execution workflow. Tracks progression from creation through completion or cancellation as managed in MES or SAP QM.' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkType rdf:type rdf:Property ;
    rdfs:label 'Rework Type' ;
    rdfs:comment 'Classification of the rework operation method. Inline repair is performed on the moving assembly line; offline rework removes the unit from the line; teardown involves partial or full disassembly; subassembly rework targets a component before vehicle integration; cosmetic repair addresses surface or finish defects. [ENUM-REF-CANDIDATE: inline_repair|offline_rework|teardown|subassembly_rework|cosmetic_repair|field_return_rework — promote to reference product]' ;
    rdfs:domain ind:ReworkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapRecordId rdf:type rdf:Property ;
    rdfs:label 'Scrap Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each scrap record transaction in the manufacturing domain. Primary key for the scrap_record data product.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Authorizing Employee Id' ;
    rdfs:comment 'Reference to the supervisor or quality engineer who authorized the scrap disposition. Required for IATF 16949 nonconforming output control and SAP CO posting authorization.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:co2ImpactKg rdf:type rdf:Property ;
    rdfs:label 'Co2 Impact Kg' ;
    rdfs:comment 'Estimated CO2 equivalent emissions impact in kilograms associated with the scrapped material, based on the material\'s embodied carbon factor. Used for environmental sustainability reporting and EPA/ISO 14001 carbon footprint tracking.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalMethodCode rdf:type rdf:Property ;
    rdfs:label 'Disposal Method Code' ;
    rdfs:comment 'Code indicating how the scrapped material is to be or was physically disposed of. RECYCLE = sent to recycling; LANDFILL = disposed to landfill; REWORK = redirected to rework process; RETURN_SUPPLIER = returned to supplier; INCINERATE = incinerated; RESALE = sold as scrap metal or secondary material.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalReference rdf:type rdf:Property ;
    rdfs:label 'Disposal Reference' ;
    rdfs:comment 'Reference number for the disposal authorization document, waste manifest, or environmental permit associated with the scrapped material disposal. Required for EPA and ISO 14001 environmental compliance documentation.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isWarrantyRelevant rdf:type rdf:Property ;
    rdfs:label 'Is Warranty Relevant' ;
    rdfs:comment 'Indicates whether the scrap event is relevant to warranty analysis, i.e., the defect type matches known warranty failure modes. True = relevant; used to correlate manufacturing scrap patterns with field warranty claims.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppmContribution rdf:type rdf:Property ;
    rdfs:label 'Ppm Contribution' ;
    rdfs:comment 'The PPM (Parts Per Million) defect rate contribution of this individual scrap event, calculated as (scrap_quantity / total production quantity) × 1,000,000. Used as a raw input for PPM defect rate KPI reporting to management and customers.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salvageValue rdf:type rdf:Property ;
    rdfs:label 'Salvage Value' ;
    rdfs:comment 'The recoverable monetary value from the scrapped material after disposal (e.g., scrap metal resale, recycled material value). Net scrap cost = scrap_value minus salvage_value. Used in SAP CO variance reporting.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapMovementType rdf:type rdf:Property ;
    rdfs:label 'Sap Movement Type' ;
    rdfs:comment 'SAP MM goods movement type used to post the scrap transaction. 551 = Scrapping from unrestricted stock; 552 = Reversal of scrapping; 553 = Scrapping from quality inspection stock; 554 = Reversal of scrapping from QI stock. Critical for SAP CO variance posting reconciliation.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPostingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Posting Document Number' ;
    rdfs:comment 'The SAP FI/CO accounting document number generated when the scrap value was posted to the production variance account. Null if not yet financially posted. Used for financial audit trail and period-end closing reconciliation.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapCategory rdf:type rdf:Property ;
    rdfs:label 'Scrap Category' ;
    rdfs:comment 'High-level classification of the scrap event origin for management reporting and corrective action routing. \'process\' = manufacturing process failure; \'material\' = incoming material defect; \'design\' = engineering design issue; \'tooling\' = tooling or fixture failure; \'supplier\' = supplier-caused defect; \'operator_error\' = human error.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Scrap Document Number' ;
    rdfs:comment 'Externally visible, human-readable document number assigned to this scrap transaction, typically generated by SAP MM/PP goods movement (movement type 551/552). Used for audit trail and cross-system reconciliation.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Scrap Reason Description' ;
    rdfs:comment 'Free-text narrative description of the scrap reason, providing additional context beyond the reason code. Entered by the operator or quality technician at the time of scrap recording in MES.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapStatus rdf:type rdf:Property ;
    rdfs:label 'Scrap Status' ;
    rdfs:comment 'Current lifecycle status of the scrap record. \'pending\' = awaiting supervisor confirmation; \'confirmed\' = approved and posted to SAP CO; \'disposed\' = material physically removed; \'reversed\' = scrap posting reversed; \'under_review\' = flagged for quality investigation.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrapTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scrap Timestamp' ;
    rdfs:comment 'The precise date and time when the scrap event was recorded on the shop floor via MES (Manufacturing Execution System). This is the principal business event timestamp, distinct from record audit timestamps.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scrapValue rdf:type rdf:Property ;
    rdfs:label 'Scrap Value' ;
    rdfs:comment 'The gross standard cost value of the scrapped material or component, calculated as scrap quantity multiplied by the SAP standard cost rate. Posted to SAP CO production variance account. Used for financial reporting of manufacturing losses.' ;
    rdfs:domain ind:ScrapRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:factoryCalendarId rdf:type rdf:Property ;
    rdfs:label 'Factory Calendar Id' ;
    rdfs:comment 'SAP factory calendar identifier governing public holidays and non-working days applicable to this shift definition (e.g., US01, DE01). Ensures production scheduling excludes statutory holidays.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FactoryCalendar .

ind:agvActive rdf:type rdf:Property ;
    rdfs:label 'Agv Active' ;
    rdfs:comment 'Indicates whether Automated Guided Vehicle (AGV) operations are active during this shift. Used for shop floor automation scheduling and safety protocol management in MES and SCADA integrations.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'Total scheduled break time in minutes for the shift (e.g., 30 minutes for a single meal break, 50 minutes for two breaks). Used to reconcile gross shift hours against planned production hours.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breakSchedule rdf:type rdf:Property ;
    rdfs:label 'Break Schedule' ;
    rdfs:comment 'Textual description of the break schedule for the shift, including break times and durations (e.g., \'10:00–10:15 AM rest break; 12:30–13:00 PM meal break\'). Supports workforce planning and ergonomic compliance documentation.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dayOfWeekMask rdf:type rdf:Property ;
    rdfs:label 'Day Of Week Mask' ;
    rdfs:comment 'Seven-character binary string (Mon–Sun) indicating which days of the week this shift runs (e.g., \'1111100\' = Monday to Friday, \'0000011\' = Saturday and Sunday). Used by MES and SAP PP for automated shift calendar generation.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyConsumptionTargetKwh rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Target Kwh' ;
    rdfs:comment 'Planned energy consumption target in kilowatt-hours for the shift. Used for energy efficiency monitoring, ISO 14001 environmental reporting, and CAFE/EPA compliance cost tracking.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossShiftHours rdf:type rdf:Property ;
    rdfs:label 'Gross Shift Hours' ;
    rdfs:comment 'Total clock hours from shift start to shift end including all breaks and non-production time (e.g., 8.0 hours). Used to distinguish gross capacity from net available production time.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handoverDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Handover Duration Minutes' ;
    rdfs:comment 'Planned duration in minutes allocated for shift handover activities between outgoing and incoming crews (e.g., 15 minutes). Included in shift scheduling to ensure continuity of production and quality checks.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isTemplate rdf:type rdf:Property ;
    rdfs:label 'Is Template' ;
    rdfs:comment 'Indicates whether this shift record is a reusable template definition (True) rather than a plant/line-specific instantiation (False). Templates are used to standardise shift configurations across multiple plants and lines.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mesShiftCode rdf:type rdf:Property ;
    rdfs:label 'Mes Shift Code' ;
    rdfs:comment 'Native shift identifier in the Apriso/Dassault MES system used for shop floor execution and traceability. Enables cross-system reconciliation between the lakehouse silver layer and the MES source of record.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfBreaks rdf:type rdf:Property ;
    rdfs:label 'Number Of Breaks' ;
    rdfs:comment 'Count of distinct scheduled break periods within the shift (e.g., 2 for a morning rest break and a meal break). Used in ergonomic compliance reporting and workforce scheduling.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oeeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Oee Target Percent' ;
    rdfs:comment 'Target OEE percentage for this shift, representing the combined availability, performance, and quality targets (e.g., 85.00%). Used as the benchmark for shift-level OEE reporting and continuous improvement initiatives.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patternCode rdf:type rdf:Property ;
    rdfs:label 'Pattern Code' ;
    rdfs:comment 'Code referencing the rotating shift pattern or schedule template to which this shift belongs (e.g., 3SHIFT_ROTATING, 2SHIFT_FIXED, CONTINENTAL). Used for workforce rostering and long-term capacity planning.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndTime rdf:type rdf:Property ;
    rdfs:label 'Planned End Time' ;
    rdfs:comment 'Planned clock time at which the shift ends production activities. Combined with planned_start_time to derive gross shift duration for capacity and OEE calculations.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedProductionHours rdf:type rdf:Property ;
    rdfs:label 'Planned Production Hours' ;
    rdfs:comment 'Net planned production hours for the shift after deducting all scheduled breaks and non-production time (e.g., 7.5 hours for an 8-hour shift with 30-minute break). Core input for OEE denominator and capacity planning in SAP PP.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedStartTime rdf:type rdf:Property ;
    rdfs:label 'Planned Start Time' ;
    rdfs:comment 'Planned clock time at which the shift begins production activities (e.g., 2024-01-15T06:00:00.000+00:00). Used for production order scheduling, JIS sequencing, and workforce rostering.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:premiumPayRate rdf:type rdf:Property ;
    rdfs:label 'Premium Pay Rate' ;
    rdfs:comment 'Pay rate multiplier applied to base wages for this shift (e.g., 1.5000 for time-and-a-half overtime, 1.2500 for night shift differential). Used in payroll cost calculations and labour cost reporting. Classified confidential as it contains compensation data.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionModel rdf:type rdf:Property ;
    rdfs:label 'Production Model' ;
    rdfs:comment 'Shift operating model classification indicating the overall production schedule structure at the plant (e.g., single_shift, two_shift, three_shift, four_shift_continental). Drives capacity planning and workforce rostering strategy.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapShiftCode rdf:type rdf:Property ;
    rdfs:label 'Sap Shift Code' ;
    rdfs:comment 'Shift identifier as defined in SAP S/4HANA PP module (Schicht). Used for production order scheduling, capacity planning, and cross-system reconciliation with the ERP source of record.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaZoneCode rdf:type rdf:Property ;
    rdfs:label 'Scada Zone Code' ;
    rdfs:comment 'Code identifying the SCADA monitoring zone associated with this shift definition. Used to correlate shift-level production data with real-time SCADA telemetry for process control and quality monitoring.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDescription rdf:type rdf:Property ;
    rdfs:label 'Shift Description' ;
    rdfs:comment 'Free-text description providing additional context about the shift definition, including special operating conditions, seasonal variations, or programme-specific notes (e.g., \'Reduced capacity shift during model year changeover\').' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftName rdf:type rdf:Property ;
    rdfs:label 'Shift Name' ;
    rdfs:comment 'Human-readable name of the shift (e.g., Day Shift, Afternoon Shift, Night Shift, Weekend Shift). Used in production scheduling dashboards, workforce planning reports, and OEE calculations.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftStatus rdf:type rdf:Property ;
    rdfs:label 'Shift Status' ;
    rdfs:comment 'Current lifecycle status of the shift definition. Active shifts are available for production order scheduling; inactive or suspended shifts are excluded from planning runs.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorRoleCode rdf:type rdf:Property ;
    rdfs:label 'Supervisor Role Code' ;
    rdfs:comment 'Code identifying the required supervisor role classification for this shift (e.g., PROD_SUPV, AREA_LEAD). Used for workforce planning and shift handover accountability. References the HR role catalogue in SuccessFactors.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTaktTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Target Takt Time Seconds' ;
    rdfs:comment 'Planned takt time in seconds per unit for this shift, calculated as net available production time divided by customer demand rate. Fundamental metric for line balancing and JIS sequencing in automotive assembly.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetUnitsPerShift rdf:type rdf:Property ;
    rdfs:label 'Target Units Per Shift' ;
    rdfs:comment 'Planned number of vehicle units (or assemblies) to be produced during this shift. Used as the production target for OEE performance ratio calculation and daily production reporting.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timezoneCode rdf:type rdf:Property ;
    rdfs:label 'Timezone Code' ;
    rdfs:comment 'IANA timezone identifier for the plant location where this shift operates (e.g., America/Detroit, Europe/Berlin). Ensures accurate timestamp interpretation for global multi-plant production scheduling and reporting.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workforceHeadcountTarget rdf:type rdf:Property ;
    rdfs:label 'Workforce Headcount Target' ;
    rdfs:comment 'Planned number of direct production workers required for this shift. Used for workforce planning, labour cost budgeting, and integration with SuccessFactors workforce scheduling.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shopFloorEventId rdf:type rdf:Property ;
    rdfs:label 'Shop Floor Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each shop floor event record generated by MES, PLC, or SCADA systems during production operations.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assemblyArea rdf:type rdf:Property ;
    rdfs:label 'Assembly Area' ;
    rdfs:comment 'Major manufacturing area where the event occurred. Supports area-level OEE reporting and quality gate management across stamping, body shop, paint, and final assembly. [ENUM-REF-CANDIDATE: stamping|body_shop|paint_shop|final_assembly|powertrain|chassis|trim — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCategory rdf:type rdf:Property ;
    rdfs:label 'Event Category' ;
    rdfs:comment 'High-level grouping of the event type for reporting and analytics. Enables aggregated OEE loss categorization (availability, performance, quality) and safety incident tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Event Duration Seconds' ;
    rdfs:comment 'Duration of the shop floor event in seconds (e.g., station cycle time, weld duration, paint cure time). Principal quantitative measurement for cycle time analysis and OEE performance rate calculation.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventPayload rdf:type rdf:Property ;
    rdfs:label 'Event Payload' ;
    rdfs:comment 'Structured JSON string containing the full event-specific payload from the MES, PLC, or SCADA system. Stores additional context-specific parameters not captured in dedicated columns (e.g., weld schedule parameters, paint recipe ID, torque angle). Stored as STRING to comply with Silver layer no-complex-type constraint.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Event Source System' ;
    rdfs:comment 'Identifies the originating control system that generated this event (MES, PLC, SCADA, AGV controller, or manual entry). Critical for data lineage and root-cause analysis. [ENUM-REF-CANDIDATE: MES|PLC|SCADA|AGV|TPMS|OBD|MANUAL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRework rdf:type rdf:Property ;
    rdfs:label 'Is Rework' ;
    rdfs:comment 'Indicates whether this event is associated with a rework operation (True) rather than a first-pass production operation (False). Used to calculate first-time quality (FTQ) and rework cost metrics.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWithinSpec rdf:type rdf:Property ;
    rdfs:label 'Is Within Spec' ;
    rdfs:comment 'Indicates whether the measured value falls within the defined process control limits (True) or represents an out-of-specification condition (False). Drives automatic quality hold triggers and PPM (Parts Per Million) defect rate calculation.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measuredValueUnit rdf:type rdf:Property ;
    rdfs:label 'Measured Value Unit' ;
    rdfs:comment 'Engineering unit of measure for the measured_value field (e.g., Nm for torque, A for weld current, µm for paint film thickness). Ensures dimensional correctness in SPC and quality analysis. [ENUM-REF-CANDIDATE: Nm|A|V|bar|°C|µm|mm|kg|kN|rpm|% — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesEventNumber rdf:type rdf:Property ;
    rdfs:label 'Mes Event Number' ;
    rdfs:comment 'Externally-known unique event reference number assigned by the Apriso/Dassault MES system. Used for cross-system traceability and audit correlation.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeLossCategory rdf:type rdf:Property ;
    rdfs:label 'Oee Loss Category' ;
    rdfs:comment 'Classifies this event\'s contribution to OEE (Overall Equipment Effectiveness) loss: availability loss (unplanned downtime), performance loss (speed reduction), quality loss (defects/rework), or no_loss (normal production). Enables direct OEE waterfall analysis per ISO 22400.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCycleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Planned Cycle Time Seconds' ;
    rdfs:comment 'Standard planned cycle time in seconds for this process step as defined in the SAP PP routing. Compared against event_duration_seconds to calculate performance rate for OEE.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processStepCode rdf:type rdf:Property ;
    rdfs:label 'Process Step Code' ;
    rdfs:comment 'Code identifying the specific manufacturing process step (e.g., STAMP-001, BODY-WELD-045, PAINT-CURE-010, ASSY-TORQUE-120) within the routing. Aligns with SAP PP routing operations.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programNumber rdf:type rdf:Property ;
    rdfs:label 'Program Number' ;
    rdfs:comment 'Version-controlled program number loaded on the PLC or robot controller at the time of this event. Critical for traceability of process parameter changes and engineering change management.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityResult rdf:type rdf:Property ;
    rdfs:label 'Quality Result' ;
    rdfs:comment 'Outcome of the quality check associated with this event. Determines whether the vehicle unit proceeds to the next station, requires rework, or is scrapped. Feeds into IATF 16949 quality records and PPM reporting.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkAttemptNumber rdf:type rdf:Property ;
    rdfs:label 'Rework Attempt Number' ;
    rdfs:comment 'Sequential count of rework attempts for this vehicle unit at this station. A value greater than 1 indicates repeated failures and triggers escalation per IATF 16949 nonconforming product procedures.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scrapCode rdf:type rdf:Property ;
    rdfs:label 'Scrap Code' ;
    rdfs:comment 'Coded reason for scrapping a component or vehicle unit at this event. Populated only when quality_result is \'scrap\'. Feeds into SAP CO scrap cost reporting and IATF 16949 quality records.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationCode rdf:type rdf:Property ;
    rdfs:label 'Station Code' ;
    rdfs:comment 'Unique code of the specific work station or assembly point within the production line where the event was triggered. Enables station-level cycle time and downtime analysis.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationName rdf:type rdf:Property ;
    rdfs:label 'Station Name' ;
    rdfs:comment 'Human-readable descriptive name of the work station (e.g., \'Underbody Weld Station 3\', \'E-Coat Oven Exit\', \'Engine Dress Final\'). Used in operator dashboards and quality reports.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vinNumber rdf:type rdf:Property ;
    rdfs:label 'Vin Number' ;
    rdfs:comment '17-character Vehicle Identification Number of the vehicle unit being processed. Denormalized here for direct event-level traceability without requiring a join. Conforms to ISO 3779 and NHTSA 49 CFR Part 565.' ;
    rdfs:domain ind:ShopFloorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorTeamId rdf:type rdf:Property ;
    rdfs:label 'Operator Team Id' ;
    rdfs:comment 'Reference to the operator team or crew responsible for executing this vehicle build. Used for workforce productivity and quality traceability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OperatorTeam .

ind:ownerPartyId rdf:type rdf:Property ;
    rdfs:label 'Owner Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Warranty registration and post-sale service depend on linking each built vehicle to its owning party; essential for service history and recall notifications.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:assemblyLineCode rdf:type rdf:Property ;
    rdfs:label 'Assembly Line Code' ;
    rdfs:comment 'Identifier for the specific production/assembly line within the plant on which this vehicle was built (e.g., LINE-A1, TRIM-LINE-3). Used for line-level throughput analysis, bottleneck identification, and SCADA/PLC integration.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batterySerialNumber rdf:type rdf:Property ;
    rdfs:label 'Battery Serial Number' ;
    rdfs:comment 'The unique serial number of the high-voltage traction battery pack installed in this vehicle (applicable to HEV, PHEV, BEV). Null for ICE vehicles. Critical for EV battery genealogy, warranty, and end-of-life regulatory compliance.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyShopEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Body Shop End Timestamp' ;
    rdfs:comment 'Actual timestamp when the body shop stage was completed and the body-in-white was released to the paint shop. Null if stage not yet completed.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bodyShopStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Body Shop Start Timestamp' ;
    rdfs:comment 'Actual timestamp when the vehicle body-in-white (BIW) entered the body shop for welding and assembly. Key milestone for build genealogy and stage cycle time tracking.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:buildEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Build End Timestamp' ;
    rdfs:comment 'Actual date and time when the vehicle build was completed at the final assembly stage and signed off for PDI (Pre-Delivery Inspection). Null if the build is still in progress. Used for cycle time, throughput, and SOP/EOP milestone tracking.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:buildSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Build Sequence Number' ;
    rdfs:comment 'The Just-in-Sequence (JIS) production sequence number assigned to this vehicle on the assembly line. Determines the order in which vehicles are built and parts are delivered to the line. Critical for JIS/JIT supply chain synchronization.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buildStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Build Start Timestamp' ;
    rdfs:comment 'Actual date and time when the vehicle build process commenced at the first production stage (typically body-in-white or stamping entry). Principal business event timestamp for the build lifecycle. Used for cycle time calculation and OTD (On-Time Delivery) analysis.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:buildStatus rdf:type rdf:Property ;
    rdfs:label 'Build Status' ;
    rdfs:comment 'Current lifecycle status of the vehicle build record. Drives shop floor workflow, MES gating, and production reporting. \'on_hold\' indicates a quality or material hold; \'rework\' indicates a defect requiring corrective action before completion.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chassisEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Chassis End Timestamp' ;
    rdfs:comment 'Actual timestamp when the chassis assembly stage was completed. Null if stage not yet completed.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chassisStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Chassis Start Timestamp' ;
    rdfs:comment 'Actual timestamp when the vehicle entered the chassis assembly stage for powertrain marriage, suspension, and drivetrain installation.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:endOfLineTestResult rdf:type rdf:Property ;
    rdfs:label 'End Of Line Test Result' ;
    rdfs:comment 'Result of the automated end-of-line (EOL) functional test performed on the completed vehicle, covering powertrain, brakes, ADAS, and electrical systems. Distinct from quality_gate_status which covers visual/dimensional inspection.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Engine Serial Number' ;
    rdfs:comment 'The unique serial number of the engine unit installed in this vehicle during chassis assembly. Critical for powertrain genealogy, warranty traceability, and recall management.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalAssemblyEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Final Assembly End Timestamp' ;
    rdfs:comment 'Actual timestamp when the final assembly stage was completed and the vehicle was released for PDI (Pre-Delivery Inspection). Null if stage not yet completed.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:finalAssemblyStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Final Assembly Start Timestamp' ;
    rdfs:comment 'Actual timestamp when the vehicle entered the final assembly stage for fluids, wheels, glass, and end-of-line checks.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdFlag rdf:type rdf:Property ;
    rdfs:label 'Hold Flag' ;
    rdfs:comment 'Indicates whether this vehicle build is currently under a production hold (True = on hold). A hold may be triggered by a quality non-conformance, missing parts, engineering change, or safety concern. Drives MES gating to prevent further assembly until resolved.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:homologationMarket rdf:type rdf:Property ;
    rdfs:label 'Homologation Market' ;
    rdfs:comment 'The target regulatory market for which this vehicle is homologated and built (e.g., USA, DEU, GBR, CHN, AUS). Determines applicable safety, emissions, and labeling standards. Uses ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paintColorCode rdf:type rdf:Property ;
    rdfs:label 'Paint Color Code' ;
    rdfs:comment 'The manufacturer\'s paint color code applied to this vehicle during the paint stage (e.g., G1W – Super White, 040 – Classic White). Used for paint shop scheduling, color sequencing optimization, and customer order matching.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paintEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Paint End Timestamp' ;
    rdfs:comment 'Actual timestamp when the paint stage was completed and the vehicle body was released to the trim/general assembly line. Null if stage not yet completed.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paintStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Paint Start Timestamp' ;
    rdfs:comment 'Actual timestamp when the vehicle body entered the paint shop for priming, painting, and clear-coat application.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityGateStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Gate Status' ;
    rdfs:comment 'Result of the end-of-line quality gate inspection for this vehicle build. \'conditional_pass\' indicates the vehicle passed with minor deviations requiring dealer rectification. Drives release-to-shipping authorization.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkCount rdf:type rdf:Property ;
    rdfs:label 'Rework Count' ;
    rdfs:comment 'Number of rework operations performed on this vehicle build. A count greater than zero indicates quality issues encountered during assembly. Used for PPM (Parts Per Million) defect rate calculation and FMEA analysis.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reworkFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Flag' ;
    rdfs:comment 'Indicates whether this vehicle build has been flagged for rework due to a detected defect or non-conformance (True = rework required). Distinct from hold_flag; a vehicle can be in rework while not on hold.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledBuildDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Build Date' ;
    rdfs:comment 'The planned calendar date on which this vehicle was scheduled to be built per the production plan (MRP/MES schedule). Used to measure schedule adherence and production plan vs. actual variance.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sopFlag rdf:type rdf:Property ;
    rdfs:label 'Sop Flag' ;
    rdfs:comment 'Indicates whether this vehicle build is part of the official Start of Production (SOP) launch batch (True = SOP vehicle). SOP vehicles are subject to enhanced quality scrutiny and PPAP sign-off requirements.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stampingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Stamping End Timestamp' ;
    rdfs:comment 'Actual timestamp when the stamping stage was completed and the body panels were released to the body shop. Null if stage not yet completed.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stampingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Stamping Start Timestamp' ;
    rdfs:comment 'Actual timestamp when the vehicle body panels entered the stamping stage. Used for stage-level cycle time analysis and production flow monitoring.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transmissionSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Transmission Serial Number' ;
    rdfs:comment 'The unique serial number of the transmission unit installed in this vehicle. Used for drivetrain genealogy, warranty claims, and component-level recall traceability.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trimEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Trim End Timestamp' ;
    rdfs:comment 'Actual timestamp when the trim assembly stage was completed. Null if stage not yet completed.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trimStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Trim Start Timestamp' ;
    rdfs:comment 'Actual timestamp when the vehicle entered the trim assembly stage for interior fitting, electrical harness installation, and dashboard assembly.' ;
    rdfs:domain ind:VehicleBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:wipInventoryId rdf:type rdf:Property ;
    rdfs:label 'Wip Inventory Id' ;
    rdfs:comment 'Unique surrogate identifier for each WIP inventory snapshot or movement record on the shop floor. Primary key for this entity.' ;
    rdfs:domain ind:WipInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agvCarrierId rdf:type rdf:Property ;
    rdfs:label 'Agv Carrier Id' ;
    rdfs:comment 'Identifier of the AGV (Automated Guided Vehicle) or carrier skid currently transporting this WIP item on the shop floor. Null when the item is stationary at a work center or buffer zone.' ;
    rdfs:domain ind:WipInventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:qualityInspectionId rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Id' ;
    rdfs:comment 'Reference to the quality inspection lot or inspection record associated with this WIP item when wip_status = \'awaiting_inspection\' or after inspection completion. Links to SAP QM inspection lot.' ;
    rdfs:domain ind:WipInventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inspection .

ind:actualCycleTimeSec rdf:type rdf:Property ;
    rdfs:label 'Actual Cycle Time Sec' ;
    rdfs:comment 'Actual time in seconds taken to complete the current operation on this WIP item, calculated from operation_start_timestamp to operation_end_timestamp. Compared against standard_cycle_time_sec for efficiency analysis.' ;
    rdfs:domain ind:WipInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bufferZoneCode rdf:type rdf:Property ;
    rdfs:label 'Buffer Zone Code' ;
    rdfs:comment 'Code identifying the buffer or staging zone where the WIP item is temporarily held between work centers (e.g., pre-paint buffer, body shop exit buffer, final assembly feeder lane). Supports JIT/JIS material flow management.' ;
    rdfs:domain ind:WipInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResult rdf:type rdf:Property ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Outcome of the most recent quality inspection gate for this WIP item: \'pass\' = conforms to specification; \'fail\' = non-conforming; \'conditional_pass\' = accepted with deviation; \'pending\' = inspection not yet completed.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReworkItem rdf:type rdf:Property ;
    rdfs:label 'Is Rework Item' ;
    rdfs:comment 'Indicates whether this WIP item has been routed to a rework station for corrective operations (True) or is following the standard production flow (False). Used to track rework rates and associated costs.' ;
    rdfs:domain ind:WipInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationEntryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Location Entry Timestamp' ;
    rdfs:comment 'Date and time when the WIP item entered the current work center, buffer zone, or AGV carrier position. Used to calculate dwell time and identify bottlenecks in the production flow.' ;
    rdfs:domain ind:WipInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:locationExitTimestamp rdf:type rdf:Property ;
    rdfs:label 'Location Exit Timestamp' ;
    rdfs:comment 'Date and time when the WIP item exited the current work center, buffer zone, or AGV carrier position. Null if the item has not yet departed. Used with location_entry_timestamp to compute cycle time per station.' ;
    rdfs:domain ind:WipInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operation End Timestamp' ;
    rdfs:comment 'Date and time when the manufacturing operation on this WIP item was completed or closed. Used to calculate actual operation duration and compare against standard cycle time.' ;
    rdfs:domain ind:WipInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operation Start Timestamp' ;
    rdfs:comment 'Date and time when the manufacturing operation on this WIP item was started by the operator or automated system. Represents the principal business event time for this WIP transaction.' ;
    rdfs:domain ind:WipInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sapOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Order Number' ;
    rdfs:comment 'SAP PP production order number (Auftragsnummer) from SAP S/4HANA that corresponds to the production_order_id. Retained as a business-visible identifier for cross-system reconciliation between MES and ERP.' ;
    rdfs:domain ind:WipInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Completion Date' ;
    rdfs:comment 'Planned date by which this WIP item is expected to complete the current operation or exit the current stage, as defined in the production order schedule. Used for OTD (On-Time Delivery) tracking.' ;
    rdfs:domain ind:WipInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'Date and time when this WIP inventory snapshot record was captured. Supports point-in-time WIP visibility and Silver Layer delta processing in the Databricks Lakehouse.' ;
    rdfs:domain ind:WipInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subAssemblyNumber rdf:type rdf:Property ;
    rdfs:label 'Sub Assembly Number' ;
    rdfs:comment 'Unique identifier for a sub-assembly unit (e.g., powertrain module, instrument panel, axle assembly) when the WIP item is not yet associated with a full VIN. Assigned by the MES during component-level traceability.' ;
    rdfs:domain ind:WipInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierDeviationNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Deviation Number' ;
    rdfs:comment 'Reference number for an approved supplier deviation or concession allowing a non-standard component to be used in this WIP item. Issued via PPAP (Production Part Approval Process) deviation process.' ;
    rdfs:domain ind:WipInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Wip Record Number' ;
    rdfs:comment 'Human-readable, externally visible business identifier for this WIP inventory record, generated by the MES (Manufacturing Execution System). Used on shop floor traveler documents and in MES dashboards.' ;
    rdfs:domain ind:WipInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipStatus rdf:type rdf:Property ;
    rdfs:label 'Wip Status' ;
    rdfs:comment 'Current lifecycle status of the WIP item on the shop floor. \'in_process\' = actively being worked on; \'on_hold\' = paused pending resolution; \'awaiting_inspection\' = queued for quality gate; \'scrapped\' = condemned and removed from flow; \'completed\' = operation finished; \'rework\' = returned for corrective operations.' ;
    rdfs:domain ind:WipInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Wip Valuation Amount' ;
    rdfs:comment 'Standard cost valuation of this WIP item in the plant currency, calculated based on the accumulated material and activity costs up to the current production stage. Used for WIP inventory valuation in SAP CO (Controlling) and financial reporting.' ;
    rdfs:domain ind:WipInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Supervisor Employee Id' ;
    rdfs:comment 'Identifier of the production supervisor or team leader responsible for this work center. Used for accountability tracking, escalation routing, and workforce management integration with SuccessFactors.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:availableCapacityHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Hours Per Day' ;
    rdfs:comment 'Total available production hours per day for this work center, accounting for planned shift schedules and scheduled breaks. Used in SAP PP capacity requirements planning (CRP) and MES scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityCategory rdf:type rdf:Property ;
    rdfs:label 'Capacity Category' ;
    rdfs:comment 'Capacity classification of the work center: bottleneck (constraining throughput of the line), standard (normal capacity), buffer (excess capacity used to absorb variation), or flexible (can be redeployed across lines). Critical for Theory of Constraints analysis and production scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Seconds' ;
    rdfs:comment 'Standard cycle time in seconds for this work center to complete one unit of work. Used in production scheduling, capacity calculation, and bottleneck analysis. Represents the designed throughput rate per station.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date on which this work center was or is planned to be permanently decommissioned and removed from production service. Nullable for active stations. Used for asset lifecycle planning and capacity forecasting.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:energyConsumptionKw rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kw' ;
    rdfs:comment 'Rated energy consumption of this work center in kilowatts (kW) under standard operating conditions. Used for energy management, sustainability reporting, and ISO 14001 environmental compliance tracking.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBottleneck rdf:type rdf:Property ;
    rdfs:label 'Is Bottleneck' ;
    rdfs:comment 'Indicates whether this work center has been identified as a production bottleneck constraining overall line throughput. Bottleneck stations receive priority in capacity planning, maintenance scheduling, and continuous improvement initiatives.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date of the most recent calibration or measurement system verification performed on this work center\'s tooling and gauges. Required for IATF 16949 Clause 7.1.5 measurement system compliance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Textual description of the physical location of the work center within the plant (e.g., \'Building A, Bay 3, Row 5\'). Supports maintenance routing, safety inspections, and shop floor navigation.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:machineRatePerHour rdf:type rdf:Property ;
    rdfs:label 'Machine Rate Per Hour' ;
    rdfs:comment 'Standard machine cost rate per hour (in local currency) for this work center, used in production order costing, standard cost calculation, and variance analysis in SAP CO.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceStrategyCode rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy Code' ;
    rdfs:comment 'Maintenance strategy applied to this work center: preventive (scheduled interval-based), predictive (condition-monitoring-based), corrective (repair after failure), or condition_based (triggered by sensor thresholds). Drives SAP PM maintenance planning.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesWorkCenterCode rdf:type rdf:Property ;
    rdfs:label 'Mes Work Center Code' ;
    rdfs:comment 'Native work center identifier in the Apriso/Dassault MES system. Used for cross-system traceability between the lakehouse silver layer and the operational MES for shop floor execution and WIP (Work in Progress) tracking.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due Date' ;
    rdfs:comment 'Scheduled date for the next calibration or measurement system verification at this work center. Triggers maintenance work orders in SAP PM and quality alerts in the MES when approaching or overdue.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfWorkers rdf:type rdf:Property ;
    rdfs:label 'Number Of Workers' ;
    rdfs:comment 'Standard number of direct labor workers assigned to this work center per shift. Used for workforce planning, labor cost allocation, and ergonomic assessment.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overheadRatePercent rdf:type rdf:Property ;
    rdfs:label 'Overhead Rate Percent' ;
    rdfs:comment 'Manufacturing overhead absorption rate as a percentage applied to this work center\'s direct costs for product costing and standard cost calculation in SAP CO.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plcNodeCode rdf:type rdf:Property ;
    rdfs:label 'Plc Node Code' ;
    rdfs:comment 'Identifier of the PLC (Programmable Logic Controller) node associated with this work center in the shop floor control network. Used for real-time production control integration and SCADA data correlation.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processCategory rdf:type rdf:Property ;
    rdfs:label 'Process Category' ;
    rdfs:comment 'Manufacturing process category to which this work center belongs, reflecting the major shop segment (e.g., stamping, body shop, paint, final assembly, powertrain). Used for shop floor segmentation, capacity analysis, and APQP (Advanced Product Quality Planning) alignment. [ENUM-REF-CANDIDATE: stamping|body_shop|paint|final_assembly|powertrain|chassis|trim|quality_inspection|logistics — promote to reference product]' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapWorkCenterCode rdf:type rdf:Property ;
    rdfs:label 'Sap Work Center Code' ;
    rdfs:comment 'Native work center identifier in SAP S/4HANA PP module. Used for cross-system reconciliation between the lakehouse and SAP for production order routing, capacity planning, and cost center allocation.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaNodeCode rdf:type rdf:Property ;
    rdfs:label 'Scada Node Code' ;
    rdfs:comment 'Identifier of the SCADA (Supervisory Control and Data Acquisition) node associated with this work center. Enables real-time monitoring, alarm management, and production data acquisition from the shop floor.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Setup Time Minutes' ;
    rdfs:comment 'Standard setup/changeover time in minutes required to prepare this work center for a new production run or model variant. Used in SAP PP capacity planning and MES work order scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftModelCode rdf:type rdf:Property ;
    rdfs:label 'Shift Model Code' ;
    rdfs:comment 'Code referencing the shift schedule model assigned to this work center (e.g., 1-shift, 2-shift, 3-shift, weekend shift). Determines available production windows for capacity planning and MES scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardValueKey rdf:type rdf:Property ;
    rdfs:label 'Standard Value Key' ;
    rdfs:comment 'SAP PP standard value key (e.g., SAP1, SAP2) defining which standard values (setup, machine, labor, teardown times) are relevant for this work center in routing operations. Governs how production order times are calculated.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teardownTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Teardown Time Minutes' ;
    rdfs:comment 'Standard teardown/cleanup time in minutes required after completing a production run at this work center. Included in total station time calculations for capacity planning.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Work Center Category' ;
    rdfs:comment 'SAP PP work center category classifying the primary resource type: machine (machine-driven capacity), labor (labor-driven capacity), machine_labor (both machine and labor capacity), or external (subcontracted operation). Determines how capacity and costing are calculated in SAP.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Work Center Description' ;
    rdfs:comment 'Detailed textual description of the work center\'s function, scope of operations, and any special capabilities or constraints relevant to production planning and scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Work Center Status' ;
    rdfs:comment 'Current lifecycle status of the work center: active (in production use), inactive (temporarily not in use), under_maintenance (scheduled or unscheduled maintenance), decommissioned (permanently retired), or planned (not yet commissioned). Drives MES scheduling eligibility and capacity planning.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adasFeatureEntitlementId rdf:type rdf:Property ;
    rdfs:label 'Adas Feature Entitlement Id' ;
    rdfs:comment 'System-generated unique identifier for the ADAS feature entitlement record.' ;
    rdfs:domain ind:AdasFeatureEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activation Timestamp' ;
    rdfs:comment 'Date and time when the feature became active on the vehicle.' ;
    rdfs:domain ind:Mobility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adasFeatureEntitlementDescription rdf:type rdf:Property ;
    rdfs:label 'Adas Feature Entitlement Description' ;
    rdfs:comment 'Free-form text describing the entitlement, conditions, or notes.' ;
    rdfs:domain ind:AdasFeatureEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adasFeatureEntitlementStatus rdf:type rdf:Property ;
    rdfs:label 'Adas Feature Entitlement Status' ;
    rdfs:comment 'Current lifecycle state of the entitlement.' ;
    rdfs:domain ind:AdasFeatureEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPlanType rdf:type rdf:Property ;
    rdfs:label 'Data Plan Type' ;
    rdfs:comment 'Category of data plan associated with the entitlement.' ;
    rdfs:domain ind:Mobility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementNumber rdf:type rdf:Property ;
    rdfs:label 'Entitlement Number' ;
    rdfs:comment 'Business identifier for the entitlement, used in contracts and billing.' ;
    rdfs:domain ind:AdasFeatureEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementPrice rdf:type rdf:Property ;
    rdfs:label 'Entitlement Price' ;
    rdfs:comment 'Monetary amount charged for the entitlement (if fee-based).' ;
    rdfs:domain ind:AdasFeatureEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entitlementSource rdf:type rdf:Property ;
    rdfs:label 'Entitlement Source' ;
    rdfs:comment 'Origin of the entitlement: factory-installed, over-the-air activated, or subscription-unlocked.' ;
    rdfs:domain ind:AdasFeatureEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Timestamp' ;
    rdfs:comment 'Date and time when the entitlement expires or is scheduled to deactivate.' ;
    rdfs:domain ind:AdasFeatureEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:featureCode rdf:type rdf:Property ;
    rdfs:label 'Feature Code' ;
    rdfs:comment 'Standardized code representing the ADAS feature in OEM catalogs.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureName rdf:type rdf:Property ;
    rdfs:label 'Feature Name' ;
    rdfs:comment 'Human-readable name of the ADAS or autonomous driving feature (e.g., Adaptive Cruise Control).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureVersion rdf:type rdf:Property ;
    rdfs:label 'Feature Version' ;
    rdfs:comment 'Version or release identifier of the ADAS feature.' ;
    rdfs:domain ind:AdasFeatureEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestriction rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction' ;
    rdfs:comment 'Three-letter ISO country or region code where the entitlement is valid (e.g., USA, CAN).' ;
    rdfs:domain ind:AdasFeatureEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTrial rdf:type rdf:Property ;
    rdfs:label 'Is Trial' ;
    rdfs:comment 'Indicates whether the entitlement is a trial (true) or a full entitlement (false).' ;
    rdfs:domain ind:Mobility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:odometerAtActivation rdf:type rdf:Property ;
    rdfs:label 'Odometer At Activation' ;
    rdfs:comment 'Vehicle odometer reading at the moment of activation.' ;
    rdfs:domain ind:AdasFeatureEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredFirmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Required Firmware Version' ;
    rdfs:comment 'Minimum vehicle firmware version required for the feature to operate.' ;
    rdfs:domain ind:AdasFeatureEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionPlan rdf:type rdf:Property ;
    rdfs:label 'Subscription Plan' ;
    rdfs:comment 'Identifier of the subscription plan that provides the entitlement, if applicable.' ;
    rdfs:domain ind:Mobility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Trial Expiry Timestamp' ;
    rdfs:comment 'Expiration timestamp for trial entitlements.' ;
    rdfs:domain ind:AdasFeatureEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:usageLimit rdf:type rdf:Property ;
    rdfs:label 'Usage Limit' ;
    rdfs:comment 'Maximum number of times the feature can be used or activated under the entitlement.' ;
    rdfs:domain ind:Mobility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:v2xEnabled rdf:type rdf:Property ;
    rdfs:label 'V2x Enabled' ;
    rdfs:comment 'Flag indicating whether Vehicle-to-Everything communication is enabled for the feature.' ;
    rdfs:domain ind:Mobility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:driverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Driver Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Fleet driver assignment report requires linking each vehicle to its current driver employee for compliance and usage tracking.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:fleetMobilityFleetAccountId rdf:type rdf:Property ;
    rdfs:label 'Fleet Mobility Fleet Account Id' ;
    rdfs:comment 'Identifier of the fleet to which the vehicle belongs, if applicable.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MobilityFleetAccount .

ind:softwareVersionId rdf:type rdf:Property ;
    rdfs:label 'Software Version Id' ;
    rdfs:comment 'Foreign key linking to mobility.software_version. Business justification: Storing the software version as a FK enables consistent version management and eliminates duplicated version strings on the vehicle record.' ;
    rdfs:domain ind:Mobility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SoftwareVersion .

ind:vehicleVinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Vin Registry Id' ;
    rdfs:comment 'Foreign key linking to vehicle.vin_registry. Business justification: Required for warranty, recall and OTA management linking each connected vehicle to the official VIN registry record.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VinRegistry .

ind:activationStatus rdf:type rdf:Property ;
    rdfs:label 'Activation Status' ;
    rdfs:comment 'Current lifecycle state of the device activation.' ;
    rdfs:domain ind:Mobility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batteryHealthPercent rdf:type rdf:Property ;
    rdfs:label 'Battery Health Percent' ;
    rdfs:comment 'Estimated health of the battery relative to its original capacity.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batteryStateOfChargePercent rdf:type rdf:Property ;
    rdfs:label 'Battery State Of Charge Percent' ;
    rdfs:comment 'Current state of charge of the vehicle\'s battery expressed as a percentage.' ;
    rdfs:domain ind:Mobility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectivityTier rdf:type rdf:Property ;
    rdfs:label 'Connectivity Tier' ;
    rdfs:comment 'Service tier defining data allowance and priority for the vehicle.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPlan rdf:type rdf:Property ;
    rdfs:label 'Data Plan' ;
    rdfs:comment 'Subscription plan governing cellular data usage.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataUsageLastReset rdf:type rdf:Property ;
    rdfs:label 'Data Usage Last Reset' ;
    rdfs:comment 'Date when the data usage counter was last reset.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deactivationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deactivation Timestamp' ;
    rdfs:comment 'Date and time when the device was deactivated or retired.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:diagnosticStatus rdf:type rdf:Property ;
    rdfs:label 'Diagnostic Status' ;
    rdfs:comment 'Overall health status derived from the latest diagnostic data.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Three-letter ISO country code representing the primary market of the vehicle.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDiagnosticTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Diagnostic Timestamp' ;
    rdfs:comment 'Timestamp of the most recent vehicle diagnostic event.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastErrorCode rdf:type rdf:Property ;
    rdfs:label 'Last Error Code' ;
    rdfs:comment 'Most recent Diagnostic Trouble Code reported by the vehicle.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTpmsUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Tpms Update Timestamp' ;
    rdfs:comment 'Timestamp of the most recent TPMS firmware or configuration update.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastV2xUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last V2x Update Timestamp' ;
    rdfs:comment 'Timestamp of the most recent V2X software update.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mileageKm rdf:type rdf:Property ;
    rdfs:label 'Mileage Km' ;
    rdfs:comment 'Total distance traveled by the vehicle, reported in kilometers.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mileageLastUpdate rdf:type rdf:Property ;
    rdfs:label 'Mileage Last Update' ;
    rdfs:comment 'Timestamp of the most recent mileage reading.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Marketing name of the vehicle model.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otaCapability rdf:type rdf:Property ;
    rdfs:label 'Ota Capability' ;
    rdfs:comment 'Indicates whether the vehicle supports Over-The-Air updates.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date the vehicle was enrolled in the connected mobility program.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current status of the vehicle\'s connectivity service registration.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:simImsi rdf:type rdf:Property ;
    rdfs:label 'Sim Imsi' ;
    rdfs:comment 'International Mobile Subscriber Identity associated with the SIM.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tpmsCapability rdf:type rdf:Property ;
    rdfs:label 'Tpms Capability' ;
    rdfs:comment 'Indicates whether the vehicle is equipped with Tire Pressure Monitoring System telemetry.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:v2xCapability rdf:type rdf:Property ;
    rdfs:label 'V2x Capability' ;
    rdfs:comment 'Indicates whether the vehicle can communicate Vehicle-to-Everything.' ;
    rdfs:domain ind:ConnectedVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evChargingSessionId rdf:type rdf:Property ;
    rdfs:label 'Ev Charging Session Id' ;
    rdfs:comment 'System-generated unique identifier for the EV charging session record.' ;
    rdfs:domain ind:EvChargingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargerId rdf:type rdf:Property ;
    rdfs:label 'Charger Id' ;
    rdfs:comment 'Identifier of the physical charger unit that delivered energy.' ;
    rdfs:domain ind:EvChargingSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EvCharger .

ind:chargerType rdf:type rdf:Property ;
    rdfs:label 'Charger Type' ;
    rdfs:comment 'Technical classification of the charger used for the session.' ;
    rdfs:domain ind:EvChargingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endSocPercent rdf:type rdf:Property ;
    rdfs:label 'End Soc Percent' ;
    rdfs:comment 'Battery state of charge at the end of the session.' ;
    rdfs:domain ind:EvChargingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:energyDeliveredKwh rdf:type rdf:Property ;
    rdfs:label 'Energy Delivered Kwh' ;
    rdfs:comment 'Total electrical energy transferred to the vehicle during the session.' ;
    rdfs:domain ind:EvChargingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedRangeAddedKm rdf:type rdf:Property ;
    rdfs:label 'Estimated Range Added Km' ;
    rdfs:comment 'Estimated additional driving range provided by the energy delivered, based on vehicle model.' ;
    rdfs:domain ind:EvChargingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evChargingSessionStatus rdf:type rdf:Property ;
    rdfs:label 'Ev Charging Session Status' ;
    rdfs:comment 'Current lifecycle status of the charging session.' ;
    rdfs:domain ind:EvChargingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOtaUpdatePerformed rdf:type rdf:Property ;
    rdfs:label 'Is Ota Update Performed' ;
    rdfs:comment 'Indicates whether an over-the-air firmware update was applied during the session.' ;
    rdfs:domain ind:EvChargingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:odometerKmAtEnd rdf:type rdf:Property ;
    rdfs:label 'Odometer Km At End' ;
    rdfs:comment 'Vehicle odometer reading at the end of the session.' ;
    rdfs:domain ind:EvChargingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:odometerKmAtStart rdf:type rdf:Property ;
    rdfs:label 'Odometer Km At Start' ;
    rdfs:comment 'Vehicle odometer reading at the start of the session.' ;
    rdfs:domain ind:EvChargingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peakPowerKw rdf:type rdf:Property ;
    rdfs:label 'Peak Power Kw' ;
    rdfs:comment 'Maximum charging power achieved during the session.' ;
    rdfs:domain ind:EvChargingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sessionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Session Duration Seconds' ;
    rdfs:comment 'Total elapsed time of the charging session.' ;
    rdfs:domain ind:Mobility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionNumber rdf:type rdf:Property ;
    rdfs:label 'Session Number' ;
    rdfs:comment 'External business identifier assigned to the charging session, used for customer reference and invoicing.' ;
    rdfs:domain ind:EvChargingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startSocPercent rdf:type rdf:Property ;
    rdfs:label 'Start Soc Percent' ;
    rdfs:comment 'Battery state of charge at the beginning of the session.' ;
    rdfs:domain ind:EvChargingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stationCity rdf:type rdf:Property ;
    rdfs:label 'Station City' ;
    rdfs:comment 'City where the charging station is located.' ;
    rdfs:domain ind:EvChargingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationCountry rdf:type rdf:Property ;
    rdfs:label 'Station Country' ;
    rdfs:comment 'Three-letter ISO country code of the charging station.' ;
    rdfs:domain ind:EvChargingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationState rdf:type rdf:Property ;
    rdfs:label 'Station State' ;
    rdfs:comment 'State or province of the charging station location.' ;
    rdfs:domain ind:EvChargingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tpmsEnabled rdf:type rdf:Property ;
    rdfs:label 'Tpms Enabled' ;
    rdfs:comment 'Indicates whether Tire Pressure Monitoring System data was available.' ;
    rdfs:domain ind:EvChargingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowedVehicleType rdf:type rdf:Property ;
    rdfs:label 'Allowed Vehicle Type' ;
    rdfs:comment 'Vehicle categories permitted to enter the geofence.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaSqMeters rdf:type rdf:Property ;
    rdfs:label 'Area Sq Meters' ;
    rdfs:comment 'Calculated surface area of the geofence.' ;
    rdfs:domain ind:Geofence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:associatedService rdf:type rdf:Property ;
    rdfs:label 'Associated Service' ;
    rdfs:comment 'Name of the mobility service (e.g., OTA, V2X) that uses this geofence.' ;
    rdfs:domain ind:Geofence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centerLatitude rdf:type rdf:Property ;
    rdfs:label 'Center Latitude' ;
    rdfs:comment 'Latitude of the geofence centre point (used for circular geofences).' ;
    rdfs:domain ind:Geofence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centerLongitude rdf:type rdf:Property ;
    rdfs:label 'Center Longitude' ;
    rdfs:comment 'Longitude of the geofence centre point (used for circular geofences).' ;
    rdfs:domain ind:Geofence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataRetentionDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Days' ;
    rdfs:comment 'Number of days telemetry related to this geofence is retained.' ;
    rdfs:domain ind:Mobility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geofenceCode rdf:type rdf:Property ;
    rdfs:label 'Geofence Code' ;
    rdfs:comment 'Business-visible code used to reference the geofence in external systems.' ;
    rdfs:domain ind:Geofence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geofenceDescription rdf:type rdf:Property ;
    rdfs:label 'Geofence Description' ;
    rdfs:comment 'Detailed description of the geofence purpose and characteristics.' ;
    rdfs:domain ind:Geofence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geofenceName rdf:type rdf:Property ;
    rdfs:label 'Geofence Name' ;
    rdfs:comment 'Human-readable name of the geofence.' ;
    rdfs:domain ind:Geofence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geometryCoordinates rdf:type rdf:Property ;
    rdfs:label 'Geometry Coordinates' ;
    rdfs:comment 'Well-Known Text (WKT) representation of the geofence geometry.' ;
    rdfs:domain ind:Geofence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geometryType rdf:type rdf:Property ;
    rdfs:label 'Geometry Type' ;
    rdfs:comment 'Shape type that defines the geofence geometry.' ;
    rdfs:domain ind:Geofence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Indicates whether this geofence is the default for its purpose.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Audit Timestamp' ;
    rdfs:comment 'Timestamp of the most recent compliance audit for the geofence.' ;
    rdfs:domain ind:Geofence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxSpeedLimitKph rdf:type rdf:Property ;
    rdfs:label 'Max Speed Limit Kph' ;
    rdfs:comment 'Maximum vehicle speed allowed within the geofence.' ;
    rdfs:domain ind:Geofence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minSpeedLimitKph rdf:type rdf:Property ;
    rdfs:label 'Min Speed Limit Kph' ;
    rdfs:comment 'Minimum vehicle speed required within the geofence.' ;
    rdfs:domain ind:Geofence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:odometerLimitKm rdf:type rdf:Property ;
    rdfs:label 'Odometer Limit Km' ;
    rdfs:comment 'Maximum cumulative odometer reading allowed while inside the geofence.' ;
    rdfs:domain ind:Geofence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perimeterMeters rdf:type rdf:Property ;
    rdfs:label 'Perimeter Meters' ;
    rdfs:comment 'Total perimeter length of the geofence boundary.' ;
    rdfs:domain ind:Geofence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Business purpose of the geofence, e.g., fleet zone, ODD, restricted area.' ;
    rdfs:domain ind:Geofence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:radiusMeters rdf:type rdf:Property ;
    rdfs:label 'Radius Meters' ;
    rdfs:comment 'Radius of the geofence when geometry_type is circle.' ;
    rdfs:domain ind:Geofence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geofenceEventId rdf:type rdf:Property ;
    rdfs:label 'Geofence Event Id' ;
    rdfs:comment 'System-generated unique identifier for each geofence event record.' ;
    rdfs:domain ind:GeofenceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dwellDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Dwell Duration Seconds' ;
    rdfs:comment 'Length of time the vehicle remained inside the geofence before exiting; populated for exit events.' ;
    rdfs:domain ind:GeofenceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Current processing state of the event within the data pipeline.' ;
    rdfs:domain ind:GeofenceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speedKph rdf:type rdf:Property ;
    rdfs:label 'Speed Kph' ;
    rdfs:comment 'Speed of the vehicle at the moment of crossing, measured in kilometers per hour.' ;
    rdfs:domain ind:Mobility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggeredAction rdf:type rdf:Property ;
    rdfs:label 'Triggered Action' ;
    rdfs:comment 'Business action automatically initiated by the event, such as sending an alert, activating a service, or notifying fleet management.' ;
    rdfs:domain ind:GeofenceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTierId rdf:type rdf:Property ;
    rdfs:label 'Service Tier Id' ;
    rdfs:comment 'Reference to the pricing tier applicable to the service.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceTier .

ind:dataPrivacyLevel rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Level' ;
    rdfs:comment 'Classifies the privacy level of data collected by the service.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Days' ;
    rdfs:comment 'Number of days the service usage data is retained.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceCompatibility rdf:type rdf:Property ;
