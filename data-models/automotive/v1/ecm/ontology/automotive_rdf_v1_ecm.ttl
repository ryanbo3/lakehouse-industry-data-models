    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mobilityOtaDeploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Mobility Ota Deployment Status' ;
    rdfs:comment 'Current lifecycle status of the OTA deployment.' ;
