    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odometerReadingKm rdf:type rdf:Property ;
    rdfs:label 'Odometer Reading Km' ;
    rdfs:comment 'Vehicle odometer reading at time of remedy in kilometers.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerResponse rdf:type rdf:Property ;
    rdfs:label 'Owner Response' ;
    rdfs:comment 'Owner\'s response to the campaign notification.' ;
    rdfs:domain ind:CampaignVin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsConsumed rdf:type rdf:Property ;
    rdfs:label 'Parts Consumed' ;
    rdfs:comment 'Comma-separated list of part numbers consumed for the remedy.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
