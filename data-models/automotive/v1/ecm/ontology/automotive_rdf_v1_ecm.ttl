    rdfs:comment 'Date when regulatory approval was granted.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remoteDiagnosticsEnabled rdf:type rdf:Property ;
