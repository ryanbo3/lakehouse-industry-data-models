    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level business area the budget pertains to.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Status' ;
    rdfs:comment 'Current lifecycle state of the budget plan.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'GL account to which the budgeted amounts are posted.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isForecast rdf:type rdf:Property ;
    rdfs:label 'Is Forecast' ;
    rdfs:comment 'Indicates whether the plan is a forecast rather than a firm budget.' ;
