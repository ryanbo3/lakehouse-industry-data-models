ind:changeId rdf:type rdf:Property ;
    rdfs:label 'Change Id' ;
    rdfs:comment 'Foreign key linking to engineering.engineering_change. Business justification: Repair orders must reference the engineering change that introduced the fix, enabling field impact tracking and change effectiveness reporting.' ;
    rdfs:domain ind:Automotive ;
