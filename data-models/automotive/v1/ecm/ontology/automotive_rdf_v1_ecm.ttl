    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handoverFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Handover Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the handover fee.' ;
