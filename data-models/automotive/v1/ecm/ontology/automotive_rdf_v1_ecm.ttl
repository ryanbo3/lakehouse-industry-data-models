    rdfs:comment 'Design-specified maximum payload capacity of the rail car, in metric tons.' ;
    rdfs:domain ind:RailCarAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:railCarNumber rdf:type rdf:Property ;
    rdfs:label 'Rail Car Number' ;
    rdfs:comment 'Unique number painted on the rail car (autorack) used for this assignment.' ;
    rdfs:domain ind:RailCarAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:railCarType rdf:type rdf:Property ;
    rdfs:label 'Rail Car Type' ;
    rdfs:comment 'Classification of the rail car based on its design and loading capability.' ;
    rdfs:domain ind:RailCarAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unloadingDate rdf:type rdf:Property ;
    rdfs:label 'Unloading Date' ;
    rdfs:comment 'Scheduled calendar date when the rail car is unloaded at the destination.' ;
    rdfs:domain ind:RailCarAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unloadingStatus rdf:type rdf:Property ;
    rdfs:label 'Unloading Status' ;
    rdfs:comment 'Operational status of the unloading process for this assignment.' ;
    rdfs:domain ind:RailCarAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vinCount rdf:type rdf:Property ;
    rdfs:label 'Vin Count' ;
    rdfs:comment 'Number of vehicles (VINs) loaded onto the rail car.' ;
    rdfs:domain ind:RailCarAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Location' ;
    rdfs:comment 'Geographic location (city) of the destination dealer or yard.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocation rdf:type rdf:Property ;
    rdfs:label 'Origin Location' ;
    rdfs:comment 'Geographic location (city) of the origin plant.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originPlantCode rdf:type rdf:Property ;
    rdfs:label 'Origin Plant Code' ;
    rdfs:comment 'Identifier of the manufacturing plant where the shipment originates.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Date' ;
    rdfs:comment 'Estimated date the shipment should arrive at the destination.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Date' ;
    rdfs:comment 'Scheduled date for shipment departure from the origin plant.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trackingUrl rdf:type rdf:Property ;
    rdfs:label 'Tracking Url' ;
    rdfs:comment 'Web link to real-time shipment tracking information.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentLegId rdf:type rdf:Property ;
    rdfs:label 'Shipment Leg Id' ;
    rdfs:comment 'Unique surrogate key for each shipment leg record.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationFacilityFunctionalLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Functional Location Id' ;
    rdfs:comment 'Identifier of the facility where the leg terminates.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunctionalLocation .

ind:distanceKm rdf:type rdf:Property ;
    rdfs:label 'Distance Km' ;
    rdfs:comment 'Physical distance covered in this leg, measured in kilometers.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legSequence rdf:type rdf:Property ;
    rdfs:label 'Leg Sequence' ;
    rdfs:comment 'Ordinal position of the leg within the multi-modal shipment.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legStatus rdf:type rdf:Property ;
    rdfs:label 'Leg Status' ;
    rdfs:comment 'Current operational status of the leg.' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odometerEnd rdf:type rdf:Property ;
    rdfs:label 'Odometer End' ;
    rdfs:comment 'Vehicle odometer reading at the end of the leg (kilometers).' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:odometerStart rdf:type rdf:Property ;
    rdfs:label 'Odometer Start' ;
    rdfs:comment 'Vehicle odometer reading at the start of the leg (kilometers).' ;
    rdfs:domain ind:ShipmentLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportDamageClaimId rdf:type rdf:Property ;
    rdfs:label 'Transport Damage Claim Id' ;
    rdfs:comment 'System generated unique identifier for each transport damage claim record.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimPartyId rdf:type rdf:Property ;
    rdfs:label 'Claim Party Id' ;
    rdfs:comment 'Foreign key linking to customer.party. Business justification: Damage claims are filed by the vehicle owner; linking claim to the owning party enables claim processing, financial reporting, and warranty tracking.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:actualRepairCost rdf:type rdf:Property ;
    rdfs:label 'Actual Repair Cost' ;
    rdfs:comment 'Final cost incurred to repair the vehicle after claim settlement.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimAdjusterCode rdf:type rdf:Property ;
    rdfs:label 'Claim Adjuster Code' ;
    rdfs:comment 'Unique identifier of the adjuster handling the claim.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimAdjusterContact rdf:type rdf:Property ;
    rdfs:label 'Claim Adjuster Contact' ;
    rdfs:comment 'Phone number of the claim adjuster.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimAdjusterName rdf:type rdf:Property ;
    rdfs:label 'Claim Adjuster Name' ;
    rdfs:comment 'Full name of the claim adjuster.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Claim Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the claim amounts.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Claim Document Url' ;
    rdfs:comment 'Link to supporting documentation (photos, reports).' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimNotes rdf:type rdf:Property ;
    rdfs:label 'Claim Notes' ;
    rdfs:comment 'Additional free-form notes entered by claim handlers.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Policy Number' ;
    rdfs:comment 'Policy number of the insurance covering the transport.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimPpmRate rdf:type rdf:Property ;
    rdfs:label 'Claim Ppm Rate' ;
    rdfs:comment 'Parts-per-million defect rate associated with the carrier for this claim.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimSettlementMethod rdf:type rdf:Property ;
    rdfs:label 'Claim Settlement Method' ;
    rdfs:comment 'Method used to settle the claim with the carrier.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimSettlementReference rdf:type rdf:Property ;
    rdfs:label 'Claim Settlement Reference' ;
    rdfs:comment 'Reference number or code for the settlement transaction.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimSource rdf:type rdf:Property ;
    rdfs:label 'Claim Source' ;
    rdfs:comment 'Origin of the claim submission.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Claim Updated By' ;
    rdfs:comment 'User identifier of the employee who last updated the claim record.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageCategory rdf:type rdf:Property ;
    rdfs:label 'Damage Category' ;
    rdfs:comment 'Classification of damage type for reporting and analytics.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageDescription rdf:type rdf:Property ;
    rdfs:label 'Damage Description' ;
    rdfs:comment 'Narrative description of the damage observed on the vehicle during transport.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageLocation rdf:type rdf:Property ;
    rdfs:label 'Damage Location' ;
    rdfs:comment 'Specific area of the vehicle where damage occurred (e.g., front bumper, left door).' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageSeverity rdf:type rdf:Property ;
    rdfs:label 'Damage Severity' ;
    rdfs:comment 'Severity rating of the damage based on repair impact.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRepairCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Repair Cost' ;
    rdfs:comment 'Initial cost estimate for repairing the reported damage.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Number' ;
    rdfs:comment 'Identifier assigned by the insurer for the related claim.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFraudFlag rdf:type rdf:Property ;
    rdfs:label 'Is Fraud Flag' ;
    rdfs:comment 'Indicates whether the claim is suspected of fraud.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otdImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Otd Impact Flag' ;
    rdfs:comment 'True if the damage caused a missed on-time delivery commitment.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repairEstimateSource rdf:type rdf:Property ;
    rdfs:label 'Repair Estimate Source' ;
    rdfs:comment 'Source of the repair cost estimate.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'Final amount paid to the claimant after claim approval.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Code' ;
    rdfs:comment 'ISO currency code for the settlement amount.' ;
    rdfs:domain ind:TransportDamageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportRateId rdf:type rdf:Property ;
    rdfs:label 'Transport Rate Id' ;
    rdfs:comment 'System-generated unique identifier for the transport rate record.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:logisticsLaneId rdf:type rdf:Property ;
    rdfs:label 'Logistics Lane Id' ;
    rdfs:comment 'Foreign key linking to logistics.lane. Business justification: Rates are also specific to a logistics lane; adding logistics_lane_id links rates to lanes and resolves lane\'s silo.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lane .

ind:accessorialCharges rdf:type rdf:Property ;
    rdfs:label 'Accessorial Charges' ;
    rdfs:comment 'Additional fixed charges (e.g., lift-gate, detention) associated with the lane.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Location Code' ;
    rdfs:comment 'Code of the destination dealer or distribution center.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargePercent rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Percent' ;
    rdfs:comment 'Percentage surcharge applied to the base rate to cover fuel price volatility.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originLocationCode rdf:type rdf:Property ;
    rdfs:label 'Origin Location Code' ;
    rdfs:comment 'Code of the origin plant or warehouse where the shipment starts.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Amount' ;
    rdfs:comment 'Base monetary amount agreed for the lane before surcharges.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCode rdf:type rdf:Property ;
    rdfs:label 'Rate Code' ;
    rdfs:comment 'Business identifier code for the transport rate contract.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Rate Source System' ;
    rdfs:comment 'Source system where the rate originated.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateVersion rdf:type rdf:Property ;
    rdfs:label 'Rate Version' ;
    rdfs:comment 'Incremental version number for the rate record to track revisions.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportRateStatus rdf:type rdf:Property ;
    rdfs:label 'Transport Rate Status' ;
    rdfs:comment 'Current lifecycle status of the rate contract.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCapacityCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Volume Capacity Cubic Meters' ;
    rdfs:comment 'Maximum volume that can be transported under this rate.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Weight Capacity Tons' ;
    rdfs:comment 'Maximum weight that can be transported under this rate.' ;
    rdfs:domain ind:TransportRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUnits rdf:type rdf:Property ;
    rdfs:label 'Capacity Units' ;
    rdfs:comment 'Maximum number of vehicles the compound can store.' ;
    rdfs:domain ind:VehicleCompound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compoundCode rdf:type rdf:Property ;
    rdfs:label 'Compound Code' ;
    rdfs:comment 'Unique business code used to reference the compound in operational systems.' ;
    rdfs:domain ind:VehicleCompound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundType rdf:type rdf:Property ;
    rdfs:label 'Compound Type' ;
    rdfs:comment 'Classification of the compound (e.g., plant yard, port yard, regional distribution center, dealer preparation site).' ;
    rdfs:domain ind:VehicleCompound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentOccupancy rdf:type rdf:Property ;
    rdfs:label 'Current Occupancy' ;
    rdfs:comment 'Current number of vehicles stored in the compound.' ;
    rdfs:domain ind:VehicleCompound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isPdiCapable rdf:type rdf:Property ;
    rdfs:label 'Is Pdi Capable' ;
    rdfs:comment 'Indicates whether the compound can perform Pre-Delivery Inspection (PDI) on vehicles.' ;
    rdfs:domain ind:VehicleCompound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatorName rdf:type rdf:Property ;
    rdfs:label 'Operator Name' ;
    rdfs:comment 'Name of the person or organization responsible for day-to-day operations of the compound.' ;
    rdfs:domain ind:VehicleCompound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otdTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Otd Target Percentage' ;
    rdfs:comment 'Target percentage for on-time delivery performance for shipments originating from this compound.' ;
    rdfs:domain ind:VehicleCompound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Security classification of the compound (low, medium, high).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Storage Area Sqft' ;
    rdfs:comment 'Total floor area of the compound in square feet.' ;
    rdfs:domain ind:VehicleCompound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleCompoundName rdf:type rdf:Property ;
    rdfs:label 'Vehicle Compound Name' ;
    rdfs:comment 'Human-readable name of the storage compound.' ;
    rdfs:domain ind:VehicleCompound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleCompoundStatus rdf:type rdf:Property ;
    rdfs:label 'Vehicle Compound Status' ;
    rdfs:comment 'Current operational status of the compound.' ;
    rdfs:domain ind:VehicleCompound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteHandlingCapability rdf:type rdf:Property ;
    rdfs:label 'Waste Handling Capability' ;
    rdfs:comment 'Indicates whether the compound is equipped to handle hazardous waste.' ;
    rdfs:domain ind:VehicleCompound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehicleHandoverId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Handover Id' ;
    rdfs:comment 'System-generated unique identifier for each vehicle handover record.' ;
    rdfs:domain ind:VehicleHandover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivingPartyId rdf:type rdf:Property ;
    rdfs:label 'Receiving Party Id' ;
    rdfs:comment 'Unique identifier of the receiving party (dealer or customer).' ;
    rdfs:domain ind:VehicleHandover ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:acceptanceSignatureStatus rdf:type rdf:Property ;
    rdfs:label 'Acceptance Signature Status' ;
    rdfs:comment 'Status of the acceptance signature: signed, unsigned, or pending.' ;
