    rdfs:range xsd:string .

ind:reliabilityCategory rdf:type rdf:Property ;
    rdfs:label 'Reliability Category' ;
    rdfs:comment 'Type of maintenance or failure mode that the reliability record reflects.' ;
    rdfs:domain ind:EquipmentReliability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reliabilityCode rdf:type rdf:Property ;
