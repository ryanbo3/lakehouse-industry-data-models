    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetLineId rdf:type rdf:Property ;
    rdfs:label 'Budget Line Id' ;
    rdfs:comment 'Unique system-generated identifier for the budget line record.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetLine .

ind:budgetHeaderBudgetPlanId rdf:type rdf:Property ;
    rdfs:label 'Budget Header Budget Plan Id' ;
    rdfs:comment 'Identifier of the parent budget plan header to which this line belongs.' ;
