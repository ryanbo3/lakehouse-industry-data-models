ind:defectRecordId rdf:type rdf:Property ;
    rdfs:label 'Defect Record Id' ;
    rdfs:comment 'Foreign key linking to quality.defect_record. Business justification: Warranty claim investigation requires linking each claim to the originating quality defect record (Warranty Claim Investigation Report).' ;
    rdfs:domain ind:Automotive ;
