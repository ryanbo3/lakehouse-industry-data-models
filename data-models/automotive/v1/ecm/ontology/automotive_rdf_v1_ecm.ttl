ind:lifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Event Id' ;
    rdfs:comment 'System-generated unique identifier for each vehicle lifecycle event record.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventLocationCity rdf:type rdf:Property ;
    rdfs:label 'Event Location City' ;
    rdfs:comment 'City name where the event was recorded.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Event Location Country' ;
    rdfs:comment 'Three-letter ISO country code where the event took place.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Event Location Latitude' ;
    rdfs:comment 'Geographic latitude of the event location in decimal degrees.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Event Location Longitude' ;
    rdfs:comment 'Geographic longitude of the event location in decimal degrees.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventLocationState rdf:type rdf:Property ;
    rdfs:label 'Event Location State' ;
    rdfs:comment 'State or province abbreviation for the event location, if applicable.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Sequence Number' ;
    rdfs:comment 'Sequential order of events for the same VIN, starting at 1.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventSourceModule rdf:type rdf:Property ;
    rdfs:label 'Event Source Module' ;
    rdfs:comment 'Specific module or component within the source system that emitted the event.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSubtype rdf:type rdf:Property ;
    rdfs:label 'Event Subtype' ;
    rdfs:comment 'More granular classification within the event category.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkDigit rdf:type rdf:Property ;
    rdfs:label 'Check Digit' ;
    rdfs:comment 'The 9th character of the VIN used to validate VIN authenticity through a mathematical algorithm. Required in North American markets. Value is 0-9 or X (representing 10).' ;
    rdfs:domain ind:VinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationMarket rdf:type rdf:Property ;
    rdfs:label 'Destination Market' ;
    rdfs:comment 'The intended sales and distribution market for this vehicle unit. May differ from homologation market for export vehicles. Three-letter ISO 3166-1 alpha-3 country code.' ;
    rdfs:domain ind:VinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelTankCapacityLiters rdf:type rdf:Property ;
    rdfs:label 'Fuel Tank Capacity Liters' ;
    rdfs:comment 'The total volume capacity of the primary fuel tank in liters. For electric vehicles, this represents the battery capacity equivalent or is null.' ;
    rdfs:domain ind:VinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gvwrKg rdf:type rdf:Property ;
    rdfs:label 'Gvwr Kg' ;
    rdfs:comment 'The maximum allowable total weight of the vehicle including chassis, body, engine, fluids, passengers, and cargo, as certified by the manufacturer. Measured in kilograms.' ;
    rdfs:domain ind:VinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Line Off Timestamp' ;
    rdfs:comment 'The precise date and time when the vehicle exited the final assembly line and passed end-of-line quality inspection. Captured from MES.' ;
    rdfs:domain ind:VinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:modelYearDecoded rdf:type rdf:Property ;
    rdfs:label 'Model Year Decoded' ;
    rdfs:comment 'The decoded four-digit calendar year representing the model year (e.g., 2023, 2024). Derived from the 10th VIN character.' ;
    rdfs:domain ind:VinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:obdProtocol rdf:type rdf:Property ;
    rdfs:label 'Obd Protocol' ;
    rdfs:comment 'The diagnostic communication protocol standard implemented in this vehicle\'s Electronic Control Units (ECUs) for emissions and diagnostics monitoring.' ;
    rdfs:domain ind:VinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Production Sequence Number' ;
    rdfs:comment 'Characters 12-17 of the VIN representing the sequential production number assigned to this vehicle unit at the assembly plant. Resets annually per plant.' ;
    rdfs:domain ind:VinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telematicsEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Telematics Enabled Flag' ;
    rdfs:comment 'Indicates whether this vehicle is equipped with connected vehicle telematics hardware and has an active data subscription for remote diagnostics, OTA updates, and mobility services.' ;
    rdfs:domain ind:VinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vds rdf:type rdf:Property ;
    rdfs:label 'Vds' ;
    rdfs:comment 'Characters 4-9 of the VIN that describe vehicle attributes such as model, body style, engine type, and restraint system. Manufacturer-specific encoding.' ;
    rdfs:domain ind:VinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleLifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Vehicle Lifecycle Status' ;
    rdfs:comment 'Current lifecycle stage of this vehicle unit from manufacturing through end-of-life. Tracks the vehicle\'s journey from plant to customer to disposal. [ENUM-REF-CANDIDATE: pre_production|in_production|quality_hold|in_transit|dealer_inventory|retail_sold|in_service|recalled|scrapped|exported|end_of_life — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vis rdf:type rdf:Property ;
    rdfs:label 'Vis' ;
    rdfs:comment 'Characters 10-17 of the VIN that include model year, plant code, and production sequence number. Uniquely identifies this specific vehicle unit.' ;
    rdfs:domain ind:VinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wltpCombinedConsumption rdf:type rdf:Property ;
    rdfs:label 'Wltp Combined Consumption' ;
    rdfs:comment 'The WLTP-certified combined fuel consumption in liters per 100 kilometers. Applicable to vehicles sold in markets requiring WLTP certification (EU, UK, etc.).' ;
    rdfs:domain ind:VinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmi rdf:type rdf:Property ;
    rdfs:label 'Wmi' ;
    rdfs:comment 'The first three characters of the VIN that identify the manufacturer and country of origin. Assigned by SAE International.' ;
    rdfs:domain ind:VinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceRecordId rdf:type rdf:Property ;
    rdfs:label 'Absence Record Id' ;
    rdfs:comment 'Unique identifier for the absence record.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAbsenceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Absence Employee Id' ;
    rdfs:comment 'Identifier of the employee to whom the absence applies.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:absenceCategory rdf:type rdf:Property ;
    rdfs:label 'Absence Category' ;
    rdfs:comment 'Indicates whether the absence is paid or unpaid.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceNumber rdf:type rdf:Property ;
    rdfs:label 'Absence Number' ;
    rdfs:comment 'Human-readable reference number for the absence transaction.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Absence Record Status' ;
    rdfs:comment 'Current lifecycle status of the absence request.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceType rdf:type rdf:Property ;
    rdfs:label 'Absence Type' ;
    rdfs:comment 'Category of the absence (e.g., vacation, sick, FMLA, parental, union, bereavement, other). [ENUM-REF-CANDIDATE: vacation|sick|fmla|parental|union|bereavement|other — promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Total duration of the absence expressed in working days.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total duration of the absence expressed in hours.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicalCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Number' ;
    rdfs:comment 'Reference number of the attached medical certificate document.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Certification Flag' ;
    rdfs:comment 'Indicates whether a medical certificate was provided for the absence.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnToWorkDate rdf:type rdf:Property ;
    rdfs:label 'Return To Work Date' ;
    rdfs:comment 'Scheduled date for the employee to return to work after the absence.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftCoverageRequired rdf:type rdf:Property ;
    rdfs:label 'Shift Coverage Required' ;
    rdfs:comment 'Indicates whether temporary coverage is required for the affected shifts.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shiftImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Shift Impact Flag' ;
    rdfs:comment 'Indicates whether the absence impacts scheduled production shifts.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionLeaveFlag rdf:type rdf:Property ;
    rdfs:label 'Union Leave Flag' ;
    rdfs:comment 'Indicates if the absence is covered under a union agreement.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:benefitEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Benefit Enrollment Id' ;
    rdfs:comment 'System-generated unique identifier for each benefit enrollment record.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
