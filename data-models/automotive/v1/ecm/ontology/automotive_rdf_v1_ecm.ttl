    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posting Timestamp' ;
    rdfs:comment 'Timestamp when the payment was posted to the general ledger.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:remittanceReference rdf:type rdf:Property ;
    rdfs:label 'Remittance Reference' ;
    rdfs:comment 'Reference provided by the payer to reconcile the payment.' ;
