    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Flag' ;
    rdfs:comment 'True if the service was performed under warranty.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aftersalesDtcEventId rdf:type rdf:Property ;
    rdfs:label 'Aftersales Dtc Event Id' ;
    rdfs:comment 'Unique identifier for the DTC event record.' ;
    rdfs:domain ind:AftersalesDtcEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ecuCatalogId rdf:type rdf:Property ;
    rdfs:label 'Ecu Catalog Id' ;
    rdfs:comment 'Identifier of the ECU module that reported the DTC.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EcuCatalog .

ind:ecuSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Ecu Specification Id' ;
    rdfs:comment 'Identifier of the ECU module that reported the DTC.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EcuSpecification .

ind:fmeaId rdf:type rdf:Property ;
    rdfs:label 'Fmea Id' ;
    rdfs:comment 'Foreign key linking to quality.fmea. Business justification: DTC analysis uses FMEA data to identify failure modes (DTC-FMEA Mapping Report).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fmea .

ind:productionOrderId rdf:type rdf:Property ;
    rdfs:label 'Production Order Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.production_order. Business justification: Recall root-cause analysis links DTC events to the specific production order that built the vehicle for batch-level defect tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:ambientTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Ambient Temperature C' ;
    rdfs:comment 'Outside air temperature in degrees Celsius when the DTC was logged.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batteryVoltageV rdf:type rdf:Property ;
    rdfs:label 'Battery Voltage V' ;
    rdfs:comment 'Vehicle battery voltage measured at the event.' ;
