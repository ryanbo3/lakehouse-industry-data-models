    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Result of the command execution on the vehicle.' ;
    rdfs:domain ind:RemoteCommand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiration Timestamp' ;
    rdfs:comment 'Time after which the command is no longer valid if not executed.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Textual description of why the command failed, if execution_status is failed.' ;
    rdfs:domain ind:RemoteCommand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issuance Timestamp' ;
    rdfs:comment 'Date-time when the remote command was created and sent to the vehicle.' ;
    rdfs:domain ind:RemoteCommand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:driverIndividualId rdf:type rdf:Property ;
    rdfs:label 'Driver Individual Id' ;
    rdfs:comment 'Internal identifier of the driver or vehicle owner associated with the session.' ;
    rdfs:domain ind:RemoteDiagnosticSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Individual .

ind:connectivityStatus rdf:type rdf:Property ;
    rdfs:label 'Connectivity Status' ;
    rdfs:comment 'Current network connectivity state of the vehicle during the session.' ;
    rdfs:domain ind:Mobility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataVolumeMb rdf:type rdf:Property ;
    rdfs:label 'Data Volume Mb' ;
    rdfs:comment 'Amount of telemetry and diagnostic data transferred during the session.' ;
    rdfs:domain ind:RemoteDiagnosticSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diagnosticScope rdf:type rdf:Property ;
    rdfs:label 'Diagnostic Scope' ;
    rdfs:comment 'Scope of the remote diagnostic session: full vehicle scan, targeted ECU, or custom set of modules.' ;
    rdfs:domain ind:RemoteDiagnosticSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCodes rdf:type rdf:Property ;
    rdfs:label 'Error Codes' ;
