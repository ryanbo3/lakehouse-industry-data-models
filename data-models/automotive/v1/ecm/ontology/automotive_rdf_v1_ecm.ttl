    rdfs:range ind:BudgetPlan .

ind:budgetPlanId rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Id' ;
    rdfs:comment 'Identifier of the parent budget plan header to which this line belongs.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetPlan .

ind:amountType rdf:type rdf:Property ;
    rdfs:label 'Amount Type' ;
    rdfs:comment 'Indicates whether the amount reflects the original plan, a revision, or a committed figure.' ;
