    rdfs:range xsd:string .

ind:depreciationRunId rdf:type rdf:Property ;
    rdfs:label 'Depreciation Run Id' ;
    rdfs:comment 'System-generated unique identifier for the depreciation run.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:depreciationArea rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area' ;
    rdfs:comment 'Depreciation area indicating the accounting book (e.g., book, tax, IFRS, statutory).' ;
