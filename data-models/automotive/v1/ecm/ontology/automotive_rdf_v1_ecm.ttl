    rdfs:comment 'Human-readable description of the return reason.' ;
    rdfs:domain ind:PartsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Return Source System' ;
    rdfs:comment 'Originating ERP or MES system that created the return record.' ;
    rdfs:domain ind:PartsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnStatus rdf:type rdf:Property ;
    rdfs:label 'Return Status' ;
    rdfs:comment 'Current processing status of the return.' ;
    rdfs:domain ind:Aftersales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnType rdf:type rdf:Property ;
    rdfs:label 'Return Type' ;
    rdfs:comment 'Category of the return based on business rules.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentTrackingNumber rdf:type rdf:Property ;
