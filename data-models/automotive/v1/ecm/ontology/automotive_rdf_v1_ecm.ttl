    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment 'External business code used to reference the service in contracts and catalogs.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDescription rdf:type rdf:Property ;
    rdfs:label 'Service Description' ;
    rdfs:comment 'Detailed textual description of the service offering.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceName rdf:type rdf:Property ;
    rdfs:label 'Service Name' ;
    rdfs:comment 'Human-readable name of the mobility service.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'Current lifecycle state of the service offering.' ;
