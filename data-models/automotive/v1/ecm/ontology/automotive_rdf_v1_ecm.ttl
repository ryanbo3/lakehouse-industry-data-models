    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementContactName rdf:type rdf:Property ;
    rdfs:label 'Procurement Contact Name' ;
    rdfs:comment 'Name of the primary procurement contact for the organization.' ;
    rdfs:domain ind:OrganizationAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementContactPhone rdf:type rdf:Property ;
    rdfs:label 'Procurement Contact Phone' ;
    rdfs:comment 'Phone number of the procurement contact.' ;
    rdfs:domain ind:OrganizationAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sicCode rdf:type rdf:Property ;
    rdfs:label 'Sic Code' ;
    rdfs:comment 'Standard Industrial Classification code for the organization.' ;
    rdfs:domain ind:OrganizationAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Tax identification number for the organization.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of the primary address (e.g., billing, shipping).' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'External credit rating assigned to the party for risk assessment.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerLifetimeValue rdf:type rdf:Property ;
    rdfs:label 'Customer Lifetime Value' ;
    rdfs:comment 'Estimated total net revenue expected from the party over the relationship.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataResidencyRegion rdf:type rdf:Property ;
    rdfs:label 'Data Residency Region' ;
    rdfs:comment 'Geographic region where the party\'s personal data is stored to satisfy data-sovereignty requirements.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'Additional external reference used for cross-system reconciliation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentEmail rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Email' ;
    rdfs:comment 'Indicates whether the party has consented to receive email communications under GDPR.' ;
