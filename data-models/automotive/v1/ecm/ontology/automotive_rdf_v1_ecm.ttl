ind:dtcStatus rdf:type rdf:Property ;
    rdfs:label 'Dtc Status' ;
    rdfs:comment 'Current lifecycle status of the DTC (e.g., pending, confirmed).' ;
    rdfs:domain ind:AftersalesDtcEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionRelatedFlag rdf:type rdf:Property ;
