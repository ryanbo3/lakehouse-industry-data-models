    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionDescription rdf:type rdf:Property ;
    rdfs:label 'Detection Description' ;
    rdfs:comment 'Narrative explanation of the detection rating.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaStatus rdf:type rdf:Property ;
    rdfs:label 'Fmea Status' ;
    rdfs:comment 'Current lifecycle status of the FMEA record.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceDescription rdf:type rdf:Property ;
    rdfs:label 'Occurrence Description' ;
    rdfs:comment 'Narrative explanation of the occurrence rating.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityDescription rdf:type rdf:Property ;
    rdfs:label 'Severity Description' ;
    rdfs:comment 'Narrative explanation of the severity rating.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subsystem rdf:type rdf:Property ;
    rdfs:label 'Subsystem' ;
    rdfs:comment 'Higher-level subsystem or system grouping the component belongs to (e.g., Powertrain, Chassis).' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateResultId rdf:type rdf:Property ;
    rdfs:label 'Gate Result Id' ;
    rdfs:comment 'Unique system-generated identifier for each gate result record.' ;
    rdfs:domain ind:GateResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateId rdf:type rdf:Property ;
    rdfs:label 'Gate Id' ;
    rdfs:comment 'Identifier of the quality gate where the vehicle was inspected.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gate .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Count of distinct defects recorded during the gate inspection.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateLocation rdf:type rdf:Property ;
    rdfs:label 'Gate Location' ;
    rdfs:comment 'Plant or line code where the gate is physically located.' ;
    rdfs:domain ind:GateResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateType rdf:type rdf:Property ;
    rdfs:label 'Gate Type' ;
    rdfs:comment 'Functional classification of the gate (e.g., assembly, paint, final).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResultCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Result Code' ;
    rdfs:comment 'Standardized code representing the detailed outcome of the inspection.' ;
    rdfs:domain ind:GateResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkLoopCount rdf:type rdf:Property ;
    rdfs:label 'Rework Loop Count' ;
    rdfs:comment 'Number of rework cycles the vehicle has undergone prior to this gate.' ;
    rdfs:domain ind:GateResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scanTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scan Timestamp' ;
    rdfs:comment 'Date and time when the vehicle passed the gate and was scanned.' ;
    rdfs:domain ind:GateResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:timeAtGateSeconds rdf:type rdf:Property ;
    rdfs:label 'Time At Gate Seconds' ;
    rdfs:comment 'Duration in seconds that the vehicle spent at the gate for inspection.' ;
    rdfs:domain ind:GateResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:custodianEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Custodian Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Gauge custodianship is assigned to a specific employee; linking enables maintenance responsibility tracking.' ;
    rdfs:domain ind:GaugeMaster ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accuracy rdf:type rdf:Property ;
    rdfs:label 'Accuracy' ;
    rdfs:comment 'Maximum permissible deviation from true value, expressed in the unit of measure.' ;
    rdfs:domain ind:GaugeMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Certificate Number' ;
    rdfs:comment 'Reference number of the most recent calibration certificate issued by the lab.' ;
    rdfs:domain ind:GaugeMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationDueFlag rdf:type rdf:Property ;
    rdfs:label 'Calibration Due Flag' ;
    rdfs:comment 'True when the current date is past the next_calibration_date and the gauge has not been recalibrated.' ;
    rdfs:domain ind:GaugeMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calibrationHistoryAvailable rdf:type rdf:Property ;
    rdfs:label 'Calibration History Available' ;
    rdfs:comment 'True if detailed calibration logs are retained for this gauge.' ;
    rdfs:domain ind:GaugeMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gaugeMasterDescription rdf:type rdf:Property ;
    rdfs:label 'Gauge Master Description' ;
    rdfs:comment 'Detailed description of the gauge, its application and special characteristics.' ;
    rdfs:domain ind:GaugeMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaugeMasterStatus rdf:type rdf:Property ;
    rdfs:label 'Gauge Master Status' ;
    rdfs:comment 'Current lifecycle state of the gauge within the quality system.' ;
    rdfs:domain ind:GaugeMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaugeType rdf:type rdf:Property ;
    rdfs:label 'Gauge Type' ;
    rdfs:comment 'Category of measurement instrument (e.g., Coordinate Measuring Machine, caliper, torque wrench, vision system, laser tracker).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCapability rdf:type rdf:Property ;
    rdfs:label 'Inspection Capability' ;
    rdfs:comment 'Main type of measurement the gauge provides for quality inspections.' ;
    rdfs:domain ind:GaugeMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalGauge rdf:type rdf:Property ;
    rdfs:label 'Is Critical Gauge' ;
    rdfs:comment 'True when the gauge is used for measurements that affect product safety or regulatory compliance.' ;
    rdfs:domain ind:GaugeMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCalibratedBy rdf:type rdf:Property ;
    rdfs:label 'Last Calibrated By' ;
    rdfs:comment 'Identifier of the person or external lab that performed the most recent calibration.' ;
    rdfs:domain ind:GaugeMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line rdf:type rdf:Property ;
    rdfs:label 'Line' ;
    rdfs:comment 'Specific line or cell within the plant that uses the gauge.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Date' ;
    rdfs:comment 'Projected date for the next required calibration based on interval.' ;
    rdfs:domain ind:GaugeMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:station rdf:type rdf:Property ;
    rdfs:label 'Station' ;
    rdfs:comment 'Exact station or work-cell where the gauge is deployed.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tolerance rdf:type rdf:Property ;
    rdfs:label 'Tolerance' ;
    rdfs:comment 'Acceptable deviation range for measurements taken with the gauge.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gaugeMsaId rdf:type rdf:Property ;
    rdfs:label 'Gauge Msa Id' ;
    rdfs:comment 'Unique surrogate key for the gauge MSA record.' ;
    rdfs:domain ind:GaugeMsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Acceptability Status' ;
    rdfs:comment 'Result classification based on %GRR thresholds: acceptable (<10%), marginal (10-30%), unacceptable (>30%).' ;
    rdfs:domain ind:GaugeMsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaugeMsaStatus rdf:type rdf:Property ;
    rdfs:label 'Gauge Msa Status' ;
    rdfs:comment 'Current lifecycle status of the gauge MSA record.' ;
    rdfs:domain ind:GaugeMsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaugeName rdf:type rdf:Property ;
    rdfs:label 'Gauge Name' ;
    rdfs:comment 'Human-readable name or label of the gauge.' ;
    rdfs:domain ind:GaugeMsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grrPercent rdf:type rdf:Property ;
    rdfs:label 'Grr Percent' ;
    rdfs:comment 'Overall %GRR result from the study.' ;
    rdfs:domain ind:GaugeMsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ndc rdf:type rdf:Property ;
    rdfs:label 'Ndc' ;
    rdfs:comment 'Count of distinct measurement categories (e.g., size bins) used in the study.' ;
    rdfs:domain ind:GaugeMsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatorCount rdf:type rdf:Property ;
    rdfs:label 'Operator Count' ;
    rdfs:comment 'Count of distinct operators who performed measurements in the study.' ;
    rdfs:domain ind:GaugeMsa ;
    rdf:type owl:DatatypeProperty ;
