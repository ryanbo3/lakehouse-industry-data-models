    rdfs:range xsd:string .

ind:overstockFlag rdf:type rdf:Property ;
    rdfs:label 'Overstock Flag' ;
    rdfs:comment 'True when the return is due to dealer overstock.' ;
    rdfs:domain ind:PartsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partCondition rdf:type rdf:Property ;
    rdfs:label 'Part Condition' ;
    rdfs:comment 'Condition of the part at the time of return.' ;
    rdfs:domain ind:PartsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityReturned rdf:type rdf:Property ;
