ind:triggeringEventCode rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Code' ;
    rdfs:comment 'Code of the event that initiated the session (e.g., DTC code).' ;
    rdfs:domain ind:RemoteDiagnosticSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tsbReferences rdf:type rdf:Property ;
    rdfs:label 'Tsb References' ;
    rdfs:comment 'Identifiers of TSBs surfaced during the session, if any.' ;
    rdfs:domain ind:RemoteDiagnosticSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleOdometerKm rdf:type rdf:Property ;
    rdfs:label 'Vehicle Odometer Km' ;
    rdfs:comment 'Odometer reading of the vehicle at the time of the session, in kilometers.' ;
