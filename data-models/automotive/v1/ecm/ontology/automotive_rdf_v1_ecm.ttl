ind:mediumSpeedCo2GPerKm rdf:type rdf:Property ;
    rdfs:label 'Medium Speed Co2 G Per Km' ;
    rdfs:comment 'CO2 emissions measured during the medium-speed phase of the WLTP cycle.' ;
    rdfs:domain ind:WltpTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediumSpeedFuelLPer100km rdf:type rdf:Property ;
    rdfs:label 'Medium Speed Fuel L Per 100km' ;
    rdfs:comment 'Fuel consumption recorded in the medium-speed phase.' ;
    rdfs:domain ind:WltpTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noxMgPerKm rdf:type rdf:Property ;
    rdfs:label 'Nox Mg Per Km' ;
    rdfs:comment 'Measured nitrogen-oxides emissions for the test cycle.' ;
    rdfs:domain ind:WltpTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:particulateMgPerKm rdf:type rdf:Property ;
    rdfs:label 'Particulate Mg Per Km' ;
    rdfs:comment 'Measured particulate matter emissions for the test cycle.' ;
    rdfs:domain ind:WltpTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powertrainVariantCode rdf:type rdf:Property ;
    rdfs:label 'Powertrain Variant Code' ;
    rdfs:comment 'Internal code identifying the specific powertrain configuration (e.g., engine, hybrid, electric) used in the test.' ;
    rdfs:domain ind:WltpTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethodology rdf:type rdf:Property ;
    rdfs:label 'Test Methodology' ;
    rdfs:comment 'Indicates whether the test was conducted on a chassis dynamometer (lab) or in-vehicle.' ;
    rdfs:domain ind:WltpTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStandardVersion rdf:type rdf:Property ;
    rdfs:label 'Test Standard Version' ;
    rdfs:comment 'Version of the WLTP standard applied (e.g., WLTP v2022).' ;
    rdfs:domain ind:WltpTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCo2GPerKm rdf:type rdf:Property ;
    rdfs:label 'Total Co2 G Per Km' ;
    rdfs:comment 'Overall CO2 emissions for the complete WLTP cycle.' ;
    rdfs:domain ind:WltpTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFuelLPer100km rdf:type rdf:Property ;
    rdfs:label 'Total Fuel L Per 100km' ;
    rdfs:comment 'Overall fuel consumption for the complete WLTP cycle.' ;
    rdfs:domain ind:WltpTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignResponseId rdf:type rdf:Property ;
    rdfs:label 'Campaign Response Id' ;
    rdfs:comment 'Unique identifier for the campaign response record. Primary key.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCampaignLeadId rdf:type rdf:Property ;
    rdfs:label 'Primary Campaign Lead Id' ;
    rdfs:comment 'Reference to the lead record if this response was converted to a lead.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lead .

ind:salesRepresentativeRepId rdf:type rdf:Property ;
    rdfs:label 'Sales Representative Rep Id' ;
    rdfs:comment 'Reference to the sales representative assigned to follow up on this campaign response.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'The date when this campaign response was converted to a lead or opportunity.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:convertedToLead rdf:type rdf:Property ;
    rdfs:label 'Converted To Lead' ;
    rdfs:comment 'Indicates whether this campaign response was converted into a lead record (True/False).' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:convertedToOpportunity rdf:type rdf:Property ;
    rdfs:label 'Converted To Opportunity' ;
    rdfs:comment 'Indicates whether this campaign response was converted into a sales opportunity record (True/False).' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financingInterest rdf:type rdf:Property ;
    rdfs:label 'Financing Interest' ;
    rdfs:comment 'Indicates whether the respondent expressed interest in financing options (True/False).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modelYearInterest rdf:type rdf:Property ;
    rdfs:label 'Model Year Interest' ;
    rdfs:comment 'The model year of the vehicle the respondent expressed interest in.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInEmail rdf:type rdf:Property ;
    rdfs:label 'Opt In Email' ;
    rdfs:comment 'Indicates whether the respondent opted in to receive email communications (True/False).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInPhone rdf:type rdf:Property ;
    rdfs:label 'Opt In Phone' ;
    rdfs:comment 'Indicates whether the respondent opted in to receive phone call communications (True/False).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInSms rdf:type rdf:Property ;
    rdfs:label 'Opt In Sms' ;
    rdfs:comment 'Indicates whether the respondent opted in to receive SMS communications (True/False).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:powertrainInterest rdf:type rdf:Property ;
    rdfs:label 'Powertrain Interest' ;
    rdfs:comment 'The powertrain type the respondent expressed interest in: ICE (Internal Combustion Engine), HEV (Hybrid Electric Vehicle), PHEV (Plug-in Hybrid Electric Vehicle), BEV (Battery Electric Vehicle), FCEV (Fuel Cell Electric Vehicle).' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseTimeframe rdf:type rdf:Property ;
    rdfs:label 'Purchase Timeframe' ;
    rdfs:comment 'The timeframe within which the respondent indicated they plan to purchase a vehicle (e.g., immediate, 1-3 months, 3-6 months, 6-12 months, over 12 months, undecided).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentEmail rdf:type rdf:Property ;
    rdfs:label 'Respondent Email' ;
    rdfs:comment 'Email address of the individual who responded to the campaign.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentFirstName rdf:type rdf:Property ;
    rdfs:label 'Respondent First Name' ;
    rdfs:comment 'First name of the individual who responded to the campaign.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentLastName rdf:type rdf:Property ;
    rdfs:label 'Respondent Last Name' ;
    rdfs:comment 'Last name of the individual who responded to the campaign.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentPhone rdf:type rdf:Property ;
    rdfs:label 'Respondent Phone' ;
    rdfs:comment 'Phone number of the individual who responded to the campaign.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseNotes rdf:type rdf:Property ;
    rdfs:label 'Response Notes' ;
    rdfs:comment 'Free-text notes or comments captured during the response or follow-up activities.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseNumber rdf:type rdf:Property ;
    rdfs:label 'Response Number' ;
    rdfs:comment 'Business-facing unique identifier or tracking number for the campaign response, used for reference and reporting purposes.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseScore rdf:type rdf:Property ;
    rdfs:label 'Response Score' ;
    rdfs:comment 'Numeric score representing the quality or likelihood of conversion for this campaign response, typically calculated by lead scoring algorithms.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Current lifecycle status of the campaign response (e.g., new, contacted, qualified, converted to lead or opportunity, disqualified, closed).' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDriveRequested rdf:type rdf:Property ;
    rdfs:label 'Test Drive Requested' ;
    rdfs:comment 'Indicates whether the respondent requested a test drive as part of their response (True/False).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeInInterest rdf:type rdf:Property ;
    rdfs:label 'Trade In Interest' ;
    rdfs:comment 'Indicates whether the respondent expressed interest in trading in an existing vehicle (True/False).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:utmCampaign rdf:type rdf:Property ;
    rdfs:label 'Utm Campaign' ;
    rdfs:comment 'UTM campaign tracking parameter captured from the response URL for digital attribution.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmMedium rdf:type rdf:Property ;
    rdfs:label 'Utm Medium' ;
    rdfs:comment 'UTM medium tracking parameter captured from the response URL for digital attribution.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmSource rdf:type rdf:Property ;
    rdfs:label 'Utm Source' ;
    rdfs:comment 'UTM source tracking parameter captured from the response URL for digital attribution.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleInterestCategory rdf:type rdf:Property ;
    rdfs:label 'Vehicle Interest Category' ;
    rdfs:comment 'The category or body style of vehicle the respondent expressed interest in (e.g., sedan, SUV, truck, van, coupe, convertible, hatchback, wagon, commercial vehicle). [ENUM-REF-CANDIDATE: sedan|suv|truck|van|coupe|convertible|hatchback|wagon|commercial — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleModelInterest rdf:type rdf:Property ;
    rdfs:label 'Vehicle Model Interest' ;
    rdfs:comment 'The specific vehicle model or nameplate the respondent expressed interest in.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Unique identifier for the sales channel. Primary key.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:applicablePowertrainTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Powertrain Types' ;
    rdfs:comment 'Comma-separated list of powertrain types eligible for this channel (e.g., ICE, EV, HEV, PHEV, FCEV). Used for product eligibility and incentive program alignment.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCategory rdf:type rdf:Property ;
    rdfs:label 'Channel Category' ;
    rdfs:comment 'Indicates whether the channel is direct (OEM-owned, no intermediary), indirect (dealer-mediated or third-party), or hybrid (combination of direct and indirect elements).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the sales channel (e.g., RETAIL_DEALER, DIRECT_CONSUMER, FLEET_COMM, GOVT, EXPORT_CKD, ONLINE_CONFIG, CPO). Used for operational reporting and system integration.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelDescription rdf:type rdf:Property ;
    rdfs:label 'Channel Description' ;
    rdfs:comment 'Detailed textual description of the sales channel, including its purpose, target customer segments, operational model, and any special characteristics or restrictions.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Full descriptive name of the sales channel (e.g., Retail Dealer Network, Direct-to-Consumer, Fleet and Commercial Sales, Government Sales, Export/CKD, Online Configurator, Certified Pre-Owned).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Status' ;
    rdfs:comment 'Current operational status of the sales channel: active (currently operational), inactive (temporarily not in use), suspended (on hold pending review), planned (future channel not yet launched), discontinued (permanently retired).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'High-level classification of the sales channel: retail (traditional dealer), direct (OEM direct-to-consumer), fleet (commercial/fleet sales), government (public sector contracts), export (international/CKD/SKD), online (digital configurator/e-commerce), cpo (certified pre-owned). [ENUM-REF-CANDIDATE: retail|direct|fleet|government|export|online|cpo — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionModel rdf:type rdf:Property ;
    rdfs:label 'Commission Model' ;
    rdfs:comment 'Type of commission structure applied to this channel: fixed (flat fee per unit), percentage (percent of sale price), tiered (volume-based tiers), hybrid (combination), none (no commission, direct OEM).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCodes rdf:type rdf:Property ;
    rdfs:label 'Country Codes' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this channel operates (e.g., USA, CAN, MEX, DEU, GBR, CHN, JPN). Used for geographic sales attribution and regulatory compliance.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Crm Integration Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this channel is integrated with the CRM system (Salesforce Automotive Cloud) for lead and opportunity tracking (True) or operates independently (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Default Commission Rate' ;
    rdfs:comment 'Default commission rate percentage applied to sales through this channel (e.g., 3.50 for 3.5%). Null if commission model is fixed or none.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmsIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Dms Integration Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this channel is integrated with the Dealer Management System (CDK Global DMS) for inventory and order management (True) or not (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:erpSalesChannelCode rdf:type rdf:Property ;
    rdfs:label 'Erp Sales Channel Code' ;
    rdfs:comment 'Corresponding sales channel code in the ERP system (SAP S/4HANA SD module). Used for order-to-cash integration and financial reporting.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveEligibility rdf:type rdf:Property ;
    rdfs:label 'Incentive Eligibility' ;
    rdfs:comment 'Indicates whether sales through this channel are eligible for OEM incentive programs: eligible (fully eligible), ineligible (excluded from incentives), conditional (eligible under specific conditions).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDealerMediated rdf:type rdf:Property ;
    rdfs:label 'Is Dealer Mediated' ;
    rdfs:comment 'Boolean flag indicating whether this channel involves a dealer or distributor intermediary (True) or is a direct OEM channel (False). Used for dealer network analytics and commission calculations.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDirectOem rdf:type rdf:Property ;
    rdfs:label 'Is Direct Oem' ;
    rdfs:comment 'Boolean flag indicating whether this channel is a direct OEM-owned channel (True) or an indirect dealer-mediated channel (False). Used for revenue attribution and margin analysis.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadSourcePriority rdf:type rdf:Property ;
    rdfs:label 'Lead Source Priority' ;
    rdfs:comment 'Numeric priority ranking for lead routing to this channel (1 = highest priority). Used in lead assignment and opportunity allocation logic.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'Pricing approach used in this channel: msrp (Manufacturer Suggested Retail Price with dealer negotiation), negotiated (fully negotiated pricing), fixed (no-haggle fixed price), dynamic (algorithm-driven pricing), auction (competitive bidding).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsFinancing rdf:type rdf:Property ;
    rdfs:label 'Supports Financing' ;
    rdfs:comment 'Boolean flag indicating whether this channel offers financing options (True) or requires cash/external financing (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsFleetSales rdf:type rdf:Property ;
    rdfs:label 'Supports Fleet Sales' ;
    rdfs:comment 'Boolean flag indicating whether this channel supports fleet or commercial bulk sales (True) or is limited to individual retail sales (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsLeasing rdf:type rdf:Property ;
    rdfs:label 'Supports Leasing' ;
    rdfs:comment 'Boolean flag indicating whether this channel offers leasing options (True) or does not support leasing (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsOnlineConfiguration rdf:type rdf:Property ;
    rdfs:label 'Supports Online Configuration' ;
    rdfs:comment 'Boolean flag indicating whether this channel supports online vehicle configuration and ordering (True) or requires in-person interaction (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsTradeIn rdf:type rdf:Property ;
    rdfs:label 'Supports Trade In' ;
    rdfs:comment 'Boolean flag indicating whether this channel accepts trade-in vehicles as part of the transaction (True) or does not support trade-ins (False).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitorVehicleId rdf:type rdf:Property ;
    rdfs:label 'Competitor Vehicle Id' ;
    rdfs:comment 'Unique identifier for the competitor vehicle record in the competitive intelligence catalog.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompetitorVehicle .

ind:baseMsrp rdf:type rdf:Property ;
    rdfs:label 'Base Msrp' ;
    rdfs:comment 'The manufacturer suggested retail price (MSRP) for the base trim level of the competitor vehicle, used for pricing comparison and competitive positioning.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoVolumeCubicFt rdf:type rdf:Property ;
    rdfs:label 'Cargo Volume Cubic Ft' ;
    rdfs:comment 'The cargo volume capacity in cubic feet, used for utility and practicality comparison.' ;
    rdfs:domain ind:CompetitorVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitivePositioning rdf:type rdf:Property ;
    rdfs:label 'Competitive Positioning' ;
    rdfs:comment 'Classification of how this competitor vehicle positions against our portfolio: direct (head-to-head competitor), indirect (adjacent segment), or emerging (new market entrant).' ;
    rdfs:domain ind:CompetitorVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorBrand rdf:type rdf:Property ;
    rdfs:label 'Competitor Brand' ;
    rdfs:comment 'The brand name of the competing Original Equipment Manufacturer (OEM) such as Toyota, Ford, BMW, Tesla, etc.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorVehicleStatus rdf:type rdf:Property ;
    rdfs:label 'Competitor Vehicle Status' ;
    rdfs:comment 'The current status of the competitor vehicle in the market: active (currently available), discontinued (no longer produced), upcoming (announced but not yet available), or rumored (unconfirmed future model).' ;
    rdfs:domain ind:CompetitorVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelEconomyCombinedMpg rdf:type rdf:Property ;
    rdfs:label 'Fuel Economy Combined Mpg' ;
    rdfs:comment 'The EPA-rated combined fuel economy in miles per gallon for ICE and hybrid vehicles.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keyFeatures rdf:type rdf:Property ;
    rdfs:label 'Key Features' ;
    rdfs:comment 'Comma-separated list of key feature highlights and differentiators of the competitor vehicle used in competitive battle cards and sales coaching (e.g., adaptive cruise control, panoramic sunroof, premium audio system).' ;
    rdfs:domain ind:CompetitorVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'The date when the competitor vehicle information was last updated by the sales strategy team.' ;
    rdfs:domain ind:CompetitorVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyRatingNcap rdf:type rdf:Property ;
    rdfs:label 'Safety Rating Ncap' ;
    rdfs:comment 'The New Car Assessment Programme (NCAP) overall safety rating (e.g., 5-star, 4-star) from Euro NCAP, NHTSA, or other regional testing authority.' ;
    rdfs:domain ind:CompetitorVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winLossRelevance rdf:type rdf:Property ;
    rdfs:label 'Win Loss Relevance' ;
    rdfs:comment 'The relevance level of this competitor vehicle in win/loss analysis and opportunity tracking: high (frequently encountered), medium (occasionally encountered), or low (rarely encountered).' ;
    rdfs:domain ind:CompetitorVehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Delivery Appointment Id' ;
    rdfs:comment 'Unique identifier for the delivery appointment record. Primary key for the delivery appointment entity.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliverySpecialistEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Delivery Specialist Employee Id' ;
    rdfs:comment 'Reference to the sales representative or delivery specialist assigned to conduct the vehicle handover and customer orientation.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rescheduledFromAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Rescheduled From Appointment Id' ;
    rdfs:comment 'Reference to the previous delivery appointment if this appointment is a rescheduled version.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryAppointment .

ind:appointmentDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Appointment Duration Minutes' ;
    rdfs:comment 'Expected duration of the delivery appointment in minutes, including vehicle walkthrough, paperwork, and handover.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Appointment Status' ;
    rdfs:comment 'Current lifecycle status of the delivery appointment. [ENUM-REF-CANDIDATE: scheduled|confirmed|in_progress|completed|cancelled|no_show|rescheduled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUserCode rdf:type rdf:Property ;
    rdfs:label 'Created By User Code' ;
    rdfs:comment 'Reference to the user who created the delivery appointment record.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Arrival Timestamp' ;
    rdfs:comment 'Date and time when the customer arrived at the delivery location for their appointment.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerConfirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Confirmation Status' ;
    rdfs:comment 'Status indicating whether the customer has confirmed their attendance at the scheduled delivery appointment.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerConfirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Confirmed Timestamp' ;
    rdfs:comment 'Date and time when the customer confirmed the delivery appointment.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line1' ;
    rdfs:comment 'Primary street address line for the delivery location if delivery is not at a standard dealership facility.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line2' ;
    rdfs:comment 'Secondary address line (suite, apartment, building) for the delivery location.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCity rdf:type rdf:Property ;
    rdfs:label 'Delivery City' ;
    rdfs:comment 'City name for the delivery location.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the delivery location.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocationType rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Type' ;
    rdfs:comment 'Classification of the delivery location where the vehicle will be handed over to the customer.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the delivery location.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverySatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Delivery Satisfaction Score' ;
    rdfs:comment 'Customer satisfaction rating for the delivery experience, typically on a scale of 1-10, collected immediately after delivery.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryStateProvince rdf:type rdf:Property ;
    rdfs:label 'Delivery State Province' ;
    rdfs:comment 'State or province code for the delivery location.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryType rdf:type rdf:Property ;
    rdfs:label 'Delivery Type' ;
    rdfs:comment 'Classification of the delivery service level provided to the customer.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalOwnerManualSent rdf:type rdf:Property ;
    rdfs:label 'Digital Owner Manual Sent' ;
    rdfs:comment 'Indicates whether the digital owner manual and vehicle information was sent to the customer.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financingStatus rdf:type rdf:Property ;
    rdfs:label 'Financing Status' ;
    rdfs:comment 'Status of financing approval and funding for the vehicle purchase if applicable.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReminderSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reminder Sent Timestamp' ;
    rdfs:comment 'Date and time when the most recent appointment reminder was sent to the customer.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:modifiedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Modified By User Code' ;
    rdfs:comment 'Reference to the user who last modified the delivery appointment record.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pdiCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pdi Completed Timestamp' ;
    rdfs:comment 'Date and time when the Pre-Delivery Inspection was completed and the vehicle was cleared for delivery.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pdiStatus rdf:type rdf:Property ;
    rdfs:label 'Pdi Status' ;
    rdfs:comment 'Status of the Pre-Delivery Inspection process ensuring the vehicle meets quality standards before customer handover.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderSentCount rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent Count' ;
    rdfs:comment 'Number of appointment reminder notifications sent to the customer via email, SMS, or phone.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'The date on which the vehicle delivery appointment is scheduled to occur.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledDeliveryTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Time' ;
    rdfs:comment 'The precise date and time when the customer is expected to arrive for vehicle handover.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tradeInStatus rdf:type rdf:Property ;
    rdfs:label 'Trade In Status' ;
    rdfs:comment 'Status of trade-in vehicle processing if the customer is trading in a vehicle as part of the transaction.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleOrientationCompleted rdf:type rdf:Property ;
    rdfs:label 'Vehicle Orientation Completed' ;
    rdfs:comment 'Indicates whether the delivery specialist completed the vehicle features and controls orientation with the customer.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehiclePreparationStatus rdf:type rdf:Property ;
    rdfs:label 'Vehicle Preparation Status' ;
    rdfs:comment 'Status of vehicle preparation activities including cleaning, fueling, accessory installation, and final detailing before delivery.' ;
    rdfs:domain ind:DeliveryAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetContractId rdf:type rdf:Property ;
    rdfs:label 'Fleet Contract Id' ;
    rdfs:comment 'Unique identifier for the fleet contract. Primary key for the fleet contract entity.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FleetContract .

ind:annualMileageAllowance rdf:type rdf:Property ;
    rdfs:label 'Annual Mileage Allowance' ;
    rdfs:comment 'Maximum annual mileage allowed per vehicle under lease terms without excess mileage charges. Typical values range from 10,000 to 25,000 miles per year. Null for purchase contracts.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Approved By User Code' ;
    rdfs:comment 'Reference to the user who granted final approval for this fleet contract. Typically a sales director or VP of fleet sales.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Base Discount Percentage' ;
    rdfs:comment 'Base percentage discount off Manufacturer Suggested Retail Price (MSRP) granted to the fleet customer. Additional volume-based discounts may apply.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedVolume rdf:type rdf:Property ;
    rdfs:label 'Committed Volume' ;
    rdfs:comment 'Total number of vehicles the fleet customer has committed to purchase or lease under this contract. Used for volume-based pricing tier qualification.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractName rdf:type rdf:Property ;
    rdfs:label 'Contract Name' ;
    rdfs:comment 'Descriptive name or title of the fleet contract, typically including customer name and program identifier for easy reference.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractSignedDate rdf:type rdf:Property ;
    rdfs:label 'Contract Signed Date' ;
    rdfs:comment 'Date when the fleet contract was formally signed by both parties. Marks the legal binding of the agreement.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle status of the fleet contract. Governs whether new orders can be placed and whether pricing and incentives are active. [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|expired|terminated|completed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Months' ;
    rdfs:comment 'Duration of the fleet contract expressed in months. Typical terms range from 12 to 60 months for corporate fleets.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractValueAmount rdf:type rdf:Property ;
    rdfs:label 'Contract Value Amount' ;
    rdfs:comment 'Total estimated monetary value of the fleet contract based on committed volume and agreed pricing. Expressed in contract currency.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveredVolume rdf:type rdf:Property ;
    rdfs:label 'Delivered Volume' ;
    rdfs:comment 'Cumulative count of vehicles delivered to the fleet customer under this contract to date. Updated upon each delivery completion.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryScheduleType rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Type' ;
    rdfs:comment 'Classification of how vehicles will be delivered over the contract term. Staggered and quarterly schedules are common for large fleet orders.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleModelYears rdf:type rdf:Property ;
    rdfs:label 'Eligible Model Years' ;
    rdfs:comment 'Comma-separated list of model years eligible for purchase under this contract. Typically current and next model year.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governmentContractFlag rdf:type rdf:Property ;
    rdfs:label 'Government Contract Flag' ;
    rdfs:comment 'Indicates whether this is a government procurement contract subject to special regulations, reporting requirements, and compliance standards.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gsaScheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Gsa Schedule Number' ;
    rdfs:comment 'GSA schedule contract number for U.S. federal government fleet purchases. Null for non-government contracts.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseTermMonths rdf:type rdf:Property ;
    rdfs:label 'Lease Term Months' ;
    rdfs:comment 'Duration of lease agreement in months if financing_type is lease. Typical fleet lease terms are 24, 36, or 48 months. Null for cash purchases.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Maintenance Included Flag' ;
    rdfs:comment 'Indicates whether scheduled maintenance services are included in the fleet contract pricing. Common for lease agreements and full-service fleet contracts.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:multiLocationDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Location Delivery Flag' ;
    rdfs:comment 'Indicates whether vehicles under this contract will be delivered to multiple locations. True for national fleet accounts with regional distribution.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nationalFleetAccountFlag rdf:type rdf:Property ;
    rdfs:label 'National Fleet Account Flag' ;
    rdfs:comment 'Indicates whether this is a national fleet account with centralized purchasing and multi-region delivery. National accounts receive special pricing and dedicated account management.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryDeliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Primary Delivery Location' ;
    rdfs:comment 'Primary geographic location or facility where fleet vehicles will be delivered. May be a corporate headquarters, fleet depot, or distribution center.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingVolume rdf:type rdf:Property ;
    rdfs:label 'Remaining Volume' ;
    rdfs:comment 'Number of vehicles remaining to be delivered under the committed volume. Calculated as committed_volume minus delivered_volume.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Eligible Flag' ;
    rdfs:comment 'Indicates whether this fleet contract is eligible for renewal upon expiration. Based on customer performance, payment history, and strategic account status.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialTermsNotes rdf:type rdf:Property ;
    rdfs:label 'Special Terms Notes' ;
    rdfs:comment 'Free-text field capturing any special terms, conditions, or negotiated provisions unique to this fleet contract that are not captured in standard fields.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeTierDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Discount Percentage' ;
    rdfs:comment 'Additional discount percentage applied when cumulative volume reaches specified tier thresholds. Stacks on top of base discount.' ;
    rdfs:domain ind:FleetContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fleetContractLineId rdf:type rdf:Property ;
    rdfs:label 'Fleet Contract Line Id' ;
    rdfs:comment 'Unique identifier for the fleet contract line item. Primary key for this entity.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryLocationId rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Id' ;
    rdfs:comment 'Reference to the specific delivery location, distribution center, or customer facility where vehicles will be delivered.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:amendmentNotes rdf:type rdf:Property ;
    rdfs:label 'Amendment Notes' ;
    rdfs:comment 'Free-text notes documenting any amendments or changes made to this contract line after initial creation.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End Date' ;
    rdfs:comment 'The latest date in the delivery window for vehicles under this contract line. Defines the end of the acceptable delivery period.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start Date' ;
    rdfs:comment 'The earliest date in the delivery window for vehicles under this contract line. Defines the beginning of the acceptable delivery period.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:destinationRegion rdf:type rdf:Property ;
    rdfs:label 'Destination Region' ;
    rdfs:comment 'The geographic region or sales territory where vehicles in this line will be delivered (e.g., Northeast, Southwest, Pacific).' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetUseType rdf:type rdf:Property ;
    rdfs:label 'Fleet Use Type' ;
    rdfs:comment 'The intended use category for the fleet vehicles: commercial (business operations), rental (rental fleet), government (public sector), corporate (executive/employee), utility (service/maintenance), or emergency (police/fire/EMS).' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Code' ;
    rdfs:comment 'The user ID of the person who last modified this contract line record. Audit trail for accountability.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedProductionMonth rdf:type rdf:Property ;
    rdfs:label 'Planned Production Month' ;
    rdfs:comment 'The planned production month for vehicles in this line, in YYYY-MM format. Aligns with manufacturing scheduling and capacity planning.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityFulfilled rdf:type rdf:Property ;
    rdfs:label 'Quantity Fulfilled' ;
    rdfs:comment 'The number of vehicle units that have been delivered and fulfilled against this contract line to date.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityRemaining rdf:type rdf:Property ;
    rdfs:label 'Quantity Remaining' ;
    rdfs:comment 'The number of vehicle units still pending delivery under this contract line. Calculated as quantity_committed minus quantity_fulfilled.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialEquipmentCodes rdf:type rdf:Property ;
    rdfs:label 'Special Equipment Codes' ;
    rdfs:comment 'Comma-separated list of special equipment or option codes included in the vehicle configuration for this line (e.g., towing package, advanced safety features).' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLineValue rdf:type rdf:Property ;
    rdfs:label 'Total Line Value' ;
    rdfs:comment 'The total monetary value of this contract line, calculated as quantity_committed multiplied by unit_contracted_price.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitContractedPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Contracted Price' ;
    rdfs:comment 'The negotiated price per vehicle unit for this contract line. Represents the agreed-upon unit price before taxes and fees.' ;
    rdfs:domain ind:FleetContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadId rdf:type rdf:Property ;
    rdfs:label 'Lead Id' ;
    rdfs:comment 'Unique identifier for the sales lead record. Primary key.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lead .

ind:assignedDealerDealershipId rdf:type rdf:Property ;
    rdfs:label 'Assigned Dealer Dealership Id' ;
    rdfs:comment 'Identifier of the dealership assigned to this lead for follow-up and conversion.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:assignedOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Lead Assignment Process needs to record the employee responsible for each lead.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignedOwnerRepId rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner Rep Id' ;
    rdfs:comment 'Identifier of the sales representative or dealer contact assigned to follow up on this lead.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:convertedOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Converted Opportunity Id' ;
    rdfs:comment 'Identifier of the opportunity record created upon lead conversion. Null if not yet converted.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:companyName rdf:type rdf:Property ;
    rdfs:label 'Company Name' ;
    rdfs:comment 'Name of the organization or company associated with the lead, applicable for fleet sales or commercial vehicle inquiries.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedDate rdf:type rdf:Property ;
    rdfs:label 'Converted Date' ;
    rdfs:comment 'The date when the lead was converted into an opportunity. Null if not yet converted. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Budget Amount' ;
    rdfs:comment 'Estimated budget or price range the lead has indicated for the vehicle purchase.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadNumber rdf:type rdf:Property ;
    rdfs:label 'Lead Number' ;
    rdfs:comment 'Human-readable business identifier for the lead, typically auto-generated by the CRM system. Format: LEAD-NNNNNNNN.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'The origin channel through which the lead was captured (web inquiry, dealer walk-in, automotive event, customer referral, digital marketing campaign, phone inquiry).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadStatus rdf:type rdf:Property ;
    rdfs:label 'Lead Status' ;
    rdfs:comment 'Current lifecycle status of the lead in the sales pipeline (new, contacted, qualified, unqualified, converted to opportunity, lost).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadType rdf:type rdf:Property ;
    rdfs:label 'Lead Type' ;
    rdfs:comment 'Classification of the lead based on buyer category: individual consumer, fleet buyer, commercial enterprise, or government entity.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lostReason rdf:type rdf:Property ;
    rdfs:label 'Lost Reason' ;
    rdfs:comment 'Reason why the lead was marked as lost (e.g., purchased from competitor, no longer interested, unresponsive).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Next Follow Up Date' ;
    rdfs:comment 'Scheduled date for the next follow-up activity with the lead. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationScore rdf:type rdf:Property ;
    rdfs:label 'Qualification Score' ;
    rdfs:comment 'Numeric score (0-100) representing the leads likelihood to convert, based on engagement, budget, authority, need, and timeline (BANT criteria).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rating rdf:type rdf:Property ;
    rdfs:label 'Rating' ;
    rdfs:comment 'Qualitative rating of the lead based on engagement and conversion potential: hot (high priority), warm (moderate interest), cold (low engagement).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'Name or identifier of the person or entity that referred this lead, if applicable.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unqualifiedReason rdf:type rdf:Property ;
    rdfs:label 'Unqualified Reason' ;
    rdfs:comment 'Reason why the lead was marked as unqualified (e.g., no budget, no authority, no need, incorrect contact information).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:webFormCode rdf:type rdf:Property ;
    rdfs:label 'Web Form Code' ;
    rdfs:comment 'Identifier of the web form or landing page through which the lead was captured, used for digital campaign attribution.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrpScheduleId rdf:type rdf:Property ;
    rdfs:label 'Msrp Schedule Id' ;
    rdfs:comment 'Unique identifier for the MSRP schedule record. Primary key.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MsrpSchedule .

ind:advertisingFee rdf:type rdf:Property ;
    rdfs:label 'Advertising Fee' ;
    rdfs:comment 'Regional or national advertising fee included in the MSRP to fund cooperative advertising programs. Disclosed separately on buyer\'s order.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationCharge rdf:type rdf:Property ;
    rdfs:label 'Destination Charge' ;
    rdfs:comment 'Standard destination and delivery charge applied to transport the vehicle from manufacturing plant to dealer. Mandated by federal regulation to be uniform within a market region.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epaFuelEconomyCity rdf:type rdf:Property ;
    rdfs:label 'Epa Fuel Economy City' ;
    rdfs:comment 'EPA-certified city fuel economy rating in miles per gallon (MPG) for ICE/HEV/PHEV, or MPGe (miles per gallon equivalent) for BEV/FCEV. Used for CAFE compliance and consumer disclosure.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:epaFuelEconomyCombined rdf:type rdf:Property ;
    rdfs:label 'Epa Fuel Economy Combined' ;
    rdfs:comment 'EPA-certified combined fuel economy rating (55% city, 45% highway) in MPG or MPGe. Primary metric for CAFE and consumer comparison.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:epaFuelEconomyHighway rdf:type rdf:Property ;
    rdfs:label 'Epa Fuel Economy Highway' ;
    rdfs:comment 'EPA-certified highway fuel economy rating in miles per gallon (MPG) or MPGe. Used for CAFE compliance and consumer disclosure.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gasGuzzlerTax rdf:type rdf:Property ;
    rdfs:label 'Gas Guzzler Tax' ;
    rdfs:comment 'Federal gas guzzler tax applied to vehicles with EPA fuel economy below statutory thresholds. Zero if not applicable.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdbackAmount rdf:type rdf:Property ;
    rdfs:label 'Holdback Amount' ;
    rdfs:comment 'Manufacturer holdback amount paid to dealer after vehicle sale, typically 2-3% of MSRP. Used to support dealer cash flow and inventory financing. Confidential business data.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powertrainWarrantyMiles rdf:type rdf:Property ;
    rdfs:label 'Powertrain Warranty Miles' ;
    rdfs:comment 'Extended powertrain warranty duration in miles (e.g., 60,000 miles). Covers engine, transmission, drivetrain components.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'Date and time when this MSRP schedule was published to dealer systems and public-facing channels (website, configurator, dealer portals).' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalMsrp rdf:type rdf:Property ;
    rdfs:label 'Total Msrp' ;
    rdfs:comment 'Total MSRP including base price, destination charge, gas guzzler tax, and any mandatory fees. Excludes dealer-installed accessories and local taxes.' ;
    rdfs:domain ind:MsrpSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'Actual date when the opportunity was closed (won or lost).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'Preferred delivery location or dealership for vehicle handover.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Close Date' ;
    rdfs:comment 'Anticipated date when the opportunity is expected to close (either won or lost).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exteriorColor rdf:type rdf:Property ;
    rdfs:label 'Exterior Color' ;
    rdfs:comment 'Preferred exterior color for the vehicle.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interiorColor rdf:type rdf:Property ;
    rdfs:label 'Interior Color' ;
    rdfs:comment 'Preferred interior color or trim for the vehicle.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isWon rdf:type rdf:Property ;
    rdfs:label 'Is Won' ;
    rdfs:comment 'Indicates whether the opportunity was closed as won (successful sale).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent sales activity or interaction related to this opportunity.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Primary reason why the opportunity was lost, if applicable. [ENUM-REF-CANDIDATE: price|product_fit|competitor|timing|financing|no_response|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Descriptive name of the opportunity, typically including prospect name and vehicle of interest.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityNumber rdf:type rdf:Property ;
    rdfs:label 'Opportunity Number' ;
    rdfs:comment 'Business-facing unique identifier for the opportunity, typically auto-generated and used in communications with dealers and sales teams.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityType rdf:type rdf:Property ;
    rdfs:label 'Opportunity Type' ;
    rdfs:comment 'Classification of the opportunity based on customer segment and purchase type.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probability rdf:type rdf:Property ;
    rdfs:label 'Probability' ;
    rdfs:comment 'Estimated probability of closing this opportunity successfully, expressed as a percentage (0-100).' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quoteDate rdf:type rdf:Property ;
    rdfs:label 'Quote Date' ;
    rdfs:comment 'Date when the quote was generated, if applicable.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteGenerated rdf:type rdf:Property ;
    rdfs:label 'Quote Generated' ;
    rdfs:comment 'Indicates whether a formal quote has been generated for this opportunity.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesStage rdf:type rdf:Property ;
    rdfs:label 'Sales Stage' ;
    rdfs:comment 'Current stage of the opportunity in the sales pipeline, reflecting progression from initial contact through close. [ENUM-REF-CANDIDATE: lead|qualification|needs_analysis|test_drive|quote|negotiation|closed_won|closed_lost — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territory rdf:type rdf:Property ;
    rdfs:label 'Territory' ;
    rdfs:comment 'Sales territory within the region where this opportunity is being managed.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDriveCompleted rdf:type rdf:Property ;
    rdfs:label 'Test Drive Completed' ;
    rdfs:comment 'Indicates whether the prospect has completed a test drive for the vehicle of interest.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testDriveDate rdf:type rdf:Property ;
    rdfs:label 'Test Drive Date' ;
    rdfs:comment 'Date when the test drive was completed, if applicable.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradeInValue rdf:type rdf:Property ;
    rdfs:label 'Trade In Value' ;
    rdfs:comment 'Appraised value of the customer\'s trade-in vehicle, if applicable.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleConfiguration rdf:type rdf:Property ;
    rdfs:label 'Vehicle Configuration' ;
    rdfs:comment 'Detailed configuration of the vehicle including trim level, options, and packages.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winReason rdf:type rdf:Property ;
    rdfs:label 'Win Reason' ;
    rdfs:comment 'Primary reason why the opportunity was won, if applicable. [ENUM-REF-CANDIDATE: price|product_features|brand_loyalty|service|financing|relationship|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeInId rdf:type rdf:Property ;
    rdfs:label 'Trade In Id' ;
    rdfs:comment 'Reference to the trade-in vehicle appraisal record if this order line includes a trade-in transaction. Null if no trade-in.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeIn .

ind:tradeInVehicleVinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Trade In Vehicle Vin Registry Id' ;
    rdfs:comment 'Reference to the trade-in vehicle appraisal record if this order line includes a trade-in transaction. Null if no trade-in.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VinRegistry .

ind:vehicleOptionPackageId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Option Package Id' ;
    rdfs:comment 'Foreign key linking to vehicle.vehicle_option_package. Business justification: Order line must reference option package entity to drive production planning, parts allocation, and warranty tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleOptionPackage .

ind:actualProductionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Production Date' ;
    rdfs:comment 'Actual date when vehicle production was completed. Populated from MES upon job completion.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fleetIndicator rdf:type rdf:Property ;
    rdfs:label 'Fleet Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this line item is part of a fleet or commercial vehicle order. True for fleet sales, False for retail sales.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Human-readable description of the line item product or service. Provides business context for reporting and customer documentation.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipDate rdf:type rdf:Property ;
    rdfs:label 'Ship Date' ;
    rdfs:comment 'Date when the line item was shipped from the manufacturing plant or distribution center to the dealer or customer.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderStatusEventId rdf:type rdf:Property ;
    rdfs:label 'Order Status Event Id' ;
    rdfs:comment 'Unique identifier for the order status event record. Primary key.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualProductionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Production Completion Date' ;
    rdfs:comment 'The actual date when the vehicle completed assembly and exited the production line. Populated when the order transitions to built status.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualProductionStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Production Start Date' ;
    rdfs:comment 'The actual date when the vehicle entered the production line. Populated when the order transitions to in_production status.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:delayDays rdf:type rdf:Property ;
    rdfs:label 'Delay Days' ;
    rdfs:comment 'The number of days the order is delayed relative to the original schedule. Calculated when a status transition occurs later than planned.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventNotes rdf:type rdf:Property ;
    rdfs:label 'Event Notes' ;
    rdfs:comment 'Free-text notes or comments associated with the status change event. Provides additional context or details not captured in structured fields.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Indicates whether this status event represents an exception or deviation from the normal order fulfillment process. True if exception, False otherwise.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The order status after this transition event. Captures the to-state in the order lifecycle. Enables end-to-end order tracking through the fulfillment pipeline. [ENUM-REF-CANDIDATE: confirmed|scheduled_for_production|in_production|built|quality_released|shipped|in_transit|at_dealer|delivered|cancelled — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'The communication channel used to notify the customer of the status change. Examples include email, SMS, mobile app push notification, customer portal, phone call.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether a customer notification was sent for this status change event. True if notification sent, False otherwise.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The order status immediately before this transition event. Captures the from-state in the order lifecycle. [ENUM-REF-CANDIDATE: placed|confirmed|scheduled_for_production|in_production|built|quality_released|shipped — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Quality Release Date' ;
    rdfs:comment 'The date when the vehicle passed final quality inspection and was released for shipment. Populated when the order transitions to quality_released status.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'The business unit, department, or role responsible for the status transition. Examples include Production Planning, Manufacturing, Quality Assurance, Logistics, Dealer Network.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Date' ;
    rdfs:comment 'The date when the vehicle was shipped from the manufacturing plant or distribution center. Populated when the order transitions to shipped status.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggeringSystem rdf:type rdf:Property ;
    rdfs:label 'Triggering System' ;
    rdfs:comment 'The source system or application that initiated the status change event. Examples include SAP SD (Sales and Distribution), MES (Manufacturing Execution System), TMS (Transportation Management System), WMS (Warehouse Management System), DMS (Dealer Management System), Salesforce Automotive Cloud, or manual entry. [ENUM-REF-CANDIDATE: SAP_SD|MES|WMS|TMS|DMS|SALESFORCE|MANUAL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringUserCode rdf:type rdf:Property ;
    rdfs:label 'Triggering User Code' ;
    rdfs:comment 'The user or system account that triggered the status change. May be a human user ID or a system service account identifier.' ;
    rdfs:domain ind:OrderStatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment Id' ;
    rdfs:comment 'Unique identifier for the price adjustment record. Primary key.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPriceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Price Employee Id' ;
    rdfs:comment 'Reference to the manager or executive who authorized this price adjustment.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustedPrice rdf:type rdf:Property ;
    rdfs:label 'Adjusted Price' ;
    rdfs:comment 'The resulting price after this adjustment is applied. May be further adjusted by subsequent adjustments in the pricing waterfall.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentCategory rdf:type rdf:Property ;
    rdfs:label 'Adjustment Category' ;
    rdfs:comment 'High-level grouping of the adjustment type for reporting and analysis purposes. Distinguishes between manufacturer-funded incentives, dealer-funded discounts, and other adjustment sources. [ENUM-REF-CANDIDATE: manufacturer_incentive|dealer_discount|regional_program|customer_loyalty|fleet_commercial|employee_affiliate|promotional_campaign|competitive_response|inventory_management|executive_override — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentMethod rdf:type rdf:Property ;
    rdfs:label 'Adjustment Method' ;
    rdfs:comment 'Method by which the adjustment is calculated: fixed dollar amount, percentage of MSRP or invoice, tiered based on volume or other criteria, or formula-based calculation.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Adjustment Percentage' ;
    rdfs:comment 'The percentage rate of the price adjustment when the adjustment method is percentage-based. Stored as a decimal (e.g., 5.00 for 5%).' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Flag' ;
    rdfs:comment 'Indicates whether this price adjustment has been flagged for audit review due to unusual amount, authorization level, or other risk factors.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:basePrice rdf:type rdf:Property ;
    rdfs:label 'Base Price' ;
    rdfs:comment 'The original price (MSRP or invoice price) before this adjustment is applied, providing context for the adjustment magnitude.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date on which the price adjustment request was rejected, if applicable.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stackingAllowed rdf:type rdf:Property ;
    rdfs:label 'Stacking Allowed' ;
    rdfs:comment 'Indicates whether this price adjustment can be combined (stacked) with other adjustments and incentives. Some programs are mutually exclusive.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submittingUserCode rdf:type rdf:Property ;
    rdfs:label 'Submitting User Code' ;
    rdfs:comment 'Reference to the sales representative or dealer user who submitted the price adjustment request.' ;
    rdfs:domain ind:PriceAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quotaId rdf:type rdf:Property ;
    rdfs:label 'Quota Id' ;
    rdfs:comment 'Unique identifier for the sales quota record. Primary key.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assigneeRepId rdf:type rdf:Property ;
    rdfs:label 'Assignee Rep Id' ;
    rdfs:comment 'Foreign key reference to the entity assigned this quota. Interpretation depends on assignee_type: references sales_representative, dealership, territory, region, or team table.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:salesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Id' ;
    rdfs:comment 'Foreign key reference to the sales territory this quota is assigned to. Null if quota is not territory-specific.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesTerritory .

ind:assigneeName rdf:type rdf:Property ;
    rdfs:label 'Assignee Name' ;
    rdfs:comment 'Human-readable name of the quota assignee (representative name, dealer name, territory name, etc.) for reporting and display purposes.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assigneeType rdf:type rdf:Property ;
    rdfs:label 'Assignee Type' ;
    rdfs:comment 'Type of entity to which the quota is assigned: sales_representative (individual salesperson), dealer (dealership entity), territory (geographic sales territory), region (multi-territory region), district (sales district), zone (sales zone), team (sales team). [ENUM-REF-CANDIDATE: sales_representative|dealer|territory|region|district|zone|team — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Month' ;
    rdfs:comment 'Fiscal month within the fiscal year (M01 through M12). Null if quota is quarterly or annual.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveEligible rdf:type rdf:Property ;
    rdfs:label 'Incentive Eligible' ;
    rdfs:comment 'Boolean flag indicating whether achievement of this quota makes the assignee eligible for incentive compensation (True) or is a non-incentivized target (False).' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotaName rdf:type rdf:Property ;
    rdfs:label 'Quota Name' ;
    rdfs:comment 'Descriptive name for the quota assignment, e.g., \'Q1 FY2024 Northeast Region EV Target\' or \'Annual MY2024 Fleet Sales Goal\'.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaNumber rdf:type rdf:Property ;
    rdfs:label 'Quota Number' ;
    rdfs:comment 'Human-readable business identifier for the quota assignment, typically following format QTA-YYYYNNNN.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaStatus rdf:type rdf:Property ;
    rdfs:label 'Quota Status' ;
    rdfs:comment 'Current lifecycle status of the quota: draft (under review), approved (management approved), active (in effect), suspended (temporarily paused), closed (period ended), cancelled (voided before completion).' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaType rdf:type rdf:Property ;
    rdfs:label 'Quota Type' ;
    rdfs:comment 'Classification of the quota by measurement type: unit_volume (vehicle units sold), revenue (dollar/currency target), ev_mix (Electric Vehicle penetration percentage), fleet_penetration (commercial fleet sales), market_share (regional market share target), model_mix (specific model line targets).' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Business reason for the most recent revision to the quota (e.g., \'Market conditions adjustment\', \'Territory realignment\', \'Product launch delay\'). Null if no revisions have been made.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetUnit rdf:type rdf:Property ;
    rdfs:label 'Target Unit' ;
    rdfs:comment 'Unit of measure for the target_value: units (vehicle count), currency codes (USD, EUR, GBP, JPY, CNY), percentage (for mix/share targets), market_points (for market share basis points). [ENUM-REF-CANDIDATE: units|usd|eur|gbp|jpy|cny|percentage|market_points — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdMinimum rdf:type rdf:Property ;
    rdfs:label 'Threshold Minimum' ;
    rdfs:comment 'Minimum performance threshold (as percentage of target_value or absolute value) required for any incentive payout or recognition. Null if no minimum threshold applies.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdStretch rdf:type rdf:Property ;
    rdfs:label 'Threshold Stretch' ;
    rdfs:comment 'Stretch performance threshold (as percentage of target_value or absolute value) that triggers maximum incentive payout or recognition. Null if no stretch threshold applies.' ;
    rdfs:domain ind:Quota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accessoriesTotal rdf:type rdf:Property ;
    rdfs:label 'Accessories Total' ;
    rdfs:comment 'Total value of dealer-installed accessories (e.g., floor mats, cargo organizers, protection packages). Separate from factory options.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aprRate rdf:type rdf:Property ;
    rdfs:label 'Apr Rate' ;
    rdfs:comment 'Annual percentage rate for financing if offered. Expressed as decimal (e.g., 0.0399 for 3.99% APR). Subject to credit approval.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:convertedToOrder rdf:type rdf:Property ;
    rdfs:label 'Converted To Order' ;
    rdfs:comment 'Indicates whether this quote was successfully converted to a customer order. True when customer accepts quote and order is created in SAP SD.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financingOffered rdf:type rdf:Property ;
    rdfs:label 'Financing Offered' ;
    rdfs:comment 'Indicates whether financing terms are included in this quote. True if quote includes loan or lease options, false for cash-only quotes.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financingTermMonths rdf:type rdf:Property ;
    rdfs:label 'Financing Term Months' ;
    rdfs:comment 'Length of financing term in months if financing_offered is true. Common terms: 36, 48, 60, 72, 84 months.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentiveTotal rdf:type rdf:Property ;
    rdfs:label 'Incentive Total' ;
    rdfs:comment 'Total value of manufacturer incentives, rebates, and discounts applied to this quote (e.g., loyalty bonus, conquest incentive, EV tax credit eligibility). Reduces net selling price.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseAnnualMileage rdf:type rdf:Property ;
    rdfs:label 'Lease Annual Mileage' ;
    rdfs:comment 'Annual mileage allowance for lease if offered. Common values: 10000, 12000, 15000 miles per year. Excess mileage incurs per-mile charges.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaseMonthlyPayment rdf:type rdf:Property ;
    rdfs:label 'Lease Monthly Payment' ;
    rdfs:comment 'Estimated monthly lease payment if lease is offered. Based on capitalized cost, residual value, money factor, and term.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseOffered rdf:type rdf:Property ;
    rdfs:label 'Lease Offered' ;
    rdfs:comment 'Indicates whether lease terms are included in this quote as an alternative to purchase financing.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:msrpBase rdf:type rdf:Property ;
    rdfs:label 'Msrp Base' ;
    rdfs:comment 'Base MSRP for the vehicle model and trim before options, accessories, and destination charges. Published pricing from OEM.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Net Selling Price' ;
    rdfs:comment 'Final vehicle price after all incentives and trade-in allowance. Calculated as subtotal_amount - incentive_total - trade_in_allowance + trade_in_payoff. Base for tax calculation.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optionsTotal rdf:type rdf:Property ;
    rdfs:label 'Options Total' ;
    rdfs:comment 'Total value of factory-installed options and packages selected by customer (e.g., ADAS, premium audio, sunroof). Sum of individual option prices.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationFee rdf:type rdf:Property ;
    rdfs:label 'Registration Fee' ;
    rdfs:comment 'Government registration and title fees for the vehicle. Varies by state/province and vehicle type.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmountDue rdf:type rdf:Property ;
    rdfs:label 'Total Amount Due' ;
    rdfs:comment 'Final total amount customer must pay. Calculated as net_selling_price + tax_amount + registration_fee + doc_fee. Used for financing calculation or cash payment.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeInPayoff rdf:type rdf:Property ;
    rdfs:label 'Trade In Payoff' ;
    rdfs:comment 'Outstanding loan balance on trade-in vehicle that must be paid off. If greater than trade_in_allowance, creates negative equity rolled into new financing.' ;
    rdfs:domain ind:Quote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quoteLineId rdf:type rdf:Property ;
    rdfs:label 'Quote Line Id' ;
    rdfs:comment 'Unique identifier for the quote line item. Primary key.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissionEligible rdf:type rdf:Property ;
    rdfs:label 'Commission Eligible' ;
    rdfs:comment 'Indicates whether this line item is eligible for sales representative commission. Certain line types (fees, trade-ins) may be excluded from commission calculations.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'Commission rate applied to this line item for sales representative compensation. Expressed as a decimal percentage. May vary by product type and sales program.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extendedPrice rdf:type rdf:Property ;
    rdfs:label 'Extended Price' ;
    rdfs:comment 'Line item subtotal before tax. Calculated as (unit_price * quantity) - discount_amount - incentive_amount. Represents the pre-tax line total.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveDescription rdf:type rdf:Property ;
    rdfs:label 'Incentive Description' ;
    rdfs:comment 'Human-readable description of the incentive applied. Provides customer-facing explanation of the incentive program, eligibility criteria, and value proposition.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginAmount rdf:type rdf:Property ;
    rdfs:label 'Margin Amount' ;
    rdfs:comment 'Gross margin for this line item. Calculated as extended_price - cost_amount. Used for profitability analysis and sales performance evaluation.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'Stock Keeping Unit (SKU) or product code for accessories, service packages, warranties, or other non-vehicle line items. Links to product master for pricing and availability.' ;
    rdfs:domain ind:QuoteLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalSalesPlanId rdf:type rdf:Property ;
    rdfs:label 'Regional Sales Plan Id' ;
    rdfs:comment 'Unique identifier for the regional sales plan record.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRegionalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Regional Employee Id' ;
    rdfs:comment 'Identifier for the sales leader or manager responsible for this regional sales plan.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryRegionalLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Regional Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier for the user who last modified this regional sales plan record.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryRegionalCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Regional Created By User Employee Id' ;
    rdfs:comment 'Identifier for the user who created this regional sales plan record.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:averageMsrp rdf:type rdf:Property ;
    rdfs:label 'Average Msrp' ;
    rdfs:comment 'Average MSRP assumed for revenue planning calculations.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealerNetworkCode rdf:type rdf:Property ;
    rdfs:label 'Dealer Network Code' ;
    rdfs:comment 'Identifier for the dealer network or distribution channel associated with this regional plan.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evPenetrationTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Ev Penetration Target Percentage' ;
    rdfs:comment 'Target percentage of electric vehicle sales within the total volume mix, supporting electrification strategy.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Ev Volume Units' ;
    rdfs:comment 'Planned sales volume for battery electric vehicles.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fleetMixPercentage rdf:type rdf:Property ;
    rdfs:label 'Fleet Mix Percentage' ;
    rdfs:comment 'Target percentage of total volume allocated to fleet and commercial sales channels.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hevVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Hev Volume Units' ;
    rdfs:comment 'Planned sales volume for hybrid electric vehicles.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iceVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Ice Volume Units' ;
    rdfs:comment 'Planned sales volume for internal combustion engine vehicles.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentiveBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Incentive Budget Amount' ;
    rdfs:comment 'Total incentive budget allocated to this regional sales plan for customer and dealer incentives.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketZone rdf:type rdf:Property ;
    rdfs:label 'Market Zone' ;
    rdfs:comment 'Sub-regional market zone or territory grouping within the broader sales region.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume Units' ;
    rdfs:comment 'Minimum acceptable sales volume threshold for the planning period.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phevVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Phev Volume Units' ;
    rdfs:comment 'Planned sales volume for plug-in hybrid electric vehicles.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planNotes rdf:type rdf:Property ;
    rdfs:label 'Plan Notes' ;
    rdfs:comment 'Free-text notes capturing assumptions, constraints, and strategic context for the regional sales plan.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the planning period covered by this regional sales plan.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the planning period covered by this regional sales plan.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retailMixPercentage rdf:type rdf:Property ;
    rdfs:label 'Retail Mix Percentage' ;
    rdfs:comment 'Target percentage of total volume allocated to retail sales channels.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stretchVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Stretch Volume Units' ;
    rdfs:comment 'Stretch or aspirational sales volume target representing best-case scenario.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Target Revenue Amount' ;
    rdfs:comment 'Planned revenue target for the region and planning period in the specified currency.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Target Volume Units' ;
    rdfs:comment 'Planned sales volume in units for the region and planning period.' ;
    rdfs:domain ind:RegionalSalesPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activityId rdf:type rdf:Property ;
    rdfs:label 'Activity Id' ;
    rdfs:comment 'Unique identifier for the sales activity record. Primary key.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activityDate rdf:type rdf:Property ;
    rdfs:label 'Activity Date' ;
    rdfs:comment 'The date on which the sales activity occurred or is scheduled to occur.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activityDescription rdf:type rdf:Property ;
    rdfs:label 'Activity Description' ;
    rdfs:comment 'Detailed description or notes about the sales activity, capturing key discussion points, customer feedback, and action items.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityNumber rdf:type rdf:Property ;
    rdfs:label 'Activity Number' ;
    rdfs:comment 'Business-facing unique identifier for the sales activity, typically system-generated in format ACT-########.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Status' ;
    rdfs:comment 'Current lifecycle status of the sales activity indicating whether it is scheduled, in progress, completed, cancelled, no-show, or rescheduled.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Classification of the sales activity indicating the nature of the interaction (call, email, test drive, demo, site visit, proposal presentation, follow-up, negotiation, or other). [ENUM-REF-CANDIDATE: call|email|meeting|test_drive|demo|site_visit|proposal_presentation|follow_up|negotiation|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorMentioned rdf:type rdf:Property ;
    rdfs:label 'Competitor Mentioned' ;
    rdfs:comment 'Name of any competitor brand or product mentioned by the customer during the sales activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSentiment rdf:type rdf:Property ;
    rdfs:label 'Customer Sentiment' ;
    rdfs:comment 'Qualitative assessment of the customer\'s sentiment or attitude during the sales activity (very positive, positive, neutral, negative, very negative).' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demoCompleted rdf:type rdf:Property ;
    rdfs:label 'Demo Completed' ;
    rdfs:comment 'Boolean flag indicating whether a product demonstration was completed as part of this sales activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDealValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Deal Value' ;
    rdfs:comment 'Estimated monetary value of the potential deal discussed or progressed during this sales activity, in the base currency.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFleetSale rdf:type rdf:Property ;
    rdfs:label 'Is Fleet Sale' ;
    rdfs:comment 'Boolean flag indicating whether this sales activity is related to a fleet sale opportunity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextAction rdf:type rdf:Property ;
    rdfs:label 'Next Action' ;
    rdfs:comment 'Description of the next planned action or follow-up step resulting from this sales activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectionRaised rdf:type rdf:Property ;
    rdfs:label 'Objection Raised' ;
    rdfs:comment 'Description of any objections or concerns raised by the customer during the sales activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectionResolved rdf:type rdf:Property ;
    rdfs:label 'Objection Resolved' ;
    rdfs:comment 'Boolean flag indicating whether the customer\'s objection was successfully resolved during the activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotePresented rdf:type rdf:Property ;
    rdfs:label 'Quote Presented' ;
    rdfs:comment 'Boolean flag indicating whether a price quote or proposal was presented during this sales activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualSpentAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spent Amount' ;
    rdfs:comment 'Total amount actually spent on the campaign to date.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSpentCurrency rdf:type rdf:Property ;
    rdfs:label 'Actual Spent Currency' ;
    rdfs:comment 'ISO 4217 currency code for the actual spent amount.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Currency' ;
    rdfs:comment 'ISO 4217 currency code for the budget amount.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Dealer Participation Flag' ;
    rdfs:comment 'Indicates whether dealers are required to participate in the campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kpiMarketShareActual rdf:type rdf:Property ;
    rdfs:label 'Kpi Market Share Actual' ;
    rdfs:comment 'Observed market-share percentage change achieved by the campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kpiMarketShareTarget rdf:type rdf:Property ;
    rdfs:label 'Kpi Market Share Target' ;
    rdfs:comment 'Target market-share percentage increase for the nameplate during the campaign period.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kpiSalesVolumeActual rdf:type rdf:Property ;
    rdfs:label 'Kpi Sales Volume Actual' ;
    rdfs:comment 'Actual number of vehicles sold attributable to the campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kpiSalesVolumeTarget rdf:type rdf:Property ;
    rdfs:label 'Kpi Sales Volume Target' ;
    rdfs:comment 'Planned number of vehicles to be sold as a result of the campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketingChannels rdf:type rdf:Property ;
    rdfs:label 'Marketing Channels' ;
    rdfs:comment 'Primary channels used to deliver the campaign messaging.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'High-level business objective the campaign aims to achieve (e.g., increase sales volume, improve market share).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetModelYear rdf:type rdf:Property ;
    rdfs:label 'Target Model Year' ;
    rdfs:comment 'Model year of the vehicle nameplate targeted by the campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetNameplate rdf:type rdf:Property ;
    rdfs:label 'Target Nameplate' ;
    rdfs:comment 'Vehicle nameplate (model family) that the campaign is aimed at.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreedPrice rdf:type rdf:Property ;
    rdfs:label 'Agreed Price' ;
    rdfs:comment 'The final negotiated selling price for the vehicle as agreed in the contract, before taxes and fees.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractDate rdf:type rdf:Property ;
    rdfs:label 'Contract Date' ;
    rdfs:comment 'The date when the sales contract was executed and became legally binding. This is the principal business event timestamp for the contract.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractingPartyName rdf:type rdf:Property ;
    rdfs:label 'Contracting Party Name' ;
    rdfs:comment 'Legal name of the selling party (OEM or dealership) as it appears on the contract. Used for legal documentation and compliance.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerLegalName rdf:type rdf:Property ;
    rdfs:label 'Customer Legal Name' ;
    rdfs:comment 'Full legal name of the customer as it appears on the executed contract. May differ from customer master name for legal entities.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference identifier or URI to the physical or digital contract document stored in the document management system.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Down Payment Amount' ;
    rdfs:comment 'Initial payment made by the customer at contract execution. Null for full financing or lease agreements with no down payment.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feesAmount rdf:type rdf:Property ;
    rdfs:label 'Fees Amount' ;
    rdfs:comment 'Total additional fees included in the contract such as documentation fees, registration fees, delivery charges, and dealer administrative fees.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'Annual percentage rate (APR) for financed purchases. Expressed as a decimal (e.g., 0.0499 for 4.99%). Null for cash purchases and leases.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Payment Amount' ;
    rdfs:comment 'Recurring monthly payment amount for financed or leased vehicles. Null for cash purchases.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialTerms rdf:type rdf:Property ;
    rdfs:label 'Special Terms' ;
    rdfs:comment 'Free-text field capturing any special conditions, clauses, or negotiated terms specific to this contract that are not captured in standard fields.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyMileageLimit rdf:type rdf:Property ;
    rdfs:label 'Warranty Mileage Limit' ;
    rdfs:comment 'Maximum mileage covered under warranty terms. Expressed in miles or kilometers depending on region. Null if no mileage limit applies.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyTermMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Term Months' ;
    rdfs:comment 'Duration of warranty coverage in months from delivery date. Null if no warranty is provided.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:repCrmUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rep Crm User Employee Id' ;
    rdfs:comment 'User identifier in Salesforce Automotive Cloud. Used to link sales activities, opportunities, and customer interactions to this representative.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:repEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rep Employee Id' ;
    rdfs:comment 'Human Resources employee identifier linking this sales representative to the workforce management system. Sourced from SuccessFactors HR system.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:repManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rep Manager Employee Id' ;
    rdfs:comment 'Employee identifier of the direct manager or regional sales manager overseeing this sales representative. Used for reporting hierarchy and approval workflows.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activeStatus rdf:type rdf:Property ;
    rdfs:label 'Active Status' ;
    rdfs:comment 'Indicates whether the sales representative is currently active and eligible for lead assignment and quota tracking. False indicates inactive (terminated, on leave, or transferred out of sales).' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionPlanCode rdf:type rdf:Property ;
    rdfs:label 'Commission Plan Code' ;
    rdfs:comment 'Identifier for the incentive compensation plan assigned to the representative. Links to commission structure, bonus tiers, and payout rules in the compensation management system.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmUserCode rdf:type rdf:Property ;
    rdfs:label 'Crm User Code' ;
    rdfs:comment 'User identifier in Salesforce Automotive Cloud. Used to link sales activities, opportunities, and customer interactions to this representative.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetAccountCount rdf:type rdf:Property ;
    rdfs:label 'Fleet Account Count' ;
    rdfs:comment 'Number of fleet or commercial accounts assigned to this representative. Applicable primarily to fleet account managers and national account executives.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languageProficiency rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency' ;
    rdfs:comment 'Comma-separated list of languages the representative is proficient in (e.g., English, Spanish, Mandarin). Used for customer matching and international account assignment.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeLocation rdf:type rdf:Property ;
    rdfs:label 'Office Location' ;
    rdfs:comment 'Primary office or branch location where the representative is based (e.g., Detroit HQ, Los Angeles Regional Office, Remote). Used for travel planning and regional coordination.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSpecialization rdf:type rdf:Property ;
    rdfs:label 'Product Specialization' ;
    rdfs:comment 'Primary product line or vehicle segment specialization (e.g., Electric Vehicles, Commercial Trucks, Luxury Sedans, SUVs, Performance Vehicles). Used for lead routing and expert assignment in Salesforce Automotive Cloud.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaAmount rdf:type rdf:Property ;
    rdfs:label 'Quota Amount' ;
    rdfs:comment 'Annual or period-based sales quota target assigned to the representative, expressed in the base currency. Used for performance measurement and incentive compensation calculation.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaCurrency rdf:type rdf:Property ;
    rdfs:label 'Quota Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the quota amount (e.g., USD, EUR, JPY). Supports multi-currency sales operations.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaPeriod rdf:type rdf:Property ;
    rdfs:label 'Quota Period' ;
    rdfs:comment 'Time period over which the quota is measured (annual, quarterly, or monthly). Aligns with fiscal year and performance review cycles.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRole rdf:type rdf:Property ;
    rdfs:label 'Sales Role' ;
    rdfs:comment 'Functional sales role classification defining the representative\'s primary responsibility area. Retail field reps manage dealer relationships, fleet account managers handle commercial fleet sales, national account executives manage large enterprise accounts, export sales covers international markets, regional sales managers oversee territories, and dealer development focuses on dealer network expansion.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesStartDate rdf:type rdf:Property ;
    rdfs:label 'Sales Start Date' ;
    rdfs:comment 'Date the representative began their current sales role or territory assignment. May differ from hire_date if the employee transferred from another department or role.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workArrangement rdf:type rdf:Property ;
    rdfs:label 'Work Arrangement' ;
    rdfs:comment 'Primary work location arrangement. Field-based representatives spend majority of time visiting dealers or customers; office-based work from regional offices; hybrid split time; remote work from home.' ;
    rdfs:domain ind:Rep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySalesManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Manager Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySalesRegionalDirectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Sales Regional Director Employee Id' ;
    rdfs:comment 'Identifier of the regional director overseeing this territory. Represents the next level of sales leadership hierarchy.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualQuotaRevenue rdf:type rdf:Property ;
    rdfs:label 'Annual Quota Revenue' ;
    rdfs:comment 'Annual revenue quota target for this territory in the base currency. Represents expected sales value including MSRP and incentives.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualQuotaUnits rdf:type rdf:Property ;
    rdfs:label 'Annual Quota Units' ;
    rdfs:comment 'Annual sales quota for this territory measured in vehicle units. Used for performance tracking and incentive calculation.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitiveIntensity rdf:type rdf:Property ;
    rdfs:label 'Competitive Intensity' ;
    rdfs:comment 'Assessment of competitive pressure in the territory based on number of competing brands, dealer density, and market share dynamics.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdCount rdf:type rdf:Property ;
    rdfs:label 'Household Count' ;
    rdfs:comment 'Number of households in the territory. Key metric for retail automotive market potential analysis.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medianHouseholdIncome rdf:type rdf:Property ;
    rdfs:label 'Median Household Income' ;
    rdfs:comment 'Median household income in the territory. Used for market segmentation and product mix planning (luxury vs. mass market).' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelYearFocus rdf:type rdf:Property ;
    rdfs:label 'Model Year Focus' ;
    rdfs:comment 'Primary model year of vehicles being sold in this territory (e.g., MY2024, MY2025). Reflects inventory and product launch timing.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationCount rdf:type rdf:Property ;
    rdfs:label 'Population Count' ;
    rdfs:comment 'Total population within the territory boundaries. Used for market sizing and potential customer base estimation.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quotaCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Quota Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for quota and revenue targets (e.g., USD, EUR, CNY, JPY).' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesManagerName rdf:type rdf:Property ;
    rdfs:label 'Sales Manager Name' ;
    rdfs:comment 'Full name of the sales manager assigned to this territory for quick reference and reporting.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Sales Office Code' ;
    rdfs:comment 'Code of the primary sales office serving this territory. Links to SAP SD sales organization structure.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleCategoryFocus rdf:type rdf:Property ;
    rdfs:label 'Vehicle Category Focus' ;
    rdfs:comment 'Primary vehicle categories sold in this territory (e.g., \'SUV, Truck\', \'Sedan, EV\', \'Commercial Vehicles\'). Reflects regional demand patterns and product strategy.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleRegistrationCount rdf:type rdf:Property ;
    rdfs:label 'Vehicle Registration Count' ;
    rdfs:comment 'Total number of registered vehicles in the territory. Indicates market saturation and replacement demand potential.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptedDate rdf:type rdf:Property ;
    rdfs:label 'Accepted Date' ;
    rdfs:comment 'Date when the customer and dealership agreed to the trade-in terms and the trade-in was officially accepted.' ;
    rdfs:domain ind:TradeIn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allowance rdf:type rdf:Property ;
    rdfs:label 'Allowance' ;
    rdfs:comment 'Agreed-upon credit amount applied toward the new vehicle purchase, which may differ from appraised value due to negotiation.' ;
    rdfs:domain ind:TradeIn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appraisedValue rdf:type rdf:Property ;
    rdfs:label 'Appraised Value' ;
    rdfs:comment 'Fair market value of the trade-in vehicle as determined by the dealership appraiser, before negotiation.' ;
    rdfs:domain ind:TradeIn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionGrade rdf:type rdf:Property ;
    rdfs:label 'Condition Grade' ;
    rdfs:comment 'Overall condition assessment of the trade-in vehicle based on physical inspection (excellent, good, fair, poor).' ;
    rdfs:domain ind:TradeIn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionAmount rdf:type rdf:Property ;
    rdfs:label 'Disposition Amount' ;
    rdfs:comment 'Actual sale or disposal amount realized when the trade-in vehicle was disposed of, used to calculate trade-in profitability.' ;
    rdfs:domain ind:TradeIn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exteriorCondition rdf:type rdf:Property ;
    rdfs:label 'Exterior Condition' ;
    rdfs:comment 'Assessment of the exterior body condition of the trade-in vehicle (paint, body panels, glass).' ;
    rdfs:domain ind:TradeIn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCompleted rdf:type rdf:Property ;
    rdfs:label 'Inspection Completed' ;
    rdfs:comment 'Indicates whether a full mechanical and safety inspection was completed on the trade-in vehicle (True/False).' ;
    rdfs:domain ind:TradeIn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interiorCondition rdf:type rdf:Property ;
    rdfs:label 'Interior Condition' ;
    rdfs:comment 'Assessment of the interior condition of the trade-in vehicle (seats, dashboard, carpets, controls).' ;
    rdfs:domain ind:TradeIn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lienHolder rdf:type rdf:Property ;
    rdfs:label 'Lien Holder' ;
    rdfs:comment 'Name of the financial institution or entity holding a lien on the trade-in vehicle, if applicable.' ;
    rdfs:domain ind:TradeIn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mechanicalCondition rdf:type rdf:Property ;
    rdfs:label 'Mechanical Condition' ;
    rdfs:comment 'Assessment of the mechanical and operational condition of the trade-in vehicle (engine, transmission, drivetrain).' ;
    rdfs:domain ind:TradeIn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingLoanBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Loan Balance' ;
    rdfs:comment 'Remaining loan balance owed on the trade-in vehicle at the time of trade, if applicable.' ;
    rdfs:domain ind:TradeIn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconditioningCost rdf:type rdf:Property ;
    rdfs:label 'Reconditioning Cost' ;
    rdfs:comment 'Total cost incurred to recondition the trade-in vehicle for resale (repairs, detailing, inspection).' ;
    rdfs:domain ind:TradeIn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceRecordsAvailable rdf:type rdf:Property ;
    rdfs:label 'Service Records Available' ;
    rdfs:comment 'Indicates whether complete service and maintenance records are available for the trade-in vehicle (True/False).' ;
    rdfs:domain ind:TradeIn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeInNumber rdf:type rdf:Property ;
    rdfs:label 'Trade In Number' ;
    rdfs:comment 'Business-facing unique transaction number assigned to the trade-in for tracking and reference purposes.' ;
    rdfs:domain ind:TradeIn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderSalesRepEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Order Sales Rep Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Order Responsibility Report tracks which employee (sales rep) is accountable for each vehicle order.' ;
    rdfs:domain ind:VehicleOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryTestEventId rdf:type rdf:Property ;
    rdfs:label 'Primary Test Event Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_test_event. Business justification: Order fulfillment includes traceability to the primary compliance test event that validated the vehicle before delivery.' ;
    rdfs:domain ind:VehicleOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestEvent .

ind:buildWeek rdf:type rdf:Property ;
    rdfs:label 'Build Week' ;
    rdfs:comment 'Scheduled production week for the vehicle in ISO week format (YYYYWWW). Represents the planned Start of Production (SOP) week.' ;
    rdfs:domain ind:VehicleOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Committed Delivery Date' ;
    rdfs:comment 'OEM-committed delivery date communicated to the customer. Represents the contractual delivery obligation.' ;
    rdfs:domain ind:VehicleOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Date' ;
    rdfs:comment 'Date when the order was confirmed by the OEM and accepted into the production schedule. Represents the commitment to fulfill the order.' ;
    rdfs:domain ind:VehicleOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Financing Reference Number' ;
    rdfs:comment 'External reference number for the financing or lease agreement associated with this vehicle order. Links to the financial institution contract.' ;
    rdfs:domain ind:VehicleOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellingPrice rdf:type rdf:Property ;
    rdfs:label 'Selling Price' ;
    rdfs:comment 'Final agreed selling price for the vehicle after all discounts, incentives, rebates, and negotiations. Represents the actual transaction price.' ;
    rdfs:domain ind:VehicleOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:winLossId rdf:type rdf:Property ;
    rdfs:label 'Win Loss Id' ;
    rdfs:comment 'Unique identifier for the win/loss analysis record. Primary key.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analysisStatus rdf:type rdf:Property ;
    rdfs:label 'Analysis Status' ;
    rdfs:comment 'Current status of the win/loss analysis record in the review workflow.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorModel rdf:type rdf:Property ;
    rdfs:label 'Competitor Model' ;
    rdfs:comment 'Specific vehicle model from the competitor that the customer selected instead of our offering.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorModelYear rdf:type rdf:Property ;
    rdfs:label 'Competitor Model Year' ;
    rdfs:comment 'Model year of the competitor vehicle selected by the customer.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitorPrice rdf:type rdf:Property ;
    rdfs:label 'Competitor Price' ;
    rdfs:comment 'Reported selling price of the competitor vehicle, if known. Used for competitive pricing analysis.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerDecisionFactorAvailability rdf:type rdf:Property ;
    rdfs:label 'Customer Decision Factor Availability' ;
    rdfs:comment 'Indicates whether vehicle availability and delivery timing were a significant factor in the customer\'s decision.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerDecisionFactorBrand rdf:type rdf:Property ;
    rdfs:label 'Customer Decision Factor Brand' ;
    rdfs:comment 'Indicates whether brand reputation and loyalty were a significant factor in the customer\'s decision.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerDecisionFactorFeatures rdf:type rdf:Property ;
    rdfs:label 'Customer Decision Factor Features' ;
    rdfs:comment 'Indicates whether vehicle features and specifications were a significant factor in the customer\'s decision.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerDecisionFactorFinancing rdf:type rdf:Property ;
    rdfs:label 'Customer Decision Factor Financing' ;
    rdfs:comment 'Indicates whether financing terms and options were a significant factor in the customer\'s decision.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerDecisionFactorPrice rdf:type rdf:Property ;
    rdfs:label 'Customer Decision Factor Price' ;
    rdfs:comment 'Indicates whether price was a significant factor in the customer\'s decision.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerDecisionFactorService rdf:type rdf:Property ;
    rdfs:label 'Customer Decision Factor Service' ;
    rdfs:comment 'Indicates whether after-sales service and dealer support were a significant factor in the customer\'s decision.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dealValue rdf:type rdf:Property ;
    rdfs:label 'Deal Value' ;
    rdfs:comment 'Total monetary value of the opportunity at the time of closure. For won deals, this is the actual sale amount; for lost deals, this is the estimated value.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outcomeDate rdf:type rdf:Property ;
    rdfs:label 'Outcome Date' ;
    rdfs:comment 'Date when the final outcome was determined and the opportunity was closed.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcomeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Outcome Timestamp' ;
    rdfs:comment 'Precise timestamp when the opportunity outcome was recorded in the system.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primaryReasonCode rdf:type rdf:Property ;
    rdfs:label 'Primary Reason Code' ;
    rdfs:comment 'Standardized code representing the primary reason for the win or loss outcome. Used for structured analysis and reporting.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Primary Reason Description' ;
    rdfs:comment 'Detailed explanation of the primary reason for the outcome, providing context beyond the standardized code.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Reviewed By User Code' ;
    rdfs:comment 'Reference to the user who reviewed and approved the win/loss analysis.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewedDate rdf:type rdf:Property ;
    rdfs:label 'Reviewed Date' ;
    rdfs:comment 'Date when the win/loss analysis was reviewed and approved.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesRepAssessment rdf:type rdf:Property ;
    rdfs:label 'Sales Rep Assessment' ;
    rdfs:comment 'Qualitative assessment and commentary from the sales representative regarding the outcome, including insights on customer behavior, competitive dynamics, and lessons learned.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryReasonCode rdf:type rdf:Property ;
    rdfs:label 'Secondary Reason Code' ;
    rdfs:comment 'Standardized code for a contributing secondary reason for the outcome, if applicable.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Secondary Reason Description' ;
    rdfs:comment 'Detailed explanation of the secondary contributing reason for the outcome.' ;
    rdfs:domain ind:WinLoss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ckdKitId rdf:type rdf:Property ;
    rdfs:label 'Ckd Kit Id' ;
    rdfs:comment 'System-generated unique identifier for the CKD/SKD kit record.' ;
    rdfs:domain ind:CkdKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispatchDate rdf:type rdf:Property ;
    rdfs:label 'Dispatch Date' ;
    rdfs:comment 'Date the kit was dispatched from the supplier or warehouse.' ;
    rdfs:domain ind:CkdKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exportCustomsClassification rdf:type rdf:Property ;
    rdfs:label 'Export Customs Classification' ;
    rdfs:comment 'Harmonized System code used for customs clearance of the exported kit.' ;
