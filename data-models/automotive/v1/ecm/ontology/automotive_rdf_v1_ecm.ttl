    rdfs:range xsd:string .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'Exact date-time when the customer submitted the survey.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceAdvisorScore rdf:type rdf:Property ;
    rdfs:label 'Service Advisor Score' ;
