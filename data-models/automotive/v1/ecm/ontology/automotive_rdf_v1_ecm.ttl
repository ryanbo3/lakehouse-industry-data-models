ind:planCostSharePercent rdf:type rdf:Property ;
    rdfs:label 'Plan Cost Share Percent' ;
    rdfs:comment 'Percentage of the premium cost shared by the employee.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planEnrollmentWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Plan Enrollment Window End' ;
