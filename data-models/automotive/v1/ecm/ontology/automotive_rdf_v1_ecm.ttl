    rdfs:range ind:Change .

ind:connectedVehicleId rdf:type rdf:Property ;
    rdfs:label 'Connected Vehicle Id' ;
    rdfs:comment 'Foreign key linking to mobility.connected_vehicle. Business justification: Remote Diagnostic Session process requires linking a repair order to the specific connected vehicle for OTA updates and diagnostics.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConnectedVehicle .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Identifier of the service advisor who created the repair order.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:inspectionLotId rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection_lot. Business justification: Repair orders are created when a quality inspection lot fails; linking provides the Inspection-to-Repair Traceability Report.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionLot .

ind:procurementPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Procurement Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Needed for Repair Order Cost Tracking report to associate parts spend on a repair with the originating purchase order.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementPurchaseOrder .

ind:recallCampaignId rdf:type rdf:Property ;
