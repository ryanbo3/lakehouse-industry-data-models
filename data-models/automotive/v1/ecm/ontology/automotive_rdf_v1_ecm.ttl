    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimResolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Claim Resolution Timestamp' ;
    rdfs:comment 'Timestamp when the claim was resolved (approved, rejected, or settled).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User identifier of the employee who created the claim.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCategory rdf:type rdf:Property ;
    rdfs:label 'Defect Category' ;
    rdfs:comment 'High-level category of the reported defect.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
