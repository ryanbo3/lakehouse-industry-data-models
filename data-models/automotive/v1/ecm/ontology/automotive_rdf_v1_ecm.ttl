    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignment rdf:type rdf:Property ;
    rdfs:label 'Assignment' ;
    rdfs:comment 'User-defined assignment field for additional categorisation (e.g., cost object).' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCc rdf:type rdf:Property ;
    rdfs:label 'Currency Cc' ;
