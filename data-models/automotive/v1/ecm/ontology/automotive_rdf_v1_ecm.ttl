    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCodeDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Code Description' ;
    rdfs:comment 'Detailed textual description of the defect.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCodeName rdf:type rdf:Property ;
    rdfs:label 'Defect Code Name' ;
    rdfs:comment 'Human-readable name describing the defect.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Typical method used to detect the defect.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCompliance rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance' ;
    rdfs:comment 'Regulatory framework(s) the defect code complies with.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityDefault rdf:type rdf:Property ;
    rdfs:label 'Severity Default' ;
    rdfs:comment 'Default severity rating assigned to the defect.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalResolutionTimeDays rdf:type rdf:Property ;
    rdfs:label 'Typical Resolution Time Days' ;
    rdfs:comment 'Average number of days to resolve the defect after detection.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyImplication rdf:type rdf:Property ;
    rdfs:label 'Warranty Implication' ;
    rdfs:comment 'Impact of the defect on warranty obligations.' ;
    rdfs:domain ind:DefectCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Defect Record Status' ;
    rdfs:comment 'Current lifecycle status of the defect record.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectType rdf:type rdf:Property ;
    rdfs:label 'Defect Type' ;
    rdfs:comment 'Classification of the defect by its origin or nature.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'Date and time when the defect was first observed.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:investigationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigation End Timestamp' ;
    rdfs:comment 'Timestamp when the investigation was concluded.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:investigationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Timestamp' ;
    rdfs:comment 'Timestamp when the root-cause investigation began.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isRepeatDefect rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Defect' ;
    rdfs:comment 'Flag indicating whether this defect has been observed previously.' ;
    rdfs:domain ind:DefectRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppmRate rdf:type rdf:Property ;
    rdfs:label 'Ppm Rate' ;
    rdfs:comment 'Defect rate expressed in parts per million for quality metrics.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityAffected rdf:type rdf:Property ;
    rdfs:label 'Quantity Affected' ;
    rdfs:comment 'Number of units or parts impacted by the defect.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Action Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: FMEA action owner must be a responsible employee; linking enables tracking accountability in corrective action reports.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:componentId rdf:type rdf:Property ;
    rdfs:label 'Component Id' ;
    rdfs:comment 'Unique identifier of the vehicle component or part to which the FMEA applies.' ;
    rdfs:domain ind:Fmea ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngineeringBomComponent .

ind:analysisNumber rdf:type rdf:Property ;
    rdfs:label 'Analysis Number' ;
    rdfs:comment 'External reference number assigned to the FMEA analysis, used for tracking across systems.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
