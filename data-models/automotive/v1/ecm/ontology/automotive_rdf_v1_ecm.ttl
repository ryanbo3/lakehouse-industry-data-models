    rdfs:comment 'Level of service features and data allowances granted to the subscriber.' ;
    rdfs:domain ind:ServiceSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextPaymentDue rdf:type rdf:Property ;
