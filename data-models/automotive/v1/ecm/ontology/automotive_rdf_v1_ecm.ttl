    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Fuel Level Percent' ;
    rdfs:comment 'Fuel tank level as a percentage at the time of the event.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTestEvent rdf:type rdf:Property ;
    rdfs:label 'Is Test Event' ;
    rdfs:comment 'True if the DTC record originates from a test or diagnostic simulation.' ;
    rdfs:domain ind:AftersalesDtcEvent ;
    rdf:type owl:DatatypeProperty ;
