ind:laneCode rdf:type rdf:Property ;
    rdfs:label 'Lane Code' ;
    rdfs:comment 'Alphanumeric identifier for the transportation lane (e.g., "DET-LAX").' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneType rdf:type rdf:Property ;
    rdfs:label 'Lane Type' ;
    rdfs:comment 'Indicates whether the lane is domestic, export, or import.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeDeliveryRatePct rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate Pct' ;
    rdfs:comment 'Percentage of shipments delivered within the agreed delivery window, calculated independently of OTD for cross-validation.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otdRatePct rdf:type rdf:Property ;
    rdfs:label 'Otd Rate Pct' ;
    rdfs:comment 'Percentage of shipments delivered on or before the committed delivery date for the period.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'Composite score (1-5) summarizing carrier performance across all metrics.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMonth rdf:type rdf:Property ;
    rdfs:label 'Performance Month' ;
    rdfs:comment 'Calendar month (first day) representing the reporting period for the carrier performance metrics.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalClaims rdf:type rdf:Property ;
    rdfs:label 'Total Claims' ;
    rdfs:comment 'Aggregate count of all claims (damage, loss, etc.) for the period.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDamageUnits rdf:type rdf:Property ;
    rdfs:label 'Total Damage Units' ;
    rdfs:comment 'Sum of individual units reported as damaged during the period.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Total Distance Km' ;
    rdfs:comment 'Total kilometers driven or sailed by the carrier for shipments on this lane in the period.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalShipments rdf:type rdf:Property ;
    rdfs:label 'Total Shipments' ;
    rdfs:comment 'Count of individual shipments moved by the carrier on the lane during the period.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitTimeCompliancePct rdf:type rdf:Property ;
    rdfs:label 'Transit Time Compliance Pct' ;
    rdfs:comment 'Percentage of shipments that met the agreed-upon transit-time windows.' ;
    rdfs:domain ind:CarrierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ckdKitShipmentId rdf:type rdf:Property ;
    rdfs:label 'Ckd Kit Shipment Id' ;
    rdfs:comment 'System generated unique identifier for the CKD kit shipment record.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CkdKitShipment .

ind:originPlantId rdf:type rdf:Property ;
    rdfs:label 'Origin Plant Id' ;
    rdfs:comment 'FK to manufacturing.plant' ;
    rdfs:domain ind:CkdKitShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Foreign key linking to logistics.shipment. Business justification: CKD/SKD kit shipments are a type of outbound shipment; linking to shipment consolidates tracking and cost reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Real-time timestamp when the shipment arrived at the destination plant.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Real-time timestamp when the shipment left the origin plant.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bomReference rdf:type rdf:Property ;
    rdfs:label 'Bom Reference' ;
    rdfs:comment 'Reference to the BOM that defines the components of the kit.' ;
    rdfs:domain ind:CkdKitShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsInvoiceCurrency rdf:type rdf:Property ;
    rdfs:label 'Customs Invoice Currency' ;
    rdfs:comment 'ISO 4217 currency code of the customs invoice value.' ;
    rdfs:domain ind:CkdKitShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsInvoiceValue rdf:type rdf:Property ;
    rdfs:label 'Customs Invoice Value' ;
    rdfs:comment 'Declared monetary value of the shipment for customs purposes.' ;
    rdfs:domain ind:CkdKitShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:delayReason rdf:type rdf:Property ;
    rdfs:label 'Delay Reason' ;
    rdfs:comment 'Free-text explanation for any delay affecting the shipment.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Export License Number' ;
    rdfs:comment 'Reference number of the export license authorizing the shipment.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialType rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Type' ;
    rdfs:comment 'Classification of hazardous material (e.g., flammable, toxic).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCode rdf:type rdf:Property ;
    rdfs:label 'Hs Code' ;
    rdfs:comment 'International tariff code for the kit contents.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'Incoterms rule governing responsibility and cost allocation. [ENUM-REF-CANDIDATE: EXW|FCA|FOB|CFR|CIF|DAP|DDP — promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitPartNumber rdf:type rdf:Property ;
    rdfs:label 'Kit Part Number' ;
    rdfs:comment 'Part number that uniquely identifies the CKD/SKD kit configuration.' ;
    rdfs:domain ind:CkdKitShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitQuantityPerContainer rdf:type rdf:Property ;
    rdfs:label 'Kit Quantity Per Container' ;
    rdfs:comment 'Number of kits packed in each container.' ;
    rdfs:domain ind:CkdKitShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netCost rdf:type rdf:Property ;
    rdfs:label 'Net Cost' ;
    rdfs:comment 'Net freight cost after discounts (freight_cost - discount_amount).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfKits rdf:type rdf:Property ;
    rdfs:label 'Number Of Kits' ;
    rdfs:comment 'Count of CKD/SKD kits included in the shipment.' ;
    rdfs:domain ind:CkdKitShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packingListReference rdf:type rdf:Property ;
    rdfs:label 'Packing List Reference' ;
    rdfs:comment 'Reference to the packing list document for the kit.' ;
    rdfs:domain ind:CkdKitShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Timestamp' ;
    rdfs:comment 'Scheduled date and time for shipment arrival at the destination plant.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Timestamp' ;
    rdfs:comment 'Scheduled date and time for shipment departure from the origin plant.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Security seal identifier applied to the container.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Business identifier assigned to the shipment by the logistics system.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Maximum temperature to be maintained inside the container.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Minimum temperature to be maintained inside the container.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'External tracking identifier provided by the carrier.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic Meters' ;
    rdfs:comment 'Total cargo volume of the shipment.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compoundMovementId rdf:type rdf:Property ;
    rdfs:label 'Compound Movement Id' ;
    rdfs:comment 'Surrogate primary key for the compound movement record.' ;
    rdfs:domain ind:CompoundMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleCompoundId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Compound Id' ;
    rdfs:comment 'Foreign key linking to logistics.vehicle_compound. Business justification: Compound movements occur within a vehicle compound; adding vehicle_compound_id links movements to their compound.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleCompound .

ind:compoundMovementStatus rdf:type rdf:Property ;
    rdfs:label 'Compound Movement Status' ;
    rdfs:comment 'Current lifecycle status of the movement.' ;
    rdfs:domain ind:CompoundMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayMinutes rdf:type rdf:Property ;
    rdfs:label 'Delay Minutes' ;
    rdfs:comment 'Minutes of delay between ETA and actual arrival.' ;
    rdfs:domain ind:CompoundMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationZone rdf:type rdf:Property ;
    rdfs:label 'Destination Zone' ;
    rdfs:comment 'Yard or bay where the vehicle is moved to.' ;
    rdfs:domain ind:CompoundMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Timestamp' ;
    rdfs:comment 'Expected arrival time at the destination zone.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadQuantity rdf:type rdf:Property ;
    rdfs:label 'Load Quantity' ;
    rdfs:comment 'Number of units moved in this transaction (typically 1).' ;
    rdfs:domain ind:CompoundMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movementReference rdf:type rdf:Property ;
    rdfs:label 'Movement Reference' ;
    rdfs:comment 'External reference number used by logistics to identify the movement transaction.' ;
    rdfs:domain ind:CompoundMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Movement Timestamp' ;
    rdfs:comment 'Date and time when the movement event occurred.' ;
    rdfs:domain ind:CompoundMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'Indicates whether the vehicle is entering, leaving, or being transferred within the compound.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originZone rdf:type rdf:Property ;
    rdfs:label 'Origin Zone' ;
    rdfs:comment 'Yard or bay where the vehicle originated.' ;
    rdfs:domain ind:CompoundMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureC rdf:type rdf:Property ;
    rdfs:label 'Temperature C' ;
    rdfs:comment 'Temperature in the yard at the time of movement.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Transport Order Number' ;
    rdfs:comment 'Reference to the transport order governing the movement.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logisticsDeliveryScheduleId rdf:type rdf:Property ;
    rdfs:label 'Logistics Delivery Schedule Id' ;
    rdfs:comment 'Unique identifier for the delivery_schedule data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LogisticsDeliverySchedule .

ind:routeId rdf:type rdf:Property ;
    rdfs:label 'Route Id' ;
    rdfs:comment 'Identifier for the transportation route used for the delivery.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Automotive .

ind:schedulerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Scheduler Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Delivery Scheduling system records which employee created/maintains each schedule for audit and performance metrics.' ;
    rdfs:domain ind:LogisticsDeliverySchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:arrivalDate rdf:type rdf:Property ;
    rdfs:label 'Arrival Date' ;
    rdfs:comment 'Scheduled date for the vehicles to arrive at the dealer location.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costActual rdf:type rdf:Property ;
    rdfs:label 'Cost Actual' ;
    rdfs:comment 'Final cost incurred for the delivery after execution.' ;
    rdfs:domain ind:LogisticsDeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsDocumentRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Document Required' ;
    rdfs:comment 'True if customs paperwork is required for the shipment.' ;
    rdfs:domain ind:LogisticsDeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End' ;
    rdfs:comment 'End of the agreed delivery time window at the dealer.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowStart rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start' ;
    rdfs:comment 'Start of the agreed delivery time window at the dealer.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureDate rdf:type rdf:Property ;
    rdfs:label 'Departure Date' ;
    rdfs:comment 'Scheduled date for the vehicles to leave the plant or compound.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exportImportFlag rdf:type rdf:Property ;
    rdfs:label 'Export Import Flag' ;
    rdfs:comment 'Indicates whether the shipment is export, import, or domestic.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightClass rdf:type rdf:Property ;
    rdfs:label 'Freight Class' ;
    rdfs:comment 'Classification of freight for tariff and handling purposes.' ;
    rdfs:domain ind:LogisticsDeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'International commercial terms governing the delivery responsibilities.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExpedited rdf:type rdf:Property ;
    rdfs:label 'Is Expedited' ;
    rdfs:comment 'Indicates whether the delivery is expedited (true) or standard (false).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazardous rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous' ;
    rdfs:comment 'True if the shipment contains hazardous materials requiring special handling.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMileDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Last Mile Delivery Method' ;
    rdfs:comment 'Method used for the final leg of delivery to the dealer or customer.' ;
    rdfs:domain ind:LogisticsDeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logisticsDeliveryScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Logistics Delivery Schedule Status' ;
    rdfs:comment 'Current lifecycle state of the delivery schedule.' ;
    rdfs:domain ind:LogisticsDeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otdActualDate rdf:type rdf:Property ;
    rdfs:label 'Otd Actual Date' ;
    rdfs:comment 'Actual date when the delivery was completed for OTD measurement.' ;
    rdfs:domain ind:LogisticsDeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:otdTargetDate rdf:type rdf:Property ;
    rdfs:label 'Otd Target Date' ;
    rdfs:comment 'Target date for achieving on-time delivery performance.' ;
    rdfs:domain ind:LogisticsDeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'Number of vehicles (or units) scheduled for delivery.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleHorizon rdf:type rdf:Property ;
    rdfs:label 'Schedule Horizon' ;
    rdfs:comment 'Planning horizon for the schedule (e.g., weekly, monthly).' ;
    rdfs:domain ind:LogisticsDeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Business identifier assigned to the delivery schedule, used for tracking and communication with dealers and carriers.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleTimestamp rdf:type rdf:Property ;
    rdfs:label 'Schedule Timestamp' ;
    rdfs:comment 'Timestamp when the delivery schedule was initially created in the system.' ;
    rdfs:domain ind:LogisticsDeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Timestamp' ;
    rdfs:comment 'Planned exact timestamp for arrival, including time of day.' ;
    rdfs:domain ind:LogisticsDeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Timestamp' ;
    rdfs:comment 'Planned exact timestamp for departure, including time of day.' ;
    rdfs:domain ind:LogisticsDeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:volumeCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Cbm' ;
    rdfs:comment 'Aggregate cargo volume in cubic meters.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exportDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Export Declaration Id' ;
    rdfs:comment 'System-generated unique identifier for the export declaration record.' ;
    rdfs:domain ind:ExportDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exporterPlantId rdf:type rdf:Property ;
    rdfs:label 'Exporter Plant Id' ;
    rdfs:comment 'Identifier of the manufacturing plant exporting the goods.' ;
    rdfs:domain ind:ExportDeclaration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:clearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Clearance Status' ;
    rdfs:comment 'Current status of customs clearance for the declaration.' ;
    rdfs:domain ind:ExportDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clearance Timestamp' ;
    rdfs:comment 'Date and time when customs cleared the export declaration.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customsAuthorityReference rdf:type rdf:Property ;
    rdfs:label 'Customs Authority Reference' ;
    rdfs:comment 'Identifier assigned by the customs authority for tracking the declaration.' ;
    rdfs:domain ind:ExportDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationNumber rdf:type rdf:Property ;
    rdfs:label 'Declaration Number' ;
    rdfs:comment 'External reference number assigned by the exporting organization for this declaration.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueAmount rdf:type rdf:Property ;
    rdfs:label 'Declared Value Amount' ;
    rdfs:comment 'Total monetary value declared for customs purposes, before duties and taxes.' ;
    rdfs:domain ind:ExportDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Declared Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the declared value.' ;
    rdfs:domain ind:ExportDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 code of the country receiving the shipment.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyAmount rdf:type rdf:Property ;
    rdfs:label 'Duty Amount' ;
    rdfs:comment 'Duty payable to customs based on the declared value and HS code.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exportDeclarationStatus rdf:type rdf:Property ;
    rdfs:label 'Export Declaration Status' ;
    rdfs:comment 'Current processing state of the export declaration.' ;
    rdfs:domain ind:ExportDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportType rdf:type rdf:Property ;
    rdfs:label 'Export Type' ;
    rdfs:comment 'Category of goods being exported (complete vehicle, CKD kit, SKD kit, or parts).' ;
    rdfs:domain ind:ExportDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netValueAmount rdf:type rdf:Property ;
    rdfs:label 'Net Value Amount' ;
    rdfs:comment 'Declared value after deducting duties and any applicable taxes.' ;
    rdfs:domain ind:ExportDeclaration ;
    rdf:type owl:DatatypeProperty ;
