    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cause rdf:type rdf:Property ;
    rdfs:label 'Cause' ;
    rdfs:comment 'Underlying cause(s) that could lead to the failure mode.' ;
