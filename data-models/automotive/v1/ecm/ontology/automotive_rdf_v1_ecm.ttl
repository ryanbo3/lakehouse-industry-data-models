    rdfs:comment 'Date when the equipment warranty coverage expires.' ;
    rdfs:domain ind:WarrantyClaimEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyCoverageStartDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Coverage Start Date' ;
    rdfs:comment 'Date when the equipment warranty coverage began.' ;
    rdfs:domain ind:WarrantyClaimEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:advancePaymentId rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Id' ;
    rdfs:comment 'Unique identifier for the advance payment record. Primary key.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Advance payments are often applied to a specific invoice; linking provides traceability.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:payerAccountId rdf:type rdf:Property ;
    rdfs:label 'Payer Account Id' ;
    rdfs:comment 'Identifier of the account making the advance payment. May reference dealer, fleet customer, or retail customer account.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:advanceAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Amount' ;
    rdfs:comment 'Total amount of the advance payment received from the payer.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advancePaymentNumber rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Number' ;
    rdfs:comment 'Business-facing unique reference number for the advance payment, used for external communication and tracking.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advanceType rdf:type rdf:Property ;
    rdfs:label 'Advance Type' ;
    rdfs:comment 'Type of advance payment: vehicle deposit, fleet prepayment, dealer advance, booking fee, order deposit, or down payment.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current status of the advance payment application: open (not yet applied), partially applied (some amount applied), fully applied (entire amount applied), refunded (returned to payer), or expired (no longer valid).' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'Cumulative amount of the advance payment that has been applied to invoices or final billing documents.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Reference Number' ;
    rdfs:comment 'Bank transaction reference or confirmation number for the advance payment, used for reconciliation with bank statements.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'Business area or division within the company that the advance payment is attributed to for internal reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'SAP company code representing the legal entity that received the advance payment.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Fiscal period (month) within the fiscal year when the advance payment was received.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'Fiscal year in which the advance payment was received, used for financial period reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'General ledger account code where the advance payment liability is recorded, typically a special GL account for customer down payments.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payerEntityType rdf:type rdf:Property ;
    rdfs:label 'Payer Entity Type' ;
    rdfs:comment 'Classification of the entity making the advance payment: dealer, fleet customer, retail customer, or corporate account.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Date when the advance payment was received from the payer.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'External reference number from the payment processor, bank, or payer system for traceability and reconciliation.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Payment terms code applicable to the transaction for which the advance was received, defining due dates and discount conditions.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment Timestamp' ;
    rdfs:comment 'Precise timestamp when the advance payment transaction was recorded in the system.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Profit center responsible for the revenue associated with this advance payment, used for profitability analysis.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date when the advance payment was successfully reconciled with bank statements and confirmed in the financial system.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status of the advance payment reconciliation with bank statements and financial records: pending, reconciled, discrepancy, or under review.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Amount of the advance payment that has been refunded to the payer due to order cancellation or overpayment.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundDate rdf:type rdf:Property ;
    rdfs:label 'Refund Date' ;
    rdfs:comment 'Date when the advance payment (or portion thereof) was refunded to the payer.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundReasonCode rdf:type rdf:Property ;
    rdfs:label 'Refund Reason Code' ;
    rdfs:comment 'Code indicating the reason for refunding the advance payment, such as order cancellation, overpayment, or customer request.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sales Order Number' ;
    rdfs:comment 'Reference to the sales order document for which this advance payment was received. Links the advance to the vehicle or parts order.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRegionCode rdf:type rdf:Property ;
    rdfs:label 'Sales Region Code' ;
    rdfs:comment 'Geographic sales region code where the advance payment originated, used for regional revenue tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapClearingDocument rdf:type rdf:Property ;
    rdfs:label 'Sap Clearing Document' ;
    rdfs:comment 'SAP FI clearing document number used when the advance payment is applied against an invoice, clearing the down payment liability.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDownPaymentDocument rdf:type rdf:Property ;
    rdfs:label 'Sap Down Payment Document' ;
    rdfs:comment 'SAP FI down payment document number (transaction F-29) that records this advance payment as a special GL transaction.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedBalance rdf:type rdf:Property ;
    rdfs:label 'Unapplied Balance' ;
    rdfs:comment 'Remaining balance of the advance payment that has not yet been applied to invoices or refunded. Calculated as advance_amount minus applied_amount minus refund_amount.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'Date when the funds became available in the company bank account, used for cash flow and treasury management.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vehicleOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Vehicle Order Number' ;
    rdfs:comment 'Specific vehicle order reference number associated with this advance payment, used for vehicle deposits and booking fees.' ;
    rdfs:domain ind:AdvancePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Unique identifier for the billing account. Primary key.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:parentAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Id' ;
    rdfs:comment 'Reference to the parent billing account for hierarchical account structures. Used for corporate accounts with multiple subsidiaries or dealer groups with multiple locations. Null for standalone accounts.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Legal or registered name of the billing party. For dealers, this is the dealership legal entity name. For retail customers, the individual or household name. For fleet/corporate, the company legal name.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-visible unique account number assigned to the billing party. Used on invoices, statements, and payment correspondence. Typically alphanumeric format following internal numbering scheme.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the billing account. Active accounts can transact normally. Suspended accounts have temporary restrictions. Closed accounts are permanently terminated. Pending approval accounts await credit review. Blocked accounts cannot transact due to payment issues. Dormant accounts have no recent activity.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the billing account based on the nature of the billing party. Dealer accounts are for franchise dealerships, retail for individual consumers, fleet for commercial fleet operators, corporate for B2B accounts, government for public sector entities, and export for international distributors.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoPayEnrolledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enrolled Flag' ;
    rdfs:comment 'Indicates whether the account is enrolled in automatic payment processing. True when account has authorized automatic ACH, direct debit, or credit card charges for recurring invoices.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'Primary street address line for billing correspondence and invoice delivery. First line of the billing party\'s registered address.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Secondary address line for suite, apartment, building, or additional location details for billing correspondence.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City or municipality name for the billing address.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Email' ;
    rdfs:comment 'Email address of the primary billing contact person. Used for invoice inquiries, payment confirmations, and account correspondence.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactName rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Name' ;
    rdfs:comment 'Name of the primary billing contact person at the billing party organization. Accounts payable manager, controller, or designated billing representative.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactPhone rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Phone' ;
    rdfs:comment 'Primary phone number for the billing contact. Used for payment inquiries, dispute resolution, and collections communication.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the billing address country (e.g., USA, CAN, MEX, DEU, CHN, JPN).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the billing address. Format varies by country.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State, province, or regional administrative division for the billing address. Format varies by country (e.g., two-letter US state codes, Canadian province codes).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the billing account was permanently closed. Null for active, suspended, or dormant accounts. Set when account status transitions to closed after final settlement.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consolidatedBillingFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidated Billing Flag' ;
    rdfs:comment 'Indicates whether this account receives consolidated invoices combining multiple transactions or sub-accounts into a single statement. Common for fleet and corporate accounts with multiple locations or cost centers.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditCheckDate rdf:type rdf:Property ;
    rdfs:label 'Credit Check Date' ;
    rdfs:comment 'Date of the most recent credit review or credit check performed for this account. Credit reviews are typically performed at account opening, annually, or when credit limit increase is requested.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Exposure Amount' ;
    rdfs:comment 'Current total outstanding receivables balance for this account, including open invoices and unbilled charges. Updated in near-real-time as transactions post. Compared against credit limit for credit control decisions.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum outstanding receivables balance allowed for this account before credit hold is triggered. Expressed in the account\'s base currency. Set by credit management based on creditworthiness assessment.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRatingCode rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Code' ;
    rdfs:comment 'Internal or external credit rating assigned to the billing party. AAA is highest creditworthiness, D is default, NR is not rated. Used for credit limit determination and risk management. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|CC|C|D|NR — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeCountYtd rdf:type rdf:Property ;
    rdfs:label 'Dispute Count Ytd' ;
    rdfs:comment 'Number of billing disputes or invoice challenges raised by this account in the current fiscal year. Used to identify problematic accounts and improve billing accuracy.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionChannelCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Code' ;
    rdfs:comment 'SAP distribution channel code indicating how products reach this account (e.g., direct sales, dealer network, fleet sales, export). Affects pricing and terms determination.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'SAP division code representing the product line or business unit (e.g., passenger vehicles, commercial vehicles, parts, service). Used for revenue segmentation and reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsAccountCode rdf:type rdf:Property ;
    rdfs:label 'Dms Account Code' ;
    rdfs:comment 'External account identifier from the dealer management system (CDK Global DMS) for dealer accounts. Used to link billing account to dealer inventory, service, and F&I transactions. Null for non-dealer account types.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Dunning Block Flag' ;
    rdfs:comment 'Indicates whether automated dunning (collections) notices are blocked for this account. True when account is in dispute resolution, payment plan, or has special handling requirements.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning (collections) level for overdue accounts. Ranges from 0 (no overdue) to higher numbers indicating escalating collection actions. Drives automated dunning letter generation and collection workflow.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Invoice Delivery Method' ;
    rdfs:comment 'Preferred method for delivering invoices and statements to the billing party. Email for electronic delivery, postal mail for paper, EDI for automated B2B integration, portal for self-service access, fax for legacy systems.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Invoice Email Address' ;
    rdfs:comment 'Primary email address for electronic invoice and statement delivery. Used when invoice delivery method is email or as backup contact for portal notifications.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInvoiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Invoice Date' ;
    rdfs:comment 'Date of the most recent invoice issued to this account. Used to identify dormant accounts and track billing activity patterns.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'Amount of the most recent payment received from this account in the account\'s base currency. Used for payment pattern analysis and collections strategy.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent payment received from this account. Used for credit assessment, collections prioritization, and customer relationship management.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date when the billing account was first established and activated. Marks the beginning of the financial relationship.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethodPreference rdf:type rdf:Property ;
    rdfs:label 'Payment Method Preference' ;
    rdfs:comment 'Preferred payment method for this account. Wire transfer and ACH for electronic payments, check for paper payments, credit card for retail, direct debit for recurring charges, letter of credit for export accounts.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Payment Performance Score' ;
    rdfs:comment 'Calculated score (0-100) representing the account\'s payment timeliness and reliability. Based on historical payment patterns, days sales outstanding, and dispute frequency. Higher scores indicate better payment performance.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days from invoice date until payment is due. Derived from payment terms code but stored for reporting convenience.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Sales Organization Code' ;
    rdfs:comment 'SAP sales organization code responsible for this billing account. Defines the organizational unit for sales and distribution processes, pricing, and revenue recognition.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCustomerNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Number' ;
    rdfs:comment 'SAP FI customer account number (KUNNR) in the ERP system. Ten-digit numeric identifier used for financial postings, invoice generation, and payment application. Primary system of record reference.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Registration Number' ;
    rdfs:comment 'Government-issued tax identification number for the billing party. Format varies by jurisdiction (e.g., EIN in USA, GST number in Canada, RFC in Mexico, VAT number in EU). Used for tax reporting and compliance.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Number' ;
    rdfs:comment 'VAT registration identifier for EU and other VAT jurisdictions. Required for cross-border invoicing and VAT reclaim. Format follows country-specific VAT ID structure.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockId rdf:type rdf:Property ;
    rdfs:label 'Block Id' ;
    rdfs:comment 'Unique identifier for the billing block record. Primary key.' ;
    rdfs:domain ind:Block ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Block Employee Id' ;
    rdfs:comment 'User ID or system identifier of the person or automated process that applied the billing block.' ;
    rdfs:domain ind:Block ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:blockReleasedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Block Released By User Employee Id' ;
    rdfs:comment 'User ID or system identifier of the person or automated process that released the billing block.' ;
    rdfs:domain ind:Block ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:disputeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Id' ;
    rdfs:comment 'Identifier of the customer dispute record associated with this billing block, if the block is dispute-related.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dispute .

ind:releasedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Released By User Employee Id' ;
    rdfs:comment 'User ID or system identifier of the person or automated process that released the billing block.' ;
    rdfs:domain ind:Block ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agingDays rdf:type rdf:Property ;
    rdfs:label 'Aging Days' ;
    rdfs:comment 'Number of days the billing block has been active since application, used for aging analysis and escalation triggers.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedByUserName rdf:type rdf:Property ;
    rdfs:label 'Applied By User Name' ;
    rdfs:comment 'Full name of the user who applied the billing block, for business user reference and audit purposes.' ;
    rdfs:domain ind:Block ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedDate rdf:type rdf:Property ;
    rdfs:label 'Applied Date' ;
    rdfs:comment 'Date on which the billing block was applied to the document, preventing invoice generation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appliedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Applied Timestamp' ;
    rdfs:comment 'Precise timestamp when the billing block was applied, including time-of-day for audit and tracking purposes.' ;
    rdfs:domain ind:Block ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:blockNumber rdf:type rdf:Property ;
    rdfs:label 'Block Number' ;
    rdfs:comment 'Business-facing unique identifier or reference number for the billing block, used for tracking and communication purposes.' ;
    rdfs:domain ind:Block ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockStatus rdf:type rdf:Property ;
    rdfs:label 'Block Status' ;
    rdfs:comment 'Current lifecycle status of the billing block. Active blocks prevent invoicing; released blocks have been cleared.' ;
    rdfs:domain ind:Block ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockType rdf:type rdf:Property ;
    rdfs:label 'Block Type' ;
    rdfs:comment 'Category of billing block applied. Indicates the reason category for preventing invoice generation.' ;
    rdfs:domain ind:Block ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Blocked Document Number' ;
    rdfs:comment 'Reference number of the sales order, delivery, or billing account that is blocked from invoicing.' ;
    rdfs:domain ind:Block ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedDocumentType rdf:type rdf:Property ;
    rdfs:label 'Blocked Document Type' ;
    rdfs:comment 'Type of document to which the billing block is applied (e.g., sales order, delivery, billing account).' ;
    rdfs:domain ind:Block ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceHoldReason rdf:type rdf:Property ;
    rdfs:label 'Compliance Hold Reason' ;
    rdfs:comment 'Specific compliance or regulatory reason for the billing hold, such as export control, sanctions screening, or regulatory investigation.' ;
    rdfs:domain ind:Block ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Exceeded Flag' ;
    rdfs:comment 'Indicates whether the billing block was triggered due to the customer exceeding their approved credit limit.' ;
    rdfs:domain ind:Block ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Number' ;
    rdfs:comment 'Delivery document number associated with the billing block, if the block is applied at the delivery level.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'SAP distribution channel through which the blocked billing document was processed (e.g., retail, fleet, wholesale).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:division rdf:type rdf:Property ;
    rdfs:label 'Division' ;
    rdfs:comment 'SAP division or product line associated with the blocked billing document (e.g., passenger vehicles, commercial vehicles, parts).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date on which the billing block was escalated for higher-level review or resolution.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether the billing block has been escalated to management or a specialized resolution team due to age or complexity.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Resolution Date' ;
    rdfs:comment 'Target date by which the billing block is expected to be resolved and released, used for SLA tracking and customer communication.' ;
    rdfs:domain ind:Block ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalHoldCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Case Number' ;
    rdfs:comment 'Case or matter number for legal holds, linking the billing block to a specific legal proceeding or investigation.' ;
    rdfs:domain ind:Block ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Detailed textual description of the reason the billing block was applied, providing context for resolution.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date on which the billing block was released or cleared, allowing invoice generation to proceed.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseNotes rdf:type rdf:Property ;
    rdfs:label 'Release Notes' ;
    rdfs:comment 'Free-text notes or comments entered by the user when releasing the billing block, documenting resolution actions taken.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'Precise timestamp when the billing block was released, including time-of-day for audit and SLA tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releasedByUserName rdf:type rdf:Property ;
    rdfs:label 'Released By User Name' ;
    rdfs:comment 'Full name of the user who released the billing block, for business user reference and audit purposes.' ;
    rdfs:domain ind:Block ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganization rdf:type rdf:Property ;
    rdfs:label 'Sales Organization' ;
    rdfs:comment 'SAP sales organization code responsible for the blocked billing document.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapBillingBlockCode rdf:type rdf:Property ;
    rdfs:label 'Sap Billing Block Code' ;
    rdfs:comment 'SAP SD system billing block code reference. Maps to SAP configuration table for billing block types and controls.' ;
    rdfs:domain ind:Block ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Analyst Employee Id' ;
    rdfs:comment 'Reference to the dispute analyst or customer service representative assigned to investigate and resolve the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:creditMemoId rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Id' ;
    rdfs:comment 'Reference to the credit memo issued as a result of the dispute resolution, if applicable. Null if no credit was issued.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditMemo .

ind:disputingPartyId rdf:type rdf:Property ;
    rdfs:label 'Disputing Party Id' ;
    rdfs:comment 'Reference to the customer, dealer, or fleet operator who raised the dispute. Links to the appropriate master data entity based on disputing_party_type.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'The business unit or division responsible for the disputed invoice (e.g., Parts, Service, Vehicle Sales, Fleet).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address of the primary contact person at the disputing party for correspondence regarding this dispute.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number of the primary contact person at the disputing party for verbal communication regarding this dispute.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditedAmount rdf:type rdf:Property ;
    rdfs:label 'Credited Amount' ;
    rdfs:comment 'The actual monetary amount credited back to the disputing party as a result of the resolution. May be less than, equal to, or zero relative to disputed_amount.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'Externally-known business identifier for the dispute, formatted as DSP- followed by 10 digits. Used in customer and dealer communications.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current lifecycle status of the dispute: open (newly raised), under_review (being investigated), resolved (solution agreed), escalated (sent to higher authority), closed (finalized), withdrawn (cancelled by disputing party).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Classification of the dispute reason: pricing (incorrect price applied), quantity (billed quantity mismatch), quality (defective parts or service), duplicate (duplicate billing), unauthorized_charge (charge not authorized), warranty (warranty coverage dispute).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'The monetary value being contested by the disputing party, in the invoice currency.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputingPartyType rdf:type rdf:Property ;
    rdfs:label 'Disputing Party Type' ;
    rdfs:comment 'Classification of the entity raising the dispute: dealer (authorized dealer), fleet_operator (commercial fleet customer), retail_customer (individual buyer), internal (internal business unit).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'The current escalation tier of the dispute: 0 (no escalation), 1 (supervisor review), 2 (manager review), 3 (director review), 4 (executive review).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Explanation of why the dispute required escalation beyond the initial analyst level.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp when this dispute record was last updated in the system, in ISO 8601 format.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'The date when the dispute was formally raised and entered into the system.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Precise date and time when the dispute was received by the billing department, in ISO 8601 format.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Three-letter geographic region code where the disputing party is located (e.g., USA, EUR, CHN).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The date when the dispute was resolved and a final decision was communicated to the disputing party.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Detailed explanation of the resolution decision, actions taken, and justification for the outcome.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'The outcome classification of the dispute resolution: accepted (dispute valid, full credit issued), rejected (dispute invalid, no action), partial_credit (compromise reached), adjustment (invoice corrected), waiver (charge waived as goodwill).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Classification of the underlying cause identified during dispute investigation: billing_error, system_error, data_entry_error, policy_misunderstanding, delivery_issue, quality_issue.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether the dispute resolution exceeded the SLA target resolution time. True if breached, False if within SLA.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetResolutionDays rdf:type rdf:Property ;
    rdfs:label 'Sla Target Resolution Days' ;
    rdfs:comment 'The number of business days within which the dispute should be resolved according to the applicable SLA policy.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportingDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Count' ;
    rdfs:comment 'The number of supporting documents (invoices, delivery notes, quality reports, photos) attached to the dispute case.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runId rdf:type rdf:Property ;
    rdfs:label 'Run Id' ;
    rdfs:comment 'Unique identifier for the billing run batch execution. Primary key.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By User Employee Id' ;
    rdfs:comment 'User ID of the supervisor or manager who approved the billing run for execution, required for high-value or correction runs.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:billingPeriodId rdf:type rdf:Property ;
    rdfs:label 'Billing Period Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_period. Business justification: A billing run belongs to a billing period; linking run to billing_period clarifies the period context.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingPeriod .

ind:runApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Run Approved By User Employee Id' ;
    rdfs:comment 'User ID of the supervisor or manager who approved the billing run for execution, required for high-value or correction runs.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:runEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Run Employee Id' ;
    rdfs:comment 'User ID or system account that triggered the billing run, used for audit trail and accountability.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:batchJobReference rdf:type rdf:Property ;
    rdfs:label 'Batch Job Reference' ;
    rdfs:comment 'SAP batch job ID or scheduler job reference for the billing run execution, used for technical troubleshooting and job monitoring.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCategory rdf:type rdf:Property ;
    rdfs:label 'Billing Category' ;
    rdfs:comment 'Business classification of the billing scope: vehicle_sales (retail and dealer vehicle invoices), parts (OEM parts and accessories), service (after-sales maintenance and repair), fleet (corporate fleet accounts), export (international sales), warranty (warranty claim reimbursements), lease (leasing contracts), or rental (vehicle rental charges). [ENUM-REF-CANDIDATE: vehicle_sales|parts|service|fleet|export|warranty|lease|rental — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDate rdf:type rdf:Property ;
    rdfs:label 'Billing Date' ;
    rdfs:comment 'The business date on which invoices in this run are dated and become effective for accounting and payment terms calculation. Determines invoice due dates and fiscal period assignment.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingDueListReference rdf:type rdf:Property ;
    rdfs:label 'Billing Due List Reference' ;
    rdfs:comment 'SAP SD transaction VF04 billing due list execution reference number, linking this run to the SAP billing due list selection and processing log.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingEntityCode rdf:type rdf:Property ;
    rdfs:label 'Billing Entity Code' ;
    rdfs:comment 'Code identifying the legal entity or company code issuing the invoices in this run, used for multi-entity OEM structures and regional billing organizations.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the billing period covered by this run, defining the cutoff for transactions included in the batch.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the billing period covered by this run, used for periodic billing cycles (e.g., monthly vehicle sales, service contracts).' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ediTransmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Transmission Status' ;
    rdfs:comment 'Status of EDI 810 invoice transmission for this billing run: not_applicable (no EDI invoices), pending (queued), transmitted (sent to trading partners), acknowledged (receipt confirmed), or failed (transmission error).' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCount rdf:type rdf:Property ;
    rdfs:label 'Error Count' ;
    rdfs:comment 'Total number of errors encountered during the billing run execution, including validation errors, data quality issues, and system exceptions.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outputFormat rdf:type rdf:Property ;
    rdfs:label 'Output Format' ;
    rdfs:comment 'Primary output format for invoices generated in this run: pdf (electronic document), xml (structured data), edi (EDI 810 invoice), print (physical mail), or email (direct delivery).' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printQueueName rdf:type rdf:Property ;
    rdfs:label 'Print Queue Name' ;
    rdfs:comment 'Name of the SAP output device or print queue to which invoices were sent for physical printing and mailing.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'Date on which the billing run was reversed and credit memos were issued to cancel the original invoices.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this billing run was subsequently reversed or cancelled, requiring credit memo generation and financial adjustment.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Code indicating the reason for billing run reversal (e.g., pricing error, wrong billing date, duplicate run, system error).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Human-readable business identifier for the billing run, typically formatted as BR-YYYYMMDD-NNNN for traceability and audit purposes.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle state of the billing run: scheduled (queued for execution), in_progress (actively processing), completed (successfully finished), failed (terminated with errors), cancelled (aborted by user), or partially_completed (finished with some errors).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the billing run execution mode: periodic (scheduled recurring), manual (user-initiated), correction (error fix), rerun (retry after failure), ad_hoc (one-time special), or final (end-of-period closing).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned date and time when the billing run was scheduled to begin execution, used for batch job planning and SLA tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:selectionCriteria rdf:type rdf:Property ;
    rdfs:label 'Selection Criteria' ;
    rdfs:comment 'Business rules and filters applied to select billing-eligible documents for this run (e.g., customer group, sales order type, delivery date range, billing block status).' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBilledAmount rdf:type rdf:Property ;
    rdfs:label 'Total Billed Amount' ;
    rdfs:comment 'Sum of all net invoice amounts generated in this billing run, representing the total revenue recognized in the batch.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Total Discount Amount' ;
    rdfs:comment 'Sum of all discounts, rebates, and allowances applied across invoices in this run, used for pricing analytics and margin analysis.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInvoicesFailed rdf:type rdf:Property ;
    rdfs:label 'Total Invoices Failed' ;
    rdfs:comment 'Number of invoice generation attempts that failed due to data errors, validation failures, or system issues during this run.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalInvoicesGenerated rdf:type rdf:Property ;
    rdfs:label 'Total Invoices Generated' ;
    rdfs:comment 'Total number of invoice documents successfully created during this billing run, used for volume tracking and reconciliation.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warningCount rdf:type rdf:Property ;
    rdfs:label 'Warning Count' ;
    rdfs:comment 'Total number of warnings generated during the billing run, indicating non-critical issues that did not prevent invoice creation but require review.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dealerIncentiveProgramId rdf:type rdf:Property ;
    rdfs:label 'Dealer Incentive Program Id' ;
    rdfs:comment 'Reference to the dealer incentive program (e.g., volume rebate, promotional allowance) that this credit memo fulfills, if applicable.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DealerIncentiveProgram .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Full name of the person who approved the credit memo. Provides human-readable audit information.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Externally-known business identifier for the credit memo, typically following format CM followed by 10 digits. Used for customer communication and SAP SD document reference.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Status' ;
    rdfs:comment 'Current lifecycle status of the credit memo in the approval and posting workflow. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|issued|posted|cancelled|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReasonCode rdf:type rdf:Property ;
    rdfs:label 'Credit Reason Code' ;
    rdfs:comment 'Categorical code indicating the business reason for issuing the credit memo. Supports financial analysis and dispute resolution tracking. [ENUM-REF-CANDIDATE: return|pricing_error|warranty_adjustment|recall_allowance|volume_rebate|goodwill|service_reversal|parts_return|quality_claim|promotional_allowance — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditType rdf:type rdf:Property ;
    rdfs:label 'Credit Type' ;
    rdfs:comment 'Classification of the credit memo by its financial treatment and business purpose.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Credit Amount' ;
    rdfs:comment 'Total credit amount before tax adjustments. Represents the base value being credited to the customer or dealer.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Username or employee identifier of the person who last modified the credit memo record.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when the credit memo record was last modified. Audit trail for record lifecycle.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'External reference number provided by the customer or dealer for their internal tracking (e.g., dealer claim number, customer case number).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Reason code or description explaining why the credit memo was rejected during approval workflow, if status is rejected.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapAccountingDocument rdf:type rdf:Property ;
    rdfs:label 'Sap Accounting Document' ;
    rdfs:comment 'SAP FI accounting document number generated when the credit memo was posted to the general ledger.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapBillingDocument rdf:type rdf:Property ;
    rdfs:label 'Sap Billing Document' ;
    rdfs:comment 'SAP SD billing document number associated with this credit memo. Used for cross-reference to billing cycles.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCreditMemoDocument rdf:type rdf:Property ;
    rdfs:label 'Sap Credit Memo Document' ;
    rdfs:comment 'SAP SD credit memo document number. Links this record to the source system of record for reconciliation and traceability.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Credit Amount' ;
    rdfs:comment 'Tax portion of the credit memo. Reverses or adjusts the tax charged on the original invoice.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealerStatementId rdf:type rdf:Property ;
    rdfs:label 'Dealer Statement Id' ;
    rdfs:comment 'Unique identifier for the dealer statement record. Primary key.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dealerAccountId rdf:type rdf:Property ;
    rdfs:label 'Dealer Account Id' ;
    rdfs:comment 'Foreign key linking to billing.account. Business justification: Dealer statements are issued per dealer account; linking to the master account removes the redundant dealer_account_number column.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:issuedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Issued By User Employee Id' ;
    rdfs:comment 'Identifier of the user or system process that issued this statement.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agingBucket30DaysAmount rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket 30 Days Amount' ;
    rdfs:comment 'Portion of the closing balance that is 1-30 days past due.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingBucket60DaysAmount rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket 60 Days Amount' ;
    rdfs:comment 'Portion of the closing balance that is 31-60 days past due.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingBucket90DaysAmount rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket 90 Days Amount' ;
    rdfs:comment 'Portion of the closing balance that is 61-90 days past due.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingBucketCurrentAmount rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket Current Amount' ;
    rdfs:comment 'Portion of the closing balance that is current and not yet past due.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingBucketOver90DaysAmount rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket Over 90 Days Amount' ;
    rdfs:comment 'Portion of the closing balance that is more than 90 days past due.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCycleCode rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Code' ;
    rdfs:comment 'Code identifying the billing cycle or schedule under which this statement was generated.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdkStatementReference rdf:type rdf:Property ;
    rdfs:label 'Cdk Statement Reference' ;
    rdfs:comment 'External reference identifier from CDK Global DMS linking this statement to the dealer management system record.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Closing Balance Amount' ;
    rdfs:comment 'The outstanding balance at the end of the statement period, calculated as opening balance plus charges minus credits and payments.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeAmount rdf:type rdf:Property ;
    rdfs:label 'Dispute Amount' ;
    rdfs:comment 'The monetary amount under dispute by the dealer, if any.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether the dealer has raised a dispute or discrepancy regarding this statement.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:comment 'Code representing the reason for the dispute, such as pricing error, quantity discrepancy, or missing credit.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorplanFinancingFlag rdf:type rdf:Property ;
    rdfs:label 'Floorplan Financing Flag' ;
    rdfs:comment 'Indicates whether this statement includes floorplan financing charges or is relevant for floorplan reporting.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Opening Balance Amount' ;
    rdfs:comment 'The outstanding balance carried forward from the previous statement period.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The date by which the dealer is expected to remit payment for the closing balance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementDate rdf:type rdf:Property ;
    rdfs:label 'Statement Date' ;
    rdfs:comment 'The date on which the statement was generated and issued to the dealer.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementNotes rdf:type rdf:Property ;
    rdfs:label 'Statement Notes' ;
    rdfs:comment 'Free-text field for additional notes, comments, or instructions related to this statement.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementNumber rdf:type rdf:Property ;
    rdfs:label 'Statement Number' ;
    rdfs:comment 'Unique business identifier for the dealer statement, externally visible and used for dealer reconciliation and reference.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period End Date' ;
    rdfs:comment 'The last date of the billing period covered by this statement.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Statement Period Start Date' ;
    rdfs:comment 'The first date of the billing period covered by this statement.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementStatus rdf:type rdf:Property ;
    rdfs:label 'Statement Status' ;
    rdfs:comment 'Current lifecycle status of the dealer statement indicating its processing stage.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementType rdf:type rdf:Property ;
    rdfs:label 'Statement Type' ;
    rdfs:comment 'Classification of the statement based on its frequency or purpose.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Total Adjustment Amount' ;
    rdfs:comment 'Sum of all manual adjustments applied to the dealer account during the statement period, including corrections and write-offs.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCreditMemoAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Memo Amount' ;
    rdfs:comment 'Sum of all credit memos issued to the dealer during the statement period, reducing the amount owed.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebitMemoAmount rdf:type rdf:Property ;
    rdfs:label 'Total Debit Memo Amount' ;
    rdfs:comment 'Sum of all debit memos issued to the dealer during the statement period, increasing the amount owed.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalIncentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Total Incentive Amount' ;
    rdfs:comment 'Sum of all dealer incentives, rebates, and promotional credits applied during the statement period.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Total Invoice Amount' ;
    rdfs:comment 'Sum of all invoices issued to the dealer during the statement period.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPartsSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Total Parts Sales Amount' ;
    rdfs:comment 'Sum of all parts sales invoices included in this statement period.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaymentReceivedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Received Amount' ;
    rdfs:comment 'Sum of all payments received from the dealer during the statement period.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalServiceChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Total Service Charges Amount' ;
    rdfs:comment 'Sum of all service and labor charges included in this statement period.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVehicleSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Total Vehicle Sales Amount' ;
    rdfs:comment 'Sum of all vehicle sales invoices included in this statement period.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWarrantyReimbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Total Warranty Reimbursement Amount' ;
    rdfs:comment 'Sum of all warranty claim reimbursements credited to the dealer during the statement period.' ;
    rdfs:domain ind:DealerStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitMemoId rdf:type rdf:Property ;
    rdfs:label 'Debit Memo Id' ;
    rdfs:comment 'Unique identifier for the debit memo record. Primary key.' ;
    rdfs:domain ind:DebitMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDebitDealershipId rdf:type rdf:Property ;
    rdfs:label 'Primary Debit Dealership Id' ;
    rdfs:comment 'Reference to the dealer or account being debited. Primary counterparty for this debit memo.' ;
    rdfs:domain ind:DebitMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dealership .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Timestamp when the debit memo was approved. Null if not yet approved.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:debitAmount rdf:type rdf:Property ;
    rdfs:label 'Debit Amount' ;
    rdfs:comment 'Gross amount being debited to the dealer or account before tax. Represents the base charge amount.' ;
    rdfs:domain ind:DebitMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Debit Memo Number' ;
    rdfs:comment 'Externally-known business identifier for the debit memo, typically following a format like DM followed by 10 digits. Used for communication with dealers and in financial documents.' ;
    rdfs:domain ind:DebitMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitReasonCode rdf:type rdf:Property ;
    rdfs:label 'Debit Reason Code' ;
    rdfs:comment 'Categorical code indicating the business reason for issuing the debit memo. Common values include FREIGHT (freight adjustments), PDI (Pre-Delivery Inspection charges), HOMOLOGATION (regulatory certification fees), PRICE_CORRECTION (price adjustments post-invoice), TOOLING (special tooling charges), ACCESSORY (additional accessory charges), LATE_FEE (late payment penalties), OTHER (miscellaneous charges). [ENUM-REF-CANDIDATE: FREIGHT|PDI|HOMOLOGATION|PRICE_CORRECTION|TOOLING|ACCESSORY|LATE_FEE|OTHER — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DebitMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Debit Reason Description' ;
    rdfs:comment 'Detailed textual explanation of why the debit memo was issued. Provides context beyond the reason code.' ;
    rdfs:domain ind:DebitMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'Date when the dealer formally disputed the debit memo. Null if never disputed.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Textual explanation provided by the dealer for disputing the debit memo. Null if not disputed.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference document number such as a purchase order, delivery note, or contract number that provides additional context for the debit memo.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapFiDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Document Number' ;
    rdfs:comment 'SAP FI accounting document number generated when the debit memo was posted to the general ledger.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSdDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Document Number' ;
    rdfs:comment 'SAP SD billing document number for the debit memo. System-of-record reference for integration and reconciliation.' ;
    rdfs:domain ind:DebitMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Total Debit Amount' ;
    rdfs:comment 'Total amount of the debit memo including tax. Sum of debit_amount and tax_amount. This is the net amount charged to the dealer.' ;
    rdfs:domain ind:DebitMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunningRecordId rdf:type rdf:Property ;
    rdfs:label 'Dunning Record Id' ;
    rdfs:comment 'Unique identifier for the dunning record. Primary key.' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Collector Employee Id' ;
    rdfs:comment 'Reference to the collections specialist or team responsible for managing this dunning case and follow-up actions.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:creditExposure rdf:type rdf:Property ;
    rdfs:label 'Credit Exposure' ;
    rdfs:comment 'The total outstanding receivables for the account at the time of the dunning run, including both overdue and current amounts. Confidential business data.' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'The approved credit limit for the billing account at the time of the dunning run. Confidential business data.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'The business segment or risk classification of the customer, influencing dunning strategy and escalation path.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOverdue rdf:type rdf:Property ;
    rdfs:label 'Days Overdue' ;
    rdfs:comment 'The number of days between the oldest overdue date and the dunning run date, representing the age of the oldest delinquency.' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryAddress rdf:type rdf:Property ;
    rdfs:label 'Delivery Address' ;
    rdfs:comment 'The email address, postal address, or portal user ID to which the dunning notice was sent. Confidential organizational contact data.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningBlockDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Block Date' ;
    rdfs:comment 'The date on which the dunning block was applied to the account. Null if not blocked.' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningBlockReason rdf:type rdf:Property ;
    rdfs:label 'Dunning Block Reason' ;
    rdfs:comment 'The reason why dunning activity has been blocked for this account. Null if not blocked.' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Dunning Fee Amount' ;
    rdfs:comment 'The administrative fee charged to the customer for this dunning notice, if applicable. Zero if no fee charged.' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunningNoticeDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Dunning Notice Delivery Method' ;
    rdfs:comment 'The channel through which the dunning notice was delivered to the customer.' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningNoticeSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dunning Notice Sent Timestamp' ;
    rdfs:comment 'The date and time when the dunning notice was successfully transmitted to the customer.' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dunningNoticeType rdf:type rdf:Property ;
    rdfs:label 'Dunning Notice Type' ;
    rdfs:comment 'The type of dunning communication sent to the customer. Reminder is courtesy notice, warning indicates escalation, final demand is last notice before legal action, legal notice indicates attorney involvement, suspension notice warns of service suspension, account hold indicates credit freeze.' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningRunDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Run Date' ;
    rdfs:comment 'The date on which the dunning run was executed and this dunning notice was generated.' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningRunNumber rdf:type rdf:Property ;
    rdfs:label 'Dunning Run Number' ;
    rdfs:comment 'Business identifier for the dunning run batch that generated this notice. Format: DUN-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningStatus rdf:type rdf:Property ;
    rdfs:label 'Dunning Status' ;
    rdfs:comment 'The current lifecycle status of this dunning record. Sent indicates notice generated, delivered indicates successful transmission, bounced indicates delivery failure, responded indicates customer reply received, escalated indicates moved to higher level, resolved indicates payment received or dispute settled, cancelled indicates dunning withdrawn. [ENUM-REF-CANDIDATE: sent|delivered|bounced|responded|escalated|resolved|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Amount' ;
    rdfs:comment 'The late payment interest accrued on the overdue amount as of the dunning run date, if applicable. Zero if no interest charged.' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextActionDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Date' ;
    rdfs:comment 'The scheduled date for the next follow-up action or escalation if payment is not received.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextActionType rdf:type rdf:Property ;
    rdfs:label 'Next Action Type' ;
    rdfs:comment 'The type of follow-up action planned for the next action date.' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oldestOverdueDate rdf:type rdf:Property ;
    rdfs:label 'Oldest Overdue Date' ;
    rdfs:comment 'The due date of the oldest unpaid invoice included in this dunning action, indicating how long the account has been delinquent.' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdueItemCount rdf:type rdf:Property ;
    rdfs:label 'Overdue Item Count' ;
    rdfs:comment 'The number of individual overdue invoices or line items included in this dunning notice.' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentPromiseAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Promise Amount' ;
    rdfs:comment 'The amount the customer has committed to pay by the promise date. May be partial or full overdue amount.' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentPromiseDate rdf:type rdf:Property ;
    rdfs:label 'Payment Promise Date' ;
    rdfs:comment 'The date by which the customer has promised to remit payment, if a payment promise was received. Null otherwise.' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDate rdf:type rdf:Property ;
    rdfs:label 'Response Date' ;
    rdfs:comment 'The date on which the customer responded to the dunning notice. Null if no response received.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Response Received Flag' ;
    rdfs:comment 'Indicates whether the customer has responded to this dunning notice (True) or not (False).' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseType rdf:type rdf:Property ;
    rdfs:label 'Response Type' ;
    rdfs:comment 'The nature of the customer response to the dunning notice. Payment promise indicates commitment to pay, dispute raised indicates disagreement with charges, payment plan request indicates request for installment arrangement, contact request indicates need for discussion.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDunningDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Dunning Document Number' ;
    rdfs:comment 'The SAP FI dunning document number generated by the dunning program. 10-digit numeric identifier.' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOverdueAmount rdf:type rdf:Property ;
    rdfs:label 'Total Overdue Amount' ;
    rdfs:comment 'The total amount of receivables that are overdue and subject to this dunning action, in the billing currency.' ;
    rdfs:domain ind:DunningRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fleetStatementId rdf:type rdf:Property ;
    rdfs:label 'Fleet Statement Id' ;
    rdfs:comment 'Unique identifier for the fleet billing statement. Primary key.' ;
    rdfs:domain ind:FleetStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerFleetAccountId rdf:type rdf:Property ;
    rdfs:label 'Customer Fleet Account Id' ;
    rdfs:comment 'Reference to the fleet account customer (corporate, government, rental) for which this statement is issued.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerFleetAccount .

ind:billingCycleEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle End Date' ;
    rdfs:comment 'End date of the billing cycle covered by this statement.' ;
    rdfs:domain ind:FleetStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingCycleStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Start Date' ;
    rdfs:comment 'Start date of the billing cycle covered by this statement.' ;
    rdfs:domain ind:FleetStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the fleet account for billing inquiries.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryEmail rdf:type rdf:Property ;
    rdfs:label 'Delivery Email' ;
    rdfs:comment 'Email address to which the statement is sent, if delivery method is email.' ;
    rdfs:domain ind:FleetStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method by which the statement is delivered to the fleet account customer.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetManagementFees rdf:type rdf:Property ;
    rdfs:label 'Fleet Management Fees' ;
    rdfs:comment 'Recurring or one-time fleet management and administration fees charged during the billing cycle.' ;
    rdfs:domain ind:FleetStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelCharges rdf:type rdf:Property ;
    rdfs:label 'Fuel Charges' ;
    rdfs:comment 'Total fuel charges billed to the fleet account during the billing cycle, if applicable.' ;
    rdfs:domain ind:FleetStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCharges rdf:type rdf:Property ;
    rdfs:label 'Insurance Charges' ;
    rdfs:comment 'Insurance premium charges for fleet vehicles during the billing cycle, if managed by OEM.' ;
    rdfs:domain ind:FleetStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Total amount due from the fleet account after applying charges, credits, and payments.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsCharges rdf:type rdf:Property ;
    rdfs:label 'Parts Charges' ;
    rdfs:comment 'Total charges for parts supplied to the fleet account during the billing cycle.' ;
    rdfs:domain ind:FleetStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousBalance rdf:type rdf:Property ;
    rdfs:label 'Previous Balance' ;
    rdfs:comment 'Outstanding balance carried forward from the previous billing statement.' ;
    rdfs:domain ind:FleetStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceCharges rdf:type rdf:Property ;
    rdfs:label 'Service Charges' ;
    rdfs:comment 'Total charges for maintenance and repair services provided to fleet vehicles during the billing cycle.' ;
    rdfs:domain ind:FleetStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tcoSummaryFlag rdf:type rdf:Property ;
    rdfs:label 'Tco Summary Flag' ;
    rdfs:comment 'Indicates whether this statement includes a Total Cost of Ownership summary for the fleet account.' ;
    rdfs:domain ind:FleetStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:telematicsSubscriptionCharges rdf:type rdf:Property ;
    rdfs:label 'Telematics Subscription Charges' ;
    rdfs:comment 'Charges for connected vehicle telematics services and subscriptions during the billing cycle.' ;
    rdfs:domain ind:FleetStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCharges rdf:type rdf:Property ;
    rdfs:label 'Total Charges' ;
    rdfs:comment 'Sum of all charges before credits and payments (vehicle acquisition, parts, service, fees, taxes).' ;
    rdfs:domain ind:FleetStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCredits rdf:type rdf:Property ;
    rdfs:label 'Total Credits' ;
    rdfs:comment 'Total credit memos, adjustments, and allowances applied to the fleet account during the billing cycle.' ;
    rdfs:domain ind:FleetStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaymentsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Payments Received' ;
    rdfs:comment 'Total payments received from the fleet account during the billing cycle, applied to outstanding balances.' ;
    rdfs:domain ind:FleetStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVehiclesBilled rdf:type rdf:Property ;
    rdfs:label 'Total Vehicles Billed' ;
    rdfs:comment 'Total count of vehicles included in this billing statement for the fleet account.' ;
    rdfs:domain ind:FleetStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleAcquisitionCharges rdf:type rdf:Property ;
    rdfs:label 'Vehicle Acquisition Charges' ;
    rdfs:comment 'Total charges for vehicle purchases or leases during the billing cycle.' ;
    rdfs:domain ind:FleetStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Invoice Id' ;
    rdfs:comment 'Unique identifier for the intercompany invoice record. Primary key.' ;
    rdfs:domain ind:IntercompanyInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuingAccountId rdf:type rdf:Property ;
    rdfs:label 'Issuing Account Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_account. Business justification: Intercompany invoices should reference the issuing billing account; the code and name become redundant.' ;
    rdfs:domain ind:IntercompanyInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Any adjustments applied to the gross amount, such as discounts, rebates, or transfer pricing adjustments. Positive values increase the invoice; negative values decrease it.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Cost center code in SAP CO that bears the cost or revenue associated with this intercompany transaction. Used for internal cost allocation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total invoice amount before taxes, adjustments, or deductions. Represents the base transfer price or service charge.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyInvoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Intercompany Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the intercompany invoice: draft (being prepared), issued (sent to receiving entity), acknowledged (received and accepted), disputed (under review for discrepancies), settled (payment completed), cancelled (voided).' ;
    rdfs:domain ind:IntercompanyInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingEntityCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Entity Code' ;
    rdfs:comment 'Code identifying the Automotive legal entity or subsidiary that receives and must pay this intercompany invoice. Typically 2-letter country code followed by 4-digit entity identifier.' ;
    rdfs:domain ind:IntercompanyInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingEntityName rdf:type rdf:Property ;
    rdfs:label 'Receiving Entity Name' ;
    rdfs:comment 'Full legal name of the receiving entity or subsidiary.' ;
    rdfs:domain ind:IntercompanyInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapIntercompanyClearingAccount rdf:type rdf:Property ;
    rdfs:label 'Sap Intercompany Clearing Account' ;
    rdfs:comment 'General ledger account number used for intercompany clearing and reconciliation in SAP FI. Tracks outstanding balances between entities.' ;
    rdfs:domain ind:IntercompanyInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment Code' ;
    rdfs:comment 'Code indicating the tax treatment applicable to this intercompany transaction, such as VAT exemption, reverse charge, or standard rate. Aligns with jurisdictional tax regulations.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the intercompany transaction: vehicle_transfer (finished vehicle transfer between entities), ckd_supply (Completely Knocked Down kit supply), skd_supply (Semi Knocked Down kit supply), royalty (intellectual property or brand royalty charges), management_fee (corporate services allocation), shared_service (shared service center charges).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPriceBasis rdf:type rdf:Property ;
    rdfs:label 'Transfer Price Basis' ;
    rdfs:comment 'Methodology used to determine the transfer price for this intercompany transaction: cost_plus (cost plus markup), market_price (prevailing market rate), arm_length (arms-length principle per OECD), negotiated (bilaterally agreed rate), comparable_uncontrolled (comparable uncontrolled price method).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Policy Reference' ;
    rdfs:comment 'Reference to the internal transfer pricing policy document or agreement that governs this transaction. Used for audit and compliance verification.' ;
    rdfs:domain ind:IntercompanyInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleModelCode rdf:type rdf:Property ;
    rdfs:label 'Vehicle Model Code' ;
    rdfs:comment 'Internal model code identifying the vehicle platform or variant being transferred. Used for vehicle_transfer and kit supply transactions.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Foreign key linking to logistics.carrier. Business justification: Invoice includes carrier charges; linking to carrier enables carrier performance reporting and compliance with freight cost audits.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:complianceEmissionsCertificationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Emissions Certification Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_emissions_certification. Business justification: Needed to associate each sold vehicle invoice with its emissions certification for mandatory emissions reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceEmissionsCertification .

ind:homologationRecordId rdf:type rdf:Property ;
    rdfs:label 'Homologation Record Id' ;
    rdfs:comment 'Foreign key linking to compliance.homologation_record. Business justification: Required for sales invoicing to verify each vehicle model is homologated for the market, supporting the Homologation Compliance Report.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HomologationRecord .

ind:paymentTermId rdf:type rdf:Property ;
    rdfs:label 'Payment Term Id' ;
    rdfs:comment 'Foreign key linking to billing.payment_term. Business justification: Invoice references a payment term; using a foreign key to payment_term provides full term details and removes the redundant code column.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTerm .

ind:repId rdf:type rdf:Property ;
    rdfs:label 'Rep Id' ;
    rdfs:comment 'Reference to the salesperson or account manager responsible for this sale, used for commission and performance tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rep .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Timestamp when the invoice was cancelled, if applicable. Null for active invoices.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice in the billing and collection workflow.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice based on the customer segment and transaction nature (dealer wholesale, retail customer, fleet account, parts sale, service work, warranty claim).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrpBasedFlag rdf:type rdf:Property ;
    rdfs:label 'Msrp Based Flag' ;
    rdfs:comment 'Indicates whether the invoice pricing is based on MSRP (true) or negotiated/contracted pricing (false).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Amount' ;
    rdfs:comment 'Remaining unpaid balance on the invoice (net_amount minus paid_amount).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Total amount paid against this invoice to date. Used to track partial payments.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Date when the full or final payment was received for this invoice. Null if not yet fully paid.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapBillingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Billing Document Number' ;
    rdfs:comment 'Reference to the SAP SD billing document number from which this invoice was generated. System of record identifier.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Billing Invoice Line Id' ;
    rdfs:comment 'Unique identifier for the invoice line item. Primary key for the invoice_line product.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingInvoiceLine .

ind:billingPriceConditionId rdf:type rdf:Property ;
    rdfs:label 'Billing Price Condition Id' ;
    rdfs:comment 'Foreign key linking to billing.price_condition. Business justification: Invoice line items can be priced by a pricing condition; linking to price_condition normalizes pricing logic.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingPriceCondition .

ind:serviceSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Service Subscription Id' ;
    rdfs:comment 'Foreign key linking to mobility.service_subscription. Business justification: Needed for the \'Usage-Based Service Billing\' report, linking each invoice line to the subscription that produced the charge.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceSubscription .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Invoice line items represent sold SKUs; linking each invoice_line to the product SKU provides traceability from billing to product catalog.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:supplyPoLineId rdf:type rdf:Property ;
    rdfs:label 'Supply Po Line Id' ;
    rdfs:comment 'Foreign key linking to supply.supply_po_line. Business justification: Invoice line validation against PO line items is required for accurate cost allocation and audit; standard in automotive AP.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplyPoLine .

ind:taxCodeId rdf:type rdf:Property ;
    rdfs:label 'Tax Code Id' ;
    rdfs:comment 'Foreign key linking to billing.tax_code. Business justification: Invoice line tax details should reference the tax_code master; the tax rate can be derived, so the string code and rate columns are redundant.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxCode .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Discount expressed as a percentage of the unit price. Provides the rate of discount applied to calculate the discount_amount.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemCode rdf:type rdf:Property ;
    rdfs:label 'Item Code' ;
    rdfs:comment 'Universal item identifier for the billed product or service. May represent a vehicle model code, part number, labor operation code, accessory SKU (Stock Keeping Unit), or fee code depending on line_item_type.' ;
    rdfs:domain ind:BillingInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Human-readable description of the billed item. Provides detailed text explaining the product, service, or charge represented by this line.' ;
    rdfs:domain ind:BillingInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborOperationCode rdf:type rdf:Property ;
    rdfs:label 'Labor Operation Code' ;
    rdfs:comment 'Standardized labor operation code for service work. Identifies the specific repair or maintenance task performed. Populated only when line_item_type is labor.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemType rdf:type rdf:Property ;
    rdfs:label 'Line Item Type' ;
    rdfs:comment 'Classification of the invoice line item. Distinguishes between vehicle units, parts, labor operations, accessories, service fees, freight charges, warranty products, and insurance products. [ENUM-REF-CANDIDATE: vehicle|part|labor|accessory|fee|freight|warranty|insurance — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BillingInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the invoice. Determines the ordering and display sequence of line items on the invoice document.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Total amount for this line item including all charges and taxes. Calculated as subtotal_amount + tax_amount. Represents the final billable amount for this line.' ;
    rdfs:domain ind:BillingInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msrp rdf:type rdf:Property ;
    rdfs:label 'Msrp' ;
    rdfs:comment 'Manufacturer Suggested Retail Price for the item. The list price recommended by the OEM (Original Equipment Manufacturer). Primarily applicable to vehicle and accessory line items.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiatedPrice rdf:type rdf:Property ;
    rdfs:label 'Negotiated Price' ;
    rdfs:comment 'Final negotiated price per unit after dealer or customer negotiations. May differ from MSRP (Manufacturer Suggested Retail Price) based on market conditions, promotions, or customer agreements.' ;
    rdfs:domain ind:BillingInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'Marketing promotion or incentive program code applied to this line. Tracks the specific promotional campaign that influenced the pricing or discount.' ;
    rdfs:domain ind:BillingInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Category' ;
    rdfs:comment 'Revenue classification for financial reporting and analytics. Categorizes the line item into major revenue streams for P&L (Profit and Loss) reporting and business intelligence. [ENUM-REF-CANDIDATE: new_vehicle|used_vehicle|parts|service|warranty|finance|insurance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BillingInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrderLineNumber rdf:type rdf:Property ;
    rdfs:label 'Sales Order Line Number' ;
    rdfs:comment 'Line number on the originating sales order. Provides traceability from the invoice line back to the specific sales order line item.' ;
    rdfs:domain ind:BillingInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Line subtotal before taxes. Calculated as (quantity × unit_price) - discount_amount. Represents the net selling amount before tax.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyCode rdf:type rdf:Property ;
    rdfs:label 'Warranty Code' ;
    rdfs:comment 'Warranty program code if this line represents warranty coverage. Identifies the specific warranty plan or extended service contract being billed.' ;
    rdfs:domain ind:BillingInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsServiceChargeId rdf:type rdf:Property ;
    rdfs:label 'Parts Service Charge Id' ;
    rdfs:comment 'Unique identifier for the parts and service charge record. Primary key for this transaction.' ;
    rdfs:domain ind:PartsServiceCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Billing Account Number' ;
    rdfs:comment 'Account number to which this charge is billed. May reference dealer account, retail customer account, or fleet account depending on charge type.' ;
    rdfs:domain ind:PartsServiceCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdkRepairOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Cdk Repair Order Number' ;
    rdfs:comment 'CDK Global DMS repair order reference number. Source system identifier linking charge to the dealer management system repair order.' ;
    rdfs:domain ind:PartsServiceCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeDate rdf:type rdf:Property ;
    rdfs:label 'Charge Date' ;
    rdfs:comment 'Date when the parts and service charge was created or incurred. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:PartsServiceCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargeNumber rdf:type rdf:Property ;
    rdfs:label 'Charge Number' ;
    rdfs:comment 'Business identifier for the parts and service charge. Externally-known unique charge reference number used in billing statements and dispute resolution.' ;
    rdfs:domain ind:PartsServiceCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeStatus rdf:type rdf:Property ;
    rdfs:label 'Charge Status' ;
    rdfs:comment 'Current lifecycle status of the charge in the billing workflow. Tracks progression from draft through approval, billing, payment, or dispute resolution. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|billed|paid|disputed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PartsServiceCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeType rdf:type rdf:Property ;
    rdfs:label 'Charge Type' ;
    rdfs:comment 'Classification of the charge based on service context. Distinguishes between warranty claims, retail service, fleet maintenance, recall campaigns, and Technical Service Bulletin (TSB) repairs. [ENUM-REF-CANDIDATE: warranty_parts|warranty_labor|retail_parts|retail_labor|fleet_maintenance|recall_parts|tsb_repair — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PartsServiceCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Amount' ;
    rdfs:comment 'Total monetary value of labor charged in this transaction before tax and adjustments. Represents the gross labor cost component.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsAmount rdf:type rdf:Property ;
    rdfs:label 'Parts Amount' ;
    rdfs:comment 'Total monetary value of parts charged in this transaction before tax and adjustments. Represents the gross parts cost component.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsQuantity rdf:type rdf:Property ;
    rdfs:label 'Parts Quantity' ;
    rdfs:comment 'Quantity of parts charged in this transaction. Supports fractional quantities for fluids, lubricants, and bulk materials.' ;
    rdfs:domain ind:PartsServiceCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Charge Amount' ;
    rdfs:comment 'Net total charge amount after applying parts, labor, tax, and discounts. Final billable amount for this charge record.' ;
    rdfs:domain ind:PartsServiceCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Unique identifier for the payment record. Primary key for the payment entity.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:payerEntityPartyId rdf:type rdf:Property ;
    rdfs:label 'Payer Entity Party Id' ;
    rdfs:comment 'Identifier of the entity making the payment (dealer, retail customer, fleet operator, or corporate account).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Authorization code provided by the payment processor or bank confirming approval of the payment transaction.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Bank account number from which the payment originated. Masked or tokenized for security. Used for reconciliation and fraud prevention.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchReference rdf:type rdf:Property ;
    rdfs:label 'Batch Reference' ;
    rdfs:comment 'Identifier for the batch or group of payments processed together. Used for bulk payment processing and reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Interface or channel through which the payment was submitted. Distinguishes between online portal, mobile app, bank transfer, mail, and in-person payments. [ENUM-REF-CANDIDATE: online_portal|mobile_app|bank_transfer|mail|in_person|automated_system|dealer_system — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'Date when the payment was cleared and funds were confirmed as received in the company bank account.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the payment amount (e.g., USD, EUR, JPY).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockboxNumber rdf:type rdf:Property ;
    rdfs:label 'Lockbox Number' ;
    rdfs:comment 'Identifier for the bank lockbox service used to receive and process the payment. Applicable for check and mail payments.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Number' ;
    rdfs:comment 'Business-facing unique reference number for the payment transaction. Used for customer communication and reconciliation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processor rdf:type rdf:Property ;
    rdfs:label 'Processor' ;
    rdfs:comment 'Name of the third-party payment processor or gateway used to process the payment (e.g., Stripe, PayPal, bank name).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceAdvice rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice' ;
    rdfs:comment 'Detailed remittance information provided by the payer indicating which invoices or charges this payment is intended to cover.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Bank routing number or SWIFT code for the payer financial institution. Used for wire transfers and ACH (Automated Clearing House) transactions.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapClearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Clearing Document Number' ;
    rdfs:comment 'Reference to the SAP FI clearing document that records the application of this payment to open invoices. Links payment to financial accounting records.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPaymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Payment Document Number' ;
    rdfs:comment 'Reference to the SAP FI payment document that records the receipt of this payment. Primary link to ERP (Enterprise Resource Planning) financial records.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsCode rdf:type rdf:Property ;
    rdfs:label 'Terms Code' ;
    rdfs:comment 'Code representing the payment terms under which this payment was made (e.g., net 30, net 60, immediate). Links to master payment terms reference.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the payment processor or gateway. Used for tracking and reconciliation with external systems.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Unapplied Amount' ;
    rdfs:comment 'Portion of the payment amount that remains unapplied and is held as credit on the payer account.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAllocationId rdf:type rdf:Property ;
    rdfs:label 'Payment Allocation Id' ;
    rdfs:comment 'Unique identifier for the payment allocation record. Primary key for the payment allocation entity.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPaymentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Employee Id' ;
    rdfs:comment 'User ID of the person who created or approved the allocation. Used for audit trail and accountability in manual allocation scenarios.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'The monetary amount from the payment that is allocated to this specific invoice or invoice line. Represents the portion of the total payment applied to settle this receivable.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedAmountBaseCurrency rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount Base Currency' ;
    rdfs:comment 'The allocated amount converted to the company base currency using the exchange rate. Enables consolidated financial reporting and accounts receivable aging in a single currency.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The date when the payment was allocated to the invoice. Represents the business event date for accounts receivable clearing and aging calculations.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to create the allocation. Automatic indicates system-matched allocation, manual indicates user-created allocation, system_proposed indicates system suggestion requiring approval, batch_clearing indicates mass clearing process.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Business-readable unique identifier for the payment allocation. Used for tracking and reference in accounts receivable operations and customer communications.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPriority rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority' ;
    rdfs:comment 'Priority sequence for applying payment when multiple invoices are eligible. Lower numbers indicate higher priority. Used in automatic allocation rules and aging calculations.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle status of the payment allocation. Pending indicates awaiting confirmation, cleared indicates successfully applied, reversed indicates allocation has been undone, disputed indicates under investigation, reconciled indicates confirmed and balanced, voided indicates cancelled allocation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Timestamp' ;
    rdfs:comment 'Precise date and time when the payment allocation was recorded in the system. Used for audit trail and transaction sequencing.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Classification of the allocation method. Full indicates complete invoice settlement, partial indicates partial payment, advance indicates prepayment before invoice, overpayment indicates excess payment requiring refund or credit, credit_memo indicates credit note application, adjustment indicates manual correction.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'SAP FI clearing document number that records the open item clearing transaction. Links the payment allocation to the financial accounting clearing entry.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingStatus rdf:type rdf:Property ;
    rdfs:label 'Clearing Status' ;
    rdfs:comment 'Status of the open item clearing in SAP FI. Open indicates invoice not yet settled, cleared indicates fully settled, partially_cleared indicates partial payment applied, reset indicates clearing was reversed.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Account Number' ;
    rdfs:comment 'Customer account number in the accounts receivable system. Used for customer-level payment tracking and credit management.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeIndicator rdf:type rdf:Property ;
    rdfs:label 'Dispute Indicator' ;
    rdfs:comment 'Flag indicating whether this allocation is under dispute. True indicates customer has contested the invoice or payment application.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Exchange rate applied when payment currency differs from invoice currency. Used for cross-currency allocation calculations and financial reporting.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingInvoiceBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Invoice Balance' ;
    rdfs:comment 'The outstanding balance remaining on the invoice after this allocation is applied. Zero indicates full settlement. Used for open item management and accounts receivable aging.' ;
    rdfs:domain ind:PaymentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this allocation has been reversed. True indicates the allocation was subsequently undone, typically due to payment failure or correction.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableAccountTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Account Types' ;
    rdfs:comment 'Comma-separated list of billing account types to which this payment term applies (e.g., dealer, fleet, retail, corporate, OEM (Original Equipment Manufacturer)).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether finance or credit manager approval is required before this payment term can be assigned to a customer account.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoDunningEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Dunning Enabled' ;
    rdfs:comment 'Indicates whether automatic dunning (collection reminder) process is enabled for invoices using this payment term.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baselineDateRule rdf:type rdf:Property ;
    rdfs:label 'Baseline Date Rule' ;
    rdfs:comment 'Rule defining the baseline date from which net due days and discount days are calculated (invoice date, delivery date, end of month, or custom).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'Code identifying the business unit or division that owns and manages this payment term (e.g., DEALER, FLEET, PARTS).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Credit Check Required' ;
    rdfs:comment 'Indicates whether a credit check is required before this payment term can be assigned to a billing account.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountDays1 rdf:type rdf:Property ;
    rdfs:label 'Discount Days 1' ;
    rdfs:comment 'Number of days from invoice date within which discount percentage 1 applies.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountDays2 rdf:type rdf:Property ;
    rdfs:label 'Discount Days 2' ;
    rdfs:comment 'Number of days from invoice date within which discount percentage 2 applies (typically longer than discount days 1).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountPercentage1 rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage 1' ;
    rdfs:comment 'First early payment discount percentage offered if payment is made within discount days 1 (e.g., 2.00 for 2%).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountPercentage2 rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage 2' ;
    rdfs:comment 'Second early payment discount percentage offered if payment is made within discount days 2 (typically lower than discount 1).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixedDayOfMonth rdf:type rdf:Property ;
    rdfs:label 'Fixed Day Of Month' ;
    rdfs:comment 'If baseline date rule is custom, specifies a fixed day of the month for payment due date (e.g., 15 for the 15th of each month). Null if not applicable.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Value' ;
    rdfs:comment 'Maximum invoice or order value for which this payment term is applicable. Null if no maximum.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Value' ;
    rdfs:comment 'Minimum invoice or order value required for this payment term to be applicable. Null if no minimum.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netDueDays rdf:type rdf:Property ;
    rdfs:label 'Net Due Days' ;
    rdfs:comment 'Number of days from invoice date by which full payment is due without penalty.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentMethodRestriction rdf:type rdf:Property ;
    rdfs:label 'Payment Method Restriction' ;
    rdfs:comment 'Comma-separated list of allowed payment methods for this term (e.g., wire_transfer, check, ACH, credit_card). Empty if no restriction.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Term Description' ;
    rdfs:comment 'Detailed explanation of the payment term conditions, including discount and penalty clauses.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermName rdf:type rdf:Property ;
    rdfs:label 'Payment Term Name' ;
    rdfs:comment 'Full descriptive name of the payment term (e.g., Net 30 Days, 2% 10 Net 30, Cash on Delivery).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Term Status' ;
    rdfs:comment 'Current lifecycle status of the payment term: active (in use), inactive (not available for new assignments), deprecated (legacy term), or pending approval (awaiting finance approval).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Penalty Calculation Method' ;
    rdfs:comment 'Method used to calculate late payment penalties: daily accrual, monthly accrual, flat fee, or none.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyGraceDays rdf:type rdf:Property ;
    rdfs:label 'Penalty Grace Days' ;
    rdfs:comment 'Number of days after net due date before penalty charges begin to accrue.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyRate rdf:type rdf:Property ;
    rdfs:label 'Penalty Rate' ;
    rdfs:comment 'Late payment penalty rate applied after grace period expires, expressed as percentage per period (e.g., 1.5% per month).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapFiPaymentTermKey rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Payment Term Key' ;
    rdfs:comment 'Reference to the SAP FI payment term key in table T052 for ERP (Enterprise Resource Planning) integration and synchronization.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Number of active billing accounts or invoices currently using this payment term. Used for impact analysis before deprecation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether application of this pricing condition requires managerial or pricing authority approval before being applied to a billing transaction. True requires approval workflow.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculationType rdf:type rdf:Property ;
    rdfs:label 'Calculation Type' ;
    rdfs:comment 'Method used to calculate the condition value in the billing transaction. Defines whether the condition is applied as a fixed amount, percentage of base, quantity-dependent, or using a tiered/formula approach.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionClass rdf:type rdf:Property ;
    rdfs:label 'Condition Class' ;
    rdfs:comment 'High-level classification of the condition type grouping similar pricing elements together for reporting and analysis purposes.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionDescription rdf:type rdf:Property ;
    rdfs:label 'Condition Description' ;
    rdfs:comment 'Detailed textual description of the pricing condition, including its business purpose, applicability rules, and any special terms or restrictions. Provides context for pricing analysts and auditors.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionExclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Condition Exclusion Flag' ;
    rdfs:comment 'Indicates whether this condition is marked for exclusion from certain pricing scenarios or customer groups. True means the condition should be excluded under specific business rules.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Condition Record Number' ;
    rdfs:comment 'Business identifier for the pricing condition record, typically sourced from SAP SD condition record (KONP table). Used for external reference and traceability.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionStatus rdf:type rdf:Property ;
    rdfs:label 'Condition Status' ;
    rdfs:comment 'Current lifecycle status of the pricing condition record. Active conditions are available for use in billing; inactive, expired, or suspended conditions are not applied.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionStepNumber rdf:type rdf:Property ;
    rdfs:label 'Condition Step Number' ;
    rdfs:comment 'Sequence number within the pricing procedure that defines the order in which this condition is evaluated and applied during billing calculation.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionType rdf:type rdf:Property ;
    rdfs:label 'Condition Type' ;
    rdfs:comment 'Type of pricing condition applied to the billing transaction. Defines whether this is a base price (MSRP), negotiated price, discount, surcharge, tax, or other pricing element. Aligns with SAP SD condition types. [ENUM-REF-CANDIDATE: msrp|negotiated|fleet_discount|dealer_margin|volume_rebate|freight|pdi_charge|tax|surcharge|promotional_discount — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionUnit rdf:type rdf:Property ;
    rdfs:label 'Condition Unit' ;
    rdfs:comment 'Unit of measure for the condition value. Indicates whether the value is an absolute amount, a percentage, or a per-unit rate.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionValue rdf:type rdf:Property ;
    rdfs:label 'Condition Value' ;
    rdfs:comment 'Monetary or percentage value of the pricing condition. For absolute amounts, represents the price or adjustment in the condition currency. For percentage-based conditions, represents the rate (e.g., 5.5 for 5.5%).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerType rdf:type rdf:Property ;
    rdfs:label 'Customer Type' ;
    rdfs:comment 'Type of customer for which this pricing condition is applicable. Enables customer segment-specific pricing strategies (retail, fleet, dealer, government, commercial).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective End Timestamp' ;
    rdfs:comment 'Precise date and time when this pricing condition record version is superseded or becomes inactive in the lakehouse. Null indicates the current active version. Used for SCD Type 2 tracking.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Start Timestamp' ;
    rdfs:comment 'Precise date and time when this pricing condition record becomes effective in the lakehouse. Used for temporal queries and slowly changing dimension (SCD) Type 2 tracking.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isCurrentFlag rdf:type rdf:Property ;
    rdfs:label 'Is Current Flag' ;
    rdfs:comment 'Indicates whether this record represents the current active version of the pricing condition. True for the latest version, False for historical versions. Supports SCD Type 2 queries.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manualOverrideAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Manual Override Allowed Flag' ;
    rdfs:comment 'Indicates whether sales or billing personnel are permitted to manually override this condition value during transaction processing. True allows manual adjustment, False enforces system-determined value.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingProcedureCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Procedure Code' ;
    rdfs:comment 'Reference to the SAP SD pricing procedure that governs the sequence and logic of condition application. Links this condition to the broader pricing determination framework.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapConditionTable rdf:type rdf:Property ;
    rdfs:label 'Sap Condition Table' ;
    rdfs:comment 'Name of the SAP SD condition table (e.g., A001, A002) from which this condition record is sourced. Provides traceability to the source system configuration.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapKonpRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Konp Record Number' ;
    rdfs:comment 'Reference to the SAP SD KONP table record number that stores the condition record master data. Enables direct linkage to the source system for audit and reconciliation.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapKonvCounter rdf:type rdf:Property ;
    rdfs:label 'Sap Konv Counter' ;
    rdfs:comment 'Reference to the SAP SD KONV table counter that tracks condition application instances in sales and billing documents. Used for transaction-level traceability.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleBasis rdf:type rdf:Property ;
    rdfs:label 'Scale Basis' ;
    rdfs:comment 'Basis for scale-based pricing conditions. Defines the dimension (quantity, value, weight, volume) used to determine tiered pricing or volume-based discounts.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleQuantityFrom rdf:type rdf:Property ;
    rdfs:label 'Scale Quantity From' ;
    rdfs:comment 'Lower bound of the scale range for tiered pricing conditions. Defines the minimum quantity or value at which this condition rate applies.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleQuantityTo rdf:type rdf:Property ;
    rdfs:label 'Scale Quantity To' ;
    rdfs:comment 'Upper bound of the scale range for tiered pricing conditions. Defines the maximum quantity or value at which this condition rate applies. Null indicates no upper limit.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifier of the source system from which this pricing condition record was extracted (e.g., SAP_SD, SFDC, DMS). Supports multi-system integration and data lineage tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'Start date from which this pricing condition becomes effective and can be applied to billing transactions. Part of the condition validity period.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'End date until which this pricing condition remains effective. Null indicates the condition is valid indefinitely. Part of the condition validity period.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vehicleTrimLevel rdf:type rdf:Property ;
    rdfs:label 'Vehicle Trim Level' ;
    rdfs:comment 'Trim or configuration level of the vehicle model for which this condition applies (e.g., base, sport, luxury, premium). Enables trim-specific pricing differentiation.' ;
    rdfs:domain ind:BillingPriceCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateAccrualId rdf:type rdf:Property ;
    rdfs:label 'Rebate Accrual Id' ;
    rdfs:comment 'Unique identifier for the rebate accrual record. Primary key for the rebate accrual entity.' ;
    rdfs:domain ind:RebateAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By User Employee Id' ;
    rdfs:comment 'System user ID of the person or automated process that created this accrual record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryRebateEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Rebate Employee Id' ;
    rdfs:comment 'Reference to the finance manager or controller who approved this accrual for posting. Null if not yet approved.' ;
    rdfs:domain ind:RebateAccrual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rebateAgreementId rdf:type rdf:Property ;
    rdfs:label 'Rebate Agreement Id' ;
    rdfs:comment 'Reference to the parent rebate agreement under which this accrual is recorded. Links to the master rebate agreement contract.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RebateAgreement .

ind:tertiaryRebateUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Rebate Updated By User Employee Id' ;
    rdfs:comment 'System user ID of the person or automated process that last modified this accrual record. Used for audit trail and accountability.' ;
    rdfs:domain ind:RebateAccrual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:updatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Updated By User Employee Id' ;
    rdfs:comment 'System user ID of the person or automated process that last modified this accrual record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accrualBasis rdf:type rdf:Property ;
    rdfs:label 'Accrual Basis' ;
    rdfs:comment 'The measurement basis used to calculate the accrual. Invoiced_units uses billed quantities; registered_units uses vehicle registrations; shipped_units uses factory shipments; delivered_units uses dealer deliveries; retail_sales uses end-customer sales.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualNotes rdf:type rdf:Property ;
    rdfs:label 'Accrual Notes' ;
    rdfs:comment 'Free-text notes or comments regarding this accrual, such as calculation methodology, special adjustments, or reconciliation remarks. Used for audit trail and internal documentation.' ;
    rdfs:domain ind:RebateAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualNumber rdf:type rdf:Property ;
    rdfs:label 'Accrual Number' ;
    rdfs:comment 'Business identifier for the accrual record, typically generated by the financial system. Used for audit trail and reconciliation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Period End Date' ;
    rdfs:comment 'The last day of the period during which sales or performance milestones were achieved that triggered this accrual. Defines the end of the measurement window.' ;
    rdfs:domain ind:RebateAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Period Start Date' ;
    rdfs:comment 'The first day of the period during which sales or performance milestones were achieved that triggered this accrual. Defines the beginning of the measurement window.' ;
    rdfs:domain ind:RebateAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualStatus rdf:type rdf:Property ;
    rdfs:label 'Accrual Status' ;
    rdfs:comment 'Current lifecycle status of the accrual record. Open indicates accrual is calculated but not yet posted to the general ledger; posted indicates the liability has been recorded; reversed indicates the accrual was backed out; settled indicates payment has been made; cancelled indicates the accrual was voided; pending_approval indicates awaiting finance approval.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accruedAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Amount' ;
    rdfs:comment 'The rebate liability amount accrued for this specific period, calculated based on the accrued units and the rebate rate defined in the agreement. Represents the incremental accrual for this period only.' ;
    rdfs:domain ind:RebateAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accruedUnits rdf:type rdf:Property ;
    rdfs:label 'Accrued Units' ;
    rdfs:comment 'The quantity of units (vehicles, parts, or other items) that qualified for rebate during this accrual period. Measured in the unit of measure specified in the rebate agreement.' ;
    rdfs:domain ind:RebateAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copaPostingReference rdf:type rdf:Property ;
    rdfs:label 'Copa Posting Reference' ;
    rdfs:comment 'Reference number of the CO-PA posting document created when this accrual was posted to the profitability analysis module. Used for traceability between accrual and profitability reporting.' ;
    rdfs:domain ind:RebateAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeAccruedAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Accrued Amount' ;
    rdfs:comment 'The total rebate liability accrued from the start of the rebate agreement through the end of this accrual period. Used for tracking progress toward tiered rebate thresholds and total liability exposure.' ;
    rdfs:domain ind:RebateAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateRate rdf:type rdf:Property ;
    rdfs:label 'Rebate Rate' ;
    rdfs:comment 'The per-unit rebate rate applied to calculate the accrued amount for this period. May be a fixed amount per unit or a percentage of the transaction value, depending on the agreement structure.' ;
    rdfs:domain ind:RebateAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateRateType rdf:type rdf:Property ;
    rdfs:label 'Rebate Rate Type' ;
    rdfs:comment 'The structure of the rebate rate. Fixed_per_unit is a flat amount per unit; percentage is a percentage of sales value; tiered uses different rates at different volume thresholds; volume_based varies continuously with volume.' ;
    rdfs:domain ind:RebateAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'The SAP financial document number generated when this accrual was posted to the general ledger. Used for audit trail and reconciliation with SAP FI.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementReference rdf:type rdf:Property ;
    rdfs:label 'Settlement Reference' ;
    rdfs:comment 'Reference to the payment document or credit memo that settled this accrual. Null if not yet settled.' ;
    rdfs:domain ind:RebateAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryAccountId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Account Id' ;
    rdfs:comment 'Identifier of the dealer or fleet customer account that is the recipient of the rebate. Links to dealer or customer master data.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:regulatoryRequirementId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_requirement. Business justification: Rebate programs are tied to specific regulatory incentives; linking enables tracking of compliance-driven rebates.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryRequirement .

ind:accrualMethod rdf:type rdf:Property ;
    rdfs:label 'Accrual Method' ;
    rdfs:comment 'Method by which rebate amounts are calculated and accrued: periodic (monthly/quarterly calculation), milestone (triggered when target is reached), transaction_based (accrued per invoice).' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:achievedVolume rdf:type rdf:Property ;
    rdfs:label 'Achieved Volume' ;
    rdfs:comment 'Actual number of vehicle units sold or delivered under this agreement as of the last accrual calculation. Updated periodically based on billing transactions.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known business identifier for the rebate agreement, typically generated by SAP SD rebate management (BO01/BO02) or dealer management system.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the rebate agreement: draft (under negotiation), active (in force), suspended (temporarily paused), expired (validity period ended), terminated (cancelled before expiry), settled (final payment completed).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the rebate agreement defining the incentive structure: volume_rebate (quantity-based), loyalty_bonus (retention incentive), conquest_bonus (new customer acquisition), fleet_incentive (commercial fleet programs), model_mix_bonus (product mix targets), early_payment_discount (payment terms incentive).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryType rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Type' ;
    rdfs:comment 'Classification of the rebate recipient: dealer (franchise dealership), fleet_customer (commercial fleet operator), distributor (regional distributor), broker (third-party intermediary).' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference number or file path to the signed legal contract or agreement document supporting this rebate arrangement. Used for audit and compliance.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerTier rdf:type rdf:Property ;
    rdfs:label 'Dealer Tier' ;
    rdfs:comment 'Performance tier classification of the dealer beneficiary, used to determine rebate eligibility and rate structure. Higher tiers may receive enhanced rebate terms.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Description of the dispute or disagreement related to the rebate agreement terms, calculation, or settlement. Null if no dispute exists.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRetroactive rdf:type rdf:Property ;
    rdfs:label 'Is Retroactive' ;
    rdfs:comment 'Indicates whether the rebate agreement applies retroactively to transactions that occurred before the agreement effective start date. True if retroactive, False otherwise.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAccrualCalculationDate rdf:type rdf:Property ;
    rdfs:label 'Last Accrual Calculation Date' ;
    rdfs:comment 'Date when the rebate accrual amounts were last recalculated based on eligible transactions. Used to track data freshness and trigger next calculation cycle.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Last Settlement Date' ;
    rdfs:comment 'Date of the most recent rebate settlement payment or credit memo issuance. Null if no settlements have occurred.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Next Settlement Date' ;
    rdfs:comment 'Scheduled date for the next rebate settlement payment or credit memo generation. Null if agreement is settled or terminated.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:powertrainScope rdf:type rdf:Property ;
    rdfs:label 'Powertrain Scope' ;
    rdfs:comment 'Powertrain types eligible for the rebate: all (any powertrain), ICE (Internal Combustion Engine), HEV (Hybrid Electric Vehicle), PHEV (Plug-in Hybrid Electric Vehicle), EV (Electric Vehicle). Used to target electrification incentives.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateAmountPerUnit rdf:type rdf:Property ;
    rdfs:label 'Rebate Amount Per Unit' ;
    rdfs:comment 'Fixed rebate amount paid per vehicle unit sold. Used for flat-rate rebate structures. Null if percentage-based rebate is used.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateRatePercent rdf:type rdf:Property ;
    rdfs:label 'Rebate Rate Percent' ;
    rdfs:comment 'Percentage rate applied to eligible transaction amounts to calculate rebate accrual. Used for percentage-based rebate structures. Null if fixed amount rebate is used.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesRegion rdf:type rdf:Property ;
    rdfs:label 'Sales Region' ;
    rdfs:comment 'Geographic sales region or territory to which this rebate agreement applies. Used for regional incentive programs and performance tracking.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapRebateAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Rebate Agreement Number' ;
    rdfs:comment 'SAP SD rebate agreement reference number from transaction codes BO01 (create) or BO02 (change). Used for system integration and traceability.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Frequency' ;
    rdfs:comment 'Frequency at which accrued rebates are paid out to the beneficiary: monthly, quarterly, semi_annual, annual, or upon_completion (at agreement end).' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetVolume rdf:type rdf:Property ;
    rdfs:label 'Target Volume' ;
    rdfs:comment 'Target number of vehicle units that must be sold or delivered to qualify for the rebate. Null for non-volume-based agreements.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Explanation for why the rebate agreement was terminated early, if applicable. Null for agreements that expired naturally or are still active.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAccruedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Accrued Amount' ;
    rdfs:comment 'Cumulative rebate amount accrued under this agreement as of the last calculation date. Represents the liability owed to the beneficiary.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSettledAmount rdf:type rdf:Property ;
    rdfs:label 'Total Settled Amount' ;
    rdfs:comment 'Cumulative rebate amount paid out to the beneficiary through credit memos or direct payments. Used to track settlement progress.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleModelScope rdf:type rdf:Property ;
    rdfs:label 'Vehicle Model Scope' ;
    rdfs:comment 'Comma-separated list of vehicle models or model families eligible for this rebate agreement. May reference SKU (Stock Keeping Unit) codes or model year (MY) designations. Empty indicates all models are eligible.' ;
    rdfs:domain ind:RebateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivableId rdf:type rdf:Property ;
    rdfs:label 'Receivable Id' ;
    rdfs:comment 'Unique identifier for the accounts receivable item. Primary key for the receivable product. Represents a single open item in the AR ledger.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentPlanId rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Id' ;
    rdfs:comment 'Reference to the active payment plan agreement if payment_plan_flag is true. Links to payment plan schedule and terms.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentPlan .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Standard aging classification bucket based on days past due. Used for AR aging reports, bad debt provisioning, and collections prioritization.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current status of collection efforts for overdue receivables. Tracks progression through collections workflow from initial contact to legal action. [ENUM-REF-CANDIDATE: not_started|in_progress|on_hold|escalated|legal|resolved|abandoned — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Flag' ;
    rdfs:comment 'Boolean flag indicating whether the debtor account is on credit hold due to this or other overdue receivables. Credit hold blocks new orders and shipments.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daysPastDue rdf:type rdf:Property ;
    rdfs:label 'Days Past Due' ;
    rdfs:comment 'Number of calendar days the receivable is overdue. Calculated as current date minus due date for unpaid balances. Zero or negative for current receivables.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeReference rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference' ;
    rdfs:comment 'External reference number for the dispute case. Links to dispute resolution system or customer service ticket.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date of the most recent contact attempt with the debtor regarding this receivable. Includes phone calls, emails, and letters.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date the most recent dunning notice was sent to the debtor. Used to calculate next dunning run eligibility and escalation timing.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDunningDate rdf:type rdf:Property ;
    rdfs:label 'Next Dunning Date' ;
    rdfs:comment 'Calculated date for the next dunning notice. Based on dunning frequency configuration and last dunning date.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalAmount rdf:type rdf:Property ;
    rdfs:label 'Original Amount' ;
    rdfs:comment 'Original gross amount of the receivable at invoice creation. Represents the initial debt obligation before any payments or adjustments.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Flag' ;
    rdfs:comment 'Boolean flag indicating whether the debtor is on an approved payment plan for this receivable. Payment plan receivables follow modified dunning rules.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivableNumber rdf:type rdf:Property ;
    rdfs:label 'Receivable Number' ;
    rdfs:comment 'Business-facing document number for the receivable item. Externally visible identifier used in collections correspondence and dunning letters.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivableStatus rdf:type rdf:Property ;
    rdfs:label 'Receivable Status' ;
    rdfs:comment 'Current lifecycle state of the receivable. Tracks progression from open through payment, dispute, collections, or write-off. [ENUM-REF-CANDIDATE: open|partially_paid|paid|disputed|written_off|under_collection|legal_action — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivableType rdf:type rdf:Property ;
    rdfs:label 'Receivable Type' ;
    rdfs:comment 'Classification of the receivable by business transaction type. Distinguishes vehicle sales, parts, service, warranty, fleet, incentive recovery, and finance charges. [ENUM-REF-CANDIDATE: vehicle_sale|parts_sale|service_charge|warranty_reimbursement|fleet_invoice|incentive_recovery|finance_charge — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapFiCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Company Code' ;
    rdfs:comment 'SAP company code representing the legal entity that owns this receivable. Used for multi-entity consolidation and statutory reporting.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'Amount written off as bad debt. May differ from outstanding balance if partial recovery was achieved before write-off.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'Date the receivable was written off. Represents the accounting period when the bad debt expense was recognized.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffFlag rdf:type rdf:Property ;
    rdfs:label 'Write Off Flag' ;
    rdfs:comment 'Boolean flag indicating whether the receivable has been written off as uncollectible bad debt. Written-off receivables are removed from active AR aging.' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:writeOffReason rdf:type rdf:Property ;
    rdfs:label 'Write Off Reason' ;
    rdfs:comment 'Reason code for the write-off decision. Documents the business justification for recognizing bad debt expense. [ENUM-REF-CANDIDATE: bankruptcy|insolvency|uncollectible|customer_closure|legal_settlement|small_balance|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Receivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableTransactionTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Transaction Types' ;
    rdfs:comment 'Comma-separated list of transaction types to which this tax code applies. Examples: vehicle_sale, parts_sale, service_labor, warranty_repair, fleet_lease, export_sale, dealer_invoice, retail_invoice. Supports multi-transaction applicability.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'The method used to calculate the tax amount. Percentage for rate-based calculation, fixed_amount for flat fees, tiered for progressive rates based on value bands, formula_based for complex calculations (e.g., emissions-based environmental levies).' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date from which this tax code and rate become active and applicable to transactions. Supports time-based tax rate changes and regulatory compliance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exemptionCertificateRequired rdf:type rdf:Property ;
    rdfs:label 'Exemption Certificate Required' ;
    rdfs:comment 'Indicates whether a tax exemption certificate must be on file to apply this code for exempt transactions. True if certificate is mandatory, False otherwise. Supports compliance with exemption documentation requirements.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'The date on which this tax code and rate cease to be valid. Nullable for indefinite validity. Supports sunset provisions and temporary tax measures.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isDeductible rdf:type rdf:Property ;
    rdfs:label 'Is Deductible' ;
    rdfs:comment 'Indicates whether the tax is deductible as a business expense for income tax purposes. Relevant for excise duties and certain non-recoverable taxes.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecoverable rdf:type rdf:Property ;
    rdfs:label 'Is Recoverable' ;
    rdfs:comment 'Indicates whether the tax paid under this code can be recovered or reclaimed from the tax authority (e.g., input VAT). True for recoverable taxes, False for non-recoverable taxes.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code or extended jurisdiction identifier (e.g., USA-CA for California, DEU for Germany, IND-MH for Maharashtra). Identifies the specific geographic area where this tax applies.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Level' ;
    rdfs:comment 'The governmental or regional level at which this tax is levied. Federal for national taxes, state for US state or equivalent provincial taxes, local for city/county taxes, EU for European Union-wide directives, APAC for Asia-Pacific regional harmonized taxes, multi_jurisdiction for taxes spanning multiple levels.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Code' ;
    rdfs:comment 'The code or box number used when reporting this tax on statutory returns (e.g., VAT return box 1, GST return line 3A). Supports automated regulatory reporting and compliance.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reverseChargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Reverse Charge Applicable' ;
    rdfs:comment 'Indicates whether the reverse charge mechanism applies, where the customer rather than the supplier accounts for VAT. Common in B2B cross-border EU transactions and certain domestic supplies.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roundingPrecision rdf:type rdf:Property ;
    rdfs:label 'Rounding Precision' ;
    rdfs:comment 'The number of decimal places to which tax amounts are rounded (e.g., 2 for cents/pence, 0 for whole currency units). Supports multi-currency precision requirements.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roundingRule rdf:type rdf:Property ;
    rdfs:label 'Rounding Rule' ;
    rdfs:comment 'The rounding method applied to calculated tax amounts. Round_up for ceiling, round_down for floor, round_nearest for standard rounding, no_rounding for exact amounts. Ensures compliance with jurisdiction-specific rounding regulations.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapFiTaxCode rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Tax Code' ;
    rdfs:comment 'The corresponding tax code identifier in SAP FI module (table T007A, field MWSKZ). Typically 1-2 character alphanumeric. Enables integration and reconciliation between lakehouse and SAP ERP.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSdTaxCode rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Tax Code' ;
    rdfs:comment 'The corresponding tax code identifier in SAP SD module used in sales orders and billing documents. May differ from FI code in some implementations. Supports sales-specific tax determination.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Name' ;
    rdfs:comment 'The name of the governmental or regulatory body responsible for administering this tax. Examples: Internal Revenue Service (IRS), HM Revenue & Customs (HMRC), Goods and Services Tax Network (GSTN), California Department of Tax and Fee Administration.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAuthorityReference rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Reference' ;
    rdfs:comment 'The official reference number, code, or identifier assigned by the tax authority for this tax type or rate. Used for regulatory reporting and audit trail.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxBasis rdf:type rdf:Property ;
    rdfs:label 'Tax Basis' ;
    rdfs:comment 'The base amount on which the tax rate is applied. Net_amount for taxes on pre-tax subtotal, gross_amount for taxes on total including other taxes (cascading), MSRP (Manufacturer Suggested Retail Price) for luxury taxes, invoice_value for dealer invoices, customs_value for import duties.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'The accounting treatment category for this tax. Input_tax for recoverable VAT on purchases, output_tax for VAT charged on sales, withholding_tax for taxes deducted at source, reverse_charge for customer-remitted VAT, exempt for tax-exempt transactions, zero_rated for 0% taxable supplies.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCodeCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code Code' ;
    rdfs:comment 'The alphanumeric tax code identifier used in billing and invoicing systems. Maps to SAP FI/SD tax code field (MWSKZ). Examples: VAT_STD, GST_18, SALES_TX_CA, EXCISE_LUX.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCodeName rdf:type rdf:Property ;
    rdfs:label 'Tax Code Name' ;
    rdfs:comment 'Human-readable name or description of the tax code for display and reporting purposes.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Code Status' ;
    rdfs:comment 'Current lifecycle status of the tax code. Active for codes in use, inactive for retired codes, pending for codes awaiting regulatory approval, superseded for codes replaced by newer versions.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'The tax rate as a percentage (e.g., 19.0000 for 19% VAT, 5.5000 for 5.5% GST). Precision to four decimal places supports fine-grained rates. Used to calculate tax amount from taxable base.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'The category of tax represented by this code. VAT (Value Added Tax) for EU and similar jurisdictions, GST (Goods and Services Tax) for India/Australia/Canada, sales_tax for US state-level, excise for fuel/alcohol/tobacco duties, luxury_tax for high-value vehicles, environmental_levy for emissions-based charges.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxApplicable rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Applicable' ;
    rdfs:comment 'Indicates whether withholding tax provisions apply to transactions using this code. Relevant for cross-border payments and certain domestic transactions where tax is deducted at source.' ;
    rdfs:domain ind:TaxCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:writeOffId rdf:type rdf:Property ;
    rdfs:label 'Write Off Id' ;
    rdfs:comment 'Unique identifier for the bad debt write-off record. Primary key.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalAuthorityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Employee Id' ;
    rdfs:comment 'Reference to the employee or manager who authorized the write-off. Links to workforce/employee master data.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Name' ;
    rdfs:comment 'Full name of the individual who approved the write-off, captured for audit trail purposes.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'The organizational level at which the write-off was approved, typically based on write-off amount thresholds. Values: manager, director, vp (vice president), cfo (chief financial officer).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Collection Agency Code' ;
    rdfs:comment 'Reference to the third-party collection agency assigned to pursue recovery of the written-off debt. Nullable if no agency was engaged.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysPastDueAtWriteOff rdf:type rdf:Property ;
    rdfs:label 'Days Past Due At Write Off' ;
    rdfs:comment 'The number of days the receivable was overdue at the time of write-off. Used for aging analysis and credit policy evaluation.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalCaseReference rdf:type rdf:Property ;
    rdfs:label 'Legal Case Reference' ;
    rdfs:comment 'Reference number for any associated legal case, bankruptcy filing, or court proceeding related to the write-off. Nullable if no legal action was involved.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalDueDate rdf:type rdf:Property ;
    rdfs:label 'Original Due Date' ;
    rdfs:comment 'The original payment due date of the invoice before it became delinquent and was subsequently written off.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Amount' ;
    rdfs:comment 'The original gross amount of the invoice before any payments, credits, or write-offs were applied. Provides context for the write-off magnitude.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingBalanceBeforeWriteOff rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance Before Write Off' ;
    rdfs:comment 'The receivable balance that was outstanding immediately before the write-off was applied. May differ from original invoice amount if partial payments were received.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Amount' ;
    rdfs:comment 'The monetary amount recovered after the write-off was recorded. Null if no recovery has occurred. Used to track bad debt recovery income.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryDate rdf:type rdf:Property ;
    rdfs:label 'Recovery Date' ;
    rdfs:comment 'The date on which a recovery payment was received for a previously written-off receivable. Null if no recovery has occurred.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recoveryFlag rdf:type rdf:Property ;
    rdfs:label 'Recovery Flag' ;
    rdfs:comment 'Boolean indicator of whether any portion of the written-off amount was subsequently recovered. True if recovery occurred, False otherwise.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapAccountingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Accounting Document Number' ;
    rdfs:comment 'The SAP accounting document number for the general ledger posting of the write-off. May differ from the write-off document number in multi-step posting scenarios.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapWriteOffDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Write Off Document Number' ;
    rdfs:comment 'The SAP FI document number generated when the write-off was posted to the financial system. Used for reconciliation and audit trail.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffCategory rdf:type rdf:Property ;
    rdfs:label 'Write Off Category' ;
    rdfs:comment 'Indicates whether the write-off is for the full outstanding balance or a partial amount. Values: full (entire balance written off), partial (portion of balance written off).' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffNumber rdf:type rdf:Property ;
    rdfs:label 'Write Off Number' ;
    rdfs:comment 'Business-readable unique identifier for the write-off transaction, typically following organizational numbering convention (e.g., WO-20240001234).' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cafeComplianceRecordId rdf:type rdf:Property ;
    rdfs:label 'Cafe Compliance Record Id' ;
    rdfs:comment 'System-generated unique identifier for the CAFE compliance record.' ;
    rdfs:domain ind:CafeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modelId rdf:type rdf:Property ;
    rdfs:label 'Model Id' ;
    rdfs:comment 'Foreign key linking to vehicle.model. Business justification: CAFE credit calculations are performed per vehicle model; linking to model allows accurate credit tracking and reporting per model.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Model .

ind:actualCafeMpg rdf:type rdf:Property ;
    rdfs:label 'Actual Cafe Mpg' ;
    rdfs:comment 'Achieved Corporate Average Fuel Economy for the fleet, expressed in miles per gallon.' ;
    rdfs:domain ind:CafeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceGapMpg rdf:type rdf:Property ;
    rdfs:label 'Compliance Gap Mpg' ;
    rdfs:comment 'Difference between actual and required CAFE; positive indicates surplus, negative indicates shortfall.' ;
    rdfs:domain ind:CafeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditBalance rdf:type rdf:Property ;
    rdfs:label 'Credit Balance' ;
    rdfs:comment 'Monetary value of CAFE credits carried forward or generated in the reporting period.' ;
    rdfs:domain ind:CafeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Credit Expiration Date' ;
    rdfs:comment 'Date on which any banked CAFE credits expire if not used.' ;
    rdfs:domain ind:CafeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fineLiabilityUsd rdf:type rdf:Property ;
    rdfs:label 'Fine Liability Usd' ;
    rdfs:comment 'Potential monetary penalty if the compliance gap is negative and insufficient credits exist.' ;
    rdfs:domain ind:CafeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fleetMixDescription rdf:type rdf:Property ;
    rdfs:label 'Fleet Mix Description' ;
    rdfs:comment 'Narrative description of the vehicle mix (e.g., percentages of cars, trucks, hybrids).' ;
    rdfs:domain ind:CafeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetType rdf:type rdf:Property ;
    rdfs:label 'Fleet Type' ;
    rdfs:comment 'Classification of the vehicle fleet (e.g., domestic car, import car, light truck).' ;
    rdfs:domain ind:CafeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether the record is currently active for reporting purposes.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordLabel rdf:type rdf:Property ;
    rdfs:label 'Record Label' ;
    rdfs:comment 'Human-readable label identifying the compliance record, typically combining model year and fleet type.' ;
    rdfs:domain ind:CafeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordNumber rdf:type rdf:Property ;
    rdfs:label 'Record Number' ;
    rdfs:comment 'External reference number used in regulatory filings and internal reporting.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingStatus rdf:type rdf:Property ;
    rdfs:label 'Reporting Status' ;
    rdfs:comment 'Current status of the regulatory filing process.' ;
    rdfs:domain ind:CafeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingYear rdf:type rdf:Property ;
    rdfs:label 'Reporting Year' ;
    rdfs:comment 'Fiscal year in which the CAFE data is reported to regulators.' ;
    rdfs:domain ind:CafeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredCafeMpg rdf:type rdf:Property ;
    rdfs:label 'Required Cafe Mpg' ;
    rdfs:comment 'Regulatory minimum CAFE value that must be met for the given model year and fleet type.' ;
    rdfs:domain ind:CafeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date the compliance record was submitted to the regulator.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalVehicles rdf:type rdf:Property ;
    rdfs:label 'Total Vehicles' ;
    rdfs:comment 'Number of vehicles included in the fleet mix for this CAFE calculation.' ;
    rdfs:domain ind:CafeComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalAuthorizer rdf:type rdf:Property ;
    rdfs:label 'Approval Authorizer' ;
    rdfs:comment 'Name of the individual who authorized the document.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityRegion rdf:type rdf:Property ;
    rdfs:label 'Authority Region' ;
    rdfs:comment 'Geographic region or country where the issuing authority operates.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksum rdf:type rdf:Property ;
    rdfs:label 'Checksum' ;
    rdfs:comment 'SHA-256 hash of the document file for integrity verification.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDocumentDescription rdf:type rdf:Property ;
    rdfs:label 'Compliance Document Description' ;
    rdfs:comment 'Brief narrative describing the purpose and content of the compliance document.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDocumentStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Document Status' ;
    rdfs:comment 'Current lifecycle status of the compliance document.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Classification indicating the sensitivity of the document content.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignaturePresent rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Present' ;
    rdfs:comment 'Indicates whether the document includes a verified digital signature.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Official reference number assigned to the compliance document by the issuing authority or internal system.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Category of the compliance document indicating its nature.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'File format of the stored digital document.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the digital document file in bytes.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Organization or agency that issued the compliance document (e.g., EPA, NHTSA).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Three-letter country code representing the jurisdiction of the regulation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'Language code (ISO 639-1) of the document content.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationType rdf:type rdf:Property ;
    rdfs:label 'Regulation Type' ;
    rdfs:comment 'Type of regulation the document satisfies.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedModelYear rdf:type rdf:Property ;
    rdfs:label 'Related Model Year' ;
    rdfs:comment 'Model year of the vehicle(s) to which the document applies.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relatedVehicleVin rdf:type rdf:Property ;
    rdfs:label 'Related Vehicle Vin' ;
    rdfs:comment 'Vehicle Identification Number of a vehicle associated with the document, if applicable.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPolicy rdf:type rdf:Property ;
    rdfs:label 'Retention Policy' ;
    rdfs:comment 'Policy governing how long the document must be retained.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageUri rdf:type rdf:Property ;
    rdfs:label 'Storage Uri' ;
    rdfs:comment 'Uniform Resource Identifier pointing to the document location in the document management system.' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionLabel rdf:type rdf:Property ;
    rdfs:label 'Version Label' ;
    rdfs:comment 'Human-readable version label (e.g., v1.2, Rev A).' ;
    rdfs:domain ind:ComplianceDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationId rdf:type rdf:Property ;
    rdfs:label 'Obligation Id' ;
    rdfs:comment 'System-generated unique identifier for the compliance obligation record.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Identifier of the internal engineering team accountable for the obligation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:actualCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Certification Date' ;
    rdfs:comment 'Date on which certification was actually obtained.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Created Timestamp' ;
    rdfs:comment 'Timestamp when the compliance obligation record was first created in the system.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the compliance obligation record.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'External agency or authority that issues the certification (e.g., EPA, NHTSA).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Score' ;
    rdfs:comment 'Numeric score (0-100) reflecting overall compliance health for the obligation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Deadline for completing corrective actions.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Planned actions to remediate non-compliance.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionValue rdf:type rdf:Property ;
    rdfs:label 'Emission Value' ;
    rdfs:comment 'Measured emission metric (e.g., g/km CO₂) associated with the obligation.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceDocumentPath rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Path' ;
    rdfs:comment 'File system or URL path to supporting evidence files.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelEconomyValue rdf:type rdf:Property ;
    rdfs:label 'Fuel Economy Value' ;
    rdfs:comment 'Measured fuel economy (e.g., mpg or L/100km) relevant to the obligation.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRegulatory rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory' ;
    rdfs:comment 'True if the obligation is mandated by external regulation; false if internal policy.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Planned date for the next compliance review.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonComplianceReason rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Reason' ;
    rdfs:comment 'Root cause description for a non-compliant status.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationNumber rdf:type rdf:Property ;
    rdfs:label 'Obligation Number' ;
    rdfs:comment 'Business identifier assigned to the regulatory obligation, often used in internal tracking and external filings.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationStatus rdf:type rdf:Property ;
    rdfs:label 'Obligation Status' ;
    rdfs:comment 'Current lifecycle status of the compliance obligation.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationCode rdf:type rdf:Property ;
    rdfs:label 'Regulation Code' ;
    rdfs:comment 'Standardized code or identifier for the regulation as defined by the governing body.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationName rdf:type rdf:Property ;
    rdfs:label 'Regulation Name' ;
    rdfs:comment 'Full official name of the regulation (e.g., "EPA Tier 3 Emissions Standard").' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleEngineeringGroup rdf:type rdf:Property ;
    rdfs:label 'Responsible Engineering Group' ;
    rdfs:comment 'Human-readable name of the engineering group leading the compliance effort.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Target Certification Date' ;
    rdfs:comment 'Planned date by which certification is expected to be achieved.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'Date on which the regulatory test was performed.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testFacility rdf:type rdf:Property ;
    rdfs:label 'Test Facility' ;
    rdfs:comment 'Name of the laboratory or site where testing occurred.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethod rdf:type rdf:Property ;
    rdfs:label 'Test Method' ;
    rdfs:comment 'Standardized method or protocol used for the test (e.g., WLTP, SAE J1979).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResult rdf:type rdf:Property ;
    rdfs:label 'Test Result' ;
    rdfs:comment 'Outcome of the regulatory test associated with the obligation.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Explanation why the obligation was waived, if applicable.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testEventId rdf:type rdf:Property ;
    rdfs:label 'Test Event Id' ;
    rdfs:comment 'System-generated unique identifier for the compliance test event record.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestEvent .

ind:homologationId rdf:type rdf:Property ;
    rdfs:label 'Homologation Id' ;
    rdfs:comment 'Identifier of the homologation record associated with this test.' ;
    rdfs:domain ind:Automotive ;
