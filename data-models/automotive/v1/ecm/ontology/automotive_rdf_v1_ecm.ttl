    rdfs:comment 'Business rules that determine which customers or vehicles may subscribe to the service.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endOfServiceDate rdf:type rdf:Property ;
    rdfs:label 'End Of Service Date' ;
    rdfs:comment 'Date when the service is retired or no longer offered.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isPremium rdf:type rdf:Property ;
    rdfs:label 'Is Premium' ;
    rdfs:comment 'Indicates whether the service is classified as a premium offering.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxSimultaneousDevices rdf:type rdf:Property ;
