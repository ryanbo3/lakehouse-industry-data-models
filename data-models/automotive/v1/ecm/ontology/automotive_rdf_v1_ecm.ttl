    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the record.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:warrantyCovered rdf:type rdf:Property ;
    rdfs:label 'Warranty Covered' ;
    rdfs:comment 'Indicates if the remedy is covered under warranty.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSatisfactionSurveyId rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Survey Id' ;
    rdfs:comment 'Unique surrogate key for each survey response record.' ;
