    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Version identifier of the budget used for the incentive program.' ;
    rdfs:domain ind:DealerIncentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerIncentiveDescription rdf:type rdf:Property ;
    rdfs:label 'Dealer Incentive Description' ;
    rdfs:comment 'Free-form description of the incentive program purpose and rules.' ;
    rdfs:domain ind:DealerIncentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealerIncentiveStatus rdf:type rdf:Property ;
    rdfs:label 'Dealer Incentive Status' ;
    rdfs:comment 'Current lifecycle status of the incentive program.' ;
    rdfs:domain ind:DealerIncentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveAmountPerUnit rdf:type rdf:Property ;
    rdfs:label 'Incentive Amount Per Unit' ;
    rdfs:comment 'Monetary amount awarded per eligible vehicle unit.' ;
    rdfs:domain ind:DealerIncentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveCategory rdf:type rdf:Property ;
    rdfs:label 'Incentive Category' ;
    rdfs:comment 'Higher-level category of the incentive (e.g., new_vehicle, electric).' ;
    rdfs:domain ind:DealerIncentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Indicates whether the incentive amount is subject to tax.' ;
