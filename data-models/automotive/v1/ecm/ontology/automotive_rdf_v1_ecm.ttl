    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearedFlag rdf:type rdf:Property ;
    rdfs:label 'Cleared Flag' ;
    rdfs:comment 'Indicates whether the DTC has been cleared (true) or remains active (false).' ;
    rdfs:domain ind:AftersalesDtcEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diagnosticSessionType rdf:type rdf:Property ;
