ind:isSerialTracked rdf:type rdf:Property ;
    rdfs:label 'Is Serial Tracked' ;
    rdfs:comment 'True if the material is tracked by serial number.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationZone rdf:type rdf:Property ;
    rdfs:label 'Location Zone' ;
    rdfs:comment 'Specific zone or area within the warehouse for the storage location.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementReason rdf:type rdf:Property ;
    rdfs:label 'Movement Reason' ;
    rdfs:comment 'Business reason prompting the inventory movement.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'Type of the reference document (Purchase Order, Production Order, Work Order, Delivery, Service Order).' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcePlant rdf:type rdf:Property ;
    rdfs:label 'Source Plant' ;
    rdfs:comment 'Plant where the material originated.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseNumber rdf:type rdf:Property ;
    rdfs:label 'Warehouse Number' ;
    rdfs:comment 'Identifier of the warehouse where the movement occurs.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Id' ;
    rdfs:comment 'System-generated unique identifier for the inventory adjustment transaction.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Created By User Employee Id' ;
    rdfs:comment 'System user identifier who created the adjustment record.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Employee Id' ;
    rdfs:comment 'Identifier of the employee who approved the inventory adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Updated By User Employee Id' ;
    rdfs:comment 'System user identifier who last modified the adjustment record.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Accounting Document Number' ;
    rdfs:comment 'Financial document number generated for the adjustment in the general ledger.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle status of the adjustment transaction.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Category describing why the inventory adjustment was performed.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Amount' ;
    rdfs:comment 'Monetary impact of the adjustment on inventory valuation.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectNumber rdf:type rdf:Property ;
    rdfs:label 'Project Number' ;
    rdfs:comment 'Project identifier if the adjustment is linked to a specific internal project.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAdjusted rdf:type rdf:Property ;
    rdfs:label 'Quantity Adjusted' ;
    rdfs:comment 'Signed quantity change; positive for additions, negative for reductions.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relatedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Related Document Number' ;
    rdfs:comment 'Reference to an external document (e.g., PPAP, audit report) linked to the adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIndicator rdf:type rdf:Property ;
    rdfs:label 'Tax Indicator' ;
    rdfs:comment 'Indicates whether the adjustment is subject to tax.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationAreaCode rdf:type rdf:Property ;
    rdfs:label 'Valuation Area Code' ;
    rdfs:comment 'Code representing the valuation area used for inventory accounting.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdId rdf:type rdf:Property ;
    rdfs:label 'Hold Id' ;
    rdfs:comment 'Unique identifier for the inventory hold record.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initiatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Initiated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Hold audit requires knowing which employee initiated the inventory hold; supports compliance and root-cause analysis.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supplierNonconformanceId rdf:type rdf:Property ;
    rdfs:label 'Supplier Nonconformance Id' ;
    rdfs:comment 'Identifier of the regulatory non-conformance case linked to the hold.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierNonconformance .

ind:actualReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Release Timestamp' ;
    rdfs:comment 'Date and time when the hold was actually released.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expected Release Timestamp' ;
    rdfs:comment 'Planned date and time for hold release.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Number' ;
    rdfs:comment 'System-generated hold reference number.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdSource rdf:type rdf:Property ;
    rdfs:label 'Hold Source' ;
    rdfs:comment 'Indicates whether the hold was generated automatically by the system or entered manually.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle status of the hold.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Category of hold indicating reason source.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatingDepartment rdf:type rdf:Property ;
    rdfs:label 'Initiating Department' ;
    rdfs:comment 'Department that initiated the hold.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalHold rdf:type rdf:Property ;
    rdfs:label 'Is Critical Hold' ;
    rdfs:comment 'Indicates if the hold is critical to production safety.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityHeld rdf:type rdf:Property ;
    rdfs:label 'Quantity Held' ;
    rdfs:comment 'Total quantity of items placed on hold.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relatedEcnNumber rdf:type rdf:Property ;
    rdfs:label 'Related Ecn Number' ;
    rdfs:comment 'Reference to the ECN that triggered the hold, if applicable.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedPpapStatus rdf:type rdf:Property ;
    rdfs:label 'Related Ppap Status' ;
    rdfs:comment 'Status of the supplier PPAP related to the hold.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumberEnd rdf:type rdf:Property ;
    rdfs:label 'Serial Number End' ;
    rdfs:comment 'Ending serial number in the range held.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumberStart rdf:type rdf:Property ;
    rdfs:label 'Serial Number Start' ;
    rdfs:comment 'Starting serial number in the range held (if serialized).' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountDeterminationRelevant rdf:type rdf:Property ;
    rdfs:label 'Account Determination Relevant' ;
    rdfs:comment 'Flag indicating whether the movement type triggers automatic account determination for financial posting.' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowedDestinationLocationType rdf:type rdf:Property ;
    rdfs:label 'Allowed Destination Location Type' ;
    rdfs:comment 'Type of location permitted as the destination for this movement.' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowedSourceLocationType rdf:type rdf:Property ;
    rdfs:label 'Allowed Source Location Type' ;
    rdfs:comment 'Type of location permitted as the source for this movement (e.g., plant, warehouse, vendor).' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchManagementRequired rdf:type rdf:Property ;
    rdfs:label 'Batch Management Required' ;
    rdfs:comment 'Indicates if batch management must be maintained for movements of this type.' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCenterRequired rdf:type rdf:Property ;
    rdfs:label 'Cost Center Required' ;
    rdfs:comment 'Indicates if a cost center must be supplied when posting this movement.' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultQuantitySign rdf:type rdf:Property ;
    rdfs:label 'Default Quantity Sign' ;
    rdfs:comment 'Default sign (+1 or -1) applied to quantity for this movement type.' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates whether the movement adds stock (inbound), removes stock (outbound), or moves stock between locations (transfer).' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialAllowed rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Allowed' ;
    rdfs:comment 'Indicates whether hazardous materials may be moved using this movement type.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryAccountingRelevant rdf:type rdf:Property ;
    rdfs:label 'Inventory Accounting Relevant' ;
    rdfs:comment 'Flag indicating whether the movement type affects inventory valuation and accounting.' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryImpact rdf:type rdf:Property ;
    rdfs:label 'Inventory Impact' ;
    rdfs:comment 'Indicates whether the movement increases, decreases, or does not change stock levels.' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isJis rdf:type rdf:Property ;
    rdfs:label 'Is Jis' ;
    rdfs:comment 'True if the movement type supports Just-In-Sequence production scheduling.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isJit rdf:type rdf:Property ;
    rdfs:label 'Is Jit' ;
    rdfs:comment 'True if the movement type is used in Just-In-Time procurement processes.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:movementCategory rdf:type rdf:Property ;
    rdfs:label 'Movement Category' ;
    rdfs:comment 'High-level category grouping of movement types.' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementReasonCode rdf:type rdf:Property ;
    rdfs:label 'Movement Reason Code' ;
    rdfs:comment 'Optional code that provides additional reason for the movement (e.g., scrap, rework).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTypeCode rdf:type rdf:Property ;
    rdfs:label 'Movement Type Code' ;
    rdfs:comment 'Alphanumeric code that uniquely identifies the movement type (e.g., 101 for goods receipt, 261 for goods issue).' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Movement Type Description' ;
    rdfs:comment 'Human-readable description of the movement type and its business purpose.' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceControl rdf:type rdf:Property ;
    rdfs:label 'Price Control' ;
    rdfs:comment 'Method used for inventory valuation for this movement type.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterRequired rdf:type rdf:Property ;
    rdfs:label 'Profit Center Required' ;
    rdfs:comment 'Indicates if a profit center must be supplied for this movement type.' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Flag indicating whether a quality inspection record is mandatory for this movement.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalAllowed rdf:type rdf:Property ;
    rdfs:label 'Reversal Allowed' ;
    rdfs:comment 'Flag indicating whether this movement type can be reversed by another movement.' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalMovementTypeCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Movement Type Code' ;
    rdfs:comment 'Code of the movement type that reverses this movement (e.g., 102 reverses 101).' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumberRequired rdf:type rdf:Property ;
    rdfs:label 'Serial Number Required' ;
    rdfs:comment 'Indicates if serial numbers must be captured for this movement type.' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Stock Indicator' ;
    rdfs:comment 'Identifies special stock categories (e.g., blocked stock, quality inspection stock) associated with the movement.' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemDefined rdf:type rdf:Property ;
    rdfs:label 'System Defined' ;
    rdfs:comment 'True if the movement type is delivered by SAP and cannot be deleted.' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxRelevant rdf:type rdf:Property ;
    rdfs:label 'Tax Relevant' ;
    rdfs:comment 'Flag indicating whether tax calculation is applicable for this movement.' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionEvent rdf:type rdf:Property ;
    rdfs:label 'Transaction Event' ;
    rdfs:comment 'Business event that typically generates this movement type (e.g., purchase order receipt, production order issue).' ;
    rdfs:domain ind:MovementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'Key used in valuation to determine price control and account assignment.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryValuationId rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Id' ;
    rdfs:comment 'System generated unique identifier for each inventory valuation record.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:area rdf:type rdf:Property ;
    rdfs:label 'Area' ;
    rdfs:comment 'Logical area used for valuation (e.g., unrestricted, blocked, quality inspection).' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastValuationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Valuation Timestamp' ;
    rdfs:comment 'Exact timestamp when the valuation calculation was performed.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:movingAveragePrice rdf:type rdf:Property ;
    rdfs:label 'Moving Average Price' ;
    rdfs:comment 'Weighted average price of the material based on receipt and issue movements, used when price control is moving average.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obsolescenceFlag rdf:type rdf:Property ;
    rdfs:label 'Obsolescence Flag' ;
    rdfs:comment 'Indicates whether the material is considered obsolete and may require a write-down.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceVariance rdf:type rdf:Property ;
    rdfs:label 'Price Variance' ;
    rdfs:comment 'Difference between standard price and moving average price, useful for variance analysis.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardPrice rdf:type rdf:Property ;
    rdfs:label 'Standard Price' ;
    rdfs:comment 'Fixed price defined for the material in the valuation class, used when price control is standard.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Stock Quantity' ;
    rdfs:comment 'Aggregated quantity of the material on hand across the valuation area, expressed in base units.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStockValue rdf:type rdf:Property ;
    rdfs:label 'Total Stock Value' ;
    rdfs:comment 'Monetary value of the total stock quantity calculated using the applicable price (standard or moving average).' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationStatus rdf:type rdf:Property ;
    rdfs:label 'Valuation Status' ;
    rdfs:comment 'Current processing state of the valuation record.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeDownAmount rdf:type rdf:Property ;
    rdfs:label 'Write Down Amount' ;
    rdfs:comment 'Financial amount to be written down from inventory value due to obsolescence or impairment.' ;
    rdfs:domain ind:InventoryValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kanbanCardId rdf:type rdf:Property ;
    rdfs:label 'Kanban Card Id' ;
    rdfs:comment 'System-generated unique identifier for the kanban card record.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardNumber rdf:type rdf:Property ;
    rdfs:label 'Card Number' ;
    rdfs:comment 'Human-readable identifier printed on the physical or electronic kanban card.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardsInCirculation rdf:type rdf:Property ;
    rdfs:label 'Cards In Circulation' ;
    rdfs:comment 'Total number of active kanban cards for this SKU and work center combination.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumingWorkCenter rdf:type rdf:Property ;
    rdfs:label 'Consuming Work Center' ;
    rdfs:comment 'Identifier of the work center that consumes the material signaled by this kanban.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerQuantity rdf:type rdf:Property ;
    rdfs:label 'Container Quantity' ;
    rdfs:comment 'Number of units of the SKU contained in one kanban container.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'Physical container format used for the kanban (e.g., bin, pallet, box).' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isJisEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Jis Enabled' ;
    rdfs:comment 'Indicates whether the kanban is used in a JIS sequencing context.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isJitEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Jit Enabled' ;
    rdfs:comment 'Indicates whether the kanban participates in a JIT production flow.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kanbanCardDescription rdf:type rdf:Property ;
    rdfs:label 'Kanban Card Description' ;
    rdfs:comment 'Free-form text describing special handling or notes for the kanban.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kanbanStatus rdf:type rdf:Property ;
    rdfs:label 'Kanban Status' ;
    rdfs:comment 'Current state of the kanban card (e.g., empty, in-transit, full, blocked).' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastConsumptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Consumption Timestamp' ;
    rdfs:comment 'Timestamp when the downstream work center recorded consumption of the kanban-linked material.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastSignalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Signal Timestamp' ;
    rdfs:comment 'Timestamp of the most recent kanban signal (e.g., when the card turned empty).' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotControlFlag rdf:type rdf:Property ;
    rdfs:label 'Lot Control Flag' ;
    rdfs:comment 'Indicates whether the material is managed by lot/lot number.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reorderPointQty rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Qty' ;
    rdfs:comment 'Inventory level at which a new kanban card is generated to trigger replenishment.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Replenishment Strategy' ;
    rdfs:comment 'Method used to replenish the downstream inventory when the kanban signals empty.' ;
    rdfs:domain ind:KanbanCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockQty rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Qty' ;
    rdfs:comment 'Minimum safety stock quantity maintained for the SKU to protect against variability.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialControlFlag rdf:type rdf:Property ;
