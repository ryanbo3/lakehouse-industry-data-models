    rdfs:range xsd:boolean .

ind:privacyPolicyVersion rdf:type rdf:Property ;
    rdfs:label 'Privacy Policy Version' ;
    rdfs:comment 'Version identifier of the privacy policy accepted at subscription time.' ;
