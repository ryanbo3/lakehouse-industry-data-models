    rdfs:range xsd:string .

ind:networkType rdf:type rdf:Property ;
    rdfs:label 'Network Type' ;
    rdfs:comment 'Communication medium used for the remote session.' ;
    rdfs:domain ind:RemoteDiagnosticSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedActionCodes rdf:type rdf:Property ;
