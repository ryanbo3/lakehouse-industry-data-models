ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Date and time of the most recent modification to the warranty policy record.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
