    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesRepEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sales Rep Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Sales commission reports require linking each subscription to the sales representative employee who closed the deal.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:billingAmount rdf:type rdf:Property ;
    rdfs:label 'Billing Amount' ;
    rdfs:comment 'Base amount charged per billing cycle before taxes, fees, or discounts.' ;
    rdfs:domain ind:Automotive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceGdprConsent rdf:type rdf:Property ;
    rdfs:label 'Compliance Gdpr Consent' ;
    rdfs:comment 'True if the subscriber has provided consent for data processing under GDPR.' ;
    rdfs:domain ind:ServiceSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractTerms rdf:type rdf:Property ;
    rdfs:label 'Contract Terms' ;
    rdfs:comment 'Free-text description of the contractual obligations, service level agreements, and special conditions.' ;
    rdfs:domain ind:ServiceSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingOptIn rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Opt In' ;
    rdfs:comment 'True if the subscriber agrees to share usage data with third-party partners.' ;
    rdfs:domain ind:ServiceSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entitlementTier rdf:type rdf:Property ;
