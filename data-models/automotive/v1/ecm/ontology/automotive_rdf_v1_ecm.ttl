ind:handoverLocation rdf:type rdf:Property ;
    rdfs:label 'Handover Location' ;
    rdfs:comment 'Physical location (plant, compound, yard, or dealer site) where the handover took place.' ;
    rdfs:domain ind:VehicleHandover ;
    rdf:type owl:DatatypeProperty ;
