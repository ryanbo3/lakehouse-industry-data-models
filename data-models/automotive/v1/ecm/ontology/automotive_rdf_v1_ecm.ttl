    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Payment Amount' ;
    rdfs:comment 'Monetary amount that has been paid to the dealer for the incentive.' ;
    rdfs:domain ind:DealerIncentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualUnitsAccrued rdf:type rdf:Property ;
    rdfs:label 'Actual Units Accrued' ;
    rdfs:comment 'Number of units that have actually accrued incentive eligibility.' ;
