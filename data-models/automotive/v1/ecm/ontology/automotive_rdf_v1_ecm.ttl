ind:partCount rdf:type rdf:Property ;
    rdfs:label 'Part Count' ;
    rdfs:comment 'Number of distinct parts measured during the study.' ;
    rdfs:domain ind:GaugeMsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:studyDate rdf:type rdf:Property ;
    rdfs:label 'Study Date' ;
    rdfs:comment 'Calendar date when the MSA study was conducted.' ;
    rdfs:domain ind:GaugeMsa ;
