    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized code describing why the part is being returned.' ;
