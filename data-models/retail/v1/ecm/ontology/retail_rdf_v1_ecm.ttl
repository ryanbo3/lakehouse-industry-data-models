    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bodyContent rdf:type rdf:Property ;
    rdfs:label 'Body Content' ;
    rdfs:comment 'Main message body content with support for HTML markup for email templates or plain text for SMS. Contains merge field placeholders for personalization.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characterCount rdf:type rdf:Property ;
    rdfs:label 'Character Count' ;
    rdfs:comment 'Total character count of the message body content. Critical for SMS templates with character limits.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceReviewed rdf:type rdf:Property ;
    rdfs:label 'Compliance Reviewed' ;
    rdfs:comment 'Indicates whether the template content has been reviewed and approved for regulatory compliance including CAN-SPAM, GDPR, and TCPA requirements.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Reviewed Date' ;
    rdfs:comment 'Date when the template was last reviewed for regulatory compliance.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Design Template Code' ;
    rdfs:comment 'Reference to the visual design template or layout framework used for rendering this message.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedSendTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Estimated Send Time Seconds' ;
    rdfs:comment 'Average estimated time in seconds required to process and send a message using this template.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
