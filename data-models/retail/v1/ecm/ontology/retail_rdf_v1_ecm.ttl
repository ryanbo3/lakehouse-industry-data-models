    rdfs:range xsd:string .

ind:templateType rdf:type rdf:Property ;
    rdfs:label 'Template Type' ;
    rdfs:comment 'Classification of the message template by delivery channel type.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSendsCount rdf:type rdf:Property ;
    rdfs:label 'Total Sends Count' ;
    rdfs:comment 'Cumulative count of messages sent using this template since activation.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unsubscribeLinkRequired rdf:type rdf:Property ;
