    rdfs:comment 'Level of enforcement power the agency holds (full enforcement with penalties, advisory only, certification authority, audit-only).' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'Date when the regulatory agency was officially established or incorporated.' ;
    rdfs:domain ind:RegulatoryAgency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionFrequencyDays rdf:type rdf:Property ;
