ind:paymentFileName rdf:type rdf:Property ;
    rdfs:label 'Payment File Name' ;
    rdfs:comment 'The name of the payment file generated for this payment run and transmitted to the bank or payment processor.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business identifier for the payment run, formatted as PR-YYYYMMDD-NNNN for external reference and audit trails.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the payment run based on the business purpose and payment category.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successfulPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Successful Payment Count' ;
    rdfs:comment 'The number of payments that were successfully processed and completed within this payment run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Amount' ;
    rdfs:comment 'The total gross amount of all payments included in this payment run before any adjustments or fees.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Count' ;
    rdfs:comment 'The total number of individual payment transactions included in this payment run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentVersionId rdf:type rdf:Property ;
    rdfs:label 'Parent Version Id' ;
    rdfs:comment 'Reference to the parent plan version from which this version was derived or copied. Null for original versions.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanVersion .

ind:scenarioId rdf:type rdf:Property ;
    rdfs:label 'Scenario Id' ;
    rdfs:comment 'Reference to the planning scenario (e.g., best case, worst case, most likely) that this version represents.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Scenario .

ind:submittedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Submitted By User Associate Id' ;
    rdfs:comment 'Reference to the user who submitted this plan version for approval.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:assumptions rdf:type rdf:Property ;
    rdfs:label 'Assumptions' ;
    rdfs:comment 'Key assumptions underlying this plan version, such as growth rates, inflation rates, market conditions, or strategic initiatives.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBaseline rdf:type rdf:Property ;
    rdfs:label 'Is Baseline' ;
    rdfs:comment 'Indicates whether this version serves as the baseline or reference version for variance analysis and performance tracking.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'The date when this plan version was submitted for review and approval.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:versionName rdf:type rdf:Property ;
    rdfs:label 'Version Name' ;
    rdfs:comment 'Human-readable name or label for this plan version (e.g., \'Initial Budget\', \'Mid-Year Reforecast\', \'Board Approved Version\').' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionType rdf:type rdf:Property ;
    rdfs:label 'Version Type' ;
    rdfs:comment 'Classification of the plan version type indicating its purpose in the planning cycle.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Initiated By User Associate Id' ;
    rdfs:comment 'Reference to the user who initiated this netting run, supporting accountability and audit trail requirements.' ;
    rdfs:domain ind:NettingRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Reference to the legal entity for which this netting run is executed, supporting multi-entity financial consolidation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:reversedByRunId rdf:type rdf:Property ;
    rdfs:label 'Reversed By Run Id' ;
    rdfs:comment 'Reference to the subsequent netting run that reversed this run, maintaining the audit trail of corrections.' ;
    rdfs:domain ind:NettingRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NettingRun .

ind:accountCount rdf:type rdf:Property ;
    rdfs:label 'Account Count' ;
    rdfs:comment 'Total number of distinct accounts (vendors, customers, intercompany entities) included in this netting run.' ;
    rdfs:domain ind:NettingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'The business date on which the netting run was executed or is scheduled to execute.' ;
    rdfs:domain ind:NettingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glBatchCode rdf:type rdf:Property ;
    rdfs:label 'Gl Batch Code' ;
    rdfs:comment 'Reference to the general ledger batch that contains the journal entries generated by this netting run.' ;
    rdfs:domain ind:NettingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netPositionIndicator rdf:type rdf:Property ;
    rdfs:label 'Net Position Indicator' ;
    rdfs:comment 'Indicates whether the netting run resulted in a net payable, net receivable, or balanced position.' ;
    rdfs:domain ind:NettingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingMethod rdf:type rdf:Property ;
    rdfs:label 'Netting Method' ;
    rdfs:comment 'The netting methodology applied in this run, determining how offsetting balances are calculated and settled.' ;
    rdfs:domain ind:NettingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingScope rdf:type rdf:Property ;
    rdfs:label 'Netting Scope' ;
    rdfs:comment 'Defines the scope of accounts and transactions included in this netting run (e.g., intercompany balances, vendor payables, customer receivables).' ;
    rdfs:domain ind:NettingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedToGlFlag rdf:type rdf:Property ;
    rdfs:label 'Posted To Gl Flag' ;
    rdfs:comment 'Indicates whether the netting run results have been posted to the general ledger, confirming financial statement impact.' ;
    rdfs:domain ind:NettingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Processing Duration Seconds' ;
    rdfs:comment 'Total time in seconds taken to complete the netting run processing, supporting performance monitoring and optimization.' ;
    rdfs:domain ind:NettingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalGrossPayableAmount rdf:type rdf:Property ;
    rdfs:label 'Total Gross Payable Amount' ;
    rdfs:comment 'Total gross amount of payables included in the netting run before netting adjustments are applied.' ;
    rdfs:domain ind:NettingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGrossReceivableAmount rdf:type rdf:Property ;
    rdfs:label 'Total Gross Receivable Amount' ;
    rdfs:comment 'Total gross amount of receivables included in the netting run before netting adjustments are applied.' ;
    rdfs:domain ind:NettingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNettedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Netted Amount' ;
    rdfs:comment 'The net amount after offsetting payables and receivables, representing the actual settlement obligation or receivable.' ;
    rdfs:domain ind:NettingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Id' ;
    rdfs:comment 'Reference to the chart of accounts structure that this ledger uses for account classification and reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'The accounting standard or framework that governs this ledger (e.g., US GAAP, IFRS).' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationVersion rdf:type rdf:Property ;
    rdfs:label 'Consolidation Version' ;
    rdfs:comment 'Version identifier for consolidation scenarios when this ledger is used for group reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConsolidationLedger rdf:type rdf:Property ;
    rdfs:label 'Is Consolidation Ledger' ;
    rdfs:comment 'Boolean flag indicating whether this ledger is used for group consolidation and intercompany elimination purposes.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeadingLedger rdf:type rdf:Property ;
    rdfs:label 'Is Leading Ledger' ;
    rdfs:comment 'Boolean flag indicating whether this is the primary leading ledger for the organization (true) or a secondary/parallel ledger (false).' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastClosedDate rdf:type rdf:Property ;
    rdfs:label 'Last Closed Date' ;
    rdfs:comment 'The date when the most recent period close was completed for this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastClosedPeriod rdf:type rdf:Property ;
    rdfs:label 'Last Closed Period' ;
    rdfs:comment 'The most recent fiscal period (YYYYMM format) that has been closed in this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerCategory rdf:type rdf:Property ;
    rdfs:label 'Ledger Category' ;
    rdfs:comment 'High-level categorization of the ledger based on reporting purpose and accounting framework alignment.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerCode rdf:type rdf:Property ;
    rdfs:label 'Ledger Code' ;
    rdfs:comment 'Unique business identifier code for the ledger used in financial reporting and system integration.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerName rdf:type rdf:Property ;
    rdfs:label 'Ledger Name' ;
    rdfs:comment 'Full descriptive name of the ledger for human-readable identification.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerType rdf:type rdf:Property ;
    rdfs:label 'Ledger Type' ;
    rdfs:comment 'Classification of the ledger based on its functional purpose in the financial accounting system.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingPeriodVariant rdf:type rdf:Property ;
    rdfs:label 'Posting Period Variant' ;
    rdfs:comment 'Code defining the number and structure of posting periods (e.g., 12 regular periods plus special periods) for this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitLossAccount rdf:type rdf:Property ;
    rdfs:label 'Profit Loss Account' ;
    rdfs:comment 'General ledger account number used for profit and loss statement aggregation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainedEarningsAccount rdf:type rdf:Property ;
    rdfs:label 'Retained Earnings Account' ;
    rdfs:comment 'General ledger account number used for retained earnings carry-forward during year-end closing.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsCostCenter rdf:type rdf:Property ;
    rdfs:label 'Supports Cost Center' ;
    rdfs:comment 'Boolean flag indicating whether this ledger supports cost center accounting for overhead allocation and analysis.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsProfitCenter rdf:type rdf:Property ;
    rdfs:label 'Supports Profit Center' ;
    rdfs:comment 'Boolean flag indicating whether this ledger supports profit center accounting for internal management reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsSegmentReporting rdf:type rdf:Property ;
    rdfs:label 'Supports Segment Reporting' ;
    rdfs:comment 'Boolean flag indicating whether this ledger supports segment-level financial reporting as required by FASB ASC 280.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valuationView rdf:type rdf:Property ;
    rdfs:label 'Valuation View' ;
    rdfs:comment 'The valuation perspective or view that this ledger represents for parallel accounting purposes.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationStepId rdf:type rdf:Property ;
    rdfs:label 'Automation Step Id' ;
    rdfs:comment 'Primary key for automation_step' ;
    rdfs:domain ind:AutomationStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:templateId rdf:type rdf:Property ;
    rdfs:label 'Template Id' ;
    rdfs:comment 'Reference to the message template used by this automation step for content rendering.' ;
    rdfs:domain ind:AutomationStep ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmailTemplate .

ind:abTestSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Ab Test Split Percentage' ;
    rdfs:comment 'Percentage of audience allocated to this A/B test variant (0.00 to 100.00).' ;
    rdfs:domain ind:AutomationStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activated Timestamp' ;
    rdfs:comment 'Date and time when this automation step was activated and made live for execution.' ;
    rdfs:domain ind:AutomationStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conditionLogic rdf:type rdf:Property ;
    rdfs:label 'Condition Logic' ;
    rdfs:comment 'Business rule or conditional expression evaluated for conditional split or branching steps (e.g., \'cart_value > 100\', \'customer_segment = VIP\').' ;
    rdfs:domain ind:AutomationStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionCount rdf:type rdf:Property ;
    rdfs:label 'Execution Count' ;
    rdfs:comment 'Total number of times this automation step has been executed since activation.' ;
    rdfs:domain ind:AutomationStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goalMetric rdf:type rdf:Property ;
    rdfs:label 'Goal Metric' ;
    rdfs:comment 'Primary success metric or key performance indicator (KPI) this automation step is designed to optimize (e.g., \'open_rate\', \'click_through_rate\', \'conversion_rate\').' ;
    rdfs:domain ind:AutomationStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retryIntervalMinutes rdf:type rdf:Property ;
    rdfs:label 'Retry Interval Minutes' ;
    rdfs:comment 'Time interval in minutes between retry attempts for failed automation step executions.' ;
    rdfs:domain ind:AutomationStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sendTimeOptimization rdf:type rdf:Property ;
    rdfs:label 'Send Time Optimization' ;
    rdfs:comment 'Indicates whether send time optimization (STO) is enabled to deliver messages at the optimal time for each recipient (True/False).' ;
    rdfs:domain ind:AutomationStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stepCode rdf:type rdf:Property ;
    rdfs:label 'Step Code' ;
    rdfs:comment 'Unique business identifier code for the automation step, used for external references and integrations.' ;
    rdfs:domain ind:AutomationStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepDescription rdf:type rdf:Property ;
    rdfs:label 'Step Description' ;
    rdfs:comment 'Detailed business description of the automation step\'s purpose, behavior, and intended outcome.' ;
    rdfs:domain ind:AutomationStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepName rdf:type rdf:Property ;
    rdfs:label 'Step Name' ;
    rdfs:comment 'Human-readable name of the automation step (e.g., \'Welcome Email\', \'Abandoned Cart Reminder\', \'Post-Purchase Survey\').' ;
    rdfs:domain ind:AutomationStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepSequence rdf:type rdf:Property ;
    rdfs:label 'Step Sequence' ;
    rdfs:comment 'Ordinal position of this step within its parent automation workflow, determining execution order.' ;
    rdfs:domain ind:AutomationStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stepStatus rdf:type rdf:Property ;
    rdfs:label 'Step Status' ;
    rdfs:comment 'Current lifecycle status of the automation step indicating whether it is active, inactive, draft, archived, deprecated, or in testing.' ;
    rdfs:domain ind:AutomationStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepType rdf:type rdf:Property ;
    rdfs:label 'Step Type' ;
    rdfs:comment 'Classification of the automation step by its execution type (email, SMS, push notification, webhook, wait, conditional split, A/B test).' ;
    rdfs:domain ind:AutomationStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throttleLimitPerHour rdf:type rdf:Property ;
    rdfs:label 'Throttle Limit Per Hour' ;
    rdfs:comment 'Maximum number of messages this automation step can send per hour to prevent system overload or deliverability issues.' ;
    rdfs:domain ind:AutomationStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waitDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Wait Duration Minutes' ;
    rdfs:comment 'Duration in minutes for wait-type automation steps before proceeding to the next step.' ;
    rdfs:domain ind:AutomationStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:webhookMethod rdf:type rdf:Property ;
    rdfs:label 'Webhook Method' ;
    rdfs:comment 'HTTP method used for webhook-type automation steps (GET, POST, PUT, PATCH, DELETE).' ;
    rdfs:domain ind:AutomationStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:webhookUrl rdf:type rdf:Property ;
    rdfs:label 'Webhook Url' ;
    rdfs:comment 'Target URL endpoint for webhook-type automation steps to send event data to external systems.' ;
    rdfs:domain ind:AutomationStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandId rdf:type rdf:Property ;
    rdfs:label 'Brand Id' ;
    rdfs:comment 'Reference to the retail brand or sub-brand this template is associated with for brand consistency.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketingBrand .

ind:parentTemplateId rdf:type rdf:Property ;
    rdfs:label 'Parent Template Id' ;
    rdfs:comment 'Reference to the parent template if this is a variant or localized version of another template.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmailTemplate .

ind:abTestEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Ab Test Enabled Flag' ;
    rdfs:comment 'Indicates whether this template is configured to support A/B testing variations for optimization.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audienceSegment rdf:type rdf:Property ;
    rdfs:label 'Audience Segment' ;
    rdfs:comment 'Description of the intended audience segment or persona this template is optimized for.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignCategory rdf:type rdf:Property ;
    rdfs:label 'Campaign Category' ;
    rdfs:comment 'High-level marketing campaign category this template is designed to support.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewedFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Reviewed Flag' ;
    rdfs:comment 'Indicates whether the template has been reviewed for regulatory compliance including CAN-SPAM, GDPR, and CASL requirements.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designFramework rdf:type rdf:Property ;
    rdfs:label 'Design Framework' ;
    rdfs:comment 'The design system or framework used to build the email template structure.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dynamicContentFlag rdf:type rdf:Property ;
    rdfs:label 'Dynamic Content Flag' ;
    rdfs:comment 'Indicates whether the template includes dynamic content blocks that change based on recipient attributes or behavior.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fromEmail rdf:type rdf:Property ;
    rdfs:label 'From Email' ;
    rdfs:comment 'Email address shown as the sender of the email. Must be a verified domain address.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:htmlBody rdf:type rdf:Property ;
    rdfs:label 'Html Body' ;
    rdfs:comment 'The HTML-formatted content of the email template including markup, styling, and personalization tokens.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Used Timestamp' ;
    rdfs:comment 'Date and time when this template was most recently used in an email campaign send.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mobileOptimizedFlag rdf:type rdf:Property ;
    rdfs:label 'Mobile Optimized Flag' ;
    rdfs:comment 'Indicates whether the template has been designed and tested for optimal rendering on mobile devices.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personalizationLevel rdf:type rdf:Property ;
    rdfs:label 'Personalization Level' ;
    rdfs:comment 'Degree of dynamic personalization and customization capability built into the template.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spamScore rdf:type rdf:Property ;
    rdfs:label 'Spam Score' ;
    rdfs:comment 'Calculated spam likelihood score for the template content, used to optimize deliverability. Lower scores indicate better deliverability.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:textBody rdf:type rdf:Property ;
    rdfs:label 'Text Body' ;
    rdfs:comment 'Plain text version of the email content for email clients that do not support HTML rendering.' ;
    rdfs:domain ind:EmailTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adFormatSupported rdf:type rdf:Property ;
    rdfs:label 'Ad Format Supported' ;
    rdfs:comment 'The types of advertising formats supported by the publisher (e.g., banner, video, native, sponsored content, email).' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceReachEstimate rdf:type rdf:Property ;
    rdfs:label 'Audience Reach Estimate' ;
    rdfs:comment 'The estimated total audience reach or user base size of the publisher platform.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandSafetyCertified rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Certified' ;
    rdfs:comment 'Indicates whether the publisher has been certified for brand safety standards and content suitability.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentCategory rdf:type rdf:Property ;
    rdfs:label 'Content Category' ;
    rdfs:comment 'The primary content category or vertical focus of the publisher (e.g., news, entertainment, lifestyle, technology, sports).' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerClickUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Per Click Usd' ;
    rdfs:comment 'The negotiated cost per click rate in USD for click-based advertising campaigns with this publisher.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerImpressionUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Per Impression Usd' ;
    rdfs:comment 'The negotiated cost per thousand impressions (CPM) rate in USD for impression-based advertising campaigns with this publisher.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Fraud Risk Level' ;
    rdfs:comment 'The assessed fraud risk level for traffic and conversions from this publisher (low, medium, high, verified).' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendor rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor' ;
    rdfs:comment 'Indicates whether this publisher is designated as a preferred or strategic vendor for marketing campaigns.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publisherCode rdf:type rdf:Property ;
    rdfs:label 'Publisher Code' ;
    rdfs:comment 'The externally-known unique code or identifier for the publisher used in campaign tracking and attribution systems.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publisherName rdf:type rdf:Property ;
    rdfs:label 'Publisher Name' ;
    rdfs:comment 'The official business name of the publisher or media platform.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publisherType rdf:type rdf:Property ;
    rdfs:label 'Publisher Type' ;
    rdfs:comment 'The category or type of publisher platform (e.g., search engine, social media, display network, affiliate, email service, video platform).' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDemographics rdf:type rdf:Property ;
    rdfs:label 'Target Demographics' ;
    rdfs:comment 'The primary demographic segments or audience profiles that the publisher reaches (e.g., millennials, parents, tech enthusiasts).' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier rdf:type rdf:Property ;
    rdfs:label 'Tier' ;
    rdfs:comment 'The tier or classification level of the publisher based on reach, performance, or strategic importance (premium, standard, emerging, test).' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingPixelEnabled rdf:type rdf:Property ;
    rdfs:label 'Tracking Pixel Enabled' ;
    rdfs:comment 'Indicates whether tracking pixel integration is enabled for attribution and conversion tracking with this publisher.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentCostZoneId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Zone Id' ;
    rdfs:comment 'Reference to a parent cost zone in a hierarchical cost zone structure, enabling nested or regional rollup of cost zones.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostZone .

ind:annualRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Amount' ;
    rdfs:comment 'Estimated or actual annual revenue generated within this cost zone in the zone\'s currency.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Units' ;
    rdfs:comment 'Estimated or actual annual sales volume in units for this cost zone, used for cost allocation and pricing optimization.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Amount' ;
    rdfs:comment 'Monetary threshold above which pricing changes in this zone require additional approval levels.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:code rdf:type rdf:Property ;
    rdfs:label 'Code' ;
    rdfs:comment 'Business identifier code for the cost zone used in pricing systems and external integrations. Typically alphanumeric and unique across the enterprise.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveIntensity rdf:type rdf:Property ;
    rdfs:label 'Competitive Intensity' ;
    rdfs:comment 'Level of competitive pressure in this cost zone affecting pricing flexibility and margin targets.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Cost Adjustment Factor' ;
    rdfs:comment 'Multiplier applied to base costs to account for zone-specific cost variations, typically ranging from 0.8 to 1.5.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Cost Review Frequency' ;
    rdfs:comment 'Scheduled frequency for reviewing and updating cost factors and margins for this cost zone.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultCostMethod rdf:type rdf:Property ;
    rdfs:label 'Default Cost Method' ;
    rdfs:comment 'Primary costing methodology applied to products within this cost zone for inventory valuation and pricing calculations.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyFactorPercentage rdf:type rdf:Property ;
    rdfs:label 'Duty Factor Percentage' ;
    rdfs:comment 'Percentage applied to base product cost to account for import duties and tariffs applicable to this cost zone.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightFactorPercentage rdf:type rdf:Property ;
    rdfs:label 'Freight Factor Percentage' ;
    rdfs:comment 'Percentage applied to base product cost to account for freight and transportation expenses specific to this cost zone.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCostReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Cost Review Date' ;
    rdfs:comment 'Date when cost factors and pricing parameters for this zone were last reviewed and validated.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumMarginPercentage rdf:type rdf:Property ;
    rdfs:label 'Minimum Margin Percentage' ;
    rdfs:comment 'Minimum acceptable gross margin percentage for products sold within this cost zone, used as a pricing floor constraint.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:name rdf:type rdf:Property ;
    rdfs:label 'Name' ;
    rdfs:comment 'Human-readable name of the cost zone for display and reporting purposes.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCostReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Cost Review Date' ;
    rdfs:comment 'Scheduled date for the next cost review and potential adjustment of zone parameters.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overheadFactorPercentage rdf:type rdf:Property ;
    rdfs:label 'Overhead Factor Percentage' ;
    rdfs:comment 'Percentage applied to base product cost to account for warehousing, handling, and operational overhead costs in this zone.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMarginPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Margin Percentage' ;
    rdfs:comment 'Target gross margin percentage that pricing strategies aim to achieve for products in this cost zone.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:type rdf:type rdf:Property ;
    rdfs:label 'Type' ;
    rdfs:comment 'Classification of the cost zone based on the segmentation strategy used (geographic regions, sales channels, store formats, vendor agreements, product categories, or custom business rules).' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoGroupId rdf:type rdf:Property ;
    rdfs:label 'Promo Group Id' ;
    rdfs:comment 'Primary key for promo_group' ;
    rdfs:domain ind:PromoGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conflictResolutionRule rdf:type rdf:Property ;
    rdfs:label 'Conflict Resolution Rule' ;
    rdfs:comment 'Rule applied when promotions within this group conflict, determining which promotion takes precedence or how they are combined.' ;
    rdfs:domain ind:PromoGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegmentApplicability rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Applicability' ;
    rdfs:comment 'Customer segments or loyalty tiers to which this promotion group applies. Null indicates applicability to all customers.' ;
    rdfs:domain ind:PromoGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionScope rdf:type rdf:Property ;
    rdfs:label 'Exclusion Scope' ;
    rdfs:comment 'Defines the scope of exclusion rules: whether promotions exclude only within this group, across specific groups, or globally across all promotions.' ;
    rdfs:domain ind:PromoGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCode rdf:type rdf:Property ;
    rdfs:label 'Group Code' ;
    rdfs:comment 'Business-assigned unique code for the promotion group used for external identification and system integration.' ;
    rdfs:domain ind:PromoGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupDescription rdf:type rdf:Property ;
    rdfs:label 'Group Description' ;
    rdfs:comment 'Detailed description of the promotion group, including its business purpose, scope, and intended use.' ;
    rdfs:domain ind:PromoGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupName rdf:type rdf:Property ;
    rdfs:label 'Group Name' ;
    rdfs:comment 'Human-readable name of the promotion group describing its purpose or theme.' ;
    rdfs:domain ind:PromoGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupType rdf:type rdf:Property ;
    rdfs:label 'Group Type' ;
    rdfs:comment 'Classification of the promotion group indicating its functional purpose in promotion management (e.g., exclusion groups prevent simultaneous application, inclusion groups bundle offers, priority groups establish precedence).' ;
    rdfs:domain ind:PromoGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxPromotionsPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Max Promotions Per Transaction' ;
    rdfs:comment 'Maximum number of promotions from this group that can be applied to a single transaction. Null indicates no limit.' ;
    rdfs:domain ind:PromoGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoApply rdf:type rdf:Property ;
    rdfs:label 'Auto Apply' ;
    rdfs:comment 'Indicates whether the promotion stack is automatically applied at checkout when eligibility criteria are met, or requires manual activation.' ;
    rdfs:domain ind:PromotionStack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetAllocated rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated' ;
    rdfs:comment 'Total budget allocated for this promotion stack including all discount costs and promotional expenses.' ;
    rdfs:domain ind:PromotionStack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:combinableWithClearance rdf:type rdf:Property ;
    rdfs:label 'Combinable With Clearance' ;
    rdfs:comment 'Indicates whether this promotion stack can be combined with clearance-priced items.' ;
    rdfs:domain ind:PromotionStack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:excludeSaleItems rdf:type rdf:Property ;
    rdfs:label 'Exclude Sale Items' ;
    rdfs:comment 'Indicates whether items already on sale are excluded from this promotion stack.' ;
    rdfs:domain ind:PromotionStack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'Entity responsible for funding the promotional discount: retailer-funded, vendor-funded, co-funded partnership, or manufacturer-funded.' ;
    rdfs:domain ind:PromotionStack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalMessage rdf:type rdf:Property ;
    rdfs:label 'Promotional Message' ;
    rdfs:comment 'Customer-facing marketing message or tagline displayed for this promotion stack across channels.' ;
    rdfs:domain ind:PromotionStack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCoupon rdf:type rdf:Property ;
    rdfs:label 'Requires Coupon' ;
    rdfs:comment 'Indicates whether a coupon code or digital coupon is required to activate this promotion stack.' ;
    rdfs:domain ind:PromotionStack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stackCode rdf:type rdf:Property ;
    rdfs:label 'Stack Code' ;
    rdfs:comment 'Business-facing unique code for the promotion stack used in operational systems and reporting.' ;
    rdfs:domain ind:PromotionStack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackDescription rdf:type rdf:Property ;
    rdfs:label 'Stack Description' ;
    rdfs:comment 'Detailed description of the promotion stack including its business objectives, target audience, and promotional strategy.' ;
    rdfs:domain ind:PromotionStack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackName rdf:type rdf:Property ;
    rdfs:label 'Stack Name' ;
    rdfs:comment 'Human-readable name of the promotion stack describing its purpose or campaign theme.' ;
    rdfs:domain ind:PromotionStack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackStatus rdf:type rdf:Property ;
    rdfs:label 'Stack Status' ;
    rdfs:comment 'Current lifecycle status of the promotion stack indicating its operational state.' ;
    rdfs:domain ind:PromotionStack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackType rdf:type rdf:Property ;
    rdfs:label 'Stack Type' ;
    rdfs:comment 'Classification of the promotion stack structure indicating whether it contains a single offer, multiple stacked offers, tiered discounts, bundled deals, cross-category promotions, or loyalty-exclusive offers.' ;
    rdfs:domain ind:PromotionStack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackingRule rdf:type rdf:Property ;
    rdfs:label 'Stacking Rule' ;
    rdfs:comment 'Rule governing how this promotion stack interacts with other promotions: exclusive (cannot combine), stackable (can combine with others), conditional (stacks under specific conditions), or best_deal (system selects best offer).' ;
    rdfs:domain ind:PromotionStack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bargainingUnitId rdf:type rdf:Property ;
    rdfs:label 'Bargaining Unit Id' ;
    rdfs:comment 'Reference to the specific bargaining unit covered by this agreement, representing a group of employees with shared interests.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BargainingUnit .

ind:unionId rdf:type rdf:Property ;
    rdfs:label 'Union Id' ;
    rdfs:comment 'Reference to the labor union or employee organization that is party to this collective bargaining agreement.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Union .

ind:arbitrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Arbitration Required Flag' ;
    rdfs:comment 'Indicates whether binding arbitration is required for unresolved grievances under this agreement.' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coveredEmployeeCount rdf:type rdf:Property ;
    rdfs:label 'Covered Employee Count' ;
    rdfs:comment 'Total number of employees covered under this collective bargaining agreement at the time of ratification or most recent count.' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coveredJobClassifications rdf:type rdf:Property ;
    rdfs:label 'Covered Job Classifications' ;
    rdfs:comment 'Description or list of job titles, roles, and classifications included in the bargaining unit covered by this agreement.' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveredLocations rdf:type rdf:Property ;
    rdfs:label 'Covered Locations' ;
    rdfs:comment 'Comma-separated list or description of specific retail locations, distribution centers, or facilities covered by this agreement.' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duesCheckoffAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Dues Checkoff Authorized Flag' ;
    rdfs:comment 'Indicates whether the employer is authorized to deduct union dues directly from employee paychecks.' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grievanceProcedureSteps rdf:type rdf:Property ;
    rdfs:label 'Grievance Procedure Steps' ;
    rdfs:comment 'Number of formal steps in the grievance resolution process defined by the agreement before arbitration.' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:healthcareContributionEmployerPercentage rdf:type rdf:Property ;
    rdfs:label 'Healthcare Contribution Employer Percentage' ;
    rdfs:comment 'Percentage of healthcare premium costs covered by the employer as negotiated in the agreement.' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lockoutClause rdf:type rdf:Property ;
    rdfs:label 'Lockout Clause' ;
    rdfs:comment 'Type of lockout provision in the agreement. No-lockout prohibits employer lockouts during the term, conditional allows lockouts under specific circumstances, unrestricted preserves full lockout rights.' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementRightsClause rdf:type rdf:Property ;
    rdfs:label 'Management Rights Clause' ;
    rdfs:comment 'Text or reference describing the scope of management rights reserved by the employer that are not subject to bargaining or grievance.' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumWageRate rdf:type rdf:Property ;
    rdfs:label 'Minimum Wage Rate' ;
    rdfs:comment 'Minimum hourly wage rate established by the collective bargaining agreement for covered employees, in local currency.' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Multiplier' ;
    rdfs:comment 'Wage multiplier for overtime hours as negotiated in the agreement (e.g., 1.50 for time-and-a-half, 2.00 for double-time).' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidTimeOffDaysAnnual rdf:type rdf:Property ;
    rdfs:label 'Paid Time Off Days Annual' ;
    rdfs:comment 'Number of paid time off days per year guaranteed to covered employees under the agreement.' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pensionContributionRate rdf:type rdf:Property ;
    rdfs:label 'Pension Contribution Rate' ;
    rdfs:comment 'Employer contribution rate to pension or retirement plans for covered employees, expressed as percentage of wages.' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:probationaryPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Probationary Period Days' ;
    rdfs:comment 'Number of calendar days new employees must work before gaining full union membership and agreement protections.' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratificationDate rdf:type rdf:Property ;
    rdfs:label 'Ratification Date' ;
    rdfs:comment 'Date when union members voted to approve and ratify the collective bargaining agreement.' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reopenerClause rdf:type rdf:Property ;
    rdfs:label 'Reopener Clause' ;
    rdfs:comment 'Description of conditions under which the agreement can be reopened for renegotiation before expiration (e.g., wage reopener, healthcare reopener).' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senioritySystemType rdf:type rdf:Property ;
    rdfs:label 'Seniority System Type' ;
    rdfs:comment 'Method by which employee seniority is calculated and applied for purposes of layoffs, recalls, promotions, and shift bidding under the agreement.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sickLeaveDaysAnnual rdf:type rdf:Property ;
    rdfs:label 'Sick Leave Days Annual' ;
    rdfs:comment 'Number of paid sick leave days per year guaranteed to covered employees under the agreement.' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:strikeClause rdf:type rdf:Property ;
    rdfs:label 'Strike Clause' ;
    rdfs:comment 'Type of strike provision in the agreement. No-strike prohibits strikes during the term, conditional allows strikes under specific circumstances, unrestricted preserves full strike rights.' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successorClauseIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Successor Clause Included Flag' ;
    rdfs:comment 'Indicates whether the agreement includes a successor clause requiring a new owner to honor the agreement in case of business sale or transfer.' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Union Representative Name' ;
    rdfs:comment 'Name of the primary union representative or business agent who negotiated on behalf of the union.' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionSecurityClause rdf:type rdf:Property ;
    rdfs:label 'Union Security Clause' ;
    rdfs:comment 'Type of union membership requirement. Closed shop requires union membership before hiring, union shop requires membership after hiring, agency shop requires fee payment without membership, open shop has no requirement, right-to-work prohibits mandatory membership.' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wageIncreasePercentage rdf:type rdf:Property ;
    rdfs:label 'Wage Increase Percentage' ;
    rdfs:comment 'Negotiated percentage wage increase for covered employees over the term of the agreement, expressed as a decimal (e.g., 3.50 for 3.5%).' ;
    rdfs:domain ind:CollectiveBargainingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Approval Deadline Date' ;
    rdfs:comment 'The final date by which all merit recommendations must be approved by management.' ;
    rdfs:domain ind:MeritCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalWorkflowRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Required' ;
    rdfs:comment 'Indicates whether a formal approval workflow is required for merit recommendations in this cycle (True/False).' ;
    rdfs:domain ind:MeritCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetPercentage rdf:type rdf:Property ;
    rdfs:label 'Budget Percentage' ;
    rdfs:comment 'The overall merit budget expressed as a percentage of total eligible payroll (e.g., 3.5 represents 3.5%).' ;
    rdfs:domain ind:MeritCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationRequired rdf:type rdf:Property ;
    rdfs:label 'Calibration Required' ;
    rdfs:comment 'Indicates whether calibration sessions are required to normalize merit recommendations across departments (True/False).' ;
    rdfs:domain ind:MeritCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationDate rdf:type rdf:Property ;
    rdfs:label 'Communication Date' ;
    rdfs:comment 'The date when merit increase decisions are communicated to employees.' ;
    rdfs:domain ind:MeritCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the merit cycle for external reference and reporting (e.g., \'MC-2024-01\', \'FY24-MERIT\').' ;
    rdfs:domain ind:MeritCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Human-readable name or title of the merit cycle (e.g., \'FY2024 Annual Merit Review\', \'Q2 2024 Performance Cycle\').' ;
    rdfs:domain ind:MeritCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleType rdf:type rdf:Property ;
    rdfs:label 'Cycle Type' ;
    rdfs:comment 'Classification of the merit cycle based on frequency and purpose (annual, mid-year, quarterly, off-cycle, special).' ;
    rdfs:domain ind:MeritCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleEmployeeCount rdf:type rdf:Property ;
    rdfs:label 'Eligible Employee Count' ;
    rdfs:comment 'The number of employees eligible to receive merit increases in this cycle.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guidelineIncreasePercentage rdf:type rdf:Property ;
    rdfs:label 'Guideline Increase Percentage' ;
    rdfs:comment 'The recommended or guideline merit increase percentage for standard performers (e.g., 3.0 represents 3%).' ;
    rdfs:domain ind:MeritCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumIncreasePercentage rdf:type rdf:Property ;
    rdfs:label 'Maximum Increase Percentage' ;
    rdfs:comment 'The maximum merit increase percentage allowed for any individual employee (e.g., 10.0 represents 10%).' ;
    rdfs:domain ind:MeritCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumIncreasePercentage rdf:type rdf:Property ;
    rdfs:label 'Minimum Increase Percentage' ;
    rdfs:comment 'The minimum merit increase percentage allowed for eligible employees (e.g., 0.0 for no minimum).' ;
    rdfs:domain ind:MeritCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performancePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Performance Period End Date' ;
    rdfs:comment 'The end date of the performance period being evaluated for this merit cycle.' ;
    rdfs:domain ind:MeritCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performancePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Performance Period Start Date' ;
    rdfs:comment 'The start date of the performance period being evaluated for this merit cycle.' ;
    rdfs:domain ind:MeritCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prorationMethod rdf:type rdf:Property ;
    rdfs:label 'Proration Method' ;
    rdfs:comment 'Method used to prorate merit increases for employees hired mid-cycle (none, hire_date, service_months, custom).' ;
    rdfs:domain ind:MeritCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewEndDate rdf:type rdf:Property ;
    rdfs:label 'Review End Date' ;
    rdfs:comment 'The date by which all performance reviews and merit recommendations must be completed.' ;
    rdfs:domain ind:MeritCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jobRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Job Requisition Id' ;
    rdfs:comment 'Reference to the job requisition or job posting that the candidate applied to.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requisition .

ind:alternatePhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Alternate Phone Number' ;
    rdfs:comment 'Secondary or alternate contact phone number for the candidate, if provided.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityDate rdf:type rdf:Property ;
    rdfs:label 'Availability Date' ;
    rdfs:comment 'Date when the candidate is available to start employment if an offer is extended.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backgroundCheckCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Completed Date' ;
    rdfs:comment 'Date when the background check process was completed for the candidate.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:candidateSource rdf:type rdf:Property ;
    rdfs:label 'Candidate Source' ;
    rdfs:comment 'Channel or source through which the candidate was identified or applied, used for recruitment effectiveness analysis.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateStatus rdf:type rdf:Property ;
    rdfs:label 'Candidate Status' ;
    rdfs:comment 'Current status of the candidate in the recruitment lifecycle, indicating their progression through the hiring process.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverLetterFilePath rdf:type rdf:Property ;
    rdfs:label 'Cover Letter File Path' ;
    rdfs:comment 'Storage location or file path reference to the candidate\'s uploaded cover letter document, if provided.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:desiredSalary rdf:type rdf:Property ;
    rdfs:label 'Desired Salary' ;
    rdfs:comment 'Salary expectation or desired compensation amount indicated by the candidate during the application process.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:highestEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Highest Education Level' ;
    rdfs:comment 'Highest level of education completed by the candidate, used for qualification assessment.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Interview Completed Date' ;
    rdfs:comment 'Date and time when the candidate\'s interview was completed.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interviewScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Interview Scheduled Date' ;
    rdfs:comment 'Date and time when the candidate\'s interview is scheduled to take place.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isEligibleForRehire rdf:type rdf:Property ;
    rdfs:label 'Is Eligible For Rehire' ;
    rdfs:comment 'Indicates whether the candidate is a former employee who is eligible for rehire based on previous employment records.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationPreference rdf:type rdf:Property ;
    rdfs:label 'Location Preference' ;
    rdfs:comment 'Preferred work location or store location indicated by the candidate.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerAcceptedDate rdf:type rdf:Property ;
    rdfs:label 'Offer Accepted Date' ;
    rdfs:comment 'Date when the candidate accepted the employment offer.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerExtendedDate rdf:type rdf:Property ;
    rdfs:label 'Offer Extended Date' ;
    rdfs:comment 'Date when a formal employment offer was extended to the candidate.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:positionAppliedFor rdf:type rdf:Property ;
    rdfs:label 'Position Applied For' ;
    rdfs:comment 'Job title or position name that the candidate has applied for.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resumeFilePath rdf:type rdf:Property ;
    rdfs:label 'Resume File Path' ;
    rdfs:comment 'Storage location or file path reference to the candidate\'s uploaded resume or curriculum vitae document.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningScore rdf:type rdf:Property ;
    rdfs:label 'Screening Score' ;
    rdfs:comment 'Numerical score assigned during initial candidate screening or assessment, used for ranking and filtering candidates.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total number of years of relevant work experience reported by the candidate.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payrollCalendarId rdf:type rdf:Property ;
    rdfs:label 'Payroll Calendar Id' ;
    rdfs:comment 'Reference to the payroll calendar that defines the schedule and timing for this payroll run.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollCalendar .

ind:reversalOfRunId rdf:type rdf:Property ;
    rdfs:label 'Reversal Of Run Id' ;
    rdfs:comment 'Reference to the original payroll run that this run reverses or corrects, if applicable.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRun .

ind:checkDate rdf:type rdf:Property ;
    rdfs:label 'Check Date' ;
    rdfs:comment 'The date printed on physical checks or used as the effective date for electronic payments.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'Total number of employees included in this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employerTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Tax Amount' ;
    rdfs:comment 'Total employer-paid payroll taxes including FICA, FUTA, SUTA, and other statutory employer contributions.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Status' ;
    rdfs:comment 'Status indicating whether payroll transactions have been posted to the general ledger.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationBatchCode rdf:type rdf:Property ;
    rdfs:label 'Integration Batch Code' ;
    rdfs:comment 'External batch identifier used for integration with Workday HCM or other payroll systems.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFinalRun rdf:type rdf:Property ;
    rdfs:label 'Is Final Run' ;
    rdfs:comment 'Indicates whether this is a final payroll run for terminated employees or end-of-year processing.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing End Timestamp' ;
    rdfs:comment 'Date and time when payroll processing completed for this run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Start Timestamp' ;
    rdfs:comment 'Date and time when payroll processing began for this run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxFilingQuarter rdf:type rdf:Property ;
    rdfs:label 'Tax Filing Quarter' ;
    rdfs:comment 'The calendar quarter for tax reporting purposes to which this payroll run belongs.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxYear rdf:type rdf:Property ;
    rdfs:label 'Tax Year' ;
    rdfs:comment 'The calendar year for tax reporting purposes to which this payroll run belongs.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cost Amount' ;
    rdfs:comment 'Total cost to the employer including gross pay, employer taxes, and employer-paid benefits for this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvingManagerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Approving Manager Associate Id' ;
    rdfs:comment 'The manager or supervisor who approved or rejected the shift swap request.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:proposedShiftShiftScheduleId rdf:type rdf:Property ;
    rdfs:label 'Proposed Shift Shift Schedule Id' ;
    rdfs:comment 'The shift assignment that the requesting employee is willing to take in exchange. May be null for one-way swap requests.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftSchedule .

ind:targetEmployeeAssociateId rdf:type rdf:Property ;
    rdfs:label 'Target Employee Associate Id' ;
    rdfs:comment 'The employee who is being asked to swap shifts with the requesting employee. May be null if request is open to any qualified employee.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:autoApproved rdf:type rdf:Property ;
    rdfs:label 'Auto Approved' ;
    rdfs:comment 'Indicates whether the shift swap request was automatically approved by the system without manual manager intervention.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Status' ;
    rdfs:comment 'Status of automated compliance validation checking labor laws, overtime rules, rest period requirements, and qualification matching.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceViolationDetails rdf:type rdf:Property ;
    rdfs:label 'Compliance Violation Details' ;
    rdfs:comment 'Detailed description of any labor law or policy violations detected during compliance checking of the shift swap request.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSent rdf:type rdf:Property ;
    rdfs:label 'Notification Sent' ;
    rdfs:comment 'Indicates whether notification has been sent to the target employee or manager about this shift swap request.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestReason rdf:type rdf:Property ;
    rdfs:label 'Request Reason' ;
    rdfs:comment 'Free-text explanation provided by the requesting employee for why they need to swap shifts.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestReasonCategory rdf:type rdf:Property ;
    rdfs:label 'Request Reason Category' ;
    rdfs:comment 'Categorical classification of the reason for the shift swap request for reporting and analytics purposes.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresManagerApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Manager Approval' ;
    rdfs:comment 'Indicates whether this shift swap request requires explicit manager approval or can be auto-approved based on business rules.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'The date and time when the target employee or manager responded to the shift swap request.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:swapEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Swap Effective Date' ;
    rdfs:comment 'The date on which the shift swap will take effect and the new schedule assignments become active.' ;
    rdfs:domain ind:ShiftSwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coveringEmployeeAssociateId rdf:type rdf:Property ;
    rdfs:label 'Covering Employee Associate Id' ;
    rdfs:comment 'Identifier of the employee who has been assigned or volunteered to provide coverage.' ;
    rdfs:domain ind:CoverageRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:requestingEmployeeAssociateId rdf:type rdf:Property ;
    rdfs:label 'Requesting Employee Associate Id' ;
    rdfs:comment 'Identifier of the employee who initiated the coverage request, if different from the employee needing coverage.' ;
    rdfs:domain ind:CoverageRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:coverageDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Date' ;
    rdfs:comment 'Date for which coverage is being requested.' ;
    rdfs:domain ind:CoverageRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageEndTime rdf:type rdf:Property ;
    rdfs:label 'Coverage End Time' ;
    rdfs:comment 'Scheduled end date and time of the shift or period requiring coverage.' ;
    rdfs:domain ind:CoverageRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:coverageStartTime rdf:type rdf:Property ;
    rdfs:label 'Coverage Start Time' ;
    rdfs:comment 'Scheduled start date and time of the shift or period requiring coverage.' ;
    rdfs:domain ind:CoverageRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Date' ;
    rdfs:comment 'Date when a covering employee was successfully assigned to fulfill the coverage request.' ;
    rdfs:domain ind:CoverageRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Timestamp' ;
    rdfs:comment 'Precise date and time when the coverage request was marked as fulfilled.' ;
    rdfs:domain ind:CoverageRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:laborCostCenter rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Center' ;
    rdfs:comment 'Cost center code to which labor costs for this coverage will be allocated.' ;
    rdfs:domain ind:CoverageRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumPayEligible rdf:type rdf:Property ;
    rdfs:label 'Premium Pay Eligible' ;
    rdfs:comment 'Indicates whether the covering employee is eligible for premium pay or incentive compensation for this coverage.' ;
    rdfs:domain ind:CoverageRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:premiumPayRate rdf:type rdf:Property ;
    rdfs:label 'Premium Pay Rate' ;
    rdfs:comment 'Multiplier applied to base pay rate for coverage shifts, such as 1.5 for time-and-a-half.' ;
    rdfs:domain ind:CoverageRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalDeadline rdf:type rdf:Property ;
    rdfs:label 'Approval Deadline' ;
    rdfs:comment 'The date and time by which managers must approve timesheets and time entries for this pay period.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isHolidayPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Holiday Period' ;
    rdfs:comment 'Indicates whether this pay period includes major holidays that may affect scheduling or payroll processing.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeEligible rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible' ;
    rdfs:comment 'Indicates whether overtime hours can be recorded and compensated during this pay period.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollCycleCode rdf:type rdf:Property ;
    rdfs:label 'Payroll Cycle Code' ;
    rdfs:comment 'Code identifying the specific payroll cycle or schedule this pay period belongs to (e.g., \'RETAIL-HOURLY\', \'CORPORATE-SALARY\').' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollProcessingDate rdf:type rdf:Property ;
    rdfs:label 'Payroll Processing Date' ;
    rdfs:comment 'The date on which payroll calculations and processing are executed for this pay period.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeEntryMethod rdf:type rdf:Property ;
    rdfs:label 'Time Entry Method' ;
    rdfs:comment 'Primary method used for time and attendance tracking during this pay period.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timesheetSubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Timesheet Submission Deadline' ;
    rdfs:comment 'The date and time by which employees must submit their timesheets for this pay period.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalDaysCount rdf:type rdf:Property ;
    rdfs:label 'Total Days Count' ;
    rdfs:comment 'The total number of calendar days in this pay period.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workingDaysCount rdf:type rdf:Property ;
    rdfs:label 'Working Days Count' ;
    rdfs:comment 'The number of standard working days (excluding weekends and holidays) within this pay period.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualRevenueTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Target' ;
    rdfs:comment 'Target annual revenue goal for this sales territory, used for performance measurement and incentive compensation.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boundaryDefinition rdf:type rdf:Property ;
    rdfs:label 'Boundary Definition' ;
    rdfs:comment 'Textual or structured definition of territory boundaries (e.g., list of counties, postal codes, geographic coordinates, or natural boundaries).' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitionLevel rdf:type rdf:Property ;
    rdfs:label 'Competition Level' ;
    rdfs:comment 'Assessment of competitive intensity within this sales territory: low (few competitors), moderate (balanced), high (many competitors), very_high (saturated market), monopoly (single dominant player).' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerCount rdf:type rdf:Property ;
    rdfs:label 'Customer Count' ;
    rdfs:comment 'Number of active customers assigned to this sales territory. Used for territory balancing and performance benchmarking.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:householdCount rdf:type rdf:Property ;
    rdfs:label 'Household Count' ;
    rdfs:comment 'Total number of households within this sales territory. Used for consumer market analysis and targeting.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketPotentialScore rdf:type rdf:Property ;
    rdfs:label 'Market Potential Score' ;
    rdfs:comment 'Quantitative score (0-100) representing the market opportunity and growth potential of this territory, based on demographics, competition, and economic indicators.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medianHouseholdIncome rdf:type rdf:Property ;
    rdfs:label 'Median Household Income' ;
    rdfs:comment 'Median annual household income within this territory, used for demographic profiling and product assortment planning.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Territory Id' ;
    rdfs:comment 'Reference to the parent sales territory in a hierarchical territory structure. Null for top-level territories.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:populationSize rdf:type rdf:Property ;
    rdfs:label 'Population Size' ;
    rdfs:comment 'Total population count within the geographic boundaries of this sales territory. Used for market sizing and penetration analysis.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postalCodeRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Postal Code Range End' ;
    rdfs:comment 'Ending postal code for territories defined by postal code ranges. Used for geographic territory assignment.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCodeRangeStart rdf:type rdf:Property ;
    rdfs:label 'Postal Code Range Start' ;
    rdfs:comment 'Starting postal code for territories defined by postal code ranges. Used for geographic territory assignment.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionId rdf:type rdf:Property ;
    rdfs:label 'Region Id' ;
    rdfs:comment 'Reference to the geographic region this territory belongs to, for regional sales reporting and management.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesManagerId rdf:type rdf:Property ;
    rdfs:label 'Sales Manager Id' ;
    rdfs:comment 'Reference to the employee who manages this sales territory. Responsible for territory performance and team oversight.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesRepCount rdf:type rdf:Property ;
    rdfs:label 'Sales Rep Count' ;
    rdfs:comment 'Number of sales representatives currently assigned to this territory. Used for capacity planning and workload balancing.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Unique business identifier code for the sales territory, used for external reference and reporting.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryDescription rdf:type rdf:Property ;
    rdfs:label 'Territory Description' ;
    rdfs:comment 'Detailed textual description of the sales territory, including geographic boundaries, key characteristics, strategic focus, and special considerations.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryLevel rdf:type rdf:Property ;
    rdfs:label 'Territory Level' ;
    rdfs:comment 'Numeric level in the territory hierarchy (e.g., 1=National, 2=Regional, 3=District, 4=Local). Used for rollup reporting and organizational structure.' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Human-readable name of the sales territory (e.g., \'Northeast Region\', \'California Metro\', \'EMEA South\').' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of the territory segmentation strategy: geographic (region-based), account-based (customer segments), product-based (product lines), channel-based (retail/wholesale/online), hybrid (combination), or strategic (key accounts).' ;
    rdfs:domain ind:SalesTerritory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'Organizational level or role required to approve contracts generated from this template.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityClauseIncluded rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Clause Included' ;
    rdfs:comment 'Indicates whether the template includes confidentiality and non-disclosure provisions.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultTermLengthDays rdf:type rdf:Property ;
    rdfs:label 'Default Term Length Days' ;
    rdfs:comment 'Standard duration in days for contracts generated from this template, representing the default commitment period.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Primary mechanism specified in the template for resolving disputes between contracting parties.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Legal Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code indicating the primary legal jurisdiction under which contracts generated from this template are governed.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityCapAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Amount' ;
    rdfs:comment 'Maximum liability amount specified in the template, representing the upper limit of financial exposure.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityCapCurrency rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the liability cap amount.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic review of this contract template to ensure continued legal and business relevance.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:templateContent rdf:type rdf:Property ;
    rdfs:label 'Template Content' ;
    rdfs:comment 'Full text content of the contract template including placeholders, clauses, terms, and conditions. May contain markup or template syntax.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateFormat rdf:type rdf:Property ;
    rdfs:label 'Template Format' ;
    rdfs:comment 'Technical format or markup language used to structure the template content.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationClauseIncluded rdf:type rdf:Property ;
    rdfs:label 'Termination Clause Included' ;
    rdfs:comment 'Indicates whether the template includes standard termination provisions and exit clauses.' ;
    rdfs:domain ind:ContractTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assumptionsSummary rdf:type rdf:Property ;
    rdfs:label 'Assumptions Summary' ;
    rdfs:comment 'Summary of key financial and business assumptions underlying this scenario (e.g., revenue growth rates, cost inflation, market conditions, strategic initiatives). Critical for scenario interpretation and sensitivity analysis.' ;
    rdfs:domain ind:Scenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineScenarioId rdf:type rdf:Property ;
    rdfs:label 'Baseline Scenario Id' ;
    rdfs:comment 'Reference to the baseline scenario used for variance analysis and comparison. Typically points to the approved budget or prior year actual scenario.' ;
    rdfs:domain ind:Scenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessUnitScope rdf:type rdf:Property ;
    rdfs:label 'Business Unit Scope' ;
    rdfs:comment 'Comma-separated list or description of business units, divisions, or legal entities included in this scenario. Defines the organizational scope of the scenario for segmented reporting and analysis.' ;
    rdfs:domain ind:Scenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationMethod rdf:type rdf:Property ;
    rdfs:label 'Consolidation Method' ;
    rdfs:comment 'Method used for consolidating financial data in this scenario. Full for 100% consolidation of subsidiaries; Proportional for consolidation based on ownership percentage; Equity for equity method accounting; None for standalone entity reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConsolidated rdf:type rdf:Property ;
    rdfs:label 'Is Consolidated' ;
    rdfs:comment 'Flag indicating whether this scenario represents consolidated financial data across multiple entities or business units. True for enterprise-wide consolidated scenarios; False for standalone entity scenarios.' ;
    rdfs:domain ind:Scenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublic rdf:type rdf:Property ;
    rdfs:label 'Is Public' ;
    rdfs:comment 'Flag indicating whether this scenario is used for external public reporting and disclosure. True for scenarios used in SEC filings, earnings releases, and investor communications; False for internal management scenarios.' ;
    rdfs:domain ind:Scenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentScenarioId rdf:type rdf:Property ;
    rdfs:label 'Parent Scenario Id' ;
    rdfs:comment 'Reference to the parent scenario from which this scenario was derived or versioned. Nullable for original scenarios. Enables hierarchical scenario relationships and version lineage tracking.' ;
    rdfs:domain ind:Scenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningHorizonMonths rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Months' ;
    rdfs:comment 'Number of months into the future that this scenario covers. Used for forecasting and planning scenarios to define the projection period (e.g., 12 for annual budget, 36 for strategic plan).' ;
    rdfs:domain ind:Scenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scenarioCategory rdf:type rdf:Property ;
    rdfs:label 'Scenario Category' ;
    rdfs:comment 'Business category of the scenario indicating its primary use case. Operational for day-to-day financial management; Strategic for long-term planning; Regulatory for compliance reporting; Management for internal decision-making; Consolidated for enterprise-wide aggregation.' ;
    rdfs:domain ind:Scenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioCode rdf:type rdf:Property ;
    rdfs:label 'Scenario Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the scenario for external reference and reporting (e.g., ACTUAL, BUDGET_2024, FORECAST_Q1).' ;
    rdfs:domain ind:Scenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioName rdf:type rdf:Property ;
    rdfs:label 'Scenario Name' ;
    rdfs:comment 'Full descriptive name of the financial scenario (e.g., Actual Results, Annual Budget 2024, Rolling Forecast Q1 2024).' ;
    rdfs:domain ind:Scenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioType rdf:type rdf:Property ;
    rdfs:label 'Scenario Type' ;
    rdfs:comment 'Classification of the scenario indicating its purpose in financial planning and analysis. Actual represents realized results; Budget represents approved annual plan; Forecast represents updated projections; Plan represents strategic multi-year plan; Projection represents long-term estimates; Baseline represents reference point for variance analysis.' ;
    rdfs:domain ind:Scenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'The date on which the legal entity was officially dissolved, liquidated, or ceased operations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:doingBusinessAsName rdf:type rdf:Property ;
    rdfs:label 'Doing Business As Name' ;
    rdfs:comment 'Trade name or fictitious business name under which the legal entity operates, if different from the legal name.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityStatus rdf:type rdf:Property ;
    rdfs:label 'Entity Status' ;
    rdfs:comment 'Current operational and legal status of the entity (e.g., active, inactive, dissolved, suspended, merged, acquired).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEndMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Month' ;
    rdfs:comment 'The month in which the legal entity\'s fiscal year ends (1-12, where 1=January, 12=December).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'The primary currency in which the legal entity conducts its business operations and maintains its books, using ISO 4217 three-letter code.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'The date on which the legal entity was officially incorporated or registered with the governing authority.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incorporationJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Incorporation Jurisdiction' ;
    rdfs:comment 'The country, state, or province where the legal entity is incorporated or registered.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Code' ;
    rdfs:comment 'The standard industry classification code for the entity\'s primary business activity (e.g., NAICS, SIC, GICS).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPublicCompany rdf:type rdf:Property ;
    rdfs:label 'Is Public Company' ;
    rdfs:comment 'Indicates whether the legal entity is a publicly traded company with securities listed on a stock exchange.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The official registered legal name of the entity as it appears on incorporation documents and regulatory filings.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiCode rdf:type rdf:Property ;
    rdfs:label 'Lei Code' ;
    rdfs:comment 'The 20-character alphanumeric Legal Entity Identifier code used for financial transaction reporting and regulatory compliance.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'The percentage of ownership interest held by the parent entity, expressed as a decimal (e.g., 100.00 for wholly-owned, 51.00 for majority-owned).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Legal Entity Id' ;
    rdfs:comment 'Reference to the parent legal entity if this entity is a subsidiary or branch within a corporate hierarchy.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line 1' ;
    rdfs:comment 'The first line of the official registered address of the legal entity as filed with regulatory authorities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line 2' ;
    rdfs:comment 'The second line of the official registered address (suite, floor, building name, etc.).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCity rdf:type rdf:Property ;
    rdfs:label 'Registered City' ;
    rdfs:comment 'The city of the official registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCountryCode rdf:type rdf:Property ;
    rdfs:label 'Registered Country Code' ;
    rdfs:comment 'The three-letter ISO country code of the official registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the official registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredStateProvince rdf:type rdf:Property ;
    rdfs:label 'Registered State Province' ;
    rdfs:comment 'The state or province of the official registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'The unique registration or incorporation number assigned by the government or regulatory authority.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockExchangeCode rdf:type rdf:Property ;
    rdfs:label 'Stock Exchange Code' ;
    rdfs:comment 'The code or symbol of the stock exchange where the entity\'s securities are listed (e.g., NYSE, NASDAQ, LSE).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTickerSymbol rdf:type rdf:Property ;
    rdfs:label 'Stock Ticker Symbol' ;
    rdfs:comment 'The ticker symbol used to identify the entity\'s publicly traded securities on the stock exchange.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'The tax identification number assigned by the tax authority for tax reporting and compliance purposes (e.g., EIN in the US).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ultimateParentLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Ultimate Parent Legal Entity Id' ;
    rdfs:comment 'Reference to the top-level parent legal entity in the corporate ownership hierarchy.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountCategory rdf:type rdf:Property ;
    rdfs:label 'Account Category' ;
    rdfs:comment 'The sub-classification within the account type, providing additional granularity for financial statement presentation and analysis (e.g., current vs. non-current assets, operating vs. non-operating revenue).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountLevel rdf:type rdf:Property ;
    rdfs:label 'Account Level' ;
    rdfs:comment 'The level in the account hierarchy (e.g., 1 for top-level summary accounts, 2 for sub-accounts, 3 for detail accounts), supporting multi-level financial reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountSubcategory rdf:type rdf:Property ;
    rdfs:label 'Account Subcategory' ;
    rdfs:comment 'Further detailed classification within the account category for more granular reporting and analysis (e.g., Trade Receivables, Inventory - Raw Materials, Salaries and Wages).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'The business unit or division code associated with this account for organizational reporting and consolidation.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationAccount rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account' ;
    rdfs:comment 'The account number in the consolidated chart of accounts that this account maps to for group-level financial reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReportingCode rdf:type rdf:Property ;
    rdfs:label 'External Reporting Code' ;
    rdfs:comment 'The code or line item reference used for external regulatory reporting (e.g., SEC filing line items, tax authority reporting codes).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatement rdf:type rdf:Property ;
    rdfs:label 'Financial Statement' ;
    rdfs:comment 'The primary financial statement where this account is reported (Balance Sheet, Income Statement, Cash Flow Statement, or Statement of Changes in Equity).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isControlAccount rdf:type rdf:Property ;
    rdfs:label 'Is Control Account' ;
    rdfs:comment 'Indicates whether this is a control account (summary account) that is reconciled to subsidiary ledgers (e.g., Accounts Receivable control account reconciled to customer sub-ledger).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIntercompany rdf:type rdf:Property ;
    rdfs:label 'Is Intercompany' ;
    rdfs:comment 'Indicates whether this account is used for intercompany transactions that require elimination during consolidation.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Posting Allowed' ;
    rdfs:comment 'Indicates whether direct transaction posting is allowed to this account. Summary/control accounts typically do not allow direct posting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReconciliationRequired rdf:type rdf:Property ;
    rdfs:label 'Is Reconciliation Required' ;
    rdfs:comment 'Indicates whether this account requires periodic reconciliation (e.g., bank accounts, intercompany accounts, suspense accounts).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:normalBalance rdf:type rdf:Property ;
    rdfs:label 'Normal Balance' ;
    rdfs:comment 'Indicates whether this account normally carries a debit or credit balance based on accounting principles (assets and expenses are debit; liabilities, equity, and revenue are credit).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Account Number' ;
    rdfs:comment 'The account number of the parent account in a hierarchical chart of accounts structure, enabling roll-up reporting and consolidation.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliation rdf:type rdf:Property ;
    rdfs:label 'Affiliation' ;
    rdfs:comment 'Parent federation or umbrella organization the union is affiliated with (e.g., AFL-CIO, Change to Win).' ;
    rdfs:domain ind:Union ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bargainingUnitDescription rdf:type rdf:Property ;
    rdfs:label 'Bargaining Unit Description' ;
    rdfs:comment 'Description of the employee group or job classifications covered by this union for collective bargaining purposes.' ;
    rdfs:domain ind:Union ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonName rdf:type rdf:Property ;
    rdfs:label 'Contact Person Name' ;
    rdfs:comment 'Full name of the primary union representative or business agent for communication and coordination.' ;
    rdfs:domain ind:Union ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'Date when the current collective bargaining agreement with this union became effective.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiration Date' ;
    rdfs:comment 'Date when the current collective bargaining agreement with this union expires.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decertificationDate rdf:type rdf:Property ;
    rdfs:label 'Decertification Date' ;
    rdfs:comment 'Date when the union was decertified or lost its bargaining rights, if applicable.' ;
    rdfs:domain ind:Union ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:duesAmount rdf:type rdf:Property ;
    rdfs:label 'Dues Amount' ;
    rdfs:comment 'Standard union dues amount charged per payment period, in the organization\'s base currency.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:duesCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Dues Calculation Method' ;
    rdfs:comment 'Method used to calculate union dues for member employees.' ;
    rdfs:domain ind:Union ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duesFrequency rdf:type rdf:Property ;
    rdfs:label 'Dues Frequency' ;
    rdfs:comment 'Frequency at which union dues are collected from member employees.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceProcedureDescription rdf:type rdf:Property ;
    rdfs:label 'Grievance Procedure Description' ;
    rdfs:comment 'Summary of the formal grievance and dispute resolution process established in the collective bargaining agreement.' ;
    rdfs:domain ind:Union ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Initiation Fee Amount' ;
    rdfs:comment 'One-time fee charged to new union members upon joining, in the organization\'s base currency.' ;
    rdfs:domain ind:Union ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRightToWorkApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Right To Work Applicable' ;
    rdfs:comment 'Indicates whether right-to-work laws apply to this union\'s jurisdiction, affecting mandatory membership requirements.' ;
    rdfs:domain ind:Union ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localNumber rdf:type rdf:Property ;
    rdfs:label 'Local Number' ;
    rdfs:comment 'Identifier for the local chapter or branch of the union, if applicable.' ;
    rdfs:domain ind:Union ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalUnionName rdf:type rdf:Property ;
