    rdfs:range xsd:string .

ind:requirementType rdf:type rdf:Property ;
    rdfs:label 'Requirement Type' ;
    rdfs:comment 'Classification of the requirement based on its origin and binding nature.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAgencyId rdf:type rdf:Property ;
    rdfs:label 'Parent Agency Id' ;
    rdfs:comment 'Reference to the parent regulatory agency if this agency is a division or sub-agency of a larger organization.' ;
