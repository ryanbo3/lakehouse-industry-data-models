    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentRequirementId rdf:type rdf:Property ;
    rdfs:label 'Parent Requirement Id' ;
    rdfs:comment 'Reference to the requirement_id of a higher-level or umbrella requirement of which this is a sub-requirement or detailed control.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requirement .

ind:supersededByRequirementId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Requirement Id' ;
    rdfs:comment 'Reference to the requirement_id of the newer requirement that replaces or supersedes this requirement, if applicable.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requirement .

ind:certificationRequired rdf:type rdf:Property ;
    rdfs:label 'Certification Required' ;
    rdfs:comment 'Indicates whether formal certification or attestation is required to demonstrate compliance with this requirement.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceObligation rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation' ;
    rdfs:comment 'Specific actions, controls, or outcomes that the organization must achieve to satisfy this requirement.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationRequired rdf:type rdf:Property ;
    rdfs:label 'Documentation Required' ;
    rdfs:comment 'Indicates whether formal documentation, records, or evidence must be maintained to demonstrate compliance.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationContact rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact' ;
    rdfs:comment 'Role or department to be contacted for escalation of compliance issues or questions related to this requirement.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Internal Policy Reference' ;
    rdfs:comment 'Reference number or identifier of the internal company policy, procedure, or standard operating procedure that implements this compliance requirement.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Penalty Amount' ;
    rdfs:comment 'The maximum monetary penalty or fine that can be imposed for violation of this requirement, in the organization\'s reporting currency.' ;
