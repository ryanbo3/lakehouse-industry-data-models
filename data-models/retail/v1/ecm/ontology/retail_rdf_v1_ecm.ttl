    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enablingLegislation rdf:type rdf:Property ;
    rdfs:label 'Enabling Legislation' ;
    rdfs:comment 'Name and citation of the primary law or statute that established the regulatory agency and grants it authority (e.g., Food Safety Modernization Act, Occupational Safety and Health Act).' ;
    rdfs:domain ind:RegulatoryAgency ;
