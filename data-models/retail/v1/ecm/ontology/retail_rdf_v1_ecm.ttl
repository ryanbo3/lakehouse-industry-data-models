# --- Attribute Properties ---
ind:accessPolicyId rdf:type rdf:Property ;
    rdfs:label 'Access Policy Id' ;
    rdfs:comment 'Unique identifier for the analytics access policy record. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessPolicy .

ind:associateId rdf:type rdf:Property ;
    rdfs:label 'Associate Id' ;
    rdfs:comment 'Individual user identifier for user-specific policy assignments. Used for exceptions and personalized access grants.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:accessLevel rdf:type rdf:Property ;
    rdfs:label 'Access Level' ;
    rdfs:comment 'Permission level granted by this policy: view (read-only), export (download capability), edit (modify), admin (full control), or deny (explicit block).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether this policy requires explicit approval workflow before activation. True for high-risk or sensitive data access policies.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when this policy was approved. Part of the governance audit trail.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'User identifier of the data steward or governance officer who approved this policy. Required for audit trail and compliance reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedGroup rdf:type rdf:Property ;
    rdfs:label 'Assigned Group' ;
    rdfs:comment 'User group identifier to which this policy is assigned. Enables group-based access management for analytics assets.' ;
    rdfs:domain ind:AccessPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedRole rdf:type rdf:Property ;
    rdfs:label 'Assigned Role' ;
    rdfs:comment 'Role identifier to which this policy is assigned. Supports role-based access control (RBAC) for analytics consumption.' ;
    rdfs:domain ind:AccessPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Business rationale for granting or restricting access. Documents the business case, regulatory requirement, or operational need driving this policy.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'Regulatory or compliance framework this policy supports (e.g., GDPR, CCPA, SOX, PCI-DSS, HIPAA). Enables compliance reporting and audit readiness.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Date and time when this policy record was first created in the system. Supports audit trail and policy lifecycle tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataClassificationConstraint rdf:type rdf:Property ;
    rdfs:label 'Data Classification Constraint' ;
    rdfs:comment 'Data classification level constraint enforced by this policy. Restricts access based on data sensitivity: restricted (PII/PHI/PCI), confidential (business-sensitive), internal (employee-only), public (unrestricted).' ;
    rdfs:domain ind:AccessPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentScopeRestriction rdf:type rdf:Property ;
    rdfs:label 'Department Scope Restriction' ;
    rdfs:comment 'Comma-separated list of department codes to which this policy restricts data visibility. Enables departmental data segmentation (e.g., merchandising, finance, supply chain).' ;
    rdfs:domain ind:AccessPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date when this access policy expires and is no longer enforced. Null indicates indefinite policy duration.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date when this access policy becomes active and enforceable. Supports time-bound access grants for temporary projects or seasonal roles.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enforcementMode rdf:type rdf:Property ;
    rdfs:label 'Enforcement Mode' ;
    rdfs:comment 'Policy enforcement behavior: enforce (block unauthorized access), audit (log violations but allow access), warn (notify user but allow access). Supports phased rollout and testing.' ;
    rdfs:domain ind:AccessPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filterExpression rdf:type rdf:Property ;
    rdfs:label 'Filter Expression' ;
    rdfs:comment 'SQL WHERE clause or filter predicate applied for row-level security. Dynamically filters data based on user context, role, or attribute values.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this policy is currently active and being enforced. False indicates the policy is disabled or archived.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAccessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Access Review Date' ;
    rdfs:comment 'Date when this policy was last reviewed for continued appropriateness and accuracy. Supports periodic access recertification processes.' ;
    rdfs:domain ind:AccessPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User identifier of the person who last modified this policy record. Tracks accountability for policy changes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Date and time when this policy record was last updated. Supports change tracking and audit compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maskingRule rdf:type rdf:Property ;
    rdfs:label 'Masking Rule' ;
    rdfs:comment 'Data masking technique applied for column-level security: none (no masking), full_mask (complete obfuscation), partial_mask (show last 4 digits), hash (one-way hash), tokenize (reversible token), redact (replace with placeholder), null (return null). [ENUM-REF-CANDIDATE: none|full_mask|partial_mask|hash|tokenize|redact|null — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Due Date' ;
    rdfs:comment 'Scheduled date for the next mandatory policy review. Ensures policies remain current and aligned with business needs and regulatory requirements.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Unique business identifier code for the access policy, used for system integration and reference.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Detailed business justification and purpose of this access policy. Explains why the policy exists and what business need it serves.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Human-readable name of the access policy for identification and management purposes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle state of the access policy: draft (under review), active (enforced), suspended (temporarily disabled), expired (past end date), revoked (permanently cancelled).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the access control mechanism: row-level (filters rows), column-level (masks columns), object-level (entire object access), attribute-level (specific field access), cell-level (individual cell masking), or dynamic (context-based).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric priority for policy evaluation when multiple policies apply to the same user and object. Lower numbers indicate higher priority. Used for conflict resolution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regionScopeRestriction rdf:type rdf:Property ;
    rdfs:label 'Region Scope Restriction' ;
    rdfs:comment 'Comma-separated list of region codes or geographic identifiers to which this policy restricts data visibility. Supports regional business unit data isolation.' ;
    rdfs:domain ind:AccessPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Risk classification of the data or analytics asset governed by this policy. Drives approval workflows and monitoring intensity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeScopeRestriction rdf:type rdf:Property ;
    rdfs:label 'Store Scope Restriction' ;
    rdfs:comment 'Comma-separated list of store identifiers or store codes to which this policy restricts data visibility. Enables store-level data segmentation for regional managers and store operations.' ;
    rdfs:domain ind:AccessPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetObjectName rdf:type rdf:Property ;
    rdfs:label 'Target Object Name' ;
    rdfs:comment 'Fully qualified name or identifier of the specific analytics object (dashboard, report, metric, data product) governed by this policy.' ;
    rdfs:domain ind:AccessPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetObjectType rdf:type rdf:Property ;
    rdfs:label 'Target Object Type' ;
    rdfs:comment 'Type of analytics object this policy governs: dashboard, report, semantic metric, data product, dataset, view, or table. [ENUM-REF-CANDIDATE: dashboard|report|semantic_metric|data_product|dataset|view|table — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSchemaName rdf:type rdf:Property ;
    rdfs:label 'Target Schema Name' ;
    rdfs:comment 'Database schema or catalog namespace where the target object resides, supporting multi-tenant and domain-segregated analytics environments.' ;
    rdfs:domain ind:AccessPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User identifier of the person who created this policy record. Part of the audit trail for governance and compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertId rdf:type rdf:Property ;
    rdfs:label 'Alert Id' ;
    rdfs:comment 'Unique identifier for the analytics alert record. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Alert .

ind:adjustmentId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Id' ;
    rdfs:comment 'Foreign key linking to inventory.adjustment. Business justification: Shrinkage alerts flag high-value adjustments (>$500, unauthorized adjustments, pattern anomalies). Loss prevention requires direct adjustment linkage for case management and investigation workflows.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:alertAssignedToUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Alert Assigned To User Associate Id' ;
    rdfs:comment 'Identifier of the user or team member assigned to investigate and resolve the alert. Null if unassigned.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:alertAssociateId rdf:type rdf:Property ;
    rdfs:label 'Alert Associate Id' ;
    rdfs:comment 'Identifier of the user who acknowledged the alert. Null if not yet acknowledged.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit_finding. Business justification: Critical audit findings trigger operational alerts (critical food safety violation, immediate corrective action required). Link enables automated escalation workflows and real-time compliance issue ma' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:businessEntityId rdf:type rdf:Property ;
    rdfs:label 'Business Entity Id' ;
    rdfs:comment 'Identifier of the specific business entity instance affected by the alert (e.g., store number, SKU, customer ID). Polymorphic reference based on business_entity_type.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SemanticLayerEntity .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Alerts trigger on campaign performance thresholds (underperforming ROAS, overspend, low conversion). Retail marketing operations require real-time alerts for campaign issues; this link enables proacti' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Operational alerts (shrink, labor variance, expense overruns) are triggered at cost center level for immediate manager notification and corrective action. Standard retail exception management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:cycleCountId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Id' ;
    rdfs:comment 'Foreign key linking to inventory.cycle_count. Business justification: Variance alerts trigger when cycle counts exceed thresholds (>5% variance, high-value discrepancies). Operations teams investigate specific count events; alert systems require direct count linkage for' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CycleCount .

ind:demandForecastId rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Id' ;
    rdfs:comment 'Foreign key linking to supplychain.demand_forecast. Business justification: Alerts planners when forecast variance exceeds thresholds, enabling exception-based planning. Essential for demand sensing and rapid response to demand shifts in retail.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandForecast .

ind:dqResultId rdf:type rdf:Property ;
    rdfs:label 'Dq Result Id' ;
    rdfs:comment 'Foreign key linking to analytics.dq_result. Business justification: Analytics alerts can be triggered by data quality rule violations. This FK links the alert to the specific DQ result execution that triggered it, enabling root cause analysis and linking alert resolut' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DqResult .

ind:financialPeriodId rdf:type rdf:Property ;
    rdfs:label 'Financial Period Id' ;
    rdfs:comment 'Foreign key linking to finance.financial_period. Business justification: Alerts on financial KPIs must reference the fiscal period for context (e.g., \'Q3 margin below threshold\'). Essential for period-specific exception reporting and close process monitoring.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialPeriod .

ind:fulfillmentNodeId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Node Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.node. Business justification: Node-level alerts (capacity threshold breaches, equipment downtime, staffing shortages, inventory discrepancies) trigger operational responses. Critical for facility management, resource allocation, a' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentNode .

ind:fulfillmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.fulfillment_order. Business justification: Alerts trigger on fulfillment order exceptions (SLA breaches, stuck orders, allocation failures, cancellation spikes). Core to real-time operational monitoring, exception management workflows, and pro' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentOrder .

ind:fulfillmentShipmentId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Shipment Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.shipment. Business justification: Shipment-level alerts (carrier delays, tracking gaps, delivery failures, damaged packages) are fundamental to logistics monitoring. Enables carrier performance tracking, customer proactive notificatio' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:itemHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Item Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to product.item_hierarchy. Business justification: Category-level alerts (department sales miss, subcategory margin below plan) trigger merchandising review. Aggregate performance monitoring at hierarchy nodes. Standard retail exception-based manageme' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItemHierarchy .

ind:kpiDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Kpi Definition Id' ;
    rdfs:comment 'Reference to the KPI definition that triggered this alert. Links to the master KPI catalog.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiDefinition .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Foreign key linking to store.store_location. Business justification: Store performance alerts (shrinkage spike, conversion drop, sales miss) trigger notifications to store/district managers. Operational exception management requires linking alerts to specific store loc' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:loyaltyMembershipId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Membership Id' ;
    rdfs:comment 'Foreign key linking to loyalty.membership. Business justification: Member-level alerts (fraud detection, unusual redemption patterns, tier qualification anomalies, points expiry warnings) trigger on specific memberships. Alerts require FK to membership for investigat' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyMembership .

ind:marginTargetId rdf:type rdf:Property ;
    rdfs:label 'Margin Target Id' ;
    rdfs:comment 'Foreign key linking to pricing.margin_target. Business justification: Margin breach alerts reference specific margin targets being violated (department, category, or buyer-level targets). Enables margin protection workflows with direct link to target definition. Real bu' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarginTarget .

ind:markdownId rdf:type rdf:Property ;
    rdfs:label 'Markdown Id' ;
    rdfs:comment 'Foreign key linking to pricing.markdown. Business justification: Markdown alerts (slow sell-through, excess inventory at clearance, markdown budget overrun) trigger on specific markdown events. Enables clearance intervention workflows. Real business process: automa' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Markdown .

ind:oshaIncidentId rdf:type rdf:Property ;
    rdfs:label 'Osha Incident Id' ;
    rdfs:comment 'Foreign key linking to compliance.osha_incident. Business justification: Serious safety incidents trigger immediate alerts to leadership and safety teams (recordable injuries, fatalities). Link supports real-time incident response, regulatory notification workflows, and sa' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OshaIncident .

ind:profileId rdf:type rdf:Property ;
    rdfs:label 'Profile Id' ;
    rdfs:comment 'Foreign key linking to customer.profile. Business justification: Customer-level alerts for high-value churn risk, VIP service issues, fraud detection, and loyalty tier changes are core to retail CRM operations. Real-time customer monitoring drives retention and los' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Executive alerts on segment performance (channel underperformance, regional margin issues) require profit center context for strategic response and resource reallocation decisions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:replenishmentPlanId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Plan Id' ;
    rdfs:comment 'Foreign key linking to supplychain.replenishment_plan. Business justification: Alerts for stockout risk, excess inventory, or service level breaches on specific replenishment plans. Core inventory health monitoring for retail operations and DC management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReplenishmentPlan .

ind:reportingHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Reporting Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to analytics.reporting_hierarchy. Business justification: Analytics alerts may be scoped to specific nodes in reporting hierarchies (e.g., alerts for a specific region or category). This FK links the alert to the hierarchy node it applies to, enabling hierar' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportingHierarchy .

ind:retailCalendarId rdf:type rdf:Property ;
    rdfs:label 'Retail Calendar Id' ;
    rdfs:comment 'Foreign key linking to analytics.retail_calendar. Business justification: Analytics alerts are triggered for specific dates in the retail calendar. This FK links the alert to the authoritative retail calendar date (typically the triggered_timestamp date), enabling fiscal pe' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailCalendar .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Alerts fire on SKU-level threshold breaches (inventory below safety stock, margin erosion, velocity drop, out-of-stock). Buyers and planners need SKU identification for action. Real-time operational m' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:skuPriceId rdf:type rdf:Property ;
    rdfs:label 'Sku Price Id' ;
    rdfs:comment 'Foreign key linking to pricing.sku_price. Business justification: Price alerts (MAP violations, competitive gap thresholds, margin floor breaches) trigger on specific SKU price records. Enables automated pricing compliance monitoring with direct link to violating pr' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuPrice .

ind:stockPositionId rdf:type rdf:Property ;
    rdfs:label 'Stock Position Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_position. Business justification: Inventory alerts (out-of-stock, overstock, dead stock, negative ATP) trigger on specific positions. Store managers and planners require direct drill-through to position details for immediate action.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:supplyPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Supply Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to supplychain.purchase_order. Business justification: Triggers alerts for PO exceptions (late delivery, cost overruns, quantity variances) to procurement teams. Critical for proactive supply chain risk management and vendor issue resolution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:acknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Timestamp' ;
    rdfs:comment 'Date and time when the alert was acknowledged by a user. Null if not yet acknowledged.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'The actual measured value of the KPI at the time the alert was triggered.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alertName rdf:type rdf:Property ;
    rdfs:label 'Alert Name' ;
    rdfs:comment 'Business-friendly name of the alert for identification and reporting purposes.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertStatus rdf:type rdf:Property ;
    rdfs:label 'Alert Status' ;
    rdfs:comment 'Current lifecycle status of the alert: new when first triggered, acknowledged when reviewed, investigating during analysis, resolved when addressed, dismissed if false positive, escalated if requiring higher attention.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertType rdf:type rdf:Property ;
    rdfs:label 'Alert Type' ;
    rdfs:comment 'Classification of the alert trigger mechanism: threshold breach when a KPI crosses a defined limit, anomaly detection for statistical outliers, trend deviation for directional changes, forecast variance for prediction misses, data quality issues, or target misses.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessEntityType rdf:type rdf:Property ;
    rdfs:label 'Business Entity Type' ;
    rdfs:comment 'Type of business entity affected by this alert (e.g., store, product, customer segment, supplier, category, region, sales channel). [ENUM-REF-CANDIDATE: store|product|customer|supplier|category|region|channel|campaign|employee|distribution_center — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for monetary KPIs (e.g., USD, EUR, GBP). Null for non-monetary metrics.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Source system or data product that provided the KPI measurement triggering this alert (e.g., SAP CAR, Oracle Retail, Blue Yonder).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Number of times the alert has been escalated to higher management levels. Zero for no escalation, increments with each escalation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:falsePositiveFlag rdf:type rdf:Property ;
    rdfs:label 'False Positive Flag' ;
    rdfs:comment 'Indicates whether the alert was determined to be a false positive after investigation. True if false alarm, False if legitimate alert.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Date and time when this alert record was last modified, tracking status changes, acknowledgments, and resolution updates.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'End date of the measurement period for which the KPI was calculated and the alert triggered.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'Start date of the measurement period for which the KPI was calculated and the alert triggered.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'Primary communication channel used to deliver the alert notification (email, SMS, push notification, Slack, Microsoft Teams, dashboard, webhook). [ENUM-REF-CANDIDATE: email|sms|push|slack|teams|dashboard|webhook — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether notification was successfully sent to recipients. True if sent, False if pending or failed.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Type of time period for the measurement: daily, weekly, monthly, quarterly, yearly, rolling window, or custom date range. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|yearly|rolling|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityScore rdf:type rdf:Property ;
    rdfs:label 'Priority Score' ;
    rdfs:comment 'Calculated priority score (0-100) combining severity, business impact, and urgency to support alert queue management and triage.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recipientList rdf:type rdf:Property ;
    rdfs:label 'Recipient List' ;
    rdfs:comment 'Comma-separated list of notification recipients (email addresses, user IDs, or distribution group names) who received or should receive this alert.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedAlertCount rdf:type rdf:Property ;
    rdfs:label 'Related Alert Count' ;
    rdfs:comment 'Number of related or correlated alerts triggered in the same time window for the same or related business entities, supporting root cause analysis.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Resolution Duration Minutes' ;
    rdfs:comment 'Time elapsed in minutes from alert trigger to resolution, used for Service Level Agreement (SLA) tracking and performance analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Free-text notes documenting the investigation findings, root cause analysis, and actions taken to resolve the alert.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the alert was marked as resolved. Null if still open or investigating.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ruleVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Version' ;
    rdfs:comment 'Version identifier of the alert rule configuration that was active when this alert triggered, supporting rule change tracking and audit.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Business impact severity of the alert: critical requires immediate action, high needs urgent attention, medium for monitoring, low for awareness, informational for FYI.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionFlag rdf:type rdf:Property ;
    rdfs:label 'Suppression Flag' ;
    rdfs:comment 'Indicates whether this alert was suppressed from notification due to alert fatigue rules, maintenance windows, or duplicate detection. True if suppressed, False if active.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppressionReason rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason' ;
    rdfs:comment 'Explanation of why the alert was suppressed (e.g., maintenance window, duplicate within 1 hour, recipient opt-out). Null if not suppressed.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'The threshold or boundary value that was breached to trigger the alert. Null for non-threshold alert types.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerCondition rdf:type rdf:Property ;
    rdfs:label 'Trigger Condition' ;
    rdfs:comment 'Detailed description of the condition that triggered the alert, including the rule logic and comparison operators used.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Triggered Timestamp' ;
    rdfs:comment 'Date and time when the alert condition was detected and the alert was triggered.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'The unit of measurement for the KPI value (e.g., USD, units, percentage, days, count).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Absolute difference between actual value and threshold value, calculated as actual minus threshold.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Percentage variance between actual and threshold, calculated as (actual - threshold) / threshold * 100.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dashboardConfigId rdf:type rdf:Property ;
    rdfs:label 'Dashboard Config Id' ;
    rdfs:comment 'Unique identifier for the dashboard configuration record. Primary key for the dashboard_config product.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DashboardConfig .

ind:accessTier rdf:type rdf:Property ;
    rdfs:label 'Access Tier' ;
    rdfs:comment 'Data classification level governing who can access this dashboard: public (all employees), internal (department-level), restricted (role-based), confidential (executive-only).' ;
    rdfs:domain ind:DashboardConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biPlatform rdf:type rdf:Property ;
    rdfs:label 'Bi Platform' ;
    rdfs:comment 'The BI platform or tool on which this dashboard is deployed (e.g., Tableau, Power BI, Databricks SQL, Looker). [ENUM-REF-CANDIDATE: tableau|power_bi|databricks_sql|looker|qlik|microstrategy|sap_analytics_cloud|oracle_analytics — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DashboardConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Date on which the dashboard was last certified by the BI governance team. Certifications typically expire after a defined period (e.g., 12 months).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Indicates whether the dashboard has been reviewed and certified by the BI governance team for data accuracy, compliance, and best practices: certified, pending_certification, not_certified.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceTags rdf:type rdf:Property ;
    rdfs:label 'Compliance Tags' ;
    rdfs:comment 'Comma-separated list of regulatory or compliance frameworks this dashboard supports (e.g., SOX, GDPR, PCI_DSS, ASC_606). Used for audit trail and regulatory reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardCode rdf:type rdf:Property ;
    rdfs:label 'Dashboard Code' ;
    rdfs:comment 'Unique business identifier code for the dashboard used in BI platform URLs and API references (e.g., STORE_PERF_001, INV_HEALTH_002).' ;
    rdfs:domain ind:DashboardConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardDescription rdf:type rdf:Property ;
    rdfs:label 'Dashboard Description' ;
    rdfs:comment 'Detailed business description of the dashboard purpose, key metrics displayed, intended use cases, and decision-making support provided.' ;
    rdfs:domain ind:DashboardConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardName rdf:type rdf:Property ;
    rdfs:label 'Dashboard Name' ;
    rdfs:comment 'Human-readable name of the business intelligence dashboard (e.g., Store Performance Scorecard, Inventory Health Monitor, Sales Executive Summary).' ;
    rdfs:domain ind:DashboardConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Dashboard Owner Email' ;
    rdfs:comment 'Email address of the dashboard owner for governance inquiries, access requests, and issue escalation.' ;
    rdfs:domain ind:DashboardConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardOwnerName rdf:type rdf:Property ;
    rdfs:label 'Dashboard Owner Name' ;
    rdfs:comment 'Full name of the business owner or product manager responsible for the dashboard content, accuracy, and governance.' ;
    rdfs:domain ind:DashboardConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardType rdf:type rdf:Property ;
    rdfs:label 'Dashboard Type' ;
    rdfs:comment 'Classification of the dashboard by its primary business purpose: operational (real-time monitoring), strategic (long-term planning), analytical (deep-dive analysis), tactical (short-term actions), executive (C-suite summary), or compliance (regulatory reporting).' ;
    rdfs:domain ind:DashboardConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceReferences rdf:type rdf:Property ;
    rdfs:label 'Data Source References' ;
    rdfs:comment 'Comma-separated or JSON list of underlying data products, tables, or views that feed this dashboard (e.g., sales_transaction, inventory_snapshot, store_master). Enables data lineage tracking.' ;
    rdfs:domain ind:DashboardConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:embeddedKpiReferences rdf:type rdf:Property ;
    rdfs:label 'Embedded Kpi References' ;
    rdfs:comment 'Comma-separated or JSON list of KPI identifiers that are visualized on this dashboard (e.g., comp_sales, gmroi, fill_rate, shrinkage_rate). Links to the KPI master data product.' ;
    rdfs:domain ind:DashboardConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportEnabled rdf:type rdf:Property ;
    rdfs:label 'Export Enabled' ;
    rdfs:comment 'Boolean flag indicating whether users are permitted to export data from this dashboard to external formats (Excel, PDF, CSV). May be restricted for confidential dashboards.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filterDefaults rdf:type rdf:Property ;
    rdfs:label 'Filter Defaults' ;
    rdfs:comment 'JSON or key-value structure defining default filter values applied when the dashboard loads (e.g., date range: last 30 days, region: all, store format: hypermarket).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAccessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Accessed Timestamp' ;
    rdfs:comment 'Timestamp of the most recent user access to this dashboard. Used to identify stale or unused dashboards for archival.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:layoutConfiguration rdf:type rdf:Property ;
    rdfs:label 'Layout Configuration' ;
    rdfs:comment 'JSON or XML structure defining the dashboard layout, including widget placement, grid dimensions, responsive breakpoints, and visual hierarchy. Stored as serialized configuration metadata.' ;
    rdfs:domain ind:DashboardConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileEnabled rdf:type rdf:Property ;
    rdfs:label 'Mobile Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this dashboard is optimized for and accessible on mobile devices (smartphones, tablets).' ;
    rdfs:domain ind:DashboardConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:owningBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Owning Business Unit' ;
    rdfs:comment 'The primary business unit or department that owns and governs this dashboard (e.g., merchandising, store_operations, supply_chain, finance, ecommerce). [ENUM-REF-CANDIDATE: merchandising|store_operations|supply_chain|finance|ecommerce|marketing|human_resources|loss_prevention|customer_service|real_estate — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationStatus rdf:type rdf:Property ;
    rdfs:label 'Publication Status' ;
    rdfs:comment 'Current lifecycle state of the dashboard: draft (under development), in_review (pending approval), published (live and accessible), archived (historical reference), deprecated (no longer maintained).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'Timestamp when this dashboard was last published and made available to end users. Distinct from creation or modification timestamps.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refreshSchedule rdf:type rdf:Property ;
    rdfs:label 'Refresh Schedule' ;
    rdfs:comment 'Frequency at which the underlying data for this dashboard is refreshed: real_time (streaming), hourly, daily, weekly, monthly, or on_demand (manual trigger).' ;
    rdfs:domain ind:DashboardConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshTime rdf:type rdf:Property ;
    rdfs:label 'Refresh Time' ;
    rdfs:comment 'Scheduled time of day (HH:MM format, 24-hour clock) when the dashboard data refresh job executes. Applicable for daily, weekly, or monthly refresh schedules.' ;
    rdfs:domain ind:DashboardConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subscriptionEnabled rdf:type rdf:Property ;
    rdfs:label 'Subscription Enabled' ;
    rdfs:comment 'Boolean flag indicating whether users can subscribe to scheduled email or notification delivery of this dashboard.' ;
    rdfs:domain ind:DashboardConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Comma-separated list of business tags or keywords for dashboard discovery and categorization (e.g., sales, inventory, store_performance, executive, real_time).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPersona rdf:type rdf:Property ;
    rdfs:label 'Target Persona' ;
    rdfs:comment 'Primary user role or persona for whom this dashboard is designed (e.g., Store Manager, Category Buyer, DC Supervisor, CFO, Merchandising Planner, Demand Planner, Loss Prevention Analyst).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalContactEmail rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Email' ;
    rdfs:comment 'Email address of the technical contact for dashboard support, bug reports, and technical inquiries.' ;
    rdfs:domain ind:DashboardConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalContactName rdf:type rdf:Property ;
    rdfs:label 'Technical Contact Name' ;
    rdfs:comment 'Full name of the technical developer or BI engineer responsible for dashboard maintenance, troubleshooting, and enhancements.' ;
    rdfs:domain ind:DashboardConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Url' ;
    rdfs:comment 'URL to a preview image or screenshot of the dashboard used in catalog listings, search results, and governance portals.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:url rdf:type rdf:Property ;
    rdfs:label 'Url' ;
    rdfs:comment 'Direct web link to access the dashboard in the BI platform. Enables single-click navigation from metadata catalogs and governance tools.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Cumulative number of times this dashboard has been accessed or viewed by users. Used for adoption tracking and ROI analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Semantic version number of the dashboard configuration (e.g., 1.0.0, 2.3.1). Incremented with each published change to track dashboard evolution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardWidgetId rdf:type rdf:Property ;
    rdfs:label 'Dashboard Widget Id' ;
    rdfs:comment 'Unique identifier for the dashboard widget. Primary key.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditEventId rdf:type rdf:Property ;
    rdfs:label 'Audit Event Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit_event. Business justification: Retail operations dashboards display recent audit results as widgets (store health scores, recent findings, compliance status). Direct link supports real-time compliance visibility for store managers ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditEvent .

ind:createdByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Created By User Associate Id' ;
    rdfs:comment 'Identifier of the user who created this widget.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:dqRuleId rdf:type rdf:Property ;
    rdfs:label 'Dq Rule Id' ;
    rdfs:comment 'Identifier of the data quality rule applied to validate the data displayed in this widget. Null if no specific rule is enforced.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DqRule .

ind:modifiedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Associate Id' ;
    rdfs:comment 'Identifier of the user who last modified this widget.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:reportDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Report Definition Id' ;
    rdfs:comment 'Identifier of the report definition that this widget renders. Null if widget displays a KPI rather than a custom report.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportDefinition .

ind:semanticLayerEntityId rdf:type rdf:Property ;
    rdfs:label 'Semantic Layer Entity Id' ;
    rdfs:comment 'Foreign key linking to analytics.semantic_layer_entity. Business justification: Dashboard widgets can query semantic layer entities directly for data-driven visualizations (e.g., a table widget showing all customers from the Customer semantic entity). This FK enables widgets to b' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SemanticLayerEntity .

ind:businessDomain rdf:type rdf:Property ;
    rdfs:label 'Business Domain' ;
    rdfs:comment 'Business domain or functional area that this widget supports (e.g., Sales, Inventory, Finance, Customer, Supply Chain).' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalFormattingRules rdf:type rdf:Property ;
    rdfs:label 'Conditional Formatting Rules' ;
    rdfs:comment 'JSON or structured text defining conditional formatting rules (color coding, icons, thresholds) applied to widget data based on business logic.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardWidgetDescription rdf:type rdf:Property ;
    rdfs:label 'Dashboard Widget Description' ;
    rdfs:comment 'Detailed business description of the widget purpose, data displayed, and intended use cases.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardWidgetStatus rdf:type rdf:Property ;
    rdfs:label 'Dashboard Widget Status' ;
    rdfs:comment 'Current lifecycle status of the widget: active (published and visible), inactive (hidden), draft (under development), archived (retained for history), or deprecated (scheduled for removal).' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQueryReference rdf:type rdf:Property ;
    rdfs:label 'Data Query Reference' ;
    rdfs:comment 'Reference to the underlying data query or dataset identifier (SQL view name, data product name, or query ID) that feeds this widget.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'Sequence number controlling the rendering order of widgets within the dashboard, used for layering and tab order.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drillThroughEnabled rdf:type rdf:Property ;
    rdfs:label 'Drill Through Enabled' ;
    rdfs:comment 'Indicates whether drill-through navigation to detailed reports or dashboards is enabled for this widget.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drillThroughTarget rdf:type rdf:Property ;
    rdfs:label 'Drill Through Target' ;
    rdfs:comment 'Reference to the target dashboard, report, or URL that users navigate to when drilling through from this widget. Null if drill-through is disabled.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportFormats rdf:type rdf:Property ;
    rdfs:label 'Export Formats' ;
    rdfs:comment 'Comma-separated list of allowed export formats (CSV, XLSX, PDF, PNG) for this widget. Null if export is disabled.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filterConfiguration rdf:type rdf:Property ;
    rdfs:label 'Filter Configuration' ;
    rdfs:comment 'JSON or structured text defining the filter configuration (filter fields, default values, filter type) for this widget. Null if filtering is disabled.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filterEnabled rdf:type rdf:Property ;
    rdfs:label 'Filter Enabled' ;
    rdfs:comment 'Indicates whether interactive filtering is enabled for this widget, allowing users to apply filters to the displayed data.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:height rdf:type rdf:Property ;
    rdfs:label 'Height' ;
    rdfs:comment 'Height of the widget in grid units or pixels, defining its vertical span on the dashboard canvas.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Timestamp' ;
    rdfs:comment 'Timestamp when the widget data was last refreshed from the underlying data source.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this widget record was last modified.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:positionX rdf:type rdf:Property ;
    rdfs:label 'Position X' ;
    rdfs:comment 'Horizontal position coordinate (in grid units or pixels) of the widget within the dashboard layout.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positionY rdf:type rdf:Property ;
    rdfs:label 'Position Y' ;
    rdfs:comment 'Vertical position coordinate (in grid units or pixels) of the widget within the dashboard layout.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refreshBehavior rdf:type rdf:Property ;
    rdfs:label 'Refresh Behavior' ;
    rdfs:comment 'Defines when the widget data is refreshed: manual (user-triggered), auto (periodic), on_load (dashboard open), or scheduled (specific times).' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Refresh Interval Seconds' ;
    rdfs:comment 'Automatic refresh interval in seconds. Null indicates manual refresh only.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tooltipText rdf:type rdf:Property ;
    rdfs:label 'Tooltip Text' ;
    rdfs:comment 'Help text or tooltip displayed to users when hovering over the widget, providing context or usage guidance.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visibilityScope rdf:type rdf:Property ;
    rdfs:label 'Visibility Scope' ;
    rdfs:comment 'Defines who can view this widget: public (all users), private (owner only), role_based (specific roles), or user_specific (specific users).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visualizationType rdf:type rdf:Property ;
    rdfs:label 'Visualization Type' ;
    rdfs:comment 'Specific visualization rendering type (bar chart, line chart, pie chart, heatmap, etc.) used to display data. [ENUM-REF-CANDIDATE: bar|line|pie|donut|scatter|heatmap|treemap|waterfall|funnel|area|combo|bullet|grid|pivot — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widgetName rdf:type rdf:Property ;
    rdfs:label 'Widget Name' ;
    rdfs:comment 'Business-friendly name of the widget displayed to end users.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widgetTitle rdf:type rdf:Property ;
    rdfs:label 'Widget Title' ;
    rdfs:comment 'Display title shown in the widget header on the dashboard canvas.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widgetType rdf:type rdf:Property ;
    rdfs:label 'Widget Type' ;
    rdfs:comment 'Functional type of the widget component (chart, table, scorecard, map, sparkline, gauge).' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:width rdf:type rdf:Property ;
    rdfs:label 'Width' ;
    rdfs:comment 'Width of the widget in grid units or pixels, defining its horizontal span on the dashboard canvas.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dqIssueId rdf:type rdf:Property ;
    rdfs:label 'Dq Issue Id' ;
    rdfs:comment 'Unique identifier for the data quality issue record. Primary key for tracking individual DQ incidents from detection through resolution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DqIssue .

ind:affectedSkuId rdf:type rdf:Property ;
    rdfs:label 'Affected Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Data quality issues often affect specific SKUs (incorrect weight causing shipping errors, missing allergen data blocking e-commerce). Issue tracking requires SKU identification for remediation workflo' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:inboundShipmentId rdf:type rdf:Property ;
    rdfs:label 'Inbound Shipment Id' ;
    rdfs:comment 'Foreign key linking to supplychain.inbound_shipment. Business justification: Manages receiving discrepancy issues (quantity variances, damaged goods) through resolution workflow. Core to warehouse quality management and supplier chargeback processes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundShipment .

ind:replenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Id' ;
    rdfs:comment 'Foreign key linking to inventory.replenishment_order. Business justification: Data quality issues in replenishment (MOQ violations, lead time anomalies, duplicate orders) require order-level tracking for supplier performance management and procurement process improvement.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReplenishmentOrder .

ind:returnFraudCaseId rdf:type rdf:Property ;
    rdfs:label 'Return Fraud Case Id' ;
    rdfs:comment 'Foreign key linking to returns.return_fraud_case. Business justification: Fraud cases often surface data quality issues (duplicate profiles, address mismatches, inconsistent purchase history) that trigger DQ investigations. Real-world fraud teams escalate data anomalies to ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReturnFraudCase .

ind:affectedAttribute rdf:type rdf:Property ;
    rdfs:label 'Affected Attribute' ;
    rdfs:comment 'The specific column or attribute within the data product that exhibits the quality issue, null if issue affects entire product.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedRecordCount rdf:type rdf:Property ;
    rdfs:label 'Affected Record Count' ;
    rdfs:comment 'Number of data records impacted by this quality issue, providing quantitative measure of issue scope and remediation effort.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'Date and time when the issue was assigned to a remediation owner, used for response time SLA measurement.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignedTo rdf:type rdf:Property ;
    rdfs:label 'Assigned To' ;
    rdfs:comment 'User ID or team name responsible for investigating and remediating this data quality issue, enabling workload tracking and escalation.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessImpact rdf:type rdf:Property ;
    rdfs:label 'Business Impact' ;
    rdfs:comment 'Narrative assessment of business consequences including affected processes, downstream systems, reporting accuracy, compliance risk, and operational disruption.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedBy rdf:type rdf:Property ;
    rdfs:label 'Closed By' ;
    rdfs:comment 'User ID of the person who verified resolution and closed the issue, typically a data steward or quality manager.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the issue was formally closed after verification and stakeholder approval, marking end of issue lifecycle.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Impact Flag' ;
    rdfs:comment 'Boolean indicator whether this data quality issue affects regulatory reporting or compliance obligations (FTC, FDA, PCI DSS, GDPR, CCPA), requiring escalation and audit trail.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataLineagePath rdf:type rdf:Property ;
    rdfs:label 'Data Lineage Path' ;
    rdfs:comment 'Comma-separated list of systems and transformations the data passed through from source to the point where the issue was detected, enabling impact analysis.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProduct rdf:type rdf:Property ;
    rdfs:label 'Data Product' ;
    rdfs:comment 'The specific data product or table where the quality issue was detected, enabling precise impact assessment and remediation targeting.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedBy rdf:type rdf:Property ;
    rdfs:label 'Detected By' ;
    rdfs:comment 'User ID or system name that detected the issue, supporting accountability and detection pattern analysis.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'Date and time when the data quality issue was first detected by automated monitoring or manual review. Critical for SLA tracking.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'How the issue was discovered: automated_rule (DQ rule engine), manual_review (data steward inspection), user_report (business user complaint), reconciliation (cross-system comparison), audit (compliance review), monitoring_alert (observability platform).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domain rdf:type rdf:Property ;
    rdfs:label 'Domain' ;
    rdfs:comment 'The business data domain where the quality issue was identified, aligning with enterprise data domain taxonomy. [ENUM-REF-CANDIDATE: customer|product|inventory|order|store|supply_chain|pricing|promotion|workforce|supplier|finance|loyalty|ecommerce|distribution|merchandising|analytics — 16 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dqIssueDescription rdf:type rdf:Property ;
    rdfs:label 'Dq Issue Description' ;
    rdfs:comment 'Detailed narrative description of the data quality issue including symptoms observed, data elements affected, and business context.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dqIssueStatus rdf:type rdf:Property ;
    rdfs:label 'Dq Issue Status' ;
    rdfs:comment 'Current lifecycle status of the data quality issue: open (newly detected), in_progress (under investigation or remediation), resolved (fix implemented), closed (verified and closed), accepted (acknowledged as acceptable risk), rejected (false positive).' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueNumber rdf:type rdf:Property ;
    rdfs:label 'Issue Number' ;
    rdfs:comment 'Human-readable business identifier for the data quality issue, typically formatted as DQ-NNNNNN for external reference and communication.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueType rdf:type rdf:Property ;
    rdfs:label 'Issue Type' ;
    rdfs:comment 'Classification of the data quality issue according to standard DQ dimensions: completeness (missing values), accuracy (incorrect values), consistency (contradictory values), validity (format violations), timeliness (stale data), uniqueness (duplicates).' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventionAction rdf:type rdf:Property ;
    rdfs:label 'Prevention Action' ;
    rdfs:comment 'Description of preventive measures implemented to avoid recurrence including process changes, rule enhancements, training, or system improvements.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Remediation priority level determining resolution urgency: P1 (immediate), P2 (urgent), P3 (normal), P4 (low). Combines severity and business criticality.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Boolean indicator whether this issue is a recurrence of a previously resolved issue, triggering deeper root cause analysis and process improvement.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Remediation Cost Estimate' ;
    rdfs:comment 'Estimated cost in USD to remediate this issue including labor, system changes, and data correction effort, supporting prioritization and resource planning.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed explanation of the remediation actions taken including data corrections, process changes, rule updates, and preventive measures implemented.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedBy rdf:type rdf:Property ;
    rdfs:label 'Resolved By' ;
    rdfs:comment 'User ID of the person who completed the remediation and marked the issue as resolved, supporting accountability and performance tracking.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'Date and time when the issue was marked as resolved after remediation actions were completed and verified.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level classification of the underlying cause: source_system (upstream system issue), etl_process (transformation logic error), data_entry (manual input error), business_rule (validation rule gap), integration (interface issue), migration (data conversion problem), manual_override (unauthorized change), unknown (under investigation). [ENUM-REF-CANDIDATE: source_system|etl_process|data_entry|business_rule|integration|migration|manual_override|unknown — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed explanation of the identified root cause including technical details, system components involved, and causal chain analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Business impact severity classification: critical (blocks operations or regulatory reporting), high (significant business impact), medium (moderate impact), low (minimal impact).' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Due Timestamp' ;
    rdfs:comment 'Target date and time by which the issue must be resolved based on priority and severity SLA commitments. Null if no SLA applies.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Name of the upstream operational system where the data originated, supporting root cause analysis and system-level quality trending.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Brief descriptive title summarizing the data quality issue for quick identification and reporting dashboards.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp when this DQ issue record was last modified, tracking issue progression and activity recency.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:verificationNotes rdf:type rdf:Property ;
    rdfs:label 'Verification Notes' ;
    rdfs:comment 'Notes documenting the verification process including tests performed, data samples reviewed, and stakeholder sign-off confirming issue resolution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSemanticLayerEntityId rdf:type rdf:Property ;
    rdfs:label 'Target Semantic Layer Entity Id' ;
    rdfs:comment 'Foreign key linking to analytics.semantic_layer_entity. Business justification: DQ results can be for semantic layer entities, consistent with dq_rule → semantic_layer_entity. When a DQ rule targets a semantic entity, the execution result should reference that entity. This FK ena' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SemanticLayerEntity .

ind:targetSkuId rdf:type rdf:Property ;
    rdfs:label 'Target Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Quality results track which SKUs failed validation (missing dimensions, incomplete nutritional data, expired compliance certs). Stewards need SKU-level failure tracking for remediation. Data quality s' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:batchCode rdf:type rdf:Property ;
    rdfs:label 'Batch Code' ;
    rdfs:comment 'Identifier for the batch or job that executed this rule. Used to group multiple rule executions that ran together as part of a scheduled DQ assessment.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSnapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Snapshot Timestamp' ;
    rdfs:comment 'Timestamp of the data snapshot that was evaluated. May differ from execution_timestamp if the rule evaluates historical or point-in-time data.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataTrustScore rdf:type rdf:Property ;
    rdfs:label 'Data Trust Score' ;
    rdfs:comment 'Calculated trust score for the target data product based on this rule execution result, ranging from 0.00 (no trust) to 100.00 (full trust). Aggregated across multiple rules to produce product-level trust metrics.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Execution Duration Seconds' ;
    rdfs:comment 'Time taken to execute the data quality rule against the target data product, measured in seconds. Used for performance monitoring and optimization.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Execution Error Message' ;
    rdfs:comment 'Technical error message if the rule execution failed or encountered issues. Null if execution completed successfully.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Technical execution status of the rule run: completed (rule executed successfully), failed (execution error), timeout (exceeded time limit), cancelled (manually stopped).' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Timestamp' ;
    rdfs:comment 'Date and time when the data quality rule was executed against the target data product. Represents the business event time of the quality check.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failureRatePercent rdf:type rdf:Property ;
    rdfs:label 'Failure Rate Percent' ;
    rdfs:comment 'Percentage of records that failed the quality check, calculated as (records_failed_count / records_evaluated_count) * 100. Used for trend analysis and SLA monitoring.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Detailed explanation of why records failed the quality check (e.g., \'Email format invalid\', \'Value exceeds maximum threshold\', \'Required field is null\').' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Overall outcome of the rule execution: pass (within acceptable threshold), fail (exceeds threshold), warning (approaching threshold), error (execution failure).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousFailureRatePercent rdf:type rdf:Property ;
    rdfs:label 'Previous Failure Rate Percent' ;
    rdfs:comment 'Failure rate from the previous execution of this rule against the same target product. Used for trend analysis and detecting quality degradation.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordsEvaluatedCount rdf:type rdf:Property ;
    rdfs:label 'Records Evaluated Count' ;
    rdfs:comment 'Total number of records in the target data product that were evaluated by this rule execution.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordsFailedCount rdf:type rdf:Property ;
    rdfs:label 'Records Failed Count' ;
    rdfs:comment 'Number of records that failed the data quality rule criteria and did not meet the expected quality threshold.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordsPassedCount rdf:type rdf:Property ;
    rdfs:label 'Records Passed Count' ;
    rdfs:comment 'Number of records that passed the data quality rule criteria.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remediationAction rdf:type rdf:Property ;
    rdfs:label 'Remediation Action' ;
    rdfs:comment 'Action taken in response to the quality check result: none (no action required), alert_sent (notification to data steward), ticket_created (incident logged), auto_corrected (automated fix applied), quarantined (records isolated), rejected (records blocked from downstream).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationOwner rdf:type rdf:Property ;
    rdfs:label 'Remediation Owner' ;
    rdfs:comment 'Name or identifier of the data steward, team, or system responsible for addressing the quality issues identified by this rule execution.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name of the data quality rule that was executed (e.g., \'Customer Email Format Validation\', \'Order Amount Range Check\').' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Category of data quality dimension being evaluated: completeness (null checks), accuracy (value correctness), consistency (cross-field logic), validity (format/range), uniqueness (duplicate detection), timeliness (freshness checks).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleFailedKeys rdf:type rdf:Property ;
    rdfs:label 'Sample Failed Keys' ;
    rdfs:comment 'Comma-separated list of primary key values for a sample of records that failed the quality check. Used for root cause analysis and remediation. Limited to first 100 keys.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'How this rule execution was initiated: scheduled (regular cadence), on_demand (manual trigger), event_triggered (data arrival event), continuous (real-time monitoring).' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Indicates whether the data quality result meets the defined SLA threshold for this rule and target product. True if within SLA, False if SLA violated.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetAttribute rdf:type rdf:Property ;
    rdfs:label 'Target Attribute' ;
    rdfs:comment 'The specific column/attribute within the target product that was evaluated. Null if the rule evaluates the entire record or multiple attributes.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDomain rdf:type rdf:Property ;
    rdfs:label 'Target Domain' ;
    rdfs:comment 'The business domain of the data product being evaluated (e.g., \'customer\', \'product\', \'order\', \'inventory\'). Aligns with enterprise data domain taxonomy.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetProduct rdf:type rdf:Property ;
    rdfs:label 'Target Product' ;
    rdfs:comment 'The specific data product (table/entity) that was evaluated by the DQ rule (e.g., \'customer.profile\', \'order.header\', \'inventory.stock_level\').' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trendDirection rdf:type rdf:Property ;
    rdfs:label 'Trend Direction' ;
    rdfs:comment 'Trend of data quality compared to previous execution: improving (failure rate decreased), stable (no significant change), degrading (failure rate increased), new (first execution).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceProgramId rdf:type rdf:Property ;
    rdfs:label 'Compliance Program Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_program. Business justification: Data quality rules enforce compliance data integrity (required fields for OSHA logs, food safety temperature ranges, training completion validation). Link enables compliance-driven DQ governance and r' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceProgram .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when this rule was formally approved for enforcement. Null for draft or unapproved rules.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:blockingFlag rdf:type rdf:Property ;
    rdfs:label 'Blocking Flag' ;
    rdfs:comment 'Indicates whether violations of this rule should halt downstream pipeline execution. True for critical data integrity rules; false for monitoring-only rules.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentationUrl rdf:type rdf:Property ;
    rdfs:label 'Documentation Url' ;
    rdfs:comment 'Link to detailed documentation, runbook, or knowledge base article explaining this rule, its business context, and remediation procedures.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date when this rule version became active and began enforcement. Used for temporal rule versioning and audit trail.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date when this rule version was superseded or retired. Null for currently active rules. Supports rule history and compliance audits.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executionFrequency rdf:type rdf:Property ;
    rdfs:label 'Execution Frequency' ;
    rdfs:comment 'Cadence at which this rule is evaluated. Real-time rules run on every record insert/update; batch rules run on scheduled intervals.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionLayer rdf:type rdf:Property ;
    rdfs:label 'Execution Layer' ;
    rdfs:comment 'Lakehouse medallion layer where this rule is enforced. Bronze for ingestion validation, Silver for transformation quality, Gold for consumption readiness.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastExecutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Execution Timestamp' ;
    rdfs:comment 'Date and time when this rule was most recently evaluated. Used to monitor rule execution health and detect stale rules.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastViolationCount rdf:type rdf:Property ;
    rdfs:label 'Last Violation Count' ;
    rdfs:comment 'Number of records that failed this rule during the most recent execution. Used for trend analysis and alerting.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User ID or service account that last updated this rule definition. Used for change tracking and accountability.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Notification Enabled' ;
    rdfs:comment 'Flag indicating whether automated alerts should be sent when this rule is violated. True enables email/Slack/PagerDuty notifications.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationRecipients rdf:type rdf:Property ;
    rdfs:label 'Notification Recipients' ;
    rdfs:comment 'Comma-separated list of email addresses, Slack channels, or distribution lists to notify when this rule is violated. Used by alerting engine.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineEnabled rdf:type rdf:Property ;
    rdfs:label 'Quarantine Enabled' ;
    rdfs:comment 'Flag indicating whether records violating this rule should be moved to a quarantine table for manual review. True enables automatic quarantine workflow.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Citation of applicable regulation, standard, or policy requiring this rule (e.g., GDPR Article 5, SOX Section 404, PCI DSS 3.2). Null if rule is business-driven only.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Unique business identifier or mnemonic code for the rule. Used for cross-system reference and automation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed business explanation of what the rule validates, why it matters, and what constitutes a violation. Used for documentation and training.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleLogic rdf:type rdf:Property ;
    rdfs:label 'Rule Logic' ;
    rdfs:comment 'SQL expression, Python function, or declarative logic defining the rule condition. Returns true for valid records, false for violations.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulePriority rdf:type rdf:Property ;
    rdfs:label 'Rule Priority' ;
    rdfs:comment 'Execution order priority when multiple rules apply to the same target. Lower numbers execute first. Used to sequence dependent validations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the rule. Active rules are enforced in production; inactive/deprecated rules are retained for audit history.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleTags rdf:type rdf:Property ;
    rdfs:label 'Rule Tags' ;
    rdfs:comment 'Comma-separated list of metadata tags for rule categorization and filtering (e.g., PII, financial, regulatory, master_data). Used for rule discovery and reporting.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdOperator rdf:type rdf:Property ;
    rdfs:label 'Threshold Operator' ;
    rdfs:comment 'Comparison operator applied to threshold_value. Defines whether the measured metric must be above, below, or equal to the threshold.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'Unit of measure for threshold_value. Percentage for error rates, count for absolute violations, ratio for proportional checks.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glossaryTermId rdf:type rdf:Property ;
    rdfs:label 'Glossary Term Id' ;
    rdfs:comment 'Unique identifier for the business glossary term record. Primary key.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exampleSkuId rdf:type rdf:Property ;
    rdfs:label 'Example Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Business glossary entries reference specific SKUs as examples (e.g., term \'private label\' links to example SKU, \'hazmat item\' shows real instance). Documentation and training practice for data literac' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Business terms for financial metrics reference specific GL accounts (e.g., \'Net Sales\' = accounts 4000-4999). Enables business-to-technical mapping for self-service analytics and data literacy.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:metricDimensionId rdf:type rdf:Property ;
    rdfs:label 'Metric Dimension Id' ;
    rdfs:comment 'Foreign key linking to analytics.metric_dimension. Business justification: Glossary terms may define or describe metric dimensions. This FK links the term to the dimension, enabling business users to understand the business meaning of dimensions used to slice and filter KPIs' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MetricDimension .

ind:obligationId rdf:type rdf:Property ;
    rdfs:label 'Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.obligation. Business justification: Compliance terms reference specific regulatory obligations (definitions cite CFR sections, OSHA standards, FDA requirements). Link provides regulatory traceability for business glossary and ensures co' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:semanticMetricId rdf:type rdf:Property ;
    rdfs:label 'Semantic Metric Id' ;
    rdfs:comment 'Foreign key linking to analytics.semantic_metric. Business justification: Glossary terms may reference semantic metrics they define or describe. This FK links the term to the metric, enabling business users to navigate from terminology definitions to the actual certified me' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SemanticMetric .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date when the glossary term was officially approved by the governance body.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current approval and publication status of the glossary term in the governance workflow. Indicates readiness for enterprise-wide use.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associatedReportNames rdf:type rdf:Property ;
    rdfs:label 'Associated Report Names' ;
    rdfs:comment 'Comma-separated list of report names or dashboard titles where this term is prominently used. Helps users understand term application.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessDefinition rdf:type rdf:Property ;
    rdfs:label 'Business Definition' ;
    rdfs:comment 'Comprehensive business definition of the term explaining its meaning, usage context, and business significance in retail operations.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Business Owner Email' ;
    rdfs:comment 'Email address of the business owner responsible for this glossary term.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessOwnerName rdf:type rdf:Property ;
    rdfs:label 'Business Owner Name' ;
    rdfs:comment 'Name of the business owner or subject matter expert who has authority over the business meaning and usage of this term.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationFormula rdf:type rdf:Property ;
    rdfs:label 'Calculation Formula' ;
    rdfs:comment 'Mathematical or logical formula used to calculate or derive this term if it represents a metric or KPI. Example: GMROI = Gross Margin / Average Inventory Cost.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeLog rdf:type rdf:Property ;
    rdfs:label 'Change Log' ;
    rdfs:comment 'Summary of changes made in this version of the glossary term. Documents evolution of the term definition over time.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containsFinancialData rdf:type rdf:Property ;
    rdfs:label 'Contains Financial Data' ;
    rdfs:comment 'Boolean flag indicating whether this term represents financial data subject to accounting standards or financial reporting requirements.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containsPii rdf:type rdf:Property ;
    rdfs:label 'Contains Pii' ;
    rdfs:comment 'Boolean flag indicating whether this term represents or includes personally identifiable information subject to privacy regulations.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalityLevel rdf:type rdf:Property ;
    rdfs:label 'Criticality Level' ;
    rdfs:comment 'Business criticality rating indicating the importance of this term to enterprise decision-making and regulatory compliance.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'Security classification level for data represented by this term. Indicates sensitivity and access control requirements.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataStewardEmail rdf:type rdf:Property ;
    rdfs:label 'Data Steward Email' ;
    rdfs:comment 'Email address of the data steward responsible for this glossary term.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataStewardName rdf:type rdf:Property ;
    rdfs:label 'Data Steward Name' ;
    rdfs:comment 'Name of the individual or role responsible for stewarding this glossary term, ensuring accuracy, consistency, and governance compliance.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataType rdf:type rdf:Property ;
    rdfs:label 'Data Type' ;
    rdfs:comment 'Expected data type for this term when represented in data products or analytics. Helps ensure consistent implementation across systems. [ENUM-REF-CANDIDATE: string|numeric|decimal|integer|date|timestamp|boolean — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Additional notes, clarifications, or context about the glossary term that do not fit in other structured fields.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningDomain rdf:type rdf:Property ;
    rdfs:label 'Owning Domain' ;
    rdfs:comment 'The primary data domain responsible for defining and maintaining this glossary term. Aligns with enterprise data domain taxonomy. [ENUM-REF-CANDIDATE: customer|product|inventory|order|store|supply_chain|pricing|promotion|workforce|supplier|finance|loyalty|ecommerce|distribution|merchandising|analytics — 16 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedTerms rdf:type rdf:Property ;
    rdfs:label 'Related Terms' ;
    rdfs:comment 'Comma-separated list of related glossary term codes or names that have semantic relationships with this term. Helps users discover connected concepts.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synonyms rdf:type rdf:Property ;
    rdfs:label 'Synonyms' ;
    rdfs:comment 'Comma-separated list of alternative terms, aliases, or synonyms used across the organization that refer to the same concept. Example: Item, Product, Article for SKU.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalDefinition rdf:type rdf:Property ;
    rdfs:label 'Technical Definition' ;
    rdfs:comment 'Technical or data-centric definition describing how the term is calculated, derived, or represented in data systems.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termAbbreviation rdf:type rdf:Property ;
    rdfs:label 'Term Abbreviation' ;
    rdfs:comment 'Standard abbreviation or acronym for the term. Example: SKU, SSS, GMROI, BOPIS, EDLP.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termCategory rdf:type rdf:Property ;
    rdfs:label 'Term Category' ;
    rdfs:comment 'Classification of the glossary term type. Indicates whether the term represents master data, transactional data, a metric, dimension, KPI, business rule, process, or system concept. [ENUM-REF-CANDIDATE: master_data|transactional_data|reference_data|metric|dimension|kpi|business_rule|process|system — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termCode rdf:type rdf:Property ;
    rdfs:label 'Term Code' ;
    rdfs:comment 'Short, unique alphanumeric code for the glossary term used for system references and lookups. Example: SKU_DEF, COMP_SALES, GMROI.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termName rdf:type rdf:Property ;
    rdfs:label 'Term Name' ;
    rdfs:comment 'The official business term or phrase as used across the enterprise. Example: Stock Keeping Unit, Comparable Store Sales, Gross Margin Return on Investment.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageExample rdf:type rdf:Property ;
    rdfs:label 'Usage Example' ;
    rdfs:comment 'Concrete example demonstrating how the term is used in business context, reports, or analytics. Provides clarity for end users.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageFrequency rdf:type rdf:Property ;
    rdfs:label 'Usage Frequency' ;
    rdfs:comment 'Indicator of how frequently this term is used across reports, dashboards, and analytics products. Helps prioritize governance efforts.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validValues rdf:type rdf:Property ;
    rdfs:label 'Valid Values' ;
    rdfs:comment 'Comma-separated list or description of valid values, ranges, or constraints for this term. Example: Active, Inactive, Suspended for Status terms.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentId rdf:type rdf:Property ;
    rdfs:label 'Department Id' ;
    rdfs:comment 'Foreign key linking to store.store_department. Business justification: Department-level KPIs (department margin, shrinkage by department, sales per labor hour) are defined for merchandising analytics. Category managers track performance by department across store fleet.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:formatId rdf:type rdf:Property ;
    rdfs:label 'Format Id' ;
    rdfs:comment 'Foreign key linking to store.store_format. Business justification: Format-level KPIs (typical sales per sqft by format, labor efficiency by format) are defined for format benchmarking and strategic planning. Retail planning teams compare hypermarket vs discount forma' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Format .

ind:memberSegmentId rdf:type rdf:Property ;
    rdfs:label 'Member Segment Id' ;
    rdfs:comment 'Foreign key linking to loyalty.member_segment. Business justification: Segment-specific KPIs (segment growth rate, segment profitability, segment churn, segment LTV) are defined per member segment for targeted measurement. Retailers track KPI definitions scoped to high-v' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MemberSegment .

ind:aggregationMethod rdf:type rdf:Property ;
    rdfs:label 'Aggregation Method' ;
    rdfs:comment 'The method used to aggregate the KPI across dimensions (e.g., sum for total sales, average for average transaction value, count for transaction count, ratio for calculated metrics like sell-through rate). [ENUM-REF-CANDIDATE: sum|average|count|min|max|median|weighted_average|ratio — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkSource rdf:type rdf:Property ;
    rdfs:label 'Benchmark Source' ;
    rdfs:comment 'The source of the benchmark value (e.g., NRF Industry Report 2023, Gartner Retail Analytics, internal historical average). Provides traceability and credibility for the benchmark.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkValue rdf:type rdf:Property ;
    rdfs:label 'Benchmark Value' ;
    rdfs:comment 'Industry benchmark or competitive reference value for this KPI, used for external performance comparison. May be sourced from NRF, industry reports, or competitive intelligence. Null if no benchmark is available.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biToolIntegration rdf:type rdf:Property ;
    rdfs:label 'Bi Tool Integration' ;
    rdfs:comment 'List of BI tools and platforms where this KPI is published and consumed (e.g., Tableau, Power BI, Looker, SAP Analytics Cloud). Comma-separated list.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardUsageCount rdf:type rdf:Property ;
    rdfs:label 'Dashboard Usage Count' ;
    rdfs:comment 'The number of enterprise dashboards and reports that currently consume this KPI. Used to assess the criticality and impact of changes to the KPI definition.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataLineageDescription rdf:type rdf:Property ;
    rdfs:label 'Data Lineage Description' ;
    rdfs:comment 'High-level description of the data lineage for this KPI: which source systems, data products, and transformation steps contribute to the calculation. Supports impact analysis and troubleshooting.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityRule rdf:type rdf:Property ;
    rdfs:label 'Data Quality Rule' ;
    rdfs:comment 'Business rules or validation logic that must be applied to ensure the accuracy and reliability of this KPI (e.g., exclude returns older than 90 days, filter out test transactions, require non-null store_id).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceDomain rdf:type rdf:Property ;
    rdfs:label 'Data Source Domain' ;
    rdfs:comment 'The primary data domain(s) from which this KPI sources its input data (e.g., Customer, Product, Inventory, Order, Store, Supply Chain, Pricing, Promotion, Finance). May reference multiple domains separated by commas.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLaggingIndicator rdf:type rdf:Property ;
    rdfs:label 'Is Lagging Indicator' ;
    rdfs:comment 'True if this KPI is a lagging indicator (measures past performance, e.g., sales revenue, profit margin). False if it is a leading indicator (predicts future performance, e.g., foot traffic, cart abandonment rate).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeadingIndicator rdf:type rdf:Property ;
    rdfs:label 'Is Leading Indicator' ;
    rdfs:comment 'True if this KPI is a leading indicator (predicts future performance, e.g., promotional engagement, inventory availability). False if it is a lagging indicator (measures past results).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublishedExternally rdf:type rdf:Property ;
    rdfs:label 'Is Published Externally' ;
    rdfs:comment 'True if this KPI is published in external reports (e.g., investor relations, annual reports, regulatory filings). False if it is for internal use only. Affects data quality and audit requirements.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kpiCode rdf:type rdf:Property ;
    rdfs:label 'Kpi Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the KPI across the enterprise (e.g., COMP_SALES, GMROI, INV_TURN). Used as a stable technical identifier in BI tools and dashboards.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiDescription rdf:type rdf:Property ;
    rdfs:label 'Kpi Description' ;
    rdfs:comment 'Detailed business description of what the KPI measures, its purpose, and how it supports retail decision-making. Includes context on when and why the metric is used.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiName rdf:type rdf:Property ;
    rdfs:label 'Kpi Name' ;
    rdfs:comment 'Human-readable business name of the KPI (e.g., Comparable Store Sales, Gross Margin Return on Investment, Inventory Turnover Rate). This is the display name used in reports and dashboards.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumAcceptableValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Acceptable Value' ;
    rdfs:comment 'The maximum acceptable value above which the KPI performance may indicate an anomaly or issue (e.g., excessive shrinkage, abnormal returns). Null if no maximum threshold is defined.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumAcceptableValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Acceptable Value' ;
    rdfs:comment 'The minimum acceptable value below which the KPI performance is considered unsatisfactory. Used for alerting and exception reporting. Null if no minimum threshold is defined.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:owningBusinessFunction rdf:type rdf:Property ;
    rdfs:label 'Owning Business Function' ;
    rdfs:comment 'The primary business function or department responsible for this KPI: merchandising, store operations, supply chain, finance, marketing, e-commerce, human resources, customer service, pricing, or inventory management. [ENUM-REF-CANDIDATE: merchandising|store_operations|supply_chain|finance|marketing|ecommerce|human_resources|customer_service|pricing|inventory — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precisionScale rdf:type rdf:Property ;
    rdfs:label 'Precision Scale' ;
    rdfs:comment 'Numeric precision and scale specification for decimal KPIs (e.g., 18,2 for currency, 5,4 for ratios). Defines the total number of digits and decimal places expected.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'Reference to any regulatory or compliance requirement that mandates the tracking and reporting of this KPI (e.g., SOX financial controls, GDPR data subject rights metrics, FTC advertising compliance). Null if not regulatory-driven.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'How often the KPI is calculated and reported: real-time (streaming), hourly, daily, weekly, monthly, quarterly, annually, or on-demand (ad-hoc). [ENUM-REF-CANDIDATE: real-time|hourly|daily|weekly|monthly|quarterly|annually|on-demand — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stewardEmail rdf:type rdf:Property ;
    rdfs:label 'Steward Email' ;
    rdfs:comment 'Email address of the business data steward responsible for this KPI. Used for inquiries, clarifications, and change requests.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stewardName rdf:type rdf:Property ;
    rdfs:label 'Steward Name' ;
    rdfs:comment 'Name of the business data steward responsible for the definition, accuracy, and governance of this KPI. This is the business owner, not a technical contact.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Target Threshold Value' ;
    rdfs:comment 'The target or goal value for this KPI that the business aims to achieve. Used for performance tracking and variance analysis. Null if no target is defined.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeGrain rdf:type rdf:Property ;
    rdfs:label 'Time Grain' ;
    rdfs:comment 'The finest level of time granularity at which this KPI is calculated: transaction-level, hourly, daily, weekly, monthly, quarterly, or annually. [ENUM-REF-CANDIDATE: transaction|hour|day|week|month|quarter|year — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyticsKpiTargetId rdf:type rdf:Property ;
    rdfs:label 'Analytics Kpi Target Id' ;
    rdfs:comment 'Unique identifier for the KPI target record. Primary key for the kpi_target product.' ;
    rdfs:domain ind:AnalyticsKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentivePlanId rdf:type rdf:Property ;
    rdfs:label 'Incentive Plan Id' ;
    rdfs:comment 'Reference to the specific incentive or compensation plan associated with this target. Null if target is not incentive-eligible.' ;
    rdfs:domain ind:AnalyticsKpiTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:inventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Inventory Node Id' ;
    rdfs:comment 'Foreign key linking to inventory.inventory_node. Business justification: Inventory KPI targets (turnover rate, fill rate, DOS) are set at node level (DC, store, region). Performance tracking and incentive compensation require node-level target linkage.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:primaryAnalyticsAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Analytics Associate Id' ;
    rdfs:comment 'Identifier of the user or manager who approved the target. Establishes accountability for target authorization.' ;
    rdfs:domain ind:AnalyticsKpiTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:targetFinancialPeriodId rdf:type rdf:Property ;
    rdfs:label 'Target Financial Period Id' ;
    rdfs:comment 'Foreign key linking to finance.financial_period. Business justification: Annual/quarterly targets must align to fiscal calendar for budget vs actual reporting, performance reviews, and incentive compensation calculations. Distinct from measurement period; targets are set p' ;
    rdfs:domain ind:AnalyticsKpiTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialPeriod .

ind:targetOwnerUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Target Owner User Associate Id' ;
    rdfs:comment 'Identifier of the individual or role accountable for achieving the target. Typically a store manager, category manager, regional director, or channel leader.' ;
    rdfs:domain ind:AnalyticsKpiTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:tertiaryAnalyticsLastUpdatedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Analytics Last Updated By User Associate Id' ;
    rdfs:comment 'Identifier of the user who most recently modified the target record. Supports accountability and audit trail.' ;
    rdfs:domain ind:AnalyticsKpiTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Fiscal period within the year (e.g., Q1, Q2, Q3, Q4, M01, M02, W01, FY) for which the target is defined. Supports quarterly, monthly, weekly, and annual target setting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'Fiscal year for which the target is set, following the organization\'s fiscal calendar (e.g., 2024, 2025).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Floor Threshold Value' ;
    rdfs:comment 'Minimum acceptable performance level below which corrective action or escalation is required. Represents the lower bound of acceptable performance.' ;
    rdfs:domain ind:AnalyticsKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Eligible Flag' ;
    rdfs:comment 'Indicates whether achievement of this target is tied to compensation, bonuses, or other incentive programs. True if target performance impacts financial rewards.' ;
    rdfs:domain ind:AnalyticsKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'End date of the performance measurement period for this target. Defines the conclusion of the evaluation window.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'Start date of the performance measurement period for this target. Defines the beginning of the evaluation window.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Explanation for why the target was revised after initial approval (e.g., market conditions changed, strategic pivot, acquisition impact). Provides context for mid-period adjustments.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stretchTargetValue rdf:type rdf:Property ;
    rdfs:label 'Stretch Target Value' ;
    rdfs:comment 'Aspirational or stretch goal value that exceeds the baseline target. Used to incentivize exceptional performance and drive continuous improvement.' ;
    rdfs:domain ind:AnalyticsKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetBasis rdf:type rdf:Property ;
    rdfs:label 'Target Basis' ;
    rdfs:comment 'Descriptive explanation of the rationale, assumptions, or data sources used to derive the target value. Provides transparency and auditability for target-setting decisions.' ;
    rdfs:domain ind:AnalyticsKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetOwnerRole rdf:type rdf:Property ;
    rdfs:label 'Target Owner Role' ;
    rdfs:comment 'Organizational role or job title of the target owner (e.g., Store Manager, Category Manager, Regional VP, E-Commerce Director). Provides context for accountability assignment.' ;
    rdfs:domain ind:AnalyticsKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSettingMethod rdf:type rdf:Property ;
    rdfs:label 'Target Setting Method' ;
    rdfs:comment 'Methodology used to establish the target value. Top-down: cascaded from corporate goals; Bottom-up: aggregated from operational plans; Algorithmic: calculated by forecasting models; Historical: based on prior period performance; Benchmark: derived from industry or peer comparisons.' ;
    rdfs:domain ind:AnalyticsKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'Planned or expected value for the KPI during the specified period. Represents the baseline performance goal that the business entity is expected to achieve.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetVersion rdf:type rdf:Property ;
    rdfs:label 'Target Version' ;
    rdfs:comment 'Version number of the target record. Increments when targets are revised or reforecasted during the performance period. Supports target change history and audit.' ;
    rdfs:domain ind:AnalyticsKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceAlertThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Variance Alert Threshold Percent' ;
    rdfs:comment 'Percentage deviation from target that triggers an alert or notification (e.g., 10.00 means alert if actual is 10% or more below target). Enables proactive performance management.' ;
    rdfs:domain ind:AnalyticsKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kpiValueId rdf:type rdf:Property ;
    rdfs:label 'Kpi Value Id' ;
    rdfs:comment 'Unique identifier for the KPI value record. Primary key for the kpi_value product.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiValue .

ind:dispositionId rdf:type rdf:Property ;
    rdfs:label 'Disposition Id' ;
    rdfs:comment 'Foreign key linking to returns.disposition. Business justification: Disposition recovery rates, restock rates, liquidation performance, and RTV success rates are key supply chain KPIs tracked for reverse logistics optimization and inventory management decisions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Disposition .

ind:engagementCampaignId rdf:type rdf:Property ;
    rdfs:label 'Engagement Campaign Id' ;
    rdfs:comment 'Foreign key linking to loyalty.engagement_campaign. Business justification: Campaign performance KPIs (participation rate, incremental spend, ROI, tier upgrade count) are measured per engagement campaign. kpi_value with business_entity_type=\'engagement_campaign\' requires FK f' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngagementCampaign .

ind:liquidationBatchId rdf:type rdf:Property ;
    rdfs:label 'Liquidation Batch Id' ;
    rdfs:comment 'Foreign key linking to returns.liquidation_batch. Business justification: Liquidation recovery rates, batch performance, and net recovery amounts are tracked as KPIs for reverse logistics optimization, vendor negotiations, and financial reporting on inventory write-offs.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LiquidationBatch .

ind:priceChangeId rdf:type rdf:Property ;
    rdfs:label 'Price Change Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_change. Business justification: Price change velocity KPIs (approval cycle time, change frequency, competitive response time) track individual price change events. Enables pricing agility dashboards. Real business process: pricing o' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceChange .

ind:returnRequestId rdf:type rdf:Property ;
    rdfs:label 'Return Request Id' ;
    rdfs:comment 'Foreign key linking to returns.return_request. Business justification: Return request metrics (approval rate, SLA compliance, request-to-RMA conversion, denial rate) are core retail KPIs tracked for customer service performance management and process optimization.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReturnRequest .

ind:returnsRmaId rdf:type rdf:Property ;
    rdfs:label 'Returns Rma Id' ;
    rdfs:comment 'Foreign key linking to returns.rma. Business justification: Returns KPIs (return rate, refund velocity, fraud rate, customer satisfaction) are measured per RMA and tracked in kpi_value for operational dashboards and executive reporting. Real-world retail opera' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rma .

ind:stockLedgerId rdf:type rdf:Property ;
    rdfs:label 'Stock Ledger Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_ledger. Business justification: Transaction-level KPIs (movement velocity, adjustment frequency, COGS accuracy) measure ledger activity. Audit trails and variance analysis reports require direct ledger linkage for regulatory complia' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockLedger .

ind:alertSeverity rdf:type rdf:Property ;
    rdfs:label 'Alert Severity' ;
    rdfs:comment 'The severity level of the alert if one was triggered: info (informational), warning (attention needed), critical (immediate action required), or none.' ;
    rdfs:domain ind:KpiValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Alert Triggered Flag' ;
    rdfs:comment 'Boolean indicator (True/False) showing whether this KPI value triggered a performance alert or threshold breach requiring management attention.' ;
    rdfs:domain ind:KpiValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'The method by which this KPI value was derived: computed from raw data, ingested from external system, manually entered, or aggregated from lower-level metrics.' ;
    rdfs:domain ind:KpiValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'The timestamp when this KPI value was computed or ingested into the analytics platform.' ;
    rdfs:domain ind:KpiValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confidenceIntervalLower rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Lower' ;
    rdfs:comment 'The lower bound of the statistical confidence interval for this KPI value, used in forecasting and predictive analytics scenarios.' ;
    rdfs:domain ind:KpiValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceIntervalUpper rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Upper' ;
    rdfs:comment 'The upper bound of the statistical confidence interval for this KPI value, used in forecasting and predictive analytics scenarios.' ;
    rdfs:domain ind:KpiValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataFreshnessTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Freshness Timestamp' ;
    rdfs:comment 'The timestamp indicating when the source data used to calculate this KPI value was last refreshed or updated. Critical for understanding data latency.' ;
    rdfs:domain ind:KpiValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'A numerical score (0-100) representing the quality and reliability of this KPI value based on completeness, accuracy, and timeliness of source data.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastModelVersion rdf:type rdf:Property ;
    rdfs:label 'Forecast Model Version' ;
    rdfs:comment 'The version identifier of the forecasting model or algorithm used to generate this KPI value, if it is a forecast. Null for actual values.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isForecast rdf:type rdf:Property ;
    rdfs:label 'Is Forecast' ;
    rdfs:comment 'Boolean indicator (True/False) showing whether this KPI value represents a forecasted/projected value rather than an actual historical measurement.' ;
    rdfs:domain ind:KpiValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceStatus rdf:type rdf:Property ;
    rdfs:label 'Performance Status' ;
    rdfs:comment 'A categorical assessment of performance relative to target: exceeds target (green), meets target (yellow), below target (amber), critical (red), or not applicable.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPeriodValue rdf:type rdf:Property ;
    rdfs:label 'Prior Period Value' ;
    rdfs:comment 'The KPI value from the comparable prior period (e.g., same period last year, previous month) used for trend analysis and year-over-year comparisons.' ;
    rdfs:domain ind:KpiValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Period Variance Amount' ;
    rdfs:comment 'The absolute difference between the actual value and the prior period value (actual_value - prior_period_value). Used for trend analysis.' ;
    rdfs:domain ind:KpiValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Prior Period Variance Percentage' ;
    rdfs:comment 'The percentage change from the prior period value, calculated as ((actual_value - prior_period_value) / prior_period_value) * 100. Enables period-over-period growth analysis.' ;
    rdfs:domain ind:KpiValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'The number of data points or transactions used to calculate this KPI value. Relevant for statistically-derived metrics to assess reliability.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacementDimensionMetricDimensionId rdf:type rdf:Property ;
    rdfs:label 'Replacement Dimension Metric Dimension Id' ;
    rdfs:comment 'Reference to the metric_dimension_id of the dimension that replaces this deprecated dimension. Null if no replacement exists. Supports migration planning and backward compatibility mapping.' ;
    rdfs:domain ind:MetricDimension ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MetricDimension .

ind:associatedDomain rdf:type rdf:Property ;
    rdfs:label 'Associated Domain' ;
    rdfs:comment 'The primary data domain to which this dimension belongs, such as Customer, Product, Inventory, Order, Store, Supply Chain, Pricing, Promotion, or Finance. Aligns the dimension with enterprise data governance and domain ownership structures.' ;
    rdfs:domain ind:MetricDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessOwner rdf:type rdf:Property ;
    rdfs:label 'Business Owner' ;
    rdfs:comment 'Name or identifier of the business unit, role, or individual responsible for the business definition, quality, and governance of this dimension. Typically a domain data steward or business subject matter expert.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessRules rdf:type rdf:Property ;
    rdfs:label 'Business Rules' ;
    rdfs:comment 'Documentation of business rules, constraints, and logic applied to this dimension. Examples include how dimension members are classified, how hierarchies are constructed, or how slowly changing dimension logic is applied.' ;
    rdfs:domain ind:MetricDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardinalityEstimate rdf:type rdf:Property ;
    rdfs:label 'Cardinality Estimate' ;
    rdfs:comment 'Estimated number of distinct members or rows in this dimension. Used for query optimization, index design, and OLAP cube sizing. For example, Store dimension might have 5000 members, while Time dimension at day grain might have 3650 members for 10 years.' ;
    rdfs:domain ind:MetricDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataQualityRules rdf:type rdf:Property ;
    rdfs:label 'Data Quality Rules' ;
    rdfs:comment 'Specification of data quality rules and validation checks applied to this dimension. Includes completeness checks, uniqueness constraints, referential integrity rules, and acceptable value ranges.' ;
    rdfs:domain ind:MetricDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultAggregation rdf:type rdf:Property ;
    rdfs:label 'Default Aggregation' ;
    rdfs:comment 'The default aggregation method to apply when this dimension is used in calculations or rolled up in hierarchies. Typically \'none\' for true dimensions, but may specify aggregation for degenerate dimensions or dimension attributes used in calculations. [ENUM-REF-CANDIDATE: sum|average|count|min|max|distinct_count|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MetricDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultSortOrder rdf:type rdf:Property ;
    rdfs:label 'Default Sort Order' ;
    rdfs:comment 'Numeric value indicating the default display order of this dimension in BI tools, dashboards, and reports. Lower values appear first. Used to standardize dimension presentation across the enterprise semantic layer.' ;
    rdfs:domain ind:MetricDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deprecatedFlag rdf:type rdf:Property ;
    rdfs:label 'Deprecated Flag' ;
    rdfs:comment 'Boolean flag indicating whether this dimension has been deprecated and is scheduled for retirement. Deprecated dimensions should not be used in new reports or dashboards but are retained for backward compatibility.' ;
    rdfs:domain ind:MetricDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deprecationDate rdf:type rdf:Property ;
    rdfs:label 'Deprecation Date' ;
    rdfs:comment 'The date on which this dimension was marked as deprecated. Null if the dimension is not deprecated. Used for planning migration and retirement activities.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dimensionCode rdf:type rdf:Property ;
    rdfs:label 'Dimension Code' ;
    rdfs:comment 'Short alphanumeric code or abbreviation for the dimension, used as a technical identifier in BI tools and semantic layer configurations. Typically uppercase and concise for system integration.' ;
    rdfs:domain ind:MetricDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionDescription rdf:type rdf:Property ;
    rdfs:label 'Dimension Description' ;
    rdfs:comment 'Comprehensive business description of the dimension, its purpose, and how it should be used in analytics and reporting. Provides context for business users and data analysts consuming the semantic layer.' ;
    rdfs:domain ind:MetricDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionName rdf:type rdf:Property ;
    rdfs:label 'Dimension Name' ;
    rdfs:comment 'The business name of the dimension used to slice and filter KPIs and metrics in the retail semantic layer. Examples include Store, Channel, Category, Brand, Region, Time Period, Customer Segment.' ;
    rdfs:domain ind:MetricDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionType rdf:type rdf:Property ;
    rdfs:label 'Dimension Type' ;
    rdfs:comment 'Classification of the dimension based on dimensional modeling patterns. Conformed dimensions are shared across multiple fact tables; degenerate dimensions are stored in the fact table; role-playing dimensions serve multiple contexts; junk dimensions combine low-cardinality flags; slowly changing dimensions track historical changes; outrigger dimensions are secondary dimensions referenced by a primary dimension.' ;
    rdfs:domain ind:MetricDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayFormat rdf:type rdf:Property ;
    rdfs:label 'Display Format' ;
    rdfs:comment 'Specification of how dimension members should be formatted for display in BI tools and reports. Examples include date formats, number formats, or custom display templates for composite keys.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillEnabled rdf:type rdf:Property ;
    rdfs:label 'Drill Enabled' ;
    rdfs:comment 'Boolean flag indicating whether drill-down and drill-up operations are enabled for this dimension in OLAP cubes and BI tools. Requires hierarchy_levels to be defined.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grainDescription rdf:type rdf:Property ;
    rdfs:label 'Grain Description' ;
    rdfs:comment 'Detailed description of the level of detail or granularity represented by this dimension. Defines what one row in the dimension table represents, such as individual store location, daily time period, or product SKU level.' ;
    rdfs:domain ind:MetricDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevels rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Levels' ;
    rdfs:comment 'Comma-separated list of hierarchical levels within the dimension, ordered from most granular to most aggregated. For example, Store dimension might have: Store > District > Region > Division. Time dimension might have: Day > Week > Month > Quarter > Year. Supports drill-down and roll-up analytics.' ;
    rdfs:domain ind:MetricDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConformed rdf:type rdf:Property ;
    rdfs:label 'Is Conformed' ;
    rdfs:comment 'Boolean flag indicating whether this dimension is a conformed dimension shared across multiple fact tables and business processes. Conformed dimensions enable consistent cross-process reporting and are a cornerstone of enterprise data warehouse design.' ;
    rdfs:domain ind:MetricDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSlowlyChanging rdf:type rdf:Property ;
    rdfs:label 'Is Slowly Changing' ;
    rdfs:comment 'Boolean flag indicating whether this dimension tracks historical changes over time using Slowly Changing Dimension (SCD) techniques. True if the dimension maintains history of attribute changes; false if only current state is maintained.' ;
    rdfs:domain ind:MetricDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'The frequency at which this dimension is refreshed from source systems. Determines data latency and impacts BI tool cache strategies and OLAP cube processing schedules.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scdType rdf:type rdf:Property ;
    rdfs:label 'Scd Type' ;
    rdfs:comment 'Classification of the SCD technique applied to this dimension. Type 0: retain original; Type 1: overwrite; Type 2: add new row with versioning; Type 3: add new column; Type 4: separate history table; Type 6: hybrid (1+2+3). Not applicable if is_slowly_changing is false. [ENUM-REF-CANDIDATE: type_0|type_1|type_2|type_3|type_4|type_6|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MetricDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClassification rdf:type rdf:Property ;
    rdfs:label 'Security Classification' ;
    rdfs:comment 'Data classification level for this dimension, determining access controls and data handling requirements. Public: no restrictions; Internal: company employees only; Confidential: sensitive business data; Restricted: highly sensitive data requiring special authorization.' ;
    rdfs:domain ind:MetricDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTable rdf:type rdf:Property ;
    rdfs:label 'Source Table' ;
    rdfs:comment 'Name of the specific table or entity in the source system from which this dimension is extracted. Used for data lineage documentation and ETL/ELT pipeline configuration.' ;
    rdfs:domain ind:MetricDimension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalOwner rdf:type rdf:Property ;
    rdfs:label 'Technical Owner' ;
    rdfs:comment 'Name or identifier of the technical team, role, or individual responsible for the implementation, maintenance, and technical quality of this dimension in the semantic layer and BI platforms.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySemanticLayerEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Semantic Layer Entity Id' ;
    rdfs:comment 'Foreign key linking to analytics.semantic_layer_entity. Business justification: Reports consume semantic layer entities as their primary data sources. The report_definition has source_data_products: STRING (comma-separated list), but a structured FK to the primary semantic entity' ;
    rdfs:domain ind:ReportDefinition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SemanticLayerEntity .

ind:primarySemanticMetricId rdf:type rdf:Property ;
    rdfs:label 'Primary Semantic Metric Id' ;
    rdfs:comment 'Foreign key linking to analytics.semantic_metric. Business justification: Reports can be built around specific semantic metrics (e.g., a \'Monthly Revenue Report\' centered on the Revenue semantic metric). This FK captures the primary metric focus of the report, enabling metr' ;
    rdfs:domain ind:ReportDefinition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SemanticMetric .

ind:accessControlGroup rdf:type rdf:Property ;
    rdfs:label 'Access Control Group' ;
    rdfs:comment 'Name of the Active Directory group, LDAP group, or IAM role that grants access to this report. Used for automated access provisioning and audit.' ;
    rdfs:domain ind:ReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageExecutionTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Average Execution Time Seconds' ;
    rdfs:comment 'Average time in seconds required to generate or refresh the report. Used for performance monitoring and capacity planning.' ;
    rdfs:domain ind:ReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataDomainsConsumed rdf:type rdf:Property ;
    rdfs:label 'Data Domains Consumed' ;
    rdfs:comment 'Comma-separated list of data domains that this report consumes data from. Examples: \'Customer, Order, Product\' or \'Inventory, Supply Chain, Store\'. Enables impact analysis and data lineage tracking.' ;
    rdfs:domain ind:ReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Days' ;
    rdfs:comment 'Number of days that historical report snapshots or output files are retained before archival or deletion. Driven by regulatory requirements and storage policies.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryFormat rdf:type rdf:Property ;
    rdfs:label 'Delivery Format' ;
    rdfs:comment 'Primary format or platform through which the report is delivered to consumers. Indicates the technical rendering mechanism (PDF, Excel) or BI platform (Tableau, Power BI, Databricks). [ENUM-REF-CANDIDATE: pdf|excel|tableau|powerbi|databricks_notebook|looker|qlik|csv|json|api — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionCount rdf:type rdf:Property ;
    rdfs:label 'Dimension Count' ;
    rdfs:comment 'Number of distinct dimensions or attributes available for slicing and filtering in the report. Indicates the analytical flexibility of the report.' ;
    rdfs:domain ind:ReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:governanceClassification rdf:type rdf:Property ;
    rdfs:label 'Governance Classification' ;
    rdfs:comment 'Data classification level of the report content, determining access controls and distribution restrictions. Public reports can be shared externally, internal reports are for employees only, confidential reports contain sensitive business data, restricted reports contain PII/PHI/PCI data.' ;
    rdfs:domain ind:ReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCertified rdf:type rdf:Property ;
    rdfs:label 'Is Certified' ;
    rdfs:comment 'Flag indicating whether the report has been certified by the BI governance team as meeting quality, accuracy, and documentation standards. Certified reports are promoted in the catalog.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kpiCount rdf:type rdf:Property ;
    rdfs:label 'Kpi Count' ;
    rdfs:comment 'Number of distinct KPIs or metrics included in the report. Provides a measure of report complexity and scope.' ;
    rdfs:domain ind:ReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:owningTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Team' ;
    rdfs:comment 'Name of the business or analytics team responsible for the report definition, maintenance, and quality. Examples: \'Merchandising Analytics\', \'Finance Reporting\', \'Executive Insights\'.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date when the report was first published to production and made available to consumers. Marks the start of the report\'s operational lifecycle.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refreshCadence rdf:type rdf:Property ;
    rdfs:label 'Refresh Cadence' ;
    rdfs:comment 'Frequency at which the report data is refreshed or regenerated. Defines the data freshness SLA for report consumers. [ENUM-REF-CANDIDATE: real_time|hourly|daily|weekly|monthly|quarterly|annually|on_demand — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryScope rdf:type rdf:Property ;
    rdfs:label 'Regulatory Scope' ;
    rdfs:comment 'Comma-separated list of regulatory frameworks or compliance requirements that this report supports. Examples: \'SOX\', \'GDPR\', \'PCI-DSS\', \'FDA\', \'FTC\'. Empty if the report has no regulatory purpose.' ;
    rdfs:domain ind:ReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportCategory rdf:type rdf:Property ;
    rdfs:label 'Report Category' ;
    rdfs:comment 'Business domain or functional area that the report primarily serves. Aligns with the enterprise data domain taxonomy to enable domain-based report discovery and governance. [ENUM-REF-CANDIDATE: sales|inventory|finance|customer|supply_chain|workforce|merchandising|ecommerce|store_operations|pricing|promotion|other — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportCode rdf:type rdf:Property ;
    rdfs:label 'Report Code' ;
    rdfs:comment 'Unique business identifier for the report, used for external references and API calls. Typically follows a naming convention like RPT_SALES_DAILY or EXEC_DASHBOARD_01.' ;
    rdfs:domain ind:ReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDescription rdf:type rdf:Property ;
    rdfs:label 'Report Description' ;
    rdfs:comment 'Detailed business description of the report purpose, key metrics included, intended audience, and business questions it answers. Provides context for report consumers and governance teams.' ;
    rdfs:domain ind:ReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportName rdf:type rdf:Property ;
    rdfs:label 'Report Name' ;
    rdfs:comment 'Human-readable name of the report as displayed in the analytics catalog and BI tools. Example: \'Daily Sales Performance Dashboard\' or \'Monthly Inventory Turnover Report\'.' ;
    rdfs:domain ind:ReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Report Owner Email' ;
    rdfs:comment 'Primary contact email address for the report owner or steward. Used for governance inquiries, change requests, and issue escalation.' ;
    rdfs:domain ind:ReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle status of the report definition. Draft reports are under development, active reports are in production use, deprecated reports are scheduled for retirement, retired reports are no longer available, suspended reports are temporarily disabled.' ;
    rdfs:domain ind:ReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the report by its primary business purpose. Operational reports support daily operations, financial reports support accounting and P&L analysis, executive reports provide strategic insights, regulatory reports meet compliance requirements, analytical reports support deep-dive analysis, and adhoc reports are one-time or exploratory.' ;
    rdfs:domain ind:ReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportUrl rdf:type rdf:Property ;
    rdfs:label 'Report Url' ;
    rdfs:comment 'Direct URL or deep link to access the report in the BI platform or analytics portal. Enables one-click navigation from the report catalog.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date when the report was retired and removed from production. Nullable for active and deprecated reports. Marks the end of the report\'s operational lifecycle.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceDataProducts rdf:type rdf:Property ;
    rdfs:label 'Source Data Products' ;
    rdfs:comment 'Comma-separated list of upstream data product names that feed this report. Enables detailed lineage tracking and change impact analysis at the product level.' ;
    rdfs:domain ind:ReportDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Description of the intended consumer audience for the report. Examples: \'Store Managers\', \'Executive Leadership\', \'Finance Controllers\', \'Merchandising Planners\'. Helps with report discovery and access provisioning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Report Subscription Id' ;
    rdfs:comment 'Unique identifier for the report subscription record. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportSubscription .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Reference to the team or group that subscribed to this report or dashboard. Nullable if subscription is individual.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:priceListId rdf:type rdf:Property ;
    rdfs:label 'Price List Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_list. Business justification: Price list distribution reports (sent to vendors, buyers, store ops) reference specific price lists for automated delivery. Enables scheduled price communication workflows. Real business process: week' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceList .

ind:primaryReportAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Report Associate Id' ;
    rdfs:comment 'Reference to the individual user who subscribed to this report or dashboard.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:tertiaryReportLastModifiedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Report Last Modified By User Associate Id' ;
    rdfs:comment 'Reference to the user who most recently modified this subscription record.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:attachmentFilenamePattern rdf:type rdf:Property ;
    rdfs:label 'Attachment Filename Pattern' ;
    rdfs:comment 'Template or pattern for naming the report file attachment, supporting dynamic variables like date, report name, and subscriber name.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'User-provided or system-generated reason for why the subscription was cancelled, used for analytics and improvement.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Timestamp when the subscription was cancelled by the user or system.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataRefreshRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Data Refresh Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether the underlying data should be refreshed before each delivery or if cached data is acceptable.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel' ;
    rdfs:comment 'The channel through which the report or dashboard will be delivered to the subscriber.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCount rdf:type rdf:Property ;
    rdfs:label 'Delivery Count' ;
    rdfs:comment 'Total number of times the report or dashboard has been successfully delivered to the subscriber since subscription creation.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Delivery Email Address' ;
    rdfs:comment 'Email address to which the report will be delivered if delivery channel is email. May differ from subscriber user email.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMessageBody rdf:type rdf:Property ;
    rdfs:label 'Delivery Message Body' ;
    rdfs:comment 'Body text or description included in the delivery message to provide context or instructions to the subscriber.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMessageSubject rdf:type rdf:Property ;
    rdfs:label 'Delivery Message Subject' ;
    rdfs:comment 'Subject line or title for the delivery message when the report is sent via email or messaging channel.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryScheduleExpression rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Expression' ;
    rdfs:comment 'Cron expression or named cadence value defining when the report should be delivered (e.g., 0 8 * * MON for weekly Monday 8am, or daily, weekly, monthly).' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryScheduleType rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Type' ;
    rdfs:comment 'Type of scheduling mechanism used for report delivery: cron expression, named cadence, on-demand, or event-triggered.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimezone rdf:type rdf:Property ;
    rdfs:label 'Delivery Timezone' ;
    rdfs:comment 'Timezone in which the delivery schedule should be interpreted (e.g., America/New_York, UTC). IANA timezone identifier.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedDeliveryCount rdf:type rdf:Property ;
    rdfs:label 'Failed Delivery Count' ;
    rdfs:comment 'Total number of failed delivery attempts for this subscription due to errors or unavailability.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:filterParametersJson rdf:type rdf:Property ;
    rdfs:label 'Filter Parameters Json' ;
    rdfs:comment 'JSON-encoded string containing the filter parameters applied to the report or dashboard for this subscription (e.g., store region, date range, product category).' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:includeEmptyResultsFlag rdf:type rdf:Property ;
    rdfs:label 'Include Empty Results Flag' ;
    rdfs:comment 'Boolean flag indicating whether the report should be delivered even when the result set is empty or contains no data.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSharedSubscription rdf:type rdf:Property ;
    rdfs:label 'Is Shared Subscription' ;
    rdfs:comment 'Boolean flag indicating whether this subscription is shared with multiple users or teams versus being a personal subscription.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Delivery Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful delivery of the report or dashboard to the subscriber.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastFailureReason rdf:type rdf:Property ;
    rdfs:label 'Last Failure Reason' ;
    rdfs:comment 'Description or error message from the most recent failed delivery attempt, used for troubleshooting and support.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDeliveryAttempts rdf:type rdf:Property ;
    rdfs:label 'Max Delivery Attempts' ;
    rdfs:comment 'Maximum number of retry attempts allowed for failed deliveries before the subscription is automatically paused or cancelled.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextScheduledDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Delivery Timestamp' ;
    rdfs:comment 'Timestamp when the next report delivery is scheduled to occur based on the delivery schedule.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationOnFailureFlag rdf:type rdf:Property ;
    rdfs:label 'Notification On Failure Flag' ;
    rdfs:comment 'Boolean flag indicating whether the subscriber should be notified when a delivery attempt fails.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outputFormat rdf:type rdf:Property ;
    rdfs:label 'Output Format' ;
    rdfs:comment 'File format in which the report or dashboard will be rendered and delivered to the subscriber.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Priority level assigned to this subscription for delivery queue management and resource allocation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionEndDate rdf:type rdf:Property ;
    rdfs:label 'Subscription End Date' ;
    rdfs:comment 'Date when the subscription expires and report deliveries should cease. Nullable for open-ended subscriptions.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionName rdf:type rdf:Property ;
    rdfs:label 'Subscription Name' ;
    rdfs:comment 'User-defined name or label for this subscription to help identify it among multiple subscriptions.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionStartDate rdf:type rdf:Property ;
    rdfs:label 'Subscription Start Date' ;
    rdfs:comment 'Date when the subscription becomes active and report deliveries should begin.' ;
    rdfs:domain ind:ReportSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Subscription Status' ;
    rdfs:comment 'Current lifecycle status of the subscription indicating whether it is actively delivering reports or has been paused, cancelled, or expired.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributesJson rdf:type rdf:Property ;
    rdfs:label 'Attributes Json' ;
    rdfs:comment 'JSON-formatted string containing hierarchy-type-specific attributes that do not warrant dedicated columns. For example, geographic hierarchies may include latitude/longitude; merchandise hierarchies may include buyer name; organizational hierarchies may include square footage. Provides extensibility without schema changes.' ;
    rdfs:domain ind:ReportingHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSystemCode rdf:type rdf:Property ;
    rdfs:label 'External System Code' ;
    rdfs:comment 'Identifier for this hierarchy node in the source operational system (e.g., SAP S/4HANA cost center, Oracle Retail location code, MDM golden record ID). Used for data lineage and reconciliation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSystemName rdf:type rdf:Property ;
    rdfs:label 'External System Name' ;
    rdfs:comment 'Name of the source operational system that owns this hierarchy node (e.g., SAP S/4HANA, Oracle Retail Merchandising System, Informatica MDM). Used for data lineage and troubleshooting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyName rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Name' ;
    rdfs:comment 'Business name of the reporting hierarchy structure (e.g., Store Geographic Hierarchy, Merchandise Category Hierarchy, Channel Hierarchy).' ;
    rdfs:domain ind:ReportingHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Type' ;
    rdfs:comment 'Classification of the hierarchy structure. Organizational hierarchies represent corporate structure (banner/division/region/district/store). Geographic hierarchies represent location rollups (country/state/city/postal). Merchandise hierarchies represent product categorization (department/category/subcategory/class). Channel hierarchies represent sales channel groupings (omnichannel/online/store/mobile). Financial hierarchies represent cost center and profit center rollups. Customer segment hierarchies represent customer classification structures.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Last Updated By' ;
    rdfs:comment 'User ID or system identifier that last modified this hierarchy node record. Used for audit trail and change tracking.' ;
    rdfs:domain ind:ReportingHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leafNodeFlag rdf:type rdf:Property ;
    rdfs:label 'Leaf Node Flag' ;
    rdfs:comment 'Indicates whether this node is a leaf (terminal) node with no children. True for leaf nodes (e.g., individual stores, SKUs), False for parent/aggregate nodes. Used to control drill-down behavior in dashboards.' ;
    rdfs:domain ind:ReportingHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:levelName rdf:type rdf:Property ;
    rdfs:label 'Level Name' ;
    rdfs:comment 'Business name for this hierarchy level (e.g., Banner, Region, District, Store for organizational hierarchy; Department, Category, Subcategory, Class for merchandise hierarchy). Provides semantic meaning to level_number.' ;
    rdfs:domain ind:ReportingHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:levelNumber rdf:type rdf:Property ;
    rdfs:label 'Level Number' ;
    rdfs:comment 'Numeric position of this node within the hierarchy depth. Root level is 1, immediate children are 2, etc. Used for level-based aggregation and drill-down control in BI tools.' ;
    rdfs:domain ind:ReportingHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nodeDescription rdf:type rdf:Property ;
    rdfs:label 'Node Description' ;
    rdfs:comment 'Detailed description of the hierarchy node, including scope, coverage, and business purpose. Provides context for reporting users.' ;
    rdfs:domain ind:ReportingHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeIdentifier rdf:type rdf:Property ;
    rdfs:label 'Node Identifier' ;
    rdfs:comment 'Business identifier for this specific node within the hierarchy. May be a store number, department code, region code, or other business key depending on hierarchy type. Used for drill-down and roll-up navigation in OLAP reporting.' ;
    rdfs:domain ind:ReportingHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Human-readable display name for this hierarchy node (e.g., Northeast Region, Electronics Department, Store #1234, E-Commerce Channel).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeOwner rdf:type rdf:Property ;
    rdfs:label 'Node Owner' ;
    rdfs:comment 'Business owner or responsible party for this hierarchy node (e.g., Regional VP, Category Manager, Channel Director). Used for governance and accountability in KPI reporting.' ;
    rdfs:domain ind:ReportingHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodePath rdf:type rdf:Property ;
    rdfs:label 'Node Path' ;
    rdfs:comment 'Full hierarchical path from root to this node, typically delimited (e.g., /Banner/Region/District/Store or Department>Category>Subcategory). Enables fast ancestor and descendant queries without recursive joins.' ;
    rdfs:domain ind:ReportingHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeStatus rdf:type rdf:Property ;
    rdfs:label 'Node Status' ;
    rdfs:comment 'Current lifecycle status of the hierarchy node. Active nodes are used in current reporting. Inactive nodes are historical. Pending nodes are scheduled for future activation. Deprecated nodes are being phased out. Merged nodes have been consolidated into another node.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentNodeIdentifier rdf:type rdf:Property ;
    rdfs:label 'Parent Node Identifier' ;
    rdfs:comment 'Business identifier of the parent node in the hierarchy. Null for root nodes. Enables recursive roll-up aggregation of KPIs and metrics from child to parent levels.' ;
    rdfs:domain ind:ReportingHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCalendarType rdf:type rdf:Property ;
    rdfs:label 'Reporting Calendar Type' ;
    rdfs:comment 'Calendar convention used for period-based reporting at this hierarchy node. Gregorian for standard calendar. Retail 4-5-4 and 4-4-5 for NRF retail calendar. Fiscal for custom fiscal periods. Enables consistent period comparisons and comp sales calculations.' ;
    rdfs:domain ind:ReportingHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollupMethod rdf:type rdf:Property ;
    rdfs:label 'Rollup Method' ;
    rdfs:comment 'Default aggregation method for rolling up metrics from child nodes to this parent node. Sum for additive metrics (sales, units). Average for rates and percentages. Weighted_average for metrics requiring weighting (average selling price). None for non-aggregatable dimensions. [ENUM-REF-CANDIDATE: sum|average|weighted_average|min|max|count|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReportingHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootNodeFlag rdf:type rdf:Property ;
    rdfs:label 'Root Node Flag' ;
    rdfs:comment 'Indicates whether this node is the root (top-level) node of the hierarchy. True for root nodes (e.g., Total Company, All Products), False for all other nodes.' ;
    rdfs:domain ind:ReportingHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric value controlling the display sequence of sibling nodes at the same hierarchy level. Lower values appear first. Used to control presentation order in reports and dashboards.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for this hierarchy node (e.g., America/New_York, America/Los_Angeles). Used for time-based reporting and comp sales calculations across geographic regions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarDate rdf:type rdf:Property ;
    rdfs:label 'Calendar Date' ;
    rdfs:comment 'The Gregorian calendar date represented by this record. Serves as the natural business key for date-based joins and filtering.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calendarDayOfMonth rdf:type rdf:Property ;
    rdfs:label 'Calendar Day Of Month' ;
    rdfs:comment 'The day of the month in the Gregorian calendar (1-31). Used for day-of-month pattern analysis and billing cycle alignment.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarDayOfYear rdf:type rdf:Property ;
    rdfs:label 'Calendar Day Of Year' ;
    rdfs:comment 'The day number within the Gregorian calendar year (1-365 or 1-366). Supports calendar year-to-date calculations.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarMonth rdf:type rdf:Property ;
    rdfs:label 'Calendar Month' ;
    rdfs:comment 'The Gregorian calendar month number (1-12). Enables calendar-month aggregations and seasonality analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarQuarter rdf:type rdf:Property ;
    rdfs:label 'Calendar Quarter' ;
    rdfs:comment 'The Gregorian calendar quarter (1-4). Supports calendar-based quarterly analysis and external benchmarking.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarYear rdf:type rdf:Property ;
    rdfs:label 'Calendar Year' ;
    rdfs:comment 'The Gregorian calendar year (YYYY). Used for calendar-year reporting and external regulatory filings.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:comparableDatePriorYear rdf:type rdf:Property ;
    rdfs:label 'Comparable Date Prior Year' ;
    rdfs:comment 'The corresponding date in the prior fiscal year for year-over-year comparable sales (comp sales) analysis. Accounts for fiscal calendar shifts.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:comparableWeekPriorYear rdf:type rdf:Property ;
    rdfs:label 'Comparable Week Prior Year' ;
    rdfs:comment 'The fiscal week number in the prior year that corresponds to this date for week-over-week year-over-year analysis.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dayAbbreviation rdf:type rdf:Property ;
    rdfs:label 'Day Abbreviation' ;
    rdfs:comment 'The three-letter abbreviation for the day of the week. Used for compact display in dashboards and reports. [ENUM-REF-CANDIDATE: Mon|Tue|Wed|Thu|Fri|Sat|Sun — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dayName rdf:type rdf:Property ;
    rdfs:label 'Day Name' ;
    rdfs:comment 'The full name of the day of the week. Provides human-readable day identification for reporting and visualization. [ENUM-REF-CANDIDATE: Monday|Tuesday|Wednesday|Thursday|Friday|Saturday|Sunday — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalDayOfPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Day Of Period' ;
    rdfs:comment 'The day number within the current fiscal period. Supports daily sales tracking and period-to-date performance analysis.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalDayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Fiscal Day Of Week' ;
    rdfs:comment 'The day number within the fiscal week (1-7). Used for day-of-week sales pattern analysis and staffing optimization.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalDayOfYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Day Of Year' ;
    rdfs:comment 'The day number within the fiscal year (1-364 or 1-371). Enables year-to-date calculations and trend analysis.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period End Date' ;
    rdfs:comment 'The end date of the fiscal period (month) to which this date belongs. Supports monthly close processes and period-end reporting.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Start Date' ;
    rdfs:comment 'The start date of the fiscal period (month) to which this date belongs. Enables period boundary identification and period-to-date calculations.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter number within the fiscal year (1-4). Used for quarterly financial reporting and planning cycles.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalWeek rdf:type rdf:Property ;
    rdfs:label 'Fiscal Week' ;
    rdfs:comment 'The fiscal week number within the fiscal year (1-52 or 1-53). Follows the retail 4-5-4 or 4-4-5 week structure for consistent period comparisons.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalWeekEndDate rdf:type rdf:Property ;
    rdfs:label 'Fiscal Week End Date' ;
    rdfs:comment 'The end date of the fiscal week to which this date belongs. Supports weekly reporting cycles and week-end inventory snapshots.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalWeekOfPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Week Of Period' ;
    rdfs:comment 'The week number within the current fiscal period (1-4 or 1-5). Enables week-level analysis within monthly periods following 4-5-4 structure.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalWeekStartDate rdf:type rdf:Property ;
    rdfs:label 'Fiscal Week Start Date' ;
    rdfs:comment 'The start date of the fiscal week to which this date belongs. Enables week boundary identification and week-to-date calculations.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalYearEndDate rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Date' ;
    rdfs:comment 'The end date of the fiscal year to which this date belongs. Supports fiscal year-end reporting and planning cycles.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalYearStartDate rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Start Date' ;
    rdfs:comment 'The start date of the fiscal year to which this date belongs. Enables fiscal year boundary identification and year-to-date calculations.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holidayName rdf:type rdf:Property ;
    rdfs:label 'Holiday Name' ;
    rdfs:comment 'The name of the holiday if the date is a recognized retail holiday. Null for non-holiday dates. Enables holiday-specific performance tracking.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:is53WeekYear rdf:type rdf:Property ;
    rdfs:label 'Is 53 Week Year' ;
    rdfs:comment 'Boolean flag indicating whether the fiscal year contains 53 weeks instead of the standard 52. Occurs approximately every 5-6 years in 4-5-4 calendars.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBackToSchoolPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Back To School Period' ;
    rdfs:comment 'Boolean flag indicating whether the date falls within the back-to-school shopping period. Drives seasonal merchandising and promotional planning.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBlackFridayWeek rdf:type rdf:Property ;
    rdfs:label 'Is Black Friday Week' ;
    rdfs:comment 'Boolean flag indicating whether the date falls within the Black Friday promotional week. Critical for peak season planning and analysis.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCurrentDate rdf:type rdf:Property ;
    rdfs:label 'Is Current Date' ;
    rdfs:comment 'Boolean flag indicating whether this record represents today\'s date. Updated daily to support current-date filtering in reports.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCyberMondayWeek rdf:type rdf:Property ;
    rdfs:label 'Is Cyber Monday Week' ;
    rdfs:comment 'Boolean flag indicating whether the date falls within the Cyber Monday promotional week. Supports digital commerce peak event analysis.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHoliday rdf:type rdf:Property ;
    rdfs:label 'Is Holiday' ;
    rdfs:comment 'Boolean flag indicating whether the date is a recognized retail holiday. Supports holiday sales analysis and staffing planning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHolidayShoppingPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Holiday Shopping Period' ;
    rdfs:comment 'Boolean flag indicating whether the date falls within the November-December holiday shopping season. Critical for peak season resource planning.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeapYear rdf:type rdf:Property ;
    rdfs:label 'Is Leap Year' ;
    rdfs:comment 'Boolean flag indicating whether the calendar year is a leap year (366 days). Used for year-over-year normalization in analytics.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWeekday rdf:type rdf:Property ;
    rdfs:label 'Is Weekday' ;
    rdfs:comment 'Boolean flag indicating whether the date falls on a weekday (Monday through Friday). Used for weekday traffic and sales pattern analysis.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWeekend rdf:type rdf:Property ;
    rdfs:label 'Is Weekend' ;
    rdfs:comment 'Boolean flag indicating whether the date falls on a weekend (Saturday or Sunday). Used for weekend vs weekday sales analysis.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoWeek rdf:type rdf:Property ;
    rdfs:label 'Iso Week' ;
    rdfs:comment 'The ISO 8601 week number (1-53). Provides standardized week numbering for international reporting and cross-industry comparisons.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isoYear rdf:type rdf:Property ;
    rdfs:label 'Iso Year' ;
    rdfs:comment 'The ISO 8601 week-numbering year. May differ from Gregorian year for dates in the first or last week of the year.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monthAbbreviation rdf:type rdf:Property ;
    rdfs:label 'Month Abbreviation' ;
    rdfs:comment 'The three-letter abbreviation for the calendar month. Used for compact display in dashboards and reports. [ENUM-REF-CANDIDATE: Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec — promote to reference product]' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthName rdf:type rdf:Property ;
    rdfs:label 'Month Name' ;
    rdfs:comment 'The full name of the calendar month. Provides human-readable month identification for reporting. [ENUM-REF-CANDIDATE: January|February|March|April|May|June|July|August|September|October|November|December — promote to reference product]' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:season rdf:type rdf:Property ;
    rdfs:label 'Season' ;
    rdfs:comment 'The retail merchandising season designation (Spring/Summer, Fall/Winter). Drives seasonal assortment planning and promotional strategies.' ;
    rdfs:domain ind:RetailCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selfServiceQueryId rdf:type rdf:Property ;
    rdfs:label 'Self Service Query Id' ;
    rdfs:comment 'Unique identifier for the self-service query execution record.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionId rdf:type rdf:Property ;
    rdfs:label 'Session Id' ;
    rdfs:comment 'The user session identifier associated with the query execution, used to group queries within a single user session.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WebSession .

ind:workspaceId rdf:type rdf:Property ;
    rdfs:label 'Workspace Id' ;
    rdfs:comment 'The workspace or project identifier where the query was executed, used for organizational segmentation.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Workspace .

ind:accessGrantedByPolicy rdf:type rdf:Property ;
    rdfs:label 'Access Granted By Policy' ;
    rdfs:comment 'The data access policy or permission rule that granted the user access to execute this query.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aggregationFunctions rdf:type rdf:Property ;
    rdfs:label 'Aggregation Functions' ;
    rdfs:comment 'The aggregation functions used in the query (e.g., SUM, AVG, COUNT, MAX, MIN), captured for complexity analysis.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biTool rdf:type rdf:Property ;
    rdfs:label 'Bi Tool' ;
    rdfs:comment 'The BI or analytics tool used to execute the query (e.g., Tableau, Power BI, Databricks SQL, Looker). [ENUM-REF-CANDIDATE: tableau|power_bi|databricks_sql|looker|qlik|thoughtspot|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cacheHit rdf:type rdf:Property ;
    rdfs:label 'Cache Hit' ;
    rdfs:comment 'Flag indicating whether the query results were served from cache rather than re-executed.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:computeCostUsd rdf:type rdf:Property ;
    rdfs:label 'Compute Cost Usd' ;
    rdfs:comment 'The estimated compute cost in USD for executing the query, used for cost attribution and chargeback.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataScannedBytes rdf:type rdf:Property ;
    rdfs:label 'Data Scanned Bytes' ;
    rdfs:comment 'The total volume of data scanned during query execution, measured in bytes.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'The error message or exception details if the query failed or encountered issues during execution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportFormat rdf:type rdf:Property ;
    rdfs:label 'Export Format' ;
    rdfs:comment 'The file format used if the query results were exported: CSV, Excel, PDF, JSON, Parquet, or none if not exported.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filterCriteria rdf:type rdf:Property ;
    rdfs:label 'Filter Criteria' ;
    rdfs:comment 'The filter or WHERE clause criteria applied by the user in the query, captured for usage pattern analysis.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:joinCount rdf:type rdf:Property ;
    rdfs:label 'Join Count' ;
    rdfs:comment 'The number of table joins performed in the query, used to assess query complexity.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:queryComplexityScore rdf:type rdf:Property ;
    rdfs:label 'Query Complexity Score' ;
    rdfs:comment 'A calculated score representing the complexity of the query based on joins, aggregations, subqueries, and data volume.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:queryDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Query Duration Seconds' ;
    rdfs:comment 'The total execution time of the query in seconds, from submission to completion.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:queryName rdf:type rdf:Property ;
    rdfs:label 'Query Name' ;
    rdfs:comment 'User-assigned name or title for the query, used for identification and reuse.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryOptimizationApplied rdf:type rdf:Property ;
    rdfs:label 'Query Optimization Applied' ;
    rdfs:comment 'Flag indicating whether automatic query optimization or rewrite was applied by the query engine.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:queryPurpose rdf:type rdf:Property ;
    rdfs:label 'Query Purpose' ;
    rdfs:comment 'The business purpose or use case for the query: ad-hoc analysis, reporting, dashboard refresh, data exploration, model training, or data quality check.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryStatus rdf:type rdf:Property ;
    rdfs:label 'Query Status' ;
    rdfs:comment 'The execution status of the query: success, failed, timeout, cancelled by user, or partial results.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryText rdf:type rdf:Property ;
    rdfs:label 'Query Text' ;
    rdfs:comment 'The full SQL or semantic query definition executed by the user. May be SQL, natural language, or semantic layer query syntax.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryType rdf:type rdf:Property ;
    rdfs:label 'Query Type' ;
    rdfs:comment 'The type or format of the query executed: SQL, semantic layer query, natural language, visual query builder, or saved query reference.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultSetSizeMb rdf:type rdf:Property ;
    rdfs:label 'Result Set Size Mb' ;
    rdfs:comment 'The size of the query result set in megabytes, used for performance and storage analysis.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rowsReturned rdf:type rdf:Property ;
    rdfs:label 'Rows Returned' ;
    rdfs:comment 'The number of rows returned by the query execution.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:savedQueryFlag rdf:type rdf:Property ;
    rdfs:label 'Saved Query Flag' ;
    rdfs:comment 'Flag indicating whether the user saved this query for future reuse.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sharedFlag rdf:type rdf:Property ;
    rdfs:label 'Shared Flag' ;
    rdfs:comment 'Flag indicating whether the query or its results were shared with other users.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetDataProduct rdf:type rdf:Property ;
    rdfs:label 'Target Data Product' ;
    rdfs:comment 'The specific data product or table accessed by the query within the target domain.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userDepartment rdf:type rdf:Property ;
    rdfs:label 'User Department' ;
    rdfs:comment 'The department or business unit of the user who executed the query, used for usage segmentation and cost allocation.' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userRole rdf:type rdf:Property ;
    rdfs:label 'User Role' ;
    rdfs:comment 'The role or job function of the user who executed the query (e.g., analyst, manager, data scientist, executive).' ;
    rdfs:domain ind:SelfServiceQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyProgramId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Id' ;
    rdfs:comment 'Foreign key linking to loyalty.loyalty_program. Business justification: Semantic entities for loyalty reporting (member_summary, points_activity, tier_movement) are scoped to specific loyalty programs in multi-program retailers. Semantic layer needs program context for co' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyProgram .

ind:replacementEntitySemanticLayerEntityId rdf:type rdf:Property ;
    rdfs:label 'Replacement Entity Semantic Layer Entity Id' ;
    rdfs:comment 'Foreign key reference to the semantic layer entity that replaces this deprecated entity. Null for active entities or deprecated entities without a direct replacement.' ;
    rdfs:domain ind:SemanticLayerEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SemanticLayerEntity .

ind:calculationLogic rdf:type rdf:Property ;
    rdfs:label 'Calculation Logic' ;
    rdfs:comment 'Detailed description or pseudocode of the calculation logic used to derive this semantic entity, if applicable. For metrics and derived entities, documents the formula, aggregation method, filters, and business rules applied.' ;
    rdfs:domain ind:SemanticLayerEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedStatus rdf:type rdf:Property ;
    rdfs:label 'Certified Status' ;
    rdfs:comment 'Certification status indicating the trustworthiness and approval level of this semantic entity. Certified = production-approved for enterprise reporting; Provisional = available but not yet fully validated; Deprecated = scheduled for retirement; Draft = under development.' ;
    rdfs:domain ind:SemanticLayerEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionTier rdf:type rdf:Property ;
    rdfs:label 'Consumption Tier' ;
    rdfs:comment 'Access tier defining who can consume this semantic entity. Self-service = available to all business users; Governed = requires approval or training; Restricted = limited to specific roles or compliance-cleared users.' ;
    rdfs:domain ind:SemanticLayerEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprecationReason rdf:type rdf:Property ;
    rdfs:label 'Deprecation Reason' ;
    rdfs:comment 'Explanation of why this semantic entity was deprecated, if applicable. Includes migration guidance and references to replacement entities. Null for active entities.' ;
    rdfs:domain ind:SemanticLayerEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityLabel rdf:type rdf:Property ;
    rdfs:label 'Entity Label' ;
    rdfs:comment 'Business-friendly display label for the semantic layer entity, used in reports and dashboards. Human-readable name that business users will recognize (e.g., \'Customer 360 View\', \'Store Performance Metrics\', \'Inventory Health\').' ;
    rdfs:domain ind:SemanticLayerEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityName rdf:type rdf:Property ;
    rdfs:label 'Entity Name' ;
    rdfs:comment 'Technical name of the semantic layer entity as defined in the BI tool or semantic layer platform (e.g., LookML model name, dbt semantic model name, Unity Catalog metric name). Must be unique within the semantic layer namespace.' ;
    rdfs:domain ind:SemanticLayerEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the semantic layer entity type. Dimension = descriptive attribute for slicing/dicing; Measure = quantitative metric; Metric = calculated KPI; Fact = transactional event; Aggregate = pre-aggregated summary; Derived = computed from other entities.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grainDefinition rdf:type rdf:Property ;
    rdfs:label 'Grain Definition' ;
    rdfs:comment 'Textual description of the grain (level of detail) of this semantic entity. Defines what one row represents (e.g., \'One row per customer\', \'One row per store per day\', \'One row per SKU per transaction\'). Critical for correct join and aggregation logic.' ;
    rdfs:domain ind:SemanticLayerEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFinancialFlag rdf:type rdf:Property ;
    rdfs:label 'Is Financial Flag' ;
    rdfs:comment 'Boolean flag indicating whether this semantic entity contains financial data subject to SOX, FASB, or other financial reporting standards. True if entity includes revenue, cost, profit, or other P&L components.' ;
    rdfs:domain ind:SemanticLayerEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPiiFlag rdf:type rdf:Property ;
    rdfs:label 'Is Pii Flag' ;
    rdfs:comment 'Boolean flag indicating whether this semantic entity contains or exposes PII data. True if any underlying attributes include customer names, emails, phone numbers, addresses, or other personal identifiers. Used for access control and compliance reporting.' ;
    rdfs:domain ind:SemanticLayerEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platformObjectCode rdf:type rdf:Property ;
    rdfs:label 'Platform Object Code' ;
    rdfs:comment 'Native identifier or URI of this entity within the semantic layer platform (e.g., Looker explore ID, dbt model unique_id, Unity Catalog full path). Used for deep linking and platform-specific integrations.' ;
    rdfs:domain ind:SemanticLayerEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformType rdf:type rdf:Property ;
    rdfs:label 'Platform Type' ;
    rdfs:comment 'The BI or semantic layer platform where this entity is defined and exposed (e.g., Looker LookML, dbt Semantic Layer, Databricks Unity Catalog, Tableau Data Model). [ENUM-REF-CANDIDATE: looker|dbt|tableau|power_bi|databricks_unity_catalog|thoughtspot|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SemanticLayerEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedKpiDefinitions rdf:type rdf:Property ;
    rdfs:label 'Related Kpi Definitions' ;
    rdfs:comment 'Comma-separated list of KPI definition IDs or names that reference or depend on this semantic entity. Establishes lineage between semantic entities and enterprise KPIs.' ;
    rdfs:domain ind:SemanticLayerEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleQuery rdf:type rdf:Property ;
    rdfs:label 'Sample Query' ;
    rdfs:comment 'Example SQL or platform-specific query demonstrating how to use this semantic entity. Helps business users understand proper usage patterns and join logic.' ;
    rdfs:domain ind:SemanticLayerEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underlyingTableReference rdf:type rdf:Property ;
    rdfs:label 'Underlying Table Reference' ;
    rdfs:comment 'Fully qualified name of the underlying physical table or view in the lakehouse that this semantic entity is built upon (e.g., \'silver.customer.profile\', \'gold.sales.daily_aggregates\'). References the source data product in the Silver or Gold layer.' ;
    rdfs:domain ind:SemanticLayerEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uniqueUserCountLast30Days rdf:type rdf:Property ;
    rdfs:label 'Unique User Count Last 30 Days' ;
    rdfs:comment 'Number of distinct users who accessed this semantic entity in the last 30 days. Measures adoption breadth across the organization.' ;
    rdfs:domain ind:SemanticLayerEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageCountLast30Days rdf:type rdf:Property ;
    rdfs:label 'Usage Count Last 30 Days' ;
    rdfs:comment 'Number of times this semantic entity was queried or used in reports/dashboards in the last 30 days. Indicates popularity and business value of the entity.' ;
    rdfs:domain ind:SemanticLayerEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version identifier for this semantic entity definition. Incremented when calculation logic, grain, or structure changes. Supports change tracking and backward compatibility.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceStrategyId rdf:type rdf:Property ;
    rdfs:label 'Price Strategy Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_strategy. Business justification: Pricing strategy effectiveness metrics (EDLP vs Hi-Lo performance, strategy ROI, competitive index achievement) must reference the strategy being measured. Enables strategy performance reporting. Real' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceStrategy .

ind:alertThresholdLower rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Lower' ;
    rdfs:comment 'Lower boundary value that triggers an automated alert or exception notification when the metric falls below this threshold, indicating potential business issue or opportunity.' ;
    rdfs:domain ind:SemanticMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alertThresholdUpper rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Upper' ;
    rdfs:comment 'Upper boundary value that triggers an automated alert or exception notification when the metric exceeds this threshold, indicating potential business issue or opportunity.' ;
    rdfs:domain ind:SemanticMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Measure' ;
    rdfs:comment 'The foundational data element or fact table measure that serves as the primary input to the metric calculation (e.g., sales_amount, inventory_units, transaction_count).' ;
    rdfs:domain ind:SemanticMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Benchmark Available Flag' ;
    rdfs:comment 'Indicates whether external industry benchmark data is available for this metric to enable competitive performance comparison (True) or not (False).' ;
    rdfs:domain ind:SemanticMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculationExpression rdf:type rdf:Property ;
    rdfs:label 'Calculation Expression' ;
    rdfs:comment 'The technical calculation logic expressed in SQL, dbt metric syntax, or semantic layer DSL that defines how the metric is computed from base measures.' ;
    rdfs:domain ind:SemanticMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationLayer rdf:type rdf:Property ;
    rdfs:label 'Calculation Layer' ;
    rdfs:comment 'The lakehouse medallion layer at which this metric is calculated: bronze (raw), silver (cleansed), gold (aggregated), semantic (business logic applied).' ;
    rdfs:domain ind:SemanticMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedBy rdf:type rdf:Property ;
    rdfs:label 'Certified By' ;
    rdfs:comment 'Name or identifier of the data steward, business owner, or governance committee member who certified this metric definition for production use.' ;
    rdfs:domain ind:SemanticMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Certified Timestamp' ;
    rdfs:comment 'Date and time when the metric definition was officially certified and approved for enterprise reporting and analytics.' ;
    rdfs:domain ind:SemanticMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dashboardCount rdf:type rdf:Property ;
    rdfs:label 'Dashboard Count' ;
    rdfs:comment 'Number of active BI dashboards and reports that currently consume this metric, used to assess impact of definition changes.' ;
    rdfs:domain ind:SemanticMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSourceTable rdf:type rdf:Property ;
    rdfs:label 'Data Source Table' ;
    rdfs:comment 'The primary fact table or data product in the lakehouse silver layer from which the base measure is sourced (e.g., sales_transaction, inventory_snapshot, order_line).' ;
    rdfs:domain ind:SemanticMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decimalPrecision rdf:type rdf:Property ;
    rdfs:label 'Decimal Precision' ;
    rdfs:comment 'Number of decimal places to display for the metric value in reports and dashboards (e.g., 2 for currency, 1 for percentages, 0 for counts).' ;
    rdfs:domain ind:SemanticMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dimensionList rdf:type rdf:Property ;
    rdfs:label 'Dimension List' ;
    rdfs:comment 'Comma-separated list of dimension attributes by which this metric can be sliced and analyzed (e.g., store, product_category, customer_segment, channel).' ;
    rdfs:domain ind:SemanticMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricCode rdf:type rdf:Property ;
    rdfs:label 'Metric Code' ;
    rdfs:comment 'Short alphanumeric code or abbreviation used to reference the metric in technical systems and data models (e.g., GM_PCT, STR, GMROI, ATV).' ;
    rdfs:domain ind:SemanticMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricName rdf:type rdf:Property ;
    rdfs:label 'Metric Name' ;
    rdfs:comment 'The canonical business name of the metric as it appears in BI tools and reports (e.g., Gross Margin Percent, Sell-Through Rate, GMROI, Average Transaction Value).' ;
    rdfs:domain ind:SemanticMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricType rdf:type rdf:Property ;
    rdfs:label 'Metric Type' ;
    rdfs:comment 'Classification of the metric calculation pattern: simple (direct measure), ratio (numerator/denominator), derived (formula from multiple measures), cumulative (running total), compound (nested calculations).' ;
    rdfs:domain ind:SemanticMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trendDirectionIndicator rdf:type rdf:Property ;
    rdfs:label 'Trend Direction Indicator' ;
    rdfs:comment 'Defines the desired direction of metric movement for positive business performance: higher_is_better (e.g., sales, margin), lower_is_better (e.g., shrinkage, cost), target_is_optimal (e.g., inventory weeks of supply).' ;
    rdfs:domain ind:SemanticMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScheduleId rdf:type rdf:Property ;
    rdfs:label 'Audit Schedule Id' ;
    rdfs:comment 'Reference to the originating audit schedule that triggered this audit event execution.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditSchedule .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Foreign key linking to supplier.vendor. Business justification: Supplier audits (factory inspections, food safety, social compliance) are conducted at vendor facilities. Audit results drive vendor scorecards, approval status, and purchase order decisions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'The date on which the audit was conducted or is scheduled to be conducted. Principal business event timestamp for the audit execution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditDurationHours rdf:type rdf:Property ;
    rdfs:label 'Audit Duration Hours' ;
    rdfs:comment 'Total duration of the audit execution in hours, calculated from start to end timestamp.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit End Timestamp' ;
    rdfs:comment 'Precise timestamp when the audit execution was completed at the audited location.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditMethod rdf:type rdf:Property ;
    rdfs:label 'Audit Method' ;
    rdfs:comment 'Method by which the audit was conducted: on-site physical inspection, remote virtual audit, hybrid combination, or document review only.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Externally-known unique business identifier for the audit event, used for regulatory reporting and cross-system tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReportUrl rdf:type rdf:Property ;
    rdfs:label 'Audit Report Url' ;
    rdfs:comment 'URL or file path to the complete audit report document stored in the document management system.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditResult rdf:type rdf:Property ;
    rdfs:label 'Audit Result' ;
    rdfs:comment 'Overall outcome of the audit event: pass (full compliance), conditional pass (minor findings requiring follow-up), fail (critical non-compliance), or not applicable.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the areas, processes, and systems covered by this audit event (e.g., receiving area, cold storage, POS terminals, employee records).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScore rdf:type rdf:Property ;
    rdfs:label 'Audit Score' ;
    rdfs:comment 'Numerical score representing the overall compliance level achieved during the audit, typically expressed as a percentage (0.00 to 100.00).' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the audit execution began at the audited location.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit event execution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Audit Team Members' ;
    rdfs:comment 'Comma-separated list of additional auditor names who participated in the audit execution alongside the lead auditor.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit based on regulatory domain: food safety (FDA/FSMA), workplace safety (OSHA), payment security (PCI-DSS), data privacy (GDPR/CCPA), environmental compliance, or quality assurance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditeeSignature rdf:type rdf:Property ;
    rdfs:label 'Auditee Signature' ;
    rdfs:comment 'Digital signature or signature capture data from the location manager or responsible party acknowledging receipt of audit findings.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorSignature rdf:type rdf:Property ;
    rdfs:label 'Auditor Signature' ;
    rdfs:comment 'Digital signature or signature capture data from the lead auditor certifying the accuracy and completeness of the audit report.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the external certification or accreditation body if this audit was conducted by or on behalf of a third-party certifier (e.g., NSF, SGS, Bureau Veritas, QSA firm).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Required Flag' ;
    rdfs:comment 'Indicates whether a formal Corrective Action Plan must be submitted by the audited location in response to findings.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of critical or major non-conformances identified that pose immediate risk to compliance, safety, or business operations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executiveSummary rdf:type rdf:Property ;
    rdfs:label 'Executive Summary' ;
    rdfs:comment 'High-level summary of audit findings, key observations, and overall compliance status for executive reporting and dashboard purposes.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Target date by which corrective actions must be completed and verified for findings identified in this audit.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required Flag' ;
    rdfs:comment 'Indicates whether corrective actions and follow-up audit activities are required based on the findings from this audit event.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadAuditorCredentials rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Credentials' ;
    rdfs:comment 'Professional certifications and credentials held by the lead auditor (e.g., Certified Food Safety Auditor, OSHA 30-Hour, PCI QSA, CISA).' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor who conducted the audit, captured for regulatory reporting and audit trail purposes.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of major non-conformances identified that represent significant deviations from compliance requirements but do not pose immediate critical risk.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of minor non-conformances or observations identified that represent opportunities for improvement but do not constitute significant compliance violations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Specific regulatory standard, framework, or compliance program against which this audit was conducted (e.g., FDA FSMA, OSHA 29 CFR 1910, PCI DSS v4.0, GDPR Article 32).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date on which regulatory authorities were notified of critical findings from this audit, if applicable.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required Flag' ;
    rdfs:comment 'Indicates whether critical findings from this audit require mandatory notification to regulatory authorities (FDA, OSHA, PCI Council, data protection authorities).' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of compliance findings (observations, non-conformances, and opportunities for improvement) identified during the audit.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Dc Facility Id' ;
    rdfs:comment 'Reference to the specific distribution center or warehouse where the finding was identified, if applicable. Null for store or corporate findings.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:previousFindingAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Audit Finding Id' ;
    rdfs:comment 'Reference to the previous audit finding record if this is a recurrence. Null if this is the first occurrence.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:primaryAuditAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Audit Associate Id' ;
    rdfs:comment 'Reference to the auditor or inspector who identified and documented this finding. May be internal auditor, third-party auditor, or regulatory inspector.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:tertiaryAuditVerifiedByAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Audit Verified By Associate Id' ;
    rdfs:comment 'Reference to the auditor or compliance officer who verified the corrective action completion. Null if not yet verified.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:affectedArea rdf:type rdf:Property ;
    rdfs:label 'Affected Area' ;
    rdfs:comment 'The business area, department, store location, distribution center, process, or system affected by the finding (e.g., Store #1234 Bakery Department, DC-West Receiving Dock, Payment Processing System, Cold Chain Transport).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingCategory rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Category' ;
    rdfs:comment 'Severity classification of the finding. Critical: immediate risk to safety/compliance; Major: significant non-conformance requiring prompt action; Minor: isolated deficiency; Observation: improvement opportunity without non-conformance.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingDescription rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Description' ;
    rdfs:comment 'Detailed narrative description of the compliance deficiency, observation, or non-conformance identified during the audit. Includes context, evidence, and specific details of what was observed.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Status' ;
    rdfs:comment 'Current lifecycle status of the finding. Open: newly identified; In Remediation: corrective action in progress; Pending Verification: awaiting auditor verification; Closed: resolved and verified; Disputed: under review or appeal.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'The date on which the finding was formally closed after successful verification of corrective action. Null if finding is not yet closed.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:controlReference rdf:type rdf:Property ;
    rdfs:label 'Control Reference' ;
    rdfs:comment 'Specific control number, clause, section, or requirement citation from the regulatory standard that was violated or assessed (e.g., PCI DSS Requirement 3.4, OSHA 1910.22(a)(1), GDPR Article 32(1)(b)).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Detailed description of the corrective action plan developed to address the finding, including specific steps, resources, and timelines.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Indicates whether a formal corrective action plan is required to address this finding. True for critical, major, and most minor findings; False for observations that are advisory only.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The target date by which corrective action must be completed and verified. Driven by regulatory timelines or internal policy based on finding severity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evidenceLocation rdf:type rdf:Property ;
    rdfs:label 'Evidence Location' ;
    rdfs:comment 'File path, document management system reference, or storage location where supporting evidence (photos, documents, logs) for this finding is stored.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated or actual financial impact of the finding, including potential fines, penalties, remediation costs, or lost revenue. Null if not quantified.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:findingNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Number' ;
    rdfs:comment 'Business-facing sequential or hierarchical identifier for the finding within the audit event (e.g., F-001, 2024-Q1-FDA-003). Used for tracking and communication.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'The date on which the finding was identified during the audit event. Represents the real-world observation date.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:photographicEvidenceFlag rdf:type rdf:Property ;
    rdfs:label 'Photographic Evidence Flag' ;
    rdfs:comment 'Indicates whether photographic or video evidence was captured to document the finding. True if evidence exists; False otherwise.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'The date on which this finding was reported to the external regulatory authority, if applicable. Null if not yet reported or reporting not required.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required Flag' ;
    rdfs:comment 'Indicates whether this finding must be reported to an external regulatory body (FDA, OSHA, PCI SSC, state agencies). True if external reporting is mandatory; False otherwise.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryStandard rdf:type rdf:Property ;
    rdfs:label 'Regulatory Standard' ;
    rdfs:comment 'The specific regulatory framework, standard, or compliance program violated or referenced by this finding (e.g., FDA FSMA, OSHA 1910.22, PCI DSS 3.2.1, GDPR Article 32, ISO 9001:2015).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Documented root cause analysis explaining the underlying reason for the deficiency. Completed during corrective action planning to prevent recurrence.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date on which corrective action was verified as complete and effective by the auditor or compliance team. Null if not yet verified.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'The method by which corrective action completion will be verified (e.g., follow-up audit, document review, photographic evidence, system validation, third-party certification).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditChecklistTemplateId rdf:type rdf:Property ;
    rdfs:label 'Audit Checklist Template Id' ;
    rdfs:comment 'Reference to the standardized audit checklist template that will be used for this audit, ensuring consistent evaluation criteria.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditChecklistTemplate .

ind:locationContactId rdf:type rdf:Property ;
    rdfs:label 'Location Contact Id' ;
    rdfs:comment 'Reference to the primary contact person at the audit location (e.g., store manager, DC operations manager) who will facilitate the audit.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:previousAuditAuditScheduleId rdf:type rdf:Property ;
    rdfs:label 'Previous Audit Audit Schedule Id' ;
    rdfs:comment 'Reference to the most recent prior audit of the same type at the same location, enabling trend analysis and follow-up tracking.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditSchedule .

ind:quaternaryAuditConfirmedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Audit Confirmed By User Associate Id' ;
    rdfs:comment 'Reference to the user who confirmed the audit schedule. Typically the compliance coordinator or audit manager.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:tertiaryAuditModifiedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Audit Modified By User Associate Id' ;
    rdfs:comment 'Reference to the user who last modified this audit schedule record. Used for accountability and audit trail.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:advanceNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Advance Notice Days' ;
    rdfs:comment 'The number of days of advance notice provided to the location before the audit. Some audits require surprise inspections (0 days), others require 7-30 days notice.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetCode rdf:type rdf:Property ;
    rdfs:label 'Budget Code' ;
    rdfs:comment 'The financial budget code or cost center to which audit expenses will be charged.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'The date and time when the audit schedule was confirmed by all parties (auditor, location contact, and coordinator). Null until confirmed.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated audit cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'The estimated total cost of conducting the audit, including auditor fees, travel expenses, and internal resource costs. Used for budget planning.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'The estimated number of hours required to complete the audit, based on audit type, scope, and historical data.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'The recurrence pattern for this audit schedule. Regulatory audits often have mandated frequencies (e.g., annual food safety audits, quarterly PCI-DSS scans). [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|semi_annual|annual|biennial|ad_hoc — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFollowUpAudit rdf:type rdf:Property ;
    rdfs:label 'Is Follow Up Audit' ;
    rdfs:comment 'Indicates whether this audit is a follow-up to address findings or corrective actions from a previous audit.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'The date on which the audit notification was sent to stakeholders. Used to track compliance with advance notice requirements.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recurrenceRule rdf:type rdf:Property ;
    rdfs:label 'Recurrence Rule' ;
    rdfs:comment 'Detailed recurrence pattern specification in iCalendar RRULE format or similar, for complex recurring audit schedules (e.g., \'Every first Monday of the quarter\').' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDeadline rdf:type rdf:Property ;
    rdfs:label 'Regulatory Deadline' ;
    rdfs:comment 'The hard deadline by which the audit must be completed to maintain regulatory compliance. Null for non-mandatory audits.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiresSiteAccessApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Site Access Approval' ;
    rdfs:comment 'Indicates whether the auditor requires special site access approval or security clearance to conduct the audit (e.g., for restricted areas, DCs with high-security zones).' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rescheduleReason rdf:type rdf:Property ;
    rdfs:label 'Reschedule Reason' ;
    rdfs:comment 'Explanation for why the audit was rescheduled from its original date. Null if the audit has not been rescheduled.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the audit schedule. Tracks progression from planning through execution to completion or cancellation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The planned date on which the audit is scheduled to occur. This is the primary business event date for audit calendar management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'The anticipated date and time when the audit is expected to conclude, used for resource planning and scheduling conflicts.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'The precise date and time when the audit is scheduled to begin, including time zone information for multi-region coordination.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Additional instructions or notes for the auditor and location staff, such as access requirements, safety protocols, or specific areas of focus.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyFirmName rdf:type rdf:Property ;
    rdfs:label 'Third Party Firm Name' ;
    rdfs:comment 'Name of the external audit firm or certification body conducting the audit, if applicable. Null for internal audits.' ;
    rdfs:domain ind:AuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationId rdf:type rdf:Property ;
    rdfs:label 'Certification Id' ;
    rdfs:comment 'Unique identifier for the organizational compliance certification record. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certification .

ind:certificationAssociateId rdf:type rdf:Property ;
    rdfs:label 'Certification Associate Id' ;
    rdfs:comment 'Foreign key reference to the workforce member (manager or compliance officer) who is accountable for maintaining this certification and managing renewal activities.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:certificationCreatedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Certification Created By User Associate Id' ;
    rdfs:comment 'Foreign key reference to the user or system account that created this certification record.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:certificationModifiedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Certification Modified By User Associate Id' ;
    rdfs:comment 'Foreign key reference to the user or system account that most recently modified this certification record.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'The name of the national or international accreditation body that accredits the certifying body (e.g., ANAB - ANSI National Accreditation Board, UKAS - United Kingdom Accreditation Service, IAF - International Accreditation Forum).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency' ;
    rdfs:comment 'The required frequency of surveillance or re-certification audits to maintain the certification. Annual indicates yearly; semi_annual indicates twice per year; quarterly indicates every three months; biennial indicates every two years; triennial indicates every three years; on_demand indicates audits triggered by events.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Url' ;
    rdfs:comment 'URL or file path to the digital copy of the official certificate document stored in the document management system.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'The externally-issued unique certificate or accreditation number assigned by the certifying body. This is the official identifier printed on the certificate document.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'The category or standard of certification held by the organization. Examples include ISO 22000 Food Safety, ISO 14001 Environmental Management, GFSI (Global Food Safety Initiative), SQF (Safe Quality Food), BRC (British Retail Consortium), Rainforest Alliance, Fair Trade, Organic Certification, LEED Building Certification.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBody rdf:type rdf:Property ;
    rdfs:label 'Certifying Body' ;
    rdfs:comment 'The name of the independent third-party organization or accreditation body that issued the certification (e.g., NSF International, SGS, Bureau Veritas, DNV GL, Intertek).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'The total cost incurred for obtaining and maintaining this certification, including application fees, audit fees, consulting fees, and annual maintenance fees.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageLevel rdf:type rdf:Property ;
    rdfs:label 'Coverage Level' ;
    rdfs:comment 'The organizational level at which the certification applies. Enterprise indicates company-wide; division indicates a specific business unit; facility indicates a single location (store, DC, plant); program indicates a specific operational program; product_line indicates a category of products.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date from which the certification becomes valid and enforceable. May differ from issue_date if there is a grace period or delayed activation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'The date on which the certification expires and is no longer valid unless renewed. Nullable for certifications with indefinite validity pending periodic audits.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date on which the certification was officially granted and the certificate was issued by the certifying body.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'The date of the most recent surveillance or re-certification audit conducted by the certifying body to verify ongoing compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:logoUrl rdf:type rdf:Property ;
    rdfs:label 'Logo Url' ;
    rdfs:comment 'URL or file path to the official certification logo or seal provided by the certifying body for use in marketing and communications materials.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'The scheduled date for the next surveillance or re-certification audit required to maintain the certification.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Flag' ;
    rdfs:comment 'Boolean indicator of whether this certification is publicly disclosed on the company website, in sustainability reports, or in marketing materials. True indicates public disclosure; False indicates internal-only tracking.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'The target date by which the renewal application or re-certification audit must be completed to maintain continuous certification status.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalWorkflowStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Workflow Status' ;
    rdfs:comment 'Current status of the certification renewal process workflow. Tracks the progression from initial renewal planning through final approval or rejection. [ENUM-REF-CANDIDATE: not_started|application_submitted|audit_scheduled|audit_in_progress|audit_completed|pending_approval|approved|rejected — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Detailed textual description of the scope of certification, including the specific business processes, product categories, facilities, or operational areas covered by the certification. For example, \'Procurement, storage, and distribution of ambient, chilled, and frozen food products across all US distribution centers.\'' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Textual explanation of why the certification was suspended, if applicable. Includes details of non-conformities, audit findings, or administrative issues that led to suspension.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Textual explanation of why the certification was withdrawn or revoked, if applicable. Includes details of major non-conformities, failure to remediate findings, or voluntary surrender.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiration Date' ;
    rdfs:comment 'Date when the current certification or accreditation expires and must be renewed. Null if not applicable or perpetual.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Official certification or accreditation number issued by the governing body or third-party auditor (e.g., ISO 27001 certificate number, PCI-DSS Attestation of Compliance number). Null if program does not issue certifications.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceProgramDescription rdf:type rdf:Property ;
    rdfs:label 'Compliance Program Description' ;
    rdfs:comment 'Detailed narrative description of the compliance program purpose, objectives, key requirements, and business rationale.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingBody rdf:type rdf:Property ;
    rdfs:label 'Governing Body' ;
    rdfs:comment 'Name of the external regulatory authority, standards organization, or certification body that oversees this compliance program (e.g., Federal Trade Commission, Consumer Product Safety Commission, PCI Security Standards Council).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCountYtd rdf:type rdf:Property ;
    rdfs:label 'Incident Count Ytd' ;
    rdfs:comment 'Number of compliance incidents, violations, or breaches recorded for this program in the current calendar year.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastAuditResult rdf:type rdf:Property ;
    rdfs:label 'Last Audit Result' ;
    rdfs:comment 'Outcome of the most recent compliance audit. Passed: full compliance. Passed_with_findings: compliant but with minor issues noted. Failed: non-compliant. Not_applicable: audit not yet conducted or program not subject to audit.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manager rdf:type rdf:Property ;
    rdfs:label 'Manager' ;
    rdfs:comment 'Name or employee identifier of the individual responsible for day-to-day program management and coordination. Business-confidential organizational information.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmountMax rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount Max' ;
    rdfs:comment 'Maximum potential financial penalty or fine (in USD) for non-compliance with this program, based on regulatory framework or historical precedent. Business-confidential risk assessment data.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:policyDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Policy Document Url' ;
    rdfs:comment 'URL or document management system reference to the official compliance program policy document, standard operating procedures, or program charter.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Externally-known unique business identifier for the compliance program (e.g., FDA-FSMA-2024, PCI-DSS-V4, GDPR-EU). Used in regulatory filings and audit documentation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Full business name of the compliance program (e.g., Food and Drug Administration Food Safety Modernization Act Program, Payment Card Industry Data Security Standard Program).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programScope rdf:type rdf:Property ;
    rdfs:label 'Program Scope' ;
    rdfs:comment 'Organizational scope of the compliance program. Enterprise_wide: applies to all Retail operations. Banner_specific: applies to specific retail banners. Channel_specific: applies to e-commerce, stores, or distribution only. Region_specific: applies to specific geographic regions. Store_specific: applies to individual stores. DC_specific: applies to distribution centers.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle state of the compliance program. Active: program is operational and enforced. Suspended: temporarily paused. Under_review: being evaluated for changes. Retired: no longer applicable. Pending_activation: approved but not yet effective. Non_compliant: program exists but organization is currently out of compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the compliance program by its nature: regulatory (government-mandated), industry_standard (voluntary best practice), internal_policy (company-specific), certification (third-party accreditation), environmental (sustainability/emissions), safety (workplace/product), privacy (data protection), security (information/payment). [ENUM-REF-CANDIDATE: regulatory|industry_standard|internal_policy|certification|environmental|safety|privacy|security — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Next scheduled date for program recertification, re-assessment, or formal renewal review. Applicable for certification-based and time-bound programs.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsor rdf:type rdf:Property ;
    rdfs:label 'Sponsor' ;
    rdfs:comment 'Name or title of the executive sponsor accountable for the compliance program (e.g., Chief Compliance Officer, VP Food Safety, Chief Information Security Officer). Business-confidential organizational information.' ;
    rdfs:domain ind:ComplianceProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingFrequency rdf:type rdf:Property ;
    rdfs:label 'Training Frequency' ;
    rdfs:comment 'Required frequency of compliance training for employees covered by this program. Not_applicable: training not required.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequired rdf:type rdf:Property ;
    rdfs:label 'Training Required' ;
    rdfs:comment 'Indicates whether employee training is mandatory for this compliance program. True: training required. False: no training requirement.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionId rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Id' ;
    rdfs:comment 'Unique identifier for the corrective action record. Primary key for the corrective action entity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveAction .

ind:environmentalEventId rdf:type rdf:Property ;
    rdfs:label 'Environmental Event Id' ;
    rdfs:comment 'Foreign key linking to compliance.environmental_event. Business justification: Environmental events (spills, waste disposal issues, etc.) require corrective actions. This FK links the corrective action to the environmental event that triggered it. Cardinality: Many corrective ac' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnvironmentalEvent .

ind:primaryCorrectiveAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Corrective Associate Id' ;
    rdfs:comment 'Reference to the employee or team member responsible for executing and completing the corrective action.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:violationNoticeId rdf:type rdf:Property ;
    rdfs:label 'Violation Notice Id' ;
    rdfs:comment 'Foreign key linking to compliance.violation_notice. Business justification: Corrective actions can be triggered by violation notices in addition to audit findings. This provides an alternative parent for corrective actions. Cardinality: Many corrective actions → One violation' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ViolationNotice .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Business identifier for the corrective action, typically formatted as CA-NNNNNN for external reference and tracking.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Classification of the corrective action approach: immediate fix (quick remediation), process change (workflow modification), training (employee education), system update (IT system enhancement), policy revision (documentation update), or equipment upgrade (physical asset replacement).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual date when the corrective action was completed. Null if still in progress.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual financial cost incurred to implement the corrective action. Null if not yet completed or cost not yet finalized.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedDepartment rdf:type rdf:Property ;
    rdfs:label 'Assigned Department' ;
    rdfs:comment 'Business department or functional area responsible for implementing the corrective action (e.g., Store Operations, Food Safety, IT Security, Human Resources).' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedOwnerName rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner Name' ;
    rdfs:comment 'Full name of the employee or team member assigned as the owner of this corrective action.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date when the corrective action was formally closed after successful verification. Null if not yet closed.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closureNotes rdf:type rdf:Property ;
    rdfs:label 'Closure Notes' ;
    rdfs:comment 'Final summary notes documenting the closure of the corrective action, including lessons learned and recommendations for preventive actions.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Category' ;
    rdfs:comment 'High-level compliance domain category: food_safety (FDA/FSMA), workplace_safety (OSHA), payment_security (PCI-DSS), data_privacy (GDPR/CCPA), environmental (EPA), or product_safety (CPSC).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed description of the corrective action plan, including specific steps, resources, and expected outcomes.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current lifecycle status of the corrective action: open (newly created), in_progress (work underway), pending_verification (awaiting validation), closed (completed and verified), or overdue (past target completion date).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Rating' ;
    rdfs:comment 'Assessment of whether the corrective action successfully addressed the root cause: effective (fully resolved), partially_effective (improvement but not complete), ineffective (did not resolve issue), or pending (awaiting verification).' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date when the corrective action was escalated to senior management or regulatory authorities. Null if no escalation occurred.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationRequired rdf:type rdf:Property ;
    rdfs:label 'Escalation Required' ;
    rdfs:comment 'Boolean flag indicating whether this corrective action requires escalation to senior management or regulatory authorities due to severity or complexity.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReportDate rdf:type rdf:Property ;
    rdfs:label 'External Report Date' ;
    rdfs:comment 'Date when the corrective action was reported to external regulatory authorities. Null if no external reporting occurred.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalReportingRequired rdf:type rdf:Property ;
    rdfs:label 'External Reporting Required' ;
    rdfs:comment 'Boolean flag indicating whether this corrective action must be reported to external regulatory bodies (FDA, OSHA, FTC, etc.).' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurrencePreventionPlan rdf:type rdf:Property ;
    rdfs:label 'Recurrence Prevention Plan' ;
    rdfs:comment 'Description of preventive measures and controls implemented to prevent recurrence of the same or similar compliance violations.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned date by which the corrective action must be completed to meet regulatory or business requirements.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verifiedByName rdf:type rdf:Property ;
    rdfs:label 'Verified By Name' ;
    rdfs:comment 'Full name of the person who verified the corrective action effectiveness.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentMethod rdf:type rdf:Property ;
    rdfs:label 'Containment Method' ;
    rdfs:comment 'Method used to contain or remediate the spill or leak (e.g., absorbent pads, containment boom, vacuum recovery, neutralization).' ;
    rdfs:domain ind:EnvironmentalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completed Date' ;
    rdfs:comment 'Actual date on which corrective actions were completed and verified.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Target date by which corrective actions must be completed to resolve the environmental event.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether corrective action is required to address the environmental event and prevent recurrence.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disposalFacilityEpaNumber rdf:type rdf:Property ;
    rdfs:label 'Disposal Facility Epa Number' ;
    rdfs:comment 'EPA-issued identification number for the treatment, storage, or disposal facility (TSDF) that received the waste.' ;
    rdfs:domain ind:EnvironmentalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalFacilityName rdf:type rdf:Property ;
    rdfs:label 'Disposal Facility Name' ;
    rdfs:comment 'Name of the final disposal, treatment, or recycling facility where the environmental material was delivered.' ;
    rdfs:domain ind:EnvironmentalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'Method used to dispose of or manage the environmental material (e.g., landfill, incineration, recycling, treatment facility). Applicable to waste disposal events. [ENUM-REF-CANDIDATE: landfill|incineration|recycling|treatment|recovery|neutralization|containment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'The date on which the environmental event occurred or was observed.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Business-assigned unique identifier for the environmental event, used for tracking and reporting to regulatory agencies.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle status of the environmental event in the compliance tracking workflow.' ;
    rdfs:domain ind:EnvironmentalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Precise date and time when the environmental event occurred, used for detailed incident tracking and regulatory reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the environmental compliance event (e.g., waste disposal, HAZMAT handling, refrigerant leak, stormwater discharge, energy consumption reporting, plastic bag ban compliance). [ENUM-REF-CANDIDATE: waste_disposal|hazmat_handling|refrigerant_leak|stormwater_discharge|energy_reporting|plastic_bag_compliance|spill_incident — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class' ;
    rdfs:comment 'DOT hazard class for hazardous materials involved in the event, if applicable (e.g., Class 2.2 for non-flammable gases, Class 9 for miscellaneous hazardous materials).' ;
    rdfs:domain ind:EnvironmentalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'Date on which the environmental inspection or audit that identified this event was conducted.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Name of the internal or external inspector who documented or verified the environmental event.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestNumber rdf:type rdf:Property ;
    rdfs:label 'Manifest Number' ;
    rdfs:comment 'Unique manifest tracking number for hazardous waste shipments, as required by EPA RCRA regulations. Applicable to waste disposal events.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Type of material or substance involved in the environmental event (e.g., refrigerant R-410A, used oil, electronic waste, stormwater runoff, plastic bags).' ;
    rdfs:domain ind:EnvironmentalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Monetary amount of the penalty or fine assessed by the regulatory agency for non-compliance related to this environmental event.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyAssessed rdf:type rdf:Property ;
    rdfs:label 'Penalty Assessed' ;
    rdfs:comment 'Indicates whether a regulatory penalty or fine was assessed against the organization for this environmental event.' ;
    rdfs:domain ind:EnvironmentalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Quantity of material or substance involved in the environmental event (e.g., gallons of waste oil, pounds of refrigerant leaked, kilowatt-hours of energy consumed).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationReference rdf:type rdf:Property ;
    rdfs:label 'Regulation Reference' ;
    rdfs:comment 'Specific citation or reference code for the environmental regulation applicable to this event (e.g., 40 CFR Part 82 for refrigerant management).' ;
    rdfs:domain ind:EnvironmentalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Indicates whether this environmental event triggers a mandatory reporting obligation to EPA, state DEQ, or local environmental agencies.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationCost rdf:type rdf:Property ;
    rdfs:label 'Remediation Cost' ;
    rdfs:comment 'Total cost incurred for remediation, cleanup, or disposal activities related to the environmental event.' ;
    rdfs:domain ind:EnvironmentalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Report Confirmation Number' ;
    rdfs:comment 'Confirmation or tracking number issued by the regulatory agency upon receipt of the environmental event report.' ;
    rdfs:domain ind:EnvironmentalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Report Submitted Date' ;
    rdfs:comment 'The date on which the environmental event report was submitted to the regulatory agency.' ;
    rdfs:domain ind:EnvironmentalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'The date on which the environmental event was formally reported to internal compliance teams or external regulatory agencies.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingDeadline rdf:type rdf:Property ;
    rdfs:label 'Reporting Deadline' ;
    rdfs:comment 'The deadline by which this environmental event must be reported to the applicable regulatory agency.' ;
    rdfs:domain ind:EnvironmentalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsiblePartyEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Email' ;
    rdfs:comment 'Email address of the individual or department responsible for the environmental event.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'Name of the individual or department responsible for managing and resolving the environmental event.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spillVolume rdf:type rdf:Property ;
    rdfs:label 'Spill Volume' ;
    rdfs:comment 'Volume of material spilled or released during an environmental incident (e.g., gallons of oil, pounds of refrigerant). Applicable to spill and leak events.' ;
    rdfs:domain ind:EnvironmentalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteHaulerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Waste Hauler License Number' ;
    rdfs:comment 'State or federal license number of the waste hauler, verifying their authorization to transport hazardous or regulated materials.' ;
    rdfs:domain ind:EnvironmentalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteHaulerName rdf:type rdf:Property ;
    rdfs:label 'Waste Hauler Name' ;
    rdfs:comment 'Name of the licensed third-party waste hauler or disposal company that transported or managed the environmental material.' ;
    rdfs:domain ind:EnvironmentalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyLogId rdf:type rdf:Property ;
    rdfs:label 'Food Safety Log Id' ;
    rdfs:comment 'Unique identifier for the food safety monitoring log entry. Primary key for the food safety log product.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FoodSafetyLog .

ind:haccpControlPointId rdf:type rdf:Property ;
    rdfs:label 'Haccp Control Point Id' ;
    rdfs:comment 'Foreign key linking to compliance.haccp_control_point. Business justification: Food safety logs are monitoring records for specific HACCP control points. Each log entry records monitoring activities against a defined control point. Cardinality: Many logs → One control point (1:N' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HaccpControlPoint .

ind:primaryFoodAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Food Associate Id' ;
    rdfs:comment 'Identifier of the employee who performed the monitoring activity. Required for accountability and training verification.' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Unique identifier linking this record to the broader audit trail and compliance documentation system. Enables cross-referencing with inspection reports and corrective action logs.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Additional notes, observations, or context related to the monitoring activity, deviation, or corrective action. Provides supplementary information for audit and investigation purposes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlPointType rdf:type rdf:Property ;
    rdfs:label 'Control Point Type' ;
    rdfs:comment 'Classification of the control point monitored: CCP (Critical Control Point per HACCP), CP (Control Point), or PRP (Prerequisite Program). Determines the level of regulatory scrutiny and corrective action requirements.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Detailed description of the corrective action taken in response to a critical limit deviation or food safety concern. Required for regulatory compliance and audit documentation.' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Timestamp' ;
    rdfs:comment 'Date and time when the corrective action was completed. Critical for demonstrating timely response to food safety deviations.' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:criticalLimitLower rdf:type rdf:Property ;
    rdfs:label 'Critical Limit Lower' ;
    rdfs:comment 'Lower boundary of the acceptable range for the control point as defined in the HACCP or HARPC plan. Values below this threshold indicate a deviation requiring corrective action.' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalLimitUpper rdf:type rdf:Property ;
    rdfs:label 'Critical Limit Upper' ;
    rdfs:comment 'Upper boundary of the acceptable range for the control point as defined in the HACCP or HARPC plan. Values above this threshold indicate a deviation requiring corrective action.' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Store department where the monitoring activity was conducted. Identifies the operational area subject to food safety controls. [ENUM-REF-CANDIDATE: deli|bakery|produce|seafood|meat|dairy|frozen|grocery — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationSeverity rdf:type rdf:Property ;
    rdfs:label 'Deviation Severity' ;
    rdfs:comment 'Severity classification of any deviation from critical limits: none (within limits), minor (approaching limits), major (exceeds limits), or critical (significant food safety risk). Determines escalation and reporting requirements.' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentCode rdf:type rdf:Property ;
    rdfs:label 'Equipment Code' ;
    rdfs:comment 'Identifier of the specific equipment or asset being monitored (e.g., refrigerator unit number, oven identifier, display case number). Enables equipment-level traceability and maintenance correlation.' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthDepartmentReportable rdf:type rdf:Property ;
    rdfs:label 'Health Department Reportable' ;
    rdfs:comment 'Boolean flag indicating whether this monitoring record or deviation must be reported to local health department authorities per regulatory requirements.' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instrumentCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Instrument Calibration Date' ;
    rdfs:comment 'Date when the monitoring instrument was last calibrated. Required to ensure measurement accuracy and regulatory compliance.' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:instrumentCode rdf:type rdf:Property ;
    rdfs:label 'Instrument Code' ;
    rdfs:comment 'Identifier of the measuring instrument or device used (e.g., thermometer serial number, pH meter ID). Required for calibration tracking and measurement traceability.' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitStatus rdf:type rdf:Property ;
    rdfs:label 'Limit Status' ;
    rdfs:comment 'Indicates whether the measured value falls within acceptable limits, exceeds critical limits, or is approaching limits. Determines whether corrective action is required.' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'Numeric value recorded during the monitoring activity (e.g., temperature reading in degrees, pH level, time elapsed in minutes, sanitizer concentration in ppm).' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringEmployeeName rdf:type rdf:Property ;
    rdfs:label 'Monitoring Employee Name' ;
    rdfs:comment 'Full name of the employee who performed the monitoring activity. Required for FDA FSMA compliance documentation and audit trail.' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringMethod rdf:type rdf:Property ;
    rdfs:label 'Monitoring Method' ;
    rdfs:comment 'Method used to perform the monitoring activity: manual measurement, automated sensor, calibrated instrument, or visual inspection. Impacts data reliability and audit requirements.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringTimestamp rdf:type rdf:Property ;
    rdfs:label 'Monitoring Timestamp' ;
    rdfs:comment 'Date and time when the food safety monitoring activity was performed. Critical for establishing compliance timeline and traceability.' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productAffected rdf:type rdf:Property ;
    rdfs:label 'Product Affected' ;
    rdfs:comment 'Description or identifier of the food product(s) affected by the monitoring activity or deviation. Critical for traceability and potential recall actions.' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDisposition rdf:type rdf:Property ;
    rdfs:label 'Product Disposition' ;
    rdfs:comment 'Final disposition of affected product following monitoring or corrective action: released for sale, held for further evaluation, destroyed, reworked, or returned to vendor.' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current status of the monitoring log record in the compliance workflow: draft (in progress), submitted (awaiting verification), verified (supervisor approved), or archived (retained for regulatory period).' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorName rdf:type rdf:Property ;
    rdfs:label 'Supervisor Name' ;
    rdfs:comment 'Full name of the supervisor or qualified individual who verified the monitoring record. Required for FDA compliance documentation.' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorVerified rdf:type rdf:Property ;
    rdfs:label 'Supervisor Verified' ;
    rdfs:comment 'Boolean flag indicating whether a supervisor or qualified individual has reviewed and verified the monitoring record and any corrective actions taken.' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationSignature rdf:type rdf:Property ;
    rdfs:label 'Verification Signature' ;
    rdfs:comment 'Electronic or digitized signature of the supervisor verifying the monitoring record. Required for regulatory compliance and audit trail integrity.' ;
    rdfs:domain ind:FoodSafetyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Date and time when the supervisor verification was completed. Establishes timeline for management oversight and compliance review.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:foodSafetyPlanId rdf:type rdf:Property ;
    rdfs:label 'Food Safety Plan Id' ;
    rdfs:comment 'Unique identifier for the food safety plan record. Primary key for the food safety plan entity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FoodSafetyPlan .

ind:allergenControlsIncluded rdf:type rdf:Property ;
    rdfs:label 'Allergen Controls Included' ;
    rdfs:comment 'Indicates whether this food safety plan includes specific preventive controls for managing food allergens (major allergens per FALCPA).' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalControlPointsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Control Points Count' ;
    rdfs:comment 'The number of Critical Control Points identified in this food safety plan where control is essential to prevent or eliminate a food safety hazard.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentLocation rdf:type rdf:Property ;
    rdfs:label 'Document Location' ;
    rdfs:comment 'The physical or digital location where the complete food safety plan documentation is stored and maintained for regulatory inspection.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalMonitoringProgram rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Program' ;
    rdfs:comment 'Indicates whether this food safety plan includes an environmental monitoring program for detecting pathogens in the production environment.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityScope rdf:type rdf:Property ;
    rdfs:label 'Facility Scope' ;
    rdfs:comment 'Description of the facility areas, operations, and food categories covered by this food safety plan (e.g., bakery operations, deli department, produce handling, meat processing).' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Registration Number' ;
    rdfs:comment 'The unique FDA facility registration number assigned to the food facility where this plan is implemented, required under FDA Food Facility Registration.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardAnalysisCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Hazard Analysis Completion Date' ;
    rdfs:comment 'The date when the comprehensive hazard analysis (biological, chemical, physical, and radiological hazards) was completed for this food safety plan.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRegulatoryInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Regulatory Inspection Date' ;
    rdfs:comment 'The date of the most recent inspection by FDA or other regulatory authority at the facility covered by this food safety plan.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'The username or identifier of the person who last modified this food safety plan record.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'The scheduled date for the next internal or external audit of this food safety plan.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Plan Approval Date' ;
    rdfs:comment 'The date when this food safety plan was officially approved by the qualified food safety professional and authorized for implementation.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Plan Effective Date' ;
    rdfs:comment 'The date when this food safety plan became active and enforceable at the facility.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Plan Expiration Date' ;
    rdfs:comment 'The date when this food safety plan version expires and must be renewed or replaced, if applicable.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'The official name or title of the food safety plan document as registered with regulatory authorities.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planReviewDate rdf:type rdf:Property ;
    rdfs:label 'Plan Review Date' ;
    rdfs:comment 'The date of the most recent comprehensive review of the food safety plan, required at least once every three years or when significant changes occur.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'The current lifecycle status of the food safety plan indicating whether it is actively enforced, under review for updates, awaiting approval, expired, or superseded by a newer version.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'The regulatory framework and methodology used for this food safety plan. HACCP (Hazard Analysis and Critical Control Points) for traditional food safety, HARPC (Hazard Analysis and Risk-Based Preventive Controls) for FSMA compliance, or other FDA-mandated plan types.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version number or identifier for this iteration of the food safety plan, used to track revisions and updates over time.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveControlsSummary rdf:type rdf:Property ;
    rdfs:label 'Preventive Controls Summary' ;
    rdfs:comment 'High-level summary of the preventive controls implemented under this plan, including process controls, allergen controls, sanitation controls, supply chain controls, and recall plan.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qfspCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Qfsp Certification Date' ;
    rdfs:comment 'The date when the QFSP completed their qualifying training or obtained their food safety certification.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qfspContactEmail rdf:type rdf:Property ;
    rdfs:label 'Qfsp Contact Email' ;
    rdfs:comment 'The business email address of the QFSP responsible for this food safety plan.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qfspContactPhone rdf:type rdf:Property ;
    rdfs:label 'Qfsp Contact Phone' ;
    rdfs:comment 'The business phone number of the QFSP responsible for this food safety plan.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qfspCredentials rdf:type rdf:Property ;
    rdfs:label 'Qfsp Credentials' ;
    rdfs:comment 'The professional certifications, training completion records, and qualifications of the QFSP (e.g., FSPCA Preventive Controls for Human Food course completion, HACCP certification).' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qfspName rdf:type rdf:Property ;
    rdfs:label 'Qfsp Name' ;
    rdfs:comment 'The full name of the Preventive Controls Qualified Individual (PCQI) or Qualified Food Safety Professional who prepared or supervised the preparation of this food safety plan.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallPlanIncluded rdf:type rdf:Property ;
    rdfs:label 'Recall Plan Included' ;
    rdfs:comment 'Indicates whether this food safety plan includes a written recall plan for rapid product removal from commerce in the event of a food safety incident.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Record Retention Years' ;
    rdfs:comment 'The number of years that records associated with this food safety plan must be retained per regulatory requirements (typically 2 years for most FSMA records).' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'The primary regulatory body with jurisdiction over this food safety plan (e.g., FDA, state health department, USDA FSIS for meat/poultry).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyChainProgramIncluded rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Program Included' ;
    rdfs:comment 'Indicates whether this food safety plan includes a supply chain preventive controls program for managing risks from suppliers and raw materials.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationActivitiesSummary rdf:type rdf:Property ;
    rdfs:label 'Verification Activities Summary' ;
    rdfs:comment 'Summary of the verification activities defined in the plan, including monitoring, verification procedures, corrective actions, and validation activities.' ;
    rdfs:domain ind:FoodSafetyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenControlFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Control Flag' ;
    rdfs:comment 'Indicates whether this control point specifically addresses allergen cross-contact prevention or allergen labeling accuracy. Allergen controls are a critical subset of preventive controls.' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedByPcqi rdf:type rdf:Property ;
    rdfs:label 'Approved By Pcqi' ;
    rdfs:comment 'Name or ID of the Preventive Controls Qualified Individual who reviewed and approved this control point. FDA FSMA requires PCQI oversight of food safety plans.' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlPointCode rdf:type rdf:Property ;
    rdfs:label 'Control Point Code' ;
    rdfs:comment 'Unique business identifier or code for the control point used in operational documentation and audit trails (e.g., CCP-001, PC-ALLER-05).' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlPointName rdf:type rdf:Property ;
    rdfs:label 'Control Point Name' ;
    rdfs:comment 'Business name of the critical control point or preventive control (e.g., Cooking Temperature Control, Metal Detection, Allergen Cleaning Verification).' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlPointStatus rdf:type rdf:Property ;
    rdfs:label 'Control Point Status' ;
    rdfs:comment 'Current operational status of the control point within the food safety plan. Active control points are currently enforced. Inactive or archived control points are no longer in use but retained for historical compliance records.' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionProcedure rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Procedure' ;
    rdfs:comment 'Documented procedure to be followed when monitoring indicates a deviation from the critical limit. Includes steps to identify cause, correct the deviation, prevent recurrence, and handle affected product.' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalLimitParameter rdf:type rdf:Property ;
    rdfs:label 'Critical Limit Parameter' ;
    rdfs:comment 'The measurable parameter that defines the boundary of safety for this control point (e.g., Temperature, Time, pH, Water Activity, Metal Detection Sensitivity, Chlorine Concentration).' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalLimitUnit rdf:type rdf:Property ;
    rdfs:label 'Critical Limit Unit' ;
    rdfs:comment 'Unit of measurement for the critical limit value (e.g., degrees Fahrenheit, degrees Celsius, minutes, hours, pH units, ppm, mm).' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalLimitValue rdf:type rdf:Property ;
    rdfs:label 'Critical Limit Value' ;
    rdfs:comment 'The specific threshold value that must be met or maintained to ensure food safety (e.g., 165°F minimum, pH below 4.6, 2 hours maximum, 1.5mm ferrous detection). May include ranges or multiple conditions.' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Flag' ;
    rdfs:comment 'Indicates whether this control point includes environmental monitoring for pathogens (e.g., Listeria in ready-to-eat food production environments). Required for certain high-risk food categories.' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gfsiSchemeAlignment rdf:type rdf:Property ;
    rdfs:label 'Gfsi Scheme Alignment' ;
    rdfs:comment 'Identifies which GFSI-benchmarked certification scheme this control point supports (e.g., SQF, BRC, FSSC 22000, IFS). Used when facility maintains third-party food safety certifications.' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardDescription rdf:type rdf:Property ;
    rdfs:label 'Hazard Description' ;
    rdfs:comment 'Detailed description of the specific food safety hazard being controlled at this point (e.g., Survival of Salmonella in raw poultry, Cross-contamination of allergens during packaging, Metal fragments from equipment wear).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardType rdf:type rdf:Property ;
    rdfs:label 'Hazard Type' ;
    rdfs:comment 'Category of food safety hazard addressed by this control point. Biological hazards include pathogens (Salmonella, Listeria, E. coli). Chemical hazards include pesticides, cleaning agents, toxins. Physical hazards include metal, glass, plastic. Allergens are a special category of chemical hazards.' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastValidationDate rdf:type rdf:Property ;
    rdfs:label 'Last Validation Date' ;
    rdfs:comment 'Date when the control point was last validated to ensure it effectively controls the identified hazard. FDA FSMA requires revalidation at least every 3 years or when significant changes occur.' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:likelihoodLevel rdf:type rdf:Property ;
    rdfs:label 'Likelihood Level' ;
    rdfs:comment 'Probability that the hazard will occur if the control point is not properly managed. Combined with severity to determine overall risk level.' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringEquipment rdf:type rdf:Property ;
    rdfs:label 'Monitoring Equipment' ;
    rdfs:comment 'Specific equipment or instruments used to perform monitoring (e.g., Digital probe thermometer Model XYZ, Metal detector Unit 5, pH meter, ATP luminometer). Supports calibration and maintenance tracking.' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'How often the control point must be monitored and measured (e.g., Continuous, Every batch, Every 2 hours, Daily, Per shift, Each production run).' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextValidationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Validation Due Date' ;
    rdfs:comment 'Scheduled date for the next required validation of this control point. Used for compliance tracking and audit preparation.' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prerequisiteProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Program Flag' ;
    rdfs:comment 'Indicates whether this control point is part of a prerequisite program (basic conditions and activities necessary to maintain a hygienic environment) rather than a process-specific preventive control.' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processStep rdf:type rdf:Property ;
    rdfs:label 'Process Step' ;
    rdfs:comment 'The specific step in the food production or handling process where this control point is applied (e.g., Receiving, Cooking, Cooling, Packaging, Storage, Distribution).' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordKeepingRequirement rdf:type rdf:Property ;
    rdfs:label 'Record Keeping Requirement' ;
    rdfs:comment 'Documentation requirements for this control point including what records must be maintained, format, retention period, and storage location. Supports regulatory compliance and audit trails.' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleRole rdf:type rdf:Property ;
    rdfs:label 'Responsible Role' ;
    rdfs:comment 'Job role or position responsible for monitoring this control point (e.g., Line Supervisor, Quality Technician, Receiving Manager, Sanitation Lead). Used for training and accountability.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierControlFlag rdf:type rdf:Property ;
    rdfs:label 'Supplier Control Flag' ;
    rdfs:comment 'Indicates whether this control point is part of the supply chain preventive controls program, addressing hazards in incoming raw materials and ingredients through supplier verification.' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationMethod rdf:type rdf:Property ;
    rdfs:label 'Validation Method' ;
    rdfs:comment 'Scientific or technical approach used to validate that the control point effectively controls the hazard (e.g., Challenge study, Inoculation study, Literature review, Historical data analysis, Predictive modeling).' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationFrequency rdf:type rdf:Property ;
    rdfs:label 'Verification Frequency' ;
    rdfs:comment 'How often verification activities must be performed (e.g., Weekly, Monthly, Quarterly, Annually, Before each production run).' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationProcedure rdf:type rdf:Property ;
    rdfs:label 'Verification Procedure' ;
    rdfs:comment 'Methods used to verify that the control point is working as intended. May include calibration checks, record review, testing, audits, and validation studies.' ;
    rdfs:domain ind:HaccpControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensePermitId rdf:type rdf:Property ;
    rdfs:label 'License Permit Id' ;
    rdfs:comment 'Unique identifier for the license or permit record. Primary key for the license_permit product. Role: MASTER_AGREEMENT.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicensePermit .

ind:associatedEntityReference rdf:type rdf:Property ;
    rdfs:label 'Associated Entity Reference' ;
    rdfs:comment 'The identifier of the entity (store, banner, or enterprise) to which this license is associated. Polymorphic reference depending on license_scope.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:associatedEntityType rdf:type rdf:Property ;
    rdfs:label 'Associated Entity Type' ;
    rdfs:comment 'The type of entity to which this license is associated. Used in conjunction with associated_entity_id to resolve the polymorphic reference.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsOfLicense rdf:type rdf:Property ;
    rdfs:label 'Conditions Of License' ;
    rdfs:comment 'Any special conditions, restrictions, or requirements attached to the license or permit by the issuing authority.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'Document Reference Url' ;
    rdfs:comment 'URL or file path to the digital copy of the license or permit document stored in the document management system.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the license fee amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether periodic inspections are required to maintain this license or permit.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'The name of the government agency, regulatory body, or certification organization that issued the license or permit.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Issuing Jurisdiction' ;
    rdfs:comment 'The geographic or administrative jurisdiction of the issuing authority (e.g., state, county, city, federal).' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'The date of the most recent inspection conducted for this license or permit.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'The date on which the license or permit was most recently renewed.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'License Fee Amount' ;
    rdfs:comment 'The monetary fee paid to obtain or renew the license or permit.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'The official license or permit number issued by the regulatory authority. This is the externally-known unique identifier for the license.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseScope rdf:type rdf:Property ;
    rdfs:label 'License Scope' ;
    rdfs:comment 'The organizational level at which the license applies: enterprise-wide, specific banner, individual location, or department.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current lifecycle status of the license or permit. Indicates whether the license is valid, expired, suspended, or under review.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Classification of the license or permit. Indicates the regulatory category and scope of the license. [ENUM-REF-CANDIDATE: business_operating_license|food_handler_permit|liquor_license|beer_wine_license|pharmacy_license|tobacco_retail_license|lottery_license|health_department_permit|fire_occupancy_permit|environmental_discharge_permit|building_permit|signage_permit — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'The date by which the next inspection must be completed to maintain compliance with the license or permit requirements.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reinstatementDate rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Date' ;
    rdfs:comment 'The date on which a suspended or revoked license or permit was reinstated to active status.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalFrequency rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency' ;
    rdfs:comment 'The frequency at which the license or permit must be renewed (e.g., annually, every two years, perpetual).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'The current status of the license renewal process. Indicates whether renewal is required and the stage of the renewal workflow.' ;
    rdfs:domain ind:LicensePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyPhone rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Phone' ;
    rdfs:comment 'The phone number of the individual or role responsible for managing this license or permit.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'The date on which the license or permit was revoked.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'The reason for revocation of the license or permit, if applicable. Populated when license_status is revoked.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'The date on which the license or permit was suspended.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requirementId rdf:type rdf:Property ;
    rdfs:label 'Requirement Id' ;
    rdfs:comment 'Reference to the regulatory requirement that mandates this obligation. Links to the regulatory requirement catalog.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requirement .

ind:cadence rdf:type rdf:Property ;
    rdfs:label 'Cadence' ;
    rdfs:comment 'Frequency at which the obligation must be fulfilled. Determines scheduling and recurrence rules for compliance tasks. [ENUM-REF-CANDIDATE: annual|semi_annual|quarterly|monthly|weekly|event_driven|one_time — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlObjective rdf:type rdf:Property ;
    rdfs:label 'Control Objective' ;
    rdfs:comment 'The high-level control objective this obligation supports. Examples include data privacy protection, payment security, food safety, workplace safety.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Days' ;
    rdfs:comment 'The number of days before the due date at which the obligation should be escalated to management if not yet fulfilled.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidenceRequired rdf:type rdf:Property ;
    rdfs:label 'Evidence Required' ;
    rdfs:comment 'Indicates whether documented evidence of fulfillment is required for audit purposes. True if evidence must be collected and retained.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceType rdf:type rdf:Property ;
    rdfs:label 'Evidence Type' ;
    rdfs:comment 'The type of evidence required to demonstrate fulfillment. Examples include document, certificate, training record, audit report, system log, attestation.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Penalty Amount' ;
    rdfs:comment 'The estimated financial penalty or fine that could be incurred for non-compliance with this obligation. Used for risk quantification.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'The legal or regulatory jurisdiction under which this obligation is mandated. Examples include USA, CAN, EU, or specific state/province codes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFulfilledDate rdf:type rdf:Property ;
    rdfs:label 'Last Fulfilled Date' ;
    rdfs:comment 'The most recent date on which this obligation was successfully fulfilled. Used for tracking compliance history and scheduling next occurrence.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationScope rdf:type rdf:Property ;
    rdfs:label 'Location Scope' ;
    rdfs:comment 'Defines the geographic or organizational scope to which this obligation applies. May reference specific stores, distribution centers, regions, or enterprise-wide applicability.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'The calculated next due date for recurring obligations. Automatically updated based on cadence and last fulfilled date.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Business identifier code for the obligation, used for external reporting and cross-system reference. Typically follows organizational coding standards.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed description of the compliance obligation, including the specific control action required, scope, and expected outcome.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationStatus rdf:type rdf:Property ;
    rdfs:label 'Obligation Status' ;
    rdfs:comment 'Current fulfillment status of the obligation. Tracks lifecycle from assignment through completion or waiver.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Classification of the obligation by the type of control action required. Determines workflow and fulfillment process.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the financial penalty amount. Examples include USD, EUR, GBP.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'The governing body or regulatory agency that mandates this obligation. Examples include FDA, FTC, OSHA, PCI SSC, GDPR authority.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'The number of days that evidence and records related to this obligation must be retained for regulatory and audit purposes.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'The assessed risk level associated with non-fulfillment of this obligation. Based on regulatory penalties, operational impact, and reputational risk.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApproved rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved' ;
    rdfs:comment 'Indicates whether a formal waiver or exception has been approved for this obligation. True if waiver is in effect.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiration Date' ;
    rdfs:comment 'The date on which the approved waiver expires and the obligation becomes enforceable again. Nullable for permanent waivers.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'The business justification for granting a waiver or exception to this obligation. Required when waiver is approved.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousIncidentOshaIncidentId rdf:type rdf:Property ;
    rdfs:label 'Previous Incident Osha Incident Id' ;
    rdfs:comment 'Reference to a previous related incident if this is a recurrence or follow-up event.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OshaIncident .

ind:primaryOshaAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Osha Associate Id' ;
    rdfs:comment 'Unique identifier of the employee involved in the incident. Protected as personally identifiable information.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:tertiaryOshaInvestigatorEmployeeAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Osha Investigator Employee Associate Id' ;
    rdfs:comment 'Identifier of the safety professional or manager assigned to investigate the incident.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:bodyPartAffected rdf:type rdf:Property ;
    rdfs:label 'Body Part Affected' ;
    rdfs:comment 'The specific body part or region injured in the incident: head, neck, back, shoulder, arm, hand, finger, leg, knee, ankle, foot, multiple body parts, etc. Null for non-injury incidents.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseClosedDate rdf:type rdf:Property ;
    rdfs:label 'Case Closed Date' ;
    rdfs:comment 'The date the incident case was officially closed after all corrective actions were completed and verified.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysAwayFromWork rdf:type rdf:Property ;
    rdfs:label 'Days Away From Work' ;
    rdfs:comment 'Total number of calendar days the employee was unable to work as a result of the incident, excluding the day of injury. Used for OSHA 300 Log column H.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysRestrictedDuty rdf:type rdf:Property ;
    rdfs:label 'Days Restricted Duty' ;
    rdfs:comment 'Total number of calendar days the employee was on restricted work activity or job transfer due to the incident. Used for OSHA 300 Log column I.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Amount' ;
    rdfs:comment 'Estimated total cost of the incident including medical expenses, lost time, workers compensation, property damage, and administrative costs.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'The calendar date on which the workplace safety incident occurred.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Detailed narrative description of how the incident occurred, including the sequence of events, equipment involved, environmental conditions, and any contributing factors.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Business-assigned unique incident tracking number following the format: location code, year, and sequential number (e.g., DC01-2024-000123).' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Incident Timestamp' ;
    rdfs:comment 'The precise date and time when the workplace safety incident occurred, including time zone information.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Primary classification of the incident: injury (physical harm to employee), illness (occupational disease), near-miss (potential incident with no harm), property damage, environmental event, or vehicle-related incident.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryType rdf:type rdf:Property ;
    rdfs:label 'Injury Type' ;
    rdfs:comment 'Specific nature of the injury sustained: laceration, strain, sprain, fracture, contusion, burn, chemical exposure, fall, struck by object, caught in equipment, repetitive motion, etc. Null for non-injury incidents.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Date' ;
    rdfs:comment 'The date the incident investigation was completed and findings documented.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Specific area within the facility where the incident occurred: sales floor, stockroom, loading dock, parking lot, break room, warehouse aisle, etc.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalFacilityName rdf:type rdf:Property ;
    rdfs:label 'Medical Facility Name' ;
    rdfs:comment 'Name of the medical facility, hospital, or clinic where the employee received treatment, if applicable.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osha300LogEntryFlag rdf:type rdf:Property ;
    rdfs:label 'Osha 300 Log Entry Flag' ;
    rdfs:comment 'Indicates whether the incident was entered on the OSHA 300 Log of Work-Related Injuries and Illnesses.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:osha301ReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Osha 301 Reportable Flag' ;
    rdfs:comment 'Indicates whether the incident requires completion of OSHA Form 301 (Injury and Illness Incident Report) or equivalent documentation.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oshaIncidentStatus rdf:type rdf:Property ;
    rdfs:label 'Osha Incident Status' ;
    rdfs:comment 'Current status of the incident case in the investigation and resolution workflow.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaRecordableFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Recordable Flag' ;
    rdfs:comment 'Indicates whether the incident meets OSHA criteria for recordability on the OSHA 300 Log (requires medical treatment beyond first aid, days away from work, restricted duty, or loss of consciousness).' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privacyCaseFlag rdf:type rdf:Property ;
    rdfs:label 'Privacy Case Flag' ;
    rdfs:comment 'Indicates whether the incident qualifies as a privacy case under OSHA regulations (certain injuries or illnesses where employee name may be withheld from OSHA 300 Log).' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatmentProvided rdf:type rdf:Property ;
    rdfs:label 'Treatment Provided' ;
    rdfs:comment 'Description of the medical treatment provided: first aid, medical treatment by physician, emergency room visit, hospitalization, surgery, physical therapy, etc.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessCount rdf:type rdf:Property ;
    rdfs:label 'Witness Count' ;
    rdfs:comment 'Number of witnesses to the incident who provided statements during the investigation.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workActivity rdf:type rdf:Property ;
    rdfs:label 'Work Activity' ;
    rdfs:comment 'The specific work task or activity the employee was performing at the time of the incident: lifting, stocking shelves, operating equipment, customer service, maintenance, etc.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workersCompensationClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Workers Compensation Claim Number' ;
    rdfs:comment 'The claim number assigned by the workers compensation insurance carrier for this incident, if a claim was filed.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Pci Assessment Id' ;
    rdfs:comment 'Unique identifier for the PCI-DSS compliance assessment record.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PciAssessment .

ind:acquiringBankName rdf:type rdf:Property ;
    rdfs:label 'Acquiring Bank Name' ;
    rdfs:comment 'Name of the acquiring bank or payment processor to which PCI-DSS compliance documentation is submitted.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualTransactionVolume rdf:type rdf:Property ;
    rdfs:label 'Annual Transaction Volume' ;
    rdfs:comment 'Total number of payment card transactions processed annually across all channels, used to determine merchant level classification.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'Date on which the PCI-DSS assessment was completed and finalized.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Business-facing reference number or code assigned to this PCI-DSS assessment for tracking and reporting purposes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReportUrl rdf:type rdf:Property ;
    rdfs:label 'Assessment Report Url' ;
    rdfs:comment 'URL or file path to the complete PCI-DSS assessment report document (SAQ or ROC) stored in the document management system.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScopeNotes rdf:type rdf:Property ;
    rdfs:label 'Assessment Scope Notes' ;
    rdfs:comment 'Additional notes and details regarding the scope boundaries, exclusions, and special considerations for this PCI-DSS assessment.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Start Date' ;
    rdfs:comment 'Date on which the PCI-DSS assessment activities commenced.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Type of PCI-DSS assessment performed. SAQ (Self-Assessment Questionnaire) variants for different merchant environments, or ROC (Report on Compliance) for Level 1 merchants requiring external audit by a Qualified Security Assessor (QSA). [ENUM-REF-CANDIDATE: SAQ-A|SAQ-A-EP|SAQ-B|SAQ-B-IP|SAQ-C|SAQ-C-VT|SAQ-D|SAQ-P2PE|ROC — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Name of the individual lead assessor or internal compliance officer who conducted or coordinated the assessment.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestationOfComplianceSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Attestation Of Compliance Submitted Flag' ;
    rdfs:comment 'Indicates whether the Attestation of Compliance (AOC) document has been submitted to the acquiring bank or payment card brands.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attestationSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Attestation Submission Date' ;
    rdfs:comment 'Date on which the Attestation of Compliance (AOC) was submitted to the acquiring bank or payment card brands.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cardholderDataEnvironmentScope rdf:type rdf:Property ;
    rdfs:label 'Cardholder Data Environment Scope' ;
    rdfs:comment 'Detailed description of the systems, networks, applications, and physical locations that comprise the Cardholder Data Environment (CDE) and are in scope for this PCI-DSS assessment.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensatingControlsCount rdf:type rdf:Property ;
    rdfs:label 'Compensating Controls Count' ;
    rdfs:comment 'Number of PCI-DSS requirements for which compensating controls were implemented and accepted in lieu of standard controls.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Overall compliance determination for this assessment. Compliant indicates all requirements met; Non-Compliant indicates one or more requirements failed; Compliant with Compensating Controls indicates alternative controls in place where standard controls cannot be implemented.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inScopeLocationsCount rdf:type rdf:Property ;
    rdfs:label 'In Scope Locations Count' ;
    rdfs:comment 'Number of physical retail locations, data centers, or facilities included in the scope of this PCI-DSS assessment.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inScopeSystemsCount rdf:type rdf:Property ;
    rdfs:label 'In Scope Systems Count' ;
    rdfs:comment 'Number of systems, servers, and network devices included in the Cardholder Data Environment (CDE) scope for this assessment.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastVulnerabilityScanDate rdf:type rdf:Property ;
    rdfs:label 'Last Vulnerability Scan Date' ;
    rdfs:comment 'Date of the most recent external vulnerability scan conducted by an Approved Scanning Vendor (ASV) for this assessment period.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:merchantLevel rdf:type rdf:Property ;
    rdfs:label 'Merchant Level' ;
    rdfs:comment 'Merchant classification level based on annual transaction volume as defined by card brands (Visa, Mastercard). Level 1: over 6 million transactions/year; Level 2: 1-6 million; Level 3: 20,000-1 million e-commerce; Level 4: fewer than 20,000 e-commerce or up to 1 million other.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due Date' ;
    rdfs:comment 'Date by which the next PCI-DSS compliance assessment must be completed to maintain continuous compliance status. Typically annual for most merchant levels.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pciDssVersion rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Version' ;
    rdfs:comment 'Version of the PCI-DSS standard against which this assessment was conducted (e.g., 3.2.1, 4.0).' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penetrationTestDate rdf:type rdf:Property ;
    rdfs:label 'Penetration Test Date' ;
    rdfs:comment 'Date of the most recent penetration test conducted on the Cardholder Data Environment (CDE) as required by PCI-DSS requirement 11.3.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penetrationTestPassFlag rdf:type rdf:Property ;
    rdfs:label 'Penetration Test Pass Flag' ;
    rdfs:comment 'Indicates whether the penetration test was successfully completed with all identified vulnerabilities remediated.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qsaFirmName rdf:type rdf:Property ;
    rdfs:label 'Qsa Firm Name' ;
    rdfs:comment 'Name of the external Qualified Security Assessor (QSA) firm that conducted the assessment. Applicable for ROC assessments; null for self-assessments (SAQ).' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Deadline Date' ;
    rdfs:comment 'Target date by which all identified non-compliant items and critical findings must be remediated to achieve full compliance.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationPlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan Required Flag' ;
    rdfs:comment 'Indicates whether a formal remediation plan is required to address failed requirements or critical findings from this assessment.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requirementsFailedCount rdf:type rdf:Property ;
    rdfs:label 'Requirements Failed Count' ;
    rdfs:comment 'Number of PCI-DSS requirements that were not met or failed during this assessment, requiring remediation.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requirementsMetCount rdf:type rdf:Property ;
    rdfs:label 'Requirements Met Count' ;
    rdfs:comment 'Number of PCI-DSS requirements that were fully satisfied and passed during this assessment.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRequirementsCount rdf:type rdf:Property ;
    rdfs:label 'Total Requirements Count' ;
    rdfs:comment 'Total number of PCI-DSS requirements applicable to this assessment based on the assessment type and merchant environment.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vulnerabilityScanPassFlag rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Scan Pass Flag' ;
    rdfs:comment 'Indicates whether the most recent quarterly vulnerability scan received a passing result with no critical vulnerabilities.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vulnerabilityScanVendor rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Scan Vendor' ;
    rdfs:comment 'Name of the PCI Security Standards Council Approved Scanning Vendor (ASV) that conducted quarterly vulnerability scans as part of PCI-DSS requirement 11.2.' ;
    rdfs:domain ind:PciAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciControlId rdf:type rdf:Property ;
    rdfs:label 'Pci Control Id' ;
    rdfs:comment 'Unique identifier for the PCI-DSS security control record. Primary key for the pci_control product.' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this control is currently active and in scope for compliance assessment. False if the control has been retired or is no longer applicable.' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicablePaymentChannels rdf:type rdf:Property ;
    rdfs:label 'Applicable Payment Channels' ;
    rdfs:comment 'Comma-separated list of payment channels this control protects (e.g., Point of Sale (POS), e-commerce, mobile app, call center). Identifies where the control is enforced across the omnichannel payment ecosystem.' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorNotes rdf:type rdf:Property ;
    rdfs:label 'Assessor Notes' ;
    rdfs:comment 'Free-text field for Qualified Security Assessor (QSA) or Internal Security Assessor (ISA) observations, findings, and recommendations related to this control.' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Indicates the degree to which this control is automated versus requiring manual intervention. Helps assess operational efficiency and consistency.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensatingControlFlag rdf:type rdf:Property ;
    rdfs:label 'Compensating Control Flag' ;
    rdfs:comment 'Indicates whether this control is implemented as a compensating control rather than the standard requirement. True if an alternative control approach has been approved.' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compensatingControlJustification rdf:type rdf:Property ;
    rdfs:label 'Compensating Control Justification' ;
    rdfs:comment 'Detailed explanation of why a compensating control is necessary and how it provides equivalent protection to the original requirement. Required documentation for compensating control approval.' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlCategory rdf:type rdf:Property ;
    rdfs:label 'Control Category' ;
    rdfs:comment 'High-level classification of the control type. Groups controls into major security domains for reporting and management purposes.' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlOwnerRole rdf:type rdf:Property ;
    rdfs:label 'Control Owner Role' ;
    rdfs:comment 'The job title or role responsible for implementing and maintaining this control (e.g., Chief Information Security Officer (CISO), IT Security Manager, Network Administrator). Identifies accountability for control execution.' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Date' ;
    rdfs:comment 'The date when this control was first fully implemented and became operational in the payment environment.' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Current state of control implementation. Tracks whether the control is fully operational, in progress, not yet started, addressed through alternative means, or not required for this environment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTestedDate rdf:type rdf:Property ;
    rdfs:label 'Last Tested Date' ;
    rdfs:comment 'The most recent date when this control was formally tested or validated for effectiveness. Used to track testing frequency and identify controls due for re-assessment.' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringTool rdf:type rdf:Property ;
    rdfs:label 'Monitoring Tool' ;
    rdfs:comment 'Name of the security tool, platform, or system used to monitor and enforce this control (e.g., Security Information and Event Management (SIEM), Data Loss Prevention (DLP), Intrusion Detection System (IDS)).' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextTestDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Test Due Date' ;
    rdfs:comment 'The scheduled date for the next required testing or validation of this control. Supports proactive compliance management and audit scheduling.' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyReference rdf:type rdf:Property ;
    rdfs:label 'Policy Reference' ;
    rdfs:comment 'Reference to the internal security policy or procedure document that governs this control. Links operational controls to corporate policy framework.' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Target date by which control deficiencies must be resolved. Used to track progress on compliance improvement initiatives.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Documented action plan to address control gaps or failures. Includes steps, timelines, and resources needed to achieve full compliance.' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementDescription rdf:type rdf:Property ;
    rdfs:label 'Requirement Description' ;
    rdfs:comment 'Full text description of the PCI-DSS requirement as stated in the official standard. Provides the complete regulatory language for this control.' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementNumber rdf:type rdf:Property ;
    rdfs:label 'Requirement Number' ;
    rdfs:comment 'The official PCI-DSS requirement identifier (e.g., 3.4, 6.3.2, 12.1). Maps to the specific section of the PCI-DSS standard that this control addresses.' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResult rdf:type rdf:Property ;
    rdfs:label 'Test Result' ;
    rdfs:comment 'Outcome of the most recent control test. Indicates whether the control is operating effectively as designed.' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingFrequency rdf:type rdf:Property ;
    rdfs:label 'Testing Frequency' ;
    rdfs:comment 'How often this control must be tested per PCI-DSS requirements or internal policy. Defines the cadence for ongoing validation activities. [ENUM-REF-CANDIDATE: continuous|daily|weekly|monthly|quarterly|annually|on_change — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingMethod rdf:type rdf:Property ;
    rdfs:label 'Testing Method' ;
    rdfs:comment 'The methodology used to validate control effectiveness. Aligns with PCI-DSS prescribed testing procedures for each requirement type.' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyDependencyFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Dependency Flag' ;
    rdfs:comment 'Indicates whether this control relies on a third-party service provider or vendor for implementation or operation. True if external dependency exists.' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyProviderName rdf:type rdf:Property ;
    rdfs:label 'Third Party Provider Name' ;
    rdfs:comment 'Name of the third-party service provider responsible for this control, if applicable. Used to track vendor compliance obligations.' ;
    rdfs:domain ind:PciControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyId rdf:type rdf:Property ;
    rdfs:label 'Policy Id' ;
    rdfs:comment 'Unique identifier for the compliance policy record. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:approverAssociateId rdf:type rdf:Property ;
    rdfs:label 'Approver Associate Id' ;
    rdfs:comment 'Identifier of the executive who approved the policy. Typically C-suite or SVP level.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:policyAssociateId rdf:type rdf:Property ;
    rdfs:label 'Policy Associate Id' ;
    rdfs:comment 'Identifier of the employee who owns and is accountable for the policy. Typically a director or VP-level role.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:policyCreatedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Policy Created By User Associate Id' ;
    rdfs:comment 'Identifier of the user who created this policy record. Links to employee or system user master.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:policyModifiedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Policy Modified By User Associate Id' ;
    rdfs:comment 'Identifier of the user who last modified this policy record. Links to employee or system user master.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:supersededPolicyId rdf:type rdf:Property ;
    rdfs:label 'Superseded Policy Id' ;
    rdfs:comment 'Foreign key to the previous version of this policy that this version replaces. Null for initial policy versions. Enables policy lineage tracking.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:acknowledgmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Required Flag' ;
    rdfs:comment 'Indicates whether employees must formally acknowledge they have read and understood the policy. Used for code of conduct and ethics policies.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableBusinessUnits rdf:type rdf:Property ;
    rdfs:label 'Applicable Business Units' ;
    rdfs:comment 'Comma-separated list of business unit codes or names where this policy is enforceable (e.g., \'Retail Stores, E-Commerce, Distribution Centers\'). \'All\' indicates enterprise-wide applicability.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableLocations rdf:type rdf:Property ;
    rdfs:label 'Applicable Locations' ;
    rdfs:comment 'Geographic scope of the policy. May specify countries, regions, or \'Global\' for worldwide applicability. Drives jurisdiction-specific compliance requirements.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionScope rdf:type rdf:Property ;
    rdfs:label 'Distribution Scope' ;
    rdfs:comment 'Target audience for policy distribution. Determines who receives policy notifications and has access to the policy document.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'Hyperlink or file path to the full policy document in the document management system. Provides access to detailed procedures and guidelines.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentVersion rdf:type rdf:Property ;
    rdfs:label 'Document Version' ;
    rdfs:comment 'Version identifier of the linked policy document. Should match the policy version field for consistency.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementMechanism rdf:type rdf:Property ;
    rdfs:label 'Enforcement Mechanism' ;
    rdfs:comment 'Description of how policy compliance is monitored and enforced (e.g., \'Quarterly audits\', \'Automated system controls\', \'Manager spot checks\').' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalPublicationFlag rdf:type rdf:Property ;
    rdfs:label 'External Publication Flag' ;
    rdfs:comment 'Indicates whether this policy is published externally (e.g., on corporate website, in supplier portals). True for supplier codes of conduct and public-facing policies.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next mandatory policy review cycle. Driven by regulatory requirements or internal governance standards.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerRole rdf:type rdf:Property ;
    rdfs:label 'Owner Role' ;
    rdfs:comment 'Job title or role of the policy owner (e.g., VP of Compliance, Director of Food Safety, Chief Privacy Officer).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyCategory rdf:type rdf:Property ;
    rdfs:label 'Policy Category' ;
    rdfs:comment 'High-level grouping of the policy by business function. Used for policy library organization and reporting. [ENUM-REF-CANDIDATE: regulatory_compliance|operational_standard|safety_protocol|security_control|privacy_protection|ethical_conduct|environmental_stewardship — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'Business-facing unique identifier for the policy, formatted as POL-{TYPE}-{SEQUENCE}. Used in policy communications and references.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyScope rdf:type rdf:Property ;
    rdfs:label 'Policy Scope' ;
    rdfs:comment 'Detailed description of what business processes, systems, or activities this policy governs. Defines boundaries of applicability.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedPolicies rdf:type rdf:Property ;
    rdfs:label 'Related Policies' ;
    rdfs:comment 'Comma-separated list of policy IDs or policy numbers that are related or cross-referenced by this policy. Enables policy network analysis.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Number of months between mandatory policy reviews. Typically 12, 24, or 36 months depending on regulatory requirements and risk level.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Training Frequency Months' ;
    rdfs:comment 'Number of months between mandatory training refreshers for this policy. Null if training is one-time only.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether employees in applicable business units must complete training on this policy. True triggers training assignment workflows.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:violationPenaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Violation Penalty Description' ;
    rdfs:comment 'Description of consequences for policy violations, ranging from retraining to termination. May reference disciplinary action matrix.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Privacy Assessment Id' ;
    rdfs:comment 'Unique identifier for the privacy assessment record. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivacyAssessment .

ind:triggeringCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Triggering Customer Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Privacy impact assessments may be triggered by new account types or processing activities (e.g., B2B accounts with special data handling). Links assessment to business process being evaluated.' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:assessmentCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Completion Date' ;
    rdfs:comment 'Date when the privacy assessment was finalized and approved.' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentMethodology rdf:type rdf:Property ;
    rdfs:label 'Assessment Methodology' ;
    rdfs:comment 'Framework or methodology used to conduct the privacy assessment (e.g., \'ISO/IEC 29134\', \'NIST Privacy Framework\', \'CNIL DPIA methodology\', \'ICO DPIA guidance\', \'Internal privacy assessment framework\').' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentName rdf:type rdf:Property ;
    rdfs:label 'Assessment Name' ;
    rdfs:comment 'Business-friendly name or title of the privacy assessment (e.g., \'Customer Loyalty Program DPIA\', \'E-Commerce Platform PIA\').' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Assessment Outcome' ;
    rdfs:comment 'Final outcome of the privacy assessment: approved (no significant risks, proceed), approved_with_conditions (proceed with mandatory mitigations), rejected (unacceptable risk, do not proceed), requires_consultation (high residual risk requiring supervisory authority consultation per GDPR Article 36).' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle status of the privacy assessment: draft (initial preparation), in_review (under business review), dpo_review (awaiting DPO validation), completed (finalized and approved), archived (historical record).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorRole rdf:type rdf:Property ;
    rdfs:label 'Assessor Role' ;
    rdfs:comment 'Role or title of the assessor (e.g., \'Privacy Analyst\', \'Compliance Manager\', \'Data Protection Officer\', \'Information Security Manager\').' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedDecisionMaking rdf:type rdf:Property ;
    rdfs:label 'Automated Decision Making' ;
    rdfs:comment 'Indicates whether the assessed process involves automated decision-making or profiling that produces legal or similarly significant effects on data subjects. True if automated decision-making is present, False otherwise. Required disclosure under GDPR Article 22.' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessProcess rdf:type rdf:Property ;
    rdfs:label 'Business Process' ;
    rdfs:comment 'The retail business process or function being assessed (e.g., \'Customer Loyalty and Engagement Programs\', \'E-Commerce and Digital Commerce Operations\', \'Order Fulfillment and Last-Mile Delivery\', \'Workforce Management\').' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'Business unit or division responsible for the assessed process or system (e.g., \'E-Commerce\', \'Store Operations\', \'Supply Chain\', \'Human Resources\', \'Marketing\').' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childrenDataProcessing rdf:type rdf:Property ;
    rdfs:label 'Children Data Processing' ;
    rdfs:comment 'Indicates whether the assessed process involves processing personal data of children (individuals under 16 years of age, or lower age as defined by member state law). True if children\'s data is processed, False otherwise. Requires parental consent under GDPR Article 8.' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consultationDate rdf:type rdf:Property ;
    rdfs:label 'Consultation Date' ;
    rdfs:comment 'Date when the supervisory authority was consulted regarding high-risk processing. Applicable only if supervisory_authority_consulted is True.' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consultationOutcome rdf:type rdf:Property ;
    rdfs:label 'Consultation Outcome' ;
    rdfs:comment 'Summary of the supervisory authority\'s response or guidance following consultation (e.g., \'Approved with additional safeguards\', \'Requires further mitigation\', \'Processing prohibited\').' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPeriod rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period' ;
    rdfs:comment 'Defined retention period for personal data processed in the assessed system or process (e.g., \'7 years\', \'90 days post-transaction\', \'Duration of employment plus 3 years\'). Required for GDPR Article 5(1)(e) storage limitation principle.' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectRightsSupported rdf:type rdf:Property ;
    rdfs:label 'Data Subject Rights Supported' ;
    rdfs:comment 'Data subject rights mechanisms implemented in the assessed system or process (e.g., \'Right to access\', \'Right to rectification\', \'Right to erasure (right to be forgotten)\', \'Right to data portability\', \'Right to object\', \'Right to restrict processing\'). Comma-separated list per GDPR Chapter III.' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjects rdf:type rdf:Property ;
    rdfs:label 'Data Subjects' ;
    rdfs:comment 'Categories of individuals whose personal data is processed (e.g., \'Customers\', \'Employees\', \'Minors\', \'Suppliers\', \'Job applicants\'). Comma-separated list.' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataTransferCountries rdf:type rdf:Property ;
    rdfs:label 'Data Transfer Countries' ;
    rdfs:comment 'Countries or regions to which personal data is transferred (e.g., \'USA\', \'GBR\', \'IND\', \'EU\'). Required for GDPR Chapter V compliance on international data transfers. Comma-separated ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoReviewDate rdf:type rdf:Property ;
    rdfs:label 'Dpo Review Date' ;
    rdfs:comment 'Date when the Data Protection Officer reviewed and validated the privacy assessment. Required for GDPR Article 35(2) compliance.' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dpoReviewerName rdf:type rdf:Property ;
    rdfs:label 'Dpo Reviewer Name' ;
    rdfs:comment 'Full name of the Data Protection Officer who reviewed the assessment.' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Geographic regions or jurisdictions where the assessed processing activities occur (e.g., \'European Union\', \'United States\', \'California\', \'Global\'). Comma-separated list.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'Legal basis for processing personal data under GDPR Article 6: consent, contract (performance of contract), legal_obligation (compliance with legal obligation), vital_interests (protection of vital interests), public_task (public interest or official authority), legitimate_interests (legitimate interests pursued by controller or third party).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationsApplied rdf:type rdf:Property ;
    rdfs:label 'Mitigations Applied' ;
    rdfs:comment 'Privacy risk mitigation measures implemented or planned (e.g., \'Encryption of data at rest and in transit\', \'Role-based access controls\', \'Data minimization procedures\', \'Automated data retention policies\', \'Privacy-by-design architecture\', \'Third-party data processing agreements\'). Comma-separated or narrative format.' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalDataCategories rdf:type rdf:Property ;
    rdfs:label 'Personal Data Categories' ;
    rdfs:comment 'Categories of personal data involved in the assessed process or system (e.g., \'Contact information (email, phone)\', \'Purchase history\', \'Payment card data\', \'Geolocation data\', \'Biometric data\', \'Employee performance records\'). Comma-separated list.' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyRisksIdentified rdf:type rdf:Property ;
    rdfs:label 'Privacy Risks Identified' ;
    rdfs:comment 'Summary of privacy risks identified during the assessment (e.g., \'Unauthorized access to customer PII\', \'Excessive data retention\', \'Lack of consent mechanism\', \'Third-party data sharing without adequate safeguards\', \'Inadequate data subject rights procedures\'). Comma-separated or narrative format.' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingPurpose rdf:type rdf:Property ;
    rdfs:label 'Processing Purpose' ;
    rdfs:comment 'Business purpose for processing personal data (e.g., \'Customer relationship management\', \'Order fulfillment\', \'Marketing and promotions\', \'Workforce scheduling\', \'Fraud prevention\').' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFrameworks rdf:type rdf:Property ;
    rdfs:label 'Regulatory Frameworks' ;
    rdfs:comment 'Privacy and data protection regulations applicable to the assessed processing (e.g., \'GDPR\', \'CCPA\', \'CPRA\', \'LGPD\', \'PIPEDA\', \'HIPAA\', \'PCI DSS\'). Comma-separated list.' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Level' ;
    rdfs:comment 'Privacy risk level remaining after mitigation measures have been applied. Used to determine if additional controls are required or if the risk is acceptable.' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialCategoryData rdf:type rdf:Property ;
    rdfs:label 'Special Category Data' ;
    rdfs:comment 'Indicates whether the assessed process involves special categories of personal data (racial/ethnic origin, political opinions, religious beliefs, trade union membership, genetic data, biometric data, health data, sex life, sexual orientation). True if special category data is processed, False otherwise. Requires heightened protection under GDPR Article 9.' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisoryAuthorityConsulted rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Consulted' ;
    rdfs:comment 'Indicates whether the supervisory authority (data protection authority) was consulted prior to processing, as required when a DPIA indicates high residual risk. True if consultation occurred, False otherwise. Required under GDPR Article 36 for high-risk processing.' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:systemName rdf:type rdf:Property ;
    rdfs:label 'System Name' ;
    rdfs:comment 'Name of the operational system or platform being assessed (e.g., \'Salesforce Commerce Cloud\', \'SAP S/4HANA Retail\', \'Workday HCM\', \'Informatica MDM\').' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyProcessors rdf:type rdf:Property ;
    rdfs:label 'Third Party Processors' ;
    rdfs:comment 'Names of third-party data processors or vendors involved in processing personal data (e.g., \'AWS\', \'Google Cloud\', \'Salesforce\', \'Payment gateway provider\'). Comma-separated list.' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferSafeguards rdf:type rdf:Property ;
    rdfs:label 'Transfer Safeguards' ;
    rdfs:comment 'Legal mechanisms used to safeguard international data transfers (e.g., \'Standard Contractual Clauses (SCC)\', \'Binding Corporate Rules (BCR)\', \'Adequacy Decision\', \'Privacy Shield (legacy)\', \'Explicit consent\').' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringEvent rdf:type rdf:Property ;
    rdfs:label 'Triggering Event' ;
    rdfs:comment 'Business event or initiative that triggered the privacy assessment (e.g., \'New CRM system implementation\', \'Third-party data sharing agreement\', \'Marketing campaign launch\', \'Process change in order fulfillment\').' ;
    rdfs:domain ind:PrivacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Unique identifier for the regulatory filing record. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:primaryRegulatoryFacilityDcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Facility Dc Facility Id' ;
    rdfs:comment 'Identifier of the retail facility, store, distribution center, or warehouse to which this filing pertains. Links the filing to the specific operational location subject to regulatory oversight.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:regulatoryAgencyId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency Id' ;
    rdfs:comment 'FK to compliance.regulatory_agency' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAgency .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date when the regulatory agency officially accepted the filing as complete and compliant. Represents successful fulfillment of the regulatory requirement.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'Date when the regulatory agency formally acknowledged receipt of the filing. Marks the beginning of the review process.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Number' ;
    rdfs:comment 'Official certification or attestation number issued by the regulatory agency upon successful acceptance of the filing. Serves as proof of compliance for audit purposes.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Date when the regulatory filing was officially submitted to the regulatory agency. This is the business event date for compliance tracking and audit purposes.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingDescription rdf:type rdf:Property ;
    rdfs:label 'Filing Description' ;
    rdfs:comment 'Detailed narrative description of the filing content, purpose, and scope. Provides context for compliance auditors and internal stakeholders.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Filing Document Url' ;
    rdfs:comment 'Uniform Resource Locator (URL) or file path to the stored copy of the submitted filing document. Provides access to the official record for audit and reference purposes.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Amount' ;
    rdfs:comment 'Monetary fee charged by the regulatory agency for processing this filing. Captured in the base currency of the business (USD for US-based retail operations).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filingFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the filing fee amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Filing Jurisdiction' ;
    rdfs:comment 'Geographic or legal jurisdiction under which this filing is required (e.g., Federal, State of California, European Union). Identifies the scope of regulatory authority.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Number' ;
    rdfs:comment 'External reference number or confirmation number assigned by the regulatory agency upon submission. Used for tracking and correspondence with the regulatory body.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period End Date' ;
    rdfs:comment 'End date of the reporting period covered by this regulatory filing. Defines the conclusion of the time window for which compliance data is being reported.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period Start Date' ;
    rdfs:comment 'Start date of the reporting period covered by this regulatory filing. Defines the beginning of the time window for which compliance data is being reported.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory filing. Tracks progression from draft through submission to final disposition by the regulatory agency. [ENUM-REF-CANDIDATE: DRAFT|SUBMITTED|ACKNOWLEDGED|ACCEPTED|REJECTED|UNDER_REVIEW|PENDING_CORRECTION|WITHDRAWN|EXPIRED — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'Category of regulatory filing or submission. Identifies the specific regulatory requirement being fulfilled (e.g., FDA food facility registration, OSHA 300A annual summary, environmental permit renewal, state liquor license renewal, PCI attestation of compliance). [ENUM-REF-CANDIDATE: FDA_FOOD_FACILITY_REGISTRATION|OSHA_300A_ANNUAL_SUMMARY|ENVIRONMENTAL_PERMIT_RENEWAL|STATE_LIQUOR_LICENSE_RENEWAL|PCI_ATTESTATION_OF_COMPLIANCE|GDPR_DATA_BREACH_NOTIFICATION|CCPA_CONSUMER_REQUEST_REPORT|FTC_ADVERTISING_DISCLOSURE|CPSC_PRODUCT_RECALL_REPORT|EEO_WORKFORCE_REPORT|EPA_HAZARDOUS_WASTE_REPORT|STATE_SALES_TAX_FILING|CUSTOMS_IMPORT_DECLARATION|FSMA_PREVENTIVE_CONTROLS_PLAN|OTHER — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFilingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Filing Due Date' ;
    rdfs:comment 'Scheduled due date for the next required filing of this type. Used for compliance calendar management and proactive deadline tracking.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'Reference number or transaction identifier for the payment of the filing fee. Links the filing to the corresponding financial transaction for reconciliation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date when the regulatory agency rejected the filing due to incompleteness, errors, or non-compliance. Triggers corrective action and resubmission workflow.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Detailed explanation provided by the regulatory agency for rejecting the filing. Documents the specific deficiencies or compliance gaps that must be addressed for resubmission.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Resubmission Required Flag' ;
    rdfs:comment 'Boolean indicator of whether this filing requires resubmission due to rejection or requested corrections. True indicates resubmission is needed; False indicates no resubmission required.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Confirmation Number' ;
    rdfs:comment 'Confirmation or tracking number provided by the submission system or regulatory agency upon receipt of the filing. Used for proof of submission and follow-up inquiries.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Channel or mechanism used to submit the filing to the regulatory agency (e.g., online portal, EDI, mail, in-person delivery). [ENUM-REF-CANDIDATE: ONLINE_PORTAL|EDI|EMAIL|POSTAL_MAIL|FAX|IN_PERSON|API|OTHER — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRegisterId rdf:type rdf:Property ;
    rdfs:label 'Risk Register Id' ;
    rdfs:comment 'Unique identifier for the compliance risk register entry. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskRegister .

ind:primaryRiskOwnerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Risk Owner Associate Id' ;
    rdfs:comment 'FK to workforce.associate' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:relatedIncidentOshaIncidentId rdf:type rdf:Property ;
    rdfs:label 'Related Incident Osha Incident Id' ;
    rdfs:comment 'Identifier of a compliance incident or violation event that is linked to this risk, supporting root cause analysis and trend identification.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OshaIncident .

ind:tertiaryRiskIdentifiedByAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Risk Identified By Associate Id' ;
    rdfs:comment 'Identifier of the employee, auditor, or system that identified the risk.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:actualClosureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Date' ;
    rdfs:comment 'Date when the risk was formally closed after successful mitigation or acceptance, enabling performance tracking against target dates.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedLocations rdf:type rdf:Property ;
    rdfs:label 'Affected Locations' ;
    rdfs:comment 'Comma-separated list or description of stores, distribution centers, or facilities where this risk is present, enabling geographic risk analysis.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlEffectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Control Effectiveness Rating' ;
    rdfs:comment 'Assessment of how well existing controls mitigate the risk on a scale of 1 (ineffective) to 5 (highly effective), based on control testing, audit results, and operational performance.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financialImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Estimate' ;
    rdfs:comment 'Estimated monetary cost if the risk materializes, including potential fines, penalties, remediation costs, legal fees, and business disruption losses.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactRating rdf:type rdf:Property ;
    rdfs:label 'Impact Rating' ;
    rdfs:comment 'Severity assessment of the consequences if the risk materializes on a scale of 1 (negligible) to 5 (catastrophic), considering financial, reputational, operational, and legal impacts.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inherentRiskScore rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Score' ;
    rdfs:comment 'Calculated risk exposure before considering controls, computed as likelihood_rating multiplied by impact_rating (range 1-25), representing the raw risk level.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date of the most recent risk assessment review, when likelihood, impact, and control effectiveness were re-evaluated.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:likelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Likelihood Rating' ;
    rdfs:comment 'Probability assessment of the risk occurring on a scale of 1 (rare) to 5 (almost certain), based on historical data, control environment, and operational exposure.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mitigationStrategy rdf:type rdf:Property ;
    rdfs:label 'Mitigation Strategy' ;
    rdfs:comment 'Detailed action plan describing controls, processes, training, technology, or policy changes implemented or planned to reduce the risk to an acceptable level.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskScore rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Score' ;
    rdfs:comment 'Net risk exposure after applying control effectiveness, calculated by adjusting inherent risk score based on control strength, representing the current risk level the organization carries.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Cadence for periodic risk reassessment, aligned with the risk level and regulatory requirements.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Primary regulatory domain classification of the risk: food safety (FDA/FSMA), workplace safety (OSHA), payment security (PCI-DSS), data privacy (GDPR/CCPA), environmental regulations, or labor law compliance.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskNumber rdf:type rdf:Property ;
    rdfs:label 'Risk Number' ;
    rdfs:comment 'Business-facing unique identifier for the risk entry, formatted as RISK-NNNNNN for external communication and tracking.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRegisterDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Register Description' ;
    rdfs:comment 'Comprehensive narrative describing the nature of the compliance risk, potential violation scenarios, affected operations, and regulatory context.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRegisterStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Register Status' ;
    rdfs:comment 'Current lifecycle state of the risk: open (identified, not yet addressed), in_progress (mitigation underway), mitigated (controls implemented), accepted (formally acknowledged), or closed (no longer applicable).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskResponseType rdf:type rdf:Property ;
    rdfs:label 'Risk Response Type' ;
    rdfs:comment 'Strategic approach to managing the risk: mitigate (reduce likelihood/impact), accept (acknowledge and monitor), transfer (insurance or third-party), or avoid (eliminate the activity).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSubcategory rdf:type rdf:Property ;
    rdfs:label 'Risk Subcategory' ;
    rdfs:comment 'Detailed classification within the primary risk category, providing granular segmentation for specialized compliance tracking (e.g., allergen labeling, forklift safety, cardholder data storage).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetClosureDate rdf:type rdf:Property ;
    rdfs:label 'Target Closure Date' ;
    rdfs:comment 'Planned date by which mitigation actions should be completed and the risk reduced to an acceptable level or closed.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyInspectionId rdf:type rdf:Property ;
    rdfs:label 'Safety Inspection Id' ;
    rdfs:comment 'Unique identifier for the workplace safety inspection record. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyInspection .

ind:checklistVersion rdf:type rdf:Property ;
    rdfs:label 'Checklist Version' ;
    rdfs:comment 'Version identifier of the safety inspection checklist or protocol used during this inspection. Ensures traceability to specific compliance standards.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Score' ;
    rdfs:comment 'Calculated compliance score or percentage representing the overall safety compliance level achieved during the inspection (0-100 scale).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionDeadline rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Deadline' ;
    rdfs:comment 'Deadline date by which all corrective actions must be completed to achieve compliance.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:criticalViolationsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Violations Count' ;
    rdfs:comment 'Number of critical or high-severity safety violations identified that pose immediate risk to employee safety or regulatory non-compliance.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emergencyPreparednessCompliant rdf:type rdf:Property ;
    rdfs:label 'Emergency Preparedness Compliant' ;
    rdfs:comment 'Indicates whether emergency preparedness standards were met including evacuation plans, emergency lighting, first aid kits, and emergency contact information.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentSafetyCompliant rdf:type rdf:Property ;
    rdfs:label 'Equipment Safety Compliant' ;
    rdfs:comment 'Indicates whether equipment safety standards were met including machine guarding, lockout/tagout procedures, and powered industrial truck safety.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ergonomicsCompliant rdf:type rdf:Property ;
    rdfs:label 'Ergonomics Compliant' ;
    rdfs:comment 'Indicates whether workplace ergonomics standards were met to prevent musculoskeletal disorders including workstation setup, lifting procedures, and repetitive motion controls.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fireSafetyCompliant rdf:type rdf:Property ;
    rdfs:label 'Fire Safety Compliant' ;
    rdfs:comment 'Indicates whether the location passed fire safety inspection criteria including fire extinguishers, alarms, exits, and sprinkler systems.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followupInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Followup Inspection Date' ;
    rdfs:comment 'Scheduled date for the follow-up inspection to verify corrective action completion.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followupInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Followup Inspection Required' ;
    rdfs:comment 'Indicates whether a follow-up inspection is required to verify that corrective actions have been completed.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatStorageCompliant rdf:type rdf:Property ;
    rdfs:label 'Hazmat Storage Compliant' ;
    rdfs:comment 'Indicates whether hazardous materials and chemical storage met OSHA and EPA standards including proper labeling, SDS availability, and containment.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Inspection Duration Minutes' ;
    rdfs:comment 'Total duration of the inspection in minutes from start to completion.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Free-text notes and observations recorded by the inspector during the safety inspection including specific findings, recommendations, and context.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Business-assigned unique inspection number or reference code for tracking and audit purposes.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionScope rdf:type rdf:Property ;
    rdfs:label 'Inspection Scope' ;
    rdfs:comment 'Description of the areas, departments, or systems covered by this inspection (e.g., sales floor, warehouse, loading dock, HVAC systems, emergency exits).' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle status of the safety inspection: scheduled, in progress, completed, cancelled, or pending review by management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Classification of the inspection: routine scheduled inspection, triggered by incident or complaint, pre-opening inspection for new facility, regulatory inspection by external authority, incident follow-up, or annual comprehensive audit.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Inspector Certification Number' ;
    rdfs:comment 'Professional certification or license number of the inspector (e.g., Certified Safety Professional, OSHA 30-Hour certification).' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorRole rdf:type rdf:Property ;
    rdfs:label 'Inspector Role' ;
    rdfs:comment 'Job title or role of the inspector (e.g., Safety Manager, EHS Specialist, Regional Safety Auditor, Third-Party Auditor).' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemsFailed rdf:type rdf:Property ;
    rdfs:label 'Items Failed' ;
    rdfs:comment 'Number of inspection items that did not meet safety standards and failed the inspection.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itemsPassed rdf:type rdf:Property ;
    rdfs:label 'Items Passed' ;
    rdfs:comment 'Number of inspection items that met safety standards and passed the inspection.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:locationManagerNotified rdf:type rdf:Property ;
    rdfs:label 'Location Manager Notified' ;
    rdfs:comment 'Indicates whether the location or facility manager was notified of the inspection results and required corrective actions.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:majorViolationsCount rdf:type rdf:Property ;
    rdfs:label 'Major Violations Count' ;
    rdfs:comment 'Number of major safety violations identified that require corrective action but do not pose immediate danger.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorViolationsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Violations Count' ;
    rdfs:comment 'Number of minor safety violations or observations that represent best-practice improvements but are not regulatory violations.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Overall outcome of the safety inspection: pass (full compliance), pass with observations (compliant but improvements recommended), fail (non-compliant, corrective action required), or conditional pass (compliant pending minor corrections).' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityNotified rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notified' ;
    rdfs:comment 'Indicates whether external regulatory authorities (OSHA, local fire marshal, etc.) were notified of inspection results or violations.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Report Document Url' ;
    rdfs:comment 'URL or file path to the detailed safety inspection report document stored in the document management system.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportGeneratedDate rdf:type rdf:Property ;
    rdfs:label 'Report Generated Date' ;
    rdfs:comment 'Date on which the formal safety inspection report was generated and distributed to stakeholders.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalItemsInspected rdf:type rdf:Property ;
    rdfs:label 'Total Items Inspected' ;
    rdfs:comment 'Total number of checklist items, safety points, or equipment units evaluated during the inspection.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thirdPartyAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Third Party Assessment Id' ;
    rdfs:comment 'Unique identifier for the third-party compliance assessment record.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThirdPartyAssessment .

ind:businessUnitId rdf:type rdf:Property ;
    rdfs:label 'Business Unit Id' ;
    rdfs:comment 'Identifier for the Retail business unit or division that owns the relationship with this third party.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:primaryThirdAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Third Associate Id' ;
    rdfs:comment 'Identifier for the internal employee or external auditor who conducted the third-party compliance assessment.' ;
    rdfs:domain ind:ThirdPartyAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'The methodology or approach used to conduct the third-party compliance assessment.' ;
    rdfs:domain ind:ThirdPartyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentResult rdf:type rdf:Property ;
    rdfs:label 'Assessment Result' ;
    rdfs:comment 'Overall outcome of the third-party compliance assessment indicating whether the third party meets the required compliance standards.' ;
    rdfs:domain ind:ThirdPartyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Numerical score or rating assigned to the third-party based on the compliance assessment, typically expressed as a percentage or on a defined scale.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractualObligations rdf:type rdf:Property ;
    rdfs:label 'Contractual Obligations' ;
    rdfs:comment 'Summary of the specific compliance obligations and requirements that the third party is contractually bound to meet as part of their service agreement with Retail.' ;
    rdfs:domain ind:ThirdPartyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Data Access Level' ;
    rdfs:comment 'Classification of the type and sensitivity of data that the third party has access to as part of their service delivery.' ;
    rdfs:domain ind:ThirdPartyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProcessingAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Data Processing Agreement Status' ;
    rdfs:comment 'Current status of the Data Processing Agreement between Retail and the third-party data processor, required under GDPR Article 28 for entities processing personal data on behalf of Retail.' ;
    rdfs:domain ind:ThirdPartyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpaExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Dpa Execution Date' ;
    rdfs:comment 'The date on which the Data Processing Agreement was signed and became effective.' ;
    rdfs:domain ind:ThirdPartyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dpaExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Dpa Expiration Date' ;
    rdfs:comment 'The date on which the Data Processing Agreement expires and requires renewal or renegotiation.' ;
    rdfs:domain ind:ThirdPartyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingsCount rdf:type rdf:Property ;
    rdfs:label 'Findings Count' ;
    rdfs:comment 'Total number of compliance findings, issues, or deficiencies identified during the third-party assessment.' ;
    rdfs:domain ind:ThirdPartyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:highFindingsCount rdf:type rdf:Property ;
    rdfs:label 'High Findings Count' ;
    rdfs:comment 'Number of high-severity compliance findings identified during the assessment.' ;
    rdfs:domain ind:ThirdPartyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lowFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Low Findings Count' ;
    rdfs:comment 'Number of low-severity compliance findings identified during the assessment.' ;
    rdfs:domain ind:ThirdPartyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mediumFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Medium Findings Count' ;
    rdfs:comment 'Number of medium-severity compliance findings identified during the assessment.' ;
    rdfs:domain ind:ThirdPartyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remediationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Remediation Required Flag' ;
    rdfs:comment 'Indicates whether corrective actions or remediation activities are required based on the assessment findings.' ;
    rdfs:domain ind:ThirdPartyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of remediation efforts undertaken by the third party to address assessment findings.' ;
    rdfs:domain ind:ThirdPartyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyName rdf:type rdf:Property ;
    rdfs:label 'Third Party Name' ;
    rdfs:comment 'Legal or business name of the third-party entity being assessed for compliance.' ;
    rdfs:domain ind:ThirdPartyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyType rdf:type rdf:Property ;
    rdfs:label 'Third Party Type' ;
    rdfs:comment 'Classification of the third-party entity based on the services or products they provide to Retail. [ENUM-REF-CANDIDATE: data_processor|food_supplier|waste_hauler|security_vendor|payment_processor|logistics_provider|technology_vendor|marketing_agency|facility_services|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ThirdPartyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionId rdf:type rdf:Property ;
    rdfs:label 'Training Completion Id' ;
    rdfs:comment 'Unique identifier for the training completion record. Primary key for this transactional record of compliance training completion.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCompletion .

ind:authorizedPromoCampaignId rdf:type rdf:Property ;
    rdfs:label 'Authorized Promo Campaign Id' ;
    rdfs:comment 'Foreign key linking to promotion.promo_campaign. Business justification: Associates completing compliance training (alcohol sales certification, pharmacy promotion authorization, tobacco handling) are authorized to execute specific regulated promotional campaigns. Links tr' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoCampaign .

ind:primaryTrainingAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Training Associate Id' ;
    rdfs:comment 'Unique identifier of the retail associate who completed the training. Links to the workforce associate master record.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:tertiaryTrainingWaiverApprovedByAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Training Waiver Approved By Associate Id' ;
    rdfs:comment 'Identifier of the manager or compliance officer who approved the training waiver, if applicable. Null if no waiver was granted.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:trainingLocationId rdf:type rdf:Property ;
    rdfs:label 'Training Location Id' ;
    rdfs:comment 'Identifier of the physical location (store, distribution center, training facility) where the training was conducted, if applicable for in-person sessions.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:trainingProgramId rdf:type rdf:Property ;
    rdfs:label 'Training Program Id' ;
    rdfs:comment 'Identifier of the specific training course or module completed by the associate. Links to the training course catalog.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingProgram .

ind:trainingVendorId rdf:type rdf:Property ;
    rdfs:label 'Training Vendor Id' ;
    rdfs:comment 'Identifier of the third-party training vendor or certification body that provided the training content or certification, if applicable.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:attemptNumber rdf:type rdf:Property ;
    rdfs:label 'Attempt Number' ;
    rdfs:comment 'Sequential number indicating which attempt this represents if the associate took the training multiple times (1 for first attempt, 2 for second, etc.).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued Date' ;
    rdfs:comment 'Date on which the certificate of completion was officially issued to the associate.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date on which the associate successfully completed the compliance training program. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionNumber rdf:type rdf:Property ;
    rdfs:label 'Completion Number' ;
    rdfs:comment 'Business-facing unique completion record number assigned by the learning management system for tracking and audit purposes.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Precise timestamp when the associate completed the final assessment or training module, recorded by the learning management system.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method by which the training was delivered to the associate. Distinguishes between online self-paced, instructor-led classroom, virtual sessions, and on-the-job training.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobRoleCategory rdf:type rdf:Property ;
    rdfs:label 'Job Role Category' ;
    rdfs:comment 'Category of job role for which this training is required (e.g., Food Handler, Forklift Operator, Manager, Cashier, Security Personnel). Used for role-based compliance tracking.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Boolean indicator of whether this training is mandatory for the associates role and compliance requirements (True) or optional/recommended (False).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passFailResult rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Result' ;
    rdfs:comment 'Outcome of the training assessment indicating whether the associate passed, failed, was waived, or was exempt from the requirement.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'Minimum score required to pass the training assessment, expressed as a percentage. Used to determine pass/fail result.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recertificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Recertification Due Date' ;
    rdfs:comment 'Date by which the associate must complete recertification training to maintain compliance status. Calculated based on certification expiration and advance notice requirements.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Training Duration Hours' ;
    rdfs:comment 'Total duration in hours that the associate spent completing the training program, including all modules and assessments.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Date' ;
    rdfs:comment 'Date on which the training waiver was approved by the authorized manager or compliance officer. Null if no waiver was granted.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accessibilityCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Accessibility Compliant Flag' ;
    rdfs:comment 'Indicates whether the training program meets ADA and WCAG 2.1 accessibility standards for associates with disabilities (True/False).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:annualEnrollmentTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Enrollment Target' ;
    rdfs:comment 'Target number of associates expected to complete this training program annually, used for capacity planning and compliance tracking.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Assessment Required Flag' ;
    rdfs:comment 'Indicates whether the training program requires a formal assessment or exam for completion (True) or is completion-based only (False).' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Issued Flag' ;
    rdfs:comment 'Indicates whether successful completion of this training results in a formal certification or credential (True) or is for awareness only (False).' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationValidityMonths rdf:type rdf:Property ;
    rdfs:label 'Certification Validity Months' ;
    rdfs:comment 'Number of months the certification remains valid before renewal is required. Null if certification does not expire or training is one-time only.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionFrequency rdf:type rdf:Property ;
    rdfs:label 'Completion Frequency' ;
    rdfs:comment 'Required frequency for associates to complete or renew this training (one-time upon hire, annual recertification, biennial, triennial, quarterly, as-needed based on role change).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentLastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Content Last Updated Date' ;
    rdfs:comment 'Date when the training curriculum content was last revised or updated.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:continuingEducationCredits rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Credits' ;
    rdfs:comment 'Number of continuing education units (CEUs) or professional development credits awarded upon successful completion, if applicable. Null if not applicable.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerLearner rdf:type rdf:Property ;
    rdfs:label 'Cost Per Learner' ;
    rdfs:comment 'Average cost per associate to deliver this training program, including vendor fees, materials, and instructor time. Used for budget planning and ROI analysis.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseMaterialsUrl rdf:type rdf:Property ;
    rdfs:label 'Course Materials Url' ;
    rdfs:comment 'URL or file path to the training course materials, curriculum guide, or e-learning module.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Expected duration of the training program in hours (e.g., 2.5 hours for e-learning, 10 hours for OSHA 10-hour certification).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobRoleScope rdf:type rdf:Property ;
    rdfs:label 'Job Role Scope' ;
    rdfs:comment 'Comma-separated list of job roles or job families required to complete this training (e.g., FOOD_HANDLER, CASHIER, STORE_MGR, IT_ADMIN, WAREHOUSE_ASSOC).' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageAvailability rdf:type rdf:Property ;
    rdfs:label 'Language Availability' ;
    rdfs:comment 'Comma-separated list of language codes (ISO 639-1) in which the training content is available (e.g., EN, ES, FR, ZH).' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningManagementSystemCode rdf:type rdf:Property ;
    rdfs:label 'Learning Management System Code' ;
    rdfs:comment 'External identifier for this training program in the corporate Learning Management System (LMS) platform (e.g., Workday Learning, Cornerstone, SAP SuccessFactors).' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningDepartment rdf:type rdf:Property ;
    rdfs:label 'Owning Department' ;
    rdfs:comment 'Business unit or department responsible for maintaining and administering this training program (e.g., Compliance, Human Resources, IT Security, Store Operations).' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyReferenceDocument rdf:type rdf:Property ;
    rdfs:label 'Policy Reference Document' ;
    rdfs:comment 'Reference to the corporate policy or regulatory standard document that mandates this training (e.g., POL-COMP-001 Food Safety Policy, OSHA 1910.120 Hazardous Waste Operations).' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prerequisitePrograms rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Programs' ;
    rdfs:comment 'Comma-separated list of training program codes that must be completed before enrolling in this program. Null if no prerequisites.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programOwnerName rdf:type rdf:Property ;
    rdfs:label 'Program Owner Name' ;
    rdfs:comment 'Name of the individual responsible for the training program content, compliance, and administration.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingFormat rdf:type rdf:Property ;
    rdfs:label 'Training Format' ;
    rdfs:comment 'Delivery method for the training program (in-person classroom, e-learning module, virtual instructor-led, on-the-job training, blended approach, self-paced online).' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingProgramDescription rdf:type rdf:Property ;
    rdfs:label 'Training Program Description' ;
    rdfs:comment 'Detailed description of the training program objectives, learning outcomes, and content coverage.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorProviderName rdf:type rdf:Property ;
    rdfs:label 'Vendor Provider Name' ;
    rdfs:comment 'Name of the third-party vendor or training provider delivering the program content, if externally sourced. Null if developed in-house.' ;
    rdfs:domain ind:TrainingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAgencyId rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency Id' ;
    rdfs:comment 'Reference to the regulatory agency or governing body that issued this violation notice.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAgency .

ind:previousViolationNoticeId rdf:type rdf:Property ;
    rdfs:label 'Previous Violation Notice Id' ;
    rdfs:comment 'Reference to the previous violation notice if this is a recurrence. Links to the original violation for trend analysis.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ViolationNotice .

ind:appealFiledDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Date' ;
    rdfs:comment 'Date when the formal appeal was filed with the regulatory agency or legal authority.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Flag' ;
    rdfs:comment 'Indicates whether Retail has filed a formal appeal of the violation notice with the regulatory agency or through legal channels.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealOutcome rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome' ;
    rdfs:comment 'Result of the appeal process if an appeal was filed. Indicates whether the original violation was upheld, overturned, or modified.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseClosureDate rdf:type rdf:Property ;
    rdfs:label 'Case Closure Date' ;
    rdfs:comment 'Date when the violation case was officially closed by the regulatory agency after all requirements, payments, and corrective actions were completed.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:citationNumber rdf:type rdf:Property ;
    rdfs:label 'Citation Number' ;
    rdfs:comment 'Official citation or case number assigned by the issuing regulatory agency. This is the externally-known identifier for tracking the violation with the regulatory body.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followupInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Followup Inspection Required Flag' ;
    rdfs:comment 'Indicates whether the regulatory agency requires a follow-up inspection to verify corrective actions have been implemented.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalCounselAssignedFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Assigned Flag' ;
    rdfs:comment 'Indicates whether internal or external legal counsel has been assigned to manage this violation case.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noticeReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Notice Received Date' ;
    rdfs:comment 'Date when Retail received the formal violation notice from the regulatory agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Date when the penalty or settlement amount was paid to the regulatory agency.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Deadline by which the penalty or settlement amount must be paid to the regulatory agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Date' ;
    rdfs:comment 'Date when the violation was publicly disclosed through regulatory filings, press releases, or other public channels.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicDisclosureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Required Flag' ;
    rdfs:comment 'Indicates whether the violation must be publicly disclosed per regulatory requirements or corporate governance policies.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryStandardViolated rdf:type rdf:Property ;
    rdfs:label 'Regulatory Standard Violated' ;
    rdfs:comment 'Specific regulatory standard, code section, or compliance requirement that was violated. References the exact regulation or standard cited by the agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDeadline rdf:type rdf:Property ;
    rdfs:label 'Response Deadline' ;
    rdfs:comment 'Regulatory deadline by which Retail must submit a formal response or corrective action plan to the issuing agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Response Document Url' ;
    rdfs:comment 'URL or file path to the formal response document submitted to the regulatory agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Date when Retail submitted its formal response or corrective action plan to the regulatory agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'Final monetary amount agreed upon in a settlement with the regulatory agency. May differ from the original penalty amount.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the settlement amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementNegotiatedFlag rdf:type rdf:Property ;
    rdfs:label 'Settlement Negotiated Flag' ;
    rdfs:comment 'Indicates whether a settlement agreement was negotiated with the regulatory agency in lieu of the original penalty.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:violationDate rdf:type rdf:Property ;
    rdfs:label 'Violation Date' ;
    rdfs:comment 'Date when the regulatory violation occurred or was observed by the regulatory agency. This is the principal business event timestamp for the violation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:violationDescription rdf:type rdf:Property ;
    rdfs:label 'Violation Description' ;
    rdfs:comment 'Detailed narrative description of the regulatory violation as documented by the issuing agency. Includes specific findings, observations, and conditions that constitute the violation.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationStatus rdf:type rdf:Property ;
    rdfs:label 'Violation Status' ;
    rdfs:comment 'Current lifecycle status of the violation notice from receipt through resolution. Tracks the progression of the case through regulatory response and closure. [ENUM-REF-CANDIDATE: received|under_review|response_submitted|appeal_filed|settled|closed|contested — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationType rdf:type rdf:Property ;
    rdfs:label 'Violation Type' ;
    rdfs:comment 'Category of regulatory violation. Classifies the nature of the violation for reporting and remediation tracking. [ENUM-REF-CANDIDATE: food_safety|workplace_safety|environmental|payment_security|data_privacy|fire_safety|building_code|labor_law|consumer_protection|advertising|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Unique identifier for the account. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:billingAddressId rdf:type rdf:Property ;
    rdfs:label 'Billing Address Id' ;
    rdfs:comment 'Reference to the default billing address for this account. Used for invoicing, credit checks, and payment processing. Null if no billing address on file.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:shippingAddressId rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Id' ;
    rdfs:comment 'Reference to the default shipping address for this account. Used for order fulfillment and delivery. Null if no default shipping address set.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-visible unique account number used for customer communication, statements, and customer service lookup. Distinct from internal account_id.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle state of the account. Active accounts can transact; suspended accounts are temporarily blocked; closed accounts are permanently terminated; pending_activation awaits customer verification; frozen accounts are under investigation; dormant accounts have no recent activity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Service tier or membership level of the account, determining benefits, discounts, and service priority. Standard is base tier; premium, VIP, and platinum offer escalating benefits.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the account indicating the nature of the commercial relationship: personal (B2C consumer), business (B2B corporate), employee (staff discount account), or wholesale (bulk buyer).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:b2bPricingFlag rdf:type rdf:Property ;
    rdfs:label 'B2b Pricing Flag' ;
    rdfs:comment 'Indicates whether this account receives B2B contract pricing instead of standard retail pricing. True for wholesale and corporate accounts; false for consumer accounts.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Date when the account was permanently closed. Null for active accounts. Used for churn analysis and account lifecycle reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum credit amount (in base currency) extended to this account for deferred payment or credit purchases. Null for cash-only accounts. Used for credit management and risk assessment.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent' ;
    rdfs:comment 'Indicates whether the account holder has consented to sharing their data with third-party partners for analytics, advertising, or personalization. True if consented; false otherwise. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultPaymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Default Payment Method Id' ;
    rdfs:comment 'Reference to the customer\'s default payment method for this account (e.g., credit card on file, bank account). Null if no default set. Used for one-click checkout and recurring billing.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeDiscountEligible rdf:type rdf:Property ;
    rdfs:label 'Employee Discount Eligible' ;
    rdfs:comment 'Indicates whether this account is eligible for employee discount pricing. True for employee accounts and authorized family members; false otherwise.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'Date of the most recent purchase or transaction on this account. Used for recency analysis, dormancy detection, and customer lifecycle segmentation (RFM analysis).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyProgramEnrolled rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Enrolled' ;
    rdfs:comment 'Indicates whether this account is enrolled in the retailer\'s loyalty or rewards program. True if enrolled; false otherwise. Used for loyalty analytics and targeted promotions.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether the account holder has consented to receive marketing communications (email, SMS, direct mail). True if opted in; false if opted out. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingOptInDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Date' ;
    rdfs:comment 'Timestamp when the account holder provided marketing consent. Null if never opted in. Used for consent audit trail and compliance reporting.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:marketingOptOutDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt Out Date' ;
    rdfs:comment 'Timestamp when the account holder withdrew marketing consent. Null if currently opted in or never opted in. Used for consent audit trail and compliance reporting.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Date when the account was first opened and activated. Used for account age calculations, tenure-based benefits, and lifecycle analytics.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Current outstanding balance owed by the account holder (in base currency). Positive values indicate amounts owed to Retail; negative values indicate credit balances. Used for accounts receivable and collections.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Channel' ;
    rdfs:comment 'Customer\'s preferred interaction channel for shopping and service. Used for omnichannel routing, personalized marketing, and channel-specific offers.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Certificate Number' ;
    rdfs:comment 'Government-issued tax exemption certificate number for tax-exempt accounts. Null for non-exempt accounts. Required for audit and compliance verification.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Expiry Date' ;
    rdfs:comment 'Expiration date of the tax exemption certificate. Null for non-exempt accounts or perpetual exemptions. Used for compliance monitoring and renewal reminders.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether this account is exempt from sales tax (e.g., non-profit organizations, government entities, resellers with valid tax exemption certificates). True if exempt; false otherwise.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalLifetimeOrders rdf:type rdf:Property ;
    rdfs:label 'Total Lifetime Orders' ;
    rdfs:comment 'Cumulative count of all orders placed by this account since inception. Used for frequency analysis in RFM segmentation and customer value scoring.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Unique identifier for the address record. Primary key.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active addresses are available for use in orders and shipments.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of the address purpose: billing, shipping, store pickup (BOPIS/ROPIS), home, work, or mailing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality name for the address.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO country code (e.g., USA, CAN, GBR) identifying the country of the address.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Special delivery instructions provided by the customer (e.g., gate code, leave at door, ring bell).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPointBarcode rdf:type rdf:Property ;
    rdfs:label 'Delivery Point Barcode' ;
    rdfs:comment 'USPS Delivery Point Barcode (DPBC) or equivalent postal barcode for automated mail sorting and delivery.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultBilling rdf:type rdf:Property ;
    rdfs:label 'Is Default Billing' ;
    rdfs:comment 'Flag indicating whether this address is the default billing address for the customer.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultShipping rdf:type rdf:Property ;
    rdfs:label 'Is Default Shipping' ;
    rdfs:comment 'Flag indicating whether this address is the default shipping destination for the customer.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'Date when this address was last used in a transaction (order, shipment, or billing event).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate in decimal degrees for geolocation and last-mile delivery optimization.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line including street number, street name, and unit/apartment number.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for additional location details such as building name, floor, suite, or department.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate in decimal degrees for geolocation and last-mile delivery optimization.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:militaryAddressFlag rdf:type rdf:Property ;
    rdfs:label 'Military Address Flag' ;
    rdfs:comment 'Indicates whether the address is a military address (APO/FPO/DPO). Requires special handling for international military mail.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nickname rdf:type rdf:Property ;
    rdfs:label 'Nickname' ;
    rdfs:comment 'Customer-provided friendly name for the address (e.g., Home, Office, Mom\'s House) for easy identification.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poBoxFlag rdf:type rdf:Property ;
    rdfs:label 'Po Box Flag' ;
    rdfs:comment 'Indicates whether the address is a PO Box. Some carriers and products cannot deliver to PO Boxes.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal code, ZIP code, or postcode for the address. Used for delivery routing and tax jurisdiction determination.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialFlag rdf:type rdf:Property ;
    rdfs:label 'Residential Flag' ;
    rdfs:comment 'Indicates whether the address is a residential location (true) or commercial/business location (false). Impacts shipping rates and delivery windows.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardizationFlag rdf:type rdf:Property ;
    rdfs:label 'Standardization Flag' ;
    rdfs:comment 'Indicates whether the address has been standardized to postal service formatting rules (USPS Publication 28, etc.).' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or region code or name. For US addresses, use two-letter state abbreviation (e.g., CA, NY).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction identifier derived from the address, used to determine applicable sales tax rates and rules.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Status of address validation against postal service standards (USPS, Canada Post, etc.). Validated addresses reduce delivery failures.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentId rdf:type rdf:Property ;
    rdfs:label 'Consent Id' ;
    rdfs:comment 'Primary key for consent' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionChannel rdf:type rdf:Property ;
    rdfs:label 'Collection Channel' ;
    rdfs:comment 'The channel through which the consent was collected: web (e-commerce site), mobile app, POS (point of sale terminal), paper form (in-store signup), call center, email campaign, or in-store kiosk. [ENUM-REF-CANDIDATE: web|mobile_app|pos|paper_form|call_center|email|in_store_kiosk — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'The method by which consent was obtained: explicit opt-in (customer actively checked box), implicit opt-in (inferred from action), pre-checked box (legacy, non-compliant), verbal (phone), or written signature (paper form).' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentScope rdf:type rdf:Property ;
    rdfs:label 'Consent Scope' ;
    rdfs:comment 'Detailed description of the scope and purpose of the consent. Explains what data will be used for and how, ensuring transparency and specificity required by privacy regulations.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current status of the consent: granted (customer opted in), withdrawn (customer opted out), pending (awaiting customer action), expired (consent period ended), or revoked (administratively cancelled).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'The exact date and time when the consent decision was captured. Critical for audit trails and regulatory proof of consent timing.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'The specific type of consent being recorded: marketing email, SMS, push notifications, data sharing with partners, profiling for personalization, cookie tracking, or third-party data sharing. [ENUM-REF-CANDIDATE: marketing_email|marketing_sms|marketing_push|data_sharing|profiling|cookies|third_party_sharing — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectRightsNotice rdf:type rdf:Property ;
    rdfs:label 'Data Subject Rights Notice' ;
    rdfs:comment 'Boolean flag indicating whether the customer was informed of their data subject rights (right to access, rectification, erasure, restriction, portability, objection) at the time of consent collection.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInConfirmed rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Confirmed' ;
    rdfs:comment 'Boolean flag indicating whether the customer confirmed their consent via a double opt-in process (e.g., email confirmation link). Best practice for email marketing consent.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Timestamp' ;
    rdfs:comment 'The date and time when the customer confirmed their consent via double opt-in. Null if double opt-in was not used or not yet confirmed.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:granularity rdf:type rdf:Property ;
    rdfs:label 'Granularity' ;
    rdfs:comment 'The level of granularity at which consent was obtained: global (all purposes), channel-specific (email vs SMS), purpose-specific (marketing vs analytics), or brand-specific (for multi-brand retailers).' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'The IP address from which the consent was submitted. Used as proof of consent origin for regulatory compliance and fraud detection.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'The language in which the consent form was presented to the customer (ISO 639-1 two-letter code, e.g., EN, ES, FR). Required for multi-lingual compliance.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Minor Consent Flag' ;
    rdfs:comment 'Boolean flag indicating whether this consent record pertains to a minor (under age of digital consent in jurisdiction). Triggers additional parental consent requirements under GDPR Article 8 and COPPA.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalConsentVerified rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Verified' ;
    rdfs:comment 'Boolean flag indicating whether parental or guardian consent has been verified for a minor. Required for COPPA and GDPR Article 8 compliance.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privacyPolicyVersion rdf:type rdf:Property ;
    rdfs:label 'Privacy Policy Version' ;
    rdfs:comment 'The specific version of the privacy policy document that was in effect and accepted by the customer at the time of consent. Required for regulatory audit trails.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Proof Document Url' ;
    rdfs:comment 'URL or storage path to the digitally signed or archived copy of the consent form as presented to the customer. Used for audit and regulatory inspection.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'System timestamp when this consent record was first created in the data platform. Immutable. Used for audit trail and data lineage.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'The name or identifier of the source system that originated this consent record (e.g., Salesforce Commerce Cloud, POS system, call center CRM). Used for data lineage and troubleshooting.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyRecipient rdf:type rdf:Property ;
    rdfs:label 'Third Party Recipient' ;
    rdfs:comment 'Name or identifier of the third party with whom data may be shared under this consent. Null if no third-party sharing is involved. Required for transparency under GDPR Article 13.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'The browser or application user agent string captured at the time of consent. Provides additional context for consent collection environment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Timestamp' ;
    rdfs:comment 'The exact date and time when the customer withdrew their consent. Null if consent has not been withdrawn. Critical for right-to-erasure workflows.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Unique identifier for the contact method record. Primary key.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bounceCount rdf:type rdf:Property ;
    rdfs:label 'Bounce Count' ;
    rdfs:comment 'The cumulative number of times communication attempts via this contact method have bounced or failed. Used to trigger contact validation workflows and suppress invalid addresses.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentSource rdf:type rdf:Property ;
    rdfs:label 'Consent Source' ;
    rdfs:comment 'The channel or touchpoint where the customer provided consent for this contact method (e.g., web registration, mobile app, POS, call center, in-store signup). Supports consent audit trails. [ENUM-REF-CANDIDATE: web|mobile_app|pos|call_center|email|in_store|third_party — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact method. Active indicates usable for communication; bounced/invalid indicates delivery failure; suppressed indicates customer request or compliance block; pending_verification indicates awaiting confirmation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'The type or category of contact method (e.g., primary email, mobile phone, work phone, WhatsApp, SMS, fax). Determines the channel and priority for omnichannel outreach. [ENUM-REF-CANDIDATE: primary_email|secondary_email|mobile|home_phone|work_phone|whatsapp|sms|fax — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactValue rdf:type rdf:Property ;
    rdfs:label 'Contact Value' ;
    rdfs:comment 'The actual contact point value: email address, phone number, or social media handle. This is the primary data element used for customer communication and CRM campaigns via Salesforce Service Cloud. Classified as restricted PII as it may contain email, phone, or other personal identifiers.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Boolean flag indicating whether this is the primary contact method for the customer. Used to prioritize communication channels in omnichannel campaigns and clienteling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Boolean flag indicating whether the contact method has been verified (e.g., email verification link clicked, phone number confirmed via OTP). Ensures data quality for marketing and transactional communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the customers preferred language for communications via this contact method (e.g., en, es, fr). Supports personalized omnichannel outreach.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastBounceDate rdf:type rdf:Property ;
    rdfs:label 'Last Bounce Date' ;
    rdfs:comment 'The date of the most recent bounce or delivery failure for this contact method. Nullable if no bounces have occurred.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInDate rdf:type rdf:Property ;
    rdfs:label 'Opt In Date' ;
    rdfs:comment 'The date when the customer provided consent for communication via this contact method. Required for audit trails under GDPR and CCPA.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInMarketing rdf:type rdf:Property ;
    rdfs:label 'Opt In Marketing' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive marketing communications via this contact method. Critical for GDPR and CCPA consent enforcement.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInTransactional rdf:type rdf:Property ;
    rdfs:label 'Opt In Transactional' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive transactional communications (order confirmations, shipping updates, receipts) via this contact method.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optOutDate rdf:type rdf:Property ;
    rdfs:label 'Opt Out Date' ;
    rdfs:comment 'The date when the customer withdrew consent or opted out of communications via this contact method. Nullable if customer has not opted out.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'The unique identifier for this contact method in the source system. Enables traceability and cross-system reconciliation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateAccountId rdf:type rdf:Property ;
    rdfs:label 'Corporate Account Id' ;
    rdfs:comment 'Unique identifier for the B2B corporate customer account. Primary key for the corporate account entity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateAccount .

ind:accountManagerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Account Manager Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: B2B corporate accounts require dedicated account managers (sales reps or account executives) who handle contract negotiations, pricing agreements, credit terms, and ongoing relationship management. Es' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:parentAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Id' ;
    rdfs:comment 'Reference to the parent corporate account if this account is part of a multi-location or subsidiary hierarchy. Null for standalone accounts or top-level parent accounts. Enables consolidated billing and enterprise-wide reporting.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:primaryContactId rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Corporate accounts have a designated primary contact person. Currently, corporate_account stores primary_contact_name, primary_contact_email, primary_contact_phone as denormalized columns. Adding prim' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:accountEstablishedDate rdf:type rdf:Property ;
    rdfs:label 'Account Established Date' ;
    rdfs:comment 'Date when the corporate account was first created in the system. Used to calculate customer tenure and lifetime value metrics.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualSpendTier rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Tier' ;
    rdfs:comment 'Classification of the corporate account based on annual purchase volume. Used to determine discount levels, service priority, and account management resources. Tier_1 = highest spend (>$1M), Tier_5 = lowest spend (<$10K). Tiers recalculated annually.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractPricingFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Pricing Flag' ;
    rdfs:comment 'Indicates whether the corporate account has negotiated contract pricing that overrides standard catalog prices. True = custom pricing agreement in place; False = standard pricing applies.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Status' ;
    rdfs:comment 'Current credit approval status for the corporate account. Determines whether the customer can purchase on credit terms. Values: approved (credit line active), pending (application submitted), declined (credit denied), under_review (periodic credit review in progress), suspended (credit privileges temporarily revoked).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'Trade name or fictitious business name under which the corporate customer operates, if different from legal name. Used for marketing and customer-facing communications.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit unique identifier assigned by Dun & Bradstreet to establish business credit profile and track commercial credit history. Used for supplier onboarding and credit evaluation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryClassificationNaics rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Naics' ;
    rdfs:comment 'Six-digit code classifying the corporate customer\'s primary industry using the NAICS standard. Provides more granular industry segmentation than SIC for modern business categories.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryClassificationSic rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Sic' ;
    rdfs:comment 'Four-digit code classifying the corporate customer\'s primary industry sector using the U.S. Standard Industrial Classification system. Used for market segmentation and industry analysis.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Order Date' ;
    rdfs:comment 'Date of the most recent purchase order placed by this corporate account. Used for recency analysis and dormant account identification.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalBusinessName rdf:type rdf:Property ;
    rdfs:label 'Legal Business Name' ;
    rdfs:comment 'The official registered legal name of the corporate entity as it appears on government filings and tax documents. Used for contracts, invoicing, and legal compliance.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Standard payment terms negotiated with the corporate customer. Values: net_30 (payment due 30 days after invoice), net_45, net_60, net_90, due_on_receipt (immediate payment), prepay (payment before shipment), custom (non-standard terms documented separately). [ENUM-REF-CANDIDATE: net_30|net_45|net_60|net_90|due_on_receipt|prepay|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Delivery Method' ;
    rdfs:comment 'Default shipping method preference for corporate orders. Values: standard_ground, expedited, next_day, freight (for large/bulk orders), customer_pickup (will-call).' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Federal tax identification number (EIN) assigned by the IRS for business tax reporting and compliance. Format: XX-XXXXXXX.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdId rdf:type rdf:Property ;
    rdfs:label 'Household Id' ;
    rdfs:comment 'Unique identifier for the household unit. Primary key for the household entity.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address of the household. Used for delivery, geo-targeting, and household matching.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address information (apartment, suite, unit number). Optional field for household address.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageBasketValue rdf:type rdf:Property ;
    rdfs:label 'Average Basket Value' ;
    rdfs:comment 'Average transaction value (ATV) across all household purchases. Used for household-level pricing and promotion strategies.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:combinedCltv rdf:type rdf:Property ;
    rdfs:label 'Combined Cltv' ;
    rdfs:comment 'Aggregated Customer Lifetime Value across all household members. Represents the total predicted revenue from the household over its lifetime. Used for household-level loyalty tier assignment and VIP treatment.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communicationPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Preference' ;
    rdfs:comment 'Preferred method for household-level marketing communications. Honors consent and privacy preferences.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedIncomeBand rdf:type rdf:Property ;
    rdfs:label 'Estimated Income Band' ;
    rdfs:comment 'Estimated annual household income range. Derived from third-party data enrichment or modeled from purchase behavior. Used for targeted marketing and assortment planning.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalHouseholdCode rdf:type rdf:Property ;
    rdfs:label 'External Household Code' ;
    rdfs:comment 'Household identifier from the source system or external partner. Used for cross-system reconciliation and data integration.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdName rdf:type rdf:Property ;
    rdfs:label 'Household Name' ;
    rdfs:comment 'Human-readable name or label for the household (e.g., \'Smith Family\', \'Johnson Household\'). Used for clienteling and personalized marketing.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdStatus rdf:type rdf:Property ;
    rdfs:label 'Household Status' ;
    rdfs:comment 'Current lifecycle status of the household record. Active households are eligible for household-level promotions and loyalty benefits.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdType rdf:type rdf:Property ;
    rdfs:label 'Household Type' ;
    rdfs:comment 'Classification of the household structure. Used for targeted marketing and assortment planning.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'Date of the most recent purchase made by any household member. Used for recency analysis in RFM (Recency Frequency Monetary) segmentation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyTier rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier' ;
    rdfs:comment 'Household-level loyalty program tier based on combined spending and engagement. Determines household-level benefits and promotions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Primary Language' ;
    rdfs:comment 'Two-letter ISO language code representing the household\'s preferred language for communications (e.g., en, es, fr). Used for localized marketing and customer service.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Marketing or behavioral segment assigned to the household based on RFM (Recency Frequency Monetary) analysis, purchase patterns, and demographics. Used for targeted campaigns.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Number of individual members in the household. Used for basket size prediction and household-level promotions.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLoyaltyPoints rdf:type rdf:Property ;
    rdfs:label 'Total Loyalty Points' ;
    rdfs:comment 'Aggregated loyalty points balance across all household members. Used for household-level redemption and rewards.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPurchaseCount rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Count' ;
    rdfs:comment 'Total number of transactions made by all household members. Used for frequency analysis in RFM (Recency Frequency Monetary) segmentation.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Total Spend Amount' ;
    rdfs:comment 'Cumulative monetary value of all purchases made by household members. Used for monetary analysis in RFM (Recency Frequency Monetary) segmentation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:identityLinkId rdf:type rdf:Property ;
    rdfs:label 'Identity Link Id' ;
    rdfs:comment 'Unique identifier for the identity link record. Primary key for the identity resolution table.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchRuleId rdf:type rdf:Property ;
    rdfs:label 'Match Rule Id' ;
    rdfs:comment 'Identifier of the specific matching rule or algorithm configuration used to establish this link. References the MDM match rule library.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rule .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The customer interaction channel where this identifier is primarily used. Supports omnichannel customer recognition and journey analytics.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierFirstSeenDate rdf:type rdf:Property ;
    rdfs:label 'Identifier First Seen Date' ;
    rdfs:comment 'The date when this specific identifier value was first observed in any source system. Used for recency analysis in RFM (Recency Frequency Monetary) segmentation. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identifierLastSeenDate rdf:type rdf:Property ;
    rdfs:label 'Identifier Last Seen Date' ;
    rdfs:comment 'The date when this identifier was most recently used in a transaction or interaction. Critical for identifying dormant identifiers. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identifierType rdf:type rdf:Property ;
    rdfs:label 'Identifier Type' ;
    rdfs:comment 'The category or type of identifier being linked. Examples include loyalty card number, email hash, device ID, cookie ID, POS customer ID, Salesforce Contact ID, SAP customer number. [ENUM-REF-CANDIDATE: loyalty_card|email_hash|device_id|cookie_id|pos_customer_id|salesforce_contact_id|sap_customer_number|mobile_app_id|web_account_id|third_party_id — promote to reference product]' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierUsageCount rdf:type rdf:Property ;
    rdfs:label 'Identifier Usage Count' ;
    rdfs:comment 'The total number of times this identifier has been used across all channels and transactions. Helps assess identifier reliability and customer engagement.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:identifierValue rdf:type rdf:Property ;
    rdfs:label 'Identifier Value' ;
    rdfs:comment 'The actual identifier value (e.g., loyalty card number 123456789, email hash abc123def, device UUID). This is the raw identifier string from the source system.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryIdentifier rdf:type rdf:Property ;
    rdfs:label 'Is Primary Identifier' ;
    rdfs:comment 'Boolean flag indicating whether this is the primary or preferred identifier for this customer. True if this is the main identifier used for customer recognition, False otherwise.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Link Confidence Score' ;
    rdfs:comment 'Numeric confidence score (0.0000 to 1.0000) indicating the certainty of the identity link. Deterministic matches typically score 1.0000, while probabilistic matches score lower based on matching algorithm confidence.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linkCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Link Created Timestamp' ;
    rdfs:comment 'The date and time when this identity link was first established in the MDM system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linkEffectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Link Effective From Date' ;
    rdfs:comment 'The date from which this identity link is considered valid and active for customer recognition across channels. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkEffectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Link Effective To Date' ;
    rdfs:comment 'The date until which this identity link remains valid. Null indicates an open-ended link. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkMethod rdf:type rdf:Property ;
    rdfs:label 'Link Method' ;
    rdfs:comment 'The methodology used to establish the identity link. Deterministic uses exact matching rules (e.g., same email), probabilistic uses statistical algorithms, manual indicates human review, third-party indicates external data provider.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkNotes rdf:type rdf:Property ;
    rdfs:label 'Link Notes' ;
    rdfs:comment 'Free-text notes or comments about this identity link, typically used for manual review cases or to document special circumstances in the linking decision.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkStatus rdf:type rdf:Property ;
    rdfs:label 'Link Status' ;
    rdfs:comment 'Current lifecycle status of the identity link. Active links are used for customer recognition, inactive links are deprecated, pending_review requires manual validation, rejected links failed validation, superseded links have been replaced by newer links.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Link Updated Timestamp' ;
    rdfs:comment 'The date and time when this identity link was last modified or re-validated. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linkedByUser rdf:type rdf:Property ;
    rdfs:label 'Linked By User' ;
    rdfs:comment 'The username or system identifier of the user or process that created this identity link. Used for audit and accountability purposes.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchAttributes rdf:type rdf:Property ;
    rdfs:label 'Match Attributes' ;
    rdfs:comment 'Comma-separated list of attributes that were used in the matching process (e.g., email, phone, postal_code). Provides transparency into the matching logic.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mergeHistoryReference rdf:type rdf:Property ;
    rdfs:label 'Merge History Reference' ;
    rdfs:comment 'Reference identifier to the merge/split history log if this link was affected by customer profile merges or splits. Supports audit trail and rollback scenarios.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'The date and time when this identifier was last validated. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:IdentityLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionId rdf:type rdf:Property ;
    rdfs:label 'Interaction Id' ;
    rdfs:comment 'Unique identifier for the customer interaction event. Primary key.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Foreign key linking to merchandising.category. Business justification: Customer interactions (browsing, inquiries, service cases) often category-specific. Enables category engagement analytics, service case routing to category-expert associates, and category-level custom' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:emailSendId rdf:type rdf:Property ;
    rdfs:label 'Email Send Id' ;
    rdfs:comment 'Foreign key linking to marketing.email_send. Business justification: Customer interactions (email opens, clicks, unsubscribes) must link to specific email sends for campaign performance measurement, deliverability analysis, and customer engagement scoring. New FK requi' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmailSend .

ind:headerId rdf:type rdf:Property ;
    rdfs:label 'Header Id' ;
    rdfs:comment 'Identifier of the order associated with this interaction, if applicable. Links to the order record. Null for non-order-related interactions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:interactionAgentAssociateId rdf:type rdf:Property ;
    rdfs:label 'Interaction Agent Associate Id' ;
    rdfs:comment 'Identifier of the call center or customer service agent who handled this interaction. Applicable for call center contacts, live chat, and service cases. Null for non-agent-assisted interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:interactionAssociateId rdf:type rdf:Property ;
    rdfs:label 'Interaction Associate Id' ;
    rdfs:comment 'Identifier of the Retail associate, agent, or employee who handled or facilitated this interaction. Applicable for in-store clienteling visits, call center contacts, and assisted digital interactions. Null for self-service interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:posTransactionId rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Id' ;
    rdfs:comment 'Identifier of the POS transaction associated with this interaction, if applicable. Links to the POS transaction record. Null for non-transaction interactions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosTransaction .

ind:promoOfferId rdf:type rdf:Property ;
    rdfs:label 'Promo Offer Id' ;
    rdfs:comment 'Identifier of the specific promotion or offer presented or redeemed during this interaction, if applicable. Null if no promotion was involved.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoOffer .

ind:serviceCaseId rdf:type rdf:Property ;
    rdfs:label 'Service Case Id' ;
    rdfs:comment 'Identifier of the customer service case or ticket associated with this interaction, if applicable. Links to the service case record. Null for non-case interactions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCase .

ind:verifiedTrainingCompletionId rdf:type rdf:Property ;
    rdfs:label 'Verified Training Completion Id' ;
    rdfs:comment 'Foreign key linking to compliance.training_completion. Business justification: Customer interactions requiring compliance verification (alcohol/tobacco sales, pharmacy consultations) must link to associate training completion records. Regulatory audit trail for age-restricted sa' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCompletion .

ind:webSessionId rdf:type rdf:Property ;
    rdfs:label 'Web Session Id' ;
    rdfs:comment 'Unique identifier for the digital session (web or mobile app) during which this interaction occurred. Applicable for website sessions and mobile app sessions. Null for non-session-based interactions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WebSession .

ind:browser rdf:type rdf:Property ;
    rdfs:label 'Browser' ;
    rdfs:comment 'The web browser used by the customer during this interaction (e.g., Chrome, Safari, Firefox, Edge). Applicable for web-based interactions. Null for non-web interactions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'The delivery and engagement status for outbound communication interactions (email, SMS, push notification). Indicates whether the message was delivered, opened, clicked, bounced, or failed. Null for inbound or non-message interactions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'The type of device used by the customer during this interaction (e.g., desktop, mobile, tablet, kiosk, POS terminal). Applicable for digital and in-store interactions. Null if device type is unknown.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalProperty rdf:type rdf:Property ;
    rdfs:label 'Digital Property' ;
    rdfs:comment 'The specific digital asset or platform where the interaction occurred (e.g., main website, mobile app, partner site, social media platform name). Applicable for digital interactions. Null for in-store interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates whether the interaction was initiated by the customer (inbound) or by Retail (outbound).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'The length of the interaction in seconds. Applicable for sessions, calls, chats, and visits. Null for instantaneous events (e.g., email send, SMS send).' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emailClickedFlag rdf:type rdf:Property ;
    rdfs:label 'Email Clicked Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer clicked a link within an outbound email. Applicable only for email interactions. Null for non-email interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailOpenedFlag rdf:type rdf:Property ;
    rdfs:label 'Email Opened Flag' ;
    rdfs:comment 'Boolean flag indicating whether an outbound email was opened by the customer. Applicable only for email interactions. Null for non-email interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geolocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Latitude' ;
    rdfs:comment 'The latitude coordinate of the customer location at the time of this interaction, if available. Applicable for mobile app interactions with location services enabled. Null if location data is unavailable.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geolocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Longitude' ;
    rdfs:comment 'The longitude coordinate of the customer location at the time of this interaction, if available. Applicable for mobile app interactions with location services enabled. Null if location data is unavailable.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction Timestamp' ;
    rdfs:comment 'The date and time when the interaction event occurred. This is the business event timestamp (when the customer engaged), distinct from record audit timestamps.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'The category of customer touchpoint or engagement event. Defines the nature of the interaction (e.g., POS visit, website session, app open, call center contact, email send, SMS send, push notification, chat, clienteling visit, NPS survey response). [ENUM-REF-CANDIDATE: pos_visit|website_session|mobile_app_open|call_center_contact|email_campaign|sms_campaign|push_notification|live_chat|clienteling_visit|nps_survey|social_media_engagement|kiosk_interaction|video_call|in_store_event — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landingPageUrl rdf:type rdf:Property ;
    rdfs:label 'Landing Page Url' ;
    rdfs:comment 'The URL of the first page visited by the customer during this interaction session. Applicable for web-based interactions. Null for non-web interactions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'The Net Promoter Score (NPS) provided by the customer during or after this interaction, if applicable. Scale 0-10. Null if no NPS was collected.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingSystem rdf:type rdf:Property ;
    rdfs:label 'Operating System' ;
    rdfs:comment 'The operating system of the device used during this interaction (e.g., Windows, macOS, iOS, Android). Applicable for digital interactions. Null for non-digital interactions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'The result or resolution status of the interaction (e.g., completed, abandoned, escalated, resolved, converted, bounced, unsubscribed). [ENUM-REF-CANDIDATE: completed|abandoned|escalated|resolved|converted|bounced|unsubscribed|pending|transferred|no_response — promote to reference product]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referrerUrl rdf:type rdf:Property ;
    rdfs:label 'Referrer Url' ;
    rdfs:comment 'The URL of the page or source that referred the customer to this interaction (e.g., search engine, social media, email link). Applicable for web-based interactions. Null for non-web interactions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentScore rdf:type rdf:Property ;
    rdfs:label 'Sentiment Score' ;
    rdfs:comment 'A numeric score representing the sentiment or emotional tone of the interaction, derived from text analytics or voice analytics. Scale typically -1.0 (negative) to +1.0 (positive). Null if sentiment analysis was not performed.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:smsDeliveredFlag rdf:type rdf:Property ;
    rdfs:label 'Sms Delivered Flag' ;
    rdfs:comment 'Boolean flag indicating whether an outbound SMS message was successfully delivered to the customer. Applicable only for SMS interactions. Null for non-SMS interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'A brief subject or title describing the purpose or topic of the interaction (e.g., product inquiry, order status check, complaint, feedback). Applicable for call center contacts, service cases, and clienteling visits. Null for automated or non-subject-based interactions.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unsubscribedFlag rdf:type rdf:Property ;
    rdfs:label 'Unsubscribed Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer unsubscribed from communications as a result of this interaction. Applicable for outbound communication interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Payment Method Id' ;
    rdfs:comment 'Primary key for payment_method' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentMethod .

ind:liabilityGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Liability Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Gift cards and store credit (payment_method has gift_card_balance, store_credit_balance) represent deferred revenue liabilities that must be tracked in specific GL accounts. Required for ASC 606 reven' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:primaryPaymentDigitalWalletAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Digital Wallet Account Id' ;
    rdfs:comment 'Tokenized identifier for the digital wallet account. Used for digital wallet transactions and reconciliation.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:binNumber rdf:type rdf:Property ;
    rdfs:label 'Bin Number' ;
    rdfs:comment 'First six digits of the card number (Bank Identification Number). Used for card type identification, fraud detection, and routing. Not considered sensitive under PCI DSS.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bnplProvider rdf:type rdf:Property ;
    rdfs:label 'Bnpl Provider' ;
    rdfs:comment 'Provider of the BNPL service (Affirm, Afterpay, Klarna, Zip, Sezzle). Applicable only when payment_method_type is bnpl.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardBrand rdf:type rdf:Property ;
    rdfs:label 'Card Brand' ;
    rdfs:comment 'Brand of the payment card (Visa, Mastercard, American Express, Discover, JCB, UnionPay). Applicable for credit and debit card payment methods.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardCountryCode rdf:type rdf:Property ;
    rdfs:label 'Card Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the country where the card was issued. Derived from BIN lookup. Used for fraud detection and international transaction processing.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderName rdf:type rdf:Property ;
    rdfs:label 'Cardholder Name' ;
    rdfs:comment 'Name of the cardholder as it appears on the payment card. Used for verification and fraud prevention.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentChannel rdf:type rdf:Property ;
    rdfs:label 'Consent Channel' ;
    rdfs:comment 'Channel through which the customer provided consent to store this payment method (web, mobile app, POS, call center, in-store). Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deactivated Timestamp' ;
    rdfs:comment 'Timestamp when this payment method was deactivated. Null if the payment method is still active. Used for lifecycle tracking and compliance reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deactivationReason rdf:type rdf:Property ;
    rdfs:label 'Deactivation Reason' ;
    rdfs:comment 'Reason why the payment method was deactivated. Used for customer service, fraud analysis, and operational reporting.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalWalletProvider rdf:type rdf:Property ;
    rdfs:label 'Digital Wallet Provider' ;
    rdfs:comment 'Provider of the digital wallet (Apple Pay, Google Pay, PayPal, Samsung Pay, Venmo). Applicable only when payment_method_type is digital_wallet.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryMonth rdf:type rdf:Property ;
    rdfs:label 'Expiry Month' ;
    rdfs:comment 'Expiration month of the payment card (1-12). Used to validate card validity at checkout and trigger proactive customer notifications for expiring cards.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryYear rdf:type rdf:Property ;
    rdfs:label 'Expiry Year' ;
    rdfs:comment 'Expiration year of the payment card (four-digit year). Used to validate card validity at checkout and trigger proactive customer notifications for expiring cards.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:giftCardBalance rdf:type rdf:Property ;
    rdfs:label 'Gift Card Balance' ;
    rdfs:comment 'Current balance remaining on the gift card. Updated after each transaction. Applicable only when payment_method_type is gift_card.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftCardNumber rdf:type rdf:Property ;
    rdfs:label 'Gift Card Number' ;
    rdfs:comment 'Tokenized or masked gift card number. Applicable only when payment_method_type is gift_card. Used for gift card balance inquiries and redemption.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Flag indicating whether this is the customers default payment method for one-click checkout and recurring purchases. Only one payment method per customer should be marked as default.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingBank rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank' ;
    rdfs:comment 'Name of the bank or financial institution that issued the payment card. Used for transaction routing and fraud detection.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFourDigits rdf:type rdf:Property ;
    rdfs:label 'Last Four Digits' ;
    rdfs:comment 'Last four digits of the card number for customer recognition and display purposes. Used in clienteling and checkout confirmation screens.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodType rdf:type rdf:Property ;
    rdfs:label 'Payment Method Type' ;
    rdfs:comment 'Type of payment instrument. BNPL = Buy Now Pay Later. Supports diverse payment options across POS, e-commerce, and mobile channels.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProcessor rdf:type rdf:Property ;
    rdfs:label 'Payment Processor' ;
    rdfs:comment 'Name of the payment processor or gateway used to process transactions with this payment method (e.g., Stripe, Adyen, Braintree, Cybersource). Used for transaction routing and reconciliation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorToken rdf:type rdf:Property ;
    rdfs:label 'Processor Token' ;
    rdfs:comment 'Payment processor-specific token for this payment method. Used for transaction processing and vault management.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCreditBalance rdf:type rdf:Property ;
    rdfs:label 'Store Credit Balance' ;
    rdfs:comment 'Current balance of store credit available to the customer. Typically issued from returns or promotional campaigns. Applicable only when payment_method_type is store_credit.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:token rdf:type rdf:Property ;
    rdfs:label 'Token' ;
    rdfs:comment 'PCI DSS compliant tokenized reference to the payment instrument. No raw PAN (Primary Account Number) is stored. Token is used for recurring purchases and one-click checkout.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of payment method verification (e.g., AVS check, CVV verification, micro-deposit confirmation). Used for fraud prevention and risk management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceId rdf:type rdf:Property ;
    rdfs:label 'Preference Id' ;
    rdfs:comment 'Unique identifier for the customer preference record. Primary key.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredItemHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Preferred Item Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to product.item_hierarchy. Business justification: Category and department preferences enable targeted marketing campaigns and personalized navigation. Retail marketing segments customers by preferred categories (e.g., \'Beauty shoppers\', \'Electronics ' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItemHierarchy .

ind:preferredSkuId rdf:type rdf:Property ;
    rdfs:label 'Preferred Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Customer product preferences at SKU level (favorite items, repeat purchases) drive personalization engines, targeted promotions, and replenishment recommendations. Retail personalization requires link' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:supersededByPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Preference Id' ;
    rdfs:comment 'Identifier of the preference record that supersedes or replaces this preference. Nullable if this is the current active preference. Supports preference lineage and history tracking.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Preference .

ind:applicationCount rdf:type rdf:Property ;
    rdfs:label 'Application Count' ;
    rdfs:comment 'The cumulative number of times this preference has been applied or used in customer interactions, recommendations, or personalization events. Supports preference effectiveness measurement and RFM (Recency Frequency Monetary) analytics.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelCaptured rdf:type rdf:Property ;
    rdfs:label 'Channel Captured' ;
    rdfs:comment 'The channel or touchpoint through which the preference was originally captured (e.g., web, mobile app, POS (Point of Sale), call center, in-store kiosk, email, survey, third-party). Supports omnichannel attribution and data quality assessment. [ENUM-REF-CANDIDATE: web|mobile_app|pos|call_center|in_store_kiosk|email|survey|third_party — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Numeric confidence score (0.00 to 100.00) indicating the reliability or certainty of the preference, especially for inferred or behavioral preferences. Higher values indicate stronger confidence. Self-declared preferences typically have 100.00 confidence.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentGiven rdf:type rdf:Property ;
    rdfs:label 'Consent Given' ;
    rdfs:comment 'Boolean flag indicating whether the customer has provided explicit consent for this preference to be used for personalization, marketing, or data processing. True indicates consent granted; False indicates consent not granted or withdrawn.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'The name or identifier of the source system or application that originally captured or provided this preference data (e.g., \'Salesforce Commerce Cloud\', \'SAP CAR\', \'Informatica MDM\', \'Mobile App v2.3\'). Supports data lineage and troubleshooting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAppliedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Applied Timestamp' ;
    rdfs:comment 'The timestamp when this preference was last actively used or applied in a customer interaction, personalization event, or recommendation. Supports preference relevance scoring and decay analysis. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optOutFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted out of having this preference used for personalization or marketing. True indicates customer has opted out; False indicates customer has not opted out. Supports GDPR right to object and CCPA opt-out requirements.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opt Out Timestamp' ;
    rdfs:comment 'The timestamp when the customer opted out of this preference. Required for compliance audit trails. Nullable if customer has not opted out. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preferenceCategory rdf:type rdf:Property ;
    rdfs:label 'Preference Category' ;
    rdfs:comment 'The category or type of preference being captured (e.g., communication channel, product category affinity, dietary restriction, brand preference, store preference, language, notification frequency, privacy consent, marketing opt-in, delivery preference, payment method preference, shopping time preference). Supports segmentation and personalization across all Retail channels. [ENUM-REF-CANDIDATE: communication_channel|product_category_affinity|dietary_restriction|brand_preference|store_preference|language|notification_frequency|privacy_consent|marketing_opt_in|delivery_preference|payment_method_preference|shopping_time_preference — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceDescription rdf:type rdf:Property ;
    rdfs:label 'Preference Description' ;
    rdfs:comment 'Free-text description or additional context about the preference, especially useful for complex or custom preferences that require explanation. Supports customer service and clienteling use cases.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceSource rdf:type rdf:Property ;
    rdfs:label 'Preference Source' ;
    rdfs:comment 'The origin of the preference data. Self-declared indicates customer explicitly provided the preference; behavioral indicates derived from purchase or browsing history; inferred indicates algorithmic prediction; third-party indicates sourced from external data provider; imported indicates migrated from legacy system.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Current lifecycle status of the preference. Active indicates currently in use; inactive indicates temporarily disabled; expired indicates no longer valid due to time constraints; superseded indicates replaced by a newer preference.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceValue rdf:type rdf:Property ;
    rdfs:label 'Preference Value' ;
    rdfs:comment 'The specific value or selection for the preference category (e.g., \'email\', \'organic produce\', \'Nike\', \'Store #1234\', \'Spanish\', \'weekly\'). Free-text or structured value depending on category.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Optional granular subcategory within the preference category for more detailed segmentation (e.g., within \'product_category_affinity\', subcategory could be \'organic_produce\', \'gluten_free_bakery\', \'athletic_footwear\'). Supports fine-grained personalization.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weight rdf:type rdf:Property ;
    rdfs:label 'Weight' ;
    rdfs:comment 'Numeric weight (0.00 to 100.00) assigned to this preference for use in recommendation algorithms and personalization scoring. Higher weights indicate stronger influence on recommendations. Used by AI/ML models for CLTV (Customer Lifetime Value) and next-best-action predictions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:privacyRequestId rdf:type rdf:Property ;
    rdfs:label 'Privacy Request Id' ;
    rdfs:comment 'Unique identifier for the privacy request. Primary key.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appealSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Submitted Flag' ;
    rdfs:comment 'Indicates whether the customer submitted an appeal or complaint regarding the handling of this privacy request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealTimestamp rdf:type rdf:Property ;
    rdfs:label 'Appeal Timestamp' ;
    rdfs:comment 'Date and time when the customer submitted an appeal or complaint.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'Date and time when the privacy request was assigned to a processor.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditLogReference rdf:type rdf:Property ;
    rdfs:label 'Audit Log Reference' ;
    rdfs:comment 'Reference identifier to the detailed audit log entries tracking all system actions taken to fulfill this privacy request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent Flag' ;
    rdfs:comment 'Indicates whether the customer was notified of the request outcome via email or other channel.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Timestamp' ;
    rdfs:comment 'Date and time when the customer was notified of the request outcome.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataCategoriesAffected rdf:type rdf:Property ;
    rdfs:label 'Data Categories Affected' ;
    rdfs:comment 'Comma-separated list of data categories affected by this request (e.g., profile, transaction_history, loyalty, marketing_preferences, location_data).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataExportExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Export Expiry Timestamp' ;
    rdfs:comment 'Date and time when the data export download link expires for security purposes.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataExportFormat rdf:type rdf:Property ;
    rdfs:label 'Data Export Format' ;
    rdfs:comment 'File format used for data portability requests: JSON, CSV, PDF, XML. Applicable only for access and portability request types.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataExportUrl rdf:type rdf:Property ;
    rdfs:label 'Data Export Url' ;
    rdfs:comment 'Secure download URL for the exported customer data package. Time-limited and encrypted. Applicable for access and portability requests.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReason rdf:type rdf:Property ;
    rdfs:label 'Denial Reason' ;
    rdfs:comment 'Legal or business justification for denying the privacy request (e.g., legal obligation to retain data, manifestly unfounded request, excessive requests).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Granted Flag' ;
    rdfs:comment 'Indicates whether a deadline extension was granted for this request due to complexity or volume.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionReason rdf:type rdf:Property ;
    rdfs:label 'Extension Reason' ;
    rdfs:comment 'Business justification for granting a deadline extension (e.g., complex request, high volume, technical difficulties).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingDeadline rdf:type rdf:Property ;
    rdfs:label 'Processing Deadline' ;
    rdfs:comment 'Regulatory deadline by which the privacy request must be completed. GDPR: 30 days (extendable to 90), CCPA: 45 days (extendable to 90).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processingNotes rdf:type rdf:Property ;
    rdfs:label 'Processing Notes' ;
    rdfs:comment 'Internal notes and comments from the assigned processor documenting actions taken, challenges encountered, and decisions made during request processing.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordsAnonymizedCount rdf:type rdf:Property ;
    rdfs:label 'Records Anonymized Count' ;
    rdfs:comment 'Number of database records anonymized (PII removed but record retained for analytics) to fulfill an erasure request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordsDeletedCount rdf:type rdf:Property ;
    rdfs:label 'Records Deleted Count' ;
    rdfs:comment 'Number of database records deleted across all systems to fulfill an erasure request.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the privacy request, used for customer communication and tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the privacy request: submitted (initial receipt), pending_verification (identity check in progress), verified (identity confirmed), in_progress (being processed), completed (fulfilled), rejected (denied), cancelled (withdrawn by customer). [ENUM-REF-CANDIDATE: submitted|pending_verification|verified|in_progress|completed|rejected|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Type of privacy request: access (right to know), erasure (right to delete), portability (data export), rectification (correction), opt_out_sale (CCPA opt-out), restriction (processing limitation).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'Channel through which the privacy request was submitted: web_portal, mobile_app, email, phone, in_store, postal_mail.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Date and time when the privacy request was submitted by the customer. Principal business event timestamp.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:systemsAffected rdf:type rdf:Property ;
    rdfs:label 'Systems Affected' ;
    rdfs:comment 'Comma-separated list of operational systems where data was accessed, modified, or deleted to fulfill this request (e.g., CRM, ERP, WMS, E-commerce).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'The channel through which the customer was originally acquired, used for CAC (Customer Acquisition Cost) analysis and channel effectiveness measurement.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date when the customer first engaged with the business, marking the start of the customer lifecycle.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cacAmount rdf:type rdf:Property ;
    rdfs:label 'Cac Amount' ;
    rdfs:comment 'Total cost incurred to acquire this customer, including marketing spend, promotional discounts, and channel costs. Used for CLTV (Customer Lifetime Value) to CAC ratio analysis.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ccpaOptOutDate rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Date' ;
    rdfs:comment 'Timestamp when CCPA opt-out request was processed, required for compliance audit trails.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ccpaOptOutFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted out of personal data sale under CCPA regulations.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cltvScore rdf:type rdf:Property ;
    rdfs:label 'Cltv Score' ;
    rdfs:comment 'Predicted total revenue value this customer will generate over their entire relationship with the business, calculated using RFM (Recency Frequency Monetary) models and predictive analytics.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerType rdf:type rdf:Property ;
    rdfs:label 'Customer Type' ;
    rdfs:comment 'Classification of customer as individual consumer (B2C) or corporate buyer (B2B), including special categories such as employee or VIP.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Date of birth of the customer, used for age verification, lifecycle marketing, and personalized birthday promotions.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for customer communication across all channels including e-commerce, loyalty programs, and promotional campaigns.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Email Opt In Flag' ;
    rdfs:comment 'Boolean flag indicating customer consent to receive promotional emails and newsletters.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeFlag rdf:type rdf:Property ;
    rdfs:label 'Employee Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer is an employee eligible for employee discount programs.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Legal first name or given name of the customer as recorded in the master data management system.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Complete legal name of the customer, typically concatenated from first, middle, and last name components.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Date' ;
    rdfs:comment 'Timestamp when GDPR consent was granted by the customer, required for compliance audit trails.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer has provided explicit consent for data processing under GDPR requirements.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Self-identified gender of the customer, used for personalized merchandising and assortment planning.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Interaction Date' ;
    rdfs:comment 'Date of the customer\'s most recent interaction with the business across any touchpoint including POS, e-commerce, mobile app, or customer service.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Legal last name or family name of the customer as recorded in the master data management system.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current stage in the customer lifecycle journey, used for targeted marketing campaigns and retention strategies. [ENUM-REF-CANDIDATE: prospect|new|active|at_risk|dormant|churned|reactivated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Consent Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer has consented to receive marketing communications including email, SMS, and direct mail.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mdmConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Mdm Confidence Score' ;
    rdfs:comment 'Confidence score (0-100) from Informatica MDM indicating the quality and reliability of the golden record match and data completeness.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mdmLastMatchDate rdf:type rdf:Property ;
    rdfs:label 'Mdm Last Match Date' ;
    rdfs:comment 'Timestamp of the last MDM matching and survivorship process execution that updated this golden record.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mdmSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Mdm Source System' ;
    rdfs:comment 'Name of the primary source system that contributed the authoritative data for this golden record (e.g., SAP CAR, Salesforce Commerce Cloud, POS).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the customer. Nullable field for customers without a middle name.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile phone number used for SMS notifications, mobile app authentication, and last-mile delivery coordination.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the customer\'s nationality or citizenship.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for customer service, order notifications, and BOPIS (Buy Online Pick Up In Store) communications.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Customer\'s preferred method for receiving communications and notifications from the business.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-2 three-letter language code representing the customer\'s preferred language for communication and marketing materials.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current operational status of the customer profile, controlling access to services and transactions across all channels.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Sms Opt In Flag' ;
    rdfs:comment 'Boolean flag indicating customer consent to receive promotional SMS messages and mobile notifications.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vipFlag rdf:type rdf:Property ;
    rdfs:label 'Vip Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer is designated as a VIP for special clienteling services and exclusive offers.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Primary key for segment' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Owner Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Customer segments are owned by marketing analysts, merchandising managers, or CRM specialists who define qualification criteria, monitor segment performance, design targeted campaigns, and refresh mem' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:preferredCategoryId rdf:type rdf:Property ;
    rdfs:label 'Preferred Category Id' ;
    rdfs:comment 'Foreign key linking to merchandising.category. Business justification: Customer segments defined by category affinity ("Premium Electronics Buyers", "Organic Enthusiasts") for category-targeted campaigns and segment-aware assortment planning. Replaces denormalized prefer' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:promoCampaignId rdf:type rdf:Property ;
    rdfs:label 'Promo Campaign Id' ;
    rdfs:comment 'Foreign key linking to promotion.promo_campaign. Business justification: Customer segments are explicitly targeted by promotional campaigns (promo_campaign.customer_segment_target exists as text field). Creating FK enables direct segment-to-campaign assignment for targeted' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoCampaign .

ind:autoRefreshFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Refresh Flag' ;
    rdfs:comment 'Indicates whether customer membership in this segment is automatically recalculated on a scheduled basis (True) or manually managed (False). True for dynamic segments (e.g., RFM tiers recalculated nightly); False for static segments (e.g., one-time campaign lists).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageAov rdf:type rdf:Property ;
    rdfs:label 'Average Aov' ;
    rdfs:comment 'Mean Average Order Value for customers in this segment over the measurement period. Key metric for pricing strategy, promotion design, and basket optimization. Expressed in base currency (USD).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageCltv rdf:type rdf:Property ;
    rdfs:label 'Average Cltv' ;
    rdfs:comment 'Mean Customer Lifetime Value across all customers currently assigned to this segment. Used for segment valuation, investment prioritization, and ROI forecasting. Expressed in base currency (USD).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averagePurchaseFrequency rdf:type rdf:Property ;
    rdfs:label 'Average Purchase Frequency' ;
    rdfs:comment 'Mean number of transactions per customer in this segment over the measurement period (typically 12 months). Used for replenishment forecasting, loyalty program design, and churn prediction.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:b2bB2cIndicator rdf:type rdf:Property ;
    rdfs:label 'B2b B2c Indicator' ;
    rdfs:comment 'Indicates whether this segment applies to B2B customers (business accounts, wholesale, corporate), B2C customers (individual consumers), or both. Drives differentiated engagement strategies, pricing models, and service levels.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaOptOutHonoredFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Honored Flag' ;
    rdfs:comment 'Indicates whether this segment respects CCPA \'Do Not Sell My Personal Information\' opt-out requests (True) or is exempt (False, e.g., service-related communications). Ensures compliance for California residents.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:churnRiskScore rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Score' ;
    rdfs:comment 'Aggregate churn risk score for this segment, ranging from 0.00 (no risk) to 100.00 (high risk). Calculated from recency, frequency, and engagement metrics. Drives retention campaign prioritization and at-risk customer interventions.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountSensitivity rdf:type rdf:Property ;
    rdfs:label 'Discount Sensitivity' ;
    rdfs:comment 'Behavioral classification of segment\'s responsiveness to promotional pricing. High: primarily purchases on promotion (Hi-Lo shoppers). Medium: balanced full-price and promotional purchases. Low: primarily full-price purchases (EDLP preference or premium segment).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Required Flag' ;
    rdfs:comment 'Indicates whether explicit customer consent is required under GDPR for marketing communications to this segment (True) or whether legitimate interest or other legal basis applies (False). Ensures regulatory compliance for EU customers.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxRfmScore rdf:type rdf:Property ;
    rdfs:label 'Max Rfm Score' ;
    rdfs:comment 'Maximum RFM composite score for customer assignment to this segment (if segment_type is rfm_tier). Defines the upper bound of the RFM tier. Null for non-RFM segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:membershipCount rdf:type rdf:Property ;
    rdfs:label 'Membership Count' ;
    rdfs:comment 'Current count of customers assigned to this segment. Updated periodically based on auto-refresh schedule. Used for segment sizing, campaign planning, and capacity forecasting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minRfmScore rdf:type rdf:Property ;
    rdfs:label 'Min Rfm Score' ;
    rdfs:comment 'Minimum RFM composite score required for customer assignment to this segment (if segment_type is rfm_tier). RFM scores typically range from 3 (lowest: 1-1-1) to 15 (highest: 5-5-5). Null for non-RFM segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorityTier rdf:type rdf:Property ;
    rdfs:label 'Priority Tier' ;
    rdfs:comment 'Service and engagement priority level assigned to this segment. Platinum: highest CLTV, white-glove service. Gold: high-value, priority support. Silver: mid-value, standard service. Bronze: emerging value. Standard: baseline service. Drives clienteling strategies and resource allocation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCriteria rdf:type rdf:Property ;
    rdfs:label 'Qualification Criteria' ;
    rdfs:comment 'Summary of the business rules and thresholds used to assign customers to this segment (e.g., \'Purchased in last 30 days AND total spend > $5000 in last 12 months\', \'RFM Score >= 9\', \'Age 25-34 AND lives in urban area\'). Human-readable representation of the segmentation logic.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the segment for operational use (e.g., VIP_GOLD, LAPSED_90D, HIGH_VALUE_B2B). Used in marketing campaigns, pricing rules, and POS systems.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative describing the segment\'s defining characteristics, business rationale, and strategic purpose. Includes target customer profile, expected behaviors, and recommended engagement strategies.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the segment (e.g., \'VIP Gold Tier\', \'Lapsed Customers - 90 Days\', \'High-Value B2B Accounts\'). Used in reporting, dashboards, and customer-facing communications.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment definition. Active: in production use for customer assignment and campaigns. Inactive: temporarily suspended, no new assignments. Archived: retired, historical reference only. Draft: under development, not yet released.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segmentation methodology applied. RFM Tier: Recency, Frequency, Monetary analysis. Demographic: age, gender, income. Behavioral: purchase patterns, product affinity. Psychographic: lifestyle, values. Lifecycle Stage: new, active, at-risk, lapsed. Geographic: region, climate zone. Channel Preference: omnichannel, e-commerce-only, store-only. Value Tier: CLTV-based stratification. [ENUM-REF-CANDIDATE: rfm_tier|demographic|behavioral|psychographic|lifecycle_stage|geographic|channel_preference|value_tier — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarketingChannel rdf:type rdf:Property ;
    rdfs:label 'Target Marketing Channel' ;
    rdfs:comment 'Primary communication channel recommended for engaging customers in this segment. Aligns segment strategy with channel preference and regulatory consent. All Channels: omnichannel engagement strategy. [ENUM-REF-CANDIDATE: email|sms|push_notification|direct_mail|in_store|call_center|social_media|all_channels — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerId rdf:type rdf:Property ;
    rdfs:label 'Buyer Id' ;
    rdfs:comment 'Foreign key linking to merchandising.buyer. Business justification: Complex product quality issues, specification disputes, or vendor-related complaints escalated to merchandise buyers for resolution and vendor coordination. Real escalation path in retail operations f' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Buyer .

ind:parentCaseServiceCaseId rdf:type rdf:Property ;
    rdfs:label 'Parent Case Service Case Id' ;
    rdfs:comment 'Identifier of the parent service case if this case is a child or follow-up case. Supports hierarchical case relationships and tracking of related issues.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCase .

ind:redemptionId rdf:type rdf:Property ;
    rdfs:label 'Redemption Id' ;
    rdfs:comment 'Foreign key linking to loyalty.redemption. Business justification: Service cases frequently involve loyalty redemption disputes (points not credited, voucher not working, reward not received). CSRs need direct link to redemption record to investigate complaints, proc' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Redemption .

ind:assignedTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Team' ;
    rdfs:comment 'Name or code of the service team or queue to which this case is assigned for resolution.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally visible unique case number assigned by the service system for customer reference and tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseOwnerType rdf:type rdf:Property ;
    rdfs:label 'Case Owner Type' ;
    rdfs:comment 'Type of owner currently assigned to the case: individual agent, team queue, or automated system. Used for workload distribution analytics.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle status of the service case. Tracks progression from new through resolution to closure. [ENUM-REF-CANDIDATE: new|open|in_progress|pending_customer|pending_vendor|escalated|resolved|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the service case by the nature of the customer issue or inquiry. Includes return inquiry, billing dispute, product complaint, delivery issue, loyalty query, order inquiry, technical support, and general inquiry. [ENUM-REF-CANDIDATE: return_inquiry|billing_dispute|product_complaint|delivery_issue|loyalty_query|order_inquiry|technical_support|general_inquiry — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactAttempts rdf:type rdf:Property ;
    rdfs:label 'Contact Attempts' ;
    rdfs:comment 'Number of times the service team attempted to contact the customer during the case lifecycle. Used for tracking customer engagement and responsiveness.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Rating' ;
    rdfs:comment 'Customer satisfaction score provided by the customer after case resolution, typically on a scale of 1 to 5. Used to calculate CSAT and NPS metrics.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Boolean indicator of whether the case was escalated to a higher support tier, supervisor, or specialized team during its lifecycle.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Reason or justification for escalating the case, such as complexity, customer request, or SLA breach.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Response Timestamp' ;
    rdfs:comment 'Timestamp when the first agent response was provided to the customer after case creation. Key metric for measuring initial response time SLA.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionCount rdf:type rdf:Property ;
    rdfs:label 'Interaction Count' ;
    rdfs:comment 'Total number of customer-agent interactions or touchpoints recorded during the lifecycle of this case. Includes calls, emails, chats, and in-person contacts.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isClosed rdf:type rdf:Property ;
    rdfs:label 'Is Closed' ;
    rdfs:comment 'Boolean indicator of whether the case is currently in a closed status. Simplifies filtering for open vs closed case analytics.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Monetary amount refunded to the customer as part of the case resolution, if applicable. Denominated in the transaction currency.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Code' ;
    rdfs:comment 'Standardized code indicating the type of resolution or action taken to close the service case. Used for resolution analytics and process improvement. [ENUM-REF-CANDIDATE: refund_issued|replacement_sent|information_provided|escalated_to_vendor|no_action_required|customer_withdrew|policy_exception_approved — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaNumber rdf:type rdf:Property ;
    rdfs:label 'Rma Number' ;
    rdfs:comment 'Return Merchandise Authorization number issued for return-related cases. Links the service case to the formal return process and inventory tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCaseDescription rdf:type rdf:Property ;
    rdfs:label 'Service Case Description' ;
    rdfs:comment 'Detailed narrative description of the customer issue, inquiry, or complaint as captured by the service agent or customer.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Boolean indicator of whether the case resolution exceeded the SLA target time, triggering a service level breach.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'Target number of hours within which the case should be resolved according to the applicable SLA policy based on case type and priority.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wishlistId rdf:type rdf:Property ;
    rdfs:label 'Wishlist Id' ;
    rdfs:comment 'Primary key for wishlist' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registryConsultantAssociateId rdf:type rdf:Property ;
    rdfs:label 'Registry Consultant Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Wedding and baby registry wishlists are managed by dedicated in-store registry consultants who assist customers with product selection, registry setup, gift tracking, and completion discounts. Support' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'Date and time when the wishlist was archived by the customer or system. Nullable if never archived. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:coRegistrantFirstName rdf:type rdf:Property ;
    rdfs:label 'Co Registrant First Name' ;
    rdfs:comment 'First name of the secondary registrant for gift registries (e.g., groom, co-host). Nullable for single-registrant or non-registry wishlists.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coRegistrantLastName rdf:type rdf:Property ;
    rdfs:label 'Co Registrant Last Name' ;
    rdfs:comment 'Last name of the secondary registrant for gift registries. Nullable for single-registrant or non-registry wishlists.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Conversion Rate Percentage' ;
    rdfs:comment 'Percentage of wishlist items that have been purchased (converted to orders). Calculated as (purchased items / total items) × 100. Key metric for wishlist effectiveness.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionStatus rdf:type rdf:Property ;
    rdfs:label 'Conversion Status' ;
    rdfs:comment 'Indicates whether items from this wishlist have been purchased: unconverted (no items purchased), partially_converted (some items purchased), fully_converted (all items purchased).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Data Retention Expiry Date' ;
    rdfs:comment 'Date when this wishlist record is eligible for permanent deletion per data retention policies. Calculated based on last activity date and regulatory requirements. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deleted Timestamp' ;
    rdfs:comment 'Date and time when the wishlist was soft-deleted. Nullable if not deleted. Supports data retention and recovery policies. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:externalWishlistCode rdf:type rdf:Property ;
    rdfs:label 'External Wishlist Code' ;
    rdfs:comment 'Original wishlist identifier from the source system (e.g., Salesforce Commerce Cloud wishlist GUID). Used for cross-system reconciliation and data lineage.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstConversionTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Conversion Timestamp' ;
    rdfs:comment 'Date and time when the first item from this wishlist was purchased. Nullable if no conversions have occurred. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isDefaultFlag rdf:type rdf:Property ;
    rdfs:label 'Is Default Flag' ;
    rdfs:comment 'Indicates whether this is the customer\'s default wishlist. True if default (items added without specifying a list go here), False otherwise. Each customer should have only one default wishlist.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastConversionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Conversion Timestamp' ;
    rdfs:comment 'Date and time when the most recent item from this wishlist was purchased. Nullable if no conversions have occurred. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastViewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Viewed Timestamp' ;
    rdfs:comment 'Date and time when the wishlist was last viewed by any user (owner or gift-giver). Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Enabled Flag' ;
    rdfs:comment 'Indicates whether the customer has enabled notifications for this wishlist (e.g., back-in-stock alerts, price drop alerts, event reminders). True if enabled, False if disabled.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationFrequency rdf:type rdf:Property ;
    rdfs:label 'Notification Frequency' ;
    rdfs:comment 'Frequency at which the customer wants to receive wishlist notifications: immediate (real-time alerts), daily digest, weekly digest, event_based (only for specific triggers), or disabled.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Privacy Consent Flag' ;
    rdfs:comment 'Indicates whether the customer has consented to use wishlist data for personalized recommendations and marketing. True if consent given, False otherwise. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrantFirstName rdf:type rdf:Property ;
    rdfs:label 'Registrant First Name' ;
    rdfs:comment 'First name of the primary registrant for gift registries (e.g., bride, birthday person). Used for registry search and display. Nullable for non-registry wishlists.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrantLastName rdf:type rdf:Property ;
    rdfs:label 'Registrant Last Name' ;
    rdfs:comment 'Last name of the primary registrant for gift registries. Used for registry search and display. Nullable for non-registry wishlists.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryNumber rdf:type rdf:Property ;
    rdfs:label 'Registry Number' ;
    rdfs:comment 'Unique public-facing registry number for gift registries, used by gift-givers to search and locate the registry. Nullable for non-registry wishlists.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shareCount rdf:type rdf:Property ;
    rdfs:label 'Share Count' ;
    rdfs:comment 'Number of times the wishlist has been shared via email, social media, or direct link. Tracks viral/social engagement.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shareUrl rdf:type rdf:Property ;
    rdfs:label 'Share Url' ;
    rdfs:comment 'Unique shareable URL for this wishlist. Generated for shared and public wishlists to enable gift-givers to view and purchase items. Nullable for private wishlists.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalItemCount rdf:type rdf:Property ;
    rdfs:label 'Total Item Count' ;
    rdfs:comment 'Total number of distinct product SKUs currently in the wishlist. Calculated from wishlist item detail records.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Quantity' ;
    rdfs:comment 'Sum of desired quantities across all items in the wishlist. Accounts for items where customer wants multiple units.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValueAmount rdf:type rdf:Property ;
    rdfs:label 'Total Value Amount' ;
    rdfs:comment 'Total monetary value of all items in the wishlist at current prices. Sum of (item price × desired quantity) for all items. Used for demand forecasting and promotional targeting.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viewCount rdf:type rdf:Property ;
    rdfs:label 'View Count' ;
    rdfs:comment 'Total number of times the wishlist has been viewed by the owner or others (for shared/public wishlists). Engagement metric.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visibility rdf:type rdf:Property ;
    rdfs:label 'Visibility' ;
    rdfs:comment 'Privacy setting for the wishlist: private (only owner can view), shared (accessible via link), public (searchable by others), or registry (publicly searchable gift registry).' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wishlistDescription rdf:type rdf:Property ;
    rdfs:label 'Wishlist Description' ;
    rdfs:comment 'Optional customer-provided description or notes about the wishlist purpose, preferences, or special instructions (e.g., \'Items for new apartment\', \'Prefer blue colors\').' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wishlistName rdf:type rdf:Property ;
    rdfs:label 'Wishlist Name' ;
    rdfs:comment 'Customer-provided name for the wishlist (e.g., \'Birthday Gifts\', \'Holiday Shopping\', \'Wedding Registry\').' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wishlistStatus rdf:type rdf:Property ;
    rdfs:label 'Wishlist Status' ;
    rdfs:comment 'Current lifecycle status of the wishlist: active (in use), archived (saved but inactive), deleted (soft-deleted), or expired (past event date for registries).' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wishlistType rdf:type rdf:Property ;
    rdfs:label 'Wishlist Type' ;
    rdfs:comment 'Classification of the wishlist purpose: standard personal wishlist, gift registry for events, save-for-later cart items, favorites collection, private collection, or shared list.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abTestId rdf:type rdf:Property ;
    rdfs:label 'Ab Test Id' ;
    rdfs:comment 'Unique surrogate identifier for each A/B or multivariate test record in the digital commerce platform. Primary key for this entity.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AbTest .

ind:storefrontId rdf:type rdf:Property ;
    rdfs:label 'Storefront Id' ;
    rdfs:comment 'Reference to the digital storefront on which this test is executed. Links to the e-commerce storefront master record in Salesforce Commerce Cloud.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Storefront .

ind:assignedVariant rdf:type rdf:Property ;
    rdfs:label 'Assigned Variant' ;
    rdfs:comment 'The specific variant (control or treatment) assigned to this visitor/session for the test. Core field for per-variant statistical analysis and CR/AOV/CTR lift calculations. [ENUM-REF-CANDIDATE: control|treatment_a|treatment_b|treatment_c|treatment_d — promote to reference product for tests with more than 4 variants]' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conclusionReason rdf:type rdf:Property ;
    rdfs:label 'Conclusion Reason' ;
    rdfs:comment 'Reason the test was concluded or stopped. Supports post-test governance review and audit trail for digital commerce optimization decisions.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Conversion Timestamp' ;
    rdfs:comment 'Precise date and time when the conversion event occurred for this assignment record. Nullable if no conversion occurred. Used for time-to-convert analysis and attribution window validation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conversionValue rdf:type rdf:Property ;
    rdfs:label 'Conversion Value' ;
    rdfs:comment 'Monetary value of the conversion event associated with this assignment (e.g., order total in local currency). Used for AOV (Average Order Value) and GMV (Gross Merchandise Value) lift analysis per variant. Nullable if no conversion occurred or metric is non-monetary.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviceTargeting rdf:type rdf:Property ;
    rdfs:label 'Device Targeting' ;
    rdfs:comment 'Device category restriction for visitor eligibility in this test. Enables device-specific experience optimization aligned with omnichannel digital commerce strategy.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Calendar date on which the test is scheduled to conclude or was actually concluded. Nullable for open-ended tests. Used for duration calculations and reporting windows.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone) when the test was deactivated or concluded. Nullable for tests still in progress. Used for exact duration and overlap analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:geoTargetingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geo Targeting Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code restricting test eligibility to visitors from a specific country (e.g., \'USA\', \'GBR\'). Nullable for globally-targeted tests. Supports regional pricing and localization experiments.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hypothesis rdf:type rdf:Property ;
    rdfs:label 'Hypothesis' ;
    rdfs:comment 'Formal statement of the expected outcome of the test (e.g., \'Changing the CTA button color to green will increase CR by 5% for mobile visitors\'). Supports scientific rigor in digital experience optimization.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConverted rdf:type rdf:Property ;
    rdfs:label 'Is Converted' ;
    rdfs:comment 'Indicates whether the assigned session/visitor completed the primary conversion event (True) as defined by the primary_metric for this test (e.g., placed an order, clicked a CTA). Core field for Conversion Rate (CR) calculation per variant.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMultivariate rdf:type rdf:Property ;
    rdfs:label 'Is Multivariate' ;
    rdfs:comment 'Indicates whether this test is a multivariate test (True) testing multiple element combinations simultaneously, or a standard A/B test (False) with a single variable. Drives statistical analysis methodology selection.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPersonalized rdf:type rdf:Property ;
    rdfs:label 'Is Personalized' ;
    rdfs:comment 'Indicates whether variant assignment uses personalization logic (True) such as customer segment or behavioral targeting, versus purely random assignment (False). Relevant for GDPR Article 22 automated decision-making compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumDetectableEffect rdf:type rdf:Property ;
    rdfs:label 'Minimum Detectable Effect' ;
    rdfs:comment 'The smallest relative or absolute change in the primary metric that the test is designed to detect with the configured confidence level and sample size. Used in pre-test power analysis.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerTeam rdf:type rdf:Property ;
    rdfs:label 'Owner Team' ;
    rdfs:comment 'Name of the business team or squad responsible for designing and monitoring this test (e.g., \'Digital Merchandising\', \'UX Optimization\', \'Pricing Strategy\'). Supports governance and accountability for digital experience experiments.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageTypeTarget rdf:type rdf:Property ;
    rdfs:label 'Page Type Target' ;
    rdfs:comment 'The type of storefront page where the test variant is rendered. PDP = Product Detail Page, PLP = Product Listing Page. Drives test scope and analytics attribution. [ENUM-REF-CANDIDATE: homepage|pdp|plp|cart|checkout|search|category|account|confirmation — promote to reference product]' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMetric rdf:type rdf:Property ;
    rdfs:label 'Primary Metric' ;
    rdfs:comment 'The principal Key Performance Indicator (KPI) used to determine the winning variant. Common values: CR (Conversion Rate), AOV (Average Order Value), CTR (Click-Through Rate), GMV (Gross Merchandise Value). [ENUM-REF-CANDIDATE: cr|aov|ctr|gmv|upt|add_to_cart_rate|bounce_rate|revenue_per_visitor — promote to reference product]' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSizeTarget rdf:type rdf:Property ;
    rdfs:label 'Sample Size Target' ;
    rdfs:comment 'Pre-calculated minimum number of visitor assignments required per variant to achieve the configured statistical power. Derived from power analysis using significance_threshold, confidence_level, and minimum_detectable_effect. Used to determine when the test has sufficient data.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondaryMetric rdf:type rdf:Property ;
    rdfs:label 'Secondary Metric' ;
    rdfs:comment 'Optional supporting KPI monitored alongside the primary metric to detect unintended side effects (e.g., monitoring AOV while optimizing for CR). Nullable.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:significanceThreshold rdf:type rdf:Property ;
    rdfs:label 'Significance Threshold' ;
    rdfs:comment 'The minimum statistical significance level (p-value threshold) required to declare a winning variant, expressed as a decimal (e.g., 0.0500 for 95% confidence). Governs when the test can be concluded.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Calendar date on which the test begins accepting visitor traffic and recording variant assignments. Used for scheduling and campaign alignment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone) when the test was activated and began serving variant experiences to visitors. Distinct from start_date for intra-day precision in traffic analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:targetAudienceSegment rdf:type rdf:Property ;
    rdfs:label 'Target Audience Segment' ;
    rdfs:comment 'Description or identifier of the visitor/customer segment eligible for this test (e.g., \'new_visitors\', \'loyalty_members\', \'mobile_us_only\'). Supports personalization and segmented experimentation strategies.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCode rdf:type rdf:Property ;
    rdfs:label 'Test Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the test, used in downstream analytics pipelines, tagging systems, and Salesforce Commerce Cloud experiment references.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDescription rdf:type rdf:Property ;
    rdfs:label 'Test Description' ;
    rdfs:comment 'Free-text description of the test scope, changes being tested, and business context. Provides additional detail beyond the hypothesis for stakeholder communication and post-test documentation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testName rdf:type rdf:Property ;
    rdfs:label 'Test Name' ;
    rdfs:comment 'Human-readable name identifying the test, used by merchandising and digital commerce teams for reporting and communication (e.g., \'Homepage Hero Banner Layout Q3 2024\').' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStatus rdf:type rdf:Property ;
    rdfs:label 'Test Status' ;
    rdfs:comment 'Current lifecycle state of the test. Controls whether variant assignment and data collection are active. Transitions: draft → running → paused/concluded/cancelled.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'Category of the element being tested on the digital storefront. Drives analytics segmentation and test design governance. [ENUM-REF-CANDIDATE: layout|pricing|copy|recommendation|navigation|personalization|checkout_flow|imagery — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTrafficAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Total Traffic Allocation Pct' ;
    rdfs:comment 'Percentage of total eligible storefront visitors included in the test (e.g., 80.00 means 80% of visitors are enrolled; the remaining 20% are excluded from all variants). Supports holdout group management.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trafficSplitConfig rdf:type rdf:Property ;
    rdfs:label 'Traffic Split Config' ;
    rdfs:comment 'JSON-serialized or delimited string describing the percentage of total eligible traffic allocated to each variant (e.g., \'control:50,treatment_a:50\' or \'control:33,treatment_a:33,treatment_b:34\'). Must sum to 100.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantCount rdf:type rdf:Property ;
    rdfs:label 'Variant Count' ;
    rdfs:comment 'Total number of variants in the test including the control group (e.g., 2 for a standard A/B test, 3+ for multivariate). Drives traffic split validation logic.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visitorCode rdf:type rdf:Property ;
    rdfs:label 'Visitor Code' ;
    rdfs:comment 'Pseudonymous cookie-based or device-based identifier for the visitor, used for anonymous visitor tracking and consistent variant assignment across sessions. Distinct from customer_id which requires authentication. Subject to GDPR/CCPA pseudonymization requirements.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winningVariant rdf:type rdf:Property ;
    rdfs:label 'Winning Variant' ;
    rdfs:comment 'Identifier of the variant declared as the winner upon test conclusion (e.g., \'treatment_a\'). Nullable until the test is concluded and a winner is determined. Used for rollout decisions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abandonedCartRecoveryId rdf:type rdf:Property ;
    rdfs:label 'Abandoned Cart Recovery Id' ;
    rdfs:comment 'Unique surrogate identifier for each abandoned cart recovery workflow execution record. Primary key for this entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:AbandonedCartRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cartId rdf:type rdf:Property ;
    rdfs:label 'Cart Id' ;
    rdfs:comment 'Reference to the abandoned shopping cart that triggered this recovery workflow. Links to the originating cart record in the e-commerce platform (Salesforce Commerce Cloud).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cart .

ind:checkoutId rdf:type rdf:Property ;
    rdfs:label 'Checkout Id' ;
    rdfs:comment 'Foreign key linking to ecommerce.checkout. Business justification: Abandoned cart recovery workflows need to know WHERE in the checkout funnel the cart was abandoned (cart review, address entry, payment entry, etc.). The checkout entity tracks funnel progression with' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Checkout .

ind:messageTemplateId rdf:type rdf:Property ;
    rdfs:label 'Message Template Id' ;
    rdfs:comment 'Identifier of the message template used for this recovery communication, as defined in the marketing automation platform (e.g., Salesforce Marketing Cloud, Braze). Enables template-level performance analysis and A/B test tracking.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MessageTemplate .

ind:abandonedCartGmv rdf:type rdf:Property ;
    rdfs:label 'Abandoned Cart Gmv' ;
    rdfs:comment 'The total Gross Merchandise Value (GMV) of the cart at the time of abandonment, representing the potential revenue at risk. Used to prioritize high-value cart recovery efforts and measure recovery rate against at-risk GMV.' ;
    rdfs:domain ind:AbandonedCartRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:abandonedCartItemCount rdf:type rdf:Property ;
    rdfs:label 'Abandoned Cart Item Count' ;
    rdfs:comment 'Number of distinct line items (SKUs) present in the cart at the time of abandonment. Used alongside abandoned_cart_gmv to segment recovery priority and personalize recovery message content.' ;
    rdfs:domain ind:AbandonedCartRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactAddress rdf:type rdf:Property ;
    rdfs:label 'Contact Address' ;
    rdfs:comment 'The actual contact address used to deliver the recovery message — email address for email channel, phone number for SMS channel, or device push token for push notification channel. Classified as restricted PII as it directly identifies the customer contact point. Aligns with GDPR and CCPA data minimization requirements.' ;
    rdfs:domain ind:AbandonedCartRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Consent Flag' ;
    rdfs:comment 'Indicates whether the customer provided valid data processing consent for marketing communications at the time this recovery record was created. True = consent on record; False = no consent. Critical for GDPR Article 6 lawful basis and CCPA compliance audits.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incentiveType rdf:type rdf:Property ;
    rdfs:label 'Incentive Type' ;
    rdfs:comment 'Type of incentive offered in the recovery message to motivate cart completion. \'none\' = no incentive; \'percentage_discount\' = markdown percentage off; \'fixed_discount\' = fixed currency reduction; \'free_shipping\' = waived shipping fee; \'loyalty_points\' = bonus loyalty program points; \'gift_with_purchase\' = complimentary item. [ENUM-REF-CANDIDATE: none|percentage_discount|fixed_discount|free_shipping|loyalty_points|gift_with_purchase — promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveValue rdf:type rdf:Property ;
    rdfs:label 'Incentive Value' ;
    rdfs:comment 'Quantitative value of the incentive offered in the recovery message. For percentage_discount, this is the percentage (e.g., 10.00 = 10%). For fixed_discount, this is the currency amount. Null when incentive_type is \'none\' or \'free_shipping\'. Used to measure cost-of-recovery against recovered GMV.' ;
    rdfs:domain ind:AbandonedCartRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFirstRecoveryAttempt rdf:type rdf:Property ;
    rdfs:label 'Is First Recovery Attempt' ;
    rdfs:comment 'Indicates whether this record represents the first recovery message sent for the associated abandoned cart. True = first attempt; False = subsequent attempt in a multi-touch sequence. Supports first-touch vs. multi-touch attribution analysis.' ;
    rdfs:domain ind:AbandonedCartRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIncentiveRedeemed rdf:type rdf:Property ;
    rdfs:label 'Is Incentive Redeemed' ;
    rdfs:comment 'Indicates whether the promotional incentive included in the recovery message was actually redeemed by the customer in the recovered order. True = incentive applied to recovered order; False = incentive not used. Null when no incentive was offered or no recovery occurred.' ;
    rdfs:domain ind:AbandonedCartRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:messageClickedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Message Clicked Timestamp' ;
    rdfs:comment 'The date and time when the customer clicked the recovery call-to-action link within the recovery message. Null if no click occurred. Used to compute Click-Through Rate (CTR) and click-to-conversion lag.' ;
    rdfs:domain ind:AbandonedCartRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:messageOpenedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Message Opened Timestamp' ;
    rdfs:comment 'The date and time when the customer opened or viewed the recovery message. Null if the message was not opened. Supports open-rate and engagement analysis by channel and template.' ;
    rdfs:domain ind:AbandonedCartRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:messageSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Message Sent Timestamp' ;
    rdfs:comment 'The exact date and time when the recovery message was dispatched to the customer via the selected recovery channel. BUSINESS_EVENT_TIMESTAMP category for the primary real-world event.' ;
    rdfs:domain ind:AbandonedCartRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'Promotional or discount code included in the recovery message as an incentive for the customer to complete the purchase (e.g., \'COMEBACK10\' for 10% off). Null if no incentive was offered. Used to measure incentive-driven vs. organic recovery rates.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveredGmv rdf:type rdf:Property ;
    rdfs:label 'Recovered Gmv' ;
    rdfs:comment 'The Gross Merchandise Value (GMV) of the order placed as a result of a successful cart recovery. Null when recovery_status is not \'recovered\'. Core revenue attribution metric for the abandoned cart recovery program. MONETARY_TRIPLET gross-base amount component.' ;
    rdfs:domain ind:AbandonedCartRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveredOrderDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Recovered Order Discount Amount' ;
    rdfs:comment 'Total discount or markdown amount applied to the recovered order, including any recovery-specific promotional incentive. Null when no recovery occurred. MONETARY_TRIPLET adjustment component.' ;
    rdfs:domain ind:AbandonedCartRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveredOrderNetAmount rdf:type rdf:Property ;
    rdfs:label 'Recovered Order Net Amount' ;
    rdfs:comment 'Net revenue amount of the recovered order after discounts and promotions, representing the actual revenue recognized. Null when no recovery occurred. MONETARY_TRIPLET net-total component.' ;
    rdfs:domain ind:AbandonedCartRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryChannel rdf:type rdf:Property ;
    rdfs:label 'Recovery Channel' ;
    rdfs:comment 'The outreach channel used to deliver the cart recovery message to the customer. Drives channel effectiveness measurement and Click-Through Rate (CTR) and Conversion Rate (CR) analysis by channel.' ;
    rdfs:domain ind:AbandonedCartRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recovery Expiry Timestamp' ;
    rdfs:comment 'The date and time after which the recovery workflow for this cart is considered expired and no further recovery attempts will be made. Determined by campaign configuration (e.g., 72 hours after abandonment). Used to manage recovery window and transition status to \'expired\'.' ;
    rdfs:domain ind:AbandonedCartRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recoverySequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Recovery Sequence Number' ;
    rdfs:comment 'Ordinal position of this recovery message within a multi-touch recovery campaign sequence for the same abandoned cart (e.g., 1 = first reminder, 2 = second reminder with incentive, 3 = final expiry notice). Supports multi-touch attribution and sequence effectiveness analysis.' ;
    rdfs:domain ind:AbandonedCartRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recoveryStatus rdf:type rdf:Property ;
    rdfs:label 'Recovery Status' ;
    rdfs:comment 'Current lifecycle state of the abandoned cart recovery workflow execution. \'sent\' = message dispatched; \'opened\' = message opened by customer; \'clicked\' = customer clicked recovery link; \'recovered\' = order placed; \'expired\' = recovery window elapsed without conversion. LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryWorkflowNumber rdf:type rdf:Property ;
    rdfs:label 'Recovery Workflow Number' ;
    rdfs:comment 'Externally-known business identifier for this recovery workflow execution, as generated by the marketing automation platform (e.g., Salesforce Marketing Cloud, Braze). Used for cross-system traceability and campaign reporting. BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:AbandonedCartRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeToConversionMinutes rdf:type rdf:Property ;
    rdfs:label 'Time To Conversion Minutes' ;
    rdfs:comment 'Number of minutes elapsed between the recovery message send timestamp and the customer\'s order placement (conversion). Null when recovery_status is not \'recovered\'. Key metric for recovery time-to-conversion analysis and campaign optimization.' ;
    rdfs:domain ind:AbandonedCartRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggerDelayMinutes rdf:type rdf:Property ;
    rdfs:label 'Trigger Delay Minutes' ;
    rdfs:comment 'Number of minutes elapsed between cart abandonment and the dispatch of this recovery message. Configured per campaign sequence step. Used to optimize trigger timing for maximum Conversion Rate (CR).' ;
    rdfs:domain ind:AbandonedCartRecovery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utmCampaign rdf:type rdf:Property ;
    rdfs:label 'Utm Campaign' ;
    rdfs:comment 'Urchin Tracking Module (UTM) campaign parameter appended to the recovery link URL, identifying the specific recovery campaign (e.g., \'abandoned_cart_q4_2024\'). Enables campaign-level attribution in web analytics platforms.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmSource rdf:type rdf:Property ;
    rdfs:label 'Utm Source' ;
    rdfs:comment 'Urchin Tracking Module (UTM) source parameter appended to the recovery link URL, identifying the marketing platform that sent the recovery message (e.g., \'salesforce_mc\', \'braze\'). Used for digital attribution and cross-channel analytics.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abandonedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Abandoned Timestamp' ;
    rdfs:comment 'The date and time when the cart was classified as abandoned, either by session timeout or explicit inactivity threshold breach. Null for non-abandoned carts. Used to calculate time-to-abandonment metrics, trigger abandoned cart recovery email sequences, and measure recovery window effectiveness.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:abandonmentReason rdf:type rdf:Property ;
    rdfs:label 'Abandonment Reason' ;
    rdfs:comment 'Classified reason code for why the cart was abandoned. \'session_timeout\' indicates the session expired; \'inactivity\' indicates no user action within the inactivity window; \'explicit_exit\' indicates the customer navigated away; \'payment_failure\' indicates checkout was attempted but payment was declined; \'out_of_stock\' indicates items became unavailable; \'price_change\' indicates a price change triggered cart exit. Null for non-abandoned carts. Supports abandonment root cause analysis.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartNumber rdf:type rdf:Property ;
    rdfs:label 'Cart Number' ;
    rdfs:comment 'Human-readable, externally referenceable business identifier for the cart instance. Used in customer service interactions, abandoned cart recovery email communications, and cross-system reconciliation between Salesforce Commerce Cloud and the Order Management System (OMS). Formatted as CART- followed by a 10-digit sequence.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartStatus rdf:type rdf:Property ;
    rdfs:label 'Cart Status' ;
    rdfs:comment 'Current lifecycle state of the shopping cart. \'active\' indicates the cart is open and being interacted with; \'abandoned\' indicates the session timed out or the customer left without checkout; \'converted\' indicates the cart was successfully submitted as an order; \'expired\' indicates the cart exceeded the maximum retention window; \'merged\' indicates the cart was consolidated with another cart (e.g., guest-to-authenticated merge). Drives abandoned cart recovery workflows and Conversion Rate (CR) reporting.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Converted Timestamp' ;
    rdfs:comment 'The date and time when the cart was successfully converted to an order at checkout completion. Null for carts that have not converted. Used for cart-to-order conversion time analysis, checkout funnel performance measurement, and Conversion Rate (CR) reporting.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:couponCode rdf:type rdf:Property ;
    rdfs:label 'Coupon Code' ;
    rdfs:comment 'The alphanumeric coupon or voucher code entered by the customer and applied to this cart. Used for promotion redemption tracking, coupon campaign effectiveness analysis, and fraud detection. Null if no coupon was applied. Distinct from promotion_id which references the underlying promotion definition.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponRedemptionChannel rdf:type rdf:Property ;
    rdfs:label 'Coupon Redemption Channel' ;
    rdfs:comment 'The digital channel through which the coupon code was delivered and redeemed by the customer. Distinguishes between web browser entry, mobile app redemption, email link click-through, push notification, and SMS-triggered redemption. Supports digital marketing attribution and channel-level promotion ROI analysis.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponRedemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Coupon Redemption Status' ;
    rdfs:comment 'Current validation and application status of the coupon code entered on this cart. \'applied\' means the code was entered and discount applied; \'validated\' means the code passed validation rules but discount is pending; \'rejected\' means the code failed validation (expired, invalid, usage limit exceeded); \'reversed\' means a previously applied discount was removed. Supports promotion effectiveness and fraud monitoring.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total monetary value of all discounts applied to the cart, including promotional markdowns, coupon redemptions, and loyalty reward deductions. Represents the aggregate reduction from subtotal_amount. Used for promotion effectiveness measurement and markdown analysis per Oracle Retail Price Management (RPM).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedShippingAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Shipping Amount' ;
    rdfs:comment 'Estimated shipping and handling cost calculated for the cart based on the selected fulfillment type, destination, and applicable shipping promotions. This is an estimate at cart stage; final shipping cost is confirmed at order submission. Relevant for BOPIS and ROPIS carts where this may be zero.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Tax Amount' ;
    rdfs:comment 'Estimated sales tax calculated on the cart based on the customer\'s shipping destination and applicable tax jurisdiction rules. This is an estimate at cart stage; final tax is confirmed at order submission. Supports pre-checkout transparency requirements per FTC pricing standards.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Timestamp' ;
    rdfs:comment 'The date and time at which this cart is scheduled to expire and be purged from the active cart pool if not converted or explicitly abandoned. Determined by storefront-level cart retention policy configuration. Used for cart lifecycle management, data retention compliance, and inventory reservation release scheduling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfillmentType rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Type' ;
    rdfs:comment 'The intended fulfillment method selected by the customer for this cart. Values include standard Ship-to-Home, Buy Online Pick Up In Store (BOPIS), Reserve Online Pick Up In Store (ROPIS), Ship-from-Store (SFS), and Drop Ship (vendor direct-to-customer). Drives downstream Order Management System (OMS) routing and Last-Mile Delivery planning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAbandoned rdf:type rdf:Property ;
    rdfs:label 'Is Abandoned' ;
    rdfs:comment 'Boolean flag indicating whether this cart has been classified as abandoned based on session timeout or inactivity threshold rules. True when cart_status is \'abandoned\'. Drives abandoned cart recovery workflow triggers in the abandoned_cart_recovery product. Supports cart abandonment rate KPI reporting.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGuestCart rdf:type rdf:Property ;
    rdfs:label 'Is Guest Cart' ;
    rdfs:comment 'Indicates whether this cart was created by an unauthenticated guest user (True) or an authenticated registered customer (False). Guest carts have limited personalization and recovery capabilities. Used for guest-to-registered conversion analysis and Customer Acquisition Cost (CAC) attribution.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCount rdf:type rdf:Property ;
    rdfs:label 'Item Count' ;
    rdfs:comment 'Total number of distinct line items (unique Stock Keeping Units / SKUs) currently in the cart. Used in Units Per Transaction (UPT) analysis, basket analysis, and assortment effectiveness reporting. Distinct from total_quantity which counts aggregate units across all line items.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:localeCode rdf:type rdf:Property ;
    rdfs:label 'Locale Code' ;
    rdfs:comment 'IETF BCP 47 locale code representing the language and regional settings of the storefront session in which this cart was created (e.g., en_US, fr_CA, es_MX). Supports multi-locale storefront operations, localized pricing, and regional promotion targeting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyPointsEarned rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Earned' ;
    rdfs:comment 'Estimated number of loyalty reward points the customer will earn upon successful conversion of this cart to an order. Displayed to the customer during checkout to incentivize purchase completion. Actual points are confirmed and awarded at order fulfillment. Supports loyalty program engagement and abandoned cart recovery messaging.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyPointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Redeemed' ;
    rdfs:comment 'Number of customer loyalty reward points applied as a discount on this cart. Supports loyalty program redemption tracking, Customer Lifetime Value (CLTV) analysis, and loyalty ROI measurement. Zero if no loyalty points were applied. Integrates with the Customer Loyalty and Engagement Programs business process.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryEmailSent rdf:type rdf:Property ;
    rdfs:label 'Recovery Email Sent' ;
    rdfs:comment 'Indicates whether an abandoned cart recovery email has been dispatched to the customer for this cart (True) or not yet sent (False). Prevents duplicate recovery communications and supports recovery campaign performance tracking. Integrates with the abandoned_cart_recovery product for full recovery workflow visibility.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:savedForLaterCount rdf:type rdf:Property ;
    rdfs:label 'Saved For Later Count' ;
    rdfs:comment 'Number of items the customer has moved from the active cart to a \'saved for later\' or wishlist holding area within the same session context. Supports purchase intent analysis, re-engagement campaign targeting, and assortment demand signal capture for merchandise planning.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Pre-discount, pre-tax gross merchandise value of all items in the cart at their listed retail prices. Represents the sum of (unit price × quantity) for all line items before any promotions, coupons, or markdowns are applied. Used as the base for Average Order Value (AOV) and Gross Merchandise Value (GMV) calculations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Estimated grand total for the cart calculated as subtotal_amount minus discount_amount plus estimated_tax_amount plus estimated_shipping_amount. Represents the net amount the customer is expected to pay. Used for Average Order Value (AOV) benchmarking and abandoned cart recovery value prioritization.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cartItemId rdf:type rdf:Property ;
    rdfs:label 'Cart Item Id' ;
    rdfs:comment 'Unique surrogate identifier for each line item within a shopping cart. Primary key for the cart_item data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addToCartSource rdf:type rdf:Property ;
    rdfs:label 'Add To Cart Source' ;
    rdfs:comment 'The digital touchpoint or page from which the customer added this item to the cart. Supports Click-Through Rate (CTR) and Conversion Rate (CR) attribution analysis and product recommendation engine performance measurement. [ENUM-REF-CANDIDATE: product_detail_page|search_results|recommendation|wishlist|email_campaign|homepage|category_page|social_media|paid_ad — promote to reference product]' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addToCartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Add To Cart Timestamp' ;
    rdfs:comment 'The date and time when the customer added this item to the shopping cart. Principal business event timestamp for this entity. Used for abandoned cart analysis, session duration analytics, and digital customer journey tracking in Salesforce Commerce Cloud.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:giftMessage rdf:type rdf:Property ;
    rdfs:label 'Gift Message' ;
    rdfs:comment 'Optional personalized message entered by the customer for a gift item. Null if is_gift is False or no message was provided. Relevant only when is_gift is True.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGift rdf:type rdf:Property ;
    rdfs:label 'Is Gift' ;
    rdfs:comment 'Indicates whether the customer designated this cart line item as a gift. True if the item is intended as a gift (may include gift wrapping or message); False otherwise. Supports gifting analytics and seasonal demand planning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInStock rdf:type rdf:Property ;
    rdfs:label 'Is In Stock' ;
    rdfs:comment 'Indicates whether the product was in stock at the time the item was added to the cart. True if inventory was available; False if the item was added as a pre-order or back-order. Supports stockout-driven cart abandonment analysis.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrivateLabel rdf:type rdf:Property ;
    rdfs:label 'Is Private Label' ;
    rdfs:comment 'Indicates whether the product is a Private Label (store brand) item. True if the product is a store-owned brand; False if it is a national or third-party brand. Supports private label penetration rate and margin analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemStatus rdf:type rdf:Property ;
    rdfs:label 'Item Status' ;
    rdfs:comment 'Current lifecycle status of the cart line item. \'active\' indicates the item is in the active cart; \'removed\' indicates the customer explicitly removed it; \'saved_for_later\' indicates the item was moved to a wishlist/save-for-later list; \'purchased\' indicates the item was converted to an order; \'expired\' indicates the cart session expired before checkout.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineSequence rdf:type rdf:Property ;
    rdfs:label 'Line Sequence' ;
    rdfs:comment 'Sequential ordering number of this line item within the parent cart. Used to maintain consistent display order and support basket analysis sequencing.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineSubtotal rdf:type rdf:Property ;
    rdfs:label 'Line Subtotal' ;
    rdfs:comment 'The total monetary value of this cart line item calculated as unit_price multiplied by quantity before tax. Contributes to Average Order Value (AOV) and Gross Merchandise Value (GMV) calculations at the cart level.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Price Override Flag' ;
    rdfs:comment 'Indicates whether the unit price on this cart line item was manually overridden from the standard Oracle Retail Price Management (RPM) price. True if a price override was applied; False otherwise. Supports pricing compliance and audit reporting.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productDepartment rdf:type rdf:Property ;
    rdfs:label 'Product Department' ;
    rdfs:comment 'The retail department classification of the product (e.g., Mens Apparel, Fresh Produce, Consumer Electronics). Supports assortment depth and breadth analysis and departmental P&L reporting.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionType rdf:type rdf:Property ;
    rdfs:label 'Promotion Type' ;
    rdfs:comment 'Classification of the promotion applied to this cart line item. Supports promotion effectiveness analysis and Gross Margin Return on Investment (GMROI) reporting. [ENUM-REF-CANDIDATE: percentage_off|fixed_amount_off|buy_x_get_y|free_shipping|bundle|loyalty_reward|clearance_markdown — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Purchased Timestamp' ;
    rdfs:comment 'The date and time when this cart line item was converted to a confirmed order line. Null if the item has not been purchased. Used for cart-to-order conversion rate (CR) analysis and Gross Merchandise Value (GMV) attribution.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'The inventory quantity available for the SKU at the time the item was added to the cart. Captured as a snapshot from the inventory system. Supports out-of-stock analysis, abandoned cart attribution to stockouts, and Fill Rate reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:removalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Removal Timestamp' ;
    rdfs:comment 'The date and time when the customer explicitly removed this item from the cart. Null if the item has not been removed. Used for abandoned cart item-level recovery workflows and assortment affinity analysis.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:savedForLaterTimestamp rdf:type rdf:Property ;
    rdfs:label 'Saved For Later Timestamp' ;
    rdfs:comment 'The date and time when the customer moved this item from the active cart to the saved-for-later list. Null if the item was never saved. Supports wishlist conversion rate analysis and re-engagement campaign targeting.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'The calculated tax amount applicable to this cart line item based on the product tax category and customer shipping destination. Supports financial reporting and FASB ASC 606 revenue recognition compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'The applicable tax rate (as a decimal fraction, e.g., 0.0875 for 8.75%) applied to this cart line item. Varies by product category and jurisdiction. Supports tax compliance reporting and financial reconciliation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceZoneId rdf:type rdf:Property ;
    rdfs:label 'Price Zone Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_zone. Business justification: Checkout must apply zone-specific pricing rules, tax jurisdictions, and fulfillment-based price adjustments from price_zone. Core business process: final order pricing calculation based on customer lo' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceZone .

ind:abandonmentStep rdf:type rdf:Property ;
    rdfs:label 'Abandonment Step' ;
    rdfs:comment 'The checkout funnel step at which the customer abandoned the session. Null for completed checkouts. Identifies the highest-friction point in the checkout funnel for Conversion Rate (CR) optimization and targeted recovery messaging.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Address Validation Status' ;
    rdfs:comment 'Status of the shipping address validation performed during the address entry checkout step. \'not_validated\' = address entry step not yet reached; \'validated\' = address confirmed by address verification service; \'failed\' = address could not be validated; \'overridden\' = customer proceeded with unvalidated address. Impacts last-mile delivery success rates.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkoutNumber rdf:type rdf:Property ;
    rdfs:label 'Checkout Number' ;
    rdfs:comment 'Human-readable, externally visible reference number for the checkout session. Used in customer communications, customer service case management, and cross-system reconciliation with Salesforce Commerce Cloud. Format: CHK- followed by 10 digits.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkoutStatus rdf:type rdf:Property ;
    rdfs:label 'Checkout Status' ;
    rdfs:comment 'Current lifecycle state of the checkout session. \'initiated\' = checkout started from cart; \'in_progress\' = customer is progressing through funnel steps; \'completed\' = order successfully placed; \'abandoned\' = customer exited without placing order; \'expired\' = session timed out before completion. Core field for Conversion Rate (CR) funnel analysis.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Date and time when the checkout was successfully completed and the order was placed. Null if the checkout was abandoned or expired. Marks the boundary between the checkout domain and the order domain.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currentStep rdf:type rdf:Property ;
    rdfs:label 'Current Step' ;
    rdfs:comment 'The most recent checkout funnel step reached by the customer. Tracks progression through: cart_review → address_entry → shipping_selection → payment_entry → order_review → order_placed. Core field for Conversion Rate (CR) funnel step analysis in Salesforce Commerce Cloud.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentMode rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Mode' ;
    rdfs:comment 'The selected fulfillment method for this checkout. \'ship_to_home\' = standard home delivery; \'bopis\' = Buy Online Pick Up In Store (BOPIS); \'ropis\' = Reserve Online Pick Up In Store (ROPIS); \'drop_ship\' = vendor ships directly to customer. Drives omnichannel attribution and last-mile delivery cost analysis.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftCardAmount rdf:type rdf:Property ;
    rdfs:label 'Gift Card Amount' ;
    rdfs:comment 'Total value of gift cards applied as payment during this checkout. Zero if no gift cards were used. Tracked separately from promotional discounts for gift card liability accounting and tender type analysis.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiated Timestamp' ;
    rdfs:comment 'Date and time when the customer first entered the checkout funnel from the cart. Represents the principal business event timestamp (TRANSACTION_HEADER: BUSINESS_EVENT_TIMESTAMP). Used to measure total checkout duration and time-to-abandon metrics.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAddressEntryCompleted rdf:type rdf:Property ;
    rdfs:label 'Is Address Entry Completed' ;
    rdfs:comment 'Indicates whether the customer completed the address entry step of the checkout funnel. True = shipping/billing address entered and validated; False = not yet reached or abandoned at this step.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCartReviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Is Cart Review Completed' ;
    rdfs:comment 'Indicates whether the customer completed the cart review step of the checkout funnel. True = step completed and customer advanced; False = step not yet reached or abandoned at this step. Enables granular step-level Conversion Rate (CR) funnel analysis.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGiftOrder rdf:type rdf:Property ;
    rdfs:label 'Is Gift Order' ;
    rdfs:comment 'Indicates whether the customer designated this checkout as a gift order. True = gift order with gift messaging and/or gift wrapping selected; False = standard order. Drives gift packaging fulfillment instructions and suppresses price display on packing slips.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGuestCheckout rdf:type rdf:Property ;
    rdfs:label 'Is Guest Checkout' ;
    rdfs:comment 'Indicates whether this checkout was completed as a guest (without a registered customer account). True = guest checkout; False = authenticated customer checkout. Used to measure guest-to-registered conversion rates and assess the impact of account creation friction on Conversion Rate (CR).' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrderReviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Is Order Review Completed' ;
    rdfs:comment 'Indicates whether the customer completed the order review step (final summary before placement). True = customer reviewed and confirmed order summary; False = not yet reached or abandoned at this step.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaymentEntryCompleted rdf:type rdf:Property ;
    rdfs:label 'Is Payment Entry Completed' ;
    rdfs:comment 'Indicates whether the customer completed the payment entry step. True = payment instrument entered and validated; False = not yet reached or abandoned at this step. High abandonment at this step may indicate payment friction or trust issues.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isShippingSelectionCompleted rdf:type rdf:Property ;
    rdfs:label 'Is Shipping Selection Completed' ;
    rdfs:comment 'Indicates whether the customer completed the shipping method selection step. True = shipping method selected and confirmed; False = not yet reached or abandoned at this step.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Order Total Amount' ;
    rdfs:comment 'The final net amount due from the customer after applying subtotal, shipping, tax, discounts, gift cards, and store credits. Represents the actual charge to the customer\'s payment instrument. Core metric for Average Order Value (AOV) and Gross Merchandise Value (GMV) reporting.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The primary payment instrument type selected by the customer during checkout. Tracks the tender type for payment mix analysis, fraud risk scoring, and PCI DSS compliance reporting. Split-tender checkouts record the primary instrument. [ENUM-REF-CANDIDATE: credit_card|debit_card|paypal|apple_pay|google_pay|gift_card|store_credit|buy_now_pay_later|bank_transfer — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Status of the payment authorization attempt during checkout. \'pending\' = authorization not yet attempted; \'authorized\' = payment instrument pre-authorized; \'captured\' = funds captured at order placement; \'declined\' = authorization declined by payment processor; \'failed\' = technical failure during authorization. Tracks payment friction in the checkout funnel.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoCode rdf:type rdf:Property ;
    rdfs:label 'Promo Code' ;
    rdfs:comment 'The promotional or coupon code entered by the customer during checkout. Null if no promo code was applied. Used for promotion campaign attribution, discount redemption tracking, and Oracle Retail Price Management (RPM) reconciliation.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Amount' ;
    rdfs:comment 'The shipping and handling charge applied to this checkout. Zero for free shipping promotions, BOPIS, and ROPIS fulfillment modes. Contributes to total order value and is tracked separately for shipping revenue and promotion effectiveness analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingMethodCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Method Code' ;
    rdfs:comment 'Code identifying the selected shipping method (e.g., STANDARD_5DAY, EXPRESS_2DAY, OVERNIGHT, SAME_DAY). Sourced from Salesforce Commerce Cloud shipping method catalog. Applicable when fulfillment_mode is \'ship_to_home\' or \'drop_ship\'. Null for BOPIS/ROPIS.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethodName rdf:type rdf:Property ;
    rdfs:label 'Shipping Method Name' ;
    rdfs:comment 'Human-readable display name of the selected shipping method as shown to the customer during checkout (e.g., \'Standard Shipping (5-7 Business Days)\', \'Express 2-Day Delivery\'). Preserved for customer-facing reporting and service resolution.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Store Credit Amount' ;
    rdfs:comment 'Total store credit balance applied as payment during this checkout. Zero if no store credit was used. Store credits typically originate from returns, loyalty rewards, or customer service adjustments. Tracked separately for liability accounting.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalCatalogId rdf:type rdf:Property ;
    rdfs:label 'Digital Catalog Id' ;
    rdfs:comment 'Unique surrogate identifier for each digital catalog record representing a channel-specific published view of a SKU on a given storefront. Primary key for this entity. Entity role: MASTER_RESOURCE — represents a digital presentation asset managed and published via Salesforce Commerce Cloud.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalCatalog .

ind:seasonId rdf:type rdf:Property ;
    rdfs:label 'Season Id' ;
    rdfs:comment 'Foreign key linking to merchandising.season. Business justification: Online catalog organized by retail seasons (Spring/Summer, Fall/Winter, Holiday). Seasonal merchandising drives publish/unpublish schedules, promotional calendars, and assortment planning. Critical fo' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Season .

ind:ageRestriction rdf:type rdf:Property ;
    rdfs:label 'Age Restriction' ;
    rdfs:comment 'Age-gating requirement for this SKU on the digital storefront, applicable to regulated product categories such as alcohol, tobacco, and certain pharmaceuticals. Drives age verification workflows at checkout. Regulated by FTC and FDA.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'Consumer-facing brand name associated with this SKU as displayed on the digital storefront. Used for brand-level filtering, faceted navigation, and brand page attribution. Includes private label (store brand) designations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:canonicalUrl rdf:type rdf:Property ;
    rdfs:label 'Canonical Url' ;
    rdfs:comment 'The canonical URL of the product detail page (PDP) used to prevent duplicate content issues across multiple storefront URLs or faceted navigation paths. Declared in the HTML link rel=canonical tag. Managed in Salesforce Commerce Cloud.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentCompletenessScore rdf:type rdf:Property ;
    rdfs:label 'Content Completeness Score' ;
    rdfs:comment 'Percentage score (0.00–100.00) measuring how complete the digital content is for this catalog record, based on presence of required fields such as title, description, images, SEO metadata, and rich media. Used to prioritize content enrichment efforts and improve Conversion Rate (CR).' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hasVideo rdf:type rdf:Property ;
    rdfs:label 'Has Video' ;
    rdfs:comment 'Indicates whether at least one product video (e.g., demonstration, unboxing, lifestyle) is published for this SKU on the storefront. Rich media presence is a key driver of Conversion Rate (CR) improvement in digital commerce.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether this SKU contains hazardous materials subject to special shipping, handling, or labeling requirements. Affects last-mile delivery eligibility and carrier selection in the Order Management System (OMS). Regulated by CPSC and OSHA.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imageCount rdf:type rdf:Property ;
    rdfs:label 'Image Count' ;
    rdfs:comment 'Total number of product images published for this SKU on the storefront, including hero, alternate angles, lifestyle, and swatch images. Used to measure digital content completeness and identify SKUs requiring additional imagery.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDropShipEligible rdf:type rdf:Property ;
    rdfs:label 'Is Drop Ship Eligible' ;
    rdfs:comment 'Indicates whether this SKU is fulfilled via Drop Ship, where the vendor ships directly to the customer without passing through a Distribution Center (DC). Relevant for extended aisle and marketplace assortment strategies.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFeatured rdf:type rdf:Property ;
    rdfs:label 'Is Featured' ;
    rdfs:comment 'Indicates whether this SKU has been manually designated as a featured product by digital merchandisers, qualifying it for placement in featured product carousels, homepage spotlights, or category hero positions on the storefront.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOnlineAvailable rdf:type rdf:Property ;
    rdfs:label 'Is Online Available' ;
    rdfs:comment 'Indicates whether the SKU is currently available for purchase on the digital storefront. Distinct from publication_status — a product may be published but temporarily unavailable due to inventory depletion or fulfillment constraints. Drives add-to-cart eligibility.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSearchable rdf:type rdf:Property ;
    rdfs:label 'Is Searchable' ;
    rdfs:comment 'Indicates whether this SKU is indexed and returned in on-site search results on the digital storefront. A product may be published but excluded from search (e.g., exclusive landing page products or clearance items managed via direct URL only).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPublishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Published Timestamp' ;
    rdfs:comment 'The exact date and time when this digital catalog record was most recently published or re-published to the live storefront. Used for content freshness tracking, cache invalidation, and audit trails in Salesforce Commerce Cloud.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:longDescription rdf:type rdf:Property ;
    rdfs:label 'Long Description' ;
    rdfs:comment 'Full consumer-facing product description displayed on the product detail page (PDP), including features, benefits, materials, and usage instructions. Supports rich HTML formatting. Managed in Salesforce Commerce Cloud content management.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryImageUrl rdf:type rdf:Property ;
    rdfs:label 'Primary Image Url' ;
    rdfs:comment 'URL of the primary hero product image displayed on the product detail page (PDP) and product listing pages (PLP). Hosted on the digital asset management (DAM) system or CDN. Critical for digital content completeness scoring.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'The consumer-facing product title as displayed on the digital storefront. May differ from the master product name in PIM to reflect channel-specific merchandising copy or A/B tested titles. Satisfies MASTER_RESOURCE IDENTITY_LABEL category.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishEndDate rdf:type rdf:Property ;
    rdfs:label 'Publish End Date' ;
    rdfs:comment 'The date on which this digital catalog record is scheduled to be or was deactivated and removed from the storefront. Used for seasonal assortment management, limited-time offers, and clearance markdown lifecycle management.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publishStartDate rdf:type rdf:Property ;
    rdfs:label 'Publish Start Date' ;
    rdfs:comment 'The date on which this digital catalog record is scheduled to become or became active and visible on the storefront. Used for pre-launch product scheduling and promotional launch coordination in Salesforce Commerce Cloud.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingAverage rdf:type rdf:Property ;
    rdfs:label 'Rating Average' ;
    rdfs:comment 'Average customer review rating for this SKU on the digital storefront, on a scale of 0.00 to 5.00. Aggregated from verified purchase reviews. Used in product ranking algorithms, content completeness scoring, and conversion rate optimization analytics.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewCount rdf:type rdf:Property ;
    rdfs:label 'Review Count' ;
    rdfs:comment 'Total number of published customer reviews for this SKU on the digital storefront. Used alongside rating_average to assess review volume credibility and identify SKUs requiring review generation campaigns.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seoMetaDescription rdf:type rdf:Property ;
    rdfs:label 'Seo Meta Description' ;
    rdfs:comment 'The HTML meta description tag for the product detail page (PDP), summarizing the product for search engine result snippets. Typically 150-160 characters. Drives organic Click-Through Rate (CTR) from search engine results pages.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seoTitle rdf:type rdf:Property ;
    rdfs:label 'Seo Title' ;
    rdfs:comment 'The HTML page title tag for the product detail page (PDP), optimized for search engine indexing. Typically limited to 60 characters per SEO best practices. Managed in Salesforce Commerce Cloud content management.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Brief consumer-facing product description displayed in product listing pages (PLP) and search results. Typically 100-200 characters. Sourced from Salesforce Commerce Cloud product content and may differ from the master description in PIM.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Tax Category Code' ;
    rdfs:comment 'Tax classification code assigned to this SKU for digital commerce tax calculation purposes, determining applicable sales tax rates at checkout. Mapped to tax engine rules in Salesforce Commerce Cloud. Relevant for FDA-regulated food items with tax exemptions.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urlSlug rdf:type rdf:Property ;
    rdfs:label 'Url Slug' ;
    rdfs:comment 'The human-readable URL path segment for the product detail page (PDP), used in constructing the storefront URL. Must be lowercase, hyphen-separated, and unique per storefront. Example: \'mens-slim-fit-chino-pants-navy\'.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalPaymentId rdf:type rdf:Property ;
    rdfs:label 'Digital Payment Id' ;
    rdfs:comment 'Unique surrogate identifier for each digital payment transaction record in the e-commerce channel. Primary key for the digital_payment data product.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ar_invoice. Business justification: Payment reconciliation and cash application require linking payment transactions to AR invoices for revenue recognition, DSO tracking, and financial close processes in retail accounting systems.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:customerPaymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Customer Payment Method Id' ;
    rdfs:comment 'Foreign key linking to customer.payment_method. Business justification: Links payment transaction to stored payment instrument. Business need: payment method performance analysis (authorization rates by card type), fraud pattern detection by instrument, PCI compliance aud' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentMethod .

ind:returnsRefundId rdf:type rdf:Property ;
    rdfs:label 'Returns Refund Id' ;
    rdfs:comment 'Foreign key linking to returns.refund. Business justification: Payment reversal and refund reconciliation is a critical business process. When returns are processed, the original digital payment must be linked to the refund transaction for accounting, dispute res' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Refund .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'The alphanumeric authorization code returned by the issuing bank or payment network upon successful authorization of the payment. Required for dispute resolution, chargeback management, and financial reconciliation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorization Timestamp' ;
    rdfs:comment 'The timestamp when the payment authorization response was received from the issuing bank or payment network. Distinct from the initiated timestamp; used for authorization latency monitoring and SLA (Service Level Agreement) tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:avsResultCode rdf:type rdf:Property ;
    rdfs:label 'Avs Result Code' ;
    rdfs:comment 'The Address Verification Service (AVS) result code returned by the issuing bank, indicating whether the billing address provided by the customer matches the address on file. Used for fraud risk assessment and chargeback liability management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 Alpha-3 country code of the customer\'s billing address (e.g., USA, GBR, DEU). Used for fraud geo-risk scoring, tax jurisdiction determination, and international payment compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'The postal/ZIP code of the customer\'s billing address. Used for Address Verification Service (AVS) fraud checks, tax jurisdiction determination, and geographic sales analytics.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Capture Timestamp' ;
    rdfs:comment 'The timestamp when the authorized payment was captured (settled) from the customer\'s account. Marks the point of revenue recognition per FASB ASC 606. Null if payment was not captured (e.g., declined or voided).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cardBin rdf:type rdf:Property ;
    rdfs:label 'Card Bin' ;
    rdfs:comment 'The Bank Identification Number (BIN), the first 6-8 digits of the payment card number, identifying the issuing bank and card network. Used for fraud analytics, card-type classification, and interchange fee analysis. Not a full PAN — PCI DSS compliant to store.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardExpiryMonth rdf:type rdf:Property ;
    rdfs:label 'Card Expiry Month' ;
    rdfs:comment 'The expiration month of the payment card (1–12). Used in conjunction with card_expiry_year for card validity checks and customer payment method management. PCI DSS permits storage of expiry date.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardExpiryYear rdf:type rdf:Property ;
    rdfs:label 'Card Expiry Year' ;
    rdfs:comment 'The four-digit expiration year of the payment card. Used in conjunction with card_expiry_month for card validity checks and customer payment method management. PCI DSS permits storage of expiry date.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardLastFour rdf:type rdf:Property ;
    rdfs:label 'Card Last Four' ;
    rdfs:comment 'The last four digits of the payment card number. PCI DSS permits storage of the last four digits for customer service, dispute resolution, and payment method recognition. Not a full PAN.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardNetwork rdf:type rdf:Property ;
    rdfs:label 'Card Network' ;
    rdfs:comment 'The payment card network associated with the transaction (e.g., Visa, Mastercard, Amex, Discover, UnionPay). Used for interchange fee analysis, network-level fraud monitoring, and tender-mix reporting.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvvResultCode rdf:type rdf:Property ;
    rdfs:label 'Cvv Result Code' ;
    rdfs:comment 'The Card Verification Value (CVV/CVC) check result code returned by the issuing bank (M=Match, N=No Match, P=Not Processed, S=Issuer Not Certified, U=Unknown). Used for fraud risk assessment. Note: The actual CVV value is NEVER stored per PCI DSS Requirement 3.2.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'Numeric fraud risk score assigned by the fraud screening engine, typically on a scale of 0–100 or 0–1000 depending on the provider. Higher scores indicate greater fraud risk. Used for threshold-based decisioning and fraud analytics.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Fraud Screening Result' ;
    rdfs:comment 'The outcome of the automated fraud screening check applied to the payment transaction by the fraud detection engine (e.g., Adyen RevenueProtect, Stripe Radar). Values: pass (cleared), review (flagged for manual review), reject (blocked). Drives order hold and manual review workflows.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayResponseCode rdf:type rdf:Property ;
    rdfs:label 'Gateway Response Code' ;
    rdfs:comment 'The raw response code returned by the payment gateway for the transaction (e.g., \'00\' for approved, \'05\' for declined). Used for decline reason analysis, gateway troubleshooting, and Conversion Rate (CR) optimization.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Gateway Transaction Reference' ;
    rdfs:comment 'The unique transaction identifier assigned by the payment gateway (Adyen, Stripe, PayPal) for this payment. Used for cross-system reconciliation, dispute management, and gateway-level reporting.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installmentCount rdf:type rdf:Property ;
    rdfs:label 'Installment Count' ;
    rdfs:comment 'The number of installment payments agreed upon for Buy Now Pay Later (BNPL) transactions. Null or 1 for non-installment payment methods. Supports BNPL provider reconciliation and deferred revenue tracking.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether this payment is part of a recurring or subscription billing arrangement (True) or a one-time transaction (False). Relevant for subscription commerce, loyalty auto-renewal, and recurring revenue reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTestTransaction rdf:type rdf:Property ;
    rdfs:label 'Is Test Transaction' ;
    rdfs:comment 'Indicates whether this payment record is a test or sandbox transaction (True) rather than a live production transaction (False). Ensures test transactions are excluded from financial reporting, GMV calculations, and fraud analytics.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The net total amount actually charged to the customer after all adjustments (discounts, promotions, taxes). Represents the final settled monetary value of the transaction. Core field for revenue recognition per FASB ASC 606.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'The gross base payment amount submitted by the customer before any adjustments. Represents the principal monetary value of the digital payment transaction. Used in Gross Merchandise Value (GMV) and Average Order Value (AOV) calculations.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'The digital channel interface through which the payment was submitted (e.g., web, mobile app, mobile web, marketplace, Buy Online Pick Up In Store (BOPIS), Reserve Online Pick Up In Store (ROPIS)). Distinct from payment_method_type. Supports omnichannel attribution and channel-level GMV reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentGateway rdf:type rdf:Property ;
    rdfs:label 'Payment Gateway' ;
    rdfs:comment 'The third-party payment gateway provider that processed the digital payment transaction (e.g., Adyen, Stripe, PayPal, Braintree, Worldpay). Used for gateway performance monitoring, fee reconciliation, and failover analysis.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciToken rdf:type rdf:Property ;
    rdfs:label 'Pci Token' ;
    rdfs:comment 'The PCI DSS-compliant tokenization reference that replaces the actual payment card number (PAN) in storage. Ensures cardholder data is never stored in plain text. Issued by the payment gateway tokenization vault.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Timestamp' ;
    rdfs:comment 'The timestamp when a refund or partial refund was initiated for this payment transaction. Null if no refund has been processed. Supports return merchandise authorization (RMA) and customer service workflows.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:threeDsStatus rdf:type rdf:Property ;
    rdfs:label 'Three Ds Status' ;
    rdfs:comment 'The result of the 3D Secure (3DS) strong customer authentication challenge applied during checkout. Indicates whether the cardholder was successfully authenticated by their issuing bank. Drives liability shift determination and chargeback risk management.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeDsVersion rdf:type rdf:Property ;
    rdfs:label 'Three Ds Version' ;
    rdfs:comment 'The version of the 3D Secure protocol used during authentication (e.g., 1.0, 2.1, 2.2, 2.3). Relevant for compliance tracking as 3DS 1.0 is deprecated and 3DS 2.x is the current standard.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference' ;
    rdfs:comment 'Externally-known unique transaction reference number assigned by the payment gateway (e.g., Adyen, Stripe, PayPal) at the time of payment initiation. Used for reconciliation, dispute resolution, and cross-system tracing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walletProvider rdf:type rdf:Property ;
    rdfs:label 'Wallet Provider' ;
    rdfs:comment 'The digital wallet provider used when payment_method_type is a wallet-based instrument (e.g., Apple Pay, Google Pay, Samsung Pay, PayPal). Null for non-wallet payment methods. Supports digital wallet adoption analytics.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketplaceListingId rdf:type rdf:Property ;
    rdfs:label 'Marketplace Listing Id' ;
    rdfs:comment 'Unique surrogate identifier for each marketplace listing record in the Retail data platform. Primary key for the marketplace_listing product. Role: MASTER_RESOURCE.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfillmentLocationId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Location Id' ;
    rdfs:comment 'Foreign key linking to store.store_location. Business justification: Marketplace orders fulfilled from stores require tracking which store ships the item. Real business process: marketplace ship-from-store operations, store-level marketplace performance reporting, inve' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:ageRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Age Restriction Flag' ;
    rdfs:comment 'Indicates whether the product listing has an age restriction (e.g., alcohol, tobacco, adult content, rated video games). True = age-gated product; False = no age restriction. Drives marketplace compliance controls and checkout age verification flows.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoryPath rdf:type rdf:Property ;
    rdfs:label 'Category Path' ;
    rdfs:comment 'The full hierarchical category path assigned to this listing on the marketplace (e.g., \'Electronics > Computers > Laptops\'). Used for category management, assortment breadth analysis, and marketplace taxonomy alignment. May differ from internal Oracle Retail Merchandising System (ORMS) category hierarchy.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorPrice rdf:type rdf:Property ;
    rdfs:label 'Competitor Price' ;
    rdfs:comment 'The lowest competing seller price observed for this listing on the marketplace at the time of last sync. Used for competitive pricing intelligence, Hi-Lo (High-Low Pricing Strategy) analysis, and automated repricing decisions via Oracle Retail Price Management (RPM). Populated from marketplace API competitive pricing data.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Content Compliance Flag' ;
    rdfs:comment 'Indicates whether the listing content meets all applicable marketplace content policies and regulatory requirements (e.g., FDA labeling for food/grocery, CPSC safety warnings, FTC advertising standards). True = compliant; False = compliance issue detected requiring remediation.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ean rdf:type rdf:Property ;
    rdfs:label 'Ean' ;
    rdfs:comment 'The 13-digit European Article Number (EAN) / GTIN-13 for the listed product. Required for international marketplace listings (e.g., eBay international, Google Shopping). Sourced from Informatica MDM product golden record.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentMethod rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Method' ;
    rdfs:comment 'The fulfillment method used for this marketplace listing. FBM = Fulfilled by Merchant (Retail ships directly); FBA = Fulfilled by Amazon (Amazon warehouses and ships); WFS = Walmart Fulfillment Services; SFS = Ship-from-Store; Dropship = vendor direct-to-customer; 3PL = Third-Party Logistics provider. Drives operational routing in Manhattan Associates WMS and Blue Yonder Demand Planning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryQuantity rdf:type rdf:Property ;
    rdfs:label 'Inventory Quantity' ;
    rdfs:comment 'The current available inventory quantity published to the marketplace for this listing. Drives out-of-stock status and buy box eligibility. Synchronized from Manhattan Associates WMS or Blue Yonder Demand Planning replenishment signals.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBuyBoxOwner rdf:type rdf:Property ;
    rdfs:label 'Is Buy Box Owner' ;
    rdfs:comment 'Indicates whether Retail currently owns the buy box (featured offer) for this marketplace listing. True = Retail is the featured seller; False = a competing seller holds the buy box. Critical KPI for marketplace channel management and competitive pricing strategy. Sourced from marketplace API sync.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Sync Timestamp' ;
    rdfs:comment 'The timestamp of the most recent successful data synchronization between Retail\'s internal systems (Salesforce Commerce Cloud / Informatica MDM) and the marketplace platform API. Used to detect stale listings and trigger re-sync workflows. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:listedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Listed Timestamp' ;
    rdfs:comment 'The timestamp when this listing was first published or activated on the marketplace platform. RECORD_AUDIT_CREATED equivalent for the MASTER_RESOURCE role. Used for listing age analysis and new product launch tracking. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:listingQualityScore rdf:type rdf:Property ;
    rdfs:label 'Listing Quality Score' ;
    rdfs:comment 'Marketplace-assigned or internally calculated score (0–100) reflecting the completeness and quality of the listing content (title, images, bullet points, description, A+ content). Higher scores correlate with improved search ranking and conversion rate (CR). Sourced from marketplace API or internal PIM (Product Information Management) audit.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:listingStatus rdf:type rdf:Property ;
    rdfs:label 'Listing Status' ;
    rdfs:comment 'Current operational lifecycle status of the marketplace listing. LIFECYCLE_STATUS for the MASTER_RESOURCE role. \'active\' = live and buyable; \'suppressed\' = marketplace has hidden the listing due to content/compliance issues; \'inactive\' = manually deactivated; \'out_of_stock\' = no inventory available; \'pending_review\' = awaiting marketplace approval; \'removed\' = permanently delisted. [ENUM-REF-CANDIDATE: active|suppressed|inactive|out_of_stock|pending_review|removed — promote to reference product]' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingTitle rdf:type rdf:Property ;
    rdfs:label 'Listing Title' ;
    rdfs:comment 'The product title as displayed on the marketplace listing page. This is the IDENTITY_LABEL for the MASTER_RESOURCE role. Optimized per marketplace SEO and content guidelines; may differ from the internal product name in the PIM (Product Information Management) system.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingUrl rdf:type rdf:Property ;
    rdfs:label 'Listing Url' ;
    rdfs:comment 'The direct URL to the product listing page on the marketplace. Used for competitive monitoring, digital marketing attribution, and customer service reference. Sourced from marketplace API.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mainImageUrl rdf:type rdf:Property ;
    rdfs:label 'Main Image Url' ;
    rdfs:comment 'URL of the primary product image displayed on the marketplace listing. Image quality and compliance with marketplace image standards directly impacts listing_quality_score and conversion rate (CR). Managed via PIM (Product Information Management) system.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketplaceItemCode rdf:type rdf:Property ;
    rdfs:label 'Marketplace Item Code' ;
    rdfs:comment 'The platform-native unique identifier assigned by the marketplace to this listing (e.g., Amazon ASIN, eBay Item ID, Walmart Item ID). Used for API synchronization, competitive pricing intelligence, and marketplace-specific operations. This is the BUSINESS_IDENTIFIER for the MASTER_RESOURCE role.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketplacePlatform rdf:type rdf:Property ;
    rdfs:label 'Marketplace Platform' ;
    rdfs:comment 'The third-party marketplace platform on which this listing is published (e.g., Amazon, eBay, Walmart Marketplace, Google Shopping). Drives channel-specific GMV (Gross Merchandise Value) reporting and marketplace channel management strategy. [ENUM-REF-CANDIDATE: amazon|ebay|walmart_marketplace|google_shopping|target_plus|other — promote to reference product if additional platforms are onboarded]' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketplacePrice rdf:type rdf:Property ;
    rdfs:label 'Marketplace Price' ;
    rdfs:comment 'The current selling price of the product on the marketplace listing, expressed in the listing currency. MEASUREMENT_OR_VALUE for the MASTER_RESOURCE role. Used for competitive pricing intelligence, AUR (Average Unit Retail) tracking, and GMV (Gross Merchandise Value) calculation. Managed via Oracle Retail Price Management (RPM).' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketplaceRating rdf:type rdf:Property ;
    rdfs:label 'Marketplace Rating' ;
    rdfs:comment 'The average customer star rating for this listing on the marketplace (typically 1.0–5.0 scale). Influences buy box eligibility, search ranking, and conversion rate (CR). Sourced from marketplace API.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketplaceSellerCode rdf:type rdf:Property ;
    rdfs:label 'Marketplace Seller Code' ;
    rdfs:comment 'Retail\'s seller account identifier on the marketplace platform (e.g., Amazon Merchant ID, Walmart Seller ID). Used to distinguish Retail\'s listings from third-party sellers on the same marketplace and to attribute GMV (Gross Merchandise Value) to the correct seller account.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketplaceStorefrontName rdf:type rdf:Property ;
    rdfs:label 'Marketplace Storefront Name' ;
    rdfs:comment 'The display name of Retail\'s storefront or seller profile on the marketplace (e.g., \'Retail Official Store\' on Amazon). Used for brand consistency monitoring and customer-facing identity management across marketplace channels.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrp rdf:type rdf:Property ;
    rdfs:label 'Msrp' ;
    rdfs:comment 'The manufacturer\'s suggested retail price (MSRP) or list price for the product. Used as the reference price for markdown calculations and marketplace price compliance. Sourced from Oracle Retail Merchandising System (ORMS).' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Prime Eligible Flag' ;
    rdfs:comment 'Indicates whether this listing qualifies for marketplace premium fast-shipping programs (e.g., Amazon Prime, Walmart TwoDay). True = eligible for fast-shipping badge; False = standard shipping only. Directly impacts buy box eligibility and conversion rate (CR).' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Eligibility Flag' ;
    rdfs:comment 'Indicates whether this marketplace listing is eligible to participate in marketplace-native promotions (e.g., Amazon Lightning Deals, Walmart Rollback). True = eligible; False = ineligible due to price, category, or performance constraints. Supports Pricing and Promotions Management business process.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reorderThreshold rdf:type rdf:Property ;
    rdfs:label 'Reorder Threshold' ;
    rdfs:comment 'The minimum inventory quantity level at which a replenishment order is triggered for this marketplace listing. Used in conjunction with Blue Yonder Demand Planning to prevent out-of-stock events and maintain listing availability.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sellThroughRate rdf:type rdf:Property ;
    rdfs:label 'Sell Through Rate' ;
    rdfs:comment 'The ratio of units sold to units available for this listing over a rolling period (expressed as a decimal, e.g., 0.75 = 75% sell-through rate). Used for inventory health monitoring, markdown decision support, and dead stock identification. Calculated from SAP Customer Activity Repository (CAR) POS/digital transaction data.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingWeightKg rdf:type rdf:Property ;
    rdfs:label 'Shipping Weight Kg' ;
    rdfs:comment 'The shipping weight of the product in kilograms as declared on the marketplace listing. Used for marketplace fulfillment fee calculation (FBA, WFS), shipping cost estimation, and hazmat classification. Sourced from Informatica MDM product master.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upc rdf:type rdf:Property ;
    rdfs:label 'Upc' ;
    rdfs:comment 'The 12-digit Universal Product Code (UPC) associated with this listing. Used by marketplaces for product catalog matching and compliance. Sourced from Informatica MDM product golden record.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationRuleId rdf:type rdf:Property ;
    rdfs:label 'Personalization Rule Id' ;
    rdfs:comment 'Unique identifier for the personalization rule. Primary key.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PersonalizationRule .

ind:customerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Id' ;
    rdfs:comment 'Identifier of the customer segment targeted by this personalization rule, enabling segment-specific experiences.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:abTestVariant rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant' ;
    rdfs:comment 'Specific variant or treatment group within the A/B test that this rule represents (e.g., control, variant_a, variant_b).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:algorithmType rdf:type rdf:Property ;
    rdfs:label 'Algorithm Type' ;
    rdfs:comment 'Machine learning or recommendation algorithm used by this rule to generate personalized experiences.' ;
    rdfs:domain ind:PersonalizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Attributed Revenue Amount' ;
    rdfs:comment 'Total revenue in the storefront currency attributed to conversions driven by this personalization rule.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clickCount rdf:type rdf:Property ;
    rdfs:label 'Click Count' ;
    rdfs:comment 'Total number of clicks on personalized recommendations generated by this rule.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confidenceThreshold rdf:type rdf:Property ;
    rdfs:label 'Confidence Threshold' ;
    rdfs:comment 'Minimum confidence score (0.0 to 1.0) required for a recommendation to be included in the personalized result set, ensuring quality control.' ;
    rdfs:domain ind:PersonalizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionCount rdf:type rdf:Property ;
    rdfs:label 'Conversion Count' ;
    rdfs:comment 'Total number of conversions (purchases) attributed to personalized recommendations from this rule.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionRate rdf:type rdf:Property ;
    rdfs:label 'Conversion Rate' ;
    rdfs:comment 'Conversion rate calculated as conversions divided by clicks, measuring purchase effectiveness of this personalization rule.' ;
    rdfs:domain ind:PersonalizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctr rdf:type rdf:Property ;
    rdfs:label 'Ctr' ;
    rdfs:comment 'Click-through rate calculated as clicks divided by impressions, measuring engagement effectiveness of this personalization rule.' ;
    rdfs:domain ind:PersonalizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviceTypeFilter rdf:type rdf:Property ;
    rdfs:label 'Device Type Filter' ;
    rdfs:comment 'Comma-separated list of device types this rule targets (e.g., mobile, tablet, desktop) when device-specific targeting is enabled.' ;
    rdfs:domain ind:PersonalizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exclusion Criteria' ;
    rdfs:comment 'Business logic defining products, categories, or content that should be excluded from personalized recommendations (e.g., out-of-stock items, age-restricted products).' ;
    rdfs:domain ind:PersonalizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackStrategy rdf:type rdf:Property ;
    rdfs:label 'Fallback Strategy' ;
    rdfs:comment 'Strategy used to populate recommendations when the primary algorithm cannot generate sufficient personalized results.' ;
    rdfs:domain ind:PersonalizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCountryCodes rdf:type rdf:Property ;
    rdfs:label 'Geo Country Codes' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this personalization rule is applied (e.g., USA, CAN, GBR).' ;
    rdfs:domain ind:PersonalizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionCount rdf:type rdf:Property ;
    rdfs:label 'Impression Count' ;
    rdfs:comment 'Total number of times this personalization rule has been displayed to customers since activation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDeviceSpecific rdf:type rdf:Property ;
    rdfs:label 'Is Device Specific' ;
    rdfs:comment 'Flag indicating whether this rule applies only to specific device types (mobile, tablet, desktop) or is device-agnostic.' ;
    rdfs:domain ind:PersonalizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGeoTargeted rdf:type rdf:Property ;
    rdfs:label 'Is Geo Targeted' ;
    rdfs:comment 'Flag indicating whether this rule applies geographic targeting based on customer location.' ;
    rdfs:domain ind:PersonalizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastExecutedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Executed Timestamp' ;
    rdfs:comment 'Timestamp when this personalization rule was last executed and generated recommendations for a customer session.' ;
    rdfs:domain ind:PersonalizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxRecommendationCount rdf:type rdf:Property ;
    rdfs:label 'Max Recommendation Count' ;
    rdfs:comment 'Maximum number of personalized items or recommendations that can be returned when this rule is executed.' ;
    rdfs:domain ind:PersonalizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minRecommendationCount rdf:type rdf:Property ;
    rdfs:label 'Min Recommendation Count' ;
    rdfs:comment 'Minimum number of personalized items or recommendations that must be returned when this rule is executed.' ;
    rdfs:domain ind:PersonalizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:placementLocation rdf:type rdf:Property ;
    rdfs:label 'Placement Location' ;
    rdfs:comment 'Digital storefront page or zone where the personalization rule is applied and recommendations are displayed. PDP refers to Product Detail Page.' ;
    rdfs:domain ind:PersonalizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementZone rdf:type rdf:Property ;
    rdfs:label 'Placement Zone' ;
    rdfs:comment 'Specific zone or slot within the placement location where personalized content is rendered (e.g., hero banner, sidebar, below-the-fold).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingCriteria rdf:type rdf:Property ;
    rdfs:label 'Targeting Criteria' ;
    rdfs:comment 'Business logic or conditions defining which customer segments, behaviors, or contexts trigger this personalization rule (e.g., new visitors, cart value > $100, mobile users).' ;
    rdfs:domain ind:PersonalizationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'User identifier or system account that last modified this personalization rule.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productPageViewId rdf:type rdf:Property ;
    rdfs:label 'Product Page View Id' ;
    rdfs:comment 'Unique surrogate identifier for each product detail page (PDP) view event record. Primary key for this event log table.' ;
    rdfs:domain ind:ProductPageView ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displayedPrice rdf:type rdf:Property ;
    rdfs:label 'Displayed Price' ;
    rdfs:comment 'The retail selling price displayed to the visitor on the product detail page at the time of the view, in the storefront\'s operating currency. Captures the price as shown, which may reflect markdowns, promotions, or personalized pricing. Used for Average Unit Retail (AUR) and price sensitivity analysis.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geo Country Code' ;
    rdfs:comment 'The ISO 3166-1 alpha-3 three-letter country code of the visitor\'s geographic location at the time of the product detail page view, derived from IP geolocation. Used for regional product demand analysis and international digital commerce reporting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'The inventory availability status displayed on the product detail page at the time of the view (e.g., in_stock, low_stock, out_of_stock, backorder, preorder). Captures the stock signal shown to the customer, which influences conversion behavior and demand signals.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAddToCart rdf:type rdf:Property ;
    rdfs:label 'Is Add To Cart' ;
    rdfs:comment 'Indicates whether the visitor added the viewed product to their shopping cart during or immediately following this product detail page view. Key metric for Conversion Rate (CR) funnel analysis and product affinity scoring.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBot rdf:type rdf:Property ;
    rdfs:label 'Is Bot' ;
    rdfs:comment 'Indicates whether this product detail page view event was identified as non-human (bot, crawler, or automated traffic) based on user-agent analysis and behavioral signals. Bot-flagged events are excluded from Conversion Rate (CR) and Click-Through Rate (CTR) calculations.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMarkdownPrice rdf:type rdf:Property ;
    rdfs:label 'Is Markdown Price' ;
    rdfs:comment 'Indicates whether the price displayed on the product detail page at the time of the view was a markdown (reduced) price rather than the regular selling price. Supports markdown effectiveness analysis and Hi-Lo pricing strategy reporting.' ;
    rdfs:domain ind:ProductPageView ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecommendationClicked rdf:type rdf:Property ;
    rdfs:label 'Is Recommendation Clicked' ;
    rdfs:comment 'Indicates whether the visitor clicked on a recommended product during this product detail page view. Used to calculate Click-Through Rate (CTR) for recommendation engine performance measurement.' ;
    rdfs:domain ind:ProductPageView ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecommendationServed rdf:type rdf:Property ;
    rdfs:label 'Is Recommendation Served' ;
    rdfs:comment 'Indicates whether a product recommendation was served to the visitor during this product detail page view. True when the personalization engine delivered at least one recommendation impression on the page.' ;
    rdfs:domain ind:ProductPageView ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWishlistAdd rdf:type rdf:Property ;
    rdfs:label 'Is Wishlist Add' ;
    rdfs:comment 'Indicates whether the visitor added the viewed product to a wishlist or saved-for-later list during this page view. Supports demand signal analysis, product affinity modeling, and personalized re-engagement campaigns.' ;
    rdfs:domain ind:ProductPageView ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pageUrl rdf:type rdf:Property ;
    rdfs:label 'Page Url' ;
    rdfs:comment 'The full URL of the product detail page (PDP) that was viewed. Used for SEO analysis, canonical URL tracking, and A/B test variant identification in digital merchandising.' ;
    rdfs:domain ind:ProductPageView ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationSegment rdf:type rdf:Property ;
    rdfs:label 'Personalization Segment' ;
    rdfs:comment 'The customer or visitor segment identifier assigned by the personalization engine at the time of the product detail page view (e.g., high_value_shopper, new_visitor, deal_seeker). Used to evaluate personalization engine effectiveness and segment-level product affinity.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Recommendation Algorithm' ;
    rdfs:comment 'The name or identifier of the recommendation algorithm or model that served product recommendations on this page view (e.g., collaborative_filtering, trending_now, frequently_bought_together, einstein_pdp). Null if no recommendation was served. Supports recommendation engine performance benchmarking.' ;
    rdfs:domain ind:ProductPageView ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationPlacement rdf:type rdf:Property ;
    rdfs:label 'Recommendation Placement' ;
    rdfs:comment 'The on-page placement zone where the recommendation widget was displayed during this product detail page view (e.g., pdp_carousel, pdp_bottom, pdp_sidebar). Null or \'none\' if no recommendation was served. Used to evaluate placement effectiveness for digital merchandising.' ;
    rdfs:domain ind:ProductPageView ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'The originating source that directed the visitor to the product detail page (e.g., google, email_campaign, homepage_banner, category_page, recommendation_widget). Supports digital attribution and marketing channel performance analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchQuery rdf:type rdf:Property ;
    rdfs:label 'Search Query' ;
    rdfs:comment 'The search term or query string entered by the visitor that led to this product detail page view via a search result click. Null if the interaction type was not a search result click. Used for search relevance optimization and product discoverability analysis.' ;
    rdfs:domain ind:ProductPageView ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchResultRank rdf:type rdf:Property ;
    rdfs:label 'Search Result Rank' ;
    rdfs:comment 'The ordinal position of the product in the search results list when the visitor clicked through to the product detail page. Null if the interaction type was not a search result click. Used to evaluate search ranking effectiveness and product discoverability.' ;
    rdfs:domain ind:ProductPageView ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'The Stock Keeping Unit code of the specific product variant (size, color, configuration) whose detail page was viewed. The SKU is the operational identifier used in Oracle Retail Merchandising System (ORMS) and SAP S/4HANA for inventory and sales tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeOnPageSeconds rdf:type rdf:Property ;
    rdfs:label 'Time On Page Seconds' ;
    rdfs:comment 'The duration in seconds the visitor spent on the product detail page before navigating away or the session ended. Indicates product engagement depth and is used to assess digital merchandising content effectiveness.' ;
    rdfs:domain ind:ProductPageView ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visitorType rdf:type rdf:Property ;
    rdfs:label 'Visitor Type' ;
    rdfs:comment 'Classifies the visitor viewing the product detail page as an authenticated registered customer, a guest/anonymous visitor, or a loyalty program member. Used to segment product engagement metrics by customer authentication state.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productReviewId rdf:type rdf:Property ;
    rdfs:label 'Product Review Id' ;
    rdfs:comment 'Unique surrogate identifier for each customer-submitted product review record on the digital storefront. Primary key for the product_review data product.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:abuseReportCount rdf:type rdf:Property ;
    rdfs:label 'Abuse Report Count' ;
    rdfs:comment 'Number of times shoppers have reported this review as abusive, spam, or inappropriate. Triggers automatic escalation to moderation queue when threshold is exceeded. Supports community trust and safety operations.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalReviewReference rdf:type rdf:Property ;
    rdfs:label 'External Review Reference' ;
    rdfs:comment 'The native identifier assigned by the originating review platform or syndication source (e.g., Bazaarvoice review ID, native platform UUID). Enables deduplication and traceability back to the source system.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitFeedback rdf:type rdf:Property ;
    rdfs:label 'Fit Feedback' ;
    rdfs:comment 'Structured fit feedback provided by the reviewer for apparel and footwear SKUs. Values: \'runs_small\', \'true_to_size\', \'runs_large\', \'not_applicable\'. Aggregated to generate size recommendation signals on the PDP and to inform private label product development.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasMedia rdf:type rdf:Property ;
    rdfs:label 'Has Media' ;
    rdfs:comment 'Boolean flag indicating whether the review includes at least one image or video attachment. Derived from media_attachment_count > 0 but stored explicitly for efficient filtering in storefront display queries and analytics.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:helpfulVoteCount rdf:type rdf:Property ;
    rdfs:label 'Helpful Vote Count' ;
    rdfs:comment 'Cumulative count of \'helpful\' votes cast by other shoppers on this review. Used to rank and surface the most useful reviews on the product detail page (PDP) and to weight social proof signals.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDeleted rdf:type rdf:Property ;
    rdfs:label 'Is Deleted' ;
    rdfs:comment 'Soft-delete flag indicating whether the review has been logically removed from active display and analytics. Set to true when a review is withdrawn by the customer (GDPR/CCPA right to erasure request) or permanently removed by moderation. Preserves the record for audit trail purposes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIncentivized rdf:type rdf:Property ;
    rdfs:label 'Is Incentivized' ;
    rdfs:comment 'Indicates whether the reviewer received an incentive (discount, loyalty points, free product) in exchange for submitting the review. Required for FTC endorsement disclosure compliance. Incentivized reviews must be disclosed on the storefront.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerifiedPurchase rdf:type rdf:Property ;
    rdfs:label 'Is Verified Purchase' ;
    rdfs:comment 'Indicates whether the reviewer has a confirmed purchase of the reviewed SKU on record, as validated against the order management system. Verified reviews carry higher trust weight in social proof algorithms and FTC compliance for endorsements.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaAttachmentCount rdf:type rdf:Property ;
    rdfs:label 'Media Attachment Count' ;
    rdfs:comment 'Number of media files (images or videos) attached to the review by the reviewer. Reviews with media attachments have higher engagement rates and conversion lift. Used to prioritize rich-media reviews for prominent display on the PDP.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:moderatedBy rdf:type rdf:Property ;
    rdfs:label 'Moderated By' ;
    rdfs:comment 'Username or system identifier of the moderator (human or automated system) who last updated the moderation status. Supports accountability and audit trail for content governance.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moderatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Moderated Timestamp' ;
    rdfs:comment 'Date and time when the review moderation decision was last applied. Used for SLA tracking of moderation turnaround and compliance audit trails.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:moderationNotes rdf:type rdf:Property ;
    rdfs:label 'Moderation Notes' ;
    rdfs:comment 'Free-text notes entered by the content moderator explaining the moderation decision, particularly for flagged or rejected reviews. Supports audit trail and escalation workflows.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moderationRejectionReason rdf:type rdf:Property ;
    rdfs:label 'Moderation Rejection Reason' ;
    rdfs:comment 'Categorical reason code assigned when a review is rejected or flagged during content moderation. Supports compliance audit trails and moderator quality reporting. [ENUM-REF-CANDIDATE: spam|profanity|off_topic|fake_review|safety_concern|competitor_mention|other — promote to reference product]' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moderationStatus rdf:type rdf:Property ;
    rdfs:label 'Moderation Status' ;
    rdfs:comment 'Current workflow state of the review in the content moderation pipeline. \'pending\' = awaiting review; \'approved\' = cleared for public display; \'rejected\' = removed for policy violation; \'flagged\' = escalated for manual review. Controls storefront visibility.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSizePurchased rdf:type rdf:Property ;
    rdfs:label 'Product Size Purchased' ;
    rdfs:comment 'Self-reported or order-derived size variant of the SKU purchased by the reviewer (e.g., \'M\', \'32x30\', \'500ml\'). Enables size-specific review filtering on the PDP and informs fit/sizing feedback for assortment planning.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseChannel rdf:type rdf:Property ;
    rdfs:label 'Purchase Channel' ;
    rdfs:comment 'The fulfillment channel through which the reviewer acquired the product. Values include: \'online\' (standard e-commerce), \'bopis\' (Buy Online Pick Up In Store), \'ropis\' (Reserve Online Pick Up In Store), \'in_store\', \'drop_ship\', \'marketplace\'. Enables channel-specific product quality analysis.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewBody rdf:type rdf:Property ;
    rdfs:label 'Review Body' ;
    rdfs:comment 'Full free-text narrative of the customer review. Primary input for NLP-based sentiment analysis, topic modelling, and product quality signal extraction. May be subject to moderation before display.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Review Language Code' ;
    rdfs:comment 'ISO 639-1 two-letter language code (optionally with ISO 3166-1 country subtag) of the review text, e.g., \'en\', \'fr\', \'es-MX\'. Supports multi-locale storefront display, NLP model routing, and translation workflows.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTitle rdf:type rdf:Property ;
    rdfs:label 'Review Title' ;
    rdfs:comment 'Short headline or subject line of the review as entered by the customer. Used for display on the product detail page (PDP) and for text analytics and sentiment classification.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerDisplayName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Display Name' ;
    rdfs:comment 'Pseudonymous or chosen display name shown publicly alongside the review on the storefront. May be a username alias rather than a legal name. Classified as confidential PII as it can be linked back to a customer identity.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerExpertiseLevel rdf:type rdf:Property ;
    rdfs:label 'Reviewer Expertise Level' ;
    rdfs:comment 'Categorical tier assigned to the reviewer based on their review history, helpfulness votes, and engagement on the platform. Used to weight review credibility in product quality scoring and to surface expert reviews prominently on the PDP.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerLocationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Reviewer Location Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code representing the self-reported or inferred country of the reviewer. Used for geo-segmented product quality analysis and regulatory compliance (GDPR for EU reviewers, CCPA for California residents).' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentLabel rdf:type rdf:Property ;
    rdfs:label 'Sentiment Label' ;
    rdfs:comment 'Categorical sentiment classification derived from the sentiment_score: \'positive\', \'neutral\', or \'negative\'. Provides a human-readable bucketing of the ML score for reporting dashboards and product quality KPI tracking.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:starRating rdf:type rdf:Property ;
    rdfs:label 'Star Rating' ;
    rdfs:comment 'Numeric star rating submitted by the reviewer on a 1-to-5 scale, where 1 is the lowest satisfaction and 5 is the highest. Core quantitative signal for product quality scoring, NPS-adjacent sentiment tracking, and GMROI analysis.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:syndicationPartnerReviewReference rdf:type rdf:Property ;
    rdfs:label 'Syndication Partner Review Reference' ;
    rdfs:comment 'The unique review identifier assigned by the third-party syndication partner (e.g., Bazaarvoice, PowerReviews). Populated only when syndication_source is not \'native\'. Enables reconciliation with partner platforms.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syndicationSource rdf:type rdf:Property ;
    rdfs:label 'Syndication Source' ;
    rdfs:comment 'Identifies the platform or syndication network from which the review originated. \'native\' = submitted directly on the retailer\'s own storefront; other values indicate third-party review syndication partners. Drives deduplication and source attribution logic.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unhelpfulVoteCount rdf:type rdf:Property ;
    rdfs:label 'Unhelpful Vote Count' ;
    rdfs:comment 'Cumulative count of \'not helpful\' votes cast by other shoppers on this review. Used alongside helpful_vote_count to compute net helpfulness score and filter low-quality reviews from prominent display.' ;
    rdfs:domain ind:ProductReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionBannerId rdf:type rdf:Property ;
    rdfs:label 'Promotion Banner Id' ;
    rdfs:comment 'Unique identifier for the promotional banner. Primary key for the promotion banner entity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromotionBanner .

ind:altText rdf:type rdf:Property ;
    rdfs:label 'Alt Text' ;
    rdfs:comment 'Accessibility-compliant alternative text description of the banner image for screen readers and assistive technologies. Required for WCAG compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributedRevenue rdf:type rdf:Property ;
    rdfs:label 'Attributed Revenue' ;
    rdfs:comment 'Total revenue in the storefront currency attributed to this banner through click-through and conversion tracking. Used to calculate campaign ROI (Return on Investment) and GMV (Gross Merchandise Value) contribution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bannerDescription rdf:type rdf:Property ;
    rdfs:label 'Banner Description' ;
    rdfs:comment 'Detailed description of the banner content, messaging, and promotional offer for internal reference and content management.' ;
    rdfs:domain ind:PromotionBanner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bannerName rdf:type rdf:Property ;
    rdfs:label 'Banner Name' ;
    rdfs:comment 'Internal name or title of the promotional banner used for identification and campaign management purposes.' ;
    rdfs:domain ind:PromotionBanner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bannerStatus rdf:type rdf:Property ;
    rdfs:label 'Banner Status' ;
    rdfs:comment 'Current lifecycle state of the promotional banner indicating whether it is being designed, scheduled for future display, actively shown to customers, temporarily paused, past its display window, or archived.' ;
    rdfs:domain ind:PromotionBanner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bannerTitle rdf:type rdf:Property ;
    rdfs:label 'Banner Title' ;
    rdfs:comment 'Customer-facing headline or title text displayed on the banner creative.' ;
    rdfs:domain ind:PromotionBanner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bannerType rdf:type rdf:Property ;
    rdfs:label 'Banner Type' ;
    rdfs:comment 'Classification of the banner format and display style. Determines rendering behavior and placement rules.' ;
    rdfs:domain ind:PromotionBanner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callToActionText rdf:type rdf:Property ;
    rdfs:label 'Call To Action Text' ;
    rdfs:comment 'Text displayed on the banner button or link that prompts user interaction (e.g., Shop Now, Learn More, Get Offer).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickThroughUrl rdf:type rdf:Property ;
    rdfs:label 'Click Through Url' ;
    rdfs:comment 'Destination URL where users are directed when they click on the banner. Typically links to a product detail page, category page, or promotional landing page.' ;
    rdfs:domain ind:PromotionBanner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeAssetUrl rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Url' ;
    rdfs:comment 'Fully qualified URL or path to the banner image or video creative asset stored in the content delivery network or digital asset management system.' ;
    rdfs:domain ind:PromotionBanner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayPriority rdf:type rdf:Property ;
    rdfs:label 'Display Priority' ;
    rdfs:comment 'Numeric ranking that determines the order in which banners are displayed when multiple banners compete for the same placement zone. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobileAssetUrl rdf:type rdf:Property ;
    rdfs:label 'Mobile Asset Url' ;
    rdfs:comment 'Fully qualified URL or path to the mobile-optimized version of the banner creative asset for responsive design and mobile-first experiences.' ;
    rdfs:domain ind:PromotionBanner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationId rdf:type rdf:Property ;
    rdfs:label 'Recommendation Id' ;
    rdfs:comment 'Unique identifier for the product recommendation event. Primary key for the recommendation product.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addedToCartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Added To Cart Timestamp' ;
    rdfs:comment 'Date and time when the recommended product was added to the cart. Null if not added.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:algorithm rdf:type rdf:Property ;
    rdfs:label 'Algorithm' ;
    rdfs:comment 'Name or identifier of the algorithm or model used to generate the recommendation. Examples include collaborative filtering, content-based, hybrid, or AI/ML model identifiers.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clicked Timestamp' ;
    rdfs:comment 'Date and time when the visitor clicked on the recommended product. Null if not clicked.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:context rdf:type rdf:Property ;
    rdfs:label 'Context' ;
    rdfs:comment 'The page or context where the recommendation was displayed. Indicates the placement and user journey stage. [ENUM-REF-CANDIDATE: homepage|product_detail_page|cart|checkout|search_results|category_page|wishlist|post_purchase|email|mobile_app — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAddedToCart rdf:type rdf:Property ;
    rdfs:label 'Is Added To Cart' ;
    rdfs:comment 'Indicates whether the recommended product was added to the shopping cart. True if added, False otherwise.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isClicked rdf:type rdf:Property ;
    rdfs:label 'Is Clicked' ;
    rdfs:comment 'Indicates whether the visitor clicked on the recommended product. True if clicked, False otherwise.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPurchased rdf:type rdf:Property ;
    rdfs:label 'Is Purchased' ;
    rdfs:comment 'Indicates whether the recommended product was ultimately purchased. True if purchased, False otherwise. Represents conversion outcome.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Version identifier of the recommendation model or algorithm used. Enables tracking of model performance and A/B testing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placement rdf:type rdf:Property ;
    rdfs:label 'Placement' ;
    rdfs:comment 'Specific placement or slot identifier on the page where the recommendation was displayed. Examples include hero banner, sidebar, below-the-fold, carousel position.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationRank rdf:type rdf:Property ;
    rdfs:label 'Recommendation Rank' ;
    rdfs:comment 'Position or rank of this recommended product within the recommendation set. Lower numbers indicate higher priority or relevance.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recommendationSource rdf:type rdf:Property ;
    rdfs:label 'Recommendation Source' ;
    rdfs:comment 'Source or generation method of the recommendation. Indicates whether the recommendation was generated in real-time, from batch processing, or as a fallback.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Confidence or relevance score assigned by the recommendation algorithm. Higher scores indicate stronger predicted affinity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:servedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Served Timestamp' ;
    rdfs:comment 'Date and time when the recommendation was served to the visitor. Represents the principal business event timestamp for this recommendation.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:strategy rdf:type rdf:Property ;
    rdfs:label 'Strategy' ;
    rdfs:comment 'The business strategy or intent behind the recommendation. Describes the merchandising or personalization approach used. [ENUM-REF-CANDIDATE: personalized|trending|bestseller|frequently_bought_together|similar_items|recently_viewed|new_arrivals|clearance|cross_sell|upsell — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeToClickSeconds rdf:type rdf:Property ;
    rdfs:label 'Time To Click Seconds' ;
    rdfs:comment 'Number of seconds between recommendation served and click event. Null if not clicked. Measures engagement speed.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeToPurchaseSeconds rdf:type rdf:Property ;
    rdfs:label 'Time To Purchase Seconds' ;
    rdfs:comment 'Number of seconds between recommendation served and purchase event. Null if not purchased. Measures conversion latency.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchQueryId rdf:type rdf:Property ;
    rdfs:label 'Search Query Id' ;
    rdfs:comment 'Unique surrogate identifier for each on-site search query event recorded on the digital storefront. Primary key for the search_query data product.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchCategoryId rdf:type rdf:Property ;
    rdfs:label 'Search Category Id' ;
    rdfs:comment 'Reference to the product category scope within which the search was executed, if the visitor scoped the search to a specific department or category (e.g., Electronics, Apparel). Null for site-wide searches. Supports category management and assortment depth analysis.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:appliedFilterCount rdf:type rdf:Property ;
    rdfs:label 'Applied Filter Count' ;
    rdfs:comment 'The number of facet filters (e.g., brand, size, color, price range, category) applied by the visitor to refine the search results. Zero indicates an unfiltered search. Used to understand search refinement behavior and optimize faceted navigation.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedSortOrder rdf:type rdf:Property ;
    rdfs:label 'Applied Sort Order' ;
    rdfs:comment 'The sort order selected by the visitor for the search results (e.g., relevance, price ascending, price descending, newest, best seller, top rated). \'default\' indicates no explicit sort was applied by the visitor. [ENUM-REF-CANDIDATE: relevance|price_asc|price_desc|newest|best_seller|top_rated|default — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickedResultPosition rdf:type rdf:Property ;
    rdfs:label 'Clicked Result Position' ;
    rdfs:comment 'The rank position (1-based) of the product result that was clicked by the visitor. Null if no click occurred. Used to analyze position bias and optimize search ranking algorithms.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clickedSku rdf:type rdf:Property ;
    rdfs:label 'Clicked Sku' ;
    rdfs:comment 'The SKU (Stock Keeping Unit) of the first product result clicked by the visitor after this search query. Null if is_click_through is False. Enables search-to-product attribution and relevance analysis.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isClickThrough rdf:type rdf:Property ;
    rdfs:label 'Is Click Through' ;
    rdfs:comment 'Indicates whether the visitor clicked on at least one product result following this search query (True) or viewed results without clicking (False). Core metric for CTR (Click-Through Rate) calculation and search relevance scoring.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPurchase rdf:type rdf:Property ;
    rdfs:label 'Is Purchase' ;
    rdfs:comment 'Indicates whether the search query ultimately led to a completed purchase within the same session (True) or not (False). Core metric for CR (Conversion Rate) measurement and search-to-revenue attribution.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRedirected rdf:type rdf:Property ;
    rdfs:label 'Is Redirected' ;
    rdfs:comment 'Indicates whether the search query triggered a merchandising redirect rule that sent the visitor to a specific landing page or category page instead of standard search results (True) or not (False).' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSpellCorrected rdf:type rdf:Property ;
    rdfs:label 'Is Spell Corrected' ;
    rdfs:comment 'Indicates whether the search engine applied automatic spell correction to the raw query text before executing the search (True) or not (False). Used to measure spell-correction effectiveness and raw query quality.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSynonymExpanded rdf:type rdf:Property ;
    rdfs:label 'Is Synonym Expanded' ;
    rdfs:comment 'Indicates whether the search engine applied synonym expansion rules to broaden the query scope (True) or not (False). Used to evaluate synonym dictionary coverage and search recall optimization.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isZeroResults rdf:type rdf:Property ;
    rdfs:label 'Is Zero Results' ;
    rdfs:comment 'Indicates whether the search query returned zero product results (True) or at least one result (False). Zero-results queries are critical demand signals for assortment gap identification and PIM (Product Information Management) enrichment.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:normalizedQueryText rdf:type rdf:Property ;
    rdfs:label 'Normalized Query Text' ;
    rdfs:comment 'The standardized, cleaned version of the search query after lowercasing, stemming, stop-word removal, and spell-correction processing. Used for query clustering, trend analysis, and search index optimization.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Query Language Code' ;
    rdfs:comment 'ISO 639-1 two-letter language code (optionally with ISO 3166-1 alpha-2 region subtag) detected or inferred for the search query text (e.g., \'en\', \'en-US\', \'fr\', \'es-MX\'). Supports multilingual storefront search analytics.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:querySource rdf:type rdf:Property ;
    rdfs:label 'Query Source' ;
    rdfs:comment 'The page or context from which the search was initiated. Identifies whether the visitor searched from the main search bar, a category page, the homepage, a Product Detail Page (PDP), cart, checkout, an email deep-link, or an external referral. Supports funnel and CR (Conversion Rate) analysis. [ENUM-REF-CANDIDATE: search_bar|category_page|homepage|pdp|cart|checkout|email_link|external — promote to reference product]' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Query Timestamp' ;
    rdfs:comment 'The exact date and time (with timezone offset) when the search query was submitted by the visitor. Principal business event timestamp for this record. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rawQueryText rdf:type rdf:Property ;
    rdfs:label 'Raw Query Text' ;
    rdfs:comment 'The verbatim, unmodified search string as entered by the visitor before any normalization or spell-correction is applied. Captures true demand signals including misspellings, slang, and natural language patterns for search relevance optimization and assortment gap identification.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redirectUrl rdf:type rdf:Property ;
    rdfs:label 'Redirect Url' ;
    rdfs:comment 'The destination URL to which the visitor was redirected when a search redirect rule was triggered. Null if is_redirected is False. Used to audit and manage search merchandising redirect configurations.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimeMs rdf:type rdf:Property ;
    rdfs:label 'Response Time Ms' ;
    rdfs:comment 'The elapsed time in milliseconds between the search query submission and the return of results to the visitor\'s browser. Used to monitor search engine SLA (Service Level Agreement) compliance and performance optimization.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resultCount rdf:type rdf:Property ;
    rdfs:label 'Result Count' ;
    rdfs:comment 'The total number of product results returned by the search engine for this query. A value of zero indicates a zero-results search event. Used to measure search engine effectiveness and identify assortment gaps.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resultPageNumber rdf:type rdf:Property ;
    rdfs:label 'Result Page Number' ;
    rdfs:comment 'The page number of search results viewed by the visitor (1-based). A value greater than 1 indicates the visitor paginated beyond the first results page. Used to analyze search depth and result page engagement.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchEngineVersion rdf:type rdf:Property ;
    rdfs:label 'Search Engine Version' ;
    rdfs:comment 'The version identifier of the search engine or search algorithm configuration active at the time the query was processed. Supports A/B testing, algorithm rollout tracking, and search relevance regression analysis.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topResultSku rdf:type rdf:Property ;
    rdfs:label 'Top Result Sku' ;
    rdfs:comment 'The SKU (Stock Keeping Unit) of the highest-ranked product returned in the search results for this query. Null when result_count is zero. Used to evaluate search ranking quality and relevance of the top-of-results position.' ;
    rdfs:domain ind:SearchQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteNotificationId rdf:type rdf:Property ;
    rdfs:label 'Site Notification Id' ;
    rdfs:comment 'Unique identifier for the site notification record. Primary key.' ;
    rdfs:domain ind:SiteNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bopisAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Bopis Appointment Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.bopis_appointment. Business justification: BOPIS appointment reminders and \'Ready for pickup\' notifications reference specific appointments; notification.bopis_appointment_id enables appointment-notification tracking for pickup communication S' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BopisAppointment .

ind:notificationLocationId rdf:type rdf:Property ;
    rdfs:label 'Notification Location Id' ;
    rdfs:comment 'Foreign key linking to store.store_location. Business justification: Notifications about BOPIS order readiness, curbside pickup arrival, or local inventory alerts are store-specific. Real business process: "your order is ready at Store #123" alerts, store-specific prom' ;
    rdfs:domain ind:SiteNotification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.shipment. Business justification: \'Shipped\' and \'Out for delivery\' notifications reference specific shipments; notification.shipment_id enables shipment-notification reconciliation for tracking update timeliness analysis and customer ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Retail .

ind:callToActionUrl rdf:type rdf:Property ;
    rdfs:label 'Call To Action Url' ;
    rdfs:comment 'Target URL or deep link that the user is directed to when clicking the notification action.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentPrice rdf:type rdf:Property ;
    rdfs:label 'Current Price' ;
    rdfs:comment 'Current price of the product displayed in the notification.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivered Timestamp' ;
    rdfs:comment 'Date and time when the notification was successfully delivered to the recipient.' ;
    rdfs:domain ind:SiteNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount applied to the product, displayed in promotional notifications.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dismissedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dismissed Timestamp' ;
    rdfs:comment 'Date and time when the recipient dismissed or closed the notification without taking action.' ;
    rdfs:domain ind:SiteNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:imageUrl rdf:type rdf:Property ;
    rdfs:label 'Image Url' ;
    rdfs:comment 'URL of the image asset displayed within the notification (e.g., product image, promotional banner).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDismissed rdf:type rdf:Property ;
    rdfs:label 'Is Dismissed' ;
    rdfs:comment 'Indicates whether the recipient dismissed the notification without taking action.' ;
    rdfs:domain ind:SiteNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRead rdf:type rdf:Property ;
    rdfs:label 'Is Read' ;
    rdfs:comment 'Indicates whether the notification has been read or viewed by the recipient.' ;
    rdfs:domain ind:SiteNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:messageBody rdf:type rdf:Property ;
    rdfs:label 'Message Body' ;
    rdfs:comment 'Full text content of the notification message providing details to the recipient.' ;
    rdfs:domain ind:SiteNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Number' ;
    rdfs:comment 'Human-readable business identifier for the notification, used for tracking and customer service reference.' ;
    rdfs:domain ind:SiteNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Status' ;
    rdfs:comment 'Current lifecycle status of the notification indicating delivery and engagement state. [ENUM-REF-CANDIDATE: pending|sent|delivered|read|dismissed|expired|failed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SiteNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationType rdf:type rdf:Property ;
    rdfs:label 'Notification Type' ;
    rdfs:comment 'Category of notification indicating the business purpose and trigger event. [ENUM-REF-CANDIDATE: stock_alert|price_drop|back_in_stock|order_status|promotion|cart_reminder|wishlist_alert|site_announcement|personalized_offer|delivery_update — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SiteNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousPrice rdf:type rdf:Property ;
    rdfs:label 'Previous Price' ;
    rdfs:comment 'Original price of the product before a price drop, used in price alert notifications.' ;
    rdfs:domain ind:SiteNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readTimestamp rdf:type rdf:Property ;
    rdfs:label 'Read Timestamp' ;
    rdfs:comment 'Date and time when the recipient opened or viewed the notification.' ;
    rdfs:domain ind:SiteNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent Timestamp' ;
    rdfs:comment 'Date and time when the notification was sent to the delivery channel.' ;
    rdfs:domain ind:SiteNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:triggerEvent rdf:type rdf:Property ;
    rdfs:label 'Trigger Event' ;
    rdfs:comment 'Business event or condition that caused the notification to be generated (e.g., inventory_replenished, price_reduced, order_shipped).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogId rdf:type rdf:Property ;
    rdfs:label 'Catalog Id' ;
    rdfs:comment 'Identifier of the product catalog assigned to this storefront within Salesforce Commerce Cloud or the PIM system. Determines which assortment of SKUs, categories, and product content is surfaced to customers on this channel. Aligns with Oracle Retail Merchandising System (ORMS) assortment planning and Informatica MDM product golden records.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalCatalog .

ind:analyticsTrackingCode rdf:type rdf:Property ;
    rdfs:label 'Analytics Tracking Code' ;
    rdfs:comment 'The web analytics platform tracking identifier assigned to this storefront (e.g., Google Analytics 4 Measurement ID \'G-XXXXXXXXXX\' or Adobe Analytics Report Suite ID). Used to attribute digital customer journey events, CTR (Click-Through Rate), CR (Conversion Rate), and session data to the correct storefront channel. Classified confidential as it represents proprietary analytics configuration.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaOptOutEnabled rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Enabled' ;
    rdfs:comment 'Indicates whether this storefront has activated the CCPA (California Consumer Privacy Act) \'Do Not Sell or Share My Personal Information\' opt-out mechanism, required for storefronts serving California consumers. Governs data sharing controls and consumer rights workflows.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Classification of the digital commerce channel operated by this storefront. Segments storefronts by their primary consumer interface: web (desktop/browser), mobile_app (iOS/Android native), marketplace (third-party platform such as Amazon or eBay), social_commerce (shoppable social media), or dark_store (fulfillment-only digital channel). Drives channel-specific analytics including CTR, CR, and GMV reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerServiceEmail rdf:type rdf:Property ;
    rdfs:label 'Customer Service Email' ;
    rdfs:comment 'The operational customer service email address displayed to customers on this storefront for support inquiries, returns (RMA — Return Merchandise Authorization), and complaints. Routed to Salesforce Service Cloud for case management. Classified confidential as an organizational contact identifier.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'The calendar date on which this storefront was or is scheduled to be permanently retired and removed from active digital commerce operations. Nullable for currently active storefronts. Used for channel sunset planning, data retention scheduling, and regulatory compliance archival.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:defaultLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Default Language Code' ;
    rdfs:comment 'ISO 639-1 two-letter language code representing the default display language for this storefront (e.g., \'en\', \'fr\', \'es\'). Used when a customer\'s browser language preference cannot be resolved or when the storefront operates in a single-language mode. Distinct from locale_code which also encodes regional formatting.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domainUrl rdf:type rdf:Property ;
    rdfs:label 'Domain Url' ;
    rdfs:comment 'The primary public-facing domain URL for this storefront (e.g., \'https://www.retail.com\' or \'https://m.retail.com\'). Used for SEO configuration, SSL certificate management, CDN routing, and digital marketing attribution. Classified confidential as it represents proprietary digital infrastructure configuration.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeShippingThreshold rdf:type rdf:Property ;
    rdfs:label 'Free Shipping Threshold' ;
    rdfs:comment 'The minimum order value (in the storefront\'s primary currency) at which free standard shipping is automatically applied at checkout. A key lever for AOV (Average Order Value) optimization and customer acquisition. Configured in Oracle Retail Price Management (RPM) or Salesforce Commerce Cloud promotion rules.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdprConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Required' ;
    rdfs:comment 'Indicates whether this storefront is subject to GDPR (General Data Protection Regulation) consent requirements, triggering cookie consent banners, data processing notices, and opt-in workflows for customers in EU/EEA jurisdictions. Drives compliance configuration in Salesforce Commerce Cloud and CRM systems.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBopisEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Bopis Enabled' ;
    rdfs:comment 'Indicates whether this storefront supports the BOPIS (Buy Online Pick Up In Store) fulfillment mode, allowing customers to purchase online and collect from a physical store location. Drives fulfillment routing logic in the OMS (Order Management System) and store operations workflows.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDropShipEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Drop Ship Enabled' ;
    rdfs:comment 'Indicates whether this storefront supports drop-ship fulfillment, where vendors ship products directly to customers without passing through Retail\'s DC (Distribution Center). Relevant for extended assortment and marketplace-style operations. Aligns with supplier management and EDI (Electronic Data Interchange) integration.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLoyaltyEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Loyalty Enabled' ;
    rdfs:comment 'Indicates whether this storefront is integrated with Retail\'s customer loyalty and engagement program, enabling points accrual, redemption, and CLTV (Customer Lifetime Value) tracking at the digital channel level. Drives loyalty-specific promotional targeting and RFM (Recency Frequency Monetary) segmentation.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRopisEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Ropis Enabled' ;
    rdfs:comment 'Indicates whether this storefront supports ROPIS (Reserve Online Pick Up In Store), allowing customers to reserve items online without payment and collect them in-store. Distinct from BOPIS in that no payment transaction occurs at the digital checkout stage.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isShipFromStoreEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Ship From Store Enabled' ;
    rdfs:comment 'Indicates whether this storefront supports SFS (Ship-from-Store) fulfillment, where physical store locations act as fulfillment centers for online orders. Enables distributed inventory utilization and faster last-mile delivery. Integrates with Manhattan Associates WMS for store-level pick/pack/ship operations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isShipToHomeEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Ship To Home Enabled' ;
    rdfs:comment 'Indicates whether this storefront supports ship-to-home fulfillment, where orders are dispatched from a DC (Distribution Center) or store directly to the customer\'s delivery address. Governs last-mile delivery eligibility and carrier integration activation for this channel.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxInclusivePricing rdf:type rdf:Property ;
    rdfs:label 'Is Tax Inclusive Pricing' ;
    rdfs:comment 'Indicates whether product prices displayed on this storefront include taxes (tax-inclusive, common in EU/UK markets) or exclude taxes (tax-exclusive, common in US markets). Governs price display logic at the product listing and checkout stages. Aligns with Oracle Retail Price Management (RPM) tax display configuration.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'The calendar date on which this storefront was first made publicly available to customers. Used for channel age analysis, anniversary promotions, and historical performance benchmarking. Represents the effective-from date for the storefront\'s commercial lifecycle.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxCartLineItems rdf:type rdf:Property ;
    rdfs:label 'Max Cart Line Items' ;
    rdfs:comment 'The maximum number of distinct line items (SKUs) permitted in a single shopping cart session on this storefront. Governs cart capacity limits configured in Salesforce Commerce Cloud to manage checkout performance and order processing capacity. Relevant for B2B or bulk-purchase storefronts.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Min Order Amount' ;
    rdfs:comment 'The minimum cart value (in the storefront\'s primary currency) required for a customer to complete checkout on this storefront. Used to enforce MOQ (Minimum Order Quantity) value thresholds, qualify for free shipping promotions, or meet marketplace seller requirements. Configured in Salesforce Commerce Cloud checkout rules.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pciComplianceLevel rdf:type rdf:Property ;
    rdfs:label 'Pci Compliance Level' ;
    rdfs:comment 'The PCI DSS (Payment Card Industry Data Security Standard) merchant compliance level assigned to this storefront, determined by annual card transaction volume (Level 1: >6M transactions; Level 2: 1M–6M; Level 3: 20K–1M; Level 4: <20K). Governs the scope of annual security assessments and SAQ (Self-Assessment Questionnaire) requirements. Classified confidential as it reveals security posture.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformVersion rdf:type rdf:Property ;
    rdfs:label 'Platform Version' ;
    rdfs:comment 'The version identifier of the Salesforce Commerce Cloud (SFCC) platform release deployed for this storefront (e.g., \'SFCC 23.7\', \'B2C Commerce 22.10\'). Used for release management, compatibility tracking, and upgrade planning across the digital commerce estate.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:robotsIndexingPolicy rdf:type rdf:Property ;
    rdfs:label 'Robots Indexing Policy' ;
    rdfs:comment 'The default robots meta directive applied to this storefront, controlling whether search engine crawlers may index pages and follow links (e.g., \'index_follow\' for the main site, \'noindex_nofollow\' for staging or dark-store channels). Impacts organic search visibility and SEO strategy.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seoMetaTitle rdf:type rdf:Property ;
    rdfs:label 'Seo Meta Title' ;
    rdfs:comment 'The default HTML meta title tag content for the storefront\'s homepage, used by search engines for indexing and SERP (Search Engine Results Page) display. Impacts organic search traffic and digital marketing performance. Managed within Salesforce Commerce Cloud site preferences.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionTimeoutMinutes rdf:type rdf:Property ;
    rdfs:label 'Session Timeout Minutes' ;
    rdfs:comment 'The number of minutes of customer inactivity after which a shopping session is automatically expired on this storefront. Governs cart abandonment timing, session-based analytics, and security compliance for authenticated customer sessions. Configured in Salesforce Commerce Cloud site security settings.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'The externally-known unique site identifier assigned within Salesforce Commerce Cloud (SFCC) for this storefront. Used as the operational reference key across digital commerce platform configurations, API calls, and integration touchpoints. Aligns to the SFCC Site object\'s siteID field.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storefrontName rdf:type rdf:Property ;
    rdfs:label 'Storefront Name' ;
    rdfs:comment 'Human-readable display name of the digital storefront or online channel (e.g., \'Retail Main Site\', \'Retail Mobile App\', \'Retail Marketplace — Amazon\'). Used in reporting dashboards, operational tooling, and business communications.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storefrontStatus rdf:type rdf:Property ;
    rdfs:label 'Storefront Status' ;
    rdfs:comment 'Current operational lifecycle state of the storefront. \'active\' indicates the storefront is live and accepting customer traffic; \'maintenance\' indicates a temporary service window; \'draft\' indicates pre-launch configuration; \'decommissioned\' indicates the channel has been permanently retired. Governs whether the storefront is eligible for traffic routing, promotional targeting, and digital commerce operations.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedPaymentMethods rdf:type rdf:Property ;
    rdfs:label 'Supported Payment Methods' ;
    rdfs:comment 'Comma-delimited list of payment methods accepted at checkout on this storefront (e.g., \'credit_card,debit_card,paypal,apple_pay,google_pay,gift_card,buy_now_pay_later\'). Governs payment gateway configuration and PCI DSS compliance scope for this channel. Managed within Salesforce Commerce Cloud payment processor settings. [ENUM-REF-CANDIDATE: credit_card|debit_card|paypal|apple_pay|google_pay|gift_card|buy_now_pay_later|bank_transfer — promote to reference product]' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:themeCode rdf:type rdf:Property ;
    rdfs:label 'Theme Code' ;
    rdfs:comment 'Identifier referencing the visual theme or template applied to this storefront within Salesforce Commerce Cloud (e.g., \'sfra-retail-v3\', \'pwa-kit-2024\'). Controls the storefront\'s UI/UX presentation layer, including layout, typography, and brand styling. Used by digital merchandising and visual merchandising teams for planogram-equivalent digital shelf configuration.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browserName rdf:type rdf:Property ;
    rdfs:label 'Browser Name' ;
    rdfs:comment 'Name of the web browser used during the session (e.g., Chrome, Safari, Firefox, Edge). Used for compatibility analysis and identifying browser-specific conversion drop-offs in the digital funnel.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browserVersion rdf:type rdf:Property ;
    rdfs:label 'Browser Version' ;
    rdfs:comment 'Version string of the web browser used during the session. Supports technical compatibility analysis and identification of outdated browser populations impacting checkout CR (Conversion Rate).' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'Version identifier of the consent notice or cookie policy presented to the visitor at session start. Enables compliance audit trails demonstrating which consent framework version was in effect at the time of data collection.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitPageUrl rdf:type rdf:Property ;
    rdfs:label 'Exit Page Url' ;
    rdfs:comment 'Full URL of the last page viewed before the visitor ended the session. Used to identify drop-off points in the digital funnel and optimize checkout flow to improve CR (Conversion Rate).' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBounce rdf:type rdf:Property ;
    rdfs:label 'Is Bounce' ;
    rdfs:comment 'Indicates whether the session was a bounce — the visitor viewed only a single page and exited without further interaction. True = bounce session. Used to calculate bounce rate as a digital storefront health KPI.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCartCreated rdf:type rdf:Property ;
    rdfs:label 'Is Cart Created' ;
    rdfs:comment 'Indicates whether the visitor created a shopping cart (added at least one item) during this session. True = cart was created. Key funnel stage flag for CR (Conversion Rate) and abandoned cart analysis in Salesforce Commerce Cloud.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCheckoutInitiated rdf:type rdf:Property ;
    rdfs:label 'Is Checkout Initiated' ;
    rdfs:comment 'Indicates whether the visitor initiated the checkout flow during this session. True = checkout was started. Enables measurement of cart-to-checkout conversion rate and identification of checkout abandonment in the digital funnel.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrderPlaced rdf:type rdf:Property ;
    rdfs:label 'Is Order Placed' ;
    rdfs:comment 'Indicates whether the session resulted in a completed order placement. True = order was placed. Primary conversion flag for CR (Conversion Rate) calculation and GMV (Gross Merchandise Value) attribution to digital sessions.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSearchQuery rdf:type rdf:Property ;
    rdfs:label 'Last Search Query' ;
    rdfs:comment 'The most recent on-site search term entered by the visitor during the session. Supports merchandising and assortment planning by revealing demand signals and zero-result search patterns.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageViewCount rdf:type rdf:Property ;
    rdfs:label 'Page View Count' ;
    rdfs:comment 'Total number of distinct pages viewed by the visitor during the session. Indicator of session engagement depth and product discovery behavior. Used in basket analysis and digital journey analytics.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referralUrl rdf:type rdf:Property ;
    rdfs:label 'Referral Url' ;
    rdfs:comment 'Full URL of the referring page or external site that directed the visitor to the digital storefront. Null for direct traffic. Enables granular attribution analysis beyond high-level referral_source classification.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchQueryCount rdf:type rdf:Property ;
    rdfs:label 'Search Query Count' ;
    rdfs:comment 'Number of on-site search queries executed by the visitor during the session. Indicator of product discovery intent and search effectiveness. Used to optimize PIM (Product Information Management) and assortment depth.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Session Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds between session_start_timestamp and session_end_timestamp. Raw measurement used to compute average session duration KPIs and correlate engagement with CR (Conversion Rate) and AOV (Average Order Value).' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session End Timestamp' ;
    rdfs:comment 'The precise date and time when the visitor session ended, either through explicit logout, timeout, or browser close. Null if session is still active. Used to compute session duration.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Start Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) when the visitor session was initiated on the digital storefront. Principal business event timestamp for session lifecycle analysis.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Current lifecycle state of the web session. \'active\' = session in progress; \'completed\' = session ended with a conversion event; \'abandoned\' = session ended without conversion; \'timed_out\' = session expired due to inactivity; \'bounced\' = single-page session with immediate exit.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionToken rdf:type rdf:Property ;
    rdfs:label 'Session Token' ;
    rdfs:comment 'Externally-known alphanumeric session identifier generated by Salesforce Commerce Cloud (SFCC) at session initiation. Used for cross-system session correlation and digital journey stitching across touchpoints.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmContent rdf:type rdf:Property ;
    rdfs:label 'Utm Content' ;
    rdfs:comment 'Urchin Tracking Module (UTM) content parameter used to differentiate ads or links pointing to the same URL (e.g., banner_top, text_link). Supports A/B testing and creative-level CTR (Click-Through Rate) analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmMedium rdf:type rdf:Property ;
    rdfs:label 'Utm Medium' ;
    rdfs:comment 'Urchin Tracking Module (UTM) medium parameter identifying the marketing medium (e.g., cpc, email, social, banner). Used alongside utm_source for multi-channel attribution and GMV (Gross Merchandise Value) contribution analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmTerm rdf:type rdf:Property ;
    rdfs:label 'Utm Term' ;
    rdfs:comment 'Urchin Tracking Module (UTM) term parameter capturing the paid search keyword that triggered the session. Used for paid search keyword-level ROI (Return on Investment) and CTR (Click-Through Rate) analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'Unique surrogate primary key for the AP invoice record in the Databricks Silver Layer lakehouse. Assigned by the data platform upon ingestion from SAP S/4HANA FI-AP.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApInvoice .

ind:paymentRunId rdf:type rdf:Property ;
    rdfs:label 'Payment Run Id' ;
    rdfs:comment 'SAP automatic payment program run identifier (F110 run ID combining run date and identification key) that processed this invoice for payment. Used to trace payment execution and remittance details.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRun .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Reference to the purchase order against which this invoice is matched during three-way match (PO/GR/Invoice) processing in SAP S/4HANA MM.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:chargebackAmount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Amount' ;
    rdfs:comment 'Amount deducted from the invoice payment as a vendor compliance penalty (chargeback) for violations such as late delivery, labeling errors, or EDI non-compliance. Reduces net payment to vendor.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'Date on which the open AP invoice item was cleared (settled) in the SAP FI-AP subledger, either by payment, credit memo offset, or manual clearing. Marks the end of the invoice lifecycle.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'SAP FI document number of the clearing transaction (AUGBL) that settled this invoice item. Enables full audit trail from invoice receipt through payment clearing for SOX compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'SAP company code (BUKRS) representing the legal entity or organizational unit responsible for this AP invoice. Determines the chart of accounts, fiscal year variant, and currency for financial reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'Last date by which payment must be made to capture the early payment cash discount offered by the vendor (e.g., 2/10 Net 30 — discount expires on day 10). Critical for cash discount capture optimization.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Reason code for invoices placed in disputed status during three-way match or AP review. Drives dispute resolution workflow and vendor communication in SAP FI-AP and Salesforce Service Cloud. [ENUM-REF-CANDIDATE: price_discrepancy|quantity_discrepancy|duplicate_invoice|missing_po|quality_issue|chargeback|other — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Exchange rate applied to convert the invoice currency to the company code local currency at the time of posting. Used for foreign currency AP revaluation and P&L reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'SAP material document number (MBLNR) for the goods receipt that is matched against this invoice during three-way match. Confirms that goods or services were received before payment is authorized.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total gross invoice amount before any deductions, discounts, or tax adjustments as stated on the vendor invoice. Represents the full obligation prior to netting. Corresponds to WRBTR in SAP FI.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date printed on the vendor invoice document. Used as the baseline date for payment terms calculation (e.g., Net 30 from invoice date) and cash discount eligibility. Corresponds to BLDAT in SAP FI.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Externally assigned invoice number as provided by the vendor on the invoice document. Used for vendor reconciliation, EDI matching, and dispute resolution. Corresponds to BELNR field in SAP FI-AP.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current workflow state of the AP invoice through the invoice-to-payment cycle. Drives AP aging analysis, payment run eligibility, and period-end close. [ENUM-REF-CANDIDATE: received|under_review|approved|posted|scheduled|paid|disputed|cancelled — promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice document type as defined in SAP FI-AP document type configuration. Determines posting logic, payment terms applicability, and GL account determination. [ENUM-REF-CANDIDATE: standard|credit_memo|debit_memo|recurring|intercompany|proforma — promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEdiReceived rdf:type rdf:Property ;
    rdfs:label 'Is Edi Received' ;
    rdfs:comment 'Indicates whether the invoice was received electronically via EDI (Electronic Data Interchange) transmission from the vendor, as opposed to paper or email. EDI invoices (e.g., ANSI X12 810) enable straight-through processing.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentBlock rdf:type rdf:Property ;
    rdfs:label 'Payment Block' ;
    rdfs:comment 'Indicator specifying whether and why the invoice is blocked from automatic payment processing. Corresponds to ZLSPR in SAP FI-AP. A value of \'none\' means the invoice is eligible for the next payment run.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'SAP FI document number generated for the payment transaction that clears this invoice. Used for bank reconciliation, remittance advice, and audit trail of the payment-to-invoice clearing.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'SAP payment terms key (ZTERM) defining the agreed payment conditions with the vendor, including net days, discount percentages, and discount periods (e.g., ZB14 = 2% 10 days Net 30). Drives due date and discount date calculation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'Date on which the invoice was posted to the SAP general ledger and AP subledger. Determines the accounting period for financial reporting and period-end close. Corresponds to BUDAT in SAP FI.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date the vendor invoice was physically or electronically received by the AP department. Used to measure invoice processing cycle time and SLA compliance for vendor payment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remittanceReference rdf:type rdf:Property ;
    rdfs:label 'Remittance Reference' ;
    rdfs:comment 'Reference number or text included in the payment remittance advice sent to the vendor, enabling the vendor to match the payment to their outstanding invoices. Supports vendor reconciliation and dispute prevention.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'Internal SAP FI document number (BELNR) assigned upon posting of the invoice in SAP S/4HANA. Used for cross-reference with the general ledger and FI-AP subledger.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Result of the three-way matching process comparing the purchase order (PO), goods receipt (GR), and vendor invoice quantities and amounts in SAP FI-AP/MM. Exceptions require AP team resolution before payment approval.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorBankAccount rdf:type rdf:Property ;
    rdfs:label 'Vendor Bank Account' ;
    rdfs:comment 'Masked or tokenized reference to the vendor bank account used for payment disbursement. Stored in compliance with PCI DSS requirements. Full account details are maintained in SAP FI-AP vendor master banking data.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'Total amount of payments and credits applied against this invoice to date. Used to calculate the outstanding open balance and support partial payment tracking in cash application.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankClearingDate rdf:type rdf:Property ;
    rdfs:label 'Bank Clearing Date' ;
    rdfs:comment 'Date on which the payment was cleared through the bank and matched to this invoice in SAP FI-AR. Null until payment is received and cleared. Used for cash flow reporting and bank reconciliation.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingCategory rdf:type rdf:Property ;
    rdfs:label 'Billing Category' ;
    rdfs:comment 'Business category of the receivable indicating the commercial relationship type. Supports segmented AR reporting across wholesale accounts, franchise fee billing, commercial receivables, intercompany settlements, and drop-ship vendor billing.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Billing Document Number' ;
    rdfs:comment 'Externally-known SAP FI-AR billing document number (BELNR) assigned at invoice creation. Used for customer remittance matching, EDI reconciliation, and dispute resolution. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER minimum category.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Discount Amount' ;
    rdfs:comment 'Early payment discount amount available to the customer if payment is received within the discount period defined in payment terms (e.g., 2% if paid within 10 days on 2/10NET30 terms).' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashDiscountDueDate rdf:type rdf:Property ;
    rdfs:label 'Cash Discount Due Date' ;
    rdfs:comment 'Last date by which the customer must pay to qualify for the early payment cash discount. Calculated from invoice_date and payment_terms_code discount period.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:comment 'Standardized SAP reason code for the customer dispute (e.g., pricing discrepancy, short shipment, quality issue, chargeback). Used for dispute root-cause analysis and vendor chargeback management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current status of any customer dispute raised against this invoice. Drives collections workflow routing and dunning block management in SAP FI-AR and Salesforce Service Cloud.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningBlock rdf:type rdf:Property ;
    rdfs:label 'Dunning Block' ;
    rdfs:comment 'Indicates whether dunning notices are blocked for this invoice (True = blocked). Set when a dispute is open, a payment arrangement is in place, or the account is under review.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunningDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Date' ;
    rdfs:comment 'Date of the most recent dunning notice sent to the customer for this invoice. Used to track collections activity and enforce dunning interval rules.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning escalation level (0–4) assigned to this invoice in SAP FI-AR dunning program. Level 0 = no dunning; higher levels indicate escalating collection notices sent to the customer.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openAmount rdf:type rdf:Property ;
    rdfs:label 'Open Amount' ;
    rdfs:comment 'Remaining unpaid balance on the invoice (net_amount minus applied_amount). Drives AR aging analysis, dunning escalation, and collections workflow prioritization.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number provided by the customer (e.g., purchase order number, contract number) for remittance matching and EDI reconciliation. Stored in SAP FI-AR XBLNR field.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which revenue from this invoice was recognized under ASC 606 criteria (performance obligation satisfied). May differ from invoice_date for multi-element arrangements or deferred revenue scenarios.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Status' ;
    rdfs:comment 'ASC 606 revenue recognition status for this invoice. Indicates whether revenue has been recognized, is deferred pending performance obligation fulfillment, or has been reversed. Critical for FASB-compliant financial reporting.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrgCode rdf:type rdf:Property ;
    rdfs:label 'Sales Org Code' ;
    rdfs:comment 'SAP sales organization (VKORG) responsible for this invoice. Enables P&L reporting and revenue attribution by sales channel, region, or business unit.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'Amount written off as uncollectible bad debt for this invoice. Used for bad debt expense reporting, allowance for doubtful accounts calculation, and FASB-compliant AR reserve management.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'Date on which the invoice balance was written off as bad debt in SAP FI-AR. Null until a write-off is executed. Required for bad debt aging and allowance for doubtful accounts reporting.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Unique identifier for the corporate bank account record. Primary key for the bank account entity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:accountClosedDate rdf:type rdf:Property ;
    rdfs:label 'Account Closed Date' ;
    rdfs:comment 'The date when the bank account was permanently closed, if applicable. Null for active accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'The legal name or business description of the bank account as registered with the financial institution.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountOpenedDate rdf:type rdf:Property ;
    rdfs:label 'Account Opened Date' ;
    rdfs:comment 'The date when the bank account was originally opened with the financial institution.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:achEnabled rdf:type rdf:Property ;
    rdfs:label 'Ach Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this bank account is enabled for ACH electronic funds transfer processing for domestic US transactions.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizedSignatories rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatories' ;
    rdfs:comment 'Comma-separated list of employee names or identifiers authorized to approve transactions and sign on behalf of the company for this bank account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableBalance rdf:type rdf:Property ;
    rdfs:label 'Available Balance' ;
    rdfs:comment 'The available balance for withdrawal or payment processing, accounting for pending transactions, holds, and minimum balance requirements.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankKey rdf:type rdf:Property ;
    rdfs:label 'Bank Key' ;
    rdfs:comment 'The unique identifier for the bank in the SAP system, used for payment processing and bank statement reconciliation.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'The name of the financial institution where the account is held.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchAddress rdf:type rdf:Property ;
    rdfs:label 'Branch Address' ;
    rdfs:comment 'The physical street address of the bank branch where the account is held, used for correspondence and regulatory reporting.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchCity rdf:type rdf:Property ;
    rdfs:label 'Branch City' ;
    rdfs:comment 'The city where the bank branch is located.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchCountryCode rdf:type rdf:Property ;
    rdfs:label 'Branch Country Code' ;
    rdfs:comment 'The three-letter ISO 3166 country code representing the country where the bank branch is located.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchName rdf:type rdf:Property ;
    rdfs:label 'Branch Name' ;
    rdfs:comment 'The name of the specific bank branch where the account is domiciled.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchPostalCode rdf:type rdf:Property ;
    rdfs:label 'Branch Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the bank branch location.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchState rdf:type rdf:Property ;
    rdfs:label 'Branch State' ;
    rdfs:comment 'The state or province where the bank branch is located.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkPrintingEnabled rdf:type rdf:Property ;
    rdfs:label 'Check Printing Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this bank account is enabled for physical check printing and disbursement.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionMethodEnabled rdf:type rdf:Property ;
    rdfs:label 'Collection Method Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this bank account is enabled for incoming payment collection (AR receipts, customer payments, lockbox processing).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'The current available balance in the bank account as of the last bank statement processing or real-time update, used for cash position reporting and treasury management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'The International Bank Account Number used for identifying bank accounts across international borders, primarily in European and other international transactions.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'The annual interest rate applied to the account balance, expressed as a decimal (e.g., 0.0250 for 2.50%), used for interest income calculation.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'The date when the last successful bank reconciliation was completed for this account, aligning bank statement balances with GL balances.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastStatementDate rdf:type rdf:Property ;
    rdfs:label 'Last Statement Date' ;
    rdfs:comment 'The date of the most recent bank statement processed for this account, used for reconciliation tracking and audit purposes.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumBalanceRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Required' ;
    rdfs:comment 'The minimum balance that must be maintained in the account per the bank agreement to avoid fees or maintain account status.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Balance' ;
    rdfs:comment 'The initial balance of the bank account when it was first opened or migrated into the system, used as the baseline for reconciliation.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdraftLimit rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit' ;
    rdfs:comment 'The maximum overdraft or line of credit limit authorized by the bank for this account, used for short-term liquidity management.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethodEnabled rdf:type rdf:Property ;
    rdfs:label 'Payment Method Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this bank account is enabled for outgoing payment processing (AP disbursements, payroll, vendor payments).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'The nine-digit American Bankers Association (ABA) routing transit number for domestic US bank transfers and ACH transactions.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftCode rdf:type rdf:Property ;
    rdfs:label 'Swift Code' ;
    rdfs:comment 'The Society for Worldwide Interbank Financial Telecommunication (SWIFT) Bank Identifier Code (BIC) used for international wire transfers and cross-border payments.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireTransferEnabled rdf:type rdf:Property ;
    rdfs:label 'Wire Transfer Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this bank account is enabled for domestic and international wire transfer processing.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financeBudgetId rdf:type rdf:Property ;
    rdfs:label 'Finance Budget Id' ;
    rdfs:comment 'Unique surrogate identifier for each budget record in the financial planning system. Primary key for the budget data product in SAP S/4HANA CO module.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceBudget .

ind:planVersionId rdf:type rdf:Property ;
    rdfs:label 'Plan Version Id' ;
    rdfs:comment 'Reference to the plan version record defining whether this budget entry belongs to the original budget, revised budget, rolling forecast, or annual plan. Maps to SAP CO plan version.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanVersion .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'The actual financial amount posted to the GL account and cost center for this budget period. Sourced from SAP S/4HANA FI actuals for budget vs. actual variance analysis.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level financial classification of the budget line: Capital Expenditure (CAPEX), Operating Expenditure (OPEX), Cost of Goods Sold (COGS), labor costs, or revenue. Drives P&L and EBITDA reporting segmentation.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the budget record, used in financial planning communications, approval workflows, and audit trails. Format: BDG-YYYY-NNNNNN.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsProjection rdf:type rdf:Property ;
    rdfs:label 'Cogs Projection' ;
    rdfs:comment 'Planned Cost of Goods Sold (COGS) for the budget period, used to project gross margin and support merchandise planning and Open to Buy (OTB) calculations.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'The amount of the budget that has been formally committed through purchase orders or contracts but not yet expensed. Supports Open to Buy (OTB) integration and encumbrance accounting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebitdaProjection rdf:type rdf:Property ;
    rdfs:label 'Ebitda Projection' ;
    rdfs:comment 'Planned Earnings Before Interest, Taxes, Depreciation, and Amortization (EBITDA) for the budget period. Key metric for investor financial guidance and enterprise P&L reporting.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAmount rdf:type rdf:Property ;
    rdfs:label 'Forecast Amount' ;
    rdfs:comment 'The latest forward-looking financial estimate for this budget line, updated during rolling forecast or reforecast cycles. Used for forecast vs. prior forecast variance analysis and investor guidance.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastMethod rdf:type rdf:Property ;
    rdfs:label 'Forecast Method' ;
    rdfs:comment 'The methodology used to derive the forecast or budget amounts: top-down (executive-driven allocation), bottom-up (cost center aggregation), driver-based (KPI-linked), statistical (model-driven), or zero-based budgeting.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossMarginProjection rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Projection' ;
    rdfs:comment 'Planned gross margin (revenue minus COGS) for the budget period and business unit. Supports Gross Margin Return on Investment (GMROI) analysis and financial close reporting.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Indicates whether this budget record has been locked for the period, preventing further edits. True when the period is closed or the budget has been formally locked post-approval.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReforecast rdf:type rdf:Property ;
    rdfs:label 'Is Reforecast' ;
    rdfs:comment 'Indicates whether this budget record represents a reforecast (True) rather than the original budget plan (False). Distinguishes reforecast iterations from baseline budget entries for variance tracking.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockDate rdf:type rdf:Property ;
    rdfs:label 'Lock Date' ;
    rdfs:comment 'The date on which this budget record was locked to prevent further modifications, typically at period-end close. Supports financial close process integrity and audit compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:otbAmount rdf:type rdf:Property ;
    rdfs:label 'Otb Amount' ;
    rdfs:comment 'The Open to Buy (OTB) amount representing the remaining purchasing budget available for merchandise procurement in this period. Calculated as planned inventory budget minus committed and received inventory costs.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'The end date of the planning period covered by this budget record. Defines the effective close of the budget window for financial reporting and period-end close processes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'The start date of the planning period covered by this budget record. Defines the effective beginning of the budget window for financial close and reporting alignment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planVersionType rdf:type rdf:Property ;
    rdfs:label 'Plan Version Type' ;
    rdfs:comment 'Classifies the budget record by planning cycle type: original budget (initial annual plan), revised budget (approved amendment), rolling forecast (monthly update), quarterly reforecast, or annual plan. Maps to SAP CO plan version category.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Amount' ;
    rdfs:comment 'The original planned financial amount for this budget line item in the functional currency. Represents the baseline against which actuals and forecasts are compared in budget vs. actual reporting.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorForecastAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Forecast Amount' ;
    rdfs:comment 'The forecast amount from the immediately preceding forecast cycle, retained for forecast vs. prior forecast variance analysis and trend tracking in financial planning.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueProjection rdf:type rdf:Property ;
    rdfs:label 'Revenue Projection' ;
    rdfs:comment 'Forward-looking revenue estimate for the business unit and channel in this budget period. Supports top-line financial planning, investor guidance, and Gross Merchandise Value (GMV) tracking.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'The date on which this budget record was formally submitted for approval in the financial planning workflow. Supports submission tracking and planning cycle compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submittedBy rdf:type rdf:Property ;
    rdfs:label 'Submitted By' ;
    rdfs:comment 'The name or employee identifier of the person who submitted this budget record for approval. Supports submission tracking and financial planning accountability.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Pct' ;
    rdfs:comment 'The percentage variance between planned and actual amounts ((actual - planned) / planned * 100). Used in financial dashboards and P&L reporting to flag material variances requiring management action.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryCostAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Cost Associate Id' ;
    rdfs:comment 'Identifier of the employee designated as the responsible manager (cost center owner) for this cost center in SAP S/4HANA (field: VERAK). Accountable for budget adherence, expense approvals, and financial close sign-off.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:actualYtdAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Ytd Amount' ;
    rdfs:comment 'Cumulative actual expenses posted to this cost center from the start of the fiscal year to the current reporting period. Sourced from SAP FI/CO actuals. Used for budget variance, EBITDA tracking, and financial close reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to allocate or distribute costs from this cost center to other cost objects (e.g., direct posting, SAP assessment cycle, distribution cycle, activity-based costing). Governs how overhead is spread across stores, DCs, and product categories.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'Total approved annual budget allocated to this cost center for the current fiscal year, expressed in the cost center currency. Used for Open to Buy (OTB) tracking, budget vs. actuals variance analysis, and financial planning.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetFiscalYear rdf:type rdf:Property ;
    rdfs:label 'Budget Fiscal Year' ;
    rdfs:comment 'The fiscal year (four-digit integer, e.g., 2025) to which the annual budget amount applies. Aligns with the SAP fiscal year variant for period-based budget vs. actuals comparison.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'SAP Business Area (GSBER) to which this cost center is assigned. Enables cross-company-code P&L reporting by business segment (e.g., Grocery, Apparel, E-Commerce). Supports FASB ASC 280 segment disclosures.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Commitment Amount' ;
    rdfs:comment 'Total open purchase order and contract commitment amounts encumbered against this cost center\'s budget but not yet invoiced. Supports available budget calculation and OTB management in SAP CO-OM.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'SAP Controlling Area (KOKRS) to which this cost center belongs. The controlling area defines the organizational unit within which cost accounting is performed. All cost centers within a controlling area share the same chart of accounts and fiscal year variant.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'SAP cost center category (KOSAR) that controls which business transactions are allowed for this cost center (e.g., \'A\' for general cost centers, \'E\' for production cost centers). Governs posting rules in FI/CO.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The externally-known alphanumeric code that uniquely identifies the cost center within the controlling area, as defined in SAP S/4HANA CO module (field: KOSTL). Used in P&L reporting, budget allocation, and expense posting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Long-form description of the cost center\'s business purpose, scope of expenses, and organizational context. Corresponds to SAP S/4HANA field LTEXT.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterLevel rdf:type rdf:Property ;
    rdfs:label 'Cost Center Level' ;
    rdfs:comment 'Numeric level of this cost center within the enterprise cost center hierarchy (1 = top/enterprise, higher numbers = more granular). Enables hierarchical roll-up queries for consolidated P&L and EBITDA reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'Human-readable name of the cost center as maintained in SAP S/4HANA (field: KTEXT). Describes the organizational unit, e.g., \'Store 042 - Chicago Loop\', \'DC Atlanta\', \'Corporate Finance\'.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. \'active\' = open for postings; \'locked\' = temporarily blocked for new postings (SAP lock indicator); \'inactive\' = no longer in use; \'pending\' = awaiting activation; \'archived\' = closed and retained for historical reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center by organizational unit type. Drives expense allocation rules, budget templates, and P&L reporting hierarchies. [ENUM-REF-CANDIDATE: store|distribution_center|corporate|regional_office|ecommerce|shared_services|manufacturing|logistics — promote to reference product]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'SAP fiscal year variant (PERIV) assigned to this cost center\'s controlling area. Defines the fiscal calendar (e.g., \'K4\' for calendar year, \'V3\' for April–March). Critical for period-based budget vs. actuals comparison and FASB-compliant financial close.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'SAP Functional Area (FKBER) classifying the cost center by business function (e.g., Sales, Administration, Production, Logistics). Used for cost-of-sales accounting and functional P&L reporting per FASB ASC 220.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'Primary General Ledger account code associated with this cost center for default expense postings. Links cost center activity to the chart of accounts in SAP FI for P&L and EBITDA reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountBudget rdf:type rdf:Property ;
    rdfs:label 'Headcount Budget' ;
    rdfs:comment 'Approved headcount (number of full-time equivalent employees) budgeted for this cost center in the current fiscal year. Used for workforce cost planning, Workday HCM integration, and labor cost as a percentage of sales analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyArea rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Area' ;
    rdfs:comment 'Node within the standard cost center hierarchy (SAP field: KOSAR/KHINR) that positions this cost center in the enterprise organizational tree. Used for roll-up reporting in P&L, EBITDA tracking, and budget consolidation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderCode rdf:type rdf:Property ;
    rdfs:label 'Internal Order Code' ;
    rdfs:comment 'SAP Internal Order (AUFNR) code linked to this cost center for detailed cost monitoring of specific activities or projects (e.g., marketing campaigns, store remodels). Enables granular expense tracking beyond standard cost center reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLockedForPosting rdf:type rdf:Property ;
    rdfs:label 'Is Locked For Posting' ;
    rdfs:comment 'Indicates whether this cost center is currently locked against new financial postings (SAP lock indicator). True = no new postings allowed; False = postings permitted. Used during period-end close and cost center restructuring.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStatistical rdf:type rdf:Property ;
    rdfs:label 'Is Statistical' ;
    rdfs:comment 'Indicates whether this cost center is a statistical cost center (SAP field: STAT). Statistical cost centers receive postings for informational/reporting purposes only and do not carry real costs. True = statistical; False = real cost center.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'SAP Profit Center (PRCTR) to which this cost center is assigned. Enables P&L reporting at the profit center level, supporting GMROI analysis and segment-level financial performance tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Internal regional classification code for the cost center\'s geographic location (e.g., \'NORTHEAST\', \'WEST\', \'EMEA\'). Supports regional P&L roll-up, comp sales (SSS) analysis, and regional budget allocation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'SAP Work Breakdown Structure (WBS) element code associated with this cost center for project-based cost tracking. Used when the cost center is linked to a capital project (e.g., store renovation, DC expansion) for CAPEX vs. OPEX classification per FASB ASC 842.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'Start date of the cost center\'s validity period (SAP field: DATAB). The cost center is open for expense postings from this date. Supports fiscal year-aligned budget and actuals reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validTo rdf:type rdf:Property ;
    rdfs:label 'Valid To' ;
    rdfs:comment 'End date of the cost center\'s validity period (SAP field: DATBI). After this date, no new postings are permitted. Null or 9999-12-31 indicates an open-ended cost center with no planned closure.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:comparablePeriodId rdf:type rdf:Property ;
    rdfs:label 'Comparable Period Id' ;
    rdfs:comment 'Reference to the corresponding financial period in the prior fiscal year used for same-store sales (SSS/Comp Sales) and year-over-year (YoY) financial comparisons. Accounts for 53-week year shifts in the NRF retail calendar.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialPeriod .

ind:priorYearPeriodFinancialPeriodId rdf:type rdf:Property ;
    rdfs:label 'Prior Year Period Financial Period Id' ;
    rdfs:comment 'Reference to the exact same period number in the immediately preceding fiscal year. Used for year-over-year (YoY) financial variance analysis, P&L comparisons, and FASB comparative financial statement preparation. Distinct from comparable_period_id which accounts for 53-week calendar shifts.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialPeriod .

ind:apPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Ap Posting Allowed' ;
    rdfs:comment 'Indicates whether accounts payable (AP) postings are permitted for this financial period. AP periods may be managed independently from GL periods in SAP S/4HANA to support vendor invoice processing timelines and COGS accruals.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Ar Posting Allowed' ;
    rdfs:comment 'Indicates whether accounts receivable (AR) postings are permitted for this financial period. AR periods may be managed independently to support customer payment processing, revenue recognition (ASC 606), and loyalty program financial settlements.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Identifier for the budget or plan version associated with this financial period (e.g., \'ORIGINAL\', \'REVISED_Q2\', \'FORECAST_V3\'). Links the period to the corresponding financial plan in SAP CO for budget vs. actual variance analysis and financial planning cycles.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarType rdf:type rdf:Property ;
    rdfs:label 'Calendar Type' ;
    rdfs:comment 'The retail fiscal calendar convention used for this period. The 4-5-4 and 4-4-5 calendars are NRF industry standards that divide the fiscal year into 4-week and 5-week periods to align comparable store sales (SSS) reporting across years.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeCycleDays rdf:type rdf:Property ;
    rdfs:label 'Close Cycle Days' ;
    rdfs:comment 'Number of calendar days allocated for completing the financial close process for this period (from period end date to scheduled close date). A KPI for finance operations efficiency; industry benchmark for retail is typically 5–10 business days for month-end close.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closeStatus rdf:type rdf:Property ;
    rdfs:label 'Close Status' ;
    rdfs:comment 'Status of the financial close process for this period. Tracks progression through the month-end or year-end close cycle. \'not_started\' indicates close activities have not begun; \'in_progress\' means close tasks are underway; \'completed\' means the period is fully closed and reconciled; \'reopened\' means a closed period was reopened for corrections.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'SAP CO controlling area code associated with this financial period. The controlling area defines the organizational unit for cost accounting, P&L reporting, and EBITDA tracking within SAP S/4HANA CO module.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Allowed' ;
    rdfs:comment 'Indicates whether general ledger (GL) journal entry postings are currently permitted for this financial period. Derived from posting_status but maintained as an explicit business flag for integration with downstream systems that check posting eligibility.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAdjustmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Adjustment Period' ;
    rdfs:comment 'Indicates whether this is a special adjustment period (periods 13–16 in SAP) used exclusively for year-end audit adjustments, accrual reversals, and FASB-required restatements. Adjustment periods do not correspond to calendar time.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQuarterEndPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Quarter End Period' ;
    rdfs:comment 'Indicates whether this period is the final period of a fiscal quarter, triggering quarterly close procedures, quarterly P&L reporting, and SEC 10-Q filing preparation for publicly traded retail entities.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isYearEndPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Year End Period' ;
    rdfs:comment 'Indicates whether this period is the final period of the fiscal year requiring year-end close procedures, including balance sheet finalization, retained earnings posting, and annual financial statement preparation per FASB standards.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'SAP S/4HANA ledger group identifier that this period applies to (e.g., \'0L\' for leading ledger, \'L1\' for local GAAP ledger, \'L2\' for IFRS ledger). Supports parallel accounting for multi-GAAP retail entities operating across jurisdictions.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mmPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Mm Posting Allowed' ;
    rdfs:comment 'Indicates whether materials management (MM) postings — including goods receipts, inventory adjustments, and COGS postings — are permitted for this financial period in SAP S/4HANA MM module. Critical for inventory valuation and COGS accuracy.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodCloseDate rdf:type rdf:Property ;
    rdfs:label 'Period Close Date' ;
    rdfs:comment 'The calendar date on which the financial period was officially closed in SAP S/4HANA FI, preventing further postings. Critical for financial close scheduling, audit compliance, and FASB revenue recognition cutoff enforcement.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodLengthDays rdf:type rdf:Property ;
    rdfs:label 'Period Length Days' ;
    rdfs:comment 'Number of calendar days in the financial period (typically 28 or 35 days for 4-week or 5-week NRF periods). Used for daily average calculations, proration of fixed costs, and lease accounting (ASC 842) period allocations.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name for the financial period (e.g., \'FY2024 Period 1\', \'Q1 FY2024 Week 1\', \'January 2024\'). Used in financial reports, P&L statements, and EBITDA dashboards for period labeling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodNumber rdf:type rdf:Property ;
    rdfs:label 'Period Number' ;
    rdfs:comment 'Sequential period number within the fiscal year (1–12 for regular periods, 13–16 for special/adjustment periods). Maps to SAP S/4HANA posting period (MONAT) in table BKPF. Controls which periods are open for posting in the general ledger.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodOpenDate rdf:type rdf:Property ;
    rdfs:label 'Period Open Date' ;
    rdfs:comment 'The calendar date on which the posting period was officially opened for journal entry postings in SAP S/4HANA FI. Used for financial close audit trails and compliance with FASB reporting timelines.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodShortCode rdf:type rdf:Property ;
    rdfs:label 'Period Short Code' ;
    rdfs:comment 'Standardized short code uniquely identifying the financial period across systems (e.g., \'FY2024P01\', \'FY2024P13\'). Used as a business key for cross-system integration between SAP S/4HANA, Oracle Retail Merchandising System (ORMS), and financial reporting tools.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current open/close status of the posting period in the general ledger. \'open\' allows new journal entries; \'closed\' prevents further postings; \'blocked\' restricts posting pending review; \'future\' indicates the period is not yet active. Controls SAP S/4HANA FI posting period management (OB52).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarterName rdf:type rdf:Property ;
    rdfs:label 'Quarter Name' ;
    rdfs:comment 'Human-readable fiscal quarter label (e.g., \'Q1 FY2024\', \'Q4 FY2023\'). Used in financial reporting dashboards, investor relations materials, and comparable store sales (SSS/Comp Sales) analysis.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarterNumber rdf:type rdf:Property ;
    rdfs:label 'Quarter Number' ;
    rdfs:comment 'Fiscal quarter (1–4) to which this period belongs within the fiscal year. Used for quarterly P&L reporting, EBITDA tracking, and SEC/FASB quarterly financial disclosures.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reopenDate rdf:type rdf:Property ;
    rdfs:label 'Reopen Date' ;
    rdfs:comment 'The date on which a previously closed financial period was reopened for additional postings or corrections. Populated only when close_status is \'reopened\'. Supports audit trail requirements for FASB restatements.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reopenReason rdf:type rdf:Property ;
    rdfs:label 'Reopen Reason' ;
    rdfs:comment 'Business justification for reopening a previously closed financial period (e.g., \'Audit adjustment required\', \'Revenue recognition restatement per ASC 606\', \'Vendor chargeback correction\'). Required for SOX compliance and audit trail documentation.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCloseDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Close Date' ;
    rdfs:comment 'The planned/target date for completing the financial close process for this period, as defined in the financial close calendar. Used to track close cycle performance and SLA adherence for the finance operations team.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:weekNumber rdf:type rdf:Property ;
    rdfs:label 'Week Number' ;
    rdfs:comment 'Fiscal week number within the fiscal year (1–52 or 1–53 for 53-week years). Critical for weekly retail performance reporting, same-store sales (SSS) comparisons, and Open-to-Buy (OTB) planning cycles.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Unique identifier for the fixed asset record. Primary key. Inferred role: MASTER_RESOURCE.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:leaseContractId rdf:type rdf:Property ;
    rdfs:label 'Lease Contract Id' ;
    rdfs:comment 'Foreign key linking to finance.lease_contract. Business justification: Fixed assets have lease_indicator_flag (BOOLEAN) indicating whether the asset is leased, but no FK to lease_contract. This FK links leased assets to their governing lease contracts (ASC 842 compliance' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeaseContract .

ind:primaryFixedGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Fixed Gl Account Id' ;
    rdfs:comment 'FK to finance.gl_account' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total cumulative depreciation expense recognized since acquisition. Subtracted from acquisition cost to calculate net book value.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Original purchase price or capitalized cost of the fixed asset including installation and setup costs. Basis for depreciation calculation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'Classification code defining the type of fixed asset (e.g., store fixtures, POS terminals, warehouse equipment, vehicles, leasehold improvements). Determines depreciation rules and useful life.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Detailed business description of the fixed asset including make, model, and distinguishing characteristics.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLocationCode rdf:type rdf:Property ;
    rdfs:label 'Asset Location Code' ;
    rdfs:comment 'Code identifying the physical location of the asset (store number, distribution center code, warehouse ID, or corporate office location).' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Externally-known unique asset identifier assigned by the enterprise asset management system. Used for physical tagging and tracking.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset. Active assets are in service and depreciating; under construction assets are capitalized but not yet depreciating; retired/disposed assets are no longer in use.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'Date the asset was capitalized and added to the fixed asset register. May differ from acquisition date for assets under construction.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationArea rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area' ;
    rdfs:comment 'SAP FI-AA depreciation area code distinguishing book depreciation (GAAP) from tax depreciation and other parallel valuations (e.g., 01=book, 15=tax).' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationKey rdf:type rdf:Property ;
    rdfs:label 'Depreciation Key' ;
    rdfs:comment 'SAP FI-AA depreciation key code that defines the calculation rule, useful life, and period control for depreciation runs.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting method used to calculate periodic depreciation expense. Straight-line is most common for retail fixed assets.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Cash or fair value received from sale or disposal of the asset. Used to calculate gain or loss on disposal.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentIndicatorFlag rdf:type rdf:Property ;
    rdfs:label 'Impairment Indicator Flag' ;
    rdfs:comment 'Boolean flag indicating whether the asset has been identified for impairment testing under FASB ASC 360. True if impairment indicators are present.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impairmentLossAmount rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss Amount' ;
    rdfs:comment 'Cumulative impairment loss recognized when the carrying value exceeds the recoverable amount. Reduces net book value and is reported in P&L.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastDepreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Last Depreciation Amount' ;
    rdfs:comment 'Depreciation expense amount posted in the most recent depreciation run. Used for monthly P&L reporting and EBITDA add-back calculation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastDepreciationRunDate rdf:type rdf:Property ;
    rdfs:label 'Last Depreciation Run Date' ;
    rdfs:comment 'Date of the most recent periodic depreciation calculation run for this asset. Updated monthly during financial close.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the manufacturer or original equipment manufacturer (OEM) of the asset.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer model or part number identifying the specific asset configuration or variant.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current carrying value of the asset calculated as acquisition cost minus accumulated depreciation. Represents the asset\'s value on the balance sheet.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Purchase order number under which the asset was procured. Provides audit trail to procurement transaction.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salvageValue rdf:type rdf:Property ;
    rdfs:label 'Salvage Value' ;
    rdfs:comment 'Estimated residual value of the asset at the end of its useful life. Subtracted from acquisition cost to determine depreciable base.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer serial number or unique equipment identifier for trackable assets such as POS terminals, vehicles, and warehouse equipment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected useful life of the asset in years as determined by asset class and accounting policy. Used to calculate annual depreciation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date on which the manufacturer or vendor warranty coverage expires. Used for maintenance planning and risk assessment.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'SAP account group (KTOKS) that controls the number range and field selection for the GL account. Groups accounts by functional category such as cash accounts, receivables, payables, revenue accounts, COGS accounts, and operating expense accounts. [ENUM-REF-CANDIDATE: cash|receivables|payables|revenue|cogs|opex|assets|liabilities|equity|statistical — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountLongName rdf:type rdf:Property ;
    rdfs:label 'Account Long Name' ;
    rdfs:comment 'Extended descriptive name of the GL account providing full business context beyond the short name. Used in detailed financial reporting, audit documentation, and regulatory disclosures.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Alternative Account Number' ;
    rdfs:comment 'Country-specific or group-level alternative account number used for local statutory reporting or group consolidation mapping. Enables cross-mapping between the operational chart of accounts and a group/statutory chart of accounts. Maps to SAP field ALTKT in SKB1.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetAccount rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Account' ;
    rdfs:comment 'Indicates whether this account is a balance sheet account (True) or a P&L income statement account (False). Balance sheet accounts carry forward balances at year-end; P&L accounts are closed to retained earnings. Maps to SAP field XBILK in SKA1.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chartOfAccountsCode rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Code' ;
    rdfs:comment 'Identifier for the chart of accounts to which this GL account belongs in SAP S/4HANA (e.g., \'INT\' for international, \'CAUS\' for US GAAP). A single enterprise may maintain multiple charts of accounts for group vs. local reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentManagement rdf:type rdf:Property ;
    rdfs:label 'Commitment Management' ;
    rdfs:comment 'Indicates whether commitment management (budget encumbrance) is active (True) for this GL account. When enabled, purchase orders and purchase requisitions create budget commitments against this account, supporting Open-to-Buy (OTB) budget control in merchandise planning.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'Indicates whether this GL account is linked to a CO (Controlling) cost element and its category. \'primary\' cost elements correspond to P&L accounts (e.g., COGS, operating expenses); \'secondary\' are internal allocation accounts; \'not_applicable\' for balance sheet accounts. Drives EBITDA and P&L cost center reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferredRevenueIndicator rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue Indicator' ;
    rdfs:comment 'Indicates whether this GL account is used to record deferred revenue (True), such as gift card liabilities, loyalty point deferrals, or advance payments not yet recognized under ASC 606. Supports balance sheet classification and revenue recognition scheduling.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fasbClassification rdf:type rdf:Property ;
    rdfs:label 'Fasb Classification' ;
    rdfs:comment 'FASB Accounting Standards Codification (ASC) topic or subtopic to which this GL account is primarily aligned (e.g., \'ASC 606\' for revenue recognition accounts, \'ASC 842\' for lease liability/ROU asset accounts, \'ASC 330\' for inventory/COGS accounts). Supports FASB-compliant regulatory reporting and audit readiness. [ENUM-REF-CANDIDATE: ASC_606|ASC_842|ASC_330|ASC_350|ASC_360|ASC_420 — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'SAP field status group code (e.g., G001, G004) assigned to this GL account that controls which fields are required, optional, or suppressed during document entry. Enforces data quality and completeness rules at the point of financial posting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementVersion rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Version' ;
    rdfs:comment 'SAP Financial Statement Version (FSV) code that determines how this account is grouped and displayed in statutory financial statements (balance sheet, P&L). Supports GAAP, IFRS, and management reporting views. Maps to SAP table T011.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsItemCode rdf:type rdf:Property ;
    rdfs:label 'Fs Item Code' ;
    rdfs:comment 'The financial statement line item code to which this GL account is assigned within the Financial Statement Version. Enables aggregation of multiple GL accounts into a single P&L or balance sheet line for external reporting and FASB-compliant disclosures.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'SAP functional area classification that segments costs by business function for cost-of-sales P&L reporting (e.g., \'SALES\', \'ADMIN\', \'LOGISTICS\', \'MARKETING\', \'STORE_OPS\'). Enables functional income statement presentation per IFRS IAS 1 and management reporting. [ENUM-REF-CANDIDATE: sales|administration|logistics|marketing|store_operations|ecommerce|supply_chain — promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:houseBankAccount rdf:type rdf:Property ;
    rdfs:label 'House Bank Account' ;
    rdfs:comment 'Indicates whether this GL account is a bank account (True) linked to a house bank in SAP FI-TR (Treasury). Bank GL accounts are used for cash management, bank reconciliation, and PCI DSS-compliant payment processing.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyAccount rdf:type rdf:Property ;
    rdfs:label 'Intercompany Account' ;
    rdfs:comment 'Indicates whether this GL account is designated for intercompany transactions (True) between legal entities within the retail group. Intercompany accounts are eliminated during group consolidation. Maps to SAP intercompany account configuration.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Changed Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this GL account master record in SAP S/4HANA. Used for change detection in ETL pipelines, audit compliance, and Sarbanes-Oxley (SOX) internal control documentation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:leaseAccountType rdf:type rdf:Property ;
    rdfs:label 'Lease Account Type' ;
    rdfs:comment 'Classifies the GL account\'s role under FASB ASC 842 lease accounting. \'rou_asset\' identifies Right-of-Use asset accounts for operating and finance leases; \'lease_liability\' identifies corresponding liability accounts; \'lease_expense\' identifies amortization/interest expense accounts; \'not_applicable\' for non-lease accounts. Critical for ASC 842 compliance reporting in retail store lease portfolios.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemDisplay rdf:type rdf:Property ;
    rdfs:label 'Line Item Display' ;
    rdfs:comment 'Indicates whether individual line items posted to this account are stored and displayable (True) in the FI line item report. Required for accounts needing detailed transaction-level audit trails. Maps to SAP field XKRES in SKB1.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagement rdf:type rdf:Property ;
    rdfs:label 'Open Item Management' ;
    rdfs:comment 'Indicates whether open item management is active (True) for this account, enabling individual line items to be matched and cleared (e.g., for clearing accounts, GR/IR accounts, bank clearing). Maps to SAP field XOPVW in SKB1.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningRelevant rdf:type rdf:Property ;
    rdfs:label 'Planning Relevant' ;
    rdfs:comment 'Indicates whether this GL account is included in financial planning and budgeting processes (True). Planning-relevant accounts are available for budget entry in SAP BPC or S/4HANA Financial Planning, supporting annual budgeting and rolling forecast cycles.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingBlocked rdf:type rdf:Property ;
    rdfs:label 'Posting Blocked' ;
    rdfs:comment 'Indicates whether financial postings to this GL account are currently blocked (True) or permitted (False). A blocked account cannot receive new journal entries but retains its historical balance. Maps to SAP field XSPEB in SKA1/SKB1.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterRelevant rdf:type rdf:Property ;
    rdfs:label 'Profit Center Relevant' ;
    rdfs:comment 'Indicates whether postings to this GL account are distributed to profit centers (True) for segment and store-level P&L reporting. Profit center-relevant accounts enable comparable store sales (Comp Sales/SSS) analysis and GMROI reporting by retail location.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitLossCategory rdf:type rdf:Property ;
    rdfs:label 'Profit Loss Category' ;
    rdfs:comment 'Business classification of the GL account within the P&L statement structure. Enables EBITDA tracking, gross margin analysis, and COGS reporting. \'revenue\' includes net sales and other income; \'cogs\' covers Cost of Goods Sold; \'gross_margin\' is a subtotal indicator; \'operating_expense\' covers SG&A and store operations; \'ebitda\' marks EBITDA-relevant accounts. [ENUM-REF-CANDIDATE: revenue|cogs|gross_margin|operating_expense|ebitda|depreciation|interest|tax|not_applicable — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationAccountType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Type' ;
    rdfs:comment 'Identifies whether this GL account serves as a reconciliation (control) account for a subledger. \'customer\' links to accounts receivable subledger; \'vendor\' links to accounts payable subledger; \'asset\' links to fixed asset subledger; \'none\' indicates a standalone GL account. Maps to SAP field MITKZ in SKB1.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'Specifies the ASC 606 revenue recognition pattern applicable to this revenue GL account. \'point_in_time\' applies to standard retail POS and e-commerce sales; \'over_time\' applies to gift card breakage, loyalty program deferrals, and subscription revenues; \'not_applicable\' for non-revenue accounts. Drives automated revenue recognition scheduling in SAP FI.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'Three-digit SAP sort key that determines which document field is used to populate the allocation field in line items posted to this account (e.g., \'001\' = posting date, \'012\' = document number). Drives line item sorting in account statements and aging reports.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalAccount rdf:type rdf:Property ;
    rdfs:label 'Statistical Account' ;
    rdfs:comment 'Indicates whether this is a statistical GL account (True) used for management reporting and KPI tracking without affecting the legal financial statements. Statistical accounts capture quantities or values for internal analytics such as footfall, units sold, or headcount.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Defines the tax relevance of the GL account for input/output tax determination. Controls whether tax codes are required, optional, or not applicable during posting. Maps to SAP field MWSKZ in SKB1. [ENUM-REF-CANDIDATE: input_tax|output_tax|not_relevant|tax_only|deferred_tax|use_tax — promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxPostingRequired rdf:type rdf:Property ;
    rdfs:label 'Tax Posting Required' ;
    rdfs:comment 'Indicates whether a tax code is mandatory (True) when posting to this GL account. Enforces tax compliance controls at the point of financial entry, ensuring all taxable transactions are properly coded for regulatory reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toleranceGroup rdf:type rdf:Property ;
    rdfs:label 'Tolerance Group' ;
    rdfs:comment 'SAP tolerance group assigned to this GL account that defines acceptable variance thresholds for payment differences, rounding, and clearing. Controls automatic clearing of small differences during accounts payable and receivable processing.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'Unique identifier for the intercompany transaction record. Primary key for cross-entity financial postings between retail subsidiaries, international entities, and corporate holding companies.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nettingRunId rdf:type rdf:Property ;
    rdfs:label 'Netting Run Id' ;
    rdfs:comment 'Identifier of the netting run in which this intercompany transaction was included for multilateral settlement optimization.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NettingRun .

ind:sendingGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Sending Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Intercompany transactions have gl_account_sending (STRING) but no FK to gl_account master. This is the FIRST of two FKs from intercompany_transaction to gl_account, so the FK column name has a disting' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:sendingProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Sending Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Intercompany transactions have sending_profit_center (STRING) but no FK to profit_center master. This is the FIRST of two FKs from intercompany_transaction to profit_center, so the FK column name has ' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:documentCurrency rdf:type rdf:Property ;
    rdfs:label 'Document Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the intercompany transaction was originally denominated (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date on the source document or invoice that originated this intercompany transaction. May differ from posting date for timing differences.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'The externally-known SAP FI document number for this intercompany transaction. Used for audit trail and reconciliation across legal entities.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminationDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Elimination Document Number' ;
    rdfs:comment 'Reference to the consolidation elimination journal entry document that offsets this intercompany transaction in group reporting.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Elimination Flag' ;
    rdfs:comment 'Boolean indicator (True/False) marking whether this intercompany transaction requires elimination entries during consolidation to remove intra-group transactions from consolidated financial statements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'Classification of the exchange rate used (spot rate, monthly average, budget rate, or fixed rate) for currency conversion.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountReceiving rdf:type rdf:Property ;
    rdfs:label 'Gl Account Receiving' ;
    rdfs:comment 'General ledger account number in the receiving company code chart of accounts where the intercompany transaction is posted.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyAmountReceiving rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount Receiving' ;
    rdfs:comment 'Transaction amount converted to the local currency of the receiving company code for statutory reporting and consolidation.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrencyAmountSending rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount Sending' ;
    rdfs:comment 'Transaction amount converted to the local currency of the sending company code for statutory reporting and consolidation.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrencyReceiving rdf:type rdf:Property ;
    rdfs:label 'Local Currency Receiving' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the receiving company code\'s local currency for statutory books.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencySending rdf:type rdf:Property ;
    rdfs:label 'Local Currency Sending' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the sending company code\'s local currency for statutory books.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingStatus rdf:type rdf:Property ;
    rdfs:label 'Netting Status' ;
    rdfs:comment 'Indicates whether this intercompany transaction has been included in a multilateral netting process to reduce settlement volumes and FX exposure.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Code' ;
    rdfs:comment 'SAP company code of the legal entity receiving the intercompany transaction (creditor side in most cases).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingProfitCenter rdf:type rdf:Property ;
    rdfs:label 'Receiving Profit Center' ;
    rdfs:comment 'Profit center within the receiving company code that is charged or credited for this intercompany transaction. Used for internal P&L reporting.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date when the intercompany transaction was successfully reconciled and confirmed by both sending and receiving entities.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Current status of the intercompany reconciliation process indicating whether sending and receiving entries match and have been confirmed by both entities.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code' ;
    rdfs:comment 'SAP company code of the legal entity originating the intercompany transaction (debtor side in most cases).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'Actual date when the intercompany transaction was settled through cash transfer, netting, or other settlement mechanism.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementMethod rdf:type rdf:Property ;
    rdfs:label 'Settlement Method' ;
    rdfs:comment 'The mechanism used to settle the intercompany transaction (cash transfer, multilateral netting, bilateral offset, or in-kind settlement).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'The monetary value of the intercompany transaction in the document currency. Represents the gross amount before any adjustments.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionDescription rdf:type rdf:Property ;
    rdfs:label 'Transaction Description' ;
    rdfs:comment 'Free-text description providing additional business context and details about the nature and purpose of this intercompany transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the intercompany transaction in the financial close and consolidation workflow.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the intercompany transaction indicating the nature of the cross-entity posting (management fee, shared service allocation, inventory transfer, loan, dividend, royalty).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Documentation Reference' ;
    rdfs:comment 'Reference identifier to the supporting transfer pricing documentation, study, or agreement that justifies the pricing of this intercompany transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'The OECD-compliant transfer pricing methodology applied to determine the arm\'s length price for this intercompany transaction for tax compliance.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The effective date for cash flow and treasury purposes, particularly relevant for intercompany loans and settlements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Unique surrogate identifier for each journal entry record in the general ledger. Primary key for the journal_entry data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:ledgerId rdf:type rdf:Property ;
    rdfs:label 'Ledger Id' ;
    rdfs:comment 'SAP S/4HANA ledger identifier specifying which accounting ledger the entry is posted to (e.g., \'0L\' = Leading Ledger for GAAP/FASB, \'N1\' = Non-Leading Ledger for IFRS parallel accounting). Supports multi-GAAP reporting requirements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ledger .

ind:accrualIndicator rdf:type rdf:Property ;
    rdfs:label 'Accrual Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry represents an accrual posting (True) — i.e., an expense or revenue recognized in the current period but not yet cash-settled. Supports accrual accounting under FASB ASC 606 and period-end close processes.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'SAP FI assignment field (ZUONR) used for sorting and matching open items in accounts payable and receivable clearing. Typically populated with the purchase order number, sales order number, or payment reference for automated clearing and reconciliation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'SAP FI business area code representing an organizational unit for which an internal balance sheet and P&L can be created. Used in retail for segment reporting across hypermarkets, department stores, discount outlets, and e-commerce channels.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether the journal entry header represents a debit (D) or credit (C) posting at the document level. Fundamental double-entry bookkeeping indicator used in SAP FI-GL for balance validation and financial statement preparation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentAmount rdf:type rdf:Property ;
    rdfs:label 'Document Amount' ;
    rdfs:comment 'Gross total amount of the journal entry in the document (transaction) currency. Represents the sum of all debit or credit line items before netting. Used for financial reporting, reconciliation, and audit trail in retail P&L and balance sheet analysis.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Document Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the transaction currency in which the journal entry amounts are originally recorded (e.g., USD, EUR, GBP). Distinct from local/company code currency. Required for multi-currency retail operations and FX reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'SAP FI two-character document type code classifying the nature of the accounting document (e.g., SA=General Ledger, KR=Vendor Invoice, DR=Customer Invoice, AA=Asset Posting, AB=Accounting Document, ZP=Payment Clearing, RV=Revenue). Drives number range assignment and account type determination. [ENUM-REF-CANDIDATE: SA|KR|DR|AA|AB|ZP|RV|KZ|DZ|WA|WE|RE — promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enteredBy rdf:type rdf:Property ;
    rdfs:label 'Entered By' ;
    rdfs:comment 'SAP user ID of the person or system process that created the journal entry in SAP S/4HANA FI-GL. Required for FASB-compliant audit trail, SOX internal controls, and financial close accountability.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The exact date and time when the journal entry record was first created and saved in SAP S/4HANA FI-GL. Serves as the RECORD_AUDIT_CREATED timestamp for audit trail and FASB-compliant financial close documentation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Classification of the journal entry by its accounting purpose: \'standard\' = normal business transaction; \'accrual\' = expense/revenue accrual; \'reversal\' = reversal of a prior entry; \'adjustment\' = period-end correction; \'intercompany\' = elimination entry; \'depreciation\' = fixed asset depreciation; \'lease\' = ASC 842 lease expense; \'reclassification\' = account reclassification. [ENUM-REF-CANDIDATE: standard|accrual|reversal|adjustment|intercompany|depreciation|lease|reclassification|deferred_revenue|cogs — promote to reference product]' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxRate rdf:type rdf:Property ;
    rdfs:label 'Fx Rate' ;
    rdfs:comment 'Exchange rate applied to translate document currency amounts to local currency at the time of posting. Sourced from SAP FI exchange rate tables. Critical for multi-currency retail operations, FX gain/loss accounting, and FASB ASC 830 compliance.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headerText rdf:type rdf:Property ;
    rdfs:label 'Header Text' ;
    rdfs:comment 'Free-text description or business justification entered at the journal entry header level in SAP FI-GL. Provides context for the posting (e.g., \'Q3 Rent Accrual\', \'COGS Adjustment - Store 1042\', \'Intercompany Elimination - FY2024 Q4\'). Required for audit trail and financial close documentation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry involves a transaction between two legal entities within the same corporate group (True). Used for intercompany elimination in consolidated financial statements under FASB ASC 810.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localAmount rdf:type rdf:Property ;
    rdfs:label 'Local Amount' ;
    rdfs:comment 'Total amount of the journal entry translated into the company code\'s local (functional) currency using the FX rate at posting date. Used for statutory P&L, balance sheet, and EBITDA reporting under FASB standards.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the company code\'s local (functional) currency. Used for statutory reporting and local GAAP compliance. Amounts are translated from document currency to local currency using the FX rate.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'SAP FI two-digit posting key controlling the debit/credit assignment, account type, and field selection for the journal entry (e.g., 40=Debit G/L, 50=Credit G/L, 01=Customer Invoice, 31=Vendor Invoice). Fundamental SAP FI-GL configuration element.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry is a reversal of a previously posted document (True) or an original posting (False). Used in SAP FI-GL for accrual reversal management and period-end close processes.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The SAP accounting document number of the original entry that this journal entry reverses. Populated only when reversal_indicator is True. Provides the audit trail link between reversal and original posting for FASB-compliant financial close.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledReversalDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Reversal Date' ;
    rdfs:comment 'The date on which SAP S/4HANA is scheduled to automatically reverse this journal entry (typically the first day of the following period for accrual entries). Populated when accrual_indicator is True. Supports automated period-end close and accrual management.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceModule rdf:type rdf:Property ;
    rdfs:label 'Source Module' ;
    rdfs:comment 'SAP S/4HANA module that originated the journal entry posting (e.g., FI-AP=Accounts Payable, FI-AR=Accounts Receivable, FI-AA=Asset Accounting, FI-TX=Tax Accounting, MM=Materials Management, SD=Sales & Distribution, CO=Controlling). Enables source-system traceability and cross-module reconciliation. [ENUM-REF-CANDIDATE: FI-AP|FI-AR|FI-AA|FI-TX|FI-GL|MM|SD|CO|PP|WM — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'SAP company code of the intercompany trading partner involved in this journal entry. Populated only when intercompany_indicator is True. Required for intercompany reconciliation and elimination in consolidated P&L and balance sheet reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each journal entry line item in the general ledger. Primary key for this silver-layer data product, aligned to SAP FI-GL line item table (BSEG).' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountDocCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Doc Currency' ;
    rdfs:comment 'The transaction amount in the document (transaction) currency, corresponding to SAP BSEG-WRBTR. Used for multi-currency financial reporting and foreign exchange analysis.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Group Currency' ;
    rdfs:comment 'The transaction amount translated to the group (consolidation) currency, corresponding to SAP BSEG-KURSF-derived group currency amount. Supports consolidated P&L and EBITDA reporting across all legal entities.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Local Currency' ;
    rdfs:comment 'The transaction amount translated to the company code local currency, corresponding to SAP BSEG-DMBTR. Used for statutory financial reporting and local GAAP compliance.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignment rdf:type rdf:Property ;
    rdfs:label 'Assignment' ;
    rdfs:comment 'Free-form assignment field used for line item sorting and allocation, corresponding to SAP BSEG-ZUONR. Typically populated with a reference number (e.g., purchase order, cost object) to facilitate reconciliation and reporting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Doc Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the document (transaction) currency, corresponding to SAP BSEG-WAERS. Enables multi-currency P&L and balance sheet reporting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'Reference to the SAP internal order (AUFNR) to which this line item is assigned. Used for project-level cost tracking, capital expenditure monitoring, and marketing campaign cost allocation.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isReversed rdf:type rdf:Property ;
    rdfs:label 'Is Reversed' ;
    rdfs:comment 'Indicates whether this journal entry line has been reversed (True) or is active (False), derived from SAP BKPF-STBLG. Reversed entries must be excluded from financial statement totals to prevent double-counting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Descriptive text for this journal entry line item, corresponding to SAP BSEG-SGTXT. Provides narrative context for auditors, financial analysts, and during financial close review.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line item number within the parent journal entry, corresponding to SAP BSEG-BUZEI. Used to order and uniquely identify each debit or credit posting within a document.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'SAP material number (MATNR in BSEG) corresponding to the Stock Keeping Unit (SKU) associated with this line item. Populated for inventory valuation, COGS, and goods movement postings. Enables drill-down from GL to product-level cost analysis.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'The SAP document number of the reversing entry (STBLG from BKPF), if this line has been reversed. Enables audit trail tracing from original posting to reversal for financial close and SOX compliance.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialGlIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Gl Indicator' ;
    rdfs:comment 'SAP special GL indicator (UMSKZ) used for down payments, guarantees, and other special transactions that are posted to alternative reconciliation accounts. Blank for standard postings.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax code assigned to this line item for VAT/sales tax determination, corresponding to SAP BSEG-MWSKZ. Drives tax reporting, compliance, and accounts payable/receivable tax calculations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'SAP WBS element (PROJK) for project-based cost assignment, corresponding to capital expenditure projects such as store openings, DC expansions, or IT implementations. Supports CAPEX tracking and ASC 842 lease accounting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rouAssetGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Rou Asset Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Lease contracts have gl_account_rou_asset (STRING) but no FK to gl_account master. This FK links to the GL account for right-of-use asset under ASC 842. This is the FIRST of two FKs from lease_contrac' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:baseRentMonthly rdf:type rdf:Property ;
    rdfs:label 'Base Rent Monthly' ;
    rdfs:comment 'Fixed monthly base rent payment amount as stipulated in the lease contract, excluding variable lease components (e.g., percentage rent, CAM charges). Used as the primary input for lease payment schedule generation and ASC 842 liability measurement.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commencementDate rdf:type rdf:Property ;
    rdfs:label 'Commencement Date' ;
    rdfs:comment 'Date on which the lease term begins and the lessee obtains the right to use the underlying asset. This is the measurement date for initial ROU asset and lease liability recognition under ASC 842.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to the lease contract, used in correspondence with lessors, auditors, and legal teams. Sourced from SAP S/4HANA FI/CO lease contract object (RE-FX module).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountLeaseLiability rdf:type rdf:Property ;
    rdfs:label 'Gl Account Lease Liability' ;
    rdfs:comment 'SAP GL account number for the lease liability recognized on the balance sheet at lease commencement under ASC 842. Tracks the present value of future lease payments for balance sheet disclosure.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implicitRate rdf:type rdf:Property ;
    rdfs:label 'Implicit Rate' ;
    rdfs:comment 'The rate of interest implicit in the lease as defined by the lessor, used as the discount rate when readily determinable. Takes precedence over the incremental borrowing rate (IBR) for lease liability measurement under ASC 842. Expressed as a decimal.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incrementalBorrowingRate rdf:type rdf:Property ;
    rdfs:label 'Incremental Borrowing Rate' ;
    rdfs:comment 'The interest rate the lessee would have to pay to borrow funds on a collateralized basis over a similar term and in a similar economic environment, used to discount future lease payments to present value when the implicit rate is not readily determinable. Expressed as a decimal (e.g., 0.045000 = 4.5%). Required for ASC 842 lease liability measurement.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initialDirectCost rdf:type rdf:Property ;
    rdfs:label 'Initial Direct Cost' ;
    rdfs:comment 'Incremental costs incurred by the lessee directly attributable to negotiating and arranging the lease (e.g., legal fees, broker commissions). Added to the initial ROU asset value at commencement under ASC 842.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date on which the most recent lease payment was made to the lessor. Used for payment reconciliation, delinquency monitoring, and lease liability roll-forward calculations during monthly close.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseIncentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Lease Incentive Amount' ;
    rdfs:comment 'Total lease incentives received from the lessor (e.g., tenant improvement allowances, rent-free periods, moving allowances). Reduces the initial ROU asset value at commencement under ASC 842 and is amortized over the lease term.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseLiabilityBalance rdf:type rdf:Property ;
    rdfs:label 'Lease Liability Balance' ;
    rdfs:comment 'Current outstanding lease liability balance as of the last accounting close, reflecting initial recognition less principal payments made to date. Split into current and non-current portions for balance sheet classification per ASC 842.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseLiabilityInitial rdf:type rdf:Property ;
    rdfs:label 'Lease Liability Initial' ;
    rdfs:comment 'Present value of future lease payments discounted at the applicable rate (implicit rate or IBR) at lease commencement date. Represents the initial lease liability recognized on the balance sheet under ASC 842.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseStatus rdf:type rdf:Property ;
    rdfs:label 'Lease Status' ;
    rdfs:comment 'Current lifecycle state of the lease contract. Drives accounting treatment, payment processing, and disclosure eligibility. \'Modified\' indicates a lease modification event requiring remeasurement under ASC 842.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseTermMonths rdf:type rdf:Property ;
    rdfs:label 'Lease Term Months' ;
    rdfs:comment 'Total non-cancellable lease term expressed in months, including any renewal periods that are reasonably certain to be exercised. Used for amortization schedule generation and ASC 842 disclosure of weighted-average remaining lease term.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaseType rdf:type rdf:Property ;
    rdfs:label 'Lease Type' ;
    rdfs:comment 'ASC 842 classification of the lease as either an operating lease (expense recognized straight-line on P&L) or a finance lease (ROU asset amortized separately from interest expense). Drives balance sheet recognition and disclosure treatment.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leasedAssetCategory rdf:type rdf:Property ;
    rdfs:label 'Leased Asset Category' ;
    rdfs:comment 'Category of the underlying leased asset. Retail-specific categories include store locations (hypermarkets, department stores, discount outlets), distribution centers (DC), dark stores, micro-fulfillment centers (MFC), equipment, and vehicles. [ENUM-REF-CANDIDATE: store_location|distribution_center|office|equipment|vehicle|dark_store|micro_fulfillment_center — promote to reference product]' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessorName rdf:type rdf:Property ;
    rdfs:label 'Lessor Name' ;
    rdfs:comment 'Legal name of the lessor (landlord or equipment owner) as stated in the lease agreement. Used for counterparty identification in AP processing, EDI transactions, and disclosure reporting.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowValueAssetFlag rdf:type rdf:Property ;
    rdfs:label 'Low Value Asset Flag' ;
    rdfs:comment 'Indicates whether the lease qualifies for the low-value asset practical expedient (typically assets with an underlying value below $5,000 when new). When True, lease payments are recognized as expense on a straight-line basis without balance sheet recognition.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modificationDate rdf:type rdf:Property ;
    rdfs:label 'Modification Date' ;
    rdfs:comment 'Date on which a lease modification event occurred (e.g., extension of lease term, addition of leased space, change in rent). Triggers remeasurement of the ROU asset and lease liability at the modification date under ASC 842.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modificationType rdf:type rdf:Property ;
    rdfs:label 'Modification Type' ;
    rdfs:comment 'Categorizes the nature of the most recent lease modification event. Determines whether the modification is accounted for as a separate new lease or a remeasurement of the existing lease under ASC 842.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Next Payment Date' ;
    rdfs:comment 'Date on which the next scheduled lease payment is due to the lessor. Used for AP cash management, payment run scheduling, and short-term lease liability classification on the balance sheet.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Frequency at which lease payments are due under the contract terms. Drives payment schedule generation, cash flow forecasting, and AP payment run scheduling in SAP S/4HANA.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Purchase Option Flag' ;
    rdfs:comment 'Indicates whether the lease contract includes an option for the lessee to purchase the underlying asset. A purchase option that is reasonably certain to be exercised is a criterion for finance lease classification under ASC 842.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Flag' ;
    rdfs:comment 'Indicates whether the lease contract contains one or more renewal options. When True, renewal_option_term_months and renewal_reasonably_certain_flag must be evaluated for inclusion in the lease term under ASC 842.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalOptionTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Term Months' ;
    rdfs:comment 'Duration in months of the renewal option period(s) available under the lease contract. Included in the lease term measurement when the lessee is reasonably certain to exercise the option.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalReasonablyCertainFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Reasonably Certain Flag' ;
    rdfs:comment 'Indicates whether the lessee has determined it is reasonably certain to exercise the renewal option, requiring inclusion of the renewal period in the lease term and remeasurement of ROU asset and lease liability under ASC 842.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rouAssetCarryingValue rdf:type rdf:Property ;
    rdfs:label 'Rou Asset Carrying Value' ;
    rdfs:comment 'Current net book value of the ROU asset after accumulated amortization (finance lease) or straight-line adjustments (operating lease) as of the last accounting close date. Used for balance sheet presentation and ASC 842 disclosure.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rouAssetInitialValue rdf:type rdf:Property ;
    rdfs:label 'Rou Asset Initial Value' ;
    rdfs:comment 'Initial carrying amount of the Right-of-Use (ROU) asset recognized at lease commencement, equal to the initial lease liability plus any lease payments made at or before commencement, less any lease incentives received, plus initial direct costs. Expressed in functional currency (USD).' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortTermLeaseFlag rdf:type rdf:Property ;
    rdfs:label 'Short Term Lease Flag' ;
    rdfs:comment 'Indicates whether the lease qualifies for the short-term lease practical expedient under ASC 842 (lease term of 12 months or less at commencement). When True, the lessee is not required to recognize an ROU asset or lease liability on the balance sheet.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Actual date on which the lease was terminated early (if applicable). Triggers derecognition of the ROU asset and lease liability and recognition of any gain or loss on termination under ASC 842.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Termination Option Flag' ;
    rdfs:comment 'Indicates whether the lease contract contains an early termination option. When True, the termination option must be assessed for reasonable certainty of exercise, which may shorten the lease term used in ASC 842 measurement.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variableLeasePaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Variable Lease Payment Flag' ;
    rdfs:comment 'Indicates whether the lease contract includes variable lease payments (e.g., percentage rent based on store sales, CPI-indexed escalations, or CAM charges). Variable payments not dependent on an index or rate are excluded from lease liability measurement but disclosed separately under ASC 842.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variablePaymentBasis rdf:type rdf:Property ;
    rdfs:label 'Variable Payment Basis' ;
    rdfs:comment 'Describes the basis on which variable lease payments are calculated. \'sales_percentage\' is common in retail (percentage rent tied to store revenue). \'cpi_index\' indicates CPI-linked escalation. \'cam_charges\' covers common area maintenance. Drives variable payment disclosure under ASC 842.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightedAvgRemainingTerm rdf:type rdf:Property ;
    rdfs:label 'Weighted Avg Remaining Term' ;
    rdfs:comment 'Weighted average remaining lease term in years as of the reporting date, calculated across the lease portfolio. Required ASC 842 disclosure for both operating and finance leases in the financial statement footnotes.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualCogsBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Cogs Budget' ;
    rdfs:comment 'Planned annual Cost of Goods Sold (COGS) budget for this profit center. Used to calculate budgeted gross margin and GMROI targets. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualOpexBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Opex Budget' ;
    rdfs:comment 'Planned annual operating expense (OPEX) budget for this profit center, excluding COGS. Includes store labor, occupancy, marketing, and overhead. Used for EBITDA planning and P&L variance reporting. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRevenueBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Budget' ;
    rdfs:comment 'Planned annual revenue target for this profit center in the profit center currency. Used for P&L variance analysis, comp sales (SSS) benchmarking, and EBITDA forecasting. Sourced from SAP CO-PCA budget planning. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asc280ReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Asc280 Reportable Flag' ;
    rdfs:comment 'Indicates whether this profit center qualifies as a reportable segment under FASB ASC 280 (Segment Reporting) based on the 10% quantitative thresholds for revenue, profit/loss, or assets (True = reportable segment). Drives external financial disclosure requirements.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetPeriod rdf:type rdf:Property ;
    rdfs:label 'Budget Period' ;
    rdfs:comment 'The fiscal year or fiscal year-period (YYYY or YYYY-MM) for which the current budget is active for this profit center. Used in Open to Buy (OTB) planning, financial forecasting, and variance analysis against actuals.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date on which this profit center was deactivated or archived. Null if the profit center is currently active. Used for historical P&L analysis, store closure reporting, and comp sales (SSS) exclusion logic.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hierarchyNodeCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node Code' ;
    rdfs:comment 'Code of the standard hierarchy node to which this profit center is assigned in SAP CO-PCA. Enables rollup P&L reporting across organizational levels (e.g., store → region → banner → enterprise). Used for segment reporting per ASC 280.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseAccountingFlag rdf:type rdf:Property ;
    rdfs:label 'Lease Accounting Flag' ;
    rdfs:comment 'Indicates whether this profit center has active lease obligations subject to ASC 842 lease accounting (True = lease obligations exist). Triggers right-of-use (ROU) asset and lease liability recognition in the financial close process for store and DC profit centers.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Block Flag' ;
    rdfs:comment 'Indicates whether financial postings to this profit center are currently blocked (True = blocked, False = open). Set during financial close periods, audits, or when a profit center is being restructured. Prevents erroneous postings during sensitive periods.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Profit Center Category' ;
    rdfs:comment 'Management accounting classification indicating the primary financial role of the profit center: \'revenue\' (generates external revenue), \'cost\' (internal cost allocation only), \'investment\' (capital-intensive with ROI tracking), \'service\' (shared service provider). Drives transfer pricing rules and internal P&L treatment.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'Detailed business description of the profit center\'s purpose, scope, and the business unit it represents. Provides context for financial analysts, auditors, and management reporting consumers.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterLevel rdf:type rdf:Property ;
    rdfs:label 'Profit Center Level' ;
    rdfs:comment 'Numeric level of this profit center within the management accounting hierarchy (e.g., 1 = enterprise, 2 = banner, 3 = region, 4 = store). Used for hierarchical P&L rollup, drill-down reporting, and segment aggregation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'Human-readable name of the profit center (e.g., \'Chicago Flagship Store\', \'US E-Commerce Channel\', \'Private Label Apparel\'). Used in P&L reports, dashboards, and management presentations. Satisfies MASTER_RESOURCE IDENTITY_LABEL category.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle state of the profit center master record. \'active\' — open for postings; \'inactive\' — temporarily closed; \'locked\' — blocked for new postings (e.g., during financial close); \'pending\' — awaiting activation; \'archived\' — historical record, no postings allowed. Satisfies MASTER_RESOURCE LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the autonomous business unit represented by this profit center. Determines the nature of P&L reporting: \'store\' (physical retail location), \'channel\' (e-commerce, BOPIS, DSD), \'product_line\' (private label, electronics, apparel), \'banner\' (hypermarket, discount outlet), \'region\' (geographic grouping), \'corporate\' (shared services). Satisfies MASTER_RESOURCE CLASSIFICATION_OR_TYPE category.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleManager rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager' ;
    rdfs:comment 'Full name or employee ID of the manager accountable for this profit center\'s financial performance. Used in management reporting, budget approval workflows, and P&L accountability assignments in SAP CO-PCA.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated display name for the profit center used in space-constrained reports, POS system displays, and financial dashboards (e.g., \'CHI-FLAGSHIP\', \'ECOM-US\').' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeNumber rdf:type rdf:Property ;
    rdfs:label 'Store Number' ;
    rdfs:comment 'Physical store identifier associated with this profit center when profit_center_type is \'store\'. Links to the store master for footfall, planogram, and comp sales (SSS) reporting. Null for non-store profit centers.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPriceFlag rdf:type rdf:Property ;
    rdfs:label 'Transfer Price Flag' ;
    rdfs:comment 'Indicates whether transfer pricing rules apply to transactions involving this profit center (True = transfer pricing active). Relevant for intercompany transactions between profit centers, particularly for cross-border operations subject to OECD transfer pricing guidelines.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'Date from which this profit center is valid and open for financial postings in SAP CO-PCA. Defines the start of the profit center\'s active period for time-dependent master data management and fiscal year planning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'Date until which this profit center is valid for financial postings. After this date, the profit center is locked for new transactions. Null indicates an open-ended validity period. Used for profit center lifecycle management and financial close.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionEventId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each ASC 606 revenue recognition event record in the silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognitionEvent .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Reference to the customer contract or sales agreement under which this revenue recognition event is triggered. Aligns with ASC 606 Step 1: Identify the contract with a customer.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeaseContract .

ind:originalEventRevenueRecognitionEventId rdf:type rdf:Property ;
    rdfs:label 'Original Event Revenue Recognition Event Id' ;
    rdfs:comment 'For reversal or adjustment events, the revenue_recognition_event_id of the original recognition event being reversed or corrected. Null for original (non-reversal) events. Supports audit trail and financial reconciliation.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognitionEvent .

ind:accountingPeriod rdf:type rdf:Property ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'The fiscal accounting period (YYYY-MM) to which this revenue recognition event is posted. Used for period-end financial close, P&L reporting, and EBITDA tracking in SAP S/4HANA FI/CO.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedTransactionPrice rdf:type rdf:Property ;
    rdfs:label 'Allocated Transaction Price' ;
    rdfs:comment 'The portion of the total transaction price allocated to this specific performance obligation under ASC 606 Step 4 (Allocate the transaction price to the performance obligations), based on relative standalone selling prices.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asc606Step rdf:type rdf:Property ;
    rdfs:label 'Asc606 Step' ;
    rdfs:comment 'Identifies which of the five ASC 606 revenue recognition steps this event record primarily documents: Step 1 (Identify contract), Step 2 (Identify performance obligations), Step 3 (Determine transaction price), Step 4 (Allocate transaction price), Step 5 (Recognize revenue). Supports compliance audit and FASB disclosure reporting.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsAmount rdf:type rdf:Property ;
    rdfs:label 'Cogs Amount' ;
    rdfs:comment 'The cost of goods sold (COGS) associated with the recognized revenue event. Used to compute gross margin and GMROI (Gross Margin Return on Investment) at the transaction level for P&L reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractModificationFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Modification Flag' ;
    rdfs:comment 'Indicates whether this revenue recognition event was triggered by a contract modification (e.g., price change, scope change, return, exchange). True = event results from a contract modification per ASC 606-10-25-10 through 25-13.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractModificationType rdf:type rdf:Property ;
    rdfs:label 'Contract Modification Type' ;
    rdfs:comment 'The accounting treatment applied to the contract modification per ASC 606. \'new_contract\' = treated as a separate contract; \'modification_existing\' = prospective adjustment to existing contract; \'cumulative_catchup\' = cumulative catch-up adjustment to revenue.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferredRevenueBalance rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue Balance' ;
    rdfs:comment 'The remaining unrecognized revenue balance for this performance obligation as of the recognition event date. Represents the contract liability on the balance sheet per ASC 606. Applicable for gift cards, extended warranties, and loyalty programs.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftCardBreakageRate rdf:type rdf:Property ;
    rdfs:label 'Gift Card Breakage Rate' ;
    rdfs:comment 'The estimated breakage rate (as a decimal proportion, e.g., 0.0850 = 8.50%) applied to gift card balances to recognize breakage income proportionally as redemptions occur. Applicable only when revenue_category = \'gift_card_breakage\'. Based on historical redemption patterns per ASC 606-10-55-48.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Amount' ;
    rdfs:comment 'The gross margin amount for this recognition event, calculated as recognized_amount minus cogs_amount. Supports P&L reporting and EBITDA tracking at the transaction level.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyPointFairValue rdf:type rdf:Property ;
    rdfs:label 'Loyalty Point Fair Value' ;
    rdfs:comment 'The estimated standalone selling price (fair value) per loyalty point at the time of the originating transaction, used for transaction price allocation under ASC 606 Step 4. Expressed in the transaction currency.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obligationSatisfactionDate rdf:type rdf:Property ;
    rdfs:label 'Obligation Satisfaction Date' ;
    rdfs:comment 'The date on which the distinct performance obligation was fully satisfied (e.g., delivery date for product sale, activation date for extended warranty, redemption date for loyalty points). Aligns with ASC 606 Step 5.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionEndDate rdf:type rdf:Property ;
    rdfs:label 'Recognition End Date' ;
    rdfs:comment 'The end date of the revenue recognition period for over-time performance obligations (e.g., extended warranty coverage end, franchise agreement expiry). Null for point-in-time recognition events.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'ASC 606 Step 5 recognition pattern. \'point_in_time\' = revenue recognized at a single moment (e.g., product sale, gift card redemption); \'over_time\' = revenue recognized progressively (e.g., extended warranty, franchise fee, subscription).' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Start Date' ;
    rdfs:comment 'The start date of the revenue recognition period for over-time performance obligations (e.g., extended warranty coverage start, franchise agreement commencement). Null for point-in-time recognition events.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Recognition Status' ;
    rdfs:comment 'Current lifecycle state of the revenue recognition event. \'pending\' = awaiting performance obligation satisfaction; \'recognized\' = revenue posted to GL; \'deferred\' = revenue deferred to future period; \'reversed\' = recognition reversed due to contract modification or return; \'cancelled\' = event voided.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recognition Timestamp' ;
    rdfs:comment 'The precise date and time at which the performance obligation was satisfied and revenue was recognized in the General Ledger. This is the principal business event timestamp for this entity.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Recognized Amount' ;
    rdfs:comment 'The actual revenue amount recognized in the current accounting period for this event. For point-in-time recognition, equals the allocated transaction price. For over-time recognition, represents the portion earned in the current period.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Category' ;
    rdfs:comment 'Classification of the revenue stream type per ASC 606 disaggregation disclosure requirements. Covers retail-specific categories including gift card breakage (unredeemed gift card income), loyalty point redemptions, franchise fees, extended warranties, and standard product sales. [ENUM-REF-CANDIDATE: product_sale|gift_card_breakage|loyalty_redemption|franchise_fee|extended_warranty|service_fee — promote to reference product]' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this recognition event is a reversal of a previously posted revenue entry (e.g., due to a return, contract cancellation, or correction). True = this is a reversal entry with a negative recognized_amount.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Source Document Number' ;
    rdfs:comment 'The business document number of the originating transaction (e.g., SAP sales order number, POS transaction ID, invoice number) that generated this revenue recognition event. Used for end-to-end audit trail and financial reconciliation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Source Document Type' ;
    rdfs:comment 'The type of originating source document that triggered this revenue recognition event. Supports audit trail and reconciliation back to SAP S/4HANA SD module or SAP CAR POS transaction data.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standaloneSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Standalone Selling Price' ;
    rdfs:comment 'The standalone selling price (SSP) of the performance obligation at contract inception, used as the basis for transaction price allocation under ASC 606 Step 4. Determined by observable prices, adjusted market assessment, or expected cost plus margin approach.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The calendar date on which the originating retail transaction (POS sale, e-commerce order, gift card purchase, etc.) occurred. Used for period-end revenue cut-off and financial close.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionPrice rdf:type rdf:Property ;
    rdfs:label 'Transaction Price' ;
    rdfs:comment 'The total transaction price allocated to the contract as determined under ASC 606 Step 3 (Determine the transaction price). Represents the gross amount before allocation to individual performance obligations. Includes variable consideration estimates.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variableConsiderationAmount rdf:type rdf:Property ;
    rdfs:label 'Variable Consideration Amount' ;
    rdfs:comment 'The estimated variable consideration included in the transaction price (e.g., volume discounts, rebates, returns allowances, markdown adjustments). Constrained per ASC 606 variable consideration constraint guidance.' ;
    rdfs:domain ind:RevenueRecognitionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxPostingId rdf:type rdf:Property ;
    rdfs:label 'Tax Posting Id' ;
    rdfs:comment 'Unique identifier for the tax posting transaction record in SAP S/4HANA FI-TX.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalPostingTaxPostingId rdf:type rdf:Property ;
    rdfs:label 'Original Posting Tax Posting Id' ;
    rdfs:comment 'Reference to the original tax posting ID that this record reverses (populated only when reversal_flag is true).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxPosting .

ind:nexusIndicator rdf:type rdf:Property ;
    rdfs:label 'Nexus Indicator' ;
    rdfs:comment 'Flag indicating whether the retailer has established tax nexus (physical or economic presence) in this jurisdiction, triggering tax collection obligation.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The fiscal period (YYYY-MM format) to which this tax posting is assigned for tax return preparation and regulatory reporting.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reverseChargeFlag rdf:type rdf:Property ;
    rdfs:label 'Reverse Charge Flag' ;
    rdfs:comment 'Indicates whether this is a reverse charge VAT transaction where the customer is responsible for self-assessing and remitting VAT.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxAmountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Tax Amount Local Currency' ;
    rdfs:comment 'The tax amount converted to local reporting currency for financial statement consolidation.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Name' ;
    rdfs:comment 'The name of the government tax authority to which this tax will be remitted (e.g., California Department of Tax and Fee Administration, IRS).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Tax Determination Date' ;
    rdfs:comment 'The business event date used to determine applicable tax rates and jurisdiction (typically transaction date or delivery date).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxDirection rdf:type rdf:Property ;
    rdfs:label 'Tax Direction' ;
    rdfs:comment 'Indicates whether this is input tax (paid to suppliers) or output tax (collected from customers).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate Number' ;
    rdfs:comment 'The exemption certificate number provided by the customer to support tax-exempt status (resale certificate, government ID, non-profit certificate).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCity rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction City' ;
    rdfs:comment 'City or municipality name for city-level sales tax jurisdictions (applicable in US multi-jurisdiction tax scenarios).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCountry rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Country' ;
    rdfs:comment 'Three-letter ISO country code of the tax jurisdiction where the tax obligation arises.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCounty rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction County' ;
    rdfs:comment 'County or district name for county-level sales tax jurisdictions (applicable in US multi-jurisdiction tax scenarios).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionState rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction State' ;
    rdfs:comment 'Two-letter state or province code within the country for state-level sales tax (US) or provincial tax (Canada).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxPointDate rdf:type rdf:Property ;
    rdfs:label 'Tax Point Date' ;
    rdfs:comment 'The date when the tax liability arises for VAT purposes (typically invoice date or goods delivery date per VAT regulations).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'The effective tax rate percentage applied to the taxable base (e.g., 8.25000 for 8.25% sales tax).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Registration Number' ;
    rdfs:comment 'The retailer\'s tax registration number with the jurisdiction\'s tax authority (sales tax permit number, VAT registration number, GST number).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'The category of tax being posted (sales tax, VAT, use tax, excise duty, withholding tax, customs duty).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Base Amount' ;
    rdfs:comment 'The gross transaction amount subject to tax before tax calculation, in transaction currency.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the tax transaction was recorded.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupAssociateId rdf:type rdf:Property ;
    rdfs:label 'Pickup Associate Id' ;
    rdfs:comment 'Reference to the store associate who handed off the order to the customer at pickup.' ;
    rdfs:domain ind:BopisAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:actualPickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Pickup Timestamp' ;
    rdfs:comment 'Timestamp when the customer physically received and collected the order from the store.' ;
    rdfs:domain ind:BopisAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualReadyMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Ready Minutes' ;
    rdfs:comment 'Actual elapsed time in minutes from order placement to ready-for-pickup status, used for SLA performance tracking.' ;
    rdfs:domain ind:BopisAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alternatePickupPersonName rdf:type rdf:Property ;
    rdfs:label 'Alternate Pickup Person Name' ;
    rdfs:comment 'Name of an alternate person authorized to pick up the order on behalf of the customer.' ;
    rdfs:domain ind:BopisAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentNumber rdf:type rdf:Property ;
    rdfs:label 'Appointment Number' ;
    rdfs:comment 'Human-readable unique appointment confirmation number provided to the customer for reference at pickup.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Appointment Status' ;
    rdfs:comment 'Current lifecycle status of the BOPIS appointment: scheduled (appointment created), ready (order ready for pickup), picked_up (customer collected order), expired (pickup window passed), cancelled (customer or system cancelled), no_show (customer did not arrive).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentType rdf:type rdf:Property ;
    rdfs:label 'Appointment Type' ;
    rdfs:comment 'Type of pickup appointment: BOPIS (Buy Online Pick Up In Store - order already paid) or ROPIS (Reserve Online Pick Up In Store - payment at pickup).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInMethod rdf:type rdf:Property ;
    rdfs:label 'Check In Method' ;
    rdfs:comment 'Method used by the customer to check in for pickup: mobile_app (customer used retailer app), kiosk (in-store self-service kiosk), associate (checked in with store associate), phone (called store), walk_in (arrived without prior check-in).' ;
    rdfs:domain ind:BopisAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check In Timestamp' ;
    rdfs:comment 'Timestamp when the customer checked in to notify the store of their arrival for pickup.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerEmail rdf:type rdf:Property ;
    rdfs:label 'Customer Email' ;
    rdfs:comment 'Email address for sending pickup ready notifications and appointment confirmations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerName rdf:type rdf:Property ;
    rdfs:label 'Customer Name' ;
    rdfs:comment 'Full name of the customer who will pick up the order, used for identity verification at the pickup counter.' ;
    rdfs:domain ind:BopisAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPhone rdf:type rdf:Property ;
    rdfs:label 'Customer Phone' ;
    rdfs:comment 'Contact phone number for the customer, used for pickup notifications and communication.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiration Timestamp' ;
    rdfs:comment 'Timestamp when the appointment expired due to customer not picking up within the allowed window.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:idVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Id Verification Method' ;
    rdfs:comment 'Method used to verify customer identity at pickup: drivers_license, passport, order_confirmation (email/SMS), photo_id, none (no verification required).' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingSpotNumber rdf:type rdf:Property ;
    rdfs:label 'Parking Spot Number' ;
    rdfs:comment 'Designated parking spot number for curbside pickup where the customer is waiting.' ;
    rdfs:domain ind:BopisAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupInstructions rdf:type rdf:Property ;
    rdfs:label 'Pickup Instructions' ;
    rdfs:comment 'Special instructions provided by the customer for pickup (e.g., curbside delivery, vehicle description, accessibility needs).' ;
    rdfs:domain ind:BopisAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupLocationCode rdf:type rdf:Property ;
    rdfs:label 'Pickup Location Code' ;
    rdfs:comment 'Code identifying the specific pickup area within the store (e.g., customer service desk, dedicated BOPIS counter, curbside zone).' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readyForPickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ready For Pickup Timestamp' ;
    rdfs:comment 'Timestamp when the order was marked as ready for customer pickup by store associates or fulfillment system.' ;
    rdfs:domain ind:BopisAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:readyNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Ready Notification Sent Flag' ;
    rdfs:comment 'Boolean flag indicating whether the ready-for-pickup notification (email/SMS) was successfully sent to the customer.' ;
    rdfs:domain ind:BopisAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:readyNotificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ready Notification Sent Timestamp' ;
    rdfs:comment 'Timestamp when the ready-for-pickup notification was sent to the customer.' ;
    rdfs:domain ind:BopisAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledTimeSlotEnd rdf:type rdf:Property ;
    rdfs:label 'Scheduled Time Slot End' ;
    rdfs:comment 'End timestamp of the customer-selected pickup time window.' ;
    rdfs:domain ind:BopisAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledTimeSlotStart rdf:type rdf:Property ;
    rdfs:label 'Scheduled Time Slot Start' ;
    rdfs:comment 'Start timestamp of the customer-selected pickup time window.' ;
    rdfs:domain ind:BopisAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Boolean flag indicating whether the BOPIS readiness SLA commitment was met (true) or missed (false).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetReadyMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Ready Minutes' ;
    rdfs:comment 'Target time in minutes from order placement to ready-for-pickup status, as committed in the BOPIS service level agreement.' ;
    rdfs:domain ind:BopisAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleDescription rdf:type rdf:Property ;
    rdfs:label 'Vehicle Description' ;
    rdfs:comment 'Description of the customers vehicle for curbside pickup identification (make, model, color, license plate).' ;
    rdfs:domain ind:BopisAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Wait Time Minutes' ;
    rdfs:comment 'Time in minutes the customer waited from check-in to actual pickup, used for customer experience KPI tracking.' ;
    rdfs:domain ind:BopisAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Primary key for carrier' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:apiIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Api Integration Flag' ;
    rdfs:comment 'Indicates whether the carrier provides API integration capabilities for real-time rate shopping, booking, and tracking.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRatePerLb rdf:type rdf:Property ;
    rdfs:label 'Base Rate Per Lb' ;
    rdfs:comment 'Negotiated base shipping rate per pound for standard service level, before surcharges and adjustments.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bopisReadyFlag rdf:type rdf:Property ;
    rdfs:label 'Bopis Ready Flag' ;
    rdfs:comment 'Indicates whether the carrier supports BOPIS fulfillment logistics including store-to-customer handoff coordination.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Code' ;
    rdfs:comment 'Internal short code or abbreviation used to identify the carrier in operational systems.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'The legal business name of the carrier or third-party logistics (3PL) provider.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Status' ;
    rdfs:comment 'Current operational status of the carrier relationship indicating whether the carrier is available for shipment assignment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Classification of the carrier based on service model: parcel (small package), LTL (Less Than Truckload), FTL (Full Truckload), last-mile delivery, same-day delivery, or third-party logistics (3PL) provider.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address of the primary carrier contact for operational communication and escalations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the primary account representative or contact person at the carrier for operational coordination and issue resolution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number of the primary carrier contact for urgent operational issues and coordination.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Date when the carrier service contract expires or is scheduled for renewal.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Date when the carrier service contract or agreement became effective.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cutoffTimeLocal rdf:type rdf:Property ;
    rdfs:label 'Cutoff Time Local' ;
    rdfs:comment 'Daily cutoff time in local warehouse time zone (HH:MM format) by which shipments must be tendered to the carrier to qualify for same-day pickup and service level commitment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionalWeightFactor rdf:type rdf:Property ;
    rdfs:label 'Dimensional Weight Factor' ;
    rdfs:comment 'Divisor used to calculate dimensional weight from package dimensions (length x width x height / factor). Common values are 139 for domestic and 166 for international.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Capable Flag' ;
    rdfs:comment 'Indicates whether the carrier supports Electronic Data Interchange (EDI) for automated shipment booking, tracking, and invoicing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extendedAreaSurcharge rdf:type rdf:Property ;
    rdfs:label 'Extended Area Surcharge' ;
    rdfs:comment 'Additional fee charged for deliveries to remote or extended service areas beyond standard coverage zones.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargePercentage rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Percentage' ;
    rdfs:comment 'Current fuel surcharge percentage applied to base shipping rates, typically adjusted monthly based on fuel price indices.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Description of the geographic regions and countries where the carrier provides service coverage. May include restrictions or limitations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether the carrier is certified and authorized to transport hazardous materials under Department of Transportation (DOT) regulations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Flag' ;
    rdfs:comment 'Indicates whether the carrier offers shipment insurance or declared value coverage for high-value packages.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxHeightInches rdf:type rdf:Property ;
    rdfs:label 'Max Height Inches' ;
    rdfs:comment 'Maximum package height dimension in inches that the carrier will accept for shipment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxLengthInches rdf:type rdf:Property ;
    rdfs:label 'Max Length Inches' ;
    rdfs:comment 'Maximum package length dimension in inches that the carrier will accept for shipment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Max Weight Lbs' ;
    rdfs:comment 'Maximum package weight in pounds that the carrier will accept for shipment under standard service terms.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWidthInches rdf:type rdf:Property ;
    rdfs:label 'Max Width Inches' ;
    rdfs:comment 'Maximum package width dimension in inches that the carrier will accept for shipment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiatedDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Negotiated Discount Percentage' ;
    rdfs:comment 'Volume-based discount percentage negotiated off published carrier rates based on annual shipping commitment.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Rate Effective Date' ;
    rdfs:comment 'Date when the current rate card and pricing terms became effective.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Rate Expiry Date' ;
    rdfs:comment 'Date when the current rate card expires and requires renegotiation or renewal.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:residentialDeliverySurcharge rdf:type rdf:Property ;
    rdfs:label 'Residential Delivery Surcharge' ;
    rdfs:comment 'Additional flat fee charged for deliveries to residential addresses versus commercial addresses.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scacCode rdf:type rdf:Property ;
    rdfs:label 'Scac Code' ;
    rdfs:comment 'Standard Carrier Alpha Code assigned by the National Motor Freight Traffic Association for freight carriers in North America.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelGround rdf:type rdf:Property ;
    rdfs:label 'Service Level Ground' ;
    rdfs:comment 'Indicates whether the carrier offers standard ground shipping service.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLevelOvernight rdf:type rdf:Property ;
    rdfs:label 'Service Level Overnight' ;
    rdfs:comment 'Indicates whether the carrier offers overnight express shipping service.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLevelSameDay rdf:type rdf:Property ;
    rdfs:label 'Service Level Same Day' ;
    rdfs:comment 'Indicates whether the carrier offers same-day delivery service for local or regional shipments.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLevelTwoDay rdf:type rdf:Property ;
    rdfs:label 'Service Level Two Day' ;
    rdfs:comment 'Indicates whether the carrier offers two-day expedited shipping service.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Required Flag' ;
    rdfs:comment 'Indicates whether the carrier requires recipient signature upon delivery as a standard service feature.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trackingCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Tracking Capability Flag' ;
    rdfs:comment 'Indicates whether the carrier provides real-time shipment tracking and visibility capabilities.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transitDaysZone1 rdf:type rdf:Property ;
    rdfs:label 'Transit Days Zone 1' ;
    rdfs:comment 'Standard number of business days for ground shipment delivery to Zone 1 (typically local or adjacent regions).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitDaysZone2 rdf:type rdf:Property ;
    rdfs:label 'Transit Days Zone 2' ;
    rdfs:comment 'Standard number of business days for ground shipment delivery to Zone 2 (typically regional).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitDaysZone3 rdf:type rdf:Property ;
    rdfs:label 'Transit Days Zone 3' ;
    rdfs:comment 'Standard number of business days for ground shipment delivery to Zone 3 (typically extended regional).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierRateId rdf:type rdf:Property ;
    rdfs:label 'Carrier Rate Id' ;
    rdfs:comment 'Unique identifier for the carrier rate record. Primary key.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierServiceId rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.carrier_service. Business justification: carrier_rate has carrier_id FK and denormalized service_level/service_code columns, but no FK to carrier_service. Business reality: a rate is pricing for a specific carrier_service offering. Adding ca' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierService .

ind:baseRateAmount rdf:type rdf:Property ;
    rdfs:label 'Base Rate Amount' ;
    rdfs:comment 'Base shipping rate amount before surcharges and discounts. This is the starting point for freight cost calculation.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the shipment destination (e.g., USA, CAN, MEX).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code' ;
    rdfs:comment 'Postal code of the shipment destination (customer delivery address).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date when this carrier rate expires and is no longer valid. Null indicates an open-ended rate with no expiration.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fuelSurchargeRate rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Rate' ;
    rdfs:comment 'Fuel surcharge rate expressed as a decimal percentage (e.g., 0.1250 for 12.50%). Applied to base rate to account for fuel cost fluctuations.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHazmatEligible rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Eligible' ;
    rdfs:comment 'Flag indicating whether this carrier service level can handle hazardous materials shipments under applicable regulations.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInternational rdf:type rdf:Property ;
    rdfs:label 'Is International' ;
    rdfs:comment 'Flag indicating whether this rate applies to international shipments (cross-border) or domestic shipments within a single country.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge Amount' ;
    rdfs:comment 'Minimum shipping charge that will be applied regardless of calculated rate. Ensures carrier covers base handling costs.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the shipment origin (e.g., USA, CAN, MEX).' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originPostalCode rdf:type rdf:Property ;
    rdfs:label 'Origin Postal Code' ;
    rdfs:comment 'Postal code of the shipment origin location (fulfillment center, store, or warehouse).' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oversizedPackageSurcharge rdf:type rdf:Property ;
    rdfs:label 'Oversized Package Surcharge' ;
    rdfs:comment 'Additional fee for packages exceeding standard size limits (length + girth thresholds vary by carrier).' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratePerKg rdf:type rdf:Property ;
    rdfs:label 'Rate Per Kg' ;
    rdfs:comment 'Incremental rate charged per kilogram above the weight break minimum. Used for weight-based pricing calculations.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateSource rdf:type rdf:Property ;
    rdfs:label 'Rate Source' ;
    rdfs:comment 'Source system or method by which this rate was obtained: carrier API (real-time), manual entry, contract upload, rate shopping engine, or third-party logistics provider.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of the carrier rate: active (in use), inactive (not in use), pending (awaiting activation), expired (past expiry date), suspended (temporarily disabled).' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the rate: base (standard published rate), negotiated (custom contract rate), published (carrier list price), spot (one-time rate), or contract (long-term agreement rate).' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateVersion rdf:type rdf:Property ;
    rdfs:label 'Rate Version' ;
    rdfs:comment 'Version number of this rate record. Incremented when rate terms are updated, enabling rate history tracking and audit trails.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateZone rdf:type rdf:Property ;
    rdfs:label 'Rate Zone' ;
    rdfs:comment 'Geographic zone or region for which this rate applies. Carriers use zone-based pricing to calculate shipping costs based on origin and destination distance.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saturdayDeliverySurcharge rdf:type rdf:Property ;
    rdfs:label 'Saturday Delivery Surcharge' ;
    rdfs:comment 'Additional fee for Saturday delivery service, which is outside standard weekday delivery schedules.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Type of shipping service offered by the carrier (e.g., ground, express, overnight, two-day, economy, priority, standard). [ENUM-REF-CANDIDATE: ground|express|overnight|two_day|economy|priority|standard — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureRequiredSurcharge rdf:type rdf:Property ;
    rdfs:label 'Signature Required Surcharge' ;
    rdfs:comment 'Additional fee charged when signature confirmation is required upon delivery.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitDays rdf:type rdf:Property ;
    rdfs:label 'Transit Days' ;
    rdfs:comment 'Expected number of business days for shipment transit from origin to destination using this service level.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightBreakMaxKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Max Kg' ;
    rdfs:comment 'Maximum weight in kilograms for this rate tier. Null indicates no upper limit for the highest tier.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBreakMinKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Min Kg' ;
    rdfs:comment 'Minimum weight in kilograms for this rate tier. Carriers use weight breaks to define tiered pricing (e.g., 0-5kg, 5-10kg, 10-20kg).' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseRate rdf:type rdf:Property ;
    rdfs:label 'Base Rate' ;
    rdfs:comment 'Base shipping rate for this carrier service in the default currency. Used as starting point for total shipping cost calculation before surcharges and discounts.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bopisEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Bopis Eligible Flag' ;
    rdfs:comment 'Indicates whether this carrier service is eligible for BOPIS (Buy Online Pick Up In Store) fulfillment scenarios. Used in omnichannel order routing.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carbonNeutralFlag rdf:type rdf:Property ;
    rdfs:label 'Carbon Neutral Flag' ;
    rdfs:comment 'Indicates whether this carrier service is certified as carbon-neutral or participates in carbon offset programs. Used in sustainability reporting and eco-conscious customer service selection.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cutoffTime rdf:type rdf:Property ;
    rdfs:label 'Cutoff Time' ;
    rdfs:comment 'Daily cutoff time (HH:MM format, 24-hour) by which orders must be placed to qualify for same-day shipment with this service. Critical for order routing and fulfillment scheduling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cutoffTimezone rdf:type rdf:Property ;
    rdfs:label 'Cutoff Timezone' ;
    rdfs:comment 'Timezone identifier for the cutoff time (e.g., EST, PST, CST, UTC). Ensures accurate cutoff enforcement across distributed fulfillment centers.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction Type' ;
    rdfs:comment 'Type of geographic restriction applied to this carrier service (e.g., domestic only, specific regions, postal code whitelist/blacklist). Used in carrier eligibility filtering.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Eligible Flag' ;
    rdfs:comment 'Indicates whether this carrier service is certified to transport hazardous materials. Used in carrier selection for restricted product categories.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holidayDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Holiday Delivery Flag' ;
    rdfs:comment 'Indicates whether this carrier service supports delivery on recognized holidays. Used in delivery date estimation and peak season planning.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Included Flag' ;
    rdfs:comment 'Indicates whether shipment insurance is automatically included with this carrier service. Affects cost calculations and risk management decisions.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceMaxValue rdf:type rdf:Property ;
    rdfs:label 'Insurance Max Value' ;
    rdfs:comment 'Maximum insured value (in base currency) covered by this carrier service. Orders exceeding this value may require additional insurance or alternative services.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internationalEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'International Eligible Flag' ;
    rdfs:comment 'Indicates whether this carrier service supports international cross-border shipments. Used in carrier selection for international orders.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxGirthCm rdf:type rdf:Property ;
    rdfs:label 'Max Girth Cm' ;
    rdfs:comment 'Maximum package girth (length + 2×width + 2×height) in centimeters. Some carriers enforce combined dimensional limits beyond individual dimension constraints.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxHeightCm rdf:type rdf:Property ;
    rdfs:label 'Max Height Cm' ;
    rdfs:comment 'Maximum package height dimension in centimeters accepted by this carrier service. Used in dimensional eligibility checks during carrier selection.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxLengthCm rdf:type rdf:Property ;
    rdfs:label 'Max Length Cm' ;
    rdfs:comment 'Maximum package length dimension in centimeters accepted by this carrier service. Used in dimensional eligibility checks during carrier selection.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Weight Kg' ;
    rdfs:comment 'Maximum shipment weight in kilograms that this carrier service can handle. Used in carrier selection logic to filter eligible services based on order weight.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWidthCm rdf:type rdf:Property ;
    rdfs:label 'Max Width Cm' ;
    rdfs:comment 'Maximum package width dimension in centimeters accepted by this carrier service. Used in dimensional eligibility checks during carrier selection.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perishableEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Perishable Eligible Flag' ;
    rdfs:comment 'Indicates whether this carrier service supports temperature-controlled or time-sensitive perishable goods (e.g., groceries, fresh food). Used in carrier selection for perishable SKUs.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedCountries rdf:type rdf:Property ;
    rdfs:label 'Restricted Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this carrier service is NOT available. Used in international order routing and carrier selection.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedPostalCodes rdf:type rdf:Property ;
    rdfs:label 'Restricted Postal Codes' ;
    rdfs:comment 'Comma-separated list of postal codes or postal code prefixes where this carrier service is NOT available. Used in carrier eligibility filtering during order routing.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saturdayDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Saturday Delivery Flag' ;
    rdfs:comment 'Indicates whether this carrier service supports Saturday delivery. Used in delivery date estimation and customer service selection.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the carrier service offering (e.g., GROUND, 2DAY, OVERNIGHT, SAMEDAY). Used in carrier selection logic and order routing.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceName rdf:type rdf:Property ;
    rdfs:label 'Service Name' ;
    rdfs:comment 'Human-readable name of the carrier service offering (e.g., Ground Shipping, Two-Day Express, Overnight Priority, Same-Day Delivery).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'Current operational status of the carrier service. Determines availability for order routing and fulfillment selection.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Classification of the carrier service by delivery speed and priority level. Used for service tier segmentation and customer selection.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipFromStoreEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Ship From Store Eligible Flag' ;
    rdfs:comment 'Indicates whether this carrier service is eligible for SFS (Ship From Store) fulfillment scenarios. Used in omnichannel order routing and inventory optimization.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaDeliveryGuaranteeFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Delivery Guarantee Flag' ;
    rdfs:comment 'Indicates whether this carrier service includes a contractual SLA (Service Level Agreement) delivery guarantee with refund or credit for late deliveries. Used in service selection and customer promise management.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sundayDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Sunday Delivery Flag' ;
    rdfs:comment 'Indicates whether this carrier service supports Sunday delivery. Used in delivery date estimation and customer service selection.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surchargeTypes rdf:type rdf:Property ;
    rdfs:label 'Surcharge Types' ;
    rdfs:comment 'Comma-separated list of surcharge types applicable to this carrier service (e.g., fuel_surcharge, residential_delivery, remote_area, oversized, peak_season). Used in total shipping cost calculation.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitDaysMax rdf:type rdf:Property ;
    rdfs:label 'Transit Days Max' ;
    rdfs:comment 'Maximum number of business days required for delivery from shipment date. Used in delivery date estimation and SLA (Service Level Agreement) calculations.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitDaysMin rdf:type rdf:Property ;
    rdfs:label 'Transit Days Min' ;
    rdfs:comment 'Minimum number of business days required for delivery from shipment date. Used in delivery date estimation and SLA (Service Level Agreement) calculations.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryRouteId rdf:type rdf:Property ;
    rdfs:label 'Delivery Route Id' ;
    rdfs:comment 'Unique identifier for the delivery route. Primary key.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryRoute .

ind:outboundShipmentId rdf:type rdf:Property ;
    rdfs:label 'Outbound Shipment Id' ;
    rdfs:comment 'Foreign key linking to supplychain.outbound_shipment. Business justification: Last-mile delivery routes consolidate shipments, some originating from DC outbound operations (store replenishment deliveries). Enables route optimization with DC shipment data and supports consolidat' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundShipment .

ind:primaryDeliveryAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Delivery Associate Id' ;
    rdfs:comment 'Identifier of the driver or delivery associate assigned to execute this route.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:actualDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Time' ;
    rdfs:comment 'Actual timestamp when the driver departed from the fulfillment center or dark store to begin the route.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Actual Distance Km' ;
    rdfs:comment 'Actual distance traveled on the route in kilometers, captured from vehicle telematics or GPS tracking.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Minutes' ;
    rdfs:comment 'Actual total duration of the route in minutes, from departure to return.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualReturnTime rdf:type rdf:Property ;
    rdfs:label 'Actual Return Time' ;
    rdfs:comment 'Actual timestamp when the driver returned to the fulfillment center after completing the route.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completedStops rdf:type rdf:Property ;
    rdfs:label 'Completed Stops' ;
    rdfs:comment 'Number of delivery stops successfully completed on this route.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispatchTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatch Timestamp' ;
    rdfs:comment 'Timestamp when this route was dispatched and assigned to the driver.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Estimated total duration of the route in minutes, including drive time and stop time, calculated by the route optimization algorithm.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failedStops rdf:type rdf:Property ;
    rdfs:label 'Failed Stops' ;
    rdfs:comment 'Number of delivery stops that failed or could not be completed on this route.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optimizationAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Optimization Algorithm' ;
    rdfs:comment 'Name or identifier of the route optimization algorithm or system used to plan this route (e.g., Blue Yonder, internal heuristic, third-party optimizer).' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizationVersion rdf:type rdf:Property ;
    rdfs:label 'Optimization Version' ;
    rdfs:comment 'Version or configuration identifier of the optimization algorithm used, for audit and performance tracking.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Time' ;
    rdfs:comment 'Scheduled timestamp when the driver is expected to depart from the fulfillment center or dark store to begin the route.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedReturnTime rdf:type rdf:Property ;
    rdfs:label 'Planned Return Time' ;
    rdfs:comment 'Scheduled timestamp when the driver is expected to return to the fulfillment center after completing all deliveries.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:routeDate rdf:type rdf:Property ;
    rdfs:label 'Route Date' ;
    rdfs:comment 'The scheduled date for this delivery route execution.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:routeName rdf:type rdf:Property ;
    rdfs:label 'Route Name' ;
    rdfs:comment 'Human-readable name or label for the route, often including geographic area or zone identifier.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeNotes rdf:type rdf:Property ;
    rdfs:label 'Route Notes' ;
    rdfs:comment 'Free-text notes or special instructions for the driver or dispatcher regarding this route (e.g., traffic alerts, access restrictions, customer preferences).' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeNumber rdf:type rdf:Property ;
    rdfs:label 'Route Number' ;
    rdfs:comment 'Business identifier for the delivery route, externally visible to drivers and operations teams.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routePriority rdf:type rdf:Property ;
    rdfs:label 'Route Priority' ;
    rdfs:comment 'Priority level assigned to this route for resource allocation and dispatch sequencing.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeStatus rdf:type rdf:Property ;
    rdfs:label 'Route Status' ;
    rdfs:comment 'Current lifecycle status of the delivery route in the fulfillment workflow.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of the route based on fulfillment model: last-mile delivery, Ship-from-Store (SFS), Buy Online Pick Up In Store (BOPIS), Reserve Online Pick Up In Store (ROPIS), or dark store fulfillment.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeZone rdf:type rdf:Property ;
    rdfs:label 'Route Zone' ;
    rdfs:comment 'Geographic zone or delivery area code covered by this route, used for territory management and planning.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether this route requires temperature-controlled transport for perishable or temperature-sensitive goods.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Total Distance Km' ;
    rdfs:comment 'Total planned distance of the route in kilometers, calculated by the route optimization algorithm.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPackages rdf:type rdf:Property ;
    rdfs:label 'Total Packages' ;
    rdfs:comment 'Total number of packages or parcels loaded on this route for delivery.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStops rdf:type rdf:Property ;
    rdfs:label 'Total Stops' ;
    rdfs:comment 'Total number of delivery stop addresses planned on this route.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Volume M3' ;
    rdfs:comment 'Total volume of all packages on this route in cubic meters, used for vehicle capacity planning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Total weight of all packages on this route in kilograms, used for vehicle capacity planning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleCode rdf:type rdf:Property ;
    rdfs:label 'Vehicle Code' ;
    rdfs:comment 'Identifier of the delivery vehicle assigned to this route.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleType rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type' ;
    rdfs:comment 'Type or class of vehicle used for this delivery route, impacting capacity and route planning.' ;
    rdfs:domain ind:DeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStopId rdf:type rdf:Property ;
    rdfs:label 'Delivery Stop Id' ;
    rdfs:comment 'Unique identifier for the delivery stop. Primary key for this entity.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outboundOrderId rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Id' ;
    rdfs:comment 'Foreign key linking to supplychain.outbound_order. Business justification: Store delivery stops fulfill DC outbound orders (store replenishment). Links last-mile delivery execution to upstream supply chain order, enabling store receipt confirmation and DC-to-store delivery p' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundOrder .

ind:accessInstructions rdf:type rdf:Property ;
    rdfs:label 'Access Instructions' ;
    rdfs:comment 'Special instructions for accessing the delivery location, such as gate codes, building entry procedures, or parking information.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual date and time when the driver arrived at the delivery stop location.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Actual date and time when the driver departed from the delivery stop location after completing the delivery attempt.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualServiceTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Service Time Minutes' ;
    rdfs:comment 'Actual duration in minutes spent at the delivery stop from arrival to departure.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line1' ;
    rdfs:comment 'Primary street address line for the delivery location.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line2' ;
    rdfs:comment 'Secondary address line for apartment, suite, or unit number at the delivery location.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCity rdf:type rdf:Property ;
    rdfs:label 'Delivery City' ;
    rdfs:comment 'City name for the delivery address.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Completion Timestamp' ;
    rdfs:comment 'Date and time when the delivery was successfully completed and proof of delivery was captured.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the delivery address.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLatitude rdf:type rdf:Property ;
    rdfs:label 'Delivery Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the delivery address, used for route optimization and GPS navigation.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryLocationType rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Type' ;
    rdfs:comment 'Specific location at the delivery address where the package was left or handed off. [ENUM-REF-CANDIDATE: front_door|back_door|side_door|mailbox|parcel_locker|reception_desk|neighbor|garage|porch — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLongitude rdf:type rdf:Property ;
    rdfs:label 'Delivery Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the delivery address, used for route optimization and GPS navigation.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryOutcome rdf:type rdf:Property ;
    rdfs:label 'Delivery Outcome' ;
    rdfs:comment 'Final result of the delivery attempt at this stop, indicating whether the delivery was successful or the reason for failure. [ENUM-REF-CANDIDATE: delivered|attempted_no_answer|attempted_access_issue|refused|damaged|address_not_found|returned_to_sender — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the delivery address, used for route optimization and zone assignment.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStateProvince rdf:type rdf:Property ;
    rdfs:label 'Delivery State Province' ;
    rdfs:comment 'State or province code for the delivery address.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverNotes rdf:type rdf:Property ;
    rdfs:label 'Driver Notes' ;
    rdfs:comment 'Free-text notes entered by the driver regarding the delivery attempt, including any issues encountered or special circumstances.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedServiceTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Service Time Minutes' ;
    rdfs:comment 'Planned duration in minutes for completing the delivery at this stop, used for route planning and optimization.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedArrivalWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Window End' ;
    rdfs:comment 'End of the scheduled time window when the driver is expected to arrive at this stop.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedArrivalWindowStart rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Window Start' ;
    rdfs:comment 'Beginning of the scheduled time window when the driver is expected to arrive at this stop.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:podCaptureMethod rdf:type rdf:Property ;
    rdfs:label 'Pod Capture Method' ;
    rdfs:comment 'Technology or device used to capture the proof of delivery evidence.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podCaptureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pod Capture Timestamp' ;
    rdfs:comment 'Date and time when the proof of delivery evidence was captured by the driver or system.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:podGpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Pod Gps Latitude' ;
    rdfs:comment 'GPS latitude coordinate captured at the moment of delivery completion, used for delivery location verification.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:podGpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Pod Gps Longitude' ;
    rdfs:comment 'GPS longitude coordinate captured at the moment of delivery completion, used for delivery location verification.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:podPhotoImageUrl rdf:type rdf:Property ;
    rdfs:label 'Pod Photo Image Url' ;
    rdfs:comment 'URL reference to the stored photograph of the delivered package at the delivery location.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podPinCode rdf:type rdf:Property ;
    rdfs:label 'Pod Pin Code' ;
    rdfs:comment 'Personal identification number provided by the recipient to confirm delivery, used for contactless delivery verification.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podSignatureImageUrl rdf:type rdf:Property ;
    rdfs:label 'Pod Signature Image Url' ;
    rdfs:comment 'URL reference to the stored digital signature image captured as proof of delivery.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:podVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Pod Verification Status' ;
    rdfs:comment 'Status indicating whether the proof of delivery evidence has been verified and accepted for compliance and dispute resolution purposes.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'Full name of the person receiving the delivery, may differ from the ordering customer.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientPhone rdf:type rdf:Property ;
    rdfs:label 'Recipient Phone' ;
    rdfs:comment 'Contact phone number for the recipient at the delivery location, used for delivery notifications and coordination.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Stop Sequence Number' ;
    rdfs:comment 'Sequential position of this stop within the delivery route, used for route optimization and driver navigation.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stopStatus rdf:type rdf:Property ;
    rdfs:label 'Stop Status' ;
    rdfs:comment 'Current lifecycle status of the delivery stop indicating progress through the last-mile delivery workflow. [ENUM-REF-CANDIDATE: scheduled|in_transit|arrived|delivered|attempted|failed|cancelled|returned_to_sender — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopType rdf:type rdf:Property ;
    rdfs:label 'Stop Type' ;
    rdfs:comment 'Classification of the delivery stop type indicating the nature of the fulfillment activity.' ;
    rdfs:domain ind:DeliveryStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dropShipOrderId rdf:type rdf:Property ;
    rdfs:label 'Drop Ship Order Id' ;
    rdfs:comment 'Primary key for drop_ship_order' ;
    rdfs:domain ind:DropShipOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costPriceId rdf:type rdf:Property ;
    rdfs:label 'Cost Price Id' ;
    rdfs:comment 'Foreign key linking to pricing.cost_price. Business justification: Drop ship orders track vendor cost for margin analysis, profitability reporting, and vendor performance evaluation. Currently has denormalized unit_cost/extended_cost; linking to cost_price provides f' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostPrice .

ind:orderLineId rdf:type rdf:Property ;
    rdfs:label 'Order Line Id' ;
    rdfs:comment 'Reference to the specific order line item being fulfilled via drop ship.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:vendorContactId rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Id' ;
    rdfs:comment 'Foreign key linking to supplier.vendor_contact. Business justification: Drop ship operations require designated vendor contact for order transmission, shipment coordination, exception resolution, and SLA escalation. Retail drop ship systems maintain contact assignments pe' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorContact .

ind:vendorContractId rdf:type rdf:Property ;
    rdfs:label 'Vendor Contract Id' ;
    rdfs:comment 'Foreign key linking to supplier.vendor_contract. Business justification: Drop ship orders execute under specific vendor contracts defining pricing, terms, SLAs, and chargeback provisions. Contract reference required for compliance verification, SLA monitoring, dispute reso' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorContract .

ind:vendorItemId rdf:type rdf:Property ;
    rdfs:label 'Vendor Item Id' ;
    rdfs:comment 'Foreign key linking to supplier.vendor_item. Business justification: Drop ship PO generation requires vendor item number, pack configuration, and vendor-specific cost from vendor item master. Critical for accurate vendor order transmission, invoice reconciliation, and ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorItem .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Date the customer actually received the drop ship delivery. Confirmed via carrier proof of delivery.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'Date the vendor actually shipped the order to the customer. Used for SLA compliance measurement.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dropShipOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Drop Ship Order Number' ;
    rdfs:comment 'Unique business identifier for the drop ship order, used for external communication and tracking.' ;
    rdfs:domain ind:DropShipOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dropShipStatus rdf:type rdf:Property ;
    rdfs:label 'Drop Ship Status' ;
    rdfs:comment 'Current lifecycle status of the drop ship order. Tracks progression from vendor notification through final delivery. [ENUM-REF-CANDIDATE: sent_to_vendor|acknowledged|in_progress|shipped|delivered|cancelled|exception|returned — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DropShipOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'Expected date the customer will receive the drop ship delivery.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Standardized code identifying the type of exception or issue encountered during drop ship fulfillment (e.g., out of stock, address invalid, delivery failed).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Detailed explanation of the exception or issue that occurred during drop ship processing or delivery.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gtin rdf:type rdf:Property ;
    rdfs:label 'Gtin' ;
    rdfs:comment 'Global standard identifier for the trade item being drop shipped.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedShipDate rdf:type rdf:Property ;
    rdfs:label 'Promised Ship Date' ;
    rdfs:comment 'Date the vendor committed to ship the order to the customer. Used for SLA tracking and customer expectation management.' ;
    rdfs:domain ind:DropShipOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'Number of units requested from the vendor for drop ship fulfillment.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityShipped rdf:type rdf:Property ;
    rdfs:label 'Quantity Shipped' ;
    rdfs:comment 'Actual number of units shipped by the vendor to the customer.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentToVendorTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent To Vendor Timestamp' ;
    rdfs:comment 'Date and time the drop ship request was transmitted to the vendor via EDI, API, or portal.' ;
    rdfs:domain ind:DropShipOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shipToAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Ship To Address Line1' ;
    rdfs:comment 'Primary street address line for the customer delivery location.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Ship To Address Line2' ;
    rdfs:comment 'Secondary address line (apartment, suite, building) for the customer delivery location.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToCity rdf:type rdf:Property ;
    rdfs:label 'Ship To City' ;
    rdfs:comment 'City name for the customer delivery location.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToCountryCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the customer delivery location.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToEmail rdf:type rdf:Property ;
    rdfs:label 'Ship To Email' ;
    rdfs:comment 'Email address for delivery notifications and tracking updates.' ;
    rdfs:domain ind:DropShipOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToName rdf:type rdf:Property ;
    rdfs:label 'Ship To Name' ;
    rdfs:comment 'Name of the recipient for the drop ship delivery.' ;
    rdfs:domain ind:DropShipOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToPhone rdf:type rdf:Property ;
    rdfs:label 'Ship To Phone' ;
    rdfs:comment 'Contact phone number for delivery coordination and customer communication.' ;
    rdfs:domain ind:DropShipOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToPostalCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the customer delivery location.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToStateProvince rdf:type rdf:Property ;
    rdfs:label 'Ship To State Province' ;
    rdfs:comment 'State or province code for the customer delivery location.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorAcknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Vendor Acknowledged Timestamp' ;
    rdfs:comment 'Date and time the vendor confirmed receipt and acceptance of the drop ship order.' ;
    rdfs:domain ind:DropShipOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vendorOrderReference rdf:type rdf:Property ;
    rdfs:label 'Vendor Order Reference' ;
    rdfs:comment 'Vendor\'s internal order reference or confirmation number for this drop ship request.' ;
    rdfs:domain ind:DropShipOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPoNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Po Number' ;
    rdfs:comment 'Purchase order number sent to the vendor to authorize the drop ship fulfillment. Used for vendor reconciliation and invoice matching.' ;
    rdfs:domain ind:DropShipOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorSlaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Sla Compliance Flag' ;
    rdfs:comment 'Indicates whether the vendor met the promised ship date commitment. True if shipped on or before promised date, false otherwise.' ;
    rdfs:domain ind:DropShipOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Tracking Number' ;
    rdfs:comment 'Carrier tracking number provided by the vendor for shipment visibility and customer self-service tracking.' ;
    rdfs:domain ind:DropShipOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionId rdf:type rdf:Property ;
    rdfs:label 'Exception Id' ;
    rdfs:comment 'Primary key for exception' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfillmentLineId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Line Id' ;
    rdfs:comment 'Reference to the specific fulfillment order line item affected by this exception. Nullable if exception applies to entire order.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentLine .

ind:customerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notified Flag' ;
    rdfs:comment 'Indicates whether the customer was notified about the exception and its impact on their order.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectedAtStage rdf:type rdf:Property ;
    rdfs:label 'Detected At Stage' ;
    rdfs:comment 'Fulfillment process stage where the exception was identified. [ENUM-REF-CANDIDATE: picking|packing|quality_check|staging|loading|carrier_handoff|in_transit|delivery — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionNumber rdf:type rdf:Property ;
    rdfs:label 'Exception Number' ;
    rdfs:comment 'Human-readable business identifier for the exception, used for tracking and communication across fulfillment teams.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Status' ;
    rdfs:comment 'Current lifecycle state of the exception in the resolution workflow.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exception Timestamp' ;
    rdfs:comment 'Date and time when the exception was first detected or logged in the fulfillment system.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionType rdf:type rdf:Property ;
    rdfs:label 'Exception Type' ;
    rdfs:comment 'Category of fulfillment exception encountered. Classifies the nature of the operational disruption. [ENUM-REF-CANDIDATE: out_of_stock_at_pick|damaged_item|mispick|carrier_pickup_missed|address_validation_failure|delivery_attempt_failure|item_not_found|quantity_shortage|quality_issue|packaging_failure|label_printing_error|system_error — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerType rdf:type rdf:Property ;
    rdfs:label 'Owner Type' ;
    rdfs:comment 'Role or system component responsible for the exception occurrence or resolution. [ENUM-REF-CANDIDATE: picker|packer|quality_inspector|carrier|system|supervisor|customer_service — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAffected rdf:type rdf:Property ;
    rdfs:label 'Quantity Affected' ;
    rdfs:comment 'Number of units impacted by the exception. Relevant for quantity shortages, damaged items, or mispicks.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Corrective action taken or planned to resolve the exception. [ENUM-REF-CANDIDATE: substitute_item|cancel_line|reroute_order|reschedule_delivery|issue_refund|contact_customer|escalate_to_supervisor|reprocess — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetResolutionMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Resolution Minutes' ;
    rdfs:comment 'Target time in minutes within which this exception type should be resolved per SLA policy.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Shipment tracking number associated with the exception. Applicable for in-transit or delivery exceptions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingUnitId rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Id' ;
    rdfs:comment 'Identifier of the shipping carton or container into which this line was packed. Links line items to physical shipment packages.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HandlingUnit .

ind:outboundOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Line Id' ;
    rdfs:comment 'Foreign key linking to supplychain.outbound_order_line. Business justification: Line-level linkage for DC-to-store replenishment. Each fulfillment_line executing store replenishment corresponds to outbound_order_line in DC system. Critical for SKU-level reconciliation and invento' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundOrderLine .

ind:primaryFulfillmentAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Fulfillment Associate Id' ;
    rdfs:comment 'Identifier of the warehouse associate who picked this line. Used for productivity tracking and quality accountability.' ;
    rdfs:domain ind:FulfillmentLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:extendedCost rdf:type rdf:Property ;
    rdfs:label 'Extended Cost' ;
    rdfs:comment 'Total cost for this line (unit cost × quantity shipped). Represents total COGS for the fulfilled quantity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentSourceType rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Source Type' ;
    rdfs:comment 'Type of fulfillment location from which this line was fulfilled (distribution center, store, dark store, vendor direct, third-party logistics). Enables omnichannel fulfillment analysis.' ;
    rdfs:domain ind:FulfillmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current fulfillment status of this line item. Tracks progression through the fulfillment workflow from allocation to shipment. [ENUM-REF-CANDIDATE: pending|allocated|picked|packed|shipped|cancelled|exception — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Manufacturing lot or batch number of the picked inventory. Critical for traceability, recalls, and expiry management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalSku rdf:type rdf:Property ;
    rdfs:label 'Original Sku' ;
    rdfs:comment 'The originally ordered SKU if this line is a substitution. Null if no substitution occurred. Enables tracking of substitution patterns and customer acceptance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Timestamp' ;
    rdfs:comment 'Date and time when this line was packed into a shipping container. Used for throughput analysis and bottleneck identification.' ;
    rdfs:domain ind:FulfillmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickLocation rdf:type rdf:Property ;
    rdfs:label 'Pick Location' ;
    rdfs:comment 'The warehouse location (aisle, bin, shelf) from which this item was picked. Used for inventory tracking and pick path optimization.' ;
    rdfs:domain ind:FulfillmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Timestamp' ;
    rdfs:comment 'Date and time when this line was physically picked from inventory. Critical for cycle time analysis and SLA tracking.' ;
    rdfs:domain ind:FulfillmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantityAllocated rdf:type rdf:Property ;
    rdfs:label 'Quantity Allocated' ;
    rdfs:comment 'The quantity of inventory allocated or reserved for this fulfillment line. Represents inventory commitment before physical picking.' ;
    rdfs:domain ind:FulfillmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityCancelled rdf:type rdf:Property ;
    rdfs:label 'Quantity Cancelled' ;
    rdfs:comment 'The quantity cancelled and not fulfilled for this line. Represents unfulfilled demand due to stockouts, customer cancellation, or other exceptions.' ;
    rdfs:domain ind:FulfillmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityPacked rdf:type rdf:Property ;
    rdfs:label 'Quantity Packed' ;
    rdfs:comment 'The quantity successfully packed into shipping containers for this line. Represents items ready for shipment.' ;
    rdfs:domain ind:FulfillmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityPicked rdf:type rdf:Property ;
    rdfs:label 'Quantity Picked' ;
    rdfs:comment 'The actual quantity physically picked from inventory for this line. May differ from ordered quantity due to stockouts or picking errors.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ship Timestamp' ;
    rdfs:comment 'Date and time when this line was shipped from the facility. Marks completion of fulfillment execution and start of delivery.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:substitutionFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Flag' ;
    rdfs:comment 'Indicates whether this line represents a product substitution (true) or the originally ordered item (false). Used to track when alternative products are fulfilled.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:substitutionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Substitution Reason Code' ;
    rdfs:comment 'Reason code explaining why a substitution was made. Used for root cause analysis and inventory planning.' ;
    rdfs:domain ind:FulfillmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Cost of Goods Sold (COGS) per unit for this item. Used for inventory valuation and profitability analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Unit' ;
    rdfs:comment 'Unit of measure for the weight field (pounds, kilograms, etc.). Standardizes weight reporting across fulfillment operations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentOrderAssociateId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Associate Id' ;
    rdfs:comment 'Reference to the warehouse or store employee assigned to pick items for this fulfillment order. Used for productivity tracking.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:fulfillmentOrderPackerEmployeeAssociateId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Packer Employee Associate Id' ;
    rdfs:comment 'Reference to the employee who packed this fulfillment order. Used for quality control and productivity analysis.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:actualFulfillmentHours rdf:type rdf:Property ;
    rdfs:label 'Actual Fulfillment Hours' ;
    rdfs:comment 'The actual elapsed time in hours from fulfillment order creation to completion. Used for performance measurement against SLA.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentAssignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Assigned Timestamp' ;
    rdfs:comment 'Timestamp when the fulfillment order was assigned to a specific fulfillment node and became actionable.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfillmentCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Created Timestamp' ;
    rdfs:comment 'Timestamp when this fulfillment order record was created in the system. Marks the start of fulfillment processing.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfillmentOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Number' ;
    rdfs:comment 'Human-readable business identifier for the fulfillment order, used for tracking and communication across systems and with partners.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current lifecycle state of the fulfillment order in the pick-pack-ship workflow. [ENUM-REF-CANDIDATE: created|assigned|picking|picked|packing|packed|shipped|ready_for_pickup|completed|cancelled — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Timestamp when the customer placed the originating order. Used for SLA calculation and aging analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCount rdf:type rdf:Property ;
    rdfs:label 'Package Count' ;
    rdfs:comment 'Number of physical packages or parcels created for this fulfillment order. Orders may be split across multiple packages.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packingCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packing Completed Timestamp' ;
    rdfs:comment 'Timestamp when the fulfillment order was packed and ready for shipment or pickup.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packingSlipUrl rdf:type rdf:Property ;
    rdfs:label 'Packing Slip Url' ;
    rdfs:comment 'URL to the packing slip document that accompanies the shipment, listing order contents.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickingCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picking Completed Timestamp' ;
    rdfs:comment 'Timestamp when all items in the fulfillment order were successfully picked from inventory.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickingStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picking Started Timestamp' ;
    rdfs:comment 'Timestamp when the picking process began for this fulfillment order.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'The date communicated to the customer as the expected delivery or pickup availability date. Used for SLA tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shipped Timestamp' ;
    rdfs:comment 'Timestamp when the fulfillment order was handed off to the carrier for delivery.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shippingCostAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost Amount' ;
    rdfs:comment 'Actual cost incurred for carrier services to ship this fulfillment order. Used for profitability analysis and cost allocation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingLabelUrl rdf:type rdf:Property ;
    rdfs:label 'Shipping Label Url' ;
    rdfs:comment 'URL to the generated shipping label document for this fulfillment order, used by warehouse staff for package labeling.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Additional instructions for fulfillment staff regarding fragile items, gift wrapping, temperature control, or other special requirements.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalItemQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Item Quantity' ;
    rdfs:comment 'Total number of individual units across all line items in this fulfillment order. Used for capacity planning and picker productivity.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLineCount rdf:type rdf:Property ;
    rdfs:label 'Total Line Count' ;
    rdfs:comment 'Number of distinct SKU line items in this fulfillment order. Impacts picking complexity and time.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cubic Meters' ;
    rdfs:comment 'Total volumetric size of the fulfillment order in cubic meters, used for transportation planning and dimensional weight pricing.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date when the fulfillment node became operational and available for order fulfillment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bopisEnabled rdf:type rdf:Property ;
    rdfs:label 'Bopis Enabled' ;
    rdfs:comment 'Indicates whether this node supports Buy Online Pick Up In Store (BOPIS) fulfillment capability. True if customers can place online orders for in-store pickup at this location.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:curbsidePickupEnabled rdf:type rdf:Property ;
    rdfs:label 'Curbside Pickup Enabled' ;
    rdfs:comment 'Indicates whether this node supports curbside pickup fulfillment. True if customers can pick up orders without entering the building.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryZoneCoverageRadiusMiles rdf:type rdf:Property ;
    rdfs:label 'Delivery Zone Coverage Radius Miles' ;
    rdfs:comment 'Maximum delivery radius in miles from this fulfillment node for last-mile delivery services. Used for order routing and delivery zone assignment.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dockDoorCount rdf:type rdf:Property ;
    rdfs:label 'Dock Door Count' ;
    rdfs:comment 'Number of loading dock doors available at this fulfillment node for inbound receiving and outbound shipping. Key constraint for DC and cross-dock operations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified' ;
    rdfs:comment 'Indicates whether this node is certified to handle and store hazardous materials per OSHA and DOT regulations. True if hazmat fulfillment is permitted.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Name of the fulfillment operations manager responsible for this node. Business reference, not direct PII.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDayDeliveryEnabled rdf:type rdf:Property ;
    rdfs:label 'Next Day Delivery Enabled' ;
    rdfs:comment 'Indicates whether this node supports next-day delivery fulfillment. True if orders can be delivered to customers on the day following order placement.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Business identifier code for the fulfillment node, used across operational systems for node identification and routing logic. Typically alphanumeric, uppercase.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeType rdf:type rdf:Property ;
    rdfs:label 'Node Type' ;
    rdfs:comment 'Classification of the fulfillment node by its primary operational purpose: distribution_center (DC - regional warehouse), store (retail location with fulfillment capability), dark_store (fulfillment-only location, no customer traffic), micro_fulfillment_center (MFC - automated urban fulfillment hub), cross_dock (direct transfer facility), returns_center (reverse logistics hub).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard operating hours for weekdays (Monday-Friday) in format HH:MM-HH:MM (e.g., 08:00-20:00). Used for order cutoff time calculations and fulfillment scheduling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekend rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekend' ;
    rdfs:comment 'Standard operating hours for weekends (Saturday-Sunday) in format HH:MM-HH:MM (e.g., 09:00-18:00). Used for order cutoff time calculations and fulfillment scheduling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packStationCount rdf:type rdf:Property ;
    rdfs:label 'Pack Station Count' ;
    rdfs:comment 'Number of packing stations available at this fulfillment node. Determines packing throughput capacity for ship-from-store and DC operations.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickCapacityOrdersPerHour rdf:type rdf:Property ;
    rdfs:label 'Pick Capacity Orders Per Hour' ;
    rdfs:comment 'Maximum number of orders that can be picked per hour at this fulfillment node under normal operating conditions. Used for capacity planning and order routing decisions.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Primary Carrier Code' ;
    rdfs:comment 'Code identifying the primary shipping carrier assigned to this fulfillment node (e.g., UPS, FedEx, USPS, regional 3PL). Used for default carrier selection in order routing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refrigeratedStorageEnabled rdf:type rdf:Property ;
    rdfs:label 'Refrigerated Storage Enabled' ;
    rdfs:comment 'Indicates whether this node has refrigerated storage capability for perishable goods (dairy, produce, frozen foods). True if cold chain fulfillment is supported.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ropisEnabled rdf:type rdf:Property ;
    rdfs:label 'Ropis Enabled' ;
    rdfs:comment 'Indicates whether this node supports Reserve Online Pick Up In Store (ROPIS) fulfillment capability. True if customers can reserve items online for later in-store pickup and payment.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sameDayDeliveryEnabled rdf:type rdf:Property ;
    rdfs:label 'Same Day Delivery Enabled' ;
    rdfs:comment 'Indicates whether this node supports same-day delivery fulfillment. True if orders can be delivered to customers on the same day they are placed.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipFromStoreEnabled rdf:type rdf:Property ;
    rdfs:label 'Ship From Store Enabled' ;
    rdfs:comment 'Indicates whether this node supports Ship From Store (SFS) fulfillment capability. True if this location can pick, pack, and ship online orders directly to customers.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageCapacitySquareFeet rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Square Feet' ;
    rdfs:comment 'Total storage capacity of the fulfillment node measured in square feet. Used for inventory capacity planning and space utilization analysis.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageZoneCount rdf:type rdf:Property ;
    rdfs:label 'Storage Zone Count' ;
    rdfs:comment 'Number of distinct storage zones within the fulfillment node (e.g., ambient, refrigerated, frozen, hazmat). Used for inventory placement and pick path optimization.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wmsSystemCode rdf:type rdf:Property ;
    rdfs:label 'Wms System Code' ;
    rdfs:comment 'Identifier of the WMS system instance managing this fulfillment node. Links to the operational WMS platform (e.g., Manhattan Associates instance ID).' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTaskId rdf:type rdf:Property ;
    rdfs:label 'Pack Task Id' ;
    rdfs:comment 'Unique identifier for the packing task record. Primary key for the pack task entity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackTask .

ind:pickTaskId rdf:type rdf:Property ;
    rdfs:label 'Pick Task Id' ;
    rdfs:comment 'Reference to the upstream pick task that provided the items for this packing operation. Links the packing workflow to the picking workflow.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PickTask .

ind:exceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Notes' ;
    rdfs:comment 'Free-text notes describing the exception or special handling required. Provides context for exception resolution and audit trail.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftMessageIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Message Included Flag' ;
    rdfs:comment 'Indicates whether a personalized gift message was printed and included in the package per customer request.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:giftWrapFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Wrap Flag' ;
    rdfs:comment 'Indicates whether gift wrapping service was requested and applied to this package. Impacts packing time and material cost.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceValueAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Value Amount' ;
    rdfs:comment 'Declared value of the package contents for insurance purposes. Used to determine insurance premium and claim limits.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemsPackedCount rdf:type rdf:Property ;
    rdfs:label 'Items Packed Count' ;
    rdfs:comment 'Total number of individual items (SKUs) packed into the package for this task. Used for productivity measurement and quality verification.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Pack Duration Seconds' ;
    rdfs:comment 'Total time in seconds spent on the packing operation from start to completion. Key metric for labor standards and productivity analysis.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack End Timestamp' ;
    rdfs:comment 'Timestamp when the packing operation was completed and the package was sealed. Used to calculate pack cycle time and throughput.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Start Timestamp' ;
    rdfs:comment 'Timestamp when the packer began the packing operation. Used to calculate pack cycle time and labor productivity.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packageHeightCm rdf:type rdf:Property ;
    rdfs:label 'Package Height Cm' ;
    rdfs:comment 'Height dimension of the package in centimeters. Used for dimensional weight calculation and carrier compliance.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageLengthCm rdf:type rdf:Property ;
    rdfs:label 'Package Length Cm' ;
    rdfs:comment 'Length dimension of the package in centimeters. Used for dimensional weight calculation and carrier compliance.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageSize rdf:type rdf:Property ;
    rdfs:label 'Package Size' ;
    rdfs:comment 'Standardized size designation of the package selected. Used for dimensional weight calculation and carrier rate determination. [ENUM-REF-CANDIDATE: XS|S|M|L|XL|XXL|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Type of packaging material selected by the packer for this task. Influences shipping cost, protection level, and carrier handling.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageWeightKg rdf:type rdf:Property ;
    rdfs:label 'Package Weight Kg' ;
    rdfs:comment 'Actual weight of the sealed package in kilograms, measured at the packing station. Used for carrier rate calculation and compliance verification.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageWidthCm rdf:type rdf:Property ;
    rdfs:label 'Package Width Cm' ;
    rdfs:comment 'Width dimension of the package in centimeters. Used for dimensional weight calculation and carrier compliance.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packingSlipPrintedFlag rdf:type rdf:Property ;
    rdfs:label 'Packing Slip Printed Flag' ;
    rdfs:comment 'Indicates whether the packing slip document was successfully printed and included in the package. Required for customer order verification.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packingStationCode rdf:type rdf:Property ;
    rdfs:label 'Packing Station Code' ;
    rdfs:comment 'Identifier of the physical packing station where the task was performed. Used for workload balancing and station performance analysis.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCheckPerformedBy rdf:type rdf:Property ;
    rdfs:label 'Quality Check Performed By' ;
    rdfs:comment 'Identifier of the associate who performed the quality inspection. Used for accountability and training needs identification.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Check Status' ;
    rdfs:comment 'Result of the quality inspection performed on the packed package. Failed status triggers rework or escalation.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingLabelAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Shipping Label Applied Flag' ;
    rdfs:comment 'Indicates whether the carrier shipping label was successfully printed and affixed to the package. Required for carrier acceptance.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taskNumber rdf:type rdf:Property ;
    rdfs:label 'Task Number' ;
    rdfs:comment 'Human-readable business identifier for the pack task. Used for operational tracking, troubleshooting, and communication between warehouse staff.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskPriority rdf:type rdf:Property ;
    rdfs:label 'Task Priority' ;
    rdfs:comment 'Priority level assigned to the pack task based on order SLA, shipping cutoff time, or customer tier. Determines task sequencing at the packing station.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle state of the packing task. Tracks progression from assignment through completion or exception handling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsPackedCount rdf:type rdf:Property ;
    rdfs:label 'Units Packed Count' ;
    rdfs:comment 'Total quantity of units packed across all items. Differs from items_packed_count when multiple units of the same SKU are included.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voidFillType rdf:type rdf:Property ;
    rdfs:label 'Void Fill Type' ;
    rdfs:comment 'Type of void fill material used to protect items and prevent shifting during transit. Impacts packaging cost and sustainability metrics.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedAssociateId rdf:type rdf:Property ;
    rdfs:label 'Assigned Associate Id' ;
    rdfs:comment 'Reference to the warehouse associate assigned to execute this task. Used for productivity tracking and workload balancing.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:waveId rdf:type rdf:Property ;
    rdfs:label 'Wave Id' ;
    rdfs:comment 'Reference to the wave batch that this task belongs to. Wave-based picking groups tasks for efficient fulfillment execution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wave .

ind:aisle rdf:type rdf:Property ;
    rdfs:label 'Aisle' ;
    rdfs:comment 'Aisle location within the warehouse where the item is stored. Part of the physical location hierarchy for item retrieval.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bay rdf:type rdf:Property ;
    rdfs:label 'Bay' ;
    rdfs:comment 'Bay location within the aisle where the item is stored. Provides granular location detail for picking accuracy.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Status' ;
    rdfs:comment 'Customer approval status for the substitution. Tracks whether customer accepted the replacement item for BOPIS and delivery orders.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionReason rdf:type rdf:Property ;
    rdfs:label 'Exception Reason' ;
    rdfs:comment 'Detailed description of the exception or issue encountered during task execution. Provides context for exception resolution.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentChannel rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Channel' ;
    rdfs:comment 'Channel through which the order is being fulfilled. Supports omnichannel fulfillment strategy including store-based and centralized fulfillment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelApplied rdf:type rdf:Property ;
    rdfs:label 'Label Applied' ;
    rdfs:comment 'Indicates whether the shipping label was successfully applied to the package. Critical checkpoint for shipment readiness.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packingSlipPrinted rdf:type rdf:Property ;
    rdfs:label 'Packing Slip Printed' ;
    rdfs:comment 'Indicates whether the packing slip was printed and included in the package. Required for customer order verification.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickTaskStatus rdf:type rdf:Property ;
    rdfs:label 'Pick Task Status' ;
    rdfs:comment 'Current lifecycle state of the pick task. Tracks progression from assignment through completion or exception handling. [ENUM-REF-CANDIDATE: pending|assigned|in_progress|completed|exception|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCheckOutcome rdf:type rdf:Property ;
    rdfs:label 'Quality Check Outcome' ;
    rdfs:comment 'Result of the quality check performed on the picked items. Ensures accuracy and condition standards before shipment.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Original quantity of the item requested for picking. Represents the target quantity from the order or wave plan.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelf rdf:type rdf:Property ;
    rdfs:label 'Shelf' ;
    rdfs:comment 'Shelf level within the bay where the item is stored. Completes the physical location coordinates for item retrieval.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutedSku rdf:type rdf:Property ;
    rdfs:label 'Substituted Sku' ;
    rdfs:comment 'Replacement SKU provided when original item was unavailable. Used for substitution analysis and customer communication.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionOccurred rdf:type rdf:Property ;
    rdfs:label 'Substitution Occurred' ;
    rdfs:comment 'Indicates whether a product substitution was made during picking. Common in grocery and BOPIS fulfillment when original item is unavailable.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taskDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Task Duration Seconds' ;
    rdfs:comment 'Total time in seconds from task start to completion. Used for associate productivity analysis and labor standards calibration.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskMethod rdf:type rdf:Property ;
    rdfs:label 'Task Method' ;
    rdfs:comment 'Picking methodology used for task execution. Defines how items are grouped and picked for optimal efficiency.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Classification of the fulfillment task activity. Determines the workflow and execution requirements for the task.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidFillUsed rdf:type rdf:Property ;
    rdfs:label 'Void Fill Used' ;
    rdfs:comment 'Indicates whether void fill material was used in the package. Tracks packaging material usage for cost and sustainability reporting.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workZone rdf:type rdf:Property ;
    rdfs:label 'Work Zone' ;
    rdfs:comment 'Designated zone within the fulfillment location where the task is performed. Used for zone-based picking and associate assignment.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Id' ;
    rdfs:comment 'Unique identifier for the proof of delivery record. Primary key.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageVerificationCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Age Verification Completed Flag' ;
    rdfs:comment 'Indicates whether age verification was successfully completed. True if verification passed, False otherwise.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ageVerificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Age Verification Required Flag' ;
    rdfs:comment 'Indicates whether age verification was required for this delivery (e.g., alcohol, tobacco). True if verification was required, False otherwise.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'The calendar date of delivery. Used for daily delivery reporting and performance analytics.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryExceptionCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Exception Code' ;
    rdfs:comment 'The code representing any exception or issue encountered during delivery (e.g., customer not home, address incorrect, access denied). Used for root cause analysis.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructionsFollowedFlag rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions Followed Flag' ;
    rdfs:comment 'Indicates whether the driver followed the customer-provided delivery instructions. True if instructions were followed, False otherwise.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Notes' ;
    rdfs:comment 'Free-text notes entered by the driver about the delivery. Captures additional context not covered by structured fields.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPhotoUrl rdf:type rdf:Property ;
    rdfs:label 'Delivery Photo Url' ;
    rdfs:comment 'The URL or storage path to the photo taken at the delivery location. Provides visual proof of package placement and condition.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStopReference rdf:type rdf:Property ;
    rdfs:label 'Delivery Stop Reference' ;
    rdfs:comment 'The unique reference number for the delivery stop on the carrier route. Used for route optimization and last-mile logistics tracking.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'The exact date and time when the delivery was completed and POD was captured. Critical for SLA compliance and dispute resolution.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disputeFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Filed Flag' ;
    rdfs:comment 'Indicates whether the customer filed a dispute regarding this delivery (e.g., not received, damaged, incorrect). True if dispute exists, False otherwise.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Status' ;
    rdfs:comment 'The current status of any delivery dispute. Used for dispute management and resolution tracking.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsAccuracyMeters rdf:type rdf:Property ;
    rdfs:label 'Gps Accuracy Meters' ;
    rdfs:comment 'The accuracy radius of the GPS coordinates in meters. Indicates the precision of the location capture.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'The date and time when the delivery completion notification was sent to the customer.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packageCondition rdf:type rdf:Property ;
    rdfs:label 'Package Condition' ;
    rdfs:comment 'The physical condition of the package as observed and recorded at the time of delivery. Critical for damage claims and carrier accountability.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinConfirmationCode rdf:type rdf:Property ;
    rdfs:label 'Pin Confirmation Code' ;
    rdfs:comment 'The personal identification number (PIN) or confirmation code provided by the recipient to authorize delivery. Used for high-value or secure deliveries.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientRelationship rdf:type rdf:Property ;
    rdfs:label 'Recipient Relationship' ;
    rdfs:comment 'The relationship of the recipient to the original customer. Used to validate authorized delivery acceptance. [ENUM-REF-CANDIDATE: customer|household_member|neighbor|building_staff|reception|security|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Captured Flag' ;
    rdfs:comment 'Indicates whether a physical or electronic signature was captured at delivery. True if signature was obtained, False otherwise.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureImageUrl rdf:type rdf:Property ;
    rdfs:label 'Signature Image Url' ;
    rdfs:comment 'The URL or storage path to the digital signature image file. Used for dispute resolution and carrier compliance verification.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtDeliveryCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature At Delivery Celsius' ;
    rdfs:comment 'The recorded temperature of the package or delivery environment at the time of delivery, measured in Celsius. Used for cold chain compliance.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Compliant Flag' ;
    rdfs:comment 'Indicates whether temperature-sensitive shipments remained within required temperature range during delivery. True if compliant, False if breach occurred. Applicable to grocery and pharmaceutical deliveries.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Carrier Charge Amount' ;
    rdfs:comment 'Actual cost charged by the carrier for transporting this shipment. Used for freight cost accounting and margin analysis.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierChargeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Charge Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the carrier charge amount (e.g., USD, CAD, EUR).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueAmount rdf:type rdf:Property ;
    rdfs:label 'Declared Value Amount' ;
    rdfs:comment 'Declared monetary value of the shipment contents for insurance and customs purposes. Used to determine carrier liability limits.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Declared Value Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the declared value amount (e.g., USD, CAD, EUR).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverySignatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Delivery Signature Required Flag' ;
    rdfs:comment 'Indicates whether a recipient signature is required upon delivery for proof of receipt. True if signature required, false otherwise.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'Shortest dimension of the shipment in centimeters. Used for carrier rating and dimensional weight calculations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'Longest dimension of the shipment in centimeters. Used for carrier rating and dimensional weight calculations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipDate rdf:type rdf:Property ;
    rdfs:label 'Ship Date' ;
    rdfs:comment 'Date when the shipment was physically dispatched from the fulfillment node. Key business event timestamp for fulfillment cycle time measurement.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipFromLocationType rdf:type rdf:Property ;
    rdfs:label 'Ship From Location Type' ;
    rdfs:comment 'Classification of the originating fulfillment location type. Supports omnichannel fulfillment analytics including ship-from-store (SFS) and dark store operations.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToContactName rdf:type rdf:Property ;
    rdfs:label 'Ship To Contact Name' ;
    rdfs:comment 'Name of the recipient or contact person at the delivery destination. Used for delivery confirmation and communication.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Ship To Email Address' ;
    rdfs:comment 'Email address for shipment tracking notifications and delivery updates sent to the recipient.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Ship To Phone Number' ;
    rdfs:comment 'Contact phone number for the shipment recipient. Used by carriers for delivery coordination and customer notifications.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Externally visible unique shipment identifier used for customer tracking and carrier communication. Business identifier for the shipment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment in the fulfillment workflow. Tracks progression from creation through final delivery or return. [ENUM-REF-CANDIDATE: created|picked|packed|manifested|in_transit|out_for_delivery|delivered|failed_delivery|returned|cancelled — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the shipping cost amount (e.g., USD, CAD, EUR).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureName rdf:type rdf:Property ;
    rdfs:label 'Signature Name' ;
    rdfs:comment 'Name of the person who signed for the shipment upon delivery. Captured for proof of delivery and dispute resolution.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'Middle dimension of the shipment in centimeters. Used for carrier rating and dimensional weight calculations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentPackageId rdf:type rdf:Property ;
    rdfs:label 'Shipment Package Id' ;
    rdfs:comment 'Unique identifier for the shipment package. Primary key.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipmentPackage .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Date and time when the package was actually delivered to the customer, confirming successful fulfillment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billableWeightKg rdf:type rdf:Property ;
    rdfs:label 'Billable Weight Kg' ;
    rdfs:comment 'The greater of actual weight or dimensional weight, used as the basis for carrier shipping charges.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentsSummary rdf:type rdf:Property ;
    rdfs:label 'Contents Summary' ;
    rdfs:comment 'High-level description of package contents, often used for customs declarations or customer communication (e.g., \'Apparel and Electronics\').' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryConfirmationMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmation Method' ;
    rdfs:comment 'Method used to confirm successful delivery of the package (e.g., signature, photo proof, GPS coordinates, contactless delivery). [ENUM-REF-CANDIDATE: signature|photo|gps|contactless|left_at_door|handed_to_resident|locker — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Dimensional Weight Kg' ;
    rdfs:comment 'Calculated dimensional weight based on package volume, used by carriers for rating when dimensional weight exceeds actual weight.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHazmat rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat' ;
    rdfs:comment 'Indicates whether the package contains hazardous materials requiring special handling and labeling per regulatory requirements.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInsured rdf:type rdf:Property ;
    rdfs:label 'Is Insured' ;
    rdfs:comment 'Indicates whether the package has been insured for loss or damage during transit.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLabelPrinted rdf:type rdf:Property ;
    rdfs:label 'Is Label Printed' ;
    rdfs:comment 'Indicates whether the shipping label has been printed for this package.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isManifested rdf:type rdf:Property ;
    rdfs:label 'Is Manifested' ;
    rdfs:comment 'Indicates whether the package has been included in a carrier manifest and is ready for pickup.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSealed rdf:type rdf:Property ;
    rdfs:label 'Is Sealed' ;
    rdfs:comment 'Indicates whether the package has been sealed and is ready for shipment.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Is Signature Required' ;
    rdfs:comment 'Indicates whether a signature is required upon delivery for this package.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labeledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Labeled Timestamp' ;
    rdfs:comment 'Date and time when the shipping label was printed and affixed to the package.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manifestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manifested Timestamp' ;
    rdfs:comment 'Date and time when the package was included in the carrier manifest, indicating readiness for carrier pickup.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packageNumber rdf:type rdf:Property ;
    rdfs:label 'Package Number' ;
    rdfs:comment 'Human-readable business identifier for the package, often printed on the label. May follow internal numbering conventions.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageSequence rdf:type rdf:Property ;
    rdfs:label 'Package Sequence' ;
    rdfs:comment 'Sequential position of this package within the parent shipment (e.g., package 1 of 3).' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle status of the package in the fulfillment and delivery process. [ENUM-REF-CANDIDATE: created|packed|sealed|labeled|manifested|picked_up|in_transit|out_for_delivery|delivered|exception|returned — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packed Timestamp' ;
    rdfs:comment 'Date and time when the package was packed and sealed, marking readiness for shipment.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickedUpTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picked Up Timestamp' ;
    rdfs:comment 'Date and time when the carrier physically picked up the package from the fulfillment location.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Fulfillment method used for this package (e.g., Ship-from-Store (SFS), Distribution Center (DC) fulfillment, Buy Online Pick Up In Store (BOPIS), Reserve Online Pick Up In Store (ROPIS), drop ship). [ENUM-REF-CANDIDATE: ship_from_store|dc_fulfillment|drop_ship|bopis|ropis|curbside|locker — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPackagesInShipment rdf:type rdf:Property ;
    rdfs:label 'Total Packages In Shipment' ;
    rdfs:comment 'Total number of packages in the parent shipment, providing context for the package sequence.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitCount rdf:type rdf:Property ;
    rdfs:label 'Unit Count' ;
    rdfs:comment 'Total quantity of units across all items in the package (sum of quantities for all SKUs).' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Actual weight of the package in kilograms, including contents and packaging materials. Used for carrier rating and shipping cost calculation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentTrackingEventId rdf:type rdf:Property ;
    rdfs:label 'Shipment Tracking Event Id' ;
    rdfs:comment 'Unique identifier for the shipment tracking event record. Primary key.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierEventCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Event Code' ;
    rdfs:comment 'The raw event code provided by the carrier in their native format. Preserved for audit and troubleshooting purposes.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierEventDescription rdf:type rdf:Property ;
    rdfs:label 'Carrier Event Description' ;
    rdfs:comment 'The human-readable event description provided by the carrier. May contain carrier-specific terminology and details.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Facility Code' ;
    rdfs:comment 'The carrier\'s internal facility or hub code where the event was recorded. Used for detailed logistics analysis.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceType rdf:type rdf:Property ;
    rdfs:label 'Data Source Type' ;
    rdfs:comment 'The integration method or channel through which this tracking event was received. Enables data quality and latency analysis by source.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverySignatureName rdf:type rdf:Property ;
    rdfs:label 'Delivery Signature Name' ;
    rdfs:comment 'Name of the person who signed for the delivery, if applicable. Captured only for delivered events with signature.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventLocationCity rdf:type rdf:Property ;
    rdfs:label 'Event Location City' ;
    rdfs:comment 'The city where the tracking event occurred, as reported by the carrier. May be null for certain event types.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventLocationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Event Location Country Code' ;
    rdfs:comment 'Three-letter ISO country code where the tracking event occurred (e.g., USA, CAN, MEX).' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventLocationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Event Location Postal Code' ;
    rdfs:comment 'The postal code or ZIP code where the tracking event occurred, as reported by the carrier.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventLocationState rdf:type rdf:Property ;
    rdfs:label 'Event Location State' ;
    rdfs:comment 'The state or province code where the tracking event occurred. Uses standard postal abbreviations (e.g., CA, TX, ON).' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Sequence Number' ;
    rdfs:comment 'Sequential ordering of events within a shipment lifecycle. Enables chronological sorting and gap detection in event streams.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'The timestamp when the customer notification was sent, if applicable. Null if no notification was sent.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'The timestamp when this tracking event record was received and ingested into the data platform. Used for data latency monitoring and audit purposes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scanType rdf:type rdf:Property ;
    rdfs:label 'Scan Type' ;
    rdfs:comment 'The method used to capture this tracking event. Indicates whether the scan was automated (conveyor), manual (handheld), mobile (driver app), or RFID-based.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The unique identifier of this event in the source carrier system or EDI transaction. Enables traceability and deduplication.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightActualKg rdf:type rdf:Property ;
    rdfs:label 'Weight Actual Kg' ;
    rdfs:comment 'The actual weight of the package as measured by the carrier, in kilograms. May differ from the declared weight and can trigger billing adjustments.' ;
    rdfs:domain ind:ShipmentTrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaId rdf:type rdf:Property ;
    rdfs:label 'Sla Id' ;
    rdfs:comment 'Primary key for sla' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productCategoryId rdf:type rdf:Property ;
    rdfs:label 'Product Category Id' ;
    rdfs:comment 'Identifier of the product category this SLA applies to (e.g., perishables may have stricter SLAs). Null if SLA applies to all product categories.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:appliesToHolidays rdf:type rdf:Property ;
    rdfs:label 'Applies To Holidays' ;
    rdfs:comment 'Indicates whether this SLA rule applies to orders placed on recognized holidays. If false, holiday orders may follow different SLA rules.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToWeekdays rdf:type rdf:Property ;
    rdfs:label 'Applies To Weekdays' ;
    rdfs:comment 'Indicates whether this SLA rule applies to orders placed on weekdays (Monday-Friday).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToWeekends rdf:type rdf:Property ;
    rdfs:label 'Applies To Weekends' ;
    rdfs:comment 'Indicates whether this SLA rule applies to orders placed on weekends (Saturday-Sunday).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold Hours' ;
    rdfs:comment 'Number of hours before the SLA deadline at which an alert or escalation should be triggered if the order is not yet fulfilled. Used for proactive SLA risk management.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold Percentage' ;
    rdfs:comment 'Percentage of the total SLA time window at which an alert should be triggered (e.g., 80% means alert when 80% of allowed time has elapsed). Alternative to breach_threshold_hours.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Carrier Cutoff Time' ;
    rdfs:comment 'Daily cutoff time (HH:MM in 24-hour format, local node time) by which orders must be ready for carrier pickup to meet the SLA. Null if not applicable.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting any regulatory, contractual, or business policy requirements that govern this SLA rule (e.g., \'Required by premium membership terms\', \'State law mandates 24-hour BOPIS readiness\').' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRule rdf:type rdf:Property ;
    rdfs:label 'Escalation Rule' ;
    rdfs:comment 'Business rule or workflow identifier defining what actions to take when SLA breach risk is detected (e.g., \'NOTIFY_STORE_MANAGER\', \'REROUTE_TO_ALTERNATE_NODE\', \'UPGRADE_CARRIER_SERVICE\').' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excludedDates rdf:type rdf:Property ;
    rdfs:label 'Excluded Dates' ;
    rdfs:comment 'Comma-separated list of specific dates (YYYY-MM-DD format) on which this SLA rule does not apply (e.g., peak season blackout dates, facility closures).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderChannel rdf:type rdf:Property ;
    rdfs:label 'Order Channel' ;
    rdfs:comment 'The sales channel through which the order was placed: web, mobile app, in-store, call center, marketplace, or social commerce.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Order Cutoff Time' ;
    rdfs:comment 'Daily cutoff time (HH:MM in 24-hour format, local node time) by which orders must be placed to qualify for this SLA (e.g., same-day delivery cutoff at 14:00). Null if no order cutoff applies.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderValueMax rdf:type rdf:Property ;
    rdfs:label 'Order Value Max' ;
    rdfs:comment 'Maximum order total amount (in currency_code) for which this SLA applies. Null if no maximum order value threshold exists.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderValueMin rdf:type rdf:Property ;
    rdfs:label 'Order Value Min' ;
    rdfs:comment 'Minimum order total amount (in currency_code) required for this SLA to apply. Null if no minimum order value threshold exists.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postalCodePattern rdf:type rdf:Property ;
    rdfs:label 'Postal Code Pattern' ;
    rdfs:comment 'Regex pattern or prefix defining the postal/ZIP codes this SLA applies to (e.g., \'^90[0-9]{3}$\' for Los Angeles area). Null if SLA is not postal-code-specific.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedHoursToDeliver rdf:type rdf:Property ;
    rdfs:label 'Promised Hours To Deliver' ;
    rdfs:comment 'Total number of hours from order placement to final delivery to the customer. Used for end-to-end delivery SLAs (same-day, next-day, standard ground).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promisedHoursToReady rdf:type rdf:Property ;
    rdfs:label 'Promised Hours To Ready' ;
    rdfs:comment 'Number of hours from order placement to when the order must be ready for customer pickup (for BOPIS/ROPIS) or ready for carrier pickup (for ship-from-store). Null if not applicable to this SLA type.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promisedHoursToShip rdf:type rdf:Property ;
    rdfs:label 'Promised Hours To Ship' ;
    rdfs:comment 'Number of hours from order placement to when the shipment must be handed off to the carrier. Applies to ship-to-home and ship-from-store fulfillment methods.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaCode rdf:type rdf:Property ;
    rdfs:label 'Sla Code' ;
    rdfs:comment 'Business-readable unique code identifying this SLA rule (e.g., BOPIS_2HR, SAMEDAY_SHIP, NEXTDAY_DEL).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaName rdf:type rdf:Property ;
    rdfs:label 'Sla Name' ;
    rdfs:comment 'Human-readable descriptive name of the SLA rule (e.g., \'Buy Online Pick Up In Store - 2 Hour Ready\', \'Same-Day Shipping Cutoff\').' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Category of SLA commitment: BOPIS readiness, ROPIS readiness, same-day ship cutoff, next-day delivery, standard ground, express delivery, or ship-from-store. [ENUM-REF-CANDIDATE: BOPIS_READINESS|ROPIS_READINESS|SAME_DAY_SHIP|NEXT_DAY_DELIVERY|STANDARD_GROUND|EXPRESS_DELIVERY|SHIP_FROM_STORE — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentAssociateId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Associate Id' ;
    rdfs:comment 'Reference to the employee or system user who originally created or submitted the inventory adjustment request. May differ from the authorizing user in approval workflows (e.g., store associate submits, store manager approves).' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:adjustmentAuthorizingUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Authorizing User Associate Id' ;
    rdfs:comment 'Reference to the employee or system user who authorized or approved the inventory adjustment. Required for audit trail and loss prevention accountability. Maps to the workforce/user master in Workday HCM or SAP.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:customerProfileId rdf:type rdf:Property ;
    rdfs:label 'Customer Profile Id' ;
    rdfs:comment 'Foreign key linking to customer.profile. Business justification: Retail adjustments for customer returns, damages at pickup, or theft incidents require customer attribution for refund processing, fraud detection, and loss prevention analytics. Supports chargeback a' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:reversalOfAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Reversal Of Adjustment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original adjustment record that this record is reversing. Populated only for reversal entries to maintain a complete audit trail of corrections. Nullable for original (non-reversal) adjustments.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:adjustedQuantity rdf:type rdf:Property ;
    rdfs:label 'Adjusted Quantity' ;
    rdfs:comment 'The net quantity change applied to on-hand inventory for the SKU at the specified location. Negative values represent inventory reductions (shrinkage, damage, write-offs); positive values represent inventory additions (found stock, receiving corrections). Expressed in the SKU\'s unit of measure.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for the adjustment transaction. Used in audit trails, loss prevention case references, and cross-system reconciliation with SAP S/4HANA and ORMS. Format: ADJ- followed by 10 digits.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current workflow lifecycle state of the adjustment record. Controls whether the adjustment has been applied to the stock ledger. \'posted\' indicates the adjustment has updated on-hand quantities; \'reversed\' indicates a correcting entry was made.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Timestamp' ;
    rdfs:comment 'The principal real-world date and time when the inventory adjustment event occurred (e.g., when shrinkage was detected, when a cycle count discrepancy was identified, when damage was observed). Distinct from system audit timestamps. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Batch or lot number of the inventory being adjusted, applicable for batch-tracked SKUs such as food, pharmaceuticals, and regulated products. Required for FDA recall traceability and CPSC product safety compliance. Nullable for non-batch-tracked items.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpact rdf:type rdf:Property ;
    rdfs:label 'Cost Impact' ;
    rdfs:comment 'Total financial impact of the inventory adjustment on Cost of Goods Sold (COGS), calculated as adjusted_quantity multiplied by unit_cost. Negative values represent write-downs (losses); positive values represent write-ups (gains). Posted to the general ledger via SAP FI/CO integration.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'The merchandise department code associated with the SKU being adjusted, sourced from the product hierarchy in Oracle Retail Merchandising System (ORMS). Enables shrinkage and adjustment reporting by department for category management and P&L analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isShrinkage rdf:type rdf:Property ;
    rdfs:label 'Is Shrinkage' ;
    rdfs:comment 'Boolean flag indicating whether this adjustment represents a shrinkage event (inventory loss due to theft, damage, administrative error, or vendor fraud). Used to filter and aggregate shrinkage metrics for loss prevention reporting and GMROI (Gross Margin Return on Investment) analysis.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSystemGenerated rdf:type rdf:Property ;
    rdfs:label 'Is System Generated' ;
    rdfs:comment 'Boolean flag indicating whether the adjustment was automatically generated by a system process (e.g., Blue Yonder replenishment system, RFID reconciliation engine, WMS cycle count automation) rather than manually entered by a user.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the inventory node type where the adjustment occurred. Distinguishes between store-level adjustments, Distribution Center (DC) adjustments, Micro-Fulfillment Center (MFC) adjustments, and dark store adjustments for segmented shrinkage and variance reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lpCaseReference rdf:type rdf:Property ;
    rdfs:label 'Lp Case Reference' ;
    rdfs:comment 'Reference number linking this inventory adjustment to an active or closed Loss Prevention (LP) investigation case (e.g., shoplifting incident, employee theft case). Nullable — only populated when the adjustment is associated with a formal LP case in Salesforce Service Cloud or a dedicated LP system.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAfterAdjustment rdf:type rdf:Property ;
    rdfs:label 'Quantity After Adjustment' ;
    rdfs:comment 'The on-hand inventory quantity for the SKU at the location immediately after this adjustment is applied. Derived at posting time and stored for audit trail and stock ledger reconciliation. Expressed in the SKU\'s unit of measure.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityBeforeAdjustment rdf:type rdf:Property ;
    rdfs:label 'Quantity Before Adjustment' ;
    rdfs:comment 'The on-hand inventory quantity for the SKU at the location immediately prior to this adjustment being applied. Captured at the time of adjustment for audit trail completeness and variance analysis. Expressed in the SKU\'s unit of measure.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCategory rdf:type rdf:Property ;
    rdfs:label 'Reason Category' ;
    rdfs:comment 'High-level classification of why the inventory adjustment is being made. Drives reporting buckets for shrinkage monitoring, COGS (Cost of Goods Sold) impact analysis, and loss prevention dashboards. [ENUM-REF-CANDIDATE: shrinkage|damage|cycle_count_correction|receiving_variance|expiry_write_off|rtv|admin_correction|found_stock — promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonSubCategory rdf:type rdf:Property ;
    rdfs:label 'Reason Sub Category' ;
    rdfs:comment 'Granular sub-classification within the reason category providing specific cause detail. Examples for shrinkage: shoplifting, employee theft, administrative error, vendor fraud. Examples for damage: in-transit damage, handling damage, shelf damage. Feeds loss prevention case analysis and shrinkage root-cause reporting. [ENUM-REF-CANDIDATE: shoplifting|employee_theft|admin_error|vendor_fraud|in_transit_damage|handling_damage|shelf_damage|expired|recalled|mis-ship — promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Boolean flag indicating whether this inventory adjustment is associated with a product recall event initiated by the CPSC, FDA, or the retailer. Enables rapid identification and financial quantification of recall-related inventory write-offs.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidTagCount rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Count' ;
    rdfs:comment 'Number of RFID (Radio Frequency Identification) tags scanned during the detection event that triggered this adjustment. Populated only for RFID-based detection methods. Supports RFID program accuracy measurement and tag read-rate analysis.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:asnId rdf:type rdf:Property ;
    rdfs:label 'Asn Id' ;
    rdfs:comment 'Unique surrogate identifier for the Advance Shipment Notice record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asn .

ind:asnInventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Asn Inventory Node Id' ;
    rdfs:comment 'Reference to the originating inventory node (DC, MFC, store, or supplier facility) from which the shipment was dispatched. Used for inter-node transfer ASNs.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:asnSupplierVendorId rdf:type rdf:Property ;
    rdfs:label 'Asn Supplier Vendor Id' ;
    rdfs:comment 'FK to supplier.vendor' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:asnVendorId rdf:type rdf:Property ;
    rdfs:label 'Asn Vendor Id' ;
    rdfs:comment 'Reference to the supplier or vendor who originated the shipment. Populated when asn_type is \'supplier\' or \'drop_ship\'. Links to the supplier master record in Informatica MDM.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:destinationNodeInventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Node Inventory Node Id' ;
    rdfs:comment 'Reference to the receiving inventory node (store, DC, or MFC) where the shipment is expected to arrive. Drives dock scheduling and pre-receiving workflows in the WMS.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:dockAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Dock Appointment Id' ;
    rdfs:comment 'Reference to the dock scheduling appointment associated with this ASN arrival. Links to supplychain.inbound_appointment for dock door and labor resource planning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DockAppointment .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Reference to the inventory goods receipt record created upon physical receipt of this shipment. Links ASN to the goods receipt for discrepancy detection and inventory valuation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:supplierEdiTransactionId rdf:type rdf:Property ;
    rdfs:label 'Supplier Edi Transaction Id' ;
    rdfs:comment 'Unique identifier of the EDI 856 transaction set that originated this ASN record. Used for EDI audit trails, reprocessing, and trading partner dispute resolution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierEdiTransaction .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'Date the shipment physically arrived at the destination node dock. Compared against expected_arrival_date to measure carrier on-time delivery performance and lead time actuals.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:asnNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Number' ;
    rdfs:comment 'Externally-known business identifier for the ASN as transmitted by the supplier or DC via EDI 856 or API. Used for cross-system reconciliation and dock scheduling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnStatus rdf:type rdf:Property ;
    rdfs:label 'Asn Status' ;
    rdfs:comment 'Current lifecycle state of the ASN. \'sent\' = transmitted by sender; \'in_transit\' = shipment en route; \'arrived\' = at destination dock; \'receiving\' = active receiving in WMS; \'received\' = fully received; \'discrepant\' = quantity or SKU variance detected; \'cancelled\' = voided prior to receipt. [ENUM-REF-CANDIDATE: sent|in_transit|arrived|receiving|received|discrepant|cancelled — promote to reference product]' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnType rdf:type rdf:Property ;
    rdfs:label 'Asn Type' ;
    rdfs:comment 'Classification of the ASN by origin and fulfillment pattern. \'supplier\' = inbound from vendor; \'dc_transfer\' = inter-DC or DC-to-store transfer; \'cross_dock\' = direct cross-dock flow; \'drop_ship\' = vendor direct-to-customer; \'return_to_dc\' = store or customer return to DC.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Bill of Lading number issued by the carrier for the shipment. Legal document of title used for freight claims, customs clearance, and receiving verification.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationNodeType rdf:type rdf:Property ;
    rdfs:label 'Destination Node Type' ;
    rdfs:comment 'Classification of the receiving node. Determines which receiving workflow and dock door assignment logic applies in the WMS.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Indicates whether a receiving discrepancy (quantity overage, shortage, or SKU mismatch) was detected when comparing the ASN to the actual goods receipt. Triggers discrepancy resolution workflow.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyType rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Type' ;
    rdfs:comment 'Classification of the receiving discrepancy detected against the ASN. \'overage\' = more units received than declared; \'shortage\' = fewer units; \'sku_mismatch\' = wrong SKU received; \'damage\' = goods received in damaged condition; \'none\' = no discrepancy.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorNumber rdf:type rdf:Property ;
    rdfs:label 'Dock Door Number' ;
    rdfs:comment 'Assigned dock door at the destination node for unloading this shipment. Pre-assigned during dock scheduling to optimize receiving throughput and yard management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Date' ;
    rdfs:comment 'Scheduled date the shipment is expected to arrive at the destination node. Drives dock door scheduling, labor planning, and replenishment availability projections.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Freight payment responsibility terms for the shipment. \'prepaid\' = supplier pays freight; \'collect\' = receiver pays; \'third_party\' = billed to a third party. Drives accounts payable freight accruals.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCrossDock rdf:type rdf:Property ;
    rdfs:label 'Is Cross Dock' ;
    rdfs:comment 'Indicates whether this shipment is designated for cross-docking (direct transfer without storage) at the destination DC. Triggers cross-dock workflow in the WMS and bypasses putaway.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRfidEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Rfid Enabled' ;
    rdfs:comment 'Indicates whether RFID tags are present on cartons or pallets in this shipment, enabling automated receiving and inventory tracking via RFID readers at the dock.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'External purchase order number as referenced on the ASN document. Denormalized from the PO for cross-system matching with EDI 856 transmissions and supplier invoices.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Number' ;
    rdfs:comment 'Carrier-assigned Progressive (PRO) number for LTL (Less-Than-Truckload) shipments. Used for freight bill matching and carrier invoice reconciliation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receiving Complete Timestamp' ;
    rdfs:comment 'Timestamp when all line items on the ASN were fully received and confirmed in the WMS. Marks the transition from \'receiving\' to \'received\' or \'discrepant\' status.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shipmentMode rdf:type rdf:Property ;
    rdfs:label 'Shipment Mode' ;
    rdfs:comment 'Transportation mode used for the shipment. Drives freight cost benchmarking, carrier selection analytics, and carbon footprint reporting. [ENUM-REF-CANDIDATE: truckload|ltl|parcel|rail|air|ocean|intermodal — promote to reference product]' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceNodeType rdf:type rdf:Property ;
    rdfs:label 'Source Node Type' ;
    rdfs:comment 'Classification of the originating node. Distinguishes supplier facilities from internal DC, MFC, store, or dark store nodes to support routing and receiving workflow logic.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCartons rdf:type rdf:Property ;
    rdfs:label 'Total Cartons' ;
    rdfs:comment 'Total number of cartons (cases/boxes) included in the shipment as declared on the ASN. Used for dock receiving verification, pallet count planning, and discrepancy detection.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPallets rdf:type rdf:Property ;
    rdfs:label 'Total Pallets' ;
    rdfs:comment 'Total number of pallets in the shipment as declared on the ASN. Used for dock door capacity planning, unloading labor scheduling, and yard management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnits rdf:type rdf:Property ;
    rdfs:label 'Total Units' ;
    rdfs:comment 'Total number of sellable units across all SKU lines declared on the ASN. Used for pre-receiving inventory projection and receiving discrepancy detection against goods receipt.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transmissionMethod rdf:type rdf:Property ;
    rdfs:label 'Transmission Method' ;
    rdfs:comment 'Channel through which the ASN was received. \'edi_856\' = GS1 EDI 856 standard; \'api\' = REST/SOAP API integration; \'manual\' = entered by receiving staff; \'portal\' = supplier self-service portal.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmission Timestamp' ;
    rdfs:comment 'Timestamp when the ASN was transmitted by the supplier or DC via EDI 856 or API. Distinct from created_timestamp; used to measure EDI lead time and supplier advance notice compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approverEmployeeAssociateId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Associate Id' ;
    rdfs:comment 'Reference to the supervisor or manager who reviewed and approved the cycle count result and any resulting variance reconciliation. Required for SOX inventory control compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:primaryCycleAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Cycle Associate Id' ;
    rdfs:comment 'Reference to the employee assigned to perform the physical count for this cycle count event. Supports accountability and audit trail for Sarbanes-Oxley (SOX) inventory controls.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'ABC classification of the SKU at the time of the cycle count, indicating inventory value and velocity tier. A = high-value/high-velocity; B = medium; C = low-value/low-velocity; D = dead stock. Drives count frequency prioritization.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentGenerated rdf:type rdf:Property ;
    rdfs:label 'Adjustment Generated' ;
    rdfs:comment 'Indicates whether an inventory_adjustment record has been generated from this cycle count variance. When True, the variance has been posted to the inventory ledger for reconciliation.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Count Device Code' ;
    rdfs:comment 'Identifier of the handheld scanner, mobile device, or RFID reader used to perform the physical count. Supports device-level audit trail and equipment calibration tracking.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count End Timestamp' ;
    rdfs:comment 'The precise date and time when the physical counting activity was completed and the count was submitted by the assigned counter.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countFrequency rdf:type rdf:Property ;
    rdfs:label 'Count Frequency' ;
    rdfs:comment 'The scheduled counting frequency for this SKU-location combination, typically driven by ABC classification or velocity. High-velocity A-items are counted more frequently than slow-moving C-items.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countNotes rdf:type rdf:Property ;
    rdfs:label 'Count Notes' ;
    rdfs:comment 'Free-text field for the counter or supervisor to record observations, exceptions, or explanations related to the cycle count result (e.g., damaged packaging, items in transit, display stock not included).' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countNumber rdf:type rdf:Property ;
    rdfs:label 'Count Number' ;
    rdfs:comment 'Externally-known business reference number assigned to the cycle count event, used for cross-system tracking and audit trail. Typically generated by the WMS (e.g., Manhattan Associates) or SAP WM module.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Start Timestamp' ;
    rdfs:comment 'The precise date and time when the physical counting activity was initiated by the assigned counter. Used for cycle time analysis and labor tracking.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current workflow state of the cycle count event. \'scheduled\' = count is planned but not started; \'in_progress\' = counting is underway; \'completed\' = physical count recorded; \'reconciled\' = variance reviewed and inventory adjustment posted; \'cancelled\' = count was voided.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Classification of the cycle count method. \'scheduled\' = routine planned count; \'ad_hoc\' = unplanned triggered count; \'blind\' = counter does not see system quantity; \'directed\' = WMS-directed count task; \'rfid_assisted\' = count performed using Radio Frequency Identification (RFID) technology.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'The actual physical quantity of the SKU observed and recorded by the counter during the cycle count. This is the primary measured outcome of the count event.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planogramLocation rdf:type rdf:Property ;
    rdfs:label 'Planogram Location' ;
    rdfs:comment 'The planogram (POG) shelf position or fixture reference for the SKU at the store location, used to direct the counter to the correct physical location during in-store cycle counts.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountNumber rdf:type rdf:Property ;
    rdfs:label 'Recount Number' ;
    rdfs:comment 'Sequential count of how many times this SKU-location has been recounted within the same cycle count event. First count = 1; first recount = 2; etc. Supports escalation workflows when repeated recounts still show variance.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recountRequired rdf:type rdf:Property ;
    rdfs:label 'Recount Required' ;
    rdfs:comment 'Indicates whether a recount of this SKU-location is required because the variance exceeded the tolerance threshold or the count was flagged for discrepancy. When True, a follow-up count must be performed before reconciliation.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shrinkageCategory rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Category' ;
    rdfs:comment 'Classification of the root cause of inventory shrinkage identified through this cycle count. Populated during the reconciliation phase when a negative variance is confirmed. Supports shrinkage investigation and loss prevention analytics.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageBin rdf:type rdf:Property ;
    rdfs:label 'Storage Bin' ;
    rdfs:comment 'The specific warehouse storage bin, shelf, or slot location within the inventory node where the SKU is physically stored and counted. Granular location identifier used by the WMS for directed counting.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageZone rdf:type rdf:Property ;
    rdfs:label 'Storage Zone' ;
    rdfs:comment 'The logical zone or area within the inventory node (e.g., ambient, refrigerated, frozen, high-value, bulk) where the SKU is stored. Used for zone-based cycle count scheduling and analysis.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemQuantity rdf:type rdf:Property ;
    rdfs:label 'System Quantity' ;
    rdfs:comment 'The inventory quantity recorded in the Warehouse Management System (WMS) or ERP at the exact time the cycle count was initiated. This is the \'book\' quantity against which the physical count is compared.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerReason rdf:type rdf:Property ;
    rdfs:label 'Trigger Reason' ;
    rdfs:comment 'Business reason that initiated this cycle count. Supports shrinkage investigation and root cause analysis. [ENUM-REF-CANDIDATE: routine|negative_inventory|shrinkage_alert|receiving_discrepancy|customer_complaint|audit_request|rfid_discrepancy — promote to reference product]' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceCost rdf:type rdf:Property ;
    rdfs:label 'Variance Cost' ;
    rdfs:comment 'The monetary value of the inventory variance, calculated as variance_quantity multiplied by the unit cost at time of count. Expressed in the local operating currency. Used for Cost of Goods Sold (COGS) impact assessment and financial reporting.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'The difference between the physically counted quantity and the system on-hand quantity (counted_quantity minus system_quantity). A negative value indicates shrinkage or loss; a positive value indicates an overcount or unrecorded receipt.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Tolerance Pct' ;
    rdfs:comment 'The maximum acceptable variance percentage for this SKU-location before a recount or inventory adjustment is triggered. Variances exceeding this threshold generate inventory_adjustment records for reconciliation.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expiryTrackingId rdf:type rdf:Property ;
    rdfs:label 'Expiry Tracking Id' ;
    rdfs:comment 'Unique surrogate identifier for each expiry tracking record at the SKU-location-batch level. Primary key for this data product.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExpiryTracking .

ind:actionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Action Completed Date' ;
    rdfs:comment 'Date on which the recommended_action was fully executed (e.g., markdown applied, product pulled from shelf, donation completed). Null if action_status is pending or in_progress.' ;
    rdfs:domain ind:ExpiryTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Execution status of the recommended_action: pending (action not yet started), in_progress (action initiated), completed (action fully executed), waived (action overridden by manager with justification). Tracks operational follow-through on expiry management.' ;
    rdfs:domain ind:ExpiryTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bestBeforeDate rdf:type rdf:Property ;
    rdfs:label 'Best Before Date' ;
    rdfs:comment 'Date until which the product is guaranteed to be at peak quality. Distinct from expiry_date — product may still be safe after this date but quality may degrade. Used for markdown and donation decision triggers.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:criticalThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Critical Threshold Days' ;
    rdfs:comment 'Number of days before expiry at which the batch escalates to critical risk status, triggering urgent pull-from-shelf or destroy actions. Configurable at the SKU or category level.' ;
    rdfs:domain ind:ExpiryTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysToExpiry rdf:type rdf:Property ;
    rdfs:label 'Days To Expiry' ;
    rdfs:comment 'Calculated number of calendar days remaining from the current date to the expiry_date. Negative values indicate the batch has already expired. Used to drive expiry risk classification and recommended action assignment. Refreshed daily by the Silver layer pipeline.' ;
    rdfs:domain ind:ExpiryTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryRiskStatus rdf:type rdf:Property ;
    rdfs:label 'Expiry Risk Status' ;
    rdfs:comment 'Current risk classification of the batch based on days_to_expiry thresholds: fresh (well within shelf life), near_expiry (approaching threshold), critical (imminent expiry requiring urgent action), expired (past expiry_date), pulled (removed from shelf). Drives recommended action and waste reduction workflows.' ;
    rdfs:domain ind:ExpiryTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fefoSequence rdf:type rdf:Property ;
    rdfs:label 'Fefo Sequence' ;
    rdfs:comment 'Picking sequence rank assigned to this batch within the same SKU-location combination, ordered by ascending expiry_date. Rank 1 = earliest expiring batch to be picked first. Drives FEFO (First Expired First Out) fulfillment logic in WMS and store replenishment.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Inventory Cost Per Unit' ;
    rdfs:comment 'Cost of Goods Sold (COGS) value per unit for this batch at the time of receipt. Used to calculate the financial write-off value of expired or disposed inventory. Sourced from SAP S/4HANA FI/CO module.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRecallActive rdf:type rdf:Property ;
    rdfs:label 'Is Recall Active' ;
    rdfs:comment 'Indicates whether this batch is subject to an active product recall issued by the supplier, FDA, or CPSC. True = recall in effect, requiring immediate pull-from-shelf and quarantine. Integrates with Salesforce Service Cloud for customer notification.' ;
    rdfs:domain ind:ExpiryTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRfidTracked rdf:type rdf:Property ;
    rdfs:label 'Is Rfid Tracked' ;
    rdfs:comment 'Indicates whether this batch is tracked using RFID (Radio Frequency Identification) technology for real-time inventory visibility. True = RFID tag attached and active; False = barcode-only tracking.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVendorManaged rdf:type rdf:Property ;
    rdfs:label 'Is Vendor Managed' ;
    rdfs:comment 'Indicates whether this batch is managed under a Vendor Managed Inventory (VMI) agreement where the supplier retains ownership and responsibility for replenishment until sold. Affects COGS recognition timing.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date of the most recent physical cycle count or inventory audit that verified the quantity_on_hand for this batch. Used to assess data freshness and trigger recount workflows for high-risk expiry batches.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date on which the batch was manufactured or produced by the supplier. Used to calculate shelf life and validate compliance with minimum remaining shelf life (MRSL) requirements.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nearExpiryThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Near Expiry Threshold Days' ;
    rdfs:comment 'Number of days before expiry at which the batch transitions to near_expiry risk status. Configurable at the SKU or category level to reflect product-specific shelf life policies (e.g., dairy = 3 days, bakery = 1 day, pharmaceuticals = 30 days).' ;
    rdfs:domain ind:ExpiryTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'Merchandise category of the SKU (e.g., Dairy, Bakery, Produce, Meat, Pharmaceuticals, Frozen Foods). Used for category-level expiry policy configuration, waste reporting, and food safety compliance segmentation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAtRisk rdf:type rdf:Property ;
    rdfs:label 'Quantity At Risk' ;
    rdfs:comment 'Portion of quantity_on_hand that is classified as near_expiry or critical based on current expiry_risk_status. Used for waste forecasting, markdown planning, and shrinkage reporting.' ;
    rdfs:domain ind:ExpiryTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDisposed rdf:type rdf:Property ;
    rdfs:label 'Quantity Disposed' ;
    rdfs:comment 'Cumulative quantity of this batch that has been disposed of (destroyed, donated, or returned to vendor) due to expiry. Contributes to shrinkage (inventory loss) reporting and COGS (Cost of Goods Sold) write-off calculations.' ;
    rdfs:domain ind:ExpiryTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Current physical quantity of the batch available at the inventory node, expressed in the SKU\'s base unit of measure. Updated by POS sales, cycle counts, adjustments, and RFID scans.' ;
    rdfs:domain ind:ExpiryTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Reference Number' ;
    rdfs:comment 'Official recall reference number issued by the FDA, CPSC, or supplier for the active recall affecting this batch. Populated only when is_recall_active = True. Used for regulatory reporting and audit trail.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date the batch was received at the inventory node from the supplier or DC. Used to calculate time-in-location and validate minimum remaining shelf life (MRSL) at receipt.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'System-recommended disposition action for the batch based on expiry risk status and business rules: none (no action needed), markdown (apply price reduction to accelerate sell-through), pull_from_shelf (remove from sale floor), donate (transfer to food bank or charity), destroy (dispose per regulatory guidelines), return_to_vendor (RTV). Supports waste reduction programs and food safety compliance.' ;
    rdfs:domain ind:ExpiryTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingShelfLifePct rdf:type rdf:Property ;
    rdfs:label 'Remaining Shelf Life Pct' ;
    rdfs:comment 'Percentage of total shelf life remaining at the current date, calculated as (days_to_expiry / shelf_life_days) * 100. Used to enforce minimum remaining shelf life (MRSL) thresholds for receiving and selling.' ;
    rdfs:domain ind:ExpiryTracking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Total shelf life of the SKU in calendar days from manufacture date to expiry date. Used to calculate remaining shelf life percentage and minimum remaining shelf life (MRSL) compliance at receipt.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Required storage temperature zone for this batch: ambient (room temperature), chilled (2–8°C), frozen (below -18°C), controlled (specific temperature-controlled environment). Used to validate storage compliance and flag temperature excursions that may accelerate expiry.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Inbound Appointment Id' ;
    rdfs:comment 'Reference to the scheduled inbound dock appointment at the receiving node. Links to the inbound_appointment product for dock scheduling, carrier arrival tracking, and receiving labor planning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundAppointment .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Reference to the specific purchase order line item being received. Enables line-level PO matching, partial receipt tracking, and SKU-level discrepancy analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:receivingAssociateId rdf:type rdf:Property ;
    rdfs:label 'Receiving Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Receiving operations require tracking which associate physically received goods for accountability, discrepancy resolution, training assessment, and performance metrics. The existing received_by text ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:acceptedQty rdf:type rdf:Property ;
    rdfs:label 'Accepted Qty' ;
    rdfs:comment 'Quantity of units accepted into inventory after quality inspection. Excludes rejected, damaged, or wrong-SKU units. This is the quantity inducted into on-hand inventory and used for COGS valuation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackEligible rdf:type rdf:Property ;
    rdfs:label 'Chargeback Eligible' ;
    rdfs:comment 'Indicates whether this goods receipt record has identified discrepancies that qualify for a vendor compliance chargeback. True = chargeback may be issued to supplier; False = no chargeback applicable. Drives the vendor compliance chargeback workflow.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Resolution Status' ;
    rdfs:comment 'Current status of the discrepancy resolution workflow. \'pending\' = discrepancy logged, not yet actioned; \'under_review\' = being investigated with supplier; \'resolved\' = discrepancy closed; \'chargeback_issued\' = vendor compliance chargeback raised; \'waived\' = discrepancy accepted without penalty.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedQty rdf:type rdf:Property ;
    rdfs:label 'Expected Qty' ;
    rdfs:comment 'Quantity of units expected at the receiving node based on the ASN or replenishment plan. May differ from ordered quantity due to partial shipments or split deliveries. Used for receiving dock planning and discrepancy detection.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQty rdf:type rdf:Property ;
    rdfs:label 'Ordered Qty' ;
    rdfs:comment 'Quantity of units originally ordered on the purchase order line. Used as the baseline for receipt variance calculation, fill rate measurement, and vendor compliance scoring.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageQty rdf:type rdf:Property ;
    rdfs:label 'Overage Qty' ;
    rdfs:comment 'Quantity of units received in excess of the ASN or PO expectation (received_qty minus expected_qty when positive). Overages require disposition decisions and may trigger vendor compliance chargebacks.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Status of the quality inspection performed on received merchandise. \'not_required\' = inspection waived per supplier agreement; \'pending\' = awaiting inspection; \'passed\' = all units meet quality standards; \'failed\' = units do not meet standards; \'partial_pass\' = some units accepted, some rejected. Drives accepted/rejected quantity split.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptMethod rdf:type rdf:Property ;
    rdfs:label 'Receipt Method' ;
    rdfs:comment 'Method by which merchandise was physically received. \'dsd\' = Direct Store Delivery from supplier; \'dc_to_store\' = replenishment from Distribution Center; \'cross_dock\' = direct transfer without storage; \'drop_ship\' = vendor direct-to-customer; \'transfer_order\' = inter-node stock transfer. Drives receiving workflow and inventory valuation logic.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptNotes rdf:type rdf:Property ;
    rdfs:label 'Receipt Notes' ;
    rdfs:comment 'Free-text notes entered by the receiving associate documenting special conditions, discrepancy details, handling instructions, or other observations at the time of receipt. Supports discrepancy investigation and vendor communication.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Externally-known business identifier for the goods receipt document, typically generated by the WMS or ERP upon physical receipt confirmation. Maps to SAP Material Document Number (MBLNR) or Manhattan WMS Receipt Number.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle state of the goods receipt workflow. \'draft\' indicates initiated but not confirmed; \'open\' indicates awaiting physical receipt; \'in_progress\' indicates receiving underway; \'completed\' indicates fully processed and inventory inducted; \'cancelled\' indicates voided; \'on_hold\' indicates paused pending resolution. [ENUM-REF-CANDIDATE: draft|open|in_progress|completed|cancelled|on_hold — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'The principal real-world event timestamp recording when the physical merchandise was received and confirmed at the receiving node (DC, store, or MFC). Distinct from system audit timestamps. Maps to SAP Posting Date/Time in MIGO.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivedQty rdf:type rdf:Property ;
    rdfs:label 'Received Qty' ;
    rdfs:comment 'Total quantity of units physically counted and received at the dock, prior to quality inspection. Includes all units regardless of condition. Used as the gross receipt quantity for inventory induction and discrepancy calculation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingNodeType rdf:type rdf:Property ;
    rdfs:label 'Receiving Node Type' ;
    rdfs:comment 'Classification of the physical location type where goods were received. \'dc\' = Distribution Center; \'store\' = retail store; \'mfc\' = Micro-Fulfillment Center; \'dark_store\' = fulfillment-only location. Determines applicable receiving workflows and inventory induction rules.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedQty rdf:type rdf:Property ;
    rdfs:label 'Rejected Qty' ;
    rdfs:comment 'Quantity of units rejected during quality inspection and not inducted into inventory. Drives Return to Vendor (RTV) processing, vendor compliance chargebacks, and RMA initiation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfidVerified rdf:type rdf:Property ;
    rdfs:label 'Rfid Verified' ;
    rdfs:comment 'Indicates whether the received merchandise was verified using RFID (Radio Frequency Identification) scanning during the receiving process. True = RFID scan confirmed; False = manual or barcode-only verification. Supports inventory accuracy at point of induction.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rtvInitiated rdf:type rdf:Property ;
    rdfs:label 'Rtv Initiated' ;
    rdfs:comment 'Indicates whether a Return to Vendor (RTV) process has been initiated for rejected units from this goods receipt. True = RTV in progress; False = no RTV initiated. Supports reverse logistics and vendor debit memo processing.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortageQty rdf:type rdf:Property ;
    rdfs:label 'Shortage Qty' ;
    rdfs:comment 'Quantity of units short-shipped relative to the ASN or PO expectation (expected_qty minus received_qty when negative). Used for vendor compliance chargeback calculation and fill rate reporting.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReceiptCost rdf:type rdf:Property ;
    rdfs:label 'Total Receipt Cost' ;
    rdfs:comment 'Total cost of accepted merchandise received (accepted_qty × unit_cost). Used for inventory valuation, COGS posting, and financial reconciliation. Classified as confidential due to commercial sensitivity.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address of the inventory node facility. Used for carrier routing, last-mile delivery coordination, and regulatory filings.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address detail (suite, dock number, building identifier) for the inventory node facility.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountFrequency rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency' ;
    rdfs:comment 'Scheduled frequency at which physical inventory cycle counts are conducted at this node. Drives WMS task scheduling and shrinkage monitoring cadence.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:districtCode rdf:type rdf:Property ;
    rdfs:label 'District Code' ;
    rdfs:comment 'Internal district code within a region, used for field management span-of-control, district-level KPI reporting, and workforce scheduling via Workday HCM.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatCode rdf:type rdf:Property ;
    rdfs:label 'Format Code' ;
    rdfs:comment 'Retail format identifier assigned to the node (e.g., \'HYPERMARKET\', \'DISCOUNT\', \'DEPT_STORE\', \'ECOMM_FC\'). Drives assortment breadth/depth rules in ORMS and planogram (POG) assignments.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gln rdf:type rdf:Property ;
    rdfs:label 'Gln' ;
    rdfs:comment 'GS1-issued 13-digit Global Location Number uniquely identifying this node in the global supply chain. Used in EDI transactions (ASC X12 / EDIFACT), RFID-based receiving, and supplier communications.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDropShipOrigin rdf:type rdf:Property ;
    rdfs:label 'Is Drop Ship Origin' ;
    rdfs:comment 'Indicates whether this node acts as a drop-ship origin point where a vendor ships directly to the end customer on behalf of the retailer, bypassing DC inventory.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVmiEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Vmi Enabled' ;
    rdfs:comment 'Indicates whether this node participates in a Vendor Managed Inventory (VMI) program where the supplier is responsible for maintaining stock levels.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxSkuCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Sku Capacity' ;
    rdfs:comment 'Maximum number of distinct SKUs (Stock Keeping Units) the node can actively stock based on shelf slots, bin locations, and planogram (POG) configuration. Used in assortment planning and OTB (Open to Buy) calculations.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current lifecycle state of the inventory node. Controls whether the node is eligible to receive stock, fulfill orders, or appear in replenishment plans. Serves as the LIFECYCLE_STATUS (MASTER_RESOURCE canonical category).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Legal ownership or operating arrangement for the node facility. Drives lease accounting under FASB ASC 842, asset capitalization rules, and P&L cost allocation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDcNodeCode rdf:type rdf:Property ;
    rdfs:label 'Primary Dc Node Code' ;
    rdfs:comment 'Node code of the primary Distribution Center (DC) that replenishes this node. Used in replenishment routing, inbound appointment scheduling, and supply chain network optimization.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Replenishment Lead Time Days' ;
    rdfs:comment 'Standard number of days from replenishment order placement to stock receipt at this node. Used by Blue Yonder Demand Planning to calculate reorder points, weeks of supply (WOS), and safety stock levels.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockDays rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Days' ;
    rdfs:comment 'Minimum days of supply maintained as safety stock buffer at this node to protect against demand variability and supply disruptions. Feeds Blue Yonder replenishment planning and WOS calculations.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sellingAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Selling Area Sqft' ;
    rdfs:comment 'Net selling floor area in square feet, excluding back-of-house, receiving docks, and storage. Used for sales-per-square-foot KPI, planogram space allocation, and GMROI analysis.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Secondary classification providing finer granularity within node_type (e.g., hypermarket, department_store, discount_outlet, cross_dock_dc, ambient_dc, cold_chain_dc, ship_from_store_hub). [ENUM-REF-CANDIDATE: hypermarket|department_store|discount_outlet|cross_dock_dc|ambient_dc|cold_chain_dc|ship_from_store_hub|ecommerce_fc — promote to reference product]' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalStorageCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Total Storage Capacity Sqft' ;
    rdfs:comment 'Total physical storage area of the node measured in square feet. Used for capacity planning, space utilization analysis, and GMROI calculations. Serves as the MEASUREMENT_OR_VALUE (MASTER_RESOURCE canonical category).' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotId rdf:type rdf:Property ;
    rdfs:label 'Lot Id' ;
    rdfs:comment 'Unique identifier for the inventory lot or batch record. Primary key for the lot entity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'Current quantity available for sale or allocation from this lot. Decreases as units are sold or reserved.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationCode rdf:type rdf:Property ;
    rdfs:label 'Certification Code' ;
    rdfs:comment 'Product certification or compliance code for the lot. Examples: organic, kosher, halal, fair trade, non-GMO. Supports labeling and marketing claims.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO country code indicating where the product was manufactured or grown. Required for customs and labeling compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResult rdf:type rdf:Property ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Detailed outcome or notes from the quality inspection process. Captures defects, non-conformances, or approval notes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecalled rdf:type rdf:Property ;
    rdfs:label 'Is Recalled' ;
    rdfs:comment 'Indicates whether this lot is subject to a product recall. True if recalled; false otherwise. Triggers immediate hold and customer notification.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Status' ;
    rdfs:comment 'Current lifecycle status of the lot. Determines whether the lot is available for sale, held for quality inspection, or restricted. [ENUM-REF-CANDIDATE: available|quarantine|hold|released|expired|recalled|disposed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Status' ;
    rdfs:comment 'Quality inspection outcome for the lot. Approved lots are available for sale; rejected lots must be returned or disposed.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Remaining Shelf Life Days' ;
    rdfs:comment 'Number of days remaining until expiry as of the current date. Calculated field used for near-expiry alerts and markdown triggers.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Warehouse bin, zone, or storage location where the lot is physically stored. Supports pick/pack operations and cycle counting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierLotReference rdf:type rdf:Property ;
    rdfs:label 'Supplier Lot Reference' ;
    rdfs:comment 'Supplier\'s original lot or batch identifier. Used for traceability back to the supplier\'s manufacturing records.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPolicyId rdf:type rdf:Property ;
    rdfs:label 'Reorder Policy Id' ;
    rdfs:comment 'Unique surrogate identifier for the reorder policy record. Primary key for the reorder_policy data product in the inventory domain.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReorderPolicy .

ind:isAutoReplenishment rdf:type rdf:Property ;
    rdfs:label 'Is Auto Replenishment' ;
    rdfs:comment 'Indicates whether replenishment orders are automatically generated and submitted when the reorder trigger is breached (True), or whether a replenishment planner must manually review and approve the suggested order (False).' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSeasonal rdf:type rdf:Property ;
    rdfs:label 'Is Seasonal' ;
    rdfs:comment 'Indicates whether this reorder policy applies seasonal adjustments to replenishment parameters (e.g., elevated safety stock or WOS targets during peak seasons). When True, seasonal override parameters may be applied by the replenishment engine.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'The most recent date on which a replenishment planner reviewed and validated the parameters of this reorder policy. Supports governance and audit of policy maintenance cadence.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'The expected number of calendar days from placement of a replenishment purchase order to receipt of goods at the destination location. Used to calculate the reorder point and ensure stock does not fall below safety stock during the replenishment cycle.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Max Stock Quantity' ;
    rdfs:comment 'The maximum allowable on-hand inventory level (in units) for this SKU at this location. Used in min/max reorder method as the upper bound. Replenishment orders are sized to bring stock up to this level without exceeding it.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Min Stock Quantity' ;
    rdfs:comment 'The minimum allowable on-hand inventory level (in units) for this SKU at this location. Used in min/max reorder method as the lower bound. Stock falling below this level triggers an urgent replenishment order.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moq rdf:type rdf:Property ;
    rdfs:label 'Moq' ;
    rdfs:comment 'The minimum number of units that must be ordered per replenishment order as stipulated by the supplier contract. Replenishment engine enforces this floor when generating inventory_replenishment_order records.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderMultiple rdf:type rdf:Property ;
    rdfs:label 'Order Multiple' ;
    rdfs:comment 'The quantity increment in which orders must be placed, reflecting the supplier\'s case pack size or Minimum Order Quantity (MOQ). All replenishment order quantities are rounded up to the nearest multiple of this value to comply with supplier constraints.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderQuantity rdf:type rdf:Property ;
    rdfs:label 'Order Quantity' ;
    rdfs:comment 'The fixed quantity (in units) to order each time a replenishment trigger is activated. Used for fixed_quantity reorder method. For other methods, this field may be null and the order quantity is dynamically calculated.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:policyVersion rdf:type rdf:Property ;
    rdfs:label 'Policy Version' ;
    rdfs:comment 'Incrementing version number for this reorder policy record, incremented each time parameters are materially changed. Supports policy change history tracking and rollback capability for replenishment planners.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reorderMethod rdf:type rdf:Property ;
    rdfs:label 'Reorder Method' ;
    rdfs:comment 'The replenishment calculation method applied by this policy: min_max (reorder when stock falls below minimum, order up to maximum), days_of_supply (maintain a target number of days of inventory), wos_based (Weeks of Supply (WOS) target), forecast_driven (demand forecast from Blue Yonder), fixed_quantity (constant order quantity), vendor_managed (VMI — Vendor Managed Inventory where supplier controls replenishment). [ENUM-REF-CANDIDATE: min_max|days_of_supply|wos_based|forecast_driven|fixed_quantity|vendor_managed — promote to reference product]' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPointQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Quantity' ;
    rdfs:comment 'The on-hand stock level (in units) at which a replenishment order is automatically triggered. When the stock_position in inventory falls at or below this threshold, an inventory_replenishment_order record is generated. Core parameter for min/max and fixed-quantity reorder methods.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewCycleDays rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Days' ;
    rdfs:comment 'The frequency in calendar days at which the replenishment engine evaluates this policy and checks whether a reorder trigger has been breached. Defines the periodic review interval (e.g., daily=1, weekly=7, bi-weekly=14).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'Buffer stock quantity (in units) maintained above the reorder point to protect against demand variability and supply lead time uncertainty. Prevents stockouts during replenishment cycles. A key input to the reorder point calculation.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetDaysOfSupply rdf:type rdf:Property ;
    rdfs:label 'Target Days Of Supply' ;
    rdfs:comment 'The desired number of days of inventory coverage to maintain at this location for this SKU. Used in days_of_supply reorder method to calculate the replenishment order quantity based on forecasted daily demand.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetWos rdf:type rdf:Property ;
    rdfs:label 'Target Wos' ;
    rdfs:comment 'The desired number of weeks of inventory coverage (Weeks of Supply — WOS) to maintain at this location for this SKU. Used in wos_based reorder method. Replenishment orders are sized to achieve this WOS target based on forecasted weekly demand.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByAssociateId rdf:type rdf:Property ;
    rdfs:label 'Created By Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Manual and emergency replenishment orders should track the creating associate for performance analysis, process improvement, and training needs assessment. Critical for understanding replenishment dec' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:primaryReplenishmentInventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Replenishment Inventory Node Id' ;
    rdfs:comment 'Reference to the originating fulfillment node (Distribution Center, Micro-Fulfillment Center, or supplier location) from which inventory will be shipped. Supports omnichannel inventory routing logic.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:supplychainEdiTransactionId rdf:type rdf:Property ;
    rdfs:label 'Supplychain Edi Transaction Id' ;
    rdfs:comment 'Reference to the EDI transaction record used to transmit this replenishment order to the supplier via Electronic Data Interchange (EDI). Links to the supplychain.supplychain_edi_transaction product for end-to-end EDI traceability. Nullable for non-EDI orders.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplychainEdiTransaction .

ind:approvedQuantity rdf:type rdf:Property ;
    rdfs:label 'Approved Quantity' ;
    rdfs:comment 'The quantity confirmed and approved for fulfillment after supplier acceptance, MOQ compliance checks, and buyer review. May differ from ordered_quantity due to supplier constraints or buyer adjustments.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyerNotes rdf:type rdf:Property ;
    rdfs:label 'Buyer Notes' ;
    rdfs:comment 'Free-text notes entered by the merchandise buyer or replenishment analyst providing context for manual overrides, special handling instructions, or supplier communication details for this replenishment order.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'The date and time the replenishment order was cancelled, if applicable. Nullable for active or completed orders. Used for supplier chargeback processing and demand planning feedback loops.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'The anticipated date on which the replenishment order is expected to arrive at the destination node, calculated from order_date plus lead_time_days. Used for inventory availability planning and receiving dock scheduling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isEmergency rdf:type rdf:Property ;
    rdfs:label 'Is Emergency' ;
    rdfs:comment 'Indicates whether this replenishment order was flagged as an emergency order due to an imminent or active out-of-stock situation. Emergency orders bypass standard lead time and approval workflows. True = emergency; False = standard.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVmi rdf:type rdf:Property ;
    rdfs:label 'Is Vmi' ;
    rdfs:comment 'Indicates whether this replenishment order is managed under a Vendor Managed Inventory (VMI) agreement where the supplier is responsible for maintaining stock levels at the destination node. True = VMI order; False = retailer-managed replenishment.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moqCompliant rdf:type rdf:Property ;
    rdfs:label 'Moq Compliant' ;
    rdfs:comment 'Indicates whether the ordered_quantity meets or exceeds the supplier\'s Minimum Order Quantity (MOQ) requirement. True = compliant; False = below MOQ threshold, requiring buyer review or override.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally-known business identifier for the replenishment order, sourced from Blue Yonder Demand Planning or SAP S/4HANA MM module. Used for cross-system traceability and supplier communication via EDI.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle state of the replenishment order. Tracks progression from draft creation through approval, shipment, receipt at destination node, and closure. Cancelled indicates the order was voided before fulfillment. [ENUM-REF-CANDIDATE: draft|submitted|approved|in_transit|received|partially_received|cancelled|closed — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of how the replenishment order was triggered. Auto-replenishment is system-generated based on reorder policy thresholds; manual is buyer-initiated; VMI (Vendor Managed Inventory) is supplier-driven; emergency covers urgent out-of-stock situations; cross_dock bypasses DC storage; drop_ship routes directly from vendor to destination. [ENUM-REF-CANDIDATE: auto_replenishment|manual|vmi|emergency|cross_dock|drop_ship — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'The quantity of the SKU originally requested in the replenishment order, expressed in the SKU\'s base unit of measure (e.g., each, case, pallet). This is the raw demand signal before supplier approval or MOQ adjustment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'The actual quantity of the SKU physically received and confirmed at the destination node. Used to calculate fill rate and identify short shipments. Populated upon goods receipt in Manhattan Associates WMS or SAP S/4HANA WM.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemOrderRef rdf:type rdf:Property ;
    rdfs:label 'Source System Order Ref' ;
    rdfs:comment 'The native order identifier from the originating source system (e.g., SAP MM document number, Blue Yonder order ID, ORMS order number). Enables reverse lookup and reconciliation with the system of record.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrderCost rdf:type rdf:Property ;
    rdfs:label 'Total Order Cost' ;
    rdfs:comment 'The total cost of the replenishment order calculated as approved_quantity multiplied by unit_cost. Represents the financial commitment for this replenishment event. Used for Open to Buy (OTB) budget tracking and P&L reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerType rdf:type rdf:Property ;
    rdfs:label 'Trigger Type' ;
    rdfs:comment 'The mechanism that triggered this replenishment order. reorder_point = on-hand fell below reorder point threshold; min_max = inventory fell below minimum level; days_of_supply = Weeks of Supply (WOS) fell below threshold; manual_override = buyer-initiated; vmi_signal = Vendor Managed Inventory (VMI) supplier signal; promotional = triggered by upcoming promotion event. [ENUM-REF-CANDIDATE: reorder_point|min_max|days_of_supply|manual_override|vmi_signal|promotional — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationId rdf:type rdf:Property ;
    rdfs:label 'Reservation Id' ;
    rdfs:comment 'Unique system-generated identifier for each inventory reservation or hold record. Primary key for the reservation data product.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfidTagId rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Id' ;
    rdfs:comment 'RFID tag identifier associated with the specific unit(s) reserved, enabling item-level tracking and automated hold verification. Populated when RFID-based inventory tracking is active at the node. Supports real-time inventory visibility for omnichannel fulfillment.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RfidTag .

ind:authorizingDepartment rdf:type rdf:Property ;
    rdfs:label 'Authorizing Department' ;
    rdfs:comment 'Name or code of the business department that authorized the hold (e.g., Quality Assurance, Legal, Compliance, Store Operations, E-Commerce Fulfillment). Supports departmental accountability reporting and hold resolution workflows.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Case Reference Number' ;
    rdfs:comment 'Reference to the service case, quality investigation, legal matter, or regulatory recall case that authorized a hard hold. Populated for quality_hold, legal_hold, regulatory_recall, and damage_hold encumbrance types. Links to Salesforce Service Cloud case management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encumbranceType rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Type' ;
    rdfs:comment 'Classifies the nature of the inventory encumbrance. Soft allocations (e.g., BOPIS reservation, ship-from-store allocation, e-commerce hold) are temporary and customer-driven; hard holds (quality hold, regulatory recall, legal hold, damage hold, price investigation) restrict stock from sale pending resolution. [ENUM-REF-CANDIDATE: soft_allocation|hard_hold|quality_hold|regulatory_recall|legal_hold|damage_hold|price_investigation — promote to reference product]' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'Standardized code identifying the specific business reason for the reservation or hold (e.g., BOPIS_ALLOC, SFS_ALLOC, ECOM_HOLD, QA_FAIL, RECALL_CPSC, LEGAL_HOLD, DMG_INBOUND, PRICE_INVEST). Enables operational reporting and root-cause analysis of inventory encumbrances.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Description' ;
    rdfs:comment 'Free-text narrative describing the specific reason for the inventory hold or reservation, providing operational context beyond the structured hold_reason_code. Required for legal holds and regulatory recalls per compliance documentation standards.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseNotes rdf:type rdf:Property ;
    rdfs:label 'Release Notes' ;
    rdfs:comment 'Free-text field capturing resolution details, disposition instructions, or compliance notes recorded at the time of hold release. Required for regulatory recalls and legal holds to document the resolution rationale for audit purposes.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Approval workflow status for releasing a hard hold. \'pending\' — release request submitted awaiting authorization; \'approved\' — release authorized by responsible department; \'rejected\' — release denied, hold remains active; \'auto_released\' — system-triggered release upon expiry or order fulfillment; \'escalated\' — requires senior authorization.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'Actual date and time when the reservation was released, cancelled, or converted. Null while the reservation is active. Used for hold duration analysis, SLA compliance reporting, and ATP recalculation upon release.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'Externally-visible, human-readable business identifier for the reservation, used in operational communications, order management, and customer-facing references (e.g., BOPIS confirmation codes). Sourced from OMS or WMS upon creation.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationStatus rdf:type rdf:Property ;
    rdfs:label 'Reservation Status' ;
    rdfs:comment 'Current lifecycle state of the inventory reservation. \'active\' — stock is currently encumbered; \'expired\' — reservation lapsed past expiry without fulfillment; \'released\' — hold manually or systematically lifted; \'cancelled\' — reservation voided before fulfillment; \'pending_release\' — awaiting authorization to release; \'converted\' — soft allocation fulfilled and converted to a shipment.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reservation Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone offset) when the inventory encumbrance was created — the principal business event timestamp. For BOPIS/e-commerce holds, this is when the customer completed checkout. For quality/legal holds, this is when the hold was authorized.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Number of units of the SKU encumbered by this reservation. Subtracted from on-hand quantity to derive ATP (Available to Promise) on the stock_position product. Must be positive and not exceed available on-hand at time of reservation creation.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:associatedOrderOrderHeaderId rdf:type rdf:Property ;
    rdfs:label 'Associated Order Order Header Id' ;
    rdfs:comment 'Reference to the purchase order or fulfillment order with which this RFID tag is associated, enabling traceability from supplier shipment through DC receiving to store floor. Supports BOPIS, ship-from-store, and DSD tracking.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:primaryRfidEncodingLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Rfid Encoding Location Id' ;
    rdfs:comment 'Reference to the facility or node (store, DC, MFC, or supplier site) where the RFID tag was encoded. Supports encoding quality audits, location-based defect analysis, and supply chain traceability.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:tertiaryRfidLocationId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Rfid Location Id' ;
    rdfs:comment 'Reference to the retail store where the RFID tag is currently assigned or was last associated. Supports store-level inventory visibility, cycle count reconciliation, and omnichannel fulfillment (BOPIS, ROPIS, ship-from-store).' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether the RFID tag meets the retailer\'s supplier compliance requirements (e.g., correct EPC encoding, approved tag model, proper placement). Non-compliant tags may trigger chargebacks to the supplier per vendor compliance agreements.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decommissionReason rdf:type rdf:Property ;
    rdfs:label 'Decommission Reason' ;
    rdfs:comment 'The business reason for decommissioning the RFID tag. Sold indicates the item was purchased and the tag was killed at POS; returned indicates a customer return; damaged indicates physical tag failure; lost indicates the tag cannot be located; recalled indicates a product recall; expired indicates end of product shelf life; retagged indicates the item was assigned a new tag. [ENUM-REF-CANDIDATE: sold|returned|damaged|lost|recalled|expired|retagged — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decommission Timestamp' ;
    rdfs:comment 'The date and time when the RFID tag was decommissioned or killed. Supports tag lifecycle reporting, shrinkage analysis, and audit trail requirements.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:encodingDate rdf:type rdf:Property ;
    rdfs:label 'Encoding Date' ;
    rdfs:comment 'The date and time when the RFID tag was encoded with its EPC and associated product data. Supports tag age analysis, encoding throughput reporting, and traceability back to the encoding event.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:encodingStandard rdf:type rdf:Property ;
    rdfs:label 'Encoding Standard' ;
    rdfs:comment 'The GS1 EPC encoding scheme used to write the Electronic Product Code onto the tag (e.g., SGTIN-96 for serialized trade items, SSCC-96 for shipping containers, GIAI-96 for individual assets). Determines how the EPC is decoded and interpreted by readers.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epcCode rdf:type rdf:Property ;
    rdfs:label 'Epc Code' ;
    rdfs:comment 'The globally unique Electronic Product Code encoded on the RFID tag, conforming to GS1 EPC standards (e.g., SGTIN-96, SSCC-96). Serves as the primary business identifier for the tag and enables interoperability across supply chain partners and retail nodes.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epcMemoryBankSize rdf:type rdf:Property ;
    rdfs:label 'Epc Memory Bank Size' ;
    rdfs:comment 'The size in bits of the EPC memory bank on the RFID tag chip. Determines the maximum length of the EPC that can be stored and influences encoding standard selection.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyBand rdf:type rdf:Property ;
    rdfs:label 'Frequency Band' ;
    rdfs:comment 'The radio frequency band used by the RFID tag: UHF (Ultra High Frequency, 860-960 MHz, most common in retail supply chain), HF (High Frequency, 13.56 MHz, used in apparel and library), LF (Low Frequency, 125-134 kHz), or NFC (Near Field Communication). Determines reader compatibility and read range.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPasswordProtected rdf:type rdf:Property ;
    rdfs:label 'Is Password Protected' ;
    rdfs:comment 'Indicates whether the RFID tag has an access or kill password set to restrict read/write operations. Supports tag security policy compliance and anti-counterfeiting measures.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:killPasswordSet rdf:type rdf:Property ;
    rdfs:label 'Kill Password Set' ;
    rdfs:comment 'Indicates whether a kill password has been programmed on the tag, enabling permanent deactivation at point of sale for consumer privacy compliance. Required for GDPR and CCPA compliance in item-level RFID deployments.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastScanTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Scan Timestamp' ;
    rdfs:comment 'The date and time of the most recent successful RFID read event for this tag. Used to determine tag freshness, identify lost or missing tags, and support cycle count reconciliation.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastScanZone rdf:type rdf:Property ;
    rdfs:label 'Last Scan Zone' ;
    rdfs:comment 'The specific zone or area within the last scan location where the tag was read (e.g., receiving dock, sales floor, backroom, fitting room, shipping dock). Provides sub-location granularity for inventory positioning and planogram compliance.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readCount rdf:type rdf:Property ;
    rdfs:label 'Read Count' ;
    rdfs:comment 'The total number of times this RFID tag has been successfully read since encoding. Supports tag durability analysis, read rate benchmarking, and identification of high-traffic inventory items.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:readErrorCount rdf:type rdf:Property ;
    rdfs:label 'Read Error Count' ;
    rdfs:comment 'The cumulative number of failed or erroneous read attempts recorded for this RFID tag. High error counts indicate tag damage, interference issues, or reader calibration problems requiring investigation.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:readerCode rdf:type rdf:Property ;
    rdfs:label 'Reader Code' ;
    rdfs:comment 'Identifier of the RFID reader device that performed the last successful scan of this tag. Supports reader performance monitoring, read rate analysis, and hardware maintenance scheduling.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidProgramType rdf:type rdf:Property ;
    rdfs:label 'Rfid Program Type' ;
    rdfs:comment 'Identifies the tagging program under which this RFID tag was applied: source_tagging (applied at manufacturer/supplier), store_tagging (applied at retail store), dc_tagging (applied at distribution center), or supplier_tagging (applied at supplier DC). Influences cost allocation, compliance tracking, and tag quality benchmarking.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalStrengthDbm rdf:type rdf:Property ;
    rdfs:label 'Signal Strength Dbm' ;
    rdfs:comment 'The received signal strength indicator (RSSI) in decibel-milliwatts (dBm) recorded during the last successful RFID read. Used for reader placement optimization, read zone calibration, and tag quality assessment.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tagManufacturer rdf:type rdf:Property ;
    rdfs:label 'Tag Manufacturer' ;
    rdfs:comment 'Name of the manufacturer or vendor who produced the physical RFID tag inlay or label (e.g., Impinj, Alien Technology, Avery Dennison). Used for vendor performance tracking, defect rate analysis, and procurement decisions.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagModel rdf:type rdf:Property ;
    rdfs:label 'Tag Model' ;
    rdfs:comment 'The specific model or part number of the RFID tag inlay or label (e.g., Impinj Monza R6, Alien Higgs-9). Supports hardware compatibility analysis, read performance benchmarking, and tag lifecycle management.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Tag Serial Number' ;
    rdfs:comment 'Manufacturer-assigned serial number printed or encoded on the physical RFID tag inlay or label. Used for hardware traceability, warranty claims, and tag defect analysis.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagStatus rdf:type rdf:Property ;
    rdfs:label 'Tag Status' ;
    rdfs:comment 'Current lifecycle state of the RFID tag. Active tags are in use and trackable; decommissioned tags have been retired from service; lost tags have not been scanned within the expected window; damaged tags have failed read/write operations; unassigned tags have been encoded but not yet associated with inventory.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagType rdf:type rdf:Property ;
    rdfs:label 'Tag Type' ;
    rdfs:comment 'Indicates the granularity level at which the RFID tag is applied: item-level (individual SKU unit), case-level (shipping case), pallet-level (full pallet), or tote-level (reusable tote). Drives cycle count logic, inventory aggregation rules, and omnichannel fulfillment visibility.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userMemoryData rdf:type rdf:Property ;
    rdfs:label 'User Memory Data' ;
    rdfs:comment 'Optional data written to the user memory bank of the RFID tag, beyond the EPC. May contain additional product attributes, batch/lot numbers, or supply chain event data encoded by the retailer or supplier.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedTransactionStockLedgerId rdf:type rdf:Property ;
    rdfs:label 'Reversed Transaction Stock Ledger Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original stock_ledger_id that this record reverses. Populated only when reversal_flag = True. Enables bidirectional audit trail linking between original and reversal entries.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockLedger .

ind:deadStockFlag rdf:type rdf:Property ;
    rdfs:label 'Dead Stock Flag' ;
    rdfs:comment 'Indicates whether this stock movement is associated with dead stock (unsold, obsolete inventory being written off or liquidated). True = dead stock write-off or clearance movement. Supports inventory health reporting and markdown decision-making.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dsdFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Flag' ;
    rdfs:comment 'Indicates whether this receipt transaction was fulfilled via Direct Store Delivery (DSD), where the supplier delivers directly to the store bypassing the Distribution Center (DC). True = DSD transaction. Impacts supply chain routing and vendor compliance tracking.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extendedRetailValue rdf:type rdf:Property ;
    rdfs:label 'Extended Retail Value' ;
    rdfs:comment 'Total retail value of this stock movement, calculated as movement_quantity multiplied by unit_retail_price. Used in the retail inventory method for inventory valuation and supports gross margin return on investment (GMROI) reporting.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movementQuantity rdf:type rdf:Property ;
    rdfs:label 'Movement Quantity' ;
    rdfs:comment 'The quantity of units moved in this transaction. Positive values indicate stock increases (receipts, returns, transfer-in); negative values indicate stock decreases (sales, write-offs, transfer-out). Expressed in the SKU\'s base unit of measure.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movementReasonCode rdf:type rdf:Property ;
    rdfs:label 'Movement Reason Code' ;
    rdfs:comment 'Standardized reason code providing additional context for the stock movement (e.g., VENDOR_RETURN, DAMAGED_GOODS, CYCLE_COUNT_VARIANCE, THEFT_SHRINKAGE, EXPIRED_PRODUCT, PROMOTIONAL_WRITE_DOWN). Supports shrinkage analysis and loss prevention reporting. [ENUM-REF-CANDIDATE: VENDOR_RETURN|DAMAGED_GOODS|CYCLE_COUNT_VARIANCE|THEFT_SHRINKAGE|EXPIRED_PRODUCT|PROMOTIONAL_WRITE_DOWN|CUSTOMER_RETURN|INTER_DC_TRANSFER — promote to reference product]' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onHandQuantityAfter rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity After' ;
    rdfs:comment 'The total on-hand inventory quantity for this SKU at this location immediately after this transaction was applied. Represents the running balance of the perpetual inventory ledger and is the authoritative stock position for omnichannel fulfillment visibility.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandQuantityBefore rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity Before' ;
    rdfs:comment 'The total on-hand inventory quantity for this SKU at this location immediately before this transaction was applied. Enables point-in-time inventory reconstruction and audit trail validation of the perpetual ledger.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'The type of source document associated with this stock movement (e.g., PURCHASE_ORDER, TRANSFER_ORDER, POS_RECEIPT, RMA = Return Merchandise Authorization, CYCLE_COUNT, WRITE_OFF_ORDER). Enables document-level drill-through for audit and reconciliation.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTracked rdf:type rdf:Property ;
    rdfs:label 'Rfid Tracked' ;
    rdfs:comment 'Indicates whether this stock movement was captured or validated using Radio Frequency Identification (RFID) technology. True = RFID-confirmed movement. Supports inventory accuracy benchmarking and RFID program performance reporting.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shrinkageFlag rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Flag' ;
    rdfs:comment 'Indicates whether this stock movement represents inventory shrinkage (loss due to theft, damage, administrative error, or vendor fraud). True = shrinkage event. Used for shrinkage monitoring, loss prevention analytics, and CPSC/NRF compliance reporting.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Externally-known business identifier for this stock movement transaction, sourced from the originating system (e.g., SAP material document number, ORMS transaction reference). Used for cross-system reconciliation and audit tracing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'The precise real-world date and time when the stock movement event occurred (e.g., POS scan time, receiving dock timestamp, cycle count completion time). This is the principal business event time, distinct from system audit timestamps.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unitRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Retail Price' ;
    rdfs:comment 'The retail selling price per unit at the time of the transaction. Used for inventory valuation under the retail inventory method and for calculating gross margin. Supports Average Unit Retail (AUR) analytics and sell-through rate calculations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'The inventory costing method applied to this stock movement for financial valuation purposes. FIFO = First In First Out; WAC = Weighted Average Cost; RETAIL_METHOD = retail inventory method; LIFO = Last In First Out (where permitted); SPECIFIC_ID = specific identification for high-value items.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmfFlag rdf:type rdf:Property ;
    rdfs:label 'Vmf Flag' ;
    rdfs:comment 'Indicates whether this stock movement is part of a Vendor Managed Inventory (VMI) arrangement, where the supplier is responsible for maintaining stock levels. True = VMI-managed transaction. Impacts replenishment ownership and supplier performance tracking.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availableToPromiseQty rdf:type rdf:Property ;
    rdfs:label 'Available To Promise Qty' ;
    rdfs:comment 'Quantity of the SKU available to commit to new customer orders or fulfillment requests. Calculated as on-hand minus reserved, damaged, and quarantine quantities. Authoritative ATP signal consumed by Salesforce Commerce Cloud for omnichannel order promising (BOPIS, ROPIS, Ship-from-Store).' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgDailySalesQty rdf:type rdf:Property ;
    rdfs:label 'Avg Daily Sales Qty' ;
    rdfs:comment 'Rolling average quantity of the SKU sold per day at this node, calculated from SAP Customer Activity Repository (CAR) POS transaction data. Used to compute Weeks of Supply (WOS), reorder point, and safety stock. Input to Blue Yonder Demand Planning forecasts.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damagedQty rdf:type rdf:Property ;
    rdfs:label 'Damaged Qty' ;
    rdfs:comment 'Quantity of the SKU identified as damaged, defective, or unsellable at the inventory node. Excluded from Available-to-Promise (ATP) calculations. Tracked for shrinkage reporting, Return to Vendor (RTV) processing, and COGS (Cost of Goods Sold) write-down.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inTransitQty rdf:type rdf:Property ;
    rdfs:label 'In Transit Qty' ;
    rdfs:comment 'Quantity of the SKU currently in transit from a supplier, Distribution Center (DC), or another node and expected to arrive at this inventory node. Sourced from Blue Yonder Demand Planning and SAP S/4HANA WM transfer orders. Used for future ATP projection.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryValuationMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Method' ;
    rdfs:comment 'Accounting method used to value this SKU\'s inventory for financial reporting. FIFO (First In First Out), LIFO (Last In First Out), WAC (Weighted Average Cost), standard_cost, or retail_method. Governed by FASB ASC 330 and reported in financial P&L statements.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeadStock rdf:type rdf:Property ;
    rdfs:label 'Is Dead Stock' ;
    rdfs:comment 'Flag indicating whether this SKU at this node is classified as dead stock — unsold, obsolete inventory with no recent sales velocity. True when sell-through rate is zero and weeks of supply exceeds the dead stock threshold. Triggers markdown or clearance actions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAdjustmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Adjustment Date' ;
    rdfs:comment 'Date of the most recent manual or system-generated inventory adjustment (positive or negative) for this SKU at this node. Adjustments include shrinkage write-offs, cycle count corrections, and damage write-downs posted in SAP S/4HANA MM.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastGoodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Receipt Date' ;
    rdfs:comment 'Date of the most recent goods receipt (inbound delivery) that updated the on-hand quantity for this SKU at this node. Sourced from SAP S/4HANA MM goods receipt postings and Manhattan Associates WMS inbound transactions. Used for freshness and lead time analysis.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSaleDate rdf:type rdf:Property ;
    rdfs:label 'Last Sale Date' ;
    rdfs:comment 'Date of the most recent Point of Sale (POS) or e-commerce sale transaction that depleted stock for this SKU at this node. Sourced from SAP Customer Activity Repository (CAR). Used for dead stock identification, velocity scoring, and markdown trigger analysis.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxStockQty rdf:type rdf:Property ;
    rdfs:label 'Max Stock Qty' ;
    rdfs:comment 'Maximum allowable on-hand quantity for this SKU at this node, used to prevent overstock and optimize shelf/storage capacity. Defined in Oracle Retail Merchandising System (ORMS) and used by replenishment planning to cap order quantities within Open-to-Buy (OTB) constraints.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandQty rdf:type rdf:Property ;
    rdfs:label 'On Hand Qty' ;
    rdfs:comment 'Total physical quantity of the SKU currently present at the inventory node, including all stock categories (sellable, reserved, damaged). Sourced from Manhattan Associates WMS goods receipt and adjustment transactions. Core metric for inventory visibility.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onOrderQty rdf:type rdf:Property ;
    rdfs:label 'On Order Qty' ;
    rdfs:comment 'Quantity of the SKU on open purchase orders or replenishment orders placed with suppliers but not yet shipped. Sourced from Oracle Retail Merchandising System (ORMS) purchase order lines. Represents future supply commitment within the Open-to-Buy (OTB) budget.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle status of the stock position record. Active: normal sellable stock; frozen: temporarily locked pending investigation; quarantine: damaged or suspect stock held for quality review; blocked: SAP-blocked stock not available for sale; closed: position deactivated (zero stock, node closed).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Position Timestamp' ;
    rdfs:comment 'The precise date and time at which this stock position snapshot was captured or last updated. Represents the real-world event time of the inventory state. Critical for real-time ATP (Available-to-Promise) accuracy and omnichannel fulfillment SLA compliance.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quarantineQty rdf:type rdf:Property ;
    rdfs:label 'Quarantine Qty' ;
    rdfs:comment 'Quantity of the SKU placed in quarantine pending quality inspection, regulatory hold, or recall investigation. Separate from damaged stock. Relevant for FDA food safety holds, CPSC recall compliance, and supplier quality disputes.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderPointQty rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Qty' ;
    rdfs:comment 'Minimum on-hand quantity threshold at which a replenishment order is automatically triggered for this SKU at this node. Calculated by Blue Yonder Demand Planning based on lead time, demand velocity, and safety stock parameters. Core input to replenishment trigger logic.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentStatus rdf:type rdf:Property ;
    rdfs:label 'Replenishment Status' ;
    rdfs:comment 'Current replenishment workflow status for this SKU-node combination. normal: no action needed; triggered: reorder point breached, order pending; in_progress: replenishment order placed and open; suspended: replenishment paused (e.g., seasonal end, discontinuation); vmi: under Vendor Managed Inventory (VMI) control.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservedQty rdf:type rdf:Property ;
    rdfs:label 'Reserved Qty' ;
    rdfs:comment 'Quantity of the SKU reserved against confirmed customer orders, BOPIS (Buy Online Pick Up In Store), ROPIS (Reserve Online Pick Up In Store), or internal transfer orders. Not available for new ATP commitments until reservation is released or fulfilled.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockQty rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Qty' ;
    rdfs:comment 'Buffer stock quantity maintained above the reorder point to protect against demand variability and supply lead time uncertainty. Set by Blue Yonder Demand Planning. Prevents stockouts during peak demand or supplier delays.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shrinkageQty rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Qty' ;
    rdfs:comment 'Cumulative quantity of inventory loss attributed to shrinkage (theft, administrative error, vendor fraud, or damage) since the last cycle count or physical inventory. Used for shrinkage monitoring, loss prevention analytics, and COGS adjustment reporting.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:velocityBand rdf:type rdf:Property ;
    rdfs:label 'Velocity Band' ;
    rdfs:comment 'ABC/D velocity classification of the SKU at this node based on sales frequency and volume. A: fast-moving (top sellers); B: medium-moving; C: slow-moving; D: very slow or non-moving (dead stock candidate). Used for replenishment prioritization, planogram slotting, and markdown strategy.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weeksOfSupply rdf:type rdf:Property ;
    rdfs:label 'Weeks Of Supply' ;
    rdfs:comment 'Number of weeks the current on-hand quantity is projected to last based on the current average weekly sales velocity. Key inventory health metric (WOS) used by merchants and planners to identify overstock, understock, and dead stock situations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockTransferId rdf:type rdf:Property ;
    rdfs:label 'Stock Transfer Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for each inter-node stock transfer record in the inventory management system.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initiatingAssociateId rdf:type rdf:Property ;
    rdfs:label 'Initiating Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Store-to-store and ship-from-store transfers are initiated by specific associates. Tracking this supports fulfillment performance analytics, operational accountability, and process improvement initiat' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:primaryStockInventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Inventory Node Id' ;
    rdfs:comment 'Identifier of the originating inventory node (store, DC, MFC, or vendor location) from which the stock transfer is dispatched. Supports network balancing and omnichannel fulfillment analytics.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:actualReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Date' ;
    rdfs:comment 'Calendar date on which the stock transfer was physically received and confirmed at the destination node. Compared against expected_receipt_date to measure carrier and DC performance against SLA targets.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Expected Receipt Date' ;
    rdfs:comment 'Planned calendar date by which the stock transfer is expected to arrive at the destination node. Used for replenishment planning, weeks of supply (WOS) calculations, and SLA compliance monitoring.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isShipFromStore rdf:type rdf:Property ;
    rdfs:label 'Is Ship From Store' ;
    rdfs:comment 'Flag indicating whether this stock transfer is part of a ship-from-store (SFS) omnichannel fulfillment flow, where a retail store acts as a fulfillment node dispatching inventory to satisfy an e-commerce or BOPIS order.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidEnabled rdf:type rdf:Property ;
    rdfs:label 'Rfid Enabled' ;
    rdfs:comment 'Flag indicating whether this stock transfer was tracked using RFID (Radio Frequency Identification) technology for real-time inventory visibility during transit. Supports RFID-based inventory accuracy programs.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Date' ;
    rdfs:comment 'Calendar date on which the stock transfer was physically dispatched from the source node. Used for lead time calculation, carrier SLA tracking, and inventory in-transit reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferCost rdf:type rdf:Property ;
    rdfs:label 'Transfer Cost' ;
    rdfs:comment 'Total logistics cost incurred for executing this stock transfer, including carrier freight charges, handling fees, and any 3PL surcharges. Used for inventory valuation (COGS), P&L allocation, and supply chain cost optimization.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Number' ;
    rdfs:comment 'Externally-known business reference number for the stock transfer, used for tracking and communication across supply chain partners, carriers, and store operations. Sourced from SAP S/4HANA MM transfer order numbering.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferQuantity rdf:type rdf:Property ;
    rdfs:label 'Transfer Quantity' ;
    rdfs:comment 'Number of units of the SKU authorized and dispatched in this stock transfer. Represents the planned transfer quantity as recorded at time of transfer creation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferReasonCode rdf:type rdf:Property ;
    rdfs:label 'Transfer Reason Code' ;
    rdfs:comment 'Business reason code explaining why the stock transfer was initiated. REPLENISHMENT: routine inventory restocking; NETWORK_BALANCE: lateral balancing to address overstock/understock; RTV: return to vendor; RECALL: product safety recall per CPSC; DAMAGE_RETURN: return of damaged goods; OMNICHANNEL: ship-from-store or BOPIS fulfillment support.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle state of the stock transfer. DRAFT: initiated but not yet dispatched; IN_TRANSIT: shipment dispatched from source node; RECEIVED: confirmed receipt at destination node; CANCELLED: transfer voided before completion; EXCEPTION: discrepancy or damage reported during transit.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the inter-node inventory movement. DC_TO_STORE: distribution center replenishment to store; STORE_TO_STORE: lateral balancing between stores; STORE_TO_DC: reverse logistics or consolidation; CROSS_DOCK: direct transfer without storage per cross-docking (DSD) model; RTV: Return to Vendor; MFC_TO_STORE: micro-fulfillment center to store for omnichannel fulfillment (ship-from-store).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Reason code explaining the cause of any quantity variance between dispatched and received units. Used for shrinkage root cause analysis, carrier chargeback (RMA) processing, and inventory reconciliation.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiAgreementId rdf:type rdf:Property ;
    rdfs:label 'Vmi Agreement Id' ;
    rdfs:comment 'Unique system-generated identifier for the VMI agreement record. Primary key for the vmi_agreement data product.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VmiAgreement .

ind:primaryBuyerId rdf:type rdf:Property ;
    rdfs:label 'Primary Buyer Id' ;
    rdfs:comment 'Reference to the internal retail buyer or category manager responsible for managing this VMI agreement on behalf of the retailer. Links to the workforce/employee master in Workday HCM.' ;
    rdfs:domain ind:VmiAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Buyer .

ind:primaryVmiVendorId rdf:type rdf:Property ;
    rdfs:label 'Primary Vmi Vendor Id' ;
    rdfs:comment 'Reference to the supplier (vendor) responsible for managing inventory under this VMI agreement. Links to the supplier master record in Informatica MDM and SAP S/4HANA vendor master.' ;
    rdfs:domain ind:VmiAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:vmiVendorId rdf:type rdf:Property ;
    rdfs:label 'Vmi Vendor Id' ;
    rdfs:comment 'FK to supplier.vendor' ;
    rdfs:domain ind:VmiAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known, human-readable reference number for the VMI agreement, used in supplier communications, EDI transactions, and contract documentation. Corresponds to the contract reference in SAP S/4HANA MM module.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the VMI arrangement defining the inventory ownership and replenishment model. Standard VMI transfers replenishment responsibility to the supplier; consignment retains supplier ownership until sold; scan-based trading (SBT) triggers payment at POS scan. [ENUM-REF-CANDIDATE: standard|consignment|scan_based_trading|cross_dock|drop_ship — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewal rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal' ;
    rdfs:comment 'Indicates whether this VMI agreement automatically renews upon reaching the effective_end_date without requiring explicit renegotiation. True enables automatic renewal; False requires manual renewal action before expiry.' ;
    rdfs:domain ind:VmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargebackEnabled rdf:type rdf:Property ;
    rdfs:label 'Chargeback Enabled' ;
    rdfs:comment 'Indicates whether the retailer is contractually permitted to issue Chargebacks (Vendor Compliance Penalties) to the supplier for SLA violations (e.g., missed fill rate, late delivery) under this VMI agreement. True enables chargeback processing; False means no financial penalties apply.' ;
    rdfs:domain ind:VmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargebackRatePct rdf:type rdf:Property ;
    rdfs:label 'Chargeback Rate Pct' ;
    rdfs:comment 'The percentage of the invoice value or a fixed rate applied as a Chargeback (Vendor Compliance Penalty) when the supplier fails to meet SLA thresholds defined in this VMI agreement. Applicable only when chargeback_enabled is True. Commercially sensitive contract term.' ;
    rdfs:domain ind:VmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediTransactionSet rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Set' ;
    rdfs:comment 'The GS1/ASC X12 EDI transaction set number used for inventory data exchange under this VMI agreement (e.g., 852 for Product Activity Data, 855 for Purchase Order Acknowledgment, 856 for Advance Ship Notice). Applicable when inventory_visibility_method is EDI.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryOwnership rdf:type rdf:Property ;
    rdfs:label 'Inventory Ownership' ;
    rdfs:comment 'Defines who holds legal title to the inventory at the covered location under this VMI agreement. Retailer ownership means the retailer takes title upon receipt; supplier ownership (consignment) means the supplier retains title until the item is sold; consignment is a hybrid model with specific transfer-of-title triggers.' ;
    rdfs:domain ind:VmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryVisibilityMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Visibility Method' ;
    rdfs:comment 'The agreed mechanism by which the retailer shares real-time inventory data with the supplier to enable VMI replenishment decisions. EDI (Electronic Data Interchange) uses standardized transaction sets (e.g., 852 Product Activity Data); RFID uses Radio Frequency Identification scanning; API uses direct system integration; portal uses a supplier web portal; manual uses periodic reports.' ;
    rdfs:domain ind:VmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxInventoryUnits rdf:type rdf:Property ;
    rdfs:label 'Max Inventory Units' ;
    rdfs:comment 'The maximum on-hand inventory quantity (in units) allowed at the covered location under the VMI agreement. Exceeding this threshold signals overstock and may require supplier action to reduce inventory. Prevents excess stock and supports GMROI optimization.' ;
    rdfs:domain ind:VmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minInventoryUnits rdf:type rdf:Property ;
    rdfs:label 'Min Inventory Units' ;
    rdfs:comment 'The minimum on-hand inventory quantity (in units) that the supplier must maintain at the covered location. Falling below this threshold triggers a replenishment obligation under the VMI agreement. Supports inventory replenishment planning in Blue Yonder.' ;
    rdfs:domain ind:VmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'The number of calendar days\' advance notice required by either party to terminate or not renew this VMI agreement. Governs the contractual exit process and operational wind-down planning.' ;
    rdfs:domain ind:VmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderTransmissionMethod rdf:type rdf:Property ;
    rdfs:label 'Order Transmission Method' ;
    rdfs:comment 'The agreed channel through which the supplier transmits replenishment purchase orders to the retailer\'s OMS (Order Management System) or ERP under this VMI agreement.' ;
    rdfs:domain ind:VmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Replenishment Frequency' ;
    rdfs:comment 'The agreed cadence at which the supplier reviews inventory levels and initiates replenishment orders under the VMI agreement. Daily and on_demand frequencies are typical for fast-moving consumer goods; weekly or biweekly for slower-moving categories.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycle rdf:type rdf:Property ;
    rdfs:label 'Review Cycle' ;
    rdfs:comment 'The agreed frequency at which the retailer and supplier formally review VMI agreement performance, SLA compliance, and terms. Drives the cadence of supplier performance scorecards and potential agreement amendments.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuScope rdf:type rdf:Property ;
    rdfs:label 'Sku Scope' ;
    rdfs:comment 'Defines the breadth of SKU coverage under this VMI agreement. All_category_skus means the supplier manages all SKUs in the covered category; selected_skus means only specific SKUs are included; new_items_only restricts to newly introduced items; seasonal_only covers seasonal assortment only.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierContactEmail rdf:type rdf:Property ;
    rdfs:label 'Supplier Contact Email' ;
    rdfs:comment 'Email address of the primary supplier contact for VMI replenishment communications and SLA escalations under this agreement.' ;
    rdfs:domain ind:VmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierContactName rdf:type rdf:Property ;
    rdfs:label 'Supplier Contact Name' ;
    rdfs:comment 'Full name of the primary supplier contact responsible for managing inventory replenishment under this VMI agreement. Used for operational communication and escalation.' ;
    rdfs:domain ind:VmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFillRatePct rdf:type rdf:Property ;
    rdfs:label 'Target Fill Rate Pct' ;
    rdfs:comment 'The contractually agreed Fill Rate (Order Completion Percentage) that the supplier must achieve under this VMI agreement, expressed as a percentage (e.g., 98.50 = 98.5%). Fill Rate is the percentage of replenishment orders fulfilled completely and on time. Used as a key SLA (Service Level Agreement) KPI for supplier performance measurement.' ;
    rdfs:domain ind:VmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetInventoryUnits rdf:type rdf:Property ;
    rdfs:label 'Target Inventory Units' ;
    rdfs:comment 'The optimal on-hand inventory quantity (in units) that the supplier aims to maintain at the covered location. Represents the ideal stock position between the minimum and maximum thresholds for service level and working capital balance.' ;
    rdfs:domain ind:VmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetOtdRatePct rdf:type rdf:Property ;
    rdfs:label 'Target Otd Rate Pct' ;
    rdfs:comment 'The contractually agreed on-time delivery rate the supplier must achieve, expressed as a percentage (e.g., 95.00 = 95%). Measures the proportion of replenishment deliveries arriving within the agreed lead time window. Distinct from fill rate which measures order completeness.' ;
    rdfs:domain ind:VmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetWeeksOfSupply rdf:type rdf:Property ;
    rdfs:label 'Target Weeks Of Supply' ;
    rdfs:comment 'The target number of weeks of inventory coverage (Weeks of Supply / WOS) the supplier is contractually required to maintain at the covered location. Calculated as on-hand units divided by average weekly sales rate; the target value is defined in the agreement.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'The reason code explaining why this VMI agreement was terminated or not renewed. Populated only when status is terminated or expired. Supports supplier relationship analysis and VMI program retrospectives.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Vmi Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the VMI agreement. Draft indicates the agreement is under negotiation; active means the supplier is actively managing inventory; suspended indicates a temporary halt; terminated means the agreement has been ended before expiry; expired means the end date has passed without renewal; pending_renewal indicates the agreement is under renegotiation.' ;
    rdfs:domain ind:VmiAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualRuleId rdf:type rdf:Property ;
    rdfs:label 'Accrual Rule Id' ;
    rdfs:comment 'Unique identifier for the loyalty points accrual rule. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccrualRule .

ind:applicableStoreFormatId rdf:type rdf:Property ;
    rdfs:label 'Applicable Store Format Id' ;
    rdfs:comment 'Foreign key linking to store.store_format. Business justification: Earning rules vary by store format (hypermarkets 1x, premium formats 2x) to reflect margin structures and customer expectations. Retail loyalty programs differentiate point accrual by format for profi' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Format .

ind:primaryAccrualAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Accrual Associate Id' ;
    rdfs:comment 'Identifier of the user or system that created this accrual rule record.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:productBrandId rdf:type rdf:Property ;
    rdfs:label 'Product Brand Id' ;
    rdfs:comment 'Foreign key linking to product.product_brand. Business justification: Brand-based earning rules are core loyalty strategy (e.g., \'3x points on private label\', \'double points on partner brands\'). Brand-level earning rules support strategic merchandising objectives requir' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductBrand .

ind:tertiaryAccrualApprovedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Accrual Approved By User Associate Id' ;
    rdfs:comment 'Identifier of the user who approved this accrual rule. Null if not yet approved.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:accrualRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Accrual Rule Status' ;
    rdfs:comment 'Current lifecycle status of the accrual rule: draft (under development), active (in use), inactive (disabled), expired (past effective period), suspended (temporarily paused).' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableChannel rdf:type rdf:Property ;
    rdfs:label 'Applicable Channel' ;
    rdfs:comment 'Sales channel(s) where this accrual rule applies: all channels, in-store (POS), online (e-commerce), mobile app, BOPIS (Buy Online Pick Up In Store), ROPIS (Reserve Online Pick Up In Store).' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableProductCategory rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Category' ;
    rdfs:comment 'Product category or categories to which this accrual rule applies. Null if rule applies to all categories. Comma-separated list if multiple.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableSkuList rdf:type rdf:Property ;
    rdfs:label 'Applicable Sku List' ;
    rdfs:comment 'Specific SKUs to which this accrual rule applies. Null if rule applies broadly. Comma-separated list if multiple SKUs.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusMultiplier rdf:type rdf:Property ;
    rdfs:label 'Bonus Multiplier' ;
    rdfs:comment 'Multiplier applied to the base earning rate for bonus promotions (e.g., 2.0 for double points, 1.5 for 50% bonus). Null if not a multiplier rule.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dayOfWeekRestriction rdf:type rdf:Property ;
    rdfs:label 'Day Of Week Restriction' ;
    rdfs:comment 'Specific days of the week when this accrual rule applies (e.g., \'Monday,Wednesday,Friday\'). Null if rule applies all days.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earningBasis rdf:type rdf:Property ;
    rdfs:label 'Earning Basis' ;
    rdfs:comment 'The basis on which points are earned: spend amount (dollars spent), unit quantity (items purchased), transaction count (number of transactions), or visit count (store visits).' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excludedProductCategory rdf:type rdf:Property ;
    rdfs:label 'Excluded Product Category' ;
    rdfs:comment 'Product categories explicitly excluded from this accrual rule (e.g., alcohol, tobacco, gift cards). Null if no exclusions. Comma-separated list if multiple.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excludedSkuList rdf:type rdf:Property ;
    rdfs:label 'Excluded Sku List' ;
    rdfs:comment 'Specific SKUs explicitly excluded from this accrual rule. Null if no exclusions. Comma-separated list if multiple SKUs.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRuleCode rdf:type rdf:Property ;
    rdfs:label 'External Rule Code' ;
    rdfs:comment 'Identifier of this accrual rule in the source system, used for cross-system reconciliation and integration.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestriction rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction' ;
    rdfs:comment 'Geographic scope where this accrual rule applies (e.g., specific countries, states, regions, or store locations). Null if no geographic restriction.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPointsPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Maximum Points Per Transaction' ;
    rdfs:comment 'Cap on the number of points that can be earned in a single transaction under this rule. Null if no cap.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberTierEligibility rdf:type rdf:Property ;
    rdfs:label 'Member Tier Eligibility' ;
    rdfs:comment 'Loyalty program membership tier(s) eligible for this accrual rule. \'all\' if rule applies to all tiers, or specific tier names.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumSpendThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Spend Threshold' ;
    rdfs:comment 'Minimum transaction amount required for the accrual rule to apply. Null if no minimum threshold.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethodRestriction rdf:type rdf:Property ;
    rdfs:label 'Payment Method Restriction' ;
    rdfs:comment 'Specific payment methods required for this accrual rule to apply (e.g., \'store_credit_card\', \'mobile_wallet\'). Null if no payment method restriction.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsPerUnit rdf:type rdf:Property ;
    rdfs:label 'Points Per Unit' ;
    rdfs:comment 'Number of loyalty points earned per unit of the earning basis (e.g., 1 point per dollar spent, 10 points per item purchased).' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingStrategyAlignment rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy Alignment' ;
    rdfs:comment 'Indicates which pricing strategy this accrual rule supports: EDLP (Everyday Low Price), Hi-Lo (High-Low promotional pricing), or hybrid.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Stacking Allowed Flag' ;
    rdfs:comment 'Indicates whether this accrual rule can be combined (stacked) with other accrual rules in the same transaction. True = stacking allowed, False = exclusive rule.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeOfDayRestriction rdf:type rdf:Property ;
    rdfs:label 'Time Of Day Restriction' ;
    rdfs:comment 'Specific time windows when this accrual rule applies (e.g., \'09:00-12:00\', \'happy hour\'). Null if rule applies all day.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientelingInteractionId rdf:type rdf:Property ;
    rdfs:label 'Clienteling Interaction Id' ;
    rdfs:comment 'Unique identifier for the clienteling interaction record. Primary key.' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberOfferId rdf:type rdf:Property ;
    rdfs:label 'Member Offer Id' ;
    rdfs:comment 'Foreign key linking to loyalty.member_offer. Business justification: Clienteling interactions often discuss specific personalized offers with members. Adding offer_id FK allows tracking which offers were presented or discussed during high-touch interactions. No columns' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MemberOffer .

ind:appointmentScheduledFlag rdf:type rdf:Property ;
    rdfs:label 'Appointment Scheduled Flag' ;
    rdfs:comment 'Boolean indicator of whether a future appointment or styling session was scheduled as an outcome of this interaction.' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSentiment rdf:type rdf:Property ;
    rdfs:label 'Customer Sentiment' ;
    rdfs:comment 'Associate assessment of the customer sentiment or satisfaction level during and at the conclusion of the interaction, used for experience quality monitoring.' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpActionRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Required' ;
    rdfs:comment 'Boolean indicator of whether a follow-up action or future touchpoint has been scheduled or is required as a result of this interaction.' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpActionType rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Type' ;
    rdfs:comment 'Classification of the type of follow-up action scheduled or recommended as a next step in the customer relationship journey. [ENUM-REF-CANDIDATE: call_back|send_email|send_text|schedule_appointment|product_arrival_notification|event_invitation|thank_you_note|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Completed Flag' ;
    rdfs:comment 'Boolean indicator of whether the scheduled follow-up action has been completed, supporting task closure and workflow management.' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interactionChannel rdf:type rdf:Property ;
    rdfs:label 'Interaction Channel' ;
    rdfs:comment 'The communication channel or touchpoint through which the clienteling interaction was conducted, supporting omnichannel engagement analysis. [ENUM-REF-CANDIDATE: in_store|phone|email|sms|video_call|mobile_app|web_chat|social_media — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionDate rdf:type rdf:Property ;
    rdfs:label 'Interaction Date' ;
    rdfs:comment 'The calendar date on which the clienteling interaction occurred, used for temporal analysis and engagement frequency tracking.' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interactionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Interaction Duration Minutes' ;
    rdfs:comment 'The total duration of the clienteling interaction measured in minutes, used to assess engagement depth and associate time investment.' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interactionInitiatedBy rdf:type rdf:Property ;
    rdfs:label 'Interaction Initiated By' ;
    rdfs:comment 'Indicator of who or what initiated the clienteling interaction, distinguishing between proactive associate outreach, customer-initiated contact, and system-triggered engagements.' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionLocationType rdf:type rdf:Property ;
    rdfs:label 'Interaction Location Type' ;
    rdfs:comment 'Classification of the physical or virtual location where the clienteling interaction took place, providing context for the service environment. [ENUM-REF-CANDIDATE: store_floor|private_styling_room|vip_lounge|customer_home|virtual|phone|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionNotes rdf:type rdf:Property ;
    rdfs:label 'Interaction Notes' ;
    rdfs:comment 'Detailed free-text notes recorded by the associate documenting the conversation, customer feedback, special requests, and any other relevant context from the interaction.' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionNumber rdf:type rdf:Property ;
    rdfs:label 'Interaction Number' ;
    rdfs:comment 'Business-facing unique identifier for the clienteling interaction, used for tracking and reference in customer service and reporting contexts.' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionOutcome rdf:type rdf:Property ;
    rdfs:label 'Interaction Outcome' ;
    rdfs:comment 'The business result or action taken as a consequence of the clienteling interaction, used to measure interaction effectiveness and conversion. [ENUM-REF-CANDIDATE: purchase_made|appointment_booked|wishlist_updated|product_reserved|no_action|referral_provided|feedback_collected|complaint_resolved — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current lifecycle status of the clienteling interaction, tracking progression from scheduling through completion or cancellation.' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberPreferencesDiscussed rdf:type rdf:Property ;
    rdfs:label 'Member Preferences Discussed' ;
    rdfs:comment 'Free-text notes capturing customer preferences, style interests, size information, color preferences, brand affinities, and other personalization details discussed during the interaction.' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAppointmentDate rdf:type rdf:Property ;
    rdfs:label 'Next Appointment Date' ;
    rdfs:comment 'The scheduled date for the next clienteling appointment or interaction with this customer, supporting relationship continuity and engagement planning.' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productsPurchased rdf:type rdf:Property ;
    rdfs:label 'Products Purchased' ;
    rdfs:comment 'Comma-separated list of Stock Keeping Unit (SKU) codes for products actually purchased as a result of this interaction, enabling recommendation-to-purchase conversion tracking.' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productsRecommended rdf:type rdf:Property ;
    rdfs:label 'Products Recommended' ;
    rdfs:comment 'Comma-separated list of Stock Keeping Unit (SKU) codes for products recommended to the customer during the interaction, supporting product affinity and recommendation effectiveness analysis.' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseMadeFlag rdf:type rdf:Property ;
    rdfs:label 'Purchase Made Flag' ;
    rdfs:comment 'Boolean indicator of whether the clienteling interaction resulted in an immediate purchase transaction, supporting conversion rate analysis.' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalInteractionValueAmount rdf:type rdf:Property ;
    rdfs:label 'Total Interaction Value Amount' ;
    rdfs:comment 'The total monetary value of purchases made as a direct result of this clienteling interaction, measured in the store operating currency, used to calculate clienteling Return on Investment (ROI).' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vipTierAtInteraction rdf:type rdf:Property ;
    rdfs:label 'Vip Tier At Interaction' ;
    rdfs:comment 'The loyalty program tier or VIP status of the member at the time of the interaction, enabling tier-specific engagement analysis and service level tracking.' ;
    rdfs:domain ind:ClientelingInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignOwnerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Campaign Owner Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Engagement campaigns require owner associates for budget accountability, approval workflows, performance measurement, and cross-functional coordination. Replaces denormalized campaign_owner_name/email' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:marketingCampaignId rdf:type rdf:Property ;
    rdfs:label 'Marketing Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Loyalty engagement campaigns are often sub-campaigns within broader marketing campaigns in retail operations. Linking enables unified campaign performance reporting, consolidated budget tracking, and ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:targetStoreClusterId rdf:type rdf:Property ;
    rdfs:label 'Target Store Cluster Id' ;
    rdfs:comment 'Foreign key linking to store.store_cluster. Business justification: Campaigns target member segments within specific store clusters (urban vs suburban, high-income vs value) to align offers with cluster demographics and shopping behaviors. Standard retail loyalty prac' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cluster .

ind:targetStoreLocationId rdf:type rdf:Property ;
    rdfs:label 'Target Store Location Id' ;
    rdfs:comment 'Foreign key linking to store.store_location. Business justification: Campaigns target members by preferred/enrollment store for in-store activation events, localized offers, store-specific promotions. Retail loyalty operations execute geo-targeted campaigns tied to spe' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:actualEnrollmentCount rdf:type rdf:Property ;
    rdfs:label 'Actual Enrollment Count' ;
    rdfs:comment 'Actual number of members who enrolled or opted-in to the campaign. Updated in real-time or batch as enrollments occur.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualIncrementalSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Incremental Spend Amount' ;
    rdfs:comment 'Actual incremental spend generated by campaign participants, measured as the difference between campaign-period spend and baseline spend. Key ROI metric.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualParticipationCount rdf:type rdf:Property ;
    rdfs:label 'Actual Participation Count' ;
    rdfs:comment 'Actual number of members who completed qualifying actions and actively participated in the campaign. Used to calculate participation rate.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualParticipationRatePct rdf:type rdf:Property ;
    rdfs:label 'Actual Participation Rate Pct' ;
    rdfs:comment 'Actual participation rate achieved, calculated as (actual_participation_count / actual_enrollment_count) * 100. Measured against target for campaign success assessment.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualTierUpgradeCount rdf:type rdf:Property ;
    rdfs:label 'Actual Tier Upgrade Count' ;
    rdfs:comment 'Actual number of members who upgraded to a higher loyalty tier during or as a result of the campaign. Measured against target for tier challenge campaigns.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Name of the individual who approved the campaign. Used for audit trail and governance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusPointsAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Points Amount' ;
    rdfs:comment 'Fixed number of bonus points awarded to members who complete campaign qualifying actions. Null if campaign does not award fixed bonus points.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Unique business identifier for the campaign, used in marketing materials, tracking URLs, and operational reporting. Externally visible code.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignDescription rdf:type rdf:Property ;
    rdfs:label 'Campaign Description' ;
    rdfs:comment 'Detailed description of the campaign objectives, mechanics, and value proposition. Used for internal alignment and external member communication.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Human-readable name of the engagement campaign, used in internal reporting and customer-facing communications.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle status of the campaign. Draft indicates planning phase; approved indicates ready for launch; active indicates currently running; paused indicates temporarily suspended; completed indicates ended successfully; archived indicates historical record; cancelled indicates terminated before completion. [ENUM-REF-CANDIDATE: draft|approved|active|paused|completed|archived|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the campaign by its primary objective and mechanic. Enrollment drive focuses on new member acquisition; double-points event accelerates points accrual; tier challenge incentivizes tier upgrades; birthday campaign celebrates member milestones; reactivation targets dormant members; streak bonus rewards consecutive engagement; spend milestone rewards cumulative spend thresholds; referral incentive drives member-get-member growth. [ENUM-REF-CANDIDATE: enrollment_drive|double_points_event|tier_challenge|birthday_campaign|reactivation|streak_bonus|spend_milestone|referral_incentive — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelAppNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Channel App Notification Flag' ;
    rdfs:comment 'Indicates whether in-app notifications or banners are used as a communication channel for this campaign. True if app notification is part of the channel mix.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelDirectMailFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Direct Mail Flag' ;
    rdfs:comment 'Indicates whether physical direct mail is used as a communication channel for this campaign. True if direct mail is part of the channel mix.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelEmailFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Email Flag' ;
    rdfs:comment 'Indicates whether email is used as a communication channel for this campaign. True if email is part of the channel mix.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelInStoreFlag rdf:type rdf:Property ;
    rdfs:label 'Channel In Store Flag' ;
    rdfs:comment 'Indicates whether in-store signage, POS displays, or associate-driven communication are used for this campaign. True if in-store is part of the channel mix.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelPushFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Push Flag' ;
    rdfs:comment 'Indicates whether mobile app push notifications are used as a communication channel for this campaign. True if push is part of the channel mix.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelSmsFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Sms Flag' ;
    rdfs:comment 'Indicates whether SMS is used as a communication channel for this campaign. True if SMS is part of the channel mix.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedEnrollmentCount rdf:type rdf:Property ;
    rdfs:label 'Expected Enrollment Count' ;
    rdfs:comment 'Projected number of members expected to enroll or opt-in to the campaign. Used for capacity planning and success measurement.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedParticipationCount rdf:type rdf:Property ;
    rdfs:label 'Expected Participation Count' ;
    rdfs:comment 'Projected number of members expected to actively participate in the campaign by completing qualifying actions. Used for ROI forecasting.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optInRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Opt In Required Flag' ;
    rdfs:comment 'Indicates whether members must explicitly opt-in to participate in the campaign. True if opt-in is required; false if all eligible members are automatically enrolled.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personalizationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Personalization Enabled Flag' ;
    rdfs:comment 'Indicates whether campaign communications and offers are personalized based on member preferences, purchase history, or behavioral data. True if personalization is enabled.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsMultiplier rdf:type rdf:Property ;
    rdfs:label 'Points Multiplier' ;
    rdfs:comment 'Multiplier applied to base points earning rate during the campaign. For example, 2.0 for double points, 3.0 for triple points. Null if campaign does not modify points earning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualifyingSpendThreshold rdf:type rdf:Property ;
    rdfs:label 'Qualifying Spend Threshold' ;
    rdfs:comment 'Minimum spend amount required for a member to qualify for campaign rewards. Null if campaign has no spend threshold requirement.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualifyingTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Qualifying Transaction Count' ;
    rdfs:comment 'Minimum number of transactions required for a member to qualify for campaign rewards. Null if campaign has no transaction count requirement.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetIncrementalSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Target Incremental Spend Amount' ;
    rdfs:comment 'Target incremental spend expected to be generated by campaign participants above their baseline spend. Used to calculate campaign ROI.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetParticipationRatePct rdf:type rdf:Property ;
    rdfs:label 'Target Participation Rate Pct' ;
    rdfs:comment 'Target participation rate expressed as a percentage of enrolled members. Key performance indicator for campaign effectiveness.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTierUpgradeCount rdf:type rdf:Property ;
    rdfs:label 'Target Tier Upgrade Count' ;
    rdfs:comment 'Target number of members expected to upgrade to a higher loyalty tier as a result of campaign participation. Relevant for tier challenge campaigns.' ;
    rdfs:domain ind:EngagementCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Manager Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Loyalty programs require designated program managers (associates) for accountability, escalations, budget ownership, and performance tracking. Replaces denormalized program_manager_name with proper FK' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:annualFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Fee Amount' ;
    rdfs:comment 'Recurring annual membership fee for subscription-based loyalty programs. Zero for free programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bannerAffiliation rdf:type rdf:Property ;
    rdfs:label 'Banner Affiliation' ;
    rdfs:comment 'Retail banner or brand name this loyalty program is associated with. Supports multi-banner retailers operating distinct programs for different store formats (e.g., Hypermarket Rewards, Discount Club, Premium Grocery).' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:charitableDonationEnabled rdf:type rdf:Property ;
    rdfs:label 'Charitable Donation Enabled' ;
    rdfs:comment 'Indicates whether members can donate their earned points or rewards to charitable organizations through the loyalty program.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerServicePhone rdf:type rdf:Property ;
    rdfs:label 'Customer Service Phone' ;
    rdfs:comment 'Dedicated customer service phone number for loyalty program member inquiries, support, and issue resolution.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecommerceIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Ecommerce Integration Enabled' ;
    rdfs:comment 'Indicates whether the loyalty program is integrated with the retailers e-commerce platform for online member identification, points accrual, and redemption during digital checkout.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentEligibilityRule rdf:type rdf:Property ;
    rdfs:label 'Enrollment Eligibility Rule' ;
    rdfs:comment 'Business rule defining who can enroll in the program (e.g., age 18+, US residents only, minimum purchase requirement, invitation only). Free-text description of eligibility criteria.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Enrollment Fee Amount' ;
    rdfs:comment 'One-time fee charged to enroll in the loyalty program. Zero for free programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gamificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Gamification Enabled' ;
    rdfs:comment 'Indicates whether the loyalty program incorporates gamification elements such as challenges, badges, leaderboards, or bonus point events to drive engagement.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mobileAppEnabled rdf:type rdf:Property ;
    rdfs:label 'Mobile App Enabled' ;
    rdfs:comment 'Indicates whether the loyalty program has a dedicated mobile application or is accessible through the retailers mobile app for member self-service, digital card, and personalized offers.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:omnichannelRecognitionEnabled rdf:type rdf:Property ;
    rdfs:label 'Omnichannel Recognition Enabled' ;
    rdfs:comment 'Indicates whether loyalty program benefits and points accrual are recognized across all customer touchpoints (in-store POS, e-commerce, mobile app, call center). True for unified omnichannel programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerCoalitionEnabled rdf:type rdf:Property ;
    rdfs:label 'Partner Coalition Enabled' ;
    rdfs:comment 'Indicates whether this loyalty program participates in a coalition with external partners (e.g., airlines, hotels, other retailers) allowing members to earn and redeem across multiple brands.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personalizationEngineEnabled rdf:type rdf:Property ;
    rdfs:label 'Personalization Engine Enabled' ;
    rdfs:comment 'Indicates whether the loyalty program leverages AI/ML-driven personalization to deliver individualized offers, recommendations, and communications to members based on purchase history and behavior.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsCurrencyName rdf:type rdf:Property ;
    rdfs:label 'Points Currency Name' ;
    rdfs:comment 'Name of the points currency used in this program (e.g., Rewards Points, Stars, Miles, Cash Back Dollars). Null for non-points programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsEarnRate rdf:type rdf:Property ;
    rdfs:label 'Points Earn Rate' ;
    rdfs:comment 'Base rate at which members earn points per unit of spend (e.g., 1.0 = 1 point per dollar, 0.5 = 1 point per 2 dollars). Null for non-points programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsExpiryDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Duration Months' ;
    rdfs:comment 'Number of months until points expire, applicable when points_expiry_policy is rolling_months or activity_based. Null for non-expiring programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsExpiryPolicy rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Policy' ;
    rdfs:comment 'Policy governing when earned points expire: never (no expiration), rolling_months (expire N months after earn date), calendar_year (expire end of year), fixed_date (expire on specific date), activity_based (expire if no activity for N months).' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsRedemptionRate rdf:type rdf:Property ;
    rdfs:label 'Points Redemption Rate' ;
    rdfs:comment 'Base rate at which points convert to monetary value for redemption (e.g., 0.01 = 1 point = $0.01, 100 points = $1). Null for non-points programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:posIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Pos Integration Enabled' ;
    rdfs:comment 'Indicates whether the loyalty program is integrated with in-store POS systems for real-time member identification, points accrual, and redemption at checkout.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privacyPolicyUrl rdf:type rdf:Property ;
    rdfs:label 'Privacy Policy Url' ;
    rdfs:comment 'URL to the privacy policy specific to the loyalty program, detailing how member data is collected, used, and protected.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Detailed description of the loyalty programs value proposition, benefits, and key features. Used for internal reference and customer-facing communications.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralProgramEnabled rdf:type rdf:Property ;
    rdfs:label 'Referral Program Enabled' ;
    rdfs:comment 'Indicates whether the loyalty program includes a member-get-member referral component where existing members earn rewards for referring new enrollees.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Target Customer Segment' ;
    rdfs:comment 'Primary customer demographic or behavioral segment this loyalty program is designed to attract and retain (e.g., high-value shoppers, frequent buyers, millennials, grocery-focused).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAndConditionsUrl rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Url' ;
    rdfs:comment 'URL to the official terms and conditions document governing the loyalty program, including member rights, obligations, and program rules.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierEvaluationPeriod rdf:type rdf:Property ;
    rdfs:label 'Tier Evaluation Period' ;
    rdfs:comment 'Time window over which tier qualification is evaluated: calendar_year (Jan-Dec), rolling_12_months (trailing 12 months), program_year (anniversary-based), lifetime (cumulative since enrollment). Null for non-tiered programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierQualificationMetric rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Metric' ;
    rdfs:comment 'Primary metric used to qualify members for tier advancement: annual_spend (total dollars spent), points_earned (total points accumulated), transaction_count (number of purchases), hybrid (combination of metrics). Null for non-tiered programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierStructureEnabled rdf:type rdf:Property ;
    rdfs:label 'Tier Structure Enabled' ;
    rdfs:comment 'Indicates whether this loyalty program has a tiered membership structure with multiple levels (e.g., Silver, Gold, Platinum). True for tiered programs, false for flat programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rewardId rdf:type rdf:Property ;
    rdfs:label 'Reward Id' ;
    rdfs:comment 'Foreign key linking to loyalty.reward. Business justification: Many member offers are tied to specific rewards from the catalog (e.g., \'Redeem this offer for Product X\'). Adding reward_id FK links offers to the reward master catalog. This is optional as not all o' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Reward .

ind:activationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activation Timestamp' ;
    rdfs:comment 'Date and time when the member activated or accepted the offer. Null if not yet activated.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:channelApplicability rdf:type rdf:Property ;
    rdfs:label 'Channel Applicability' ;
    rdfs:comment 'Sales channel(s) where the offer can be redeemed: all (omnichannel), in_store (physical stores only), online (e-commerce website), mobile_app (mobile application), call_center (phone orders).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'Type of discount provided: percentage (percent off total or item) or fixed_amount (dollar/currency amount off). Null if offer is not discount-based.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountValue rdf:type rdf:Property ;
    rdfs:label 'Discount Value' ;
    rdfs:comment 'Numeric value of the discount: percentage (e.g., 15.00 for 15% off) or fixed currency amount (e.g., 10.00 for $10 off). Null if offer is not discount-based.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibleProductCategory rdf:type rdf:Property ;
    rdfs:label 'Eligible Product Category' ;
    rdfs:comment 'Product category or categories eligible for this offer (e.g., \'Apparel\', \'Electronics\'). Null if offer applies to all products.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Liability Amount' ;
    rdfs:comment 'Estimated financial liability or cost to the business if this offer is fully redeemed, used for points liability and financial planning.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxRedemptions rdf:type rdf:Property ;
    rdfs:label 'Max Redemptions' ;
    rdfs:comment 'Maximum number of times this offer can be redeemed by the member. Null for unlimited redemptions within validity period.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Quantity' ;
    rdfs:comment 'Minimum number of items or units required to qualify for the offer. Null if no quantity requirement.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Spend Amount' ;
    rdfs:comment 'Minimum purchase amount required to qualify for the offer. Null if no minimum spend requirement.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offerCode rdf:type rdf:Property ;
    rdfs:label 'Offer Code' ;
    rdfs:comment 'Unique alphanumeric code representing this offer, used for tracking and redemption. Externally visible identifier.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerDescription rdf:type rdf:Property ;
    rdfs:label 'Offer Description' ;
    rdfs:comment 'Detailed description of the offer terms, benefits, and conditions as communicated to the member.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerName rdf:type rdf:Property ;
    rdfs:label 'Offer Name' ;
    rdfs:comment 'Human-readable name of the offer as presented to the member (e.g., \'Birthday Bonus Points\', \'Welcome Back Discount\').' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerSource rdf:type rdf:Property ;
    rdfs:label 'Offer Source' ;
    rdfs:comment 'Origin of the offer assignment: automated (system-generated based on rules), manual (created by loyalty manager), campaign (part of marketing campaign), clienteling (personalized by store associate), tier_benefit (automatic tier-based perk).' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerStatus rdf:type rdf:Property ;
    rdfs:label 'Offer Status' ;
    rdfs:comment 'Current lifecycle status of the offer: pending (assigned but not yet presented), presented (communicated to member), activated (member accepted), redeemed (member used), expired (validity period ended), declined (member rejected), cancelled (offer withdrawn by business). [ENUM-REF-CANDIDATE: pending|presented|activated|redeemed|expired|declined|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerType rdf:type rdf:Property ;
    rdfs:label 'Offer Type' ;
    rdfs:comment 'Category of the offer benefit: bonus_points (points multiplier or fixed bonus), discount (percentage or fixed amount off), free_item (complimentary product), early_access (exclusive access to sales or products), experiential_reward (event tickets, services), tier_upgrade (accelerated tier progression).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationScore rdf:type rdf:Property ;
    rdfs:label 'Personalization Score' ;
    rdfs:comment 'Algorithmic score indicating the degree of personalization or relevance of this offer to the member, typically 0.00 to 1.00. Used for offer optimization and analytics.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:presentationPriority rdf:type rdf:Property ;
    rdfs:label 'Presentation Priority' ;
    rdfs:comment 'Numeric priority for displaying this offer when multiple offers are available to the member. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:presentationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Presentation Timestamp' ;
    rdfs:comment 'Date and time when the offer was first presented or communicated to the member. Null if not yet presented.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:redemptionCount rdf:type rdf:Property ;
    rdfs:label 'Redemption Count' ;
    rdfs:comment 'Number of times this offer has been redeemed by the member to date.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Redemption Timestamp' ;
    rdfs:comment 'Date and time when the offer was redeemed by the member. Null if not yet redeemed.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:termsAndConditions rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions' ;
    rdfs:comment 'Full legal terms and conditions governing the offer, including restrictions, exclusions, and compliance disclosures.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingAudienceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Marketing Audience Segment Id' ;
    rdfs:comment 'Foreign key linking to marketing.audience_segment. Business justification: Retail operations synchronize loyalty member segments with marketing audience segments for coordinated targeting across channels. Marketers need to activate loyalty segments in paid media, email, and ' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceSegment .

ind:segmentOwnerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Segment Owner Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Member segments require business owner associates for strategy ownership, campaign planning, and segment performance accountability. Replaces denormalized segment_owner string with proper FK for organ' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'Method used to assign members to this segment: rule-based (deterministic business rules), ml_model (machine learning model prediction), manual (analyst-driven assignment), hybrid (combination of automated and manual).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageAnnualSpend rdf:type rdf:Property ;
    rdfs:label 'Average Annual Spend' ;
    rdfs:comment 'Average annual spend (trailing 12 months) of members in this segment. Used for spend-based segmentation validation and campaign ROI forecasting. Currency implied by program configuration.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageLtv rdf:type rdf:Property ;
    rdfs:label 'Average Ltv' ;
    rdfs:comment 'Average Customer Lifetime Value (CLTV) of members in this segment. Calculated metric used for segment value ranking and ROI analysis. Currency implied by program configuration.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averagePointsBalance rdf:type rdf:Property ;
    rdfs:label 'Average Points Balance' ;
    rdfs:comment 'Average loyalty points balance across all members in this segment. Used for points liability forecasting and segment value analysis.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Campaign Eligibility Flag' ;
    rdfs:comment 'Boolean flag indicating whether members in this segment are eligible for targeted marketing campaigns. False may indicate test segments or internal analytical segments not intended for outbound communication.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:definitionCriteria rdf:type rdf:Property ;
    rdfs:label 'Definition Criteria' ;
    rdfs:comment 'Business rules or criteria defining segment membership. May be SQL-like expression, natural language rule description, or reference to external rule engine configuration. Examples: \'Points earned > 5000 in last 90 days AND redemption count >= 2\', \'RFM score R>=4 AND F>=3\'.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'Boolean flag indicating whether members can belong to only this segment (true) or can be assigned to multiple segments simultaneously (false). Supports mutually exclusive vs. overlapping segmentation strategies.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberCount rdf:type rdf:Property ;
    rdfs:label 'Member Count' ;
    rdfs:comment 'Current count of loyalty members assigned to this segment. Updated with each segment refresh cycle. Used for campaign sizing and ROI forecasting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Minimum Confidence Score' ;
    rdfs:comment 'Minimum confidence threshold (0.0000 to 1.0000) required for ML-based segment assignment. Members with confidence scores below this threshold are not assigned to the segment. Null for rule-based segments.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mlModelReference rdf:type rdf:Property ;
    rdfs:label 'Ml Model Reference' ;
    rdfs:comment 'Reference identifier to the ML model used for segment assignment (e.g., model name, version, registry URI). Null for non-ML-based segments. Enables model lineage tracking and reproducibility.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlModelVersion rdf:type rdf:Property ;
    rdfs:label 'Ml Model Version' ;
    rdfs:comment 'Version identifier of the ML model used for segment assignment. Supports model versioning and A/B testing of segmentation strategies.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Refresh Timestamp' ;
    rdfs:comment 'Scheduled timestamp for the next segment membership refresh. Null for on-demand segments. Supports proactive monitoring and capacity planning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:offerEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Offer Eligibility Flag' ;
    rdfs:comment 'Boolean flag indicating whether members in this segment are eligible for personalized offers and promotions. Supports offer targeting and exclusion rules.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetMemberCount rdf:type rdf:Property ;
    rdfs:label 'Target Member Count' ;
    rdfs:comment 'Target or expected member count for this segment based on business planning. Used to monitor segment size drift and validate segmentation model performance.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierQualificationFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Flag' ;
    rdfs:comment 'Boolean flag indicating whether this segment is used for loyalty tier qualification or upgrade/downgrade decisions. True for segments that drive tier movement logic.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentTierId rdf:type rdf:Property ;
    rdfs:label 'Current Tier Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier. Business justification: Critical normalization opportunity. membership.current_tier is currently a STRING field (likely storing tier code or name). This should be normalized to a FK to tier.tier_id. The tier table is the aut' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:primaryLoyaltyLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Loyalty Location Id' ;
    rdfs:comment 'Store location where the customer enrolled, if enrollment occurred in-store. Null for digital enrollments.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:primaryStorefrontId rdf:type rdf:Property ;
    rdfs:label 'Primary Storefront Id' ;
    rdfs:comment 'Foreign key linking to ecommerce.storefront. Business justification: Members enroll and transact through specific digital storefronts; tracking primary storefront enables channel-specific loyalty offers, omnichannel recognition, and storefront-level member segmentation' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Storefront .

ind:referredByMemberLoyaltyMembershipId rdf:type rdf:Property ;
    rdfs:label 'Referred By Member Loyalty Membership Id' ;
    rdfs:comment 'Reference to the member who referred this customer to the loyalty program. Null if not a referral enrollment.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyMembership .

ind:anniversaryDate rdf:type rdf:Property ;
    rdfs:label 'Anniversary Date' ;
    rdfs:comment 'Annual anniversary date of membership enrollment. Used for anniversary campaigns and special offers.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedReason rdf:type rdf:Property ;
    rdfs:label 'Closed Reason' ;
    rdfs:comment 'Reason code or description for membership closure. Examples: customer_request, fraud, terms_violation, duplicate_account, deceased.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Current Points Balance' ;
    rdfs:comment 'Current available points balance that can be redeemed. Calculated as lifetime earned minus lifetime redeemed minus expired points.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'Channel through which the customer enrolled in the loyalty program. Supports omnichannel enrollment tracking and channel effectiveness analysis. [ENUM-REF-CANDIDATE: in_store|online|mobile_app|call_center|referral|partner|social_media — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date when the customer enrolled in the loyalty program. Used for tenure analysis and anniversary campaigns.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fraudFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Flag' ;
    rdfs:comment 'Indicates whether the membership has been flagged for suspected fraudulent activity. Used for risk management and account review.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent member activity (purchase, points redemption, offer engagement, or interaction). Used for lapse risk scoring and reactivation targeting.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRedemptionDate rdf:type rdf:Property ;
    rdfs:label 'Last Redemption Date' ;
    rdfs:comment 'Date of the most recent points redemption by the member. Used for engagement analysis and redemption behavior tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimePointsEarned rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Earned' ;
    rdfs:comment 'Total points earned by the member since enrollment. Includes base points, bonus points, and promotional points. Used for tier qualification and CLTV (Customer Lifetime Value) analysis.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimePointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Redeemed' ;
    rdfs:comment 'Total points redeemed by the member since enrollment. Used for engagement analysis and points liability tracking.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memberNumber rdf:type rdf:Property ;
    rdfs:label 'Member Number' ;
    rdfs:comment 'Externally visible unique member identifier used for program recognition across all touchpoints (POS, e-commerce, mobile app). Customer-facing identifier.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of the membership. Active members can earn and redeem points; suspended members are temporarily blocked; lapsed members have not engaged within retention window; closed memberships are permanently terminated.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Next Expiry Date' ;
    rdfs:comment 'Date when the next batch of points will expire. Null if no points are set to expire.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInDirectMail rdf:type rdf:Property ;
    rdfs:label 'Opt In Direct Mail' ;
    rdfs:comment 'Indicates whether the member has opted in to receive loyalty program communications via postal mail.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInEmail rdf:type rdf:Property ;
    rdfs:label 'Opt In Email' ;
    rdfs:comment 'Indicates whether the member has opted in to receive loyalty program communications via email.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInPush rdf:type rdf:Property ;
    rdfs:label 'Opt In Push' ;
    rdfs:comment 'Indicates whether the member has opted in to receive loyalty program push notifications via mobile app.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInSms rdf:type rdf:Property ;
    rdfs:label 'Opt In Sms' ;
    rdfs:comment 'Indicates whether the member has opted in to receive loyalty program communications via SMS text messages.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsExpiringSoon rdf:type rdf:Property ;
    rdfs:label 'Points Expiring Soon' ;
    rdfs:comment 'Points balance that will expire within the next 90 days. Used for expiration reminder campaigns and urgency messaging.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referralCode rdf:type rdf:Property ;
    rdfs:label 'Referral Code' ;
    rdfs:comment 'Unique referral code assigned to this member for referring new customers to the loyalty program. Used in member-get-member campaigns.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Status Effective Date' ;
    rdfs:comment 'Date when the current membership status became effective. Used for status duration analysis and reactivation campaigns.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statusReason rdf:type rdf:Property ;
    rdfs:label 'Status Reason' ;
    rdfs:comment 'Reason code or description for the current membership status. Examples: fraud_detected, customer_request, inactivity, terms_violation.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Tier Expiry Date' ;
    rdfs:comment 'Date when the current tier status expires and re-qualification is required. Null for lifetime tiers.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Date' ;
    rdfs:comment 'Date when the member qualified for their current tier. Used for tier tenure tracking and re-qualification calculations.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalTransactions rdf:type rdf:Property ;
    rdfs:label 'Total Transactions' ;
    rdfs:comment 'Total number of purchase transactions completed by the member since enrollment. Used for frequency analysis and tier qualification.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerProgramId rdf:type rdf:Property ;
    rdfs:label 'Partner Program Id' ;
    rdfs:comment 'Unique identifier for the coalition or partner loyalty arrangement. Primary key.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerProgram .

ind:apiEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint Url' ;
    rdfs:comment 'Base URL for the partner API endpoint used for real-time transaction posting and member validation. Confidential technical integration detail.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoEnrollmentFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Enrollment Flag' ;
    rdfs:comment 'Indicates whether loyalty program members are automatically enrolled in this partner program or must opt-in explicitly.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Date' ;
    rdfs:comment 'Date when the partner program contract is scheduled for renewal or renegotiation. Used for relationship management and planning.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costPerPointEarned rdf:type rdf:Property ;
    rdfs:label 'Cost Per Point Earned' ;
    rdfs:comment 'Cost to the retailer for each loyalty point earned by members at the partner location. Used for financial liability tracking and program ROI analysis.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSharingAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Agreement Reference' ;
    rdfs:comment 'Reference number or identifier for the legal data sharing agreement governing member data exchange between the retailer and partner. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earnCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Earn Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the currency in which partner transactions are denominated for points accrual calculation.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earnRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Earn Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to base loyalty points when members make purchases at the partner. For example, 1.5 means members earn 1.5x points per dollar spent at partner locations.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusionRules rdf:type rdf:Property ;
    rdfs:label 'Exclusion Rules' ;
    rdfs:comment 'Business rules defining product categories, transaction types, or conditions that are excluded from points earning or redemption at the partner (e.g., gift cards, alcohol, tobacco).' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationMethod rdf:type rdf:Property ;
    rdfs:label 'Integration Method' ;
    rdfs:comment 'Technical integration approach used to exchange transaction and member data between the retailer and partner systems.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumEarnPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Maximum Earn Per Transaction' ;
    rdfs:comment 'Cap on the number of loyalty points that can be earned in a single transaction at the partner. Nullable if no cap applies.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memberCommunicationAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Member Communication Allowed Flag' ;
    rdfs:comment 'Indicates whether the partner is permitted to send marketing communications directly to loyalty program members under the data sharing agreement.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberEligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Member Eligibility Criteria' ;
    rdfs:comment 'Business rules or criteria defining which loyalty program members are eligible to participate in this partner program (e.g., tier requirements, geographic restrictions, age limits).' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Transaction Amount' ;
    rdfs:comment 'Minimum purchase amount required at the partner location for the transaction to qualify for loyalty points accrual. Nullable if no minimum applies.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerCode rdf:type rdf:Property ;
    rdfs:label 'Partner Code' ;
    rdfs:comment 'Externally-known unique code identifying the partner program for integration and operational reference. Used in API calls, EDI transactions, and partner communications.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Partner Contact Email' ;
    rdfs:comment 'Email address of the primary business contact at the partner organization. Used for operational communications and issue resolution.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerContactName rdf:type rdf:Property ;
    rdfs:label 'Partner Contact Name' ;
    rdfs:comment 'Name of the primary business contact at the partner organization responsible for the loyalty program relationship.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Partner Contact Phone' ;
    rdfs:comment 'Phone number of the primary business contact at the partner organization. Used for operational communications and issue resolution.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerName rdf:type rdf:Property ;
    rdfs:label 'Partner Name' ;
    rdfs:comment 'Legal or trading name of the coalition partner organization (e.g., airline, hotel chain, fuel retailer, financial institution).' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerStatus rdf:type rdf:Property ;
    rdfs:label 'Partner Status' ;
    rdfs:comment 'Current lifecycle status of the partner program arrangement. Controls whether members can earn or redeem points with this partner.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Classification of the partner organization by industry vertical or business category. Determines applicable earn and redemption rules. [ENUM-REF-CANDIDATE: airline|hotel|fuel_retailer|financial_institution|restaurant|entertainment|travel|ecommerce|telecom|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceSlaTarget rdf:type rdf:Property ;
    rdfs:label 'Performance Sla Target' ;
    rdfs:comment 'Service Level Agreement (SLA) performance targets for the partner integration, such as API uptime percentage, transaction processing time, or data accuracy thresholds.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalBonusEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Bonus Eligible Flag' ;
    rdfs:comment 'Indicates whether this partner program is eligible for promotional bonus point campaigns and limited-time earn rate multipliers.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redeemCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Redeem Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the currency in which partner redemptions are valued and settled.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redeemRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Redeem Rate Multiplier' ;
    rdfs:comment 'Multiplier applied when members redeem loyalty points for partner rewards or services. Determines the value conversion rate from points to partner currency.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenuePerPointRedeemed rdf:type rdf:Property ;
    rdfs:label 'Revenue Per Point Redeemed' ;
    rdfs:comment 'Revenue received by the retailer for each loyalty point redeemed by members for partner rewards. Used for financial settlement and program ROI analysis.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Frequency' ;
    rdfs:comment 'Frequency at which financial settlements for points earned or redeemed are reconciled and settled between the retailer and partner.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the partner program arrangement, as specified in the contract.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerTransactionId rdf:type rdf:Property ;
    rdfs:label 'Partner Transaction Id' ;
    rdfs:comment 'Unique identifier for the partner transaction record. Primary key.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerTransaction .

ind:originalTransactionPartnerTransactionId rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Partner Transaction Id' ;
    rdfs:comment 'Reference to the original partner transaction that this record reverses or adjusts.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerTransaction .

ind:settlementGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Settlement Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Partner transactions require GL account mapping for settlement accounting. Partner commissions, points purchases from partners, and reconciliation entries all flow through specific GL accounts. Requir' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Monetary value of the transaction at the partner location before points conversion.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusPoints rdf:type rdf:Property ;
    rdfs:label 'Bonus Points' ;
    rdfs:comment 'Additional promotional or campaign-driven bonus points awarded on top of base points for this transaction.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Commission Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the partner commission amount.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether this transaction is under dispute between the retailer and coalition partner.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberTierAtTransaction rdf:type rdf:Property ;
    rdfs:label 'Member Tier At Transaction' ;
    rdfs:comment 'Loyalty program tier level of the member at the time of this transaction, used for tier-based points calculation.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCategory rdf:type rdf:Property ;
    rdfs:label 'Partner Category' ;
    rdfs:comment 'Business category or industry vertical of the coalition partner (e.g., travel, dining, fuel, entertainment).' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Partner Commission Amount' ;
    rdfs:comment 'Commission or interchange fee paid to or received from the coalition partner for this transaction.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerFileBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Partner File Batch Number' ;
    rdfs:comment 'Identifier of the partner data file or Electronic Data Interchange (EDI) batch that contained this transaction record.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerLocationCode rdf:type rdf:Property ;
    rdfs:label 'Partner Location Code' ;
    rdfs:comment 'Code identifying the specific partner location or outlet where the transaction occurred.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerMerchantCode rdf:type rdf:Property ;
    rdfs:label 'Partner Merchant Code' ;
    rdfs:comment 'Unique merchant identifier assigned by the partner organization for transaction tracking.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsAwarded rdf:type rdf:Property ;
    rdfs:label 'Points Awarded' ;
    rdfs:comment 'Number of loyalty points awarded to the member for this partner transaction. Positive for earn transactions, zero for redemptions.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Date' ;
    rdfs:comment 'Date when the points awarded in this transaction will expire if not redeemed.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Points Redeemed' ;
    rdfs:comment 'Number of loyalty points deducted from the member account for this partner redemption transaction. Positive for redemptions, zero for earn transactions.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'External transaction reference number provided by the coalition partner system for reconciliation and audit purposes.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Code indicating the reason for transaction reversal or cancellation, if applicable.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'Timestamp when the transaction was reversed or cancelled.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Settlement Batch Number' ;
    rdfs:comment 'Reference to the financial settlement batch in which this partner transaction was reconciled and settled.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionChannel rdf:type rdf:Property ;
    rdfs:label 'Transaction Channel' ;
    rdfs:comment 'Channel through which the partner transaction was initiated by the member.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsLedgerId rdf:type rdf:Property ;
    rdfs:label 'Points Ledger Id' ;
    rdfs:comment 'Unique identifier for each points ledger entry. Primary key for the immutable append-only ledger.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:membershipId rdf:type rdf:Property ;
    rdfs:label 'Membership Id' ;
    rdfs:comment 'FK to loyalty.membership.membership_id — Points ledger to membership is the core loyalty accounting join. Every points balance inquiry, tier qualification check, and loyalty statement requires this link.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyMembership .

ind:redemptionRuleId rdf:type rdf:Property ;
    rdfs:label 'Redemption Rule Id' ;
    rdfs:comment 'Foreign key linking to loyalty.redemption_rule. Business justification: Points ledger entries of type \'redeem\' should reference which redemption rule was applied. Parallel to accrual_rule_id, this enables audit trail for rule enforcement, compliance reporting, and analyti' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RedemptionRule .

ind:reversalReferencePointsLedgerId rdf:type rdf:Property ;
    rdfs:label 'Reversal Reference Points Ledger Id' ;
    rdfs:comment 'Points ledger ID of the original transaction being reversed. Populated only for transaction_type = reversal. Creates audit trail linking correction to original entry.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PointsLedger .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Free-text explanation for manual points adjustments. Populated only for transaction_type = adjust. Provides business context for non-standard transactions requiring audit trail.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Base Currency Amount' ;
    rdfs:comment 'Monetary value in base currency (USD, EUR, etc.) that generated the points earn. Used to calculate points-per-dollar ratio and Customer Lifetime Value (CLTV). Null for non-purchase transactions.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakageRate rdf:type rdf:Property ;
    rdfs:label 'Breakage Rate' ;
    rdfs:comment 'Expected percentage of points that will never be redeemed (expire or go unused). Applied at transaction time for liability calculation. Expressed as decimal (e.g., 0.15 for 15% breakage).' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earnMultiplier rdf:type rdf:Property ;
    rdfs:label 'Earn Multiplier' ;
    rdfs:comment 'Multiplier applied to base earn rate for this transaction. Standard earn is 1.0, promotional or tier-based accelerators may be 2.0, 3.0, etc. Null for non-earn transactions.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPromotional rdf:type rdf:Property ;
    rdfs:label 'Is Promotional' ;
    rdfs:comment 'Flag indicating whether this points transaction was part of a promotional or bonus program (True) or standard program rules (False). Used to segment promotional vs. organic points activity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newTier rdf:type rdf:Property ;
    rdfs:label 'New Tier' ;
    rdfs:comment 'Loyalty membership tier after this transaction. Populated only for transaction_type = tier_qualify. Records the tier achieved through qualification event.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsAmount rdf:type rdf:Property ;
    rdfs:label 'Points Amount' ;
    rdfs:comment 'Signed points value for this transaction. Positive for earn/bonus/transfer-in, negative for redeem/expire/transfer-out. Supports fractional points for partner conversions.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Points Liability Amount' ;
    rdfs:comment 'Estimated monetary liability (in base currency) associated with the points in this transaction. Calculated using breakage-adjusted redemption value. Critical for ASC 606 deferred revenue accounting.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousTier rdf:type rdf:Property ;
    rdfs:label 'Previous Tier' ;
    rdfs:comment 'Loyalty membership tier before this transaction. Populated only for transaction_type = tier_qualify. Captures tier transition history for member journey analysis.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Qualification Period End' ;
    rdfs:comment 'End date of the evaluation period used to assess tier qualification. Populated only for transaction_type = tier_qualify. Completes the qualification window definition.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Qualification Period Start' ;
    rdfs:comment 'Start date of the evaluation period used to assess tier qualification. Populated only for transaction_type = tier_qualify. Defines the rolling window or calendar period for tier assessment.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingPointsAmount rdf:type rdf:Property ;
    rdfs:label 'Qualifying Points Amount' ;
    rdfs:comment 'Total points earned that qualified the member for tier change. Populated only for transaction_type = tier_qualify. Alternative or complementary qualification metric to spend.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualifyingSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Qualifying Spend Amount' ;
    rdfs:comment 'Total spend amount that qualified the member for tier change. Populated only for transaction_type = tier_qualify. Provides evidence for tier qualification audit.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionValuePerPoint rdf:type rdf:Property ;
    rdfs:label 'Redemption Value Per Point' ;
    rdfs:comment 'Estimated monetary value (in base currency) of one loyalty point at time of transaction. Used to calculate points liability. May vary by tier, promotion, or partner agreement.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Business reason for reversing a prior points transaction: return (product returned), cancellation (order cancelled), fraud (fraudulent activity detected), system_error (technical issue correction), customer_service (goodwill adjustment). Populated only for reversal transactions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runningBalance rdf:type rdf:Property ;
    rdfs:label 'Running Balance' ;
    rdfs:comment 'Cumulative points balance for the membership after this transaction is applied. Provides snapshot of available points at this moment in time.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Source Reference Code' ;
    rdfs:comment 'Identifier of the originating transaction or event in the source system. Links back to POS transaction ID, order number, promotion code, partner transaction ID, or adjustment ticket number for full audit trail.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceType rdf:type rdf:Property ;
    rdfs:label 'Source Reference Type' ;
    rdfs:comment 'Category of the originating business event that triggered this points transaction: pos_transaction (in-store purchase via Point of Sale), order (e-commerce or omnichannel order), promotion (marketing campaign or offer), partner (third-party loyalty partner activity), tier_evaluation (automated tier qualification assessment), manual_adjustment (customer service or program admin correction), campaign (targeted engagement initiative). [ENUM-REF-CANDIDATE: pos_transaction|order|promotion|partner|tier_evaluation|manual_adjustment|campaign — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudDetectionScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Detection Score' ;
    rdfs:comment 'Numerical risk score (0-100) assigned by fraud detection algorithms at the time of redemption. Higher scores indicate higher fraud risk.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFraudulent rdf:type rdf:Property ;
    rdfs:label 'Is Fraudulent' ;
    rdfs:comment 'Boolean flag indicating whether the redemption was identified as fraudulent by fraud detection systems or manual review. True if fraudulent, False otherwise.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monetaryValue rdf:type rdf:Property ;
    rdfs:label 'Monetary Value' ;
    rdfs:comment 'Equivalent monetary value of the redemption in the base currency. Used for ROI analysis and financial reconciliation of loyalty program costs.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionNumber rdf:type rdf:Property ;
    rdfs:label 'Redemption Number' ;
    rdfs:comment 'Human-readable business identifier for the redemption transaction, used for customer service inquiries and operational tracking.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Status' ;
    rdfs:comment 'Current lifecycle state of the redemption: issued (voucher/code generated), activated (member claimed), used (redeemed at point of sale or fulfillment), expired (passed validity period), cancelled (member or system cancelled), reversed (points restored due to return or error).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionType rdf:type rdf:Property ;
    rdfs:label 'Redemption Type' ;
    rdfs:comment 'Discriminator indicating the category of redemption: catalog reward (standard rewards catalog item), personalized offer (targeted member-specific offer), promotional offer (campaign-driven offer), partner reward (third-party partner reward), instant discount (point-of-sale discount), or voucher (gift certificate or coupon).' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierAtRedemption rdf:type rdf:Property ;
    rdfs:label 'Tier At Redemption' ;
    rdfs:comment 'The loyalty program tier level of the member at the time of redemption (e.g., Silver, Gold, Platinum). Captured for tier-based redemption analysis and benefit tracking.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageTimestamp rdf:type rdf:Property ;
    rdfs:label 'Usage Timestamp' ;
    rdfs:comment 'Date and time when the voucher or reward was actually used in a transaction. Null if status is issued or activated but not yet used.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:voucherCode rdf:type rdf:Property ;
    rdfs:label 'Voucher Code' ;
    rdfs:comment 'Unique alphanumeric code issued to the member for redemption at point of sale or online checkout. Used to track usage and prevent fraud.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRedemptionAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Redemption Associate Id' ;
    rdfs:comment 'Identifier of the user or system account that created this redemption rule record.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:approvalWorkflowCode rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Code' ;
    rdfs:comment 'Identifier of the approval workflow process to be triggered when requires_approval_flag is True. Nullable if no approval required.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutEndDate rdf:type rdf:Property ;
    rdfs:label 'Blackout End Date' ;
    rdfs:comment 'End date of blackout period during which redemptions under this rule are not allowed. Nullable if no blackout applies.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blackoutStartDate rdf:type rdf:Property ;
    rdfs:label 'Blackout Start Date' ;
    rdfs:comment 'Start date of blackout period during which redemptions under this rule are not allowed. Nullable if no blackout applies.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:combinableWithPromotionsFlag rdf:type rdf:Property ;
    rdfs:label 'Combinable With Promotions Flag' ;
    rdfs:comment 'Indicates whether this redemption rule can be combined with other promotional offers (True) or must be used exclusively (False).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleChannels rdf:type rdf:Property ;
    rdfs:label 'Eligible Channels' ;
    rdfs:comment 'Comma-separated list of channels where this redemption rule can be applied (e.g., store, online, mobile_app, call_center).' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleRewardTypes rdf:type rdf:Property ;
    rdfs:label 'Eligible Reward Types' ;
    rdfs:comment 'Comma-separated list of reward types that can be redeemed under this rule (e.g., merchandise, gift_card, discount, cashback, travel).' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excludedProductCategories rdf:type rdf:Property ;
    rdfs:label 'Excluded Product Categories' ;
    rdfs:comment 'Comma-separated list of product category codes that are excluded from redemption under this rule (e.g., alcohol, tobacco, gift cards). Nullable if no exclusions.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Liability Impact Category' ;
    rdfs:comment 'Classification of how this redemption rule impacts loyalty points liability accounting (immediate recognition, deferred, conditional on fulfillment, or no impact).' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingMessage rdf:type rdf:Property ;
    rdfs:label 'Marketing Message' ;
    rdfs:comment 'Customer-facing marketing message or promotional text to be displayed when presenting this redemption rule to members.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPointsThreshold rdf:type rdf:Property ;
    rdfs:label 'Maximum Points Threshold' ;
    rdfs:comment 'Maximum number of loyalty points that can be redeemed in a single transaction under this rule. Nullable for unlimited redemptions.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumRedemptionsPerDay rdf:type rdf:Property ;
    rdfs:label 'Maximum Redemptions Per Day' ;
    rdfs:comment 'Maximum number of redemption transactions allowed per member per day under this rule. Nullable for unlimited daily usage.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumRedemptionsPerMember rdf:type rdf:Property ;
    rdfs:label 'Maximum Redemptions Per Member' ;
    rdfs:comment 'Maximum number of times a single member can use this redemption rule within the effective period. Nullable for unlimited usage.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumMembershipTier rdf:type rdf:Property ;
    rdfs:label 'Minimum Membership Tier' ;
    rdfs:comment 'Minimum loyalty program tier required for a member to use this redemption rule (e.g., bronze, silver, gold, platinum). Nullable if no tier restriction.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumPointsThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Points Threshold' ;
    rdfs:comment 'Minimum number of loyalty points required to initiate a redemption transaction under this rule.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partialRedemptionAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Redemption Allowed Flag' ;
    rdfs:comment 'Indicates whether members can redeem points in amounts less than the full reward value (True) or must redeem in full increments only (False).' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posIntegrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pos Integration Required Flag' ;
    rdfs:comment 'Indicates whether this redemption rule requires real-time integration with Point of Sale (POS) systems for in-store redemptions (True) or can be processed offline (False).' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redemptionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Redemption Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the monetary value associated with point redemptions.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionRate rdf:type rdf:Property ;
    rdfs:label 'Redemption Rate' ;
    rdfs:comment 'Conversion rate defining how many points equal one unit of currency or reward value (e.g., 100 points = 1 USD).' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Rule Status' ;
    rdfs:comment 'Current lifecycle status of the redemption rule indicating its operational state.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Approval Flag' ;
    rdfs:comment 'Indicates whether redemptions under this rule require manager or system approval before processing (True) or are auto-approved (False).' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roundingRule rdf:type rdf:Property ;
    rdfs:label 'Rounding Rule' ;
    rdfs:comment 'Rule for rounding points during redemption calculations when fractional points result from conversion.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralId rdf:type rdf:Property ;
    rdfs:label 'Referral Id' ;
    rdfs:comment 'Unique identifier for the referral transaction. Primary key for the referral data product.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstPurchaseOrderHeaderId rdf:type rdf:Property ;
    rdfs:label 'First Purchase Order Header Id' ;
    rdfs:comment 'Foreign key linking to order.order_header. Business justification: Referral programs require linking referee\'s qualifying first order to automate reward fulfillment, validate qualification criteria, detect fraud, and measure referral campaign ROI—standard retail loya' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:referralLoyaltyMembershipId rdf:type rdf:Property ;
    rdfs:label 'Referral Loyalty Membership Id' ;
    rdfs:comment 'Identifier of the loyalty program member who initiated the referral. Links to the member who is advocating for the program.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyMembership .

ind:referralReferredMemberMembershipLoyaltyMembershipId rdf:type rdf:Property ;
    rdfs:label 'Referral Referred Member Membership Loyalty Membership Id' ;
    rdfs:comment 'Identifier of the loyalty membership created for the referred individual upon successful enrollment. Null until the referred individual completes enrollment.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyMembership .

ind:firstPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'First Purchase Amount' ;
    rdfs:comment 'Total monetary value of the first purchase made by the referred individual. Used to evaluate referral quality and program ROI.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstPurchaseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'First Purchase Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the first purchase amount. Supports multi-currency loyalty program operations.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'First Purchase Date' ;
    rdfs:comment 'Date when the referred individual completed their first purchase. Used to track conversion from enrollment to active customer status.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'Date when the referral met all qualification criteria for reward eligibility. Null if qualification has not been achieved.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationMetFlag rdf:type rdf:Property ;
    rdfs:label 'Qualification Met Flag' ;
    rdfs:comment 'Indicates whether the referred individual has satisfied all qualification criteria. True when qualification is complete, false otherwise.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refereeRewardCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Referee Reward Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for monetary rewards granted to the referred individual. Null for non-monetary rewards.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refereeRewardDate rdf:type rdf:Property ;
    rdfs:label 'Referee Reward Date' ;
    rdfs:comment 'Date when the reward was granted to the referred individual. Null if the reward has not yet been issued.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refereeRewardType rdf:type rdf:Property ;
    rdfs:label 'Referee Reward Type' ;
    rdfs:comment 'Type of reward granted to the referred individual upon enrollment or first purchase. Incentivizes new member acquisition.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refereeRewardValue rdf:type rdf:Property ;
    rdfs:label 'Referee Reward Value' ;
    rdfs:comment 'Monetary or points value of the reward granted to the referred individual. Denominated in points or currency depending on reward type.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referralDate rdf:type rdf:Property ;
    rdfs:label 'Referral Date' ;
    rdfs:comment 'Date when the referral was initiated by the referring member. Represents the business event timestamp for the referral action.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralTimestamp rdf:type rdf:Property ;
    rdfs:label 'Referral Timestamp' ;
    rdfs:comment 'Precise timestamp when the referral was created in the system. Captures the exact moment of referral initiation for audit and sequencing purposes.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referrerRewardCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Referrer Reward Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for monetary rewards granted to the referring member. Null for non-monetary rewards such as points or tier credits.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referrerRewardDate rdf:type rdf:Property ;
    rdfs:label 'Referrer Reward Date' ;
    rdfs:comment 'Date when the reward was granted to the referring member. Null if the reward has not yet been issued.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referrerRewardType rdf:type rdf:Property ;
    rdfs:label 'Referrer Reward Type' ;
    rdfs:comment 'Type of reward granted to the referring member upon successful referral qualification. Defines the incentive structure for advocacy.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referrerRewardValue rdf:type rdf:Property ;
    rdfs:label 'Referrer Reward Value' ;
    rdfs:comment 'Monetary or points value of the reward granted to the referring member. Denominated in points or currency depending on reward type.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viralCoefficientContribution rdf:type rdf:Property ;
    rdfs:label 'Viral Coefficient Contribution' ;
    rdfs:comment 'Calculated metric representing this referrals contribution to program viral growth. Measures the multiplier effect of member advocacy on program enrollment.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibleStoreFormatId rdf:type rdf:Property ;
    rdfs:label 'Eligible Store Format Id' ;
    rdfs:comment 'Foreign key linking to store.store_format. Business justification: Reward eligibility restricted by format (experiential rewards only at flagship, bulk discounts only at warehouse). Retail loyalty catalogs curated per format to match inventory, service capabilities, ' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Format .

ind:partnerVendorId rdf:type rdf:Property ;
    rdfs:label 'Partner Vendor Id' ;
    rdfs:comment 'External identifier for the partner vendor in the vendor management system. Null for internally-fulfilled rewards.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:productSkuId rdf:type rdf:Property ;
    rdfs:label 'Product Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Loyalty rewards can be product-based (e.g., \'redeem points for this SKU\'). The reward.product_sku_restriction field suggests SKU-level restrictions exist. This links loyalty rewards to the product cat' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:brandRestriction rdf:type rdf:Property ;
    rdfs:label 'Brand Restriction' ;
    rdfs:comment 'Comma-separated list of brand codes this reward applies to or excludes. Null if no brand restriction. Supports brand-sponsored rewards.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryRestriction rdf:type rdf:Property ;
    rdfs:label 'Category Restriction' ;
    rdfs:comment 'Comma-separated list of product category codes this reward applies to or excludes (e.g., \'ELECTRONICS,APPAREL\'). Null if no category restriction.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelAvailability rdf:type rdf:Property ;
    rdfs:label 'Channel Availability' ;
    rdfs:comment 'Channels where this reward can be redeemed: in-store (physical locations), online (e-commerce site), mobile app, call center, or all channels (omnichannel). Supports channel-specific reward strategies.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costToBusiness rdf:type rdf:Property ;
    rdfs:label 'Cost To Business' ;
    rdfs:comment 'Internal cost to the business for fulfilling this reward (e.g., wholesale cost, partner fee). Used for program ROI analysis and points liability valuation. Business-confidential.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User identifier or system account that created this reward record. Part of audit trail.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:descriptionLong rdf:type rdf:Property ;
    rdfs:label 'Description Long' ;
    rdfs:comment 'Detailed customer-facing description of the reward, including benefits, usage instructions, and value proposition. Used in reward detail pages.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:descriptionShort rdf:type rdf:Property ;
    rdfs:label 'Description Short' ;
    rdfs:comment 'Brief customer-facing description of the reward (typically 1-2 sentences), used in catalog list views and mobile notifications.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleMemberTiers rdf:type rdf:Property ;
    rdfs:label 'Eligible Member Tiers' ;
    rdfs:comment 'Comma-separated list of loyalty tier codes eligible to redeem this reward (e.g., \'SILVER,GOLD,PLATINUM\'). Null or \'ALL\' if available to all tiers. Enables tier-exclusive rewards.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCombinable rdf:type rdf:Property ;
    rdfs:label 'Is Combinable' ;
    rdfs:comment 'Boolean flag indicating whether this reward can be combined with other rewards or promotions in a single transaction. True if combinable, false if exclusive.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marginPercentage rdf:type rdf:Property ;
    rdfs:label 'Margin Percentage' ;
    rdfs:comment 'Calculated margin percentage between monetary value and cost to business ((monetary_value - cost_to_business) / monetary_value * 100). Used for reward profitability analysis. Business-confidential.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Discount Amount' ;
    rdfs:comment 'Cap on the discount amount for percentage-based rewards (e.g., 20% off up to $50 maximum discount). Null if no cap applies.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Purchase Amount' ;
    rdfs:comment 'Minimum transaction amount required to redeem this reward. Null if no minimum applies. Used to enforce redemption rules and protect margin.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsCost rdf:type rdf:Property ;
    rdfs:label 'Points Cost' ;
    rdfs:comment 'Number of loyalty points required to redeem this reward. Core pricing mechanism for the loyalty program.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productSkuRestriction rdf:type rdf:Property ;
    rdfs:label 'Product Sku Restriction' ;
    rdfs:comment 'Comma-separated list of SKU codes this reward applies to or excludes. Used for product-specific rewards (e.g., free product reward for specific SKU). Null if no SKU restriction.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityLimitPerMember rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Per Member' ;
    rdfs:comment 'Maximum number of times a single loyalty member can redeem this reward within the validity period. Null for no limit.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionValidityDays rdf:type rdf:Property ;
    rdfs:label 'Redemption Validity Days' ;
    rdfs:comment 'Number of days from redemption date that the reward voucher or certificate remains valid for use. Null for instant-use rewards.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rewardCategory rdf:type rdf:Property ;
    rdfs:label 'Reward Category' ;
    rdfs:comment 'Business classification grouping for the reward (e.g., \'Grocery\', \'Apparel\', \'Electronics\', \'Travel\', \'Dining\', \'Wellness\'). Used for catalog navigation and reporting.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardCode rdf:type rdf:Property ;
    rdfs:label 'Reward Code' ;
    rdfs:comment 'Externally-facing unique alphanumeric code for the reward, used in customer communications and redemption interfaces.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardName rdf:type rdf:Property ;
    rdfs:label 'Reward Name' ;
    rdfs:comment 'Customer-facing display name of the reward (e.g., \'$10 Off Next Purchase\', \'Free Coffee\', \'Premium Gift Card\').' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardStatus rdf:type rdf:Property ;
    rdfs:label 'Reward Status' ;
    rdfs:comment 'Current lifecycle status of the reward in the catalog. Active: available for redemption. Inactive: temporarily unavailable. Sold out: inventory depleted. Discontinued: permanently removed. Pending approval: awaiting merchandising review.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardType rdf:type rdf:Property ;
    rdfs:label 'Reward Type' ;
    rdfs:comment 'Classification of the reward by its nature: discount voucher (percentage or fixed amount off), free product (complimentary item), gift card (prepaid card), experience (event or service), charitable donation (contribution to cause), cashback (monetary return), or points multiplier (bonus points on future purchases). [ENUM-REF-CANDIDATE: discount_voucher|free_product|gift_card|experience|charitable_donation|cashback|points_multiplier — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'User identifier or system account that last modified this reward record. Part of audit trail.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierId rdf:type rdf:Property ;
    rdfs:label 'Tier Id' ;
    rdfs:comment 'Unique identifier for the loyalty program tier. Primary key.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:badgeColor rdf:type rdf:Property ;
    rdfs:label 'Badge Color' ;
    rdfs:comment 'Hex color code or color name for the tier badge displayed in digital channels and physical membership cards (e.g., #C0C0C0 for Silver, #FFD700 for Gold, #E5E4E2 for Platinum, #B9F2FF for Diamond).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:badgeIconUrl rdf:type rdf:Property ;
    rdfs:label 'Badge Icon Url' ;
    rdfs:comment 'URL to the digital asset (icon or badge image) representing this tier in mobile apps, websites, and digital communications.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitsSummary rdf:type rdf:Property ;
    rdfs:label 'Benefits Summary' ;
    rdfs:comment 'Textual summary of key benefits and privileges associated with this tier (e.g., free shipping, priority customer service, exclusive access to sales, birthday rewards, concierge service). Used for customer communication and marketing.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downgradeRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Downgrade Rule Description' ;
    rdfs:comment 'Textual description of the rules and conditions under which a customer is downgraded from this tier (e.g., automatic if maintenance threshold not met, grace period of 3 months, no downgrades for lifetime tiers).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gracePeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Grace Period Months' ;
    rdfs:comment 'Number of months a customer retains tier status after failing to meet maintenance threshold before being downgraded. Null if no grace period is offered.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invitationOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Invitation Only Flag' ;
    rdfs:comment 'Indicates whether this tier is available only by invitation from the company (True) or can be achieved through standard qualification rules (False). Typically used for ultra-premium or VIP tiers.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifetimeTierFlag rdf:type rdf:Property ;
    rdfs:label 'Lifetime Tier Flag' ;
    rdfs:comment 'Indicates whether this tier, once achieved, is retained for the customer\'s lifetime regardless of future activity (True) or is subject to periodic review and potential downgrade (False).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenancePeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Maintenance Period Months' ;
    rdfs:comment 'Number of months over which the maintenance threshold must be met to retain tier status (e.g., 12 for annual review). Null if no maintenance requirement.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Maintenance Threshold Value' ;
    rdfs:comment 'Numeric value a customer must achieve to maintain this tier after initial qualification. Often lower than qualification threshold to encourage retention. Null if maintenance equals qualification.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingDescription rdf:type rdf:Property ;
    rdfs:label 'Marketing Description' ;
    rdfs:comment 'Extended marketing copy describing the tier\'s value proposition, benefits, and aspirational messaging. Used in promotional materials, program brochures, and enrollment campaigns.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsEarningMultiplier rdf:type rdf:Property ;
    rdfs:label 'Points Earning Multiplier' ;
    rdfs:comment 'Multiplier applied to base points earning rate for members of this tier (e.g., 1.0 for base tier, 1.5 for Gold, 2.0 for Platinum). Higher tiers earn points faster.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsRedemptionDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Points Redemption Discount Pct' ;
    rdfs:comment 'Percentage discount applied to points required for redemption rewards for this tier (e.g., 0 for base tier, 10 for Gold means 10% fewer points needed, 20 for Platinum). Enhances redemption value for premium tiers.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Qualification Period Months' ;
    rdfs:comment 'Number of months over which the qualification threshold must be met (e.g., 12 for annual qualification, 3 for quarterly). Null indicates lifetime qualification.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationThresholdType rdf:type rdf:Property ;
    rdfs:label 'Qualification Threshold Type' ;
    rdfs:comment 'The metric used to determine tier qualification: spend (total monetary spend), points (loyalty points earned), transactions (number of purchases), or hybrid (combination of multiple metrics).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Qualification Threshold Value' ;
    rdfs:comment 'Numeric value a customer must achieve to qualify for this tier (e.g., $5000 annual spend, 10000 points earned, 50 transactions). Interpretation depends on qualification_threshold_type.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the tier within the program (e.g., SILVER, GOLD, PLAT, DIAM). Used for system integration and reporting.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Human-readable name of the loyalty tier displayed to customers (e.g., Silver Member, Gold Member, Platinum Elite, Diamond VIP).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierRank rdf:type rdf:Property ;
    rdfs:label 'Tier Rank' ;
    rdfs:comment 'Ordinal ranking of the tier within the loyalty program hierarchy. Lower numbers indicate entry-level tiers; higher numbers indicate premium tiers (e.g., 1=Silver, 2=Gold, 3=Platinum, 4=Diamond).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Status' ;
    rdfs:comment 'Current lifecycle status of the tier. Active tiers are available for customer enrollment and qualification; inactive tiers are no longer offered but may have legacy members; deprecated tiers are being phased out; planned tiers are under development.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Upgrade Rule Description' ;
    rdfs:comment 'Textual description of the rules and conditions under which a customer is upgraded to this tier (e.g., automatic upon reaching threshold, manual review required, invitation-only for top tier).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abTestCampaignId rdf:type rdf:Property ;
    rdfs:label 'Ab Test Campaign Id' ;
    rdfs:comment 'Unique identifier for the A/B test campaign record. Primary key.' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audienceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Id' ;
    rdfs:comment 'Reference to the audience segment used for this A/B test, defining the target population.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceSegment .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Foreign key linking to marketing.marketing_channel. Business justification: A/B test campaigns are conducted within specific marketing channels and should reference the authoritative marketing_channel master. Currently, ab_test_campaign has a denormalized channel_tested STRIN' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:creativeAssetId rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Id' ;
    rdfs:comment 'Foreign key linking to marketing.creative_asset. Business justification: A/B tests often test different creative variants. The ab_test_campaign should link to the creative_asset being tested. The control_variant_definition and test_variant_definition are STRING description' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreativeAsset .

ind:modifiedByAssociateId rdf:type rdf:Property ;
    rdfs:label 'Modified By Associate Id' ;
    rdfs:comment 'Reference to the employee or user who last modified this A/B test campaign record.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:primaryAbAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Ab Associate Id' ;
    rdfs:comment 'Reference to the employee or user responsible for designing, executing, and analyzing this A/B test.' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:testSkuPriceId rdf:type rdf:Property ;
    rdfs:label 'Test Sku Price Id' ;
    rdfs:comment 'Foreign key linking to pricing.sku_price. Business justification: A/B tests in retail frequently test different price points or promotional depths. Test variant definitions require linking to the specific prices being tested. Real business process: promotional optim' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuPrice .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'The precise timestamp when the A/B test campaign execution ended.' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'The precise timestamp when the A/B test campaign execution began.' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confidenceLevelPct rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Pct' ;
    rdfs:comment 'The actual confidence level achieved in the test results, indicating the statistical reliability of the outcome.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlAudienceSize rdf:type rdf:Property ;
    rdfs:label 'Control Audience Size' ;
    rdfs:comment 'Number of individuals or contacts assigned to the control variant.' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlAudienceSplitPct rdf:type rdf:Property ;
    rdfs:label 'Control Audience Split Pct' ;
    rdfs:comment 'Percentage of the total audience allocated to the control variant (e.g., 50.00 for a 50/50 split).' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlMetricValue rdf:type rdf:Property ;
    rdfs:label 'Control Metric Value' ;
    rdfs:comment 'The measured value of the primary success metric for the control variant (e.g., 25.50 for 25.5% open rate).' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlVariantDefinition rdf:type rdf:Property ;
    rdfs:label 'Control Variant Definition' ;
    rdfs:comment 'Detailed description of the control (baseline) variant used in the test, including creative elements, messaging, and configuration.' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liftPct rdf:type rdf:Property ;
    rdfs:label 'Lift Pct' ;
    rdfs:comment 'The percentage improvement (or decline) of the test variant over the control variant for the primary success metric.' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primarySuccessMetric rdf:type rdf:Property ;
    rdfs:label 'Primary Success Metric' ;
    rdfs:comment 'The key performance indicator (KPI) used to determine the winning variant (e.g., open rate, click-through rate, conversion rate, revenue, engagement rate).' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalSignificanceThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Statistical Significance Threshold Pct' ;
    rdfs:comment 'The confidence level threshold (e.g., 95.00) required to declare a variant as statistically significant winner.' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testAudienceSize rdf:type rdf:Property ;
    rdfs:label 'Test Audience Size' ;
    rdfs:comment 'Number of individuals or contacts assigned to the test variant(s).' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testAudienceSplitPct rdf:type rdf:Property ;
    rdfs:label 'Test Audience Split Pct' ;
    rdfs:comment 'Percentage of the total audience allocated to the test variant(s) (e.g., 50.00 for a 50/50 split).' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testEndDate rdf:type rdf:Property ;
    rdfs:label 'Test End Date' ;
    rdfs:comment 'The date when the A/B test campaign concluded or is scheduled to conclude.' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testMetricValue rdf:type rdf:Property ;
    rdfs:label 'Test Metric Value' ;
    rdfs:comment 'The measured value of the primary success metric for the test variant (e.g., 28.75 for 28.75% open rate).' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testNotes rdf:type rdf:Property ;
    rdfs:label 'Test Notes' ;
    rdfs:comment 'Additional notes, observations, or learnings captured during or after the test execution.' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStartDate rdf:type rdf:Property ;
    rdfs:label 'Test Start Date' ;
    rdfs:comment 'The date when the A/B test campaign was launched and began collecting data.' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testVariantDefinition rdf:type rdf:Property ;
    rdfs:label 'Test Variant Definition' ;
    rdfs:comment 'Detailed description of the test (challenger) variant(s) used in the experiment, including creative elements, messaging, and configuration.' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAudienceSize rdf:type rdf:Property ;
    rdfs:label 'Total Audience Size' ;
    rdfs:comment 'Total number of individuals or contacts included in the A/B test across all variants.' ;
    rdfs:domain ind:AbTestCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agencyBriefId rdf:type rdf:Property ;
    rdfs:label 'Agency Brief Id' ;
    rdfs:comment 'Unique identifier for the agency brief record. Primary key.' ;
    rdfs:domain ind:AgencyBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agencyAssociateId rdf:type rdf:Property ;
    rdfs:label 'Agency Associate Id' ;
    rdfs:comment 'FK to workforce.associate' ;
    rdfs:domain ind:AgencyBrief ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:marketingBrandId rdf:type rdf:Property ;
    rdfs:label 'Marketing Brand Id' ;
    rdfs:comment 'Identifier of the retail brand or private label that this brief supports.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketingBrand .

ind:primaryAgencyAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Agency Associate Id' ;
    rdfs:comment 'Identifier of the internal user who approved the agency deliverables.' ;
    rdfs:domain ind:AgencyBrief ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:agencyContactEmail rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Email' ;
    rdfs:comment 'Email address of the primary agency contact for communication regarding this brief.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyContactName rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Name' ;
    rdfs:comment 'Primary contact person at the agency responsible for this brief.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Phone' ;
    rdfs:comment 'Phone number of the primary agency contact for urgent communications.' ;
    rdfs:domain ind:AgencyBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'Name of the external agency (creative, media, digital, PR, or influencer) to which this brief is issued.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyType rdf:type rdf:Property ;
    rdfs:label 'Agency Type' ;
    rdfs:comment 'Classification of the agency based on their specialization and service offering.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Brief Issued Date' ;
    rdfs:comment 'Date when the brief was officially issued to the agency, marking the start of the agency engagement.' ;
    rdfs:domain ind:AgencyBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:briefName rdf:type rdf:Property ;
    rdfs:label 'Brief Name' ;
    rdfs:comment 'Descriptive name of the agency brief that summarizes the project or initiative.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefNumber rdf:type rdf:Property ;
    rdfs:label 'Brief Number' ;
    rdfs:comment 'Human-readable unique reference number for the agency brief, used for tracking and communication with agencies.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefStatus rdf:type rdf:Property ;
    rdfs:label 'Brief Status' ;
    rdfs:comment 'Current lifecycle status of the agency brief indicating its progress through the workflow. [ENUM-REF-CANDIDATE: draft|issued|in_progress|delivered|approved|rejected|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Amount' ;
    rdfs:comment 'Total budget amount allocated to the agency for this brief, covering all deliverables and services.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the budget allocated amount.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelFocus rdf:type rdf:Property ;
    rdfs:label 'Channel Focus' ;
    rdfs:comment 'Primary marketing channels or media types that this brief targets (e.g., social media, TV, print, digital display).' ;
    rdfs:domain ind:AgencyBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'Legal, regulatory, and industry compliance requirements that the agency must adhere to (e.g., FTC disclosure, GDPR, advertising standards).' ;
    rdfs:domain ind:AgencyBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference number of the master service agreement or contract under which this brief is executed.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeGuidelines rdf:type rdf:Property ;
    rdfs:label 'Creative Guidelines' ;
    rdfs:comment 'Brand guidelines, tone of voice, visual standards, and creative constraints that the agency must follow.' ;
    rdfs:domain ind:AgencyBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableStatus rdf:type rdf:Property ;
    rdfs:label 'Deliverable Status' ;
    rdfs:comment 'Current status of the deliverables from the agency, tracking progress toward completion. [ENUM-REF-CANDIDATE: not_started|in_progress|submitted|under_review|approved|rejected|revision_required — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AgencyBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverablesList rdf:type rdf:Property ;
    rdfs:label 'Deliverables List' ;
    rdfs:comment 'Comma-separated or structured list of specific deliverables expected from the agency (e.g., creative concepts, media plans, content pieces, reports).' ;
    rdfs:domain ind:AgencyBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackNotes rdf:type rdf:Property ;
    rdfs:label 'Feedback Notes' ;
    rdfs:comment 'Internal feedback and comments provided to the agency regarding their submissions and deliverables.' ;
    rdfs:domain ind:AgencyBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyMessage rdf:type rdf:Property ;
    rdfs:label 'Key Message' ;
    rdfs:comment 'Primary message or value proposition that the agency should communicate through their deliverables.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneDates rdf:type rdf:Property ;
    rdfs:label 'Milestone Dates' ;
    rdfs:comment 'Key milestone dates and checkpoints throughout the project timeline, formatted as structured text or JSON.' ;
    rdfs:domain ind:AgencyBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectEndDate rdf:type rdf:Property ;
    rdfs:label 'Project End Date' ;
    rdfs:comment 'Planned or actual end date by which all deliverables should be completed and delivered.' ;
    rdfs:domain ind:AgencyBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectStartDate rdf:type rdf:Property ;
    rdfs:label 'Project Start Date' ;
    rdfs:comment 'Planned or actual start date for the agency to begin work on the brief deliverables.' ;
    rdfs:domain ind:AgencyBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Date by which the agency is expected to submit their initial response or proposal to the brief.' ;
    rdfs:domain ind:AgencyBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionCount rdf:type rdf:Property ;
    rdfs:label 'Revision Count' ;
    rdfs:comment 'Number of revision rounds requested for the deliverables, tracking iteration cycles.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scopeOfWork rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work' ;
    rdfs:comment 'Detailed description of the work to be performed by the agency, including objectives, requirements, and boundaries.' ;
    rdfs:domain ind:AgencyBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successCriteria rdf:type rdf:Property ;
    rdfs:label 'Success Criteria' ;
    rdfs:comment 'Measurable criteria and KPIs (Key Performance Indicators) that define success for this agency engagement.' ;
    rdfs:domain ind:AgencyBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceDescription rdf:type rdf:Property ;
    rdfs:label 'Target Audience Description' ;
    rdfs:comment 'Detailed description of the target audience for the campaign, including demographics, psychographics, and behavioral characteristics.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionModelId rdf:type rdf:Property ;
    rdfs:label 'Attribution Model Id' ;
    rdfs:comment 'Unique identifier for the attribution model configuration. Primary key.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttributionModel .

ind:baselineModelId rdf:type rdf:Property ;
    rdfs:label 'Baseline Model Id' ;
    rdfs:comment 'Reference to another attribution model used as the baseline for comparison and incrementality analysis. Enables A/B testing of attribution methodologies and measurement of model impact on ROI reporting.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttributionModel .

ind:primaryAttributionOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Attribution Org Unit Id' ;
    rdfs:comment 'Identifier of the analytics or marketing team responsible for maintaining and governing this attribution model configuration.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:algorithmicModelCode rdf:type rdf:Property ;
    rdfs:label 'Algorithmic Model Code' ;
    rdfs:comment 'Reference identifier to the machine learning or data-driven model used for algorithmic attribution. Applicable only when model_type is \'algorithmic\' or \'data_driven\'. Links to the ML model registry or experiment tracking system.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelWeightingRules rdf:type rdf:Property ;
    rdfs:label 'Channel Weighting Rules' ;
    rdfs:comment 'JSON or structured text defining the credit allocation rules per marketing channel. For position-based models, specifies percentage weights (e.g., \'first:40%, last:40%, middle:20%\'). For time-decay, defines the decay function parameters. For algorithmic models, references the ML model version.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionEventTypes rdf:type rdf:Property ;
    rdfs:label 'Conversion Event Types' ;
    rdfs:comment 'Comma-separated list of conversion event types in scope for this attribution model (e.g., \'purchase, add_to_cart, lead_submission, store_visit\'). Defines which customer actions are treated as conversions for credit assignment.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossChannelEnabled rdf:type rdf:Property ;
    rdfs:label 'Cross Channel Enabled' ;
    rdfs:comment 'Flag indicating whether this attribution model spans multiple marketing channels (omnichannel attribution). When true, touchpoints from online and offline channels are unified in the attribution path.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossDeviceEnabled rdf:type rdf:Property ;
    rdfs:label 'Cross Device Enabled' ;
    rdfs:comment 'Flag indicating whether this attribution model includes cross-device tracking and attribution. When true, touchpoints across multiple devices (mobile, desktop, tablet) for the same user are unified in the attribution path.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSourceSystems rdf:type rdf:Property ;
    rdfs:label 'Data Source Systems' ;
    rdfs:comment 'Comma-separated list of source systems providing touchpoint and conversion data for this attribution model (e.g., \'Google Analytics, Adobe Analytics, Salesforce, SAP CAR\'). Documents data lineage and integration points.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deduplicationWindowHours rdf:type rdf:Property ;
    rdfs:label 'Deduplication Window Hours' ;
    rdfs:comment 'Time window in hours used to deduplicate repeated touchpoints from the same channel. Multiple interactions within this window are collapsed into a single touchpoint to avoid over-crediting repetitive exposures.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:excludedChannels rdf:type rdf:Property ;
    rdfs:label 'Excluded Channels' ;
    rdfs:comment 'Comma-separated list of marketing channels explicitly excluded from this attribution model (e.g., \'internal_traffic, test_campaigns\'). Used to filter out non-customer touchpoints or internal activity.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:includedChannels rdf:type rdf:Property ;
    rdfs:label 'Included Channels' ;
    rdfs:comment 'Comma-separated list of marketing channels included in this attribution model (e.g., \'paid_search, organic_search, email, social_media, display, affiliate, direct\'). Channels not listed are excluded from attribution credit.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultModel rdf:type rdf:Property ;
    rdfs:label 'Is Default Model' ;
    rdfs:comment 'Flag indicating whether this is the default attribution model used for standard campaign ROI reporting when no specific model is requested. Only one model should be marked as default at any given time.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lookbackWindowDays rdf:type rdf:Property ;
    rdfs:label 'Lookback Window Days' ;
    rdfs:comment 'Number of days prior to conversion during which touchpoints are considered for attribution credit. Common values are 7, 14, 30, 60, or 90 days. Defines the temporal scope of the customer journey included in attribution analysis.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxTouchpointsConsidered rdf:type rdf:Property ;
    rdfs:label 'Max Touchpoints Considered' ;
    rdfs:comment 'Maximum number of touchpoints in a customer journey that will be included in attribution analysis. Touchpoints beyond this limit are truncated. Used to manage computational complexity and focus on most relevant interactions.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minTouchpointsRequired rdf:type rdf:Property ;
    rdfs:label 'Min Touchpoints Required' ;
    rdfs:comment 'Minimum number of marketing touchpoints required in a customer journey for attribution credit to be assigned. Journeys with fewer touchpoints may be excluded or handled differently. Common values are 1 (all journeys) or 2 (multi-touch only).' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modelCode rdf:type rdf:Property ;
    rdfs:label 'Model Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the model for system integration and reporting (e.g., \'LC_2024Q4\', \'MTL_STD\').' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelDescription rdf:type rdf:Property ;
    rdfs:label 'Model Description' ;
    rdfs:comment 'Detailed business description of the attribution model\'s purpose, methodology, use cases, and any special considerations. Provides context for analysts and stakeholders on when and how to apply this model.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Business-friendly name of the attribution model (e.g., \'Q4 2024 Last-Click Model\', \'Multi-Touch Linear Attribution\').' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelStatus rdf:type rdf:Property ;
    rdfs:label 'Model Status' ;
    rdfs:comment 'Current lifecycle status of the attribution model. Active models are in production use; inactive models are paused; draft models are under development; archived models are retained for historical reference; deprecated models are superseded by newer versions.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelType rdf:type rdf:Property ;
    rdfs:label 'Model Type' ;
    rdfs:comment 'The methodology used to assign conversion credit across touchpoints. Last-click assigns 100% credit to the final touchpoint; first-click to the initial touchpoint; linear distributes credit equally; time-decay gives more weight to recent interactions; position-based (U-shaped) emphasizes first and last; algorithmic/data-driven uses machine learning to determine credit distribution. [ENUM-REF-CANDIDATE: last_click|first_click|linear|time_decay|position_based|algorithmic|data_driven — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code used for all revenue and ROI calculations in this attribution model (e.g., \'USD\', \'EUR\', \'GBP\'). Ensures consistent financial reporting across campaigns.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionTouchpointId rdf:type rdf:Property ;
    rdfs:label 'Attribution Touchpoint Id' ;
    rdfs:comment 'Unique identifier for the attribution touchpoint event. Primary key for the immutable event record capturing each marketing interaction on the customer journey to conversion.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttributionTouchpoint .

ind:exposedSkuPriceId rdf:type rdf:Property ;
    rdfs:label 'Exposed Sku Price Id' ;
    rdfs:comment 'Foreign key linking to pricing.sku_price. Business justification: Attribution analysis needs to know which price point the customer saw at each touchpoint to understand price sensitivity and conversion drivers. Real business process: price elasticity modeling uses t' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuPrice .

ind:mediaBuyId rdf:type rdf:Property ;
    rdfs:label 'Media Buy Id' ;
    rdfs:comment 'Reference to the media buy or insertion order that funded this touchpoint. Links to media spend data for cost-per-touchpoint and ROAS (Return on Ad Spend) calculation.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaBuy .

ind:trackingPrivacyAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Tracking Privacy Assessment Id' ;
    rdfs:comment 'Foreign key linking to compliance.privacy_assessment. Business justification: Cross-device tracking and behavioral attribution require privacy assessment under GDPR Article 35 and CCPA. Real business need: legal basis validation for tracking technologies, data subject rights. R' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivacyAssessment .

ind:adNetwork rdf:type rdf:Property ;
    rdfs:label 'Ad Network' ;
    rdfs:comment 'The advertising network or platform that served this touchpoint (e.g., Google Ads, Facebook Ads, Criteo). Used for network-level attribution and vendor performance comparison.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adPlacement rdf:type rdf:Property ;
    rdfs:label 'Ad Placement' ;
    rdfs:comment 'The specific placement or position where the ad was shown (e.g., search_top, sidebar, feed, pre_roll). Used for placement-level attribution and media optimization.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:anonymousVisitorCode rdf:type rdf:Property ;
    rdfs:label 'Anonymous Visitor Code' ;
    rdfs:comment 'Pseudonymous identifier for unidentified visitors (cookie ID, device fingerprint, or session token). Used to track pre-conversion touchpoints before customer identification. May be stitched to customer_id post-conversion.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Conversion Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the conversion revenue amount. Required for multi-currency attribution reporting and global campaign analysis.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionEventFlag rdf:type rdf:Property ;
    rdfs:label 'Conversion Event Flag' ;
    rdfs:comment 'Indicates whether this touchpoint directly resulted in a conversion event (purchase, signup, lead submission). True for the final converting touchpoint; false for assisting touchpoints.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conversionRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Conversion Revenue Amount' ;
    rdfs:comment 'The total revenue amount (in base currency) attributed to the conversion event linked to this touchpoint. Used for revenue-weighted attribution models and ROAS calculation.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerTouchpoint rdf:type rdf:Property ;
    rdfs:label 'Cost Per Touchpoint' ;
    rdfs:comment 'The allocated media cost for this individual touchpoint (CPC for clicks, CPM-derived for impressions). Used for touchpoint-level ROI and efficiency analysis.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Event Source System' ;
    rdfs:comment 'The source system or platform that captured this touchpoint event (e.g., Google Analytics, Adobe Analytics, Salesforce Marketing Cloud). Used for data lineage and multi-source attribution reconciliation.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCity rdf:type rdf:Property ;
    rdfs:label 'Geographic City' ;
    rdfs:comment 'The city derived from IP geolocation. Used for hyper-local attribution and store-level marketing campaign analysis in omnichannel retail.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code derived from IP geolocation or device settings. Used for geographic attribution and regional campaign performance analysis.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'The state, province, or region derived from IP geolocation. Used for sub-national geographic attribution and local market campaign analysis.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'The timestamp when this touchpoint event was ingested into the lakehouse. Used for data freshness monitoring and late-arriving event handling in attribution pipelines.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isViewThrough rdf:type rdf:Property ;
    rdfs:label 'Is View Through' ;
    rdfs:comment 'Indicates whether this touchpoint was a view-through (impression-only, no click) that contributed to conversion. True for display impressions that influenced purchase without direct click.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeToConversionHours rdf:type rdf:Property ;
    rdfs:label 'Time To Conversion Hours' ;
    rdfs:comment 'The number of hours between this touchpoint and the eventual conversion event. Used for time-decay attribution models and customer journey velocity analysis.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:touchpointSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Sequence Number' ;
    rdfs:comment 'The ordinal position of this touchpoint in the customer journey (1 for first touch, incrementing for each subsequent touchpoint). Used for position-based attribution models.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:touchpointTimestamp rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Timestamp' ;
    rdfs:comment 'Precise date and time when the marketing touchpoint occurred (impression served, email opened, ad clicked, SMS delivered). Critical for time-decay attribution models and customer journey sequencing.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:touchpointType rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Type' ;
    rdfs:comment 'The specific type of interaction or exposure at this touchpoint. Distinguishes passive impressions from active engagements for weighted attribution models. [ENUM-REF-CANDIDATE: impression|click|email_open|email_click|sms_click|push_open|push_click|video_view|video_complete|social_engagement|landing_page_view|form_submit — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentSegmentAudienceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Segment Audience Segment Id' ;
    rdfs:comment 'Reference to a parent segment if this segment is a refinement or sub-segment of a broader audience definition. Null for top-level segments.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceSegment .

ind:activationChannels rdf:type rdf:Property ;
    rdfs:label 'Activation Channels' ;
    rdfs:comment 'Comma-separated list of marketing channels where this segment is activated (e.g., email, SMS, social media, display advertising, search, in-store personalization).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationStatus rdf:type rdf:Property ;
    rdfs:label 'Activation Status' ;
    rdfs:comment 'Indicates whether the segment has been activated for use in live marketing campaigns and media buying platforms.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualReach rdf:type rdf:Property ;
    rdfs:label 'Actual Reach' ;
    rdfs:comment 'Actual count of unique customers or contacts currently assigned to this segment after the last refresh execution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessObjective rdf:type rdf:Property ;
    rdfs:label 'Business Objective' ;
    rdfs:comment 'Strategic marketing objective or campaign goal this segment supports (e.g., customer acquisition, retention, cross-sell, win-back, loyalty tier upgrade).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'Statistical confidence or quality score for modeled segments, representing the predicted accuracy of segment membership (0.0000 to 1.0000). Null for non-modeled segments.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Required Flag' ;
    rdfs:comment 'Indicates whether explicit customer consent is required before activating this segment for marketing communications, per privacy regulations.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creationMethod rdf:type rdf:Property ;
    rdfs:label 'Creation Method' ;
    rdfs:comment 'Method used to create the segment: manual selection, rule-based logic, machine learning model, lookalike modeling, imported from external system, or cloned from existing segment.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSources rdf:type rdf:Property ;
    rdfs:label 'Data Sources' ;
    rdfs:comment 'Comma-separated list or description of source systems and data domains used to build this segment (e.g., CRM, loyalty program, web analytics, POS transaction data, email engagement).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definitionLogic rdf:type rdf:Property ;
    rdfs:label 'Definition Logic' ;
    rdfs:comment 'SQL predicate, rule set, or business logic defining the segment membership criteria. May reference customer attributes, transaction history, loyalty tier, web behavior, or other data sources.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedReach rdf:type rdf:Property ;
    rdfs:label 'Estimated Reach' ;
    rdfs:comment 'Estimated number of customers or contacts that qualify for this segment based on the most recent evaluation of the definition logic.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusion Flag' ;
    rdfs:comment 'Indicates whether this is a suppression segment used to exclude customers from campaigns (e.g., unsubscribed, opted-out, recent purchasers to avoid over-messaging).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automationEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Automation Enrollment Id' ;
    rdfs:comment 'Unique identifier for the automation enrollment record. Primary key.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:automationFlowId rdf:type rdf:Property ;
    rdfs:label 'Automation Flow Id' ;
    rdfs:comment 'Identifier of the marketing automation flow that the customer was enrolled into. References the specific automation campaign or journey definition.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AutomationFlow .

ind:currentStepId rdf:type rdf:Property ;
    rdfs:label 'Current Step Id' ;
    rdfs:comment 'Identifier of the current step or stage in the automation flow where the customer is positioned. Null if the customer has exited the flow.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AutomationStep .

ind:primaryAutomationAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Automation Associate Id' ;
    rdfs:comment 'Identifier of the user or system process that created this enrollment record. Used for audit trail and accountability.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:conversionFlag rdf:type rdf:Property ;
    rdfs:label 'Conversion Flag' ;
    rdfs:comment 'Indicates whether the customer achieved the target conversion goal of the automation flow. True if the customer completed the desired action (purchase, sign-up, engagement), false otherwise.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conversionValueAmount rdf:type rdf:Property ;
    rdfs:label 'Conversion Value Amount' ;
    rdfs:comment 'The monetary value attributed to the conversion event. Represents revenue, order value, or estimated customer lifetime value (CLTV) impact from the automation-driven conversion.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentStepEntryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Current Step Entry Timestamp' ;
    rdfs:comment 'The date and time when the customer entered the current step of the automation flow. Used to calculate time-in-step and identify stalled journeys.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currentStepName rdf:type rdf:Property ;
    rdfs:label 'Current Step Name' ;
    rdfs:comment 'Human-readable name of the current step in the automation flow. Provides business context for operational monitoring and reporting.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentCode rdf:type rdf:Property ;
    rdfs:label 'Enrollment Code' ;
    rdfs:comment 'Business-readable unique code for this enrollment instance. Used for operational tracking and customer service reference.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentNotes rdf:type rdf:Property ;
    rdfs:label 'Enrollment Notes' ;
    rdfs:comment 'Free-text notes or comments about this enrollment. Used for operational context, troubleshooting, or manual intervention documentation.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSource rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source' ;
    rdfs:comment 'The system or method that initiated the enrollment. Indicates whether the enrollment was triggered automatically by an event, manually by a user, or via batch processing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the customer within the automation flow. Indicates whether the customer is actively progressing, has completed, or has exited the flow.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrollment Timestamp' ;
    rdfs:comment 'The date and time when the customer was enrolled into the automation flow. Represents the start of the customers journey through the automation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:enrollmentTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Enrollment Trigger Event' ;
    rdfs:comment 'The business event or action that triggered the customers enrollment into the automation flow. Examples include cart abandonment, product purchase, account creation, loyalty tier change, or manual enrollment.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitReason rdf:type rdf:Property ;
    rdfs:label 'Exit Reason' ;
    rdfs:comment 'The reason the customer exited the automation flow. Examples include completed (finished all steps), unsubscribed (opted out), suppressed (consent withdrawn), manually_removed (admin action), goal_achieved (converted), or error (technical failure). Null if still active.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exit Timestamp' ;
    rdfs:comment 'The date and time when the customer exited the automation flow. Null if the customer is still actively enrolled.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastInteractionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Interaction Timestamp' ;
    rdfs:comment 'The date and time of the customers most recent interaction with any message in this automation flow. Includes opens, clicks, or other engagement actions.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nextScheduledActionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Action Timestamp' ;
    rdfs:comment 'The date and time when the next automation action (message send, step transition, or evaluation) is scheduled for this enrollment. Used for operational monitoring and queue management.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stepSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Step Sequence Number' ;
    rdfs:comment 'The ordinal position of the current step within the automation flow. Indicates progression depth through the journey.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suppressionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Suppression Timestamp' ;
    rdfs:comment 'The date and time when the customer was suppressed from the automation flow. Null if not suppressed.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalMessagesClicked rdf:type rdf:Property ;
    rdfs:label 'Total Messages Clicked' ;
    rdfs:comment 'Count of marketing messages where the customer clicked a link or call-to-action during this automation enrollment. Indicates deeper engagement and intent.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalMessagesOpened rdf:type rdf:Property ;
    rdfs:label 'Total Messages Opened' ;
    rdfs:comment 'Count of marketing messages that the customer opened during this automation enrollment. Used to measure engagement and message effectiveness.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalMessagesSent rdf:type rdf:Property ;
    rdfs:label 'Total Messages Sent' ;
    rdfs:comment 'Count of marketing messages (emails, SMS, push notifications) sent to the customer as part of this automation enrollment. Used to measure communication volume and frequency.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStepsCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Steps Completed' ;
    rdfs:comment 'Count of automation flow steps that the customer has successfully completed since enrollment. Used to measure journey progression and engagement.' ;
    rdfs:domain ind:AutomationEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByAssociateId rdf:type rdf:Property ;
    rdfs:label 'Approved By Associate Id' ;
    rdfs:comment 'Identifier of the employee who approved the campaign for execution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:parentCampaignId rdf:type rdf:Property ;
    rdfs:label 'Parent Campaign Id' ;
    rdfs:comment 'Reference to the parent campaign if this campaign is part of a hierarchical campaign structure (e.g., a sub-campaign or wave within a master campaign).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:primaryKpiDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Primary Kpi Definition Id' ;
    rdfs:comment 'Foreign key linking to analytics.kpi_definition. Business justification: Campaigns are measured against specific KPIs (ROAS, conversion rate, CTR) defined in analytics. Marketing teams set primary success metrics at campaign launch; this link enables performance tracking, ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiDefinition .

ind:requiredTrainingProgramId rdf:type rdf:Property ;
    rdfs:label 'Required Training Program Id' ;
    rdfs:comment 'Foreign key linking to compliance.training_program. Business justification: Marketing associates require mandatory compliance training (data privacy, advertising standards, FTC disclosure rules) before executing campaigns. Real business need: ensuring campaign creators are ce' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingProgram .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual date when the campaign execution concluded, may differ from planned end date.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Amount' ;
    rdfs:comment 'Total actual expenditure incurred for the campaign across all channels and activities.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date when the campaign execution began, may differ from planned start date due to operational adjustments.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Total allocated budget for the campaign across all channels and activities.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelMix rdf:type rdf:Property ;
    rdfs:label 'Channel Mix' ;
    rdfs:comment 'Comma-separated list or description of marketing channels used in this campaign (e.g., email, SMS, social media, paid search, display, in-store, direct mail).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeTheme rdf:type rdf:Property ;
    rdfs:label 'Creative Theme' ;
    rdfs:comment 'The overarching creative theme, messaging concept, or visual identity used in campaign assets.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOmnichannel rdf:type rdf:Property ;
    rdfs:label 'Is Omnichannel' ;
    rdfs:comment 'Flag indicating whether the campaign is executed across multiple channels in an integrated omnichannel approach.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'Primary business objective or goal of the campaign (e.g., increase store traffic, drive online sales, build brand awareness, grow loyalty membership).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Scheduled date when the campaign is planned to conclude.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled date when the campaign is planned to begin execution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryChannel rdf:type rdf:Property ;
    rdfs:label 'Primary Channel' ;
    rdfs:comment 'The primary or lead marketing channel for this campaign. [ENUM-REF-CANDIDATE: email|sms|social_media|paid_search|display|in_store|direct_mail|out_of_home — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceDefinition rdf:type rdf:Property ;
    rdfs:label 'Target Audience Definition' ;
    rdfs:comment 'Description of the target audience segment for this campaign, including demographic, behavioral, and geographic criteria.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceSize rdf:type rdf:Property ;
    rdfs:label 'Target Audience Size' ;
    rdfs:comment 'Estimated or actual number of customers or prospects targeted by this campaign.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetConversionGoal rdf:type rdf:Property ;
    rdfs:label 'Target Conversion Goal' ;
    rdfs:comment 'Target number of conversions (e.g., purchases, sign-ups, store visits) expected from this campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetCountryCodes rdf:type rdf:Property ;
    rdfs:label 'Target Country Codes' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where the campaign is executed (e.g., USA, CAN, GBR).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRevenueGoal rdf:type rdf:Property ;
    rdfs:label 'Target Revenue Goal' ;
    rdfs:comment 'Revenue target or goal set for this campaign, used to measure campaign success.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignAudienceId rdf:type rdf:Property ;
    rdfs:label 'Campaign Audience Id' ;
    rdfs:comment 'Unique identifier for the campaign audience association record.' ;
    rdfs:domain ind:CampaignAudience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationEndDate rdf:type rdf:Property ;
    rdfs:label 'Activation End Date' ;
    rdfs:comment 'The date when this audience segment targeting ends or expires within the campaign. Used for time-bound targeting windows or campaign flight schedules.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activationStartDate rdf:type rdf:Property ;
    rdfs:label 'Activation Start Date' ;
    rdfs:comment 'The date when this audience segment targeting becomes active within the campaign. Used for scheduled or phased campaign rollouts.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualReachedCount rdf:type rdf:Property ;
    rdfs:label 'Actual Reached Count' ;
    rdfs:comment 'The actual number of customers or contacts successfully reached after campaign execution. Populated post-execution for performance measurement.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Amount' ;
    rdfs:comment 'The portion of the campaign budget allocated specifically to this audience segment for media spend, creative production, or channel costs.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAllocationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the budget allocation amount.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignAudienceStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Audience Status' ;
    rdfs:comment 'The current lifecycle status of this campaign-audience association. Tracks whether the targeting configuration is in planning, execution, or post-campaign state.' ;
    rdfs:domain ind:CampaignAudience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Consent Verification Date' ;
    rdfs:comment 'The date when opt-in consent was last verified for this audience segment. Used for regulatory compliance and audit trails.' ;
    rdfs:domain ind:CampaignAudience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Conversion Rate Percent' ;
    rdfs:comment 'The percentage of reached customers who converted (conversion_count / actual_reached_count * 100). Primary metric for campaign return on investment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerAcquisition rdf:type rdf:Property ;
    rdfs:label 'Cost Per Acquisition' ;
    rdfs:comment 'The average cost to acquire one conversion from this audience segment (budget_allocation_amount / conversion_count). Key efficiency metric for campaign optimization.' ;
    rdfs:domain ind:CampaignAudience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryRatePercent rdf:type rdf:Property ;
    rdfs:label 'Delivery Rate Percent' ;
    rdfs:comment 'The percentage of the estimated reach that was successfully delivered (actual_reached_count / estimated_reach * 100). Calculated post-execution to measure targeting accuracy and deliverability.' ;
    rdfs:domain ind:CampaignAudience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyCap rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap' ;
    rdfs:comment 'The maximum number of times a customer in this audience segment should be contacted or exposed to campaign messages within the campaign period. Used to prevent over-messaging.' ;
    rdfs:domain ind:CampaignAudience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyCapPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Period Days' ;
    rdfs:comment 'The time period in days over which the frequency cap is enforced. For example, a frequency cap of 3 over 7 days means no more than 3 messages in any 7-day window.' ;
    rdfs:domain ind:CampaignAudience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lookalikeModelCode rdf:type rdf:Property ;
    rdfs:label 'Lookalike Model Code' ;
    rdfs:comment 'Reference to the lookalike modeling algorithm or configuration used when this audience segment serves as a seed for lookalike expansion. Only populated when targeting_role is lookalike_seed.' ;
    rdfs:domain ind:CampaignAudience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lookalikeSimilarityThreshold rdf:type rdf:Property ;
    rdfs:label 'Lookalike Similarity Threshold' ;
    rdfs:comment 'The minimum similarity score (0.0000 to 1.0000) required for a customer to be included in the lookalike expansion audience. Higher thresholds produce smaller, more similar audiences.' ;
    rdfs:domain ind:CampaignAudience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optInConsentVerified rdf:type rdf:Property ;
    rdfs:label 'Opt In Consent Verified' ;
    rdfs:comment 'Flag indicating whether opt-in consent has been verified for all customers in this audience segment for the specified channel. Required for GDPR, CCPA, and CAN-SPAM compliance.' ;
    rdfs:domain ind:CampaignAudience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personalizationStrategy rdf:type rdf:Property ;
    rdfs:label 'Personalization Strategy' ;
    rdfs:comment 'The personalization or dynamic content strategy applied to this audience segment within the campaign (e.g., product recommendations, location-based offers, behavioral triggers, demographic customization).' ;
    rdfs:domain ind:CampaignAudience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseCount rdf:type rdf:Property ;
    rdfs:label 'Response Count' ;
    rdfs:comment 'The number of customers in this audience segment who responded to the campaign (clicked, opened, converted, or took the desired action). Populated post-execution for performance measurement.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseRatePercent rdf:type rdf:Property ;
    rdfs:label 'Response Rate Percent' ;
    rdfs:comment 'The percentage of reached customers who responded to the campaign (response_count / actual_reached_count * 100). Key performance indicator for campaign effectiveness.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnOnAdSpend rdf:type rdf:Property ;
    rdfs:label 'Return On Ad Spend' ;
    rdfs:comment 'The ratio of attributed revenue to budget allocation for this audience segment (revenue_attributed_amount / budget_allocation_amount). Measures campaign profitability per segment.' ;
    rdfs:domain ind:CampaignAudience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueAttributedAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Attributed Amount' ;
    rdfs:comment 'The total revenue attributed to this audience segment from the campaign based on the attribution model. Used for ROI calculation and segment performance comparison.' ;
    rdfs:domain ind:CampaignAudience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueAttributedCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Attributed Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the attributed revenue amount.' ;
    rdfs:domain ind:CampaignAudience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentRefreshDate rdf:type rdf:Property ;
    rdfs:label 'Segment Refresh Date' ;
    rdfs:comment 'The date when the audience segment membership was last refreshed or recalculated prior to campaign activation. Important for understanding data recency.' ;
    rdfs:domain ind:CampaignAudience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetingRole rdf:type rdf:Property ;
    rdfs:label 'Targeting Role' ;
    rdfs:comment 'The role this audience segment plays in the campaign targeting strategy (include for primary targeting, exclude/suppress for opt-outs or suppression lists, lookalike_seed for expansion modeling, control_group for A/B testing, holdout for measurement).' ;
    rdfs:domain ind:CampaignAudience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testGroupIndicator rdf:type rdf:Property ;
    rdfs:label 'Test Group Indicator' ;
    rdfs:comment 'Flag indicating whether this audience segment is part of an A/B test or experimental group within the campaign. True if this is a test variant, false if control or standard execution.' ;
    rdfs:domain ind:CampaignAudience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testVariantName rdf:type rdf:Property ;
    rdfs:label 'Test Variant Name' ;
    rdfs:comment 'The name or identifier of the test variant applied to this audience segment (e.g., Variant A, Creative B, Offer 20% Off). Only populated when test_group_indicator is true.' ;
    rdfs:domain ind:CampaignAudience ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignBriefId rdf:type rdf:Property ;
    rdfs:label 'Campaign Brief Id' ;
    rdfs:comment 'Unique identifier for the campaign brief. Primary key.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Name of the executive or stakeholder who provided final approval sign-off on the brief.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverTitle rdf:type rdf:Property ;
    rdfs:label 'Approver Title' ;
    rdfs:comment 'Job title or role of the approver who signed off on the campaign brief.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedAgencyName rdf:type rdf:Property ;
    rdfs:label 'Assigned Agency Name' ;
    rdfs:comment 'Name of the external creative or media agency assigned to execute this campaign brief.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Brief Approved Date' ;
    rdfs:comment 'Date when the campaign brief received final approval and sign-off.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:briefSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Brief Submitted Date' ;
    rdfs:comment 'Date when the campaign brief was formally submitted for review and approval.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:briefType rdf:type rdf:Property ;
    rdfs:label 'Brief Type' ;
    rdfs:comment 'Classification of the brief by campaign execution scope and channel mix. [ENUM-REF-CANDIDATE: integrated|digital_only|print_only|social_media|email|in_store|omnichannel — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callToAction rdf:type rdf:Property ;
    rdfs:label 'Call To Action' ;
    rdfs:comment 'Primary call-to-action that the campaign should drive (e.g., Shop Now, Sign Up, Learn More, Visit Store).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignEndDate rdf:type rdf:Property ;
    rdfs:label 'Campaign End Date' ;
    rdfs:comment 'Planned end date for campaign execution as specified in the brief.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:campaignStartDate rdf:type rdf:Property ;
    rdfs:label 'Campaign Start Date' ;
    rdfs:comment 'Planned start date for campaign execution as specified in the brief.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:channelMixStrategy rdf:type rdf:Property ;
    rdfs:label 'Channel Mix Strategy' ;
    rdfs:comment 'Strategic allocation and prioritization of marketing channels (email, social, paid search, display, in-store, etc.) for campaign execution.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveContext rdf:type rdf:Property ;
    rdfs:label 'Competitive Context' ;
    rdfs:comment 'Analysis of competitive landscape, competitor campaigns, and market positioning considerations relevant to this brief.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeAssetsRequired rdf:type rdf:Property ;
    rdfs:label 'Creative Assets Required' ;
    rdfs:comment 'List of creative deliverables required (e.g., video, display ads, email templates, social posts, in-store signage).' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeLeadName rdf:type rdf:Property ;
    rdfs:label 'Creative Lead Name' ;
    rdfs:comment 'Name of the creative lead or art director responsible for creative development.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalTeamAssignment rdf:type rdf:Property ;
    rdfs:label 'Internal Team Assignment' ;
    rdfs:comment 'Internal marketing team or department responsible for managing and executing this brief.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Legal Compliance Notes' ;
    rdfs:comment 'Legal and regulatory compliance considerations, disclaimers, and requirements that must be adhered to in campaign execution.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryBrandElements rdf:type rdf:Property ;
    rdfs:label 'Mandatory Brand Elements' ;
    rdfs:comment 'List of required brand assets, logos, taglines, legal disclaimers, and visual elements that must appear in all campaign materials.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategoryFocus rdf:type rdf:Property ;
    rdfs:label 'Product Category Focus' ;
    rdfs:comment 'Primary product categories or merchandise assortments featured in the campaign.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNotes rdf:type rdf:Property ;
    rdfs:label 'Revision Notes' ;
    rdfs:comment 'Notes documenting changes, feedback, and revisions made to the brief during the review process.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Version number tracking the number of revisions made to the campaign brief.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:successKpiDefinition rdf:type rdf:Property ;
    rdfs:label 'Success Kpi Definition' ;
    rdfs:comment 'Definition of key performance indicators and success metrics that will be used to measure campaign effectiveness.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetConversionRatePct rdf:type rdf:Property ;
    rdfs:label 'Target Conversion Rate Pct' ;
    rdfs:comment 'Target conversion rate percentage that the campaign aims to achieve.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetReach rdf:type rdf:Property ;
    rdfs:label 'Target Reach' ;
    rdfs:comment 'Target number of unique customers or impressions the campaign aims to achieve.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetRoiPct rdf:type rdf:Property ;
    rdfs:label 'Target Roi Pct' ;
    rdfs:comment 'Target return on investment percentage expected from the campaign spend.' ;
    rdfs:domain ind:CampaignBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toneOfVoice rdf:type rdf:Property ;
    rdfs:label 'Tone Of Voice' ;
    rdfs:comment 'Prescribed tone and style for campaign communications (e.g., friendly, authoritative, playful, urgent).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Campaign Performance Id' ;
    rdfs:comment 'Unique identifier for the campaign performance record. Primary key for this operational performance snapshot.' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpaAmount rdf:type rdf:Property ;
    rdfs:label 'Cpa Amount' ;
    rdfs:comment 'Cost per acquisition or conversion (CPA) for this campaign and channel during the reporting period, in the spend currency.' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpcAmount rdf:type rdf:Property ;
    rdfs:label 'Cpc Amount' ;
    rdfs:comment 'Cost per click (CPC) for this campaign and channel during the reporting period, in the spend currency.' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpmAmount rdf:type rdf:Property ;
    rdfs:label 'Cpm Amount' ;
    rdfs:comment 'Cost per thousand impressions (CPM) for this campaign and channel during the reporting period, in the spend currency.' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctrPercent rdf:type rdf:Property ;
    rdfs:label 'Ctr Percent' ;
    rdfs:comment 'Click-through rate expressed as a percentage, calculated as (clicks / impressions) * 100 for the reporting period.' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emailDeliveredCount rdf:type rdf:Property ;
    rdfs:label 'Email Delivered Count' ;
    rdfs:comment 'Total number of emails successfully delivered (not bounced) for this campaign during the reporting period. Applicable only when channel_type is email.' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emailOpenCount rdf:type rdf:Property ;
    rdfs:label 'Email Open Count' ;
    rdfs:comment 'Total number of email opens recorded for this campaign during the reporting period. Applicable only when channel_type is email.' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emailOpenRatePercent rdf:type rdf:Property ;
    rdfs:label 'Email Open Rate Percent' ;
    rdfs:comment 'Email open rate expressed as a percentage, calculated as (opens / delivered) * 100 for the reporting period. Applicable only when channel_type is email.' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emailSendCount rdf:type rdf:Property ;
    rdfs:label 'Email Send Count' ;
    rdfs:comment 'Total number of emails sent for this campaign during the reporting period. Applicable only when channel_type is email.' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emailUnsubscribeCount rdf:type rdf:Property ;
    rdfs:label 'Email Unsubscribe Count' ;
    rdfs:comment 'Total number of unsubscribes triggered by this campaign during the reporting period. Applicable only when channel_type is email.' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emailUnsubscribeRatePercent rdf:type rdf:Property ;
    rdfs:label 'Email Unsubscribe Rate Percent' ;
    rdfs:comment 'Email unsubscribe rate expressed as a percentage, calculated as (unsubscribes / delivered) * 100 for the reporting period. Applicable only when channel_type is email.' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementCount rdf:type rdf:Property ;
    rdfs:label 'Engagement Count' ;
    rdfs:comment 'Total number of engagements (likes, shares, comments, reactions) recorded for this campaign and channel during the reporting period. Primarily applicable to social media channels.' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementRatePercent rdf:type rdf:Property ;
    rdfs:label 'Engagement Rate Percent' ;
    rdfs:comment 'Engagement rate expressed as a percentage, calculated as (engagements / impressions) * 100 for the reporting period. Primarily applicable to social media channels.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressionsDelivered rdf:type rdf:Property ;
    rdfs:label 'Impressions Delivered' ;
    rdfs:comment 'Total number of impressions delivered during the reporting period for this campaign and channel combination.' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The timestamp when this performance data was measured and recorded. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reachCount rdf:type rdf:Property ;
    rdfs:label 'Reach Count' ;
    rdfs:comment 'Total unique individuals or accounts reached during the reporting period for this campaign and channel.' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'The end date of the reporting period for which this performance data was captured. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'The start date of the reporting period for which this performance data was captured. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodType rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Type' ;
    rdfs:comment 'The granularity of the reporting period for this performance snapshot (daily, weekly, monthly, quarterly).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the attributed revenue amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roasRatio rdf:type rdf:Property ;
    rdfs:label 'Roas Ratio' ;
    rdfs:comment 'Return on Ad Spend ratio, calculated as attributed revenue divided by spend for this campaign and channel during the reporting period. A value of 3.50 means $3.50 revenue per $1.00 spent.' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendAmount rdf:type rdf:Property ;
    rdfs:label 'Spend Amount' ;
    rdfs:comment 'Total media spend or campaign cost for this campaign and channel during the reporting period.' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Spend Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the spend amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoCompletionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Video Completion Rate Percent' ;
    rdfs:comment 'Percentage of video views that were completed (watched to the end) during the reporting period. Applicable only when channel_type is video.' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoViewCount rdf:type rdf:Property ;
    rdfs:label 'Video View Count' ;
    rdfs:comment 'Total number of video views recorded for this campaign during the reporting period. Applicable only when channel_type is video.' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionEventId rdf:type rdf:Property ;
    rdfs:label 'Conversion Event Id' ;
    rdfs:comment 'Unique identifier for the conversion event record. Primary key.' ;
    rdfs:domain ind:ConversionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributedChannel rdf:type rdf:Property ;
    rdfs:label 'Attributed Channel' ;
    rdfs:comment 'Marketing channel attributed to driving this conversion event based on the attribution model applied. [ENUM-REF-CANDIDATE: email|social_media|paid_search|organic_search|display|affiliate|direct — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConversionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributedTouchpoint rdf:type rdf:Property ;
    rdfs:label 'Attributed Touchpoint' ;
    rdfs:comment 'Specific marketing touchpoint or interaction attributed to driving this conversion. May include campaign creative, ad placement, or email message identifier.' ;
    rdfs:domain ind:ConversionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionEventCode rdf:type rdf:Property ;
    rdfs:label 'Conversion Event Code' ;
    rdfs:comment 'Business-readable unique code identifying this conversion event for reporting and tracking purposes.' ;
    rdfs:domain ind:ConversionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionNotes rdf:type rdf:Property ;
    rdfs:label 'Conversion Notes' ;
    rdfs:comment 'Free-text notes or comments about this conversion event. Captures additional context or special circumstances.' ;
    rdfs:domain ind:ConversionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionPageUrl rdf:type rdf:Property ;
    rdfs:label 'Conversion Page Url' ;
    rdfs:comment 'URL of the page where the conversion event was completed. Identifies the exact location of the conversion action.' ;
    rdfs:domain ind:ConversionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionPathLength rdf:type rdf:Property ;
    rdfs:label 'Conversion Path Length' ;
    rdfs:comment 'Number of marketing touchpoints the customer interacted with before completing this conversion event. Measures the complexity of the customer journey.' ;
    rdfs:domain ind:ConversionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionType rdf:type rdf:Property ;
    rdfs:label 'Conversion Type' ;
    rdfs:comment 'Type of conversion event that occurred. Categorizes the nature of the customer action that constitutes a conversion.' ;
    rdfs:domain ind:ConversionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isNewCustomer rdf:type rdf:Property ;
    rdfs:label 'Is New Customer' ;
    rdfs:comment 'Boolean flag indicating whether this conversion represents a new customer acquisition. True if this is the customers first conversion event.' ;
    rdfs:domain ind:ConversionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:featuredSkuId rdf:type rdf:Property ;
    rdfs:label 'Featured Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Creative assets (product images, videos, copy) are produced for specific SKUs in retail marketing. Critical for digital asset management, content attribution, and ensuring correct product representati' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:featuredSkuPriceId rdf:type rdf:Property ;
    rdfs:label 'Featured Sku Price Id' ;
    rdfs:comment 'Foreign key linking to pricing.sku_price. Business justification: Retail creative assets (circulars, display ads, social posts) display product prices. Legal compliance and brand standards require price accuracy validation. Real business process: creative asset appr' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuPrice .

ind:parentAssetCreativeAssetId rdf:type rdf:Property ;
    rdfs:label 'Parent Asset Creative Asset Id' ;
    rdfs:comment 'Identifier of the parent or master creative asset from which this asset was derived or adapted. Null if this is an original asset.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreativeAsset .

ind:primaryCreativeOwnerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Creative Owner Associate Id' ;
    rdfs:comment 'Identifier of the individual user who owns or is accountable for the creative asset within the organization.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:assetCode rdf:type rdf:Property ;
    rdfs:label 'Asset Code' ;
    rdfs:comment 'Unique business identifier or SKU-like code assigned to the creative asset for cataloging and reference across marketing systems.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetName rdf:type rdf:Property ;
    rdfs:label 'Asset Name' ;
    rdfs:comment 'Human-readable name or title of the creative asset, used for identification and search within the Digital Asset Management (DAM) system.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Classification of the creative asset by its primary format and intended use case. [ENUM-REF-CANDIDATE: digital_banner|email_template|sms_copy|social_media_post|video_ad|print_artwork|in_store_signage|landing_page|display_ad|native_ad|audio_ad|podcast_ad|influencer_content|gif_animation|interactive_content — promote to reference product]' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelSuitability rdf:type rdf:Property ;
    rdfs:label 'Channel Suitability' ;
    rdfs:comment 'Comma-separated list of marketing channels for which this creative asset is suitable or optimized (e.g., email, social, display, in-store, mobile).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeAgencyName rdf:type rdf:Property ;
    rdfs:label 'Creative Agency Name' ;
    rdfs:comment 'Name of the external creative agency or vendor that produced the creative asset.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeAssetDescription rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Description' ;
    rdfs:comment 'Detailed textual description of the creative asset content, purpose, and intended use case.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensions rdf:type rdf:Property ;
    rdfs:label 'Dimensions' ;
    rdfs:comment 'Physical or pixel dimensions of the creative asset (e.g., 1920x1080 for video, 8.5x11 inches for print, 300x250 pixels for banner).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'File Reference Url' ;
    rdfs:comment 'Uniform Resource Locator (URL) or Digital Asset Management (DAM) system path pointing to the stored creative asset file.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeKb rdf:type rdf:Property ;
    rdfs:label 'File Size Kb' ;
    rdfs:comment 'Size of the creative asset file in kilobytes, used for storage management and delivery optimization.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'Technical file format or MIME type of the creative asset (e.g., JPG, PNG, MP4, HTML, PDF).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Compliant' ;
    rdfs:comment 'Boolean flag indicating whether the creative asset has passed all regulatory and brand compliance checks (True) or has outstanding compliance issues (False).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMasterVersion rdf:type rdf:Property ;
    rdfs:label 'Is Master Version' ;
    rdfs:comment 'Boolean flag indicating whether this is the master or canonical version of the creative asset (True) or a derivative/variant (False).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of keywords or tags for search and discovery of the creative asset within the DAM system.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the primary language of the creative asset content.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'License Expiry Date' ;
    rdfs:comment 'Date when the usage license for the creative asset expires, after which continued use may require renewal or renegotiation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licensingTerms rdf:type rdf:Property ;
    rdfs:label 'Licensing Terms' ;
    rdfs:comment 'Detailed text description of licensing terms, restrictions, and usage conditions for the creative asset, including geographic and temporal constraints.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetUrl rdf:type rdf:Property ;
    rdfs:label 'Target Url' ;
    rdfs:comment 'Destination URL that users are directed to when they interact with the creative asset (click-through link).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRights rdf:type rdf:Property ;
    rdfs:label 'Usage Rights' ;
    rdfs:comment 'Type of intellectual property rights governing the use of the creative asset (owned, licensed, royalty-free, rights-managed, creative commons).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmParameters rdf:type rdf:Property ;
    rdfs:label 'Utm Parameters' ;
    rdfs:comment 'Urchin Tracking Module (UTM) parameters appended to the target URL for campaign tracking and attribution (utm_source, utm_medium, utm_campaign, utm_content, utm_term).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailTemplateId rdf:type rdf:Property ;
    rdfs:label 'Email Template Id' ;
    rdfs:comment 'Identifier for the email creative template or asset used in this send. Links to the design and content structure in the marketing automation platform.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmailTemplate .

ind:actualSendTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Send Timestamp' ;
    rdfs:comment 'The actual date and time when the email send job was executed by the Email Service Provider (ESP). Represents the real-world business event time for send execution.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveredCount rdf:type rdf:Property ;
    rdfs:label 'Delivered Count' ;
    rdfs:comment 'The number of emails successfully delivered to recipient inboxes without bouncing. Key metric for deliverability performance.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:espJobCode rdf:type rdf:Property ;
    rdfs:label 'Esp Job Code' ;
    rdfs:comment 'The unique job or batch identifier assigned by the Email Service Provider (e.g., Salesforce Marketing Cloud, Braze, Klaviyo). Used for reconciliation and troubleshooting.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:espPlatformName rdf:type rdf:Property ;
    rdfs:label 'Esp Platform Name' ;
    rdfs:comment 'The name of the Email Service Provider platform used to execute this send (e.g., Salesforce Marketing Cloud, Braze, Klaviyo, Mailchimp). Enables multi-platform send analysis.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fromEmailAddress rdf:type rdf:Property ;
    rdfs:label 'From Email Address' ;
    rdfs:comment 'The sender email address used for this send. Must be authenticated and verified with the ESP for deliverability.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fromName rdf:type rdf:Property ;
    rdfs:label 'From Name' ;
    rdfs:comment 'The sender name displayed in the recipient inbox. Represents the brand or person sending the email.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardBounceCount rdf:type rdf:Property ;
    rdfs:label 'Hard Bounce Count' ;
    rdfs:comment 'The number of emails that permanently failed delivery due to invalid or non-existent email addresses. Indicates data quality issues.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isTestSend rdf:type rdf:Property ;
    rdfs:label 'Is Test Send' ;
    rdfs:comment 'Boolean flag indicating whether this send was a test or quality assurance execution rather than a production send to customers.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openCount rdf:type rdf:Property ;
    rdfs:label 'Open Count' ;
    rdfs:comment 'The total number of times emails from this send were opened by recipients. Includes multiple opens by the same recipient.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preheaderText rdf:type rdf:Property ;
    rdfs:label 'Preheader Text' ;
    rdfs:comment 'The preview text displayed after the subject line in most email clients. Used to provide additional context and improve open rates.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replyToEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Reply To Email Address' ;
    rdfs:comment 'The email address where recipient replies will be directed. May differ from the from_email_address for operational routing.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledSendTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Send Timestamp' ;
    rdfs:comment 'The planned date and time when the email send was scheduled to execute. Used for campaign timing analysis and scheduling optimization.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sendName rdf:type rdf:Property ;
    rdfs:label 'Send Name' ;
    rdfs:comment 'Business-friendly name assigned to this email send event for identification and reporting purposes.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendPriority rdf:type rdf:Property ;
    rdfs:label 'Send Priority' ;
    rdfs:comment 'The priority level assigned to this email send for queue processing and resource allocation. High priority sends are processed first.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendStatus rdf:type rdf:Property ;
    rdfs:label 'Send Status' ;
    rdfs:comment 'Current lifecycle status of the email send job. Tracks the execution state from scheduling through completion or failure.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendType rdf:type rdf:Property ;
    rdfs:label 'Send Type' ;
    rdfs:comment 'Classification of the email send execution method. Batch sends are scheduled bulk sends, triggered sends are event-driven, transactional sends are operational confirmations, automated sends are part of nurture flows, and test sends are quality assurance executions.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentCount rdf:type rdf:Property ;
    rdfs:label 'Sent Count' ;
    rdfs:comment 'The total number of email messages successfully handed off to the Email Service Provider for delivery. Represents the actual send volume.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:softBounceCount rdf:type rdf:Property ;
    rdfs:label 'Soft Bounce Count' ;
    rdfs:comment 'The number of emails that temporarily failed delivery due to issues like full mailboxes or server problems. May succeed on retry.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spamComplaintCount rdf:type rdf:Property ;
    rdfs:label 'Spam Complaint Count' ;
    rdfs:comment 'The number of recipients who marked the email as spam or junk. High complaint rates damage sender reputation and deliverability.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectLine rdf:type rdf:Property ;
    rdfs:label 'Subject Line' ;
    rdfs:comment 'The subject line text displayed in the recipient inbox. Critical for open rate optimization and A/B testing analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionListApplied rdf:type rdf:Property ;
    rdfs:label 'Suppression List Applied' ;
    rdfs:comment 'Boolean flag indicating whether suppression lists (unsubscribed, bounced, or blocked addresses) were applied to filter the target audience before sending.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetRecipientCount rdf:type rdf:Property ;
    rdfs:label 'Target Recipient Count' ;
    rdfs:comment 'The total number of recipients in the target audience segment at the time of send scheduling. Represents the intended send volume.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uniqueClickCount rdf:type rdf:Property ;
    rdfs:label 'Unique Click Count' ;
    rdfs:comment 'The number of unique recipients who clicked at least one link in the email. Used to calculate click-through rate (CTR).' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uniqueOpenCount rdf:type rdf:Property ;
    rdfs:label 'Unique Open Count' ;
    rdfs:comment 'The number of unique recipients who opened the email at least once. Used to calculate open rate.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unsubscribeCount rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Count' ;
    rdfs:comment 'The number of recipients who opted out of future email communications via the unsubscribe link. Critical for list health and compliance.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:influencerId rdf:type rdf:Property ;
    rdfs:label 'Influencer Id' ;
    rdfs:comment 'Unique identifier for the influencer or content creator partner. Primary key for the influencer master record.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Influencer .

ind:influencerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Influencer Associate Id' ;
    rdfs:comment 'The unique identifier of the user or system that created the influencer record.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:influencerModifiedByAssociateId rdf:type rdf:Property ;
    rdfs:label 'Influencer Modified By Associate Id' ;
    rdfs:comment 'The unique identifier of the user or system that last modified the influencer record.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:audienceAgeRange rdf:type rdf:Property ;
    rdfs:label 'Audience Age Range' ;
    rdfs:comment 'The predominant age range of the influencer\'s audience based on platform demographics.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceGenderSplit rdf:type rdf:Property ;
    rdfs:label 'Audience Gender Split' ;
    rdfs:comment 'The gender distribution of the influencer\'s audience, typically expressed as percentages (e.g., 60% Female, 40% Male).' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceGeography rdf:type rdf:Property ;
    rdfs:label 'Audience Geography' ;
    rdfs:comment 'The primary geographic regions or countries where the influencer\'s audience is located, expressed as comma-separated ISO 3-letter country codes or region names.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentNiche rdf:type rdf:Property ;
    rdfs:label 'Content Niche' ;
    rdfs:comment 'The primary content category or niche that the influencer specializes in. [ENUM-REF-CANDIDATE: Fashion|Beauty|Lifestyle|Fitness|Food|Travel|Tech|Gaming|Home|Parenting|Finance|Education — promote to reference product]' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'The current status of the contractual relationship between the influencer and the retail organization.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityTerms rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Terms' ;
    rdfs:comment 'Description of any exclusivity clauses in the influencer contract, such as category exclusivity, competitor restrictions, or time-based exclusivity periods.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facebookFollowerCount rdf:type rdf:Property ;
    rdfs:label 'Facebook Follower Count' ;
    rdfs:comment 'The total number of followers or page likes the influencer has on Facebook as of the last update.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facebookHandle rdf:type rdf:Property ;
    rdfs:label 'Facebook Handle' ;
    rdfs:comment 'The influencer\'s username or page name on Facebook.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftcDisclosureCompliant rdf:type rdf:Property ;
    rdfs:label 'Ftc Disclosure Compliant' ;
    rdfs:comment 'Indicates whether the influencer consistently follows FTC disclosure requirements for sponsored content and paid partnerships.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instagramFollowerCount rdf:type rdf:Property ;
    rdfs:label 'Instagram Follower Count' ;
    rdfs:comment 'The total number of followers the influencer has on Instagram as of the last update.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:instagramHandle rdf:type rdf:Property ;
    rdfs:label 'Instagram Handle' ;
    rdfs:comment 'The influencer\'s username or handle on Instagram.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCampaignDate rdf:type rdf:Property ;
    rdfs:label 'Last Campaign Date' ;
    rdfs:comment 'The date of the most recent campaign the influencer participated in for the retail organization.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'An internal performance rating for the influencer based on past campaign results, engagement quality, and professionalism, typically on a scale of 1.00 to 5.00.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContentFormat rdf:type rdf:Property ;
    rdfs:label 'Preferred Content Format' ;
    rdfs:comment 'The primary content format the influencer specializes in or prefers to create for sponsored campaigns.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPlatform rdf:type rdf:Property ;
    rdfs:label 'Primary Platform' ;
    rdfs:comment 'The primary social media platform where the influencer has the largest following or engagement. [ENUM-REF-CANDIDATE: Instagram|TikTok|YouTube|Facebook|Twitter|LinkedIn|Pinterest|Snapchat|Twitch|Reddit — promote to reference product]' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the influencer\'s rate (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePerPostAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Per Post Amount' ;
    rdfs:comment 'The standard fee or rate charged by the influencer for a single sponsored post or content piece.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stageName rdf:type rdf:Property ;
    rdfs:label 'Stage Name' ;
    rdfs:comment 'The public-facing stage name, alias, or brand name used by the influencer across platforms.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierClassification rdf:type rdf:Property ;
    rdfs:label 'Tier Classification' ;
    rdfs:comment 'The tier classification of the influencer based on follower count: Nano (1K-10K), Micro (10K-100K), Macro (100K-1M), Mega (1M+), Celebrity (established public figure).' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tiktokFollowerCount rdf:type rdf:Property ;
    rdfs:label 'Tiktok Follower Count' ;
    rdfs:comment 'The total number of followers the influencer has on TikTok as of the last update.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tiktokHandle rdf:type rdf:Property ;
    rdfs:label 'Tiktok Handle' ;
    rdfs:comment 'The influencer\'s username or handle on TikTok.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCampaignsCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Campaigns Completed' ;
    rdfs:comment 'The total number of marketing campaigns the influencer has completed with the retail organization to date.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:twitterFollowerCount rdf:type rdf:Property ;
    rdfs:label 'Twitter Follower Count' ;
    rdfs:comment 'The total number of followers the influencer has on Twitter (X) as of the last update.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:twitterHandle rdf:type rdf:Property ;
    rdfs:label 'Twitter Handle' ;
    rdfs:comment 'The influencer\'s username or handle on Twitter (X).' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:youtubeChannelName rdf:type rdf:Property ;
    rdfs:label 'Youtube Channel Name' ;
    rdfs:comment 'The influencer\'s YouTube channel name or handle.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:youtubeSubscriberCount rdf:type rdf:Property ;
    rdfs:label 'Youtube Subscriber Count' ;
    rdfs:comment 'The total number of subscribers the influencer has on YouTube as of the last update.' ;
    rdfs:domain ind:Influencer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:influencerEngagementId rdf:type rdf:Property ;
    rdfs:label 'Influencer Engagement Id' ;
    rdfs:comment 'Unique identifier for the influencer engagement record. Primary key.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disclosurePolicyId rdf:type rdf:Property ;
    rdfs:label 'Disclosure Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: Influencer content requires FTC disclosure compliance (16 CFR Part 255 - Endorsement Guides). Real business need: ftc_disclosure_compliant_flag validation, legal review workflow. Retail influencer mar' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:actualClicksCount rdf:type rdf:Property ;
    rdfs:label 'Actual Clicks Count' ;
    rdfs:comment 'Number of clicks on links or call-to-action elements within the influencer\'s content.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCommentsCount rdf:type rdf:Property ;
    rdfs:label 'Actual Comments Count' ;
    rdfs:comment 'Number of comments received on the published content.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualEngagementCount rdf:type rdf:Property ;
    rdfs:label 'Actual Engagement Count' ;
    rdfs:comment 'Total number of user interactions with the content (likes, comments, shares, saves, clicks).' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualImpressionsCount rdf:type rdf:Property ;
    rdfs:label 'Actual Impressions Count' ;
    rdfs:comment 'Total number of times the influencer\'s content was displayed, including multiple views by the same user.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualLikesCount rdf:type rdf:Property ;
    rdfs:label 'Actual Likes Count' ;
    rdfs:comment 'Number of likes or reactions received on the published content.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualReachCount rdf:type rdf:Property ;
    rdfs:label 'Actual Reach Count' ;
    rdfs:comment 'Actual number of unique users who saw the influencer\'s content, as reported by the platform analytics.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualSharesCount rdf:type rdf:Property ;
    rdfs:label 'Actual Shares Count' ;
    rdfs:comment 'Number of times the content was shared or reposted by users.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualVideoViewsCount rdf:type rdf:Property ;
    rdfs:label 'Actual Video Views Count' ;
    rdfs:comment 'Number of video views if the content is video format, as reported by the platform.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percent' ;
    rdfs:comment 'Commission percentage rate applied to sales generated through this influencer engagement, if applicable.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationType rdf:type rdf:Property ;
    rdfs:label 'Compensation Type' ;
    rdfs:comment 'Type of compensation structure for this engagement (flat fee, commission-based, product gifting, or hybrid model).' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Content Approval Date' ;
    rdfs:comment 'Date when the submitted content was approved by the brand or marketing team.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contentPublishDate rdf:type rdf:Property ;
    rdfs:label 'Content Publish Date' ;
    rdfs:comment 'Date when the approved content was published or went live on the influencer\'s platform.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contentSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Content Submission Date' ;
    rdfs:comment 'Date when the influencer submitted content for review and approval.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractedDeliverables rdf:type rdf:Property ;
    rdfs:label 'Contracted Deliverables' ;
    rdfs:comment 'Description of the deliverables agreed upon in the influencer contract (e.g., number of posts, stories, videos, event attendance).' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureText rdf:type rdf:Property ;
    rdfs:label 'Disclosure Text' ;
    rdfs:comment 'The actual disclosure text or hashtag used by the influencer to indicate sponsored content (e.g., #ad, #sponsored, #partner).' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementCode rdf:type rdf:Property ;
    rdfs:label 'Engagement Code' ;
    rdfs:comment 'Business identifier or reference code for this influencer engagement, used for tracking and reporting purposes.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementNotes rdf:type rdf:Property ;
    rdfs:label 'Engagement Notes' ;
    rdfs:comment 'Additional notes, comments, or special instructions related to this influencer engagement.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementStatus rdf:type rdf:Property ;
    rdfs:label 'Engagement Status' ;
    rdfs:comment 'Current lifecycle status of the influencer engagement (draft, contracted, content submitted, approved, published, completed, cancelled). [ENUM-REF-CANDIDATE: draft|contracted|content_submitted|approved|published|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementType rdf:type rdf:Property ;
    rdfs:label 'Engagement Type' ;
    rdfs:comment 'Type of influencer engagement or activation (e.g., sponsored post, product seeding, affiliate partnership, brand ambassador program, event appearance, unboxing video, product review). [ENUM-REF-CANDIDATE: sponsored_post|product_seeding|affiliate|brand_ambassador|event_appearance|unboxing_video|product_review — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flatFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Flat Fee Amount' ;
    rdfs:comment 'Fixed monetary compensation amount agreed for this engagement, if applicable.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ftcDisclosureCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ftc Disclosure Compliant Flag' ;
    rdfs:comment 'Indicates whether the influencer content includes proper FTC-required disclosure of the sponsored relationship (true/false).' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:giftingValueAmount rdf:type rdf:Property ;
    rdfs:label 'Gifting Value Amount' ;
    rdfs:comment 'Monetary value of products or services gifted to the influencer as part of this engagement.' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformName rdf:type rdf:Property ;
    rdfs:label 'Platform Name' ;
    rdfs:comment 'Social media or content platform where the influencer published the content (Instagram, TikTok, YouTube, Facebook, Twitter, Pinterest, blog). [ENUM-REF-CANDIDATE: instagram|tiktok|youtube|facebook|twitter|pinterest|blog — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedContentUrl rdf:type rdf:Property ;
    rdfs:label 'Published Content Url' ;
    rdfs:comment 'URL or link to the published content on the influencer\'s platform (social media post, blog, video).' ;
    rdfs:domain ind:InfluencerEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Audience Segment Id' ;
    rdfs:comment 'Reference to the customer segment that is eligible for this automation flow. Defines the population scope for enrollment.' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceSegment .

ind:activeEnrolledCount rdf:type rdf:Property ;
    rdfs:label 'Active Enrolled Count' ;
    rdfs:comment 'Current number of customers actively progressing through the flow (not yet completed or exited). Indicates in-flight journey volume.' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:branchingLogicDescription rdf:type rdf:Property ;
    rdfs:label 'Branching Logic Description' ;
    rdfs:comment 'Description of conditional branching and decision points within the flow (e.g., \'If email opened, send offer; if not opened after 24h, send reminder\'). Captures personalization and dynamic path logic.' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelSequence rdf:type rdf:Property ;
    rdfs:label 'Channel Sequence' ;
    rdfs:comment 'Ordered list of marketing channels used in this flow (e.g., \'email → SMS → push notification\', \'email → email → SMS\'). Describes the multi-touch communication strategy.' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedCount rdf:type rdf:Property ;
    rdfs:label 'Completed Count' ;
    rdfs:comment 'Total number of customers who have completed all steps in the automation flow. Measures journey completion rate.' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entryCriteria rdf:type rdf:Property ;
    rdfs:label 'Entry Criteria' ;
    rdfs:comment 'Detailed business rules and conditions that a customer must meet to enter this automation flow. May include segment membership, purchase history, engagement thresholds, or attribute filters.' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitCriteria rdf:type rdf:Property ;
    rdfs:label 'Exit Criteria' ;
    rdfs:comment 'Conditions under which a customer is removed from the automation flow before completion (e.g., purchase made, unsubscribed, goal achieved, maximum time elapsed).' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowCode rdf:type rdf:Property ;
    rdfs:label 'Flow Code' ;
    rdfs:comment 'Unique business identifier or code for the automation flow, used for external reference and integration with marketing automation platforms.' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowDescription rdf:type rdf:Property ;
    rdfs:label 'Flow Description' ;
    rdfs:comment 'Detailed narrative description of the automation flows purpose, strategy, and expected customer experience. Provides context for stakeholders and future reference.' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowName rdf:type rdf:Property ;
    rdfs:label 'Flow Name' ;
    rdfs:comment 'Human-readable name of the marketing automation flow or journey (e.g., \'Cart Abandonment Recovery\', \'Loyalty Welcome Series\', \'Post-Purchase Thank You\').' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowStatus rdf:type rdf:Property ;
    rdfs:label 'Flow Status' ;
    rdfs:comment 'Current lifecycle status of the automation flow: draft (being configured), active (running and enrolling customers), paused (temporarily stopped), completed (finished execution), or archived (historical record).' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowType rdf:type rdf:Property ;
    rdfs:label 'Flow Type' ;
    rdfs:comment 'Classification of the automation flow based on execution pattern: triggered by customer action, scheduled at specific times, recurring on a cadence, one-time campaign, event-based, or behavioral targeting.' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalAchievedCount rdf:type rdf:Property ;
    rdfs:label 'Goal Achieved Count' ;
    rdfs:comment 'Number of customers who achieved the defined goal while enrolled in this flow. Primary success metric for conversion attribution.' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goalDefinition rdf:type rdf:Property ;
    rdfs:label 'Goal Definition' ;
    rdfs:comment 'The primary business objective or conversion goal for this automation flow (e.g., \'Complete purchase\', \'Activate loyalty account\', \'Re-engage dormant customer\', \'Increase Average Order Value (AOV)\').' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformFlowCode rdf:type rdf:Property ;
    rdfs:label 'Platform Flow Code' ;
    rdfs:comment 'External identifier for this flow in the source marketing automation platform. Used for integration and reconciliation with platform reporting.' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepCount rdf:type rdf:Property ;
    rdfs:label 'Step Count' ;
    rdfs:comment 'Total number of steps or touchpoints configured in this automation flow. Indicates complexity and length of the customer journey.' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suppressionListAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Suppression List Applied Flag' ;
    rdfs:comment 'Indicates whether suppression lists (unsubscribed, opted-out, or blocked customers) are enforced for this flow to ensure compliance with communication preferences.' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testModeFlag rdf:type rdf:Property ;
    rdfs:label 'Test Mode Flag' ;
    rdfs:comment 'Indicates whether this flow is running in test or preview mode (not sending to real customers). Used during configuration and quality assurance.' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalEnrolledCount rdf:type rdf:Property ;
    rdfs:label 'Total Enrolled Count' ;
    rdfs:comment 'Cumulative number of customers who have entered this automation flow since activation. Key metric for reach and scale assessment.' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waitPeriodDescription rdf:type rdf:Property ;
    rdfs:label 'Wait Period Description' ;
    rdfs:comment 'Human-readable description of wait times and delays between steps in the flow (e.g., \'Wait 2 hours, then wait 1 day, then wait 3 days\'). Defines the timing cadence of the journey.' ;
    rdfs:domain ind:AutomationFlow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentBrandMarketingBrandId rdf:type rdf:Property ;
    rdfs:label 'Parent Brand Marketing Brand Id' ;
    rdfs:comment 'Reference to the parent brand if this is a sub-brand or brand extension. Null for standalone brands.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketingBrand .

ind:primaryMarketingAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Marketing Associate Id' ;
    rdfs:comment 'Employee identifier of the brand manager or marketing lead responsible for this brand.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:accentColorHex rdf:type rdf:Property ;
    rdfs:label 'Accent Color Hex' ;
    rdfs:comment 'Hexadecimal color code for the brand\'s accent color used for highlights and call-to-action elements.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualMarketingBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Marketing Budget Amount' ;
    rdfs:comment 'Total annual marketing budget allocated to this brand for campaigns, media, and promotional activities.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandCategory rdf:type rdf:Property ;
    rdfs:label 'Brand Category' ;
    rdfs:comment 'Primary product category or merchandise division this brand operates within (e.g., apparel, electronics, grocery, home goods).' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
    rdfs:comment 'Internal alphanumeric code used to uniquely identify the brand in marketing systems and campaigns.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Status' ;
    rdfs:comment 'Current lifecycle status of the brand in the marketing portfolio.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandTier rdf:type rdf:Property ;
    rdfs:label 'Brand Tier' ;
    rdfs:comment 'Price and quality positioning tier of the brand within the retail portfolio.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandType rdf:type rdf:Property ;
    rdfs:label 'Brand Type' ;
    rdfs:comment 'Classification of the brand ownership and positioning model: national banner (third-party national brand), private label (store-owned brand), sub-brand (variant of parent brand), co-brand (partnership brand), licensed brand (licensed IP), or exclusive brand (retailer-exclusive third-party).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date when the brand was discontinued or sunset from the active portfolio. Null for active brands.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equityScore rdf:type rdf:Property ;
    rdfs:label 'Equity Score' ;
    rdfs:comment 'Quantitative brand equity index score derived from brand health tracking studies, measuring overall brand strength, awareness, and consumer perception. Scale and methodology defined by marketing analytics team.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guidelinesDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Guidelines Document Reference' ;
    rdfs:comment 'URI or document management system reference to the official brand guidelines document containing usage rules, visual standards, and messaging frameworks.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthTrackingStatus rdf:type rdf:Property ;
    rdfs:label 'Health Tracking Status' ;
    rdfs:comment 'Indicates whether this brand is actively monitored through brand health tracking studies measuring awareness, consideration, preference, and loyalty metrics.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSustainableBrand rdf:type rdf:Property ;
    rdfs:label 'Is Sustainable Brand' ;
    rdfs:comment 'Boolean flag indicating whether this brand is positioned and marketed with a sustainability or environmental responsibility focus.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logoAssetReference rdf:type rdf:Property ;
    rdfs:label 'Logo Asset Reference' ;
    rdfs:comment 'Digital asset management system reference or URI pointing to the primary brand logo file in approved formats.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPromoterScore rdf:type rdf:Property ;
    rdfs:label 'Net Promoter Score' ;
    rdfs:comment 'Most recent Net Promoter Score for this brand, measuring customer loyalty and likelihood to recommend. Score ranges from -100 to +100.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:owningMarketingTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Marketing Team' ;
    rdfs:comment 'Name or identifier of the marketing team or business unit responsible for managing this brand\'s strategy, campaigns, and performance.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positioningStatement rdf:type rdf:Property ;
    rdfs:label 'Positioning Statement' ;
    rdfs:comment 'Strategic statement defining the brand\'s unique value proposition, target audience, and competitive differentiation in the market.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryColorHex rdf:type rdf:Property ;
    rdfs:label 'Primary Color Hex' ;
    rdfs:comment 'Hexadecimal color code for the brand\'s primary color used in visual identity and marketing materials.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryColorHex rdf:type rdf:Property ;
    rdfs:label 'Secondary Color Hex' ;
    rdfs:comment 'Hexadecimal color code for the brand\'s secondary color used in visual identity and marketing materials.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaHandles rdf:type rdf:Property ;
    rdfs:label 'Social Media Handles' ;
    rdfs:comment 'JSON or comma-separated list of official social media account handles for this brand across platforms (e.g., @brandname on Twitter, Facebook, Instagram).' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagline rdf:type rdf:Property ;
    rdfs:label 'Tagline' ;
    rdfs:comment 'Official tagline or slogan associated with the brand used in advertising and marketing communications.' ;
    rdfs:domain ind:MarketingBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDemographic rdf:type rdf:Property ;
    rdfs:label 'Target Demographic' ;
    rdfs:comment 'Primary demographic profile of the intended consumer audience for this brand, including age range, income level, lifestyle attributes, and psychographic characteristics.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Primary website URL or landing page dedicated to this brand for consumer engagement and information.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingBudgetId rdf:type rdf:Property ;
    rdfs:label 'Marketing Budget Id' ;
    rdfs:comment 'Unique identifier for the marketing budget record. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketingBudget .

ind:actualSpendToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Spend To Date' ;
    rdfs:comment 'Total actual expenditure against this budget as of the current date, including all invoiced and paid amounts.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agencyFeesBudget rdf:type rdf:Property ;
    rdfs:label 'Agency Fees Budget' ;
    rdfs:comment 'Budget allocation for external agency retainers, project fees, and consulting services.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetName rdf:type rdf:Property ;
    rdfs:label 'Budget Name' ;
    rdfs:comment 'Descriptive name of the marketing budget allocation (e.g., \'Q1 2024 Digital Campaign Budget\', \'Holiday Season Omnichannel Budget\').' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of the budget allocation. Tracks progression from draft through approval to active execution and closure.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedSpend rdf:type rdf:Property ;
    rdfs:label 'Committed Spend' ;
    rdfs:comment 'Total amount of budget committed through media buys, agency contracts, and vendor bookings but not yet invoiced or paid.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentProductionBudget rdf:type rdf:Property ;
    rdfs:label 'Content Production Budget' ;
    rdfs:comment 'Budget allocation for creative content production including photography, videography, copywriting, and design services.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalChannelBudget rdf:type rdf:Property ;
    rdfs:label 'Digital Channel Budget' ;
    rdfs:comment 'Budget allocation specifically for digital marketing channels including e-commerce, social media, search, display, and email.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:displayAdvertisingBudget rdf:type rdf:Property ;
    rdfs:label 'Display Advertising Budget' ;
    rdfs:comment 'Budget allocation for display advertising including banner ads, video ads, and programmatic advertising.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emailMarketingBudget rdf:type rdf:Property ;
    rdfs:label 'Email Marketing Budget' ;
    rdfs:comment 'Budget allocation for email marketing campaigns, automation platforms, and SMS marketing activities.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventsSponsorshipBudget rdf:type rdf:Property ;
    rdfs:label 'Events Sponsorship Budget' ;
    rdfs:comment 'Budget allocation for event marketing, trade shows, sponsorships, and experiential marketing activities.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:influencerMarketingBudget rdf:type rdf:Property ;
    rdfs:label 'Influencer Marketing Budget' ;
    rdfs:comment 'Budget allocation for influencer partnerships, sponsored content, and brand ambassador programs.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Last Revision Date' ;
    rdfs:comment 'Date when this budget allocation was last revised or amended. Tracks budget reforecasting and reallocation activities.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketResearchBudget rdf:type rdf:Property ;
    rdfs:label 'Market Research Budget' ;
    rdfs:comment 'Budget allocation for market research, consumer insights, competitive analysis, and brand tracking studies.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingBudget rdf:type rdf:Property ;
    rdfs:label 'Remaining Budget' ;
    rdfs:comment 'Remaining unallocated budget calculated as total approved budget minus committed spend and actual spend to date.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:searchEngineMarketingBudget rdf:type rdf:Property ;
    rdfs:label 'Search Engine Marketing Budget' ;
    rdfs:comment 'Budget allocation for paid search advertising including Google Ads, Bing Ads, and other search engine marketing platforms.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialMediaBudget rdf:type rdf:Property ;
    rdfs:label 'Social Media Budget' ;
    rdfs:comment 'Budget allocation specifically for social media marketing activities across platforms (Facebook, Instagram, Twitter, LinkedIn, TikTok).' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetRoiPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Roi Percentage' ;
    rdfs:comment 'Target return on investment percentage expected from this marketing budget allocation. Used for performance measurement and attribution analysis.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalApprovedBudget rdf:type rdf:Property ;
    rdfs:label 'Total Approved Budget' ;
    rdfs:comment 'Total approved budget amount for this allocation across all channels and campaigns. Represents the authorized spending limit.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:traditionalChannelBudget rdf:type rdf:Property ;
    rdfs:label 'Traditional Channel Budget' ;
    rdfs:comment 'Budget allocation for traditional marketing channels including TV, radio, print, outdoor, and direct mail.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Percentage' ;
    rdfs:comment 'Percentage of total approved budget that has been spent or committed, calculated as (actual_spend_to_date + committed_spend) / total_approved_budget * 100.' ;
    rdfs:domain ind:MarketingBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apiAuthenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Api Authentication Method' ;
    rdfs:comment 'Authentication method required for API integration: OAuth, API key, basic authentication, SAML (Security Assertion Markup Language), or none.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionWindowDays rdf:type rdf:Property ;
    rdfs:label 'Attribution Window Days' ;
    rdfs:comment 'Number of days after interaction during which conversions are attributed to this channel for attribution analytics.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageCpaAmount rdf:type rdf:Property ;
    rdfs:label 'Average Cpa Amount' ;
    rdfs:comment 'Average cost per acquisition or conversion for this channel, key metric for ROI (Return on Investment) measurement.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageCpcAmount rdf:type rdf:Property ;
    rdfs:label 'Average Cpc Amount' ;
    rdfs:comment 'Average cost per click for this channel, used for performance benchmarking and budget allocation.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageCpmAmount rdf:type rdf:Property ;
    rdfs:label 'Average Cpm Amount' ;
    rdfs:comment 'Average cost per thousand impressions for this channel, used for budget planning and ROI (Return on Investment) analysis.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelCategory rdf:type rdf:Property ;
    rdfs:label 'Channel Category' ;
    rdfs:comment 'High-level classification of the channel: owned (company-controlled properties), earned (organic reach), or paid (purchased media).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the channel for reporting and integration purposes.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelDescription rdf:type rdf:Property ;
    rdfs:label 'Channel Description' ;
    rdfs:comment 'Detailed description of the channel, including its purpose, audience reach, and typical use cases within the marketing strategy.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'The business name of the marketing channel (e.g., Google Ads, Facebook, Email Newsletter, In-Store Display).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costModel rdf:type rdf:Property ;
    rdfs:label 'Cost Model' ;
    rdfs:comment 'Pricing model for the channel: CPM (Cost Per Mille/Thousand Impressions), CPC (Cost Per Click), CPA (Cost Per Acquisition), flat (fixed fee), hybrid (combination), performance (outcome-based).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRefreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Data Refresh Frequency' ;
    rdfs:comment 'Frequency at which performance data from this channel is refreshed in the marketing analytics platform: real-time, hourly, daily, weekly, or manual.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationStatus rdf:type rdf:Property ;
    rdfs:label 'Integration Status' ;
    rdfs:comment 'Current integration status with the marketing automation platform: integrated (fully connected), pending (in progress), not_integrated (manual or offline), deprecated (legacy, no longer used).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Email' ;
    rdfs:comment 'Email address of the channel owner for operational communication and escalation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Name of the individual or team responsible for managing and optimizing this channel.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformVendorName rdf:type rdf:Property ;
    rdfs:label 'Platform Vendor Name' ;
    rdfs:comment 'Name of the platform or vendor providing the channel service (e.g., Google, Meta, Salesforce Marketing Cloud, Mailchimp, Adobe Campaign).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryKpi rdf:type rdf:Property ;
    rdfs:label 'Primary Kpi' ;
    rdfs:comment 'The primary key performance indicator used to measure success for this channel (e.g., CTR (Click-Through Rate), conversion rate, ROAS (Return on Ad Spend), engagement rate).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsAbTesting rdf:type rdf:Property ;
    rdfs:label 'Supports Ab Testing' ;
    rdfs:comment 'Indicates whether the channel supports A/B testing or multivariate testing for campaign optimization. True if supported, False otherwise.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsAutomation rdf:type rdf:Property ;
    rdfs:label 'Supports Automation' ;
    rdfs:comment 'Indicates whether the channel supports marketing automation workflows (e.g., triggered campaigns, drip sequences). True if supported, False otherwise.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsPersonalization rdf:type rdf:Property ;
    rdfs:label 'Supports Personalization' ;
    rdfs:comment 'Indicates whether the channel supports personalized content delivery based on customer data and segmentation. True if supported, False otherwise.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetAudienceProfile rdf:type rdf:Property ;
    rdfs:label 'Target Audience Profile' ;
    rdfs:comment 'Description of the typical audience demographics and psychographics that this channel reaches most effectively.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContractNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Contract Number' ;
    rdfs:comment 'Contract or agreement number with the channel vendor or platform provider, used for procurement and compliance tracking.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advertisedSkuPriceId rdf:type rdf:Property ;
    rdfs:label 'Advertised Sku Price Id' ;
    rdfs:comment 'Foreign key linking to pricing.sku_price. Business justification: Media buys feature specific products at specific advertised prices ("$9.99 sale" in display ads). Creative approval and legal compliance require verifying advertised prices match current authorized re' ;
    rdfs:domain ind:MediaBuy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuPrice .

ind:mediaPlanId rdf:type rdf:Property ;
    rdfs:label 'Media Plan Id' ;
    rdfs:comment 'Reference to the parent media plan under which this buy was executed. Links the buy to strategic planning and budget allocation.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaPlan .

ind:publisherId rdf:type rdf:Property ;
    rdfs:label 'Publisher Id' ;
    rdfs:comment 'Reference to the supplier or vendor master record for the publisher. Links to vendor management and payment systems.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Publisher .

ind:bookingDate rdf:type rdf:Property ;
    rdfs:label 'Booking Date' ;
    rdfs:comment 'The date when the media buy was officially booked or reserved with the publisher. Key milestone in the buy lifecycle.' ;
    rdfs:domain ind:MediaBuy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:buyReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Buy Reference Number' ;
    rdfs:comment 'External business identifier for the media buy, used in vendor communications, invoices, and reporting. Human-readable unique code.' ;
    rdfs:domain ind:MediaBuy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyStatus rdf:type rdf:Property ;
    rdfs:label 'Buy Status' ;
    rdfs:comment 'Current lifecycle status of the media buy. Tracks progression from planning through execution to completion or cancellation. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|booked|in_flight|completed|cancelled|paused — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBuy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyType rdf:type rdf:Property ;
    rdfs:label 'Buy Type' ;
    rdfs:comment 'Pricing model for the media buy. CPM (Cost Per Mille/Thousand Impressions), CPC (Cost Per Click), CPV (Cost Per View), CPA (Cost Per Acquisition), CPL (Cost Per Lead), flat fee, or sponsorship. [ENUM-REF-CANDIDATE: cpm|cpc|cpv|cpa|cpl|flat_fee|sponsorship|programmatic_rtb — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MediaBuy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedRate rdf:type rdf:Property ;
    rdfs:label 'Contracted Rate' ;
    rdfs:comment 'The negotiated unit rate for the buy based on the buy type (e.g., rate per thousand impressions for CPM, rate per click for CPC). Basis for cost calculation.' ;
    rdfs:domain ind:MediaBuy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daypartTargeting rdf:type rdf:Property ;
    rdfs:label 'Daypart Targeting' ;
    rdfs:comment 'Time-of-day or day-of-week targeting applied to the buy (e.g., weekday mornings, prime time). Used for scheduling optimization.' ;
    rdfs:domain ind:MediaBuy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredImpressions rdf:type rdf:Property ;
    rdfs:label 'Delivered Impressions' ;
    rdfs:comment 'Actual number of ad impressions served by the publisher for this buy. Used for delivery reconciliation and performance analysis.' ;
    rdfs:domain ind:MediaBuy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dspPlatformName rdf:type rdf:Property ;
    rdfs:label 'Dsp Platform Name' ;
    rdfs:comment 'Name of the demand-side platform used for programmatic buys (e.g., Google DV360, The Trade Desk, Amazon DSP). Null for direct buys.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightEndDate rdf:type rdf:Property ;
    rdfs:label 'Flight End Date' ;
    rdfs:comment 'The date when the media buy placement stops running. Defines the end of the active delivery window.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flightStartDate rdf:type rdf:Property ;
    rdfs:label 'Flight Start Date' ;
    rdfs:comment 'The date when the media buy placement begins running. Defines the start of the active delivery window.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicTargeting rdf:type rdf:Property ;
    rdfs:label 'Geographic Targeting' ;
    rdfs:comment 'Geographic scope for ad delivery (countries, regions, DMAs, postal codes). Defines where the ad will be shown.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insertionOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Insertion Order Number' ;
    rdfs:comment 'The insertion order or contract number issued to the publisher for this buy. Legal and financial reference for the placement.' ;
    rdfs:domain ind:MediaBuy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isProgrammatic rdf:type rdf:Property ;
    rdfs:label 'Is Programmatic' ;
    rdfs:comment 'Indicates whether this buy was executed through programmatic advertising platforms (DSP, ad exchange) versus direct publisher negotiation.' ;
    rdfs:domain ind:MediaBuy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementType rdf:type rdf:Property ;
    rdfs:label 'Placement Type' ;
    rdfs:comment 'Specific type of media placement within the channel (e.g., search keyword, display banner, video pre-roll, sponsored post, billboard, TV spot). Describes the ad format and positioning.' ;
    rdfs:domain ind:MediaBuy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedImpressions rdf:type rdf:Property ;
    rdfs:label 'Planned Impressions' ;
    rdfs:comment 'Target number of ad impressions contracted or forecasted for this buy. Used for reach and frequency planning.' ;
    rdfs:domain ind:MediaBuy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Spend Amount' ;
    rdfs:comment 'Budgeted or forecasted spend for this media buy at the time of booking. Used for budget tracking and variance analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viewabilityRate rdf:type rdf:Property ;
    rdfs:label 'Viewability Rate' ;
    rdfs:comment 'Percentage of impressions that met viewability standards (MRC: 50% of pixels in view for 1+ seconds for display, 2+ seconds for video). Quality metric.' ;
    rdfs:domain ind:MediaBuy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryMediaAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Media Associate Id' ;
    rdfs:comment 'Identifier of the user or manager who approved this media plan.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:audienceSegmentIds rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Ids' ;
    rdfs:comment 'Comma-separated list of audience segment identifiers targeted by this media plan.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Display Budget Amount' ;
    rdfs:comment 'Budget allocated to display advertising (banner ads, programmatic display, retargeting).' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emailBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Email Budget Amount' ;
    rdfs:comment 'Budget allocated to email marketing campaigns and automation.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oohBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Ooh Budget Amount' ;
    rdfs:comment 'Budget allocated to out-of-home advertising (billboards, transit ads, digital signage).' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidSearchBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Search Budget Amount' ;
    rdfs:comment 'Budget allocated to paid search advertising channels (Google Ads, Bing Ads, etc.).' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidSocialBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Social Budget Amount' ;
    rdfs:comment 'Budget allocated to paid social media advertising channels (Facebook, Instagram, LinkedIn, TikTok, etc.).' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Unique alphanumeric code for the media plan, used for external reference and integration with media buying platforms.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed description of the media plan strategy, objectives, and tactical approach.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedFrequency rdf:type rdf:Property ;
    rdfs:label 'Planned Frequency' ;
    rdfs:comment 'Average number of times each individual in the target audience is expected to be exposed to the campaign.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReach rdf:type rdf:Property ;
    rdfs:label 'Planned Reach' ;
    rdfs:comment 'Estimated number of unique individuals or households expected to be exposed to the campaign at least once.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedTotalImpressions rdf:type rdf:Property ;
    rdfs:label 'Planned Total Impressions' ;
    rdfs:comment 'Total number of ad impressions planned across all channels for this media plan.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the planning period for which this media plan is designed.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the planning period for which this media plan is designed.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:printBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Print Budget Amount' ;
    rdfs:comment 'Budget allocated to print advertising (newspapers, magazines, circulars).' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:radioBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Radio Budget Amount' ;
    rdfs:comment 'Budget allocated to radio advertising (terrestrial and streaming radio).' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:smsBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Sms Budget Amount' ;
    rdfs:comment 'Budget allocated to SMS marketing campaigns and automation.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCpa rdf:type rdf:Property ;
    rdfs:label 'Target Cpa' ;
    rdfs:comment 'Target cost per customer acquisition or conversion for performance marketing channels.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCpc rdf:type rdf:Property ;
    rdfs:label 'Target Cpc' ;
    rdfs:comment 'Target cost per click for paid search and paid social channels.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCpm rdf:type rdf:Property ;
    rdfs:label 'Target Cpm' ;
    rdfs:comment 'Target cost per thousand impressions for media buying efficiency.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetRoas rdf:type rdf:Property ;
    rdfs:label 'Target Roas' ;
    rdfs:comment 'Target return on ad spend ratio, expressed as revenue generated per dollar spent on advertising.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPlannedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Planned Budget Amount' ;
    rdfs:comment 'Total budget allocated for this media plan across all channels and placements.' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tvBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Tv Budget Amount' ;
    rdfs:comment 'Budget allocated to television advertising (broadcast, cable, connected TV).' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Video Budget Amount' ;
    rdfs:comment 'Budget allocated to video advertising channels (YouTube, OTT, streaming platforms).' ;
    rdfs:domain ind:MediaPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optInRecordId rdf:type rdf:Property ;
    rdfs:label 'Opt In Record Id' ;
    rdfs:comment 'Unique identifier for the marketing communication opt-in record. Primary key for the opt-in record entity.' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:canSpamCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Can Spam Compliant Flag' ;
    rdfs:comment 'Indicates whether this opt-in record meets CAN-SPAM Act requirements for email marketing. True if compliant, false otherwise.' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccpaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Compliant Flag' ;
    rdfs:comment 'Indicates whether this opt-in record meets CCPA requirements for California residents. True if compliant, false otherwise.' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiry Date' ;
    rdfs:comment 'The date when this opt-in consent expires and must be re-confirmed. Null if consent does not expire. Required in some jurisdictions (e.g., GDPR recommends periodic re-consent).' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentTextVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Text Version' ;
    rdfs:comment 'Version identifier of the consent language presented to the customer at the time of opt-in. Required for GDPR compliance to prove informed consent.' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactCount rdf:type rdf:Property ;
    rdfs:label 'Contact Count' ;
    rdfs:comment 'The total number of marketing communications sent to this customer via this channel since opt-in. Used for frequency capping and customer experience management.' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Contact Verification Timestamp' ;
    rdfs:comment 'The date and time when the contact value was last verified. Null if never verified.' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Contact Verified Flag' ;
    rdfs:comment 'Indicates whether the contact value has been verified as valid and deliverable. True if verified, false otherwise.' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentPreference rdf:type rdf:Property ;
    rdfs:label 'Content Preference' ;
    rdfs:comment 'Free-text or coded description of the types of content the customer wants to receive (e.g., promotions, new arrivals, loyalty rewards). Used for personalized targeting.' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleOptInConfirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Confirmation Timestamp' ;
    rdfs:comment 'The date and time when the customer confirmed their opt-in via double opt-in process. Null if double opt-in was not used or not yet confirmed.' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:doubleOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Flag' ;
    rdfs:comment 'Indicates whether the customer confirmed their opt-in via a double opt-in process (e.g., email confirmation link). True if double opt-in confirmed, false if single opt-in.' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyPreference rdf:type rdf:Property ;
    rdfs:label 'Frequency Preference' ;
    rdfs:comment 'The customers preferred frequency for receiving marketing communications on this channel. Used to honor customer preferences and reduce unsubscribes.' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant Flag' ;
    rdfs:comment 'Indicates whether this opt-in record meets GDPR consent requirements for customers in EU jurisdictions. True if compliant, false otherwise.' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'The date when the customer was last contacted via this channel. Used to enforce frequency preferences and avoid over-communication.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInSource rdf:type rdf:Property ;
    rdfs:label 'Opt In Source' ;
    rdfs:comment 'The touchpoint or system where the customer provided their opt-in consent. Critical for audit trail and consent provenance. [ENUM-REF-CANDIDATE: checkout|loyalty_enrollment|website_preference_center|in_store|mobile_app|customer_service|third_party — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInStatus rdf:type rdf:Property ;
    rdfs:label 'Opt In Status' ;
    rdfs:comment 'Current opt-in status for this customer and channel combination. Governs whether the customer can be contacted via this channel.' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opt In Timestamp' ;
    rdfs:comment 'The date and time when the customer opted in to receive marketing communications for this channel. Required for CAN-SPAM and GDPR consent audit trails.' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optOutMethod rdf:type rdf:Property ;
    rdfs:label 'Opt Out Method' ;
    rdfs:comment 'The mechanism or channel through which the customer opted out. Required for compliance reporting and process improvement. [ENUM-REF-CANDIDATE: unsubscribe_link|preference_center|customer_service|email_reply|sms_stop|in_store|automated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutReason rdf:type rdf:Property ;
    rdfs:label 'Opt Out Reason' ;
    rdfs:comment 'Free-text or coded reason provided by the customer for opting out. Used for customer experience analysis and retention strategies.' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionListFlag rdf:type rdf:Property ;
    rdfs:label 'Suppression List Flag' ;
    rdfs:comment 'Indicates whether this customer-channel combination is on a suppression list and must not be contacted. True if suppressed, false otherwise.' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tcpaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Tcpa Compliant Flag' ;
    rdfs:comment 'Indicates whether this opt-in record meets TCPA requirements for SMS and phone marketing. True if compliant, false otherwise. Applies to SMS and phone channels only.' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyConsentDate rdf:type rdf:Property ;
    rdfs:label 'Third Party Consent Date' ;
    rdfs:comment 'The date when consent was originally obtained by the third-party source. Null if not applicable. Required for GDPR Article 14 transparency.' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:thirdPartySourceName rdf:type rdf:Property ;
    rdfs:label 'Third Party Source Name' ;
    rdfs:comment 'Name of the third-party vendor or partner who provided this opt-in record, if applicable. Null if opt-in was collected directly. Required for compliance and data lineage.' ;
    rdfs:domain ind:OptInRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pushNotificationSendId rdf:type rdf:Property ;
    rdfs:label 'Push Notification Send Id' ;
    rdfs:comment 'Unique identifier for the push notification send event. Primary key for this transactional record.' ;
    rdfs:domain ind:PushNotificationSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPushAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Push Associate Id' ;
    rdfs:comment 'Reference to the user or system account that created this push notification send record. Supports audit trail and accountability.' ;
    rdfs:domain ind:PushNotificationSend ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:actionButton1Label rdf:type rdf:Property ;
    rdfs:label 'Action Button 1 Label' ;
    rdfs:comment 'The text label for the first action button displayed in the push notification. Enables direct customer actions such as Shop Now or View Details.' ;
    rdfs:domain ind:PushNotificationSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionButton1Url rdf:type rdf:Property ;
    rdfs:label 'Action Button 1 Url' ;
    rdfs:comment 'The deep link URL associated with the first action button. Directs the customer to a specific app screen when the button is tapped.' ;
    rdfs:domain ind:PushNotificationSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionButton2Label rdf:type rdf:Property ;
    rdfs:label 'Action Button 2 Label' ;
    rdfs:comment 'The text label for the second action button displayed in the push notification. Provides an alternative customer action option.' ;
    rdfs:domain ind:PushNotificationSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionButton2Url rdf:type rdf:Property ;
    rdfs:label 'Action Button 2 Url' ;
    rdfs:comment 'The deep link URL associated with the second action button. Directs the customer to an alternative app screen when the button is tapped.' ;
    rdfs:domain ind:PushNotificationSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:badgeCount rdf:type rdf:Property ;
    rdfs:label 'Badge Count' ;
    rdfs:comment 'The number displayed on the app icon badge after this notification is delivered. Used to indicate unread notifications or pending actions.' ;
    rdfs:domain ind:PushNotificationSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deepLinkUrl rdf:type rdf:Property ;
    rdfs:label 'Deep Link Url' ;
    rdfs:comment 'The URL that directs the customer to a specific screen or content within the retailers mobile app when the notification is tapped. Enables direct navigation to relevant product, category, or promotional content.' ;
    rdfs:domain ind:PushNotificationSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dismissedCount rdf:type rdf:Property ;
    rdfs:label 'Dismissed Count' ;
    rdfs:comment 'The number of customers who dismissed or swiped away the push notification without opening it. Indicates lack of engagement or relevance.' ;
    rdfs:domain ind:PushNotificationSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failedCount rdf:type rdf:Property ;
    rdfs:label 'Failed Count' ;
    rdfs:comment 'The number of push notifications that failed to deliver due to technical errors, invalid device tokens, or platform issues.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isSilentNotification rdf:type rdf:Property ;
    rdfs:label 'Is Silent Notification' ;
    rdfs:comment 'Indicates whether this push notification was sent as a silent background notification without alerting the user. Used for data synchronization or app state updates.' ;
    rdfs:domain ind:PushNotificationSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationBody rdf:type rdf:Property ;
    rdfs:label 'Notification Body' ;
    rdfs:comment 'The main message content or body text of the push notification. Provides detailed information or call-to-action to the customer.' ;
    rdfs:domain ind:PushNotificationSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationTitle rdf:type rdf:Property ;
    rdfs:label 'Notification Title' ;
    rdfs:comment 'The headline or title text displayed in the push notification on the customers mobile device. Primary attention-grabbing message component.' ;
    rdfs:domain ind:PushNotificationSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openedCount rdf:type rdf:Property ;
    rdfs:label 'Opened Count' ;
    rdfs:comment 'The number of customers who tapped or opened the push notification. Key engagement metric for measuring notification effectiveness.' ;
    rdfs:domain ind:PushNotificationSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:personalizationApplied rdf:type rdf:Property ;
    rdfs:label 'Personalization Applied' ;
    rdfs:comment 'Indicates whether dynamic personalization was applied to the notification content based on customer data. Personalized notifications may include customer name, product recommendations, or behavioral triggers.' ;
    rdfs:domain ind:PushNotificationSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:platform rdf:type rdf:Property ;
    rdfs:label 'Platform' ;
    rdfs:comment 'The mobile operating system platform targeted by this push notification send. Determines the push notification service used (APNS for iOS, FCM for Android).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pushPlatformJobCode rdf:type rdf:Property ;
    rdfs:label 'Push Platform Job Code' ;
    rdfs:comment 'The unique job or batch identifier assigned by the push notification platform (e.g., Firebase Cloud Messaging, Apple Push Notification Service) for this send execution. Used for technical troubleshooting and reconciliation.' ;
    rdfs:domain ind:PushNotificationSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendCode rdf:type rdf:Property ;
    rdfs:label 'Send Code' ;
    rdfs:comment 'Unique business identifier or code for this push notification send, used for external reference and cross-system tracking.' ;
    rdfs:domain ind:PushNotificationSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendCostAmount rdf:type rdf:Property ;
    rdfs:label 'Send Cost Amount' ;
    rdfs:comment 'The total cost incurred for executing this push notification send, typically charged by the push notification platform provider on a per-message or per-recipient basis.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sendCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Send Cost Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the send cost amount. Enables multi-currency cost tracking for global marketing operations.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soundFileName rdf:type rdf:Property ;
    rdfs:label 'Sound File Name' ;
    rdfs:comment 'The name of the audio file played when the push notification is received. Enables custom notification sounds for different message types.' ;
    rdfs:domain ind:PushNotificationSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeToLiveSeconds rdf:type rdf:Property ;
    rdfs:label 'Time To Live Seconds' ;
    rdfs:comment 'The duration in seconds that the push notification platform will attempt to deliver the notification if the device is offline. After this period, the notification expires.' ;
    rdfs:domain ind:PushNotificationSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:smsSendId rdf:type rdf:Property ;
    rdfs:label 'Sms Send Id' ;
    rdfs:comment 'Unique identifier for the SMS/MMS send event. Primary key for the sms_send product.' ;
    rdfs:domain ind:SmsSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySmsAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Sms Associate Id' ;
    rdfs:comment 'Reference to the user or system account that created this SMS send record. Used for audit trails and accountability in campaign execution.' ;
    rdfs:domain ind:SmsSend ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:bouncedCount rdf:type rdf:Property ;
    rdfs:label 'Bounced Count' ;
    rdfs:comment 'The number of messages that bounced due to permanent delivery failures such as disconnected numbers or invalid phone numbers. Subset of failed_count requiring list cleanup.' ;
    rdfs:domain ind:SmsSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierRouting rdf:type rdf:Property ;
    rdfs:label 'Carrier Routing' ;
    rdfs:comment 'The mobile carrier network or SMS gateway provider used to route and deliver this SMS send. Examples include Twilio, Vonage, or direct carrier integrations. Impacts delivery rates and cost.' ;
    rdfs:domain ind:SmsSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceConsentVerified rdf:type rdf:Property ;
    rdfs:label 'Compliance Consent Verified' ;
    rdfs:comment 'Boolean flag indicating whether all recipients in this send have verified opt-in consent on file, as required by TCPA and CTIA guidelines. Critical for regulatory compliance and audit trails.' ;
    rdfs:domain ind:SmsSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMms rdf:type rdf:Property ;
    rdfs:label 'Is Mms' ;
    rdfs:comment 'Boolean flag indicating whether this send included multimedia content (images, video, audio) making it an MMS rather than plain text SMS. MMS has different pricing and delivery characteristics.' ;
    rdfs:domain ind:SmsSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaUrl rdf:type rdf:Property ;
    rdfs:label 'Media Url' ;
    rdfs:comment 'The URL of the multimedia asset (image, video, audio file) included in an MMS message. Null for standard SMS. Used for content tracking and compliance archiving.' ;
    rdfs:domain ind:SmsSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageContent rdf:type rdf:Property ;
    rdfs:label 'Message Content' ;
    rdfs:comment 'The actual text content of the SMS/MMS message sent to recipients. May include personalization tokens that were dynamically replaced per recipient. For MMS, this is the text portion; media URLs are tracked separately.' ;
    rdfs:domain ind:SmsSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageLength rdf:type rdf:Property ;
    rdfs:label 'Message Length' ;
    rdfs:comment 'The character count of the SMS message content. Standard SMS is 160 characters; longer messages are segmented. Used for billing and compliance tracking.' ;
    rdfs:domain ind:SmsSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:messageSegmentCount rdf:type rdf:Property ;
    rdfs:label 'Message Segment Count' ;
    rdfs:comment 'The number of SMS segments required to transmit the message. Messages over 160 characters are split into multiple segments, each billed separately. Critical for cost calculation.' ;
    rdfs:domain ind:SmsSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optOutCount rdf:type rdf:Property ;
    rdfs:label 'Opt Out Count' ;
    rdfs:comment 'The number of recipients who replied with STOP or unsubscribe keywords in response to this SMS send, triggering automatic removal from future sends. Critical for TCPA compliance and list management.' ;
    rdfs:domain ind:SmsSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformJobCode rdf:type rdf:Property ;
    rdfs:label 'Platform Job Code' ;
    rdfs:comment 'The unique job or batch identifier assigned by the SMS marketing automation platform (e.g., Salesforce Marketing Cloud, Braze, Iterable) for this send execution. Used for platform-specific troubleshooting and reconciliation.' ;
    rdfs:domain ind:SmsSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderCode rdf:type rdf:Property ;
    rdfs:label 'Sender Code' ;
    rdfs:comment 'The alphanumeric sender ID or long code phone number displayed to recipients as the message sender. Alternative to short codes, used for lower-volume or international sends.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortCode rdf:type rdf:Property ;
    rdfs:label 'Short Code' ;
    rdfs:comment 'The 5-6 digit short code number used as the sender ID for this SMS send. Short codes are leased from carriers and used for high-volume marketing sends. Provides brand recognition and opt-out handling.' ;
    rdfs:domain ind:SmsSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRecipients rdf:type rdf:Property ;
    rdfs:label 'Total Recipients' ;
    rdfs:comment 'The total number of unique mobile phone numbers targeted by this SMS send. Represents the audience size before any delivery filtering or failures.' ;
    rdfs:domain ind:SmsSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trackedUrl rdf:type rdf:Property ;
    rdfs:label 'Tracked Url' ;
    rdfs:comment 'The shortened, trackable URL included in the SMS message that redirects to the campaign landing page. Enables click tracking and attribution. Typically uses bit.ly or custom domain shortener.' ;
    rdfs:domain ind:SmsSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialPostId rdf:type rdf:Property ;
    rdfs:label 'Social Post Id' ;
    rdfs:comment 'Unique identifier for the social media post record. Primary key.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advertisingPolicyId rdf:type rdf:Property ;
    rdfs:label 'Advertising Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: Boosted social posts must comply with FTC disclosure policies and platform advertising policies. Real business need: approval workflow before paid promotion, regulatory compliance verification. Retail' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:primarySocialAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Social Associate Id' ;
    rdfs:comment 'Reference to the internal user or marketing team member who created the post record. Used for content authorship tracking and workflow accountability.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:tertiarySocialModifiedByAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Social Modified By Associate Id' ;
    rdfs:comment 'Reference to the internal user who last modified the post record. Used for audit trail and accountability tracking.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:accountHandle rdf:type rdf:Property ;
    rdfs:label 'Account Handle' ;
    rdfs:comment 'The username or handle of the brand or banner account that published the post (e.g., @RetailBrandUSA). Identifies which corporate social account owns the post.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualPublishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Publish Timestamp' ;
    rdfs:comment 'The actual date and time when the post went live on the platform. May differ from scheduled time due to manual overrides, platform delays, or approval workflows.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:boostBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Boost Budget Amount' ;
    rdfs:comment 'The total budget allocated for boosting or promoting this post, in the currency specified by boost_budget_currency_code. Null for organic posts.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boostBudgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Boost Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the boost budget (e.g., USD, EUR, GBP). Null for organic posts.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementRate rdf:type rdf:Property ;
    rdfs:label 'Engagement Rate' ;
    rdfs:comment 'The calculated engagement rate for the post, typically (likes + comments + shares) / reach. Expressed as a decimal (e.g., 0.0523 for 5.23%). May be calculated internally or sourced from platform analytics.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hashtags rdf:type rdf:Property ;
    rdfs:label 'Hashtags' ;
    rdfs:comment 'Comma-separated list of hashtags included in the post (e.g., #RetailDeals, #SummerSale, #BOPIS). Used for content categorization and trend analysis.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressions rdf:type rdf:Property ;
    rdfs:label 'Impressions' ;
    rdfs:comment 'The total number of times the post was displayed, including multiple views by the same user. Platform-reported metric; updated periodically via API sync.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBoosted rdf:type rdf:Property ;
    rdfs:label 'Is Boosted' ;
    rdfs:comment 'Indicates whether the post has paid media spend behind it (boosted or promoted). True means paid amplification is active; false means organic reach only.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:likes rdf:type rdf:Property ;
    rdfs:label 'Likes' ;
    rdfs:comment 'The total number of likes or reactions the post received. Platform-reported metric; updated periodically via API sync.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkClicks rdf:type rdf:Property ;
    rdfs:label 'Link Clicks' ;
    rdfs:comment 'The total number of clicks on any links embedded in the post (e.g., product links, landing page URLs). Platform-reported metric; updated periodically via API sync.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mentions rdf:type rdf:Property ;
    rdfs:label 'Mentions' ;
    rdfs:comment 'Comma-separated list of user handles or brand accounts mentioned in the post (e.g., @InfluencerName, @PartnerBrand). Used for influencer tracking and partnership attribution.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformPostCode rdf:type rdf:Property ;
    rdfs:label 'Platform Post Code' ;
    rdfs:comment 'The unique identifier assigned by the social media platform to this post (e.g., Facebook Post ID, Instagram Media ID). Used for API integration and cross-system reconciliation.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postContent rdf:type rdf:Property ;
    rdfs:label 'Post Content' ;
    rdfs:comment 'The full text content of the social media post, including captions, hashtags, and copy. May be null for image-only or video-only posts without text.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postStatus rdf:type rdf:Property ;
    rdfs:label 'Post Status' ;
    rdfs:comment 'Current lifecycle status of the post. Draft indicates content is being prepared; scheduled indicates approved and queued; published indicates live; failed indicates publication error; deleted indicates removed by user; archived indicates past content retained for compliance.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postType rdf:type rdf:Property ;
    rdfs:label 'Post Type' ;
    rdfs:comment 'The format or media type of the social post. Carousel refers to multi-image swipeable posts; story refers to ephemeral 24-hour content; reel refers to short-form vertical video. [ENUM-REF-CANDIDATE: image|video|carousel|story|reel|live|link|text — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postUrl rdf:type rdf:Property ;
    rdfs:label 'Post Url' ;
    rdfs:comment 'The direct URL link to the published post on the social media platform. Used for auditing, reporting, and customer service reference.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reach rdf:type rdf:Property ;
    rdfs:label 'Reach' ;
    rdfs:comment 'The total number of unique users who saw the post at least once. Platform-reported metric; updated periodically via API sync.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:saves rdf:type rdf:Property ;
    rdfs:label 'Saves' ;
    rdfs:comment 'The total number of times users saved or bookmarked the post for later viewing. Applicable to platforms like Instagram and Pinterest. Platform-reported metric; updated periodically via API sync.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledPublishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Publish Timestamp' ;
    rdfs:comment 'The date and time when the post was scheduled to be published. Used for content calendar planning and automated publishing workflows.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shares rdf:type rdf:Property ;
    rdfs:label 'Shares' ;
    rdfs:comment 'The total number of times the post was shared or reposted by users. Platform-reported metric; updated periodically via API sync.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetAgeRange rdf:type rdf:Property ;
    rdfs:label 'Target Age Range' ;
    rdfs:comment 'The age range targeted for boosted posts (e.g., 18-24, 25-34, 35-44). Null for organic posts or when age targeting is not applied.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGender rdf:type rdf:Property ;
    rdfs:label 'Target Gender' ;
    rdfs:comment 'The gender demographic targeted for boosted posts. All indicates no gender filtering. Null for organic posts.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:videoViews rdf:type rdf:Property ;
    rdfs:label 'Video Views' ;
    rdfs:comment 'The total number of video views for video or reel posts. Definition of a view varies by platform (e.g., 3 seconds on Facebook, 1 second on TikTok). Null for non-video posts. Platform-reported metric; updated periodically via API sync.' ;
    rdfs:domain ind:SocialPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utmParameterId rdf:type rdf:Property ;
    rdfs:label 'Utm Parameter Id' ;
    rdfs:comment 'Unique identifier for the UTM parameter configuration record.' ;
    rdfs:domain ind:UtmParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryUtmAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Utm Associate Id' ;
    rdfs:comment 'User identifier of the person who created this UTM parameter configuration record.' ;
    rdfs:domain ind:UtmParameter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:tertiaryUtmApprovedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Utm Approved By User Associate Id' ;
    rdfs:comment 'User identifier of the person who approved this UTM parameter configuration for campaign use.' ;
    rdfs:domain ind:UtmParameter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:baseUrl rdf:type rdf:Property ;
    rdfs:label 'Base Url' ;
    rdfs:comment 'The destination URL before UTM parameters are appended (e.g., https://www.retailer.com/products/shoes). Used as the foundation for tagged URL construction.' ;
    rdfs:domain ind:UtmParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeAssetReference rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Reference' ;
    rdfs:comment 'Reference identifier to the creative asset (banner, video, email template) associated with this UTM configuration. Links to Digital Asset Management (DAM) system.' ;
    rdfs:domain ind:UtmParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullTaggedUrl rdf:type rdf:Property ;
    rdfs:label 'Full Tagged Url' ;
    rdfs:comment 'Complete URL with all UTM parameters appended as query string. This is the final URL used in marketing materials and campaigns.' ;
    rdfs:domain ind:UtmParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicTarget rdf:type rdf:Property ;
    rdfs:label 'Geographic Target' ;
    rdfs:comment 'Geographic scope for this UTM configuration (e.g., USA, CAN, GBR, global). Uses ISO 3166-1 alpha-3 country codes or \'global\' for worldwide campaigns.' ;
    rdfs:domain ind:UtmParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterCode rdf:type rdf:Property ;
    rdfs:label 'Parameter Code' ;
    rdfs:comment 'Unique business code for this UTM parameter configuration, used for system integration and lookup.' ;
    rdfs:domain ind:UtmParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterName rdf:type rdf:Property ;
    rdfs:label 'Parameter Name' ;
    rdfs:comment 'Human-readable name for this UTM parameter configuration, used for internal reference and governance.' ;
    rdfs:domain ind:UtmParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterStatus rdf:type rdf:Property ;
    rdfs:label 'Parameter Status' ;
    rdfs:comment 'Current lifecycle status of this UTM parameter configuration. Active configurations are approved for use in campaigns.' ;
    rdfs:domain ind:UtmParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformIntegration rdf:type rdf:Property ;
    rdfs:label 'Platform Integration' ;
    rdfs:comment 'Name of the marketing platform or tool where this UTM configuration is deployed (e.g., Google Ads, Facebook Ads Manager, Salesforce Marketing Cloud, Mailchimp).' ;
    rdfs:domain ind:UtmParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortUrl rdf:type rdf:Property ;
    rdfs:label 'Short Url' ;
    rdfs:comment 'Shortened version of the full tagged URL, used in space-constrained marketing materials such as SMS, social media posts, or print ads.' ;
    rdfs:domain ind:UtmParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyVersion rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Version' ;
    rdfs:comment 'Version identifier of the UTM taxonomy standard applied to this configuration. Ensures consistency across campaigns and prevents taxonomy drift.' ;
    rdfs:domain ind:UtmParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingDomain rdf:type rdf:Property ;
    rdfs:label 'Tracking Domain' ;
    rdfs:comment 'Domain used for URL shortening or click tracking (e.g., bit.ly, custom branded domain). Used when the full tagged URL is shortened for display purposes.' ;
    rdfs:domain ind:UtmParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationErrors rdf:type rdf:Property ;
    rdfs:label 'Validation Errors' ;
    rdfs:comment 'Description of any validation errors or warnings identified during automated quality checks. Used for governance and correction workflows.' ;
    rdfs:domain ind:UtmParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assortmentItemId rdf:type rdf:Property ;
    rdfs:label 'Assortment Item Id' ;
    rdfs:comment 'Unique identifier for the assortment item record. Primary key for this association between SKU, assortment plan, store cluster, and season.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assortmentPlanId rdf:type rdf:Property ;
    rdfs:label 'Assortment Plan Id' ;
    rdfs:comment 'Reference to the parent assortment plan that defines the strategic merchandise mix for a specific season and store cluster.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssortmentPlan .

ind:clusterId rdf:type rdf:Property ;
    rdfs:label 'Cluster Id' ;
    rdfs:comment 'Reference to the store cluster grouping that this assortment item applies to. Store clusters group locations by similar demographics, performance, or format.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cluster .

ind:featuredCampaignId rdf:type rdf:Property ;
    rdfs:label 'Featured Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Individual SKUs are featured in marketing campaigns as hero products, promotional items, or new arrivals. Retailers track which SKUs are featured in which campaigns for promotional planning, inventory' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:productSafetyCertificationId rdf:type rdf:Property ;
    rdfs:label 'Product Safety Certification Id' ;
    rdfs:comment 'Foreign key linking to compliance.certification. Business justification: Assortment items (especially private label, imported goods, children\'s products) require product safety certifications (CPSC, FDA, CE marking). Assortment planning validates certification status befor' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certification .

ind:assortmentDepthTier rdf:type rdf:Property ;
    rdfs:label 'Assortment Depth Tier' ;
    rdfs:comment 'Classification of how many variants (sizes, colors, styles) of this item are carried within its category. Deep assortments offer extensive choice within a category, narrow assortments offer limited variety.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assortmentRole rdf:type rdf:Property ;
    rdfs:label 'Assortment Role' ;
    rdfs:comment 'Strategic role of this item within the assortment. Core items are year-round staples, seasonal items are time-bound, trend items capture emerging demand, clearance items are being phased out, promotional items support campaigns, and test items are being evaluated.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributesChecklistComplete rdf:type rdf:Property ;
    rdfs:label 'Attributes Checklist Complete' ;
    rdfs:comment 'Indicates whether all required product attributes (dimensions, weight, materials, care instructions, etc.) have been captured in the Product Information Management (PIM) system for this SKU.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceStrategy rdf:type rdf:Property ;
    rdfs:label 'Clearance Strategy' ;
    rdfs:comment 'Planned approach for clearing remaining inventory of discontinued items. Markdown uses progressive price reductions, liquidation sells to third parties, RTV returns unsold units to vendor, donation gives to charity, disposal destroys unsellable goods.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Cpsc Certification Status' ;
    rdfs:comment 'Status of CPSC safety certification for products requiring consumer safety compliance (toys, children\'s products, electronics, etc.). Not required for all product categories.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationReason rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Reason' ;
    rdfs:comment 'Business reason for discontinuing this SKU from the assortment. Captures strategic rationale for removal decisions to inform future assortment planning.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Fda Certification Status' ;
    rdfs:comment 'Status of FDA certification for food, beverage, pharmaceutical, and cosmetic products requiring regulatory approval. Not required for non-food/drug categories.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalDispositionDate rdf:type rdf:Property ;
    rdfs:label 'Final Disposition Date' ;
    rdfs:comment 'Date when all remaining inventory of this discontinued SKU must be cleared from stores and distribution centers. Marks the end of the item lifecycle in this assortment.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goLiveDate rdf:type rdf:Property ;
    rdfs:label 'Go Live Date' ;
    rdfs:comment 'Planned or actual date when this SKU becomes available for sale in the designated store cluster. Critical milestone for new item launches and seasonal transitions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inclusionStatus rdf:type rdf:Property ;
    rdfs:label 'Inclusion Status' ;
    rdfs:comment 'Current inclusion or exclusion status of this SKU in the assortment plan. Indicates whether the item is actively carried, excluded from the plan, or pending final decision.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumPresentationQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Presentation Quantity' ;
    rdfs:comment 'Minimum number of units that must be displayed on the shelf to maintain visual impact and avoid out-of-stock perception. Used for store replenishment triggers.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Detailed status of new item onboarding process. Tracks progress through attribute setup, compliance certification, and go-live readiness for items in onboarding lifecycle stage.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAur rdf:type rdf:Property ;
    rdfs:label 'Planned Aur' ;
    rdfs:comment 'Target average selling price per unit for this SKU during the season, accounting for planned markdowns and promotions. Used for revenue forecasting and Gross Margin Return on Investment (GMROI) calculations.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedGmroi rdf:type rdf:Property ;
    rdfs:label 'Planned Gmroi' ;
    rdfs:comment 'Target Gross Margin Return on Investment for this assortment item. Measures how many dollars of gross margin are returned for every dollar invested in inventory. Key profitability metric for assortment decisions.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedSellThroughRate rdf:type rdf:Property ;
    rdfs:label 'Planned Sell Through Rate' ;
    rdfs:comment 'Target percentage of inventory expected to sell during the season without markdown. Key metric for assortment performance planning and Open to Buy (OTB) budgeting. Expressed as percentage (e.g., 85.50 for 85.5%).' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedUnits rdf:type rdf:Property ;
    rdfs:label 'Planned Units' ;
    rdfs:comment 'Target quantity of units to be purchased and sold for this SKU in this store cluster during the season. Foundation for Open to Buy (OTB) budget allocation.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedWeeksOfSupply rdf:type rdf:Property ;
    rdfs:label 'Planned Weeks Of Supply' ;
    rdfs:comment 'Target number of weeks that planned inventory should last based on forecasted demand. Critical for replenishment planning and avoiding overstock or stockouts.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planogramPositionRequired rdf:type rdf:Property ;
    rdfs:label 'Planogram Position Required' ;
    rdfs:comment 'Indicates whether this SKU requires a specific shelf position defined in store planograms. True for items with strategic placement requirements (endcaps, eye-level, checkout displays).' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privateLabelFlag rdf:type rdf:Property ;
    rdfs:label 'Private Label Flag' ;
    rdfs:comment 'Indicates whether this SKU is a store brand (private label) product versus a national brand. Private label items typically have higher margins and exclusive positioning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:upcRegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'Upc Registration Status' ;
    rdfs:comment 'Status of UPC or GTIN registration with GS1 for this SKU. Required for point-of-sale scanning and supply chain tracking.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assortmentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Assortment Category Id' ;
    rdfs:comment 'Reference to the merchandise subcategory within the category for more granular assortment planning and analysis.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:primaryAssortmentAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Assortment Associate Id' ;
    rdfs:comment 'Reference to the merchandise planner responsible for financial planning, OTB (Open to Buy) management, and inventory allocation for this assortment plan.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:primaryAssortmentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Primary Assortment Category Id' ;
    rdfs:comment 'Reference to the merchandise category this assortment plan covers. Links to the product category hierarchy for strategic alignment.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:assortmentBreadthTarget rdf:type rdf:Property ;
    rdfs:label 'Assortment Breadth Target' ;
    rdfs:comment 'Target number of distinct product lines or styles to be carried, representing the width of the assortment offering across the category.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assortmentDepthTarget rdf:type rdf:Property ;
    rdfs:label 'Assortment Depth Target' ;
    rdfs:comment 'Target number of variants (sizes, colors, styles) within each product line to achieve desired assortment depth. Balances customer choice with inventory complexity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clusterStrategyDescription rdf:type rdf:Property ;
    rdfs:label 'Cluster Strategy Description' ;
    rdfs:comment 'Detailed description of the assortment strategy tailored for the store cluster, including rationale for SKU selection, depth/breadth decisions, and localization considerations.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusteringMethodology rdf:type rdf:Property ;
    rdfs:label 'Clustering Methodology' ;
    rdfs:comment 'Methodology used to define the store cluster for this assortment plan: sales_volume (grouped by revenue tiers), demographics (customer profile similarity), climate (weather-driven assortment needs), format (store size/type), geographic (regional proximity), or hybrid (combination of multiple factors).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalPlanReference rdf:type rdf:Property ;
    rdfs:label 'External Plan Reference' ;
    rdfs:comment 'External reference identifier for the assortment plan in upstream or partner systems, used for cross-system reconciliation and integration.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalBrandSkuCount rdf:type rdf:Property ;
    rdfs:label 'National Brand Sku Count' ;
    rdfs:comment 'Number of national brand (vendor brand) SKUs included in the assortment plan. Complements private label count to show brand mix strategy.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otbBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Otb Budget Amount' ;
    rdfs:comment 'OTB (Open to Buy) budget allocated for purchasing inventory under this assortment plan, expressed in the company\'s reporting currency. Controls inventory investment and ensures financial discipline in buying decisions.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otbCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Otb Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the OTB (Open to Buy) budget amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedSkuCount rdf:type rdf:Property ;
    rdfs:label 'Planned Sku Count' ;
    rdfs:comment 'Total number of distinct SKUs (Stock Keeping Units) planned to be carried under this assortment plan. Represents assortment breadth and is a key metric for space planning and inventory investment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planogramRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Planogram Required Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether a planogram (POG - shelf layout diagram) is required for this assortment plan. True indicates visual merchandising and space planning are needed.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privateLabelMixPercent rdf:type rdf:Property ;
    rdfs:label 'Private Label Mix Percent' ;
    rdfs:comment 'Target percentage of private label SKUs within the total assortment, expressed as a percentage (0.00 to 100.00). Key metric for margin management and brand positioning strategy.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:privateLabelSkuCount rdf:type rdf:Property ;
    rdfs:label 'Private Label Sku Count' ;
    rdfs:comment 'Number of private label (store brand) SKUs included in the assortment plan. Used to track private label penetration strategy and margin optimization.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetGmroi rdf:type rdf:Property ;
    rdfs:label 'Target Gmroi' ;
    rdfs:comment 'Target GMROI (Gross Margin Return on Investment) for the assortment plan, measuring gross margin dollars earned for every dollar of average inventory investment. Key profitability metric for assortment performance evaluation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetInventoryTurnRate rdf:type rdf:Property ;
    rdfs:label 'Target Inventory Turn Rate' ;
    rdfs:comment 'Target number of times inventory should turn (sell and replenish) during the plan period. Higher turns indicate better inventory productivity and reduced carrying costs.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSellThroughRatePercent rdf:type rdf:Property ;
    rdfs:label 'Target Sell Through Rate Percent' ;
    rdfs:comment 'Target sell-through rate (percentage of inventory sold within the plan period) for this assortment plan, expressed as a percentage (0.00 to 100.00). Critical KPI (Key Performance Indicator) for inventory productivity and markdown risk management.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Buyer Associate Id' ;
    rdfs:comment 'Human resources employee identifier linking the buyer to the workforce management system. Used for payroll, performance tracking, and organizational hierarchy.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:buyerReportingManagerEmployeeAssociateId rdf:type rdf:Property ;
    rdfs:label 'Buyer Reporting Manager Employee Associate Id' ;
    rdfs:comment 'Employee ID of the buyer\'s direct manager in the organizational hierarchy. Used for approval workflows and performance management.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:assignedCategoryCodes rdf:type rdf:Property ;
    rdfs:label 'Assigned Category Codes' ;
    rdfs:comment 'Comma-separated list of category codes for which this buyer has purchasing and assortment planning responsibility. Categories are sub-groupings within departments (e.g., Men\'s Shirts, Laptops, Bedding).' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedDepartmentCodes rdf:type rdf:Property ;
    rdfs:label 'Assigned Department Codes' ;
    rdfs:comment 'Comma-separated list of department codes for which this buyer has purchasing responsibility. Departments represent high-level merchandise groupings (e.g., Apparel, Electronics, Home Goods).' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assortmentPlanningSystemAccess rdf:type rdf:Property ;
    rdfs:label 'Assortment Planning System Access' ;
    rdfs:comment 'Level of access the buyer has to the assortment planning and space optimization systems. Full access allows creation and modification of planograms and assortment plans.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerCode rdf:type rdf:Property ;
    rdfs:label 'Buyer Code' ;
    rdfs:comment 'Short alphanumeric code identifying the buyer in purchase orders, vendor contracts, and merchandising reports. Often used as a business key in legacy systems.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerName rdf:type rdf:Property ;
    rdfs:label 'Buyer Name' ;
    rdfs:comment 'Full legal name of the merchandise buyer or category manager.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerStatus rdf:type rdf:Property ;
    rdfs:label 'Buyer Status' ;
    rdfs:comment 'Current employment and operational status of the buyer. Inactive or terminated buyers cannot approve purchase orders or modify OTB budgets.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerType rdf:type rdf:Property ;
    rdfs:label 'Buyer Type' ;
    rdfs:comment 'Classification of the buyer role indicating seniority and scope of responsibility. Determines approval authority and OTB (Open to Buy) limits.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyingAuthorityLimit rdf:type rdf:Property ;
    rdfs:label 'Buying Authority Limit' ;
    rdfs:comment 'Maximum dollar amount the buyer can approve for a single purchase order without requiring additional management approval. Expressed in the company\'s reporting currency.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationCredentials rdf:type rdf:Property ;
    rdfs:label 'Certification Credentials' ;
    rdfs:comment 'Comma-separated list of professional certifications held by the buyer (e.g., Certified Professional in Supply Management, Retail Management Certificate). Used for professional development tracking.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'Code representing the merchandising division to which the buyer belongs (e.g., Hardlines, Softlines, Grocery). Divisions are the highest level of merchandise organization.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmroiTarget rdf:type rdf:Property ;
    rdfs:label 'Gmroi Target' ;
    rdfs:comment 'Target GMROI (Gross Margin Return on Investment) ratio assigned to the buyer for their assigned categories. Measures how much gross margin is generated for every dollar of inventory investment. Expressed as a ratio (e.g., 2.50 means $2.50 of gross margin per $1.00 of inventory).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the buyer was hired into the organization. Used for tenure analysis and performance benchmarking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internationalSourcingFlag rdf:type rdf:Property ;
    rdfs:label 'International Sourcing Flag' ;
    rdfs:comment 'Indicates whether the buyer is authorized to source products from international vendors and manage cross-border procurement. True if international sourcing is within scope.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryTurnTarget rdf:type rdf:Property ;
    rdfs:label 'Inventory Turn Target' ;
    rdfs:comment 'Target inventory turnover ratio assigned to the buyer for their assigned categories. Measures how many times inventory is sold and replaced over a period (typically annually). Higher turns indicate more efficient inventory management.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:languageProficiency rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency' ;
    rdfs:comment 'Comma-separated list of languages the buyer is proficient in, relevant for international vendor negotiations and global sourcing activities.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User ID or system identifier of the person or process that last modified the buyer record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'Date of the buyer\'s most recent formal performance review. Used to track review cycles and identify buyers due for evaluation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:markdownPercentageLimit rdf:type rdf:Property ;
    rdfs:label 'Markdown Percentage Limit' ;
    rdfs:comment 'Maximum allowable markdown percentage the buyer can authorize without additional approval. Expressed as a percentage of original retail price (e.g., 30.00 means up to 30% markdown is allowed).' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:officeLocationCode rdf:type rdf:Property ;
    rdfs:label 'Office Location Code' ;
    rdfs:comment 'Code identifying the physical office or buying center where the buyer is based. Used for travel expense allocation and regional vendor assignments.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otbBudgetLimit rdf:type rdf:Property ;
    rdfs:label 'Otb Budget Limit' ;
    rdfs:comment 'Total OTB (Open to Buy) budget allocated to this buyer for the current fiscal period. Represents the maximum inventory investment the buyer can commit to across all assigned categories.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredVendorCount rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Count' ;
    rdfs:comment 'Number of preferred or strategic vendors the buyer actively manages relationships with. Used to assess vendor portfolio concentration and diversification strategy.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:privateLabelFocusFlag rdf:type rdf:Property ;
    rdfs:label 'Private Label Focus Flag' ;
    rdfs:comment 'Indicates whether the buyer has primary responsibility for private label (store brand) product development and sourcing. True if the buyer manages private label assortments.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sellThroughRateTarget rdf:type rdf:Property ;
    rdfs:label 'Sell Through Rate Target' ;
    rdfs:comment 'Target sell-through rate percentage assigned to the buyer for their assigned categories. Represents the percentage of inventory that should be sold within a defined period (typically a season). Expressed as a percentage (e.g., 85.00 means 85% of inventory should sell through).' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorNegotiationRating rdf:type rdf:Property ;
    rdfs:label 'Vendor Negotiation Rating' ;
    rdfs:comment 'Performance rating reflecting the buyer\'s effectiveness in negotiating favorable commercial terms with vendors. Based on achieved cost reductions, payment terms, and markdown allowances.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfBuyingExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Buying Experience' ;
    rdfs:comment 'Total number of years the individual has worked in merchandise buying roles, including experience prior to joining the current organization. Used for capability assessment and succession planning.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buyingOrderId rdf:type rdf:Property ;
    rdfs:label 'Buying Order Id' ;
    rdfs:comment 'Unique identifier for the merchandise buying order record in ORMS (Oracle Retail Merchandising System). Primary key for this entity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BuyingOrder .

ind:destinationLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Id' ;
    rdfs:comment 'Identifier of the specific distribution center, store, or cross-dock facility where the merchandise will be received. Links to inventory node or store master data.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:importLicensePermitId rdf:type rdf:Property ;
    rdfs:label 'Import License Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.license_permit. Business justification: Import buying orders for regulated categories (alcohol, tobacco, pharmaceuticals, firearms) require valid import licenses. Customs brokers verify license validity before shipment. Real business proces' ;
    rdfs:domain ind:BuyingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicensePermit .

ind:otbBudgetId rdf:type rdf:Property ;
    rdfs:label 'Otb Budget Id' ;
    rdfs:comment 'Identifier of the OTB (Open to Buy) budget allocation against which this buying order is committed. Used to track spending against merchandise financial plans and prevent over-buying.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OtbBudget .

ind:primaryBuyingAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Buying Associate Id' ;
    rdfs:comment 'Identifier of the user (merchandise manager or authorized approver) who provided final approval for the buying order. Links to workforce/employee master data.' ;
    rdfs:domain ind:BuyingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:receivingFulfillmentNodeId rdf:type rdf:Property ;
    rdfs:label 'Receiving Fulfillment Node Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.node. Business justification: Inbound purchase orders must specify receiving DC/warehouse for inventory routing and capacity planning. Retail operations require knowing which fulfillment node will process incoming vendor shipments' ;
    rdfs:domain ind:BuyingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentNode .

ind:cancelDate rdf:type rdf:Property ;
    rdfs:label 'Cancel Date' ;
    rdfs:comment 'Date when the buying order was cancelled. Nullable for active orders. Populated when order_status transitions to cancelled.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for order cancellation. Nullable for active orders. Used for supplier performance analysis and procurement process improvement.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationType rdf:type rdf:Property ;
    rdfs:label 'Destination Type' ;
    rdfs:comment 'Type of destination location where the merchandise will be delivered: distribution center for centralized receiving, store for direct store delivery (DSD), cross_dock for immediate transfer, or vendor_direct for drop-ship to customer.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyCost rdf:type rdf:Property ;
    rdfs:label 'Duty Cost' ;
    rdfs:comment 'Estimated or actual customs duty and import taxes for international shipments. Used to calculate landed cost and COGS (Cost of Goods Sold).' ;
    rdfs:domain ind:BuyingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fobTerms rdf:type rdf:Property ;
    rdfs:label 'Fob Terms' ;
    rdfs:comment 'Incoterms defining the point at which ownership and risk transfer from supplier to retailer. Determines freight responsibility and cost allocation. [ENUM-REF-CANDIDATE: fob_origin|fob_destination|exw|fca|cif|dap|ddp — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BuyingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'Estimated or actual freight and shipping cost for transporting the merchandise from supplier to destination. May be retailer-paid or supplier-paid depending on FOB terms.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landedCost rdf:type rdf:Property ;
    rdfs:label 'Landed Cost' ;
    rdfs:comment 'Total cost of merchandise including product cost, freight, duties, and other charges to deliver goods to the distribution center. Used for margin analysis and pricing decisions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Date' ;
    rdfs:comment 'Target date by which the merchandise is expected to arrive at the distribution center or store. Used for inventory planning and assortment timing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Ship Window End Date' ;
    rdfs:comment 'Latest date the supplier must ship the merchandise to meet planned receipt date. Defines the end of the acceptable shipping window; late shipments may incur chargebacks.' ;
    rdfs:domain ind:BuyingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Ship Window Start Date' ;
    rdfs:comment 'Earliest date the supplier is authorized to ship the merchandise. Defines the beginning of the acceptable shipping window for timely assortment flow.' ;
    rdfs:domain ind:BuyingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Order Quantity' ;
    rdfs:comment 'Total quantity of units ordered across all SKUs (Stock Keeping Units) in this buying order. Aggregated from line-level quantities.' ;
    rdfs:domain ind:BuyingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Order Number' ;
    rdfs:comment 'Supplier\'s own order reference number assigned when they acknowledge the buying order. Used for order tracking and supplier communication.' ;
    rdfs:domain ind:BuyingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyingOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Buying Order Line Id' ;
    rdfs:comment 'Unique identifier for the buying order line item. Primary key for this entity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BuyingOrderLine .

ind:subclassCategoryId rdf:type rdf:Property ;
    rdfs:label 'Subclass Category Id' ;
    rdfs:comment 'Reference to the merchandise subclass within the class. Enables detailed category performance tracking and assortment optimization at the most granular level.' ;
    rdfs:domain ind:BuyingOrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:uomId rdf:type rdf:Property ;
    rdfs:label 'Uom Id' ;
    rdfs:comment 'Foreign key linking to product.uom. Business justification: Buying order lines specify unit of measure for ordered quantities. Must link to standardized UOM master for unit conversion, case pack calculations, receiving validation, and inventory reconciliation ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Uom .

ind:allocationQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocation Quantity' ;
    rdfs:comment 'Quantity of this SKU allocated to the specified store cluster. Supports pre-distribution planning and ensures inventory is directed to the right locations based on demand forecasts.' ;
    rdfs:domain ind:BuyingOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancelledQuantity rdf:type rdf:Property ;
    rdfs:label 'Cancelled Quantity' ;
    rdfs:comment 'Quantity cancelled by either the retailer or vendor for this line item. Tracks order changes and impacts OTB budget availability and assortment plans.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dropShipFlag rdf:type rdf:Property ;
    rdfs:label 'Drop Ship Flag' ;
    rdfs:comment 'Indicates whether this line item will be drop shipped directly from vendor to customer rather than through the retailers distribution network. Supports omnichannel fulfillment strategies.' ;
    rdfs:domain ind:BuyingOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Minimum quantity that must be ordered from the vendor for this SKU. Enforces vendor-imposed order constraints and impacts OTB planning decisions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packSize rdf:type rdf:Property ;
    rdfs:label 'Pack Size' ;
    rdfs:comment 'Number of individual units contained in a vendor pack or case. Used for calculating total units from case quantities and for warehouse receiving operations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Margin Amount' ;
    rdfs:comment 'Planned gross margin amount per unit calculated as retail price minus unit cost. Represents the expected profit contribution per unit sold.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Planned Margin Percent' ;
    rdfs:comment 'Planned gross margin percentage calculated as (retail price minus unit cost) divided by retail price. Key metric for category profitability and GMROI (Gross Margin Return on Investment) planning.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Detailed textual description of the merchandise item being ordered. Includes product name, attributes, size, color, and other distinguishing characteristics.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailPrice rdf:type rdf:Property ;
    rdfs:label 'Retail Price' ;
    rdfs:comment 'Planned retail selling price for this SKU at the time of order placement. Used for initial margin calculation and pricing strategy execution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storeClusterCode rdf:type rdf:Property ;
    rdfs:label 'Store Cluster Code' ;
    rdfs:comment 'Code identifying the store cluster or group for which this merchandise is allocated. Enables assortment planning by store type, geography, or performance tier.' ;
    rdfs:domain ind:BuyingOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorStyleNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Style Number' ;
    rdfs:comment 'Vendor-assigned style or model number for this product. Used for cross-referencing with vendor catalogs and facilitating reorder processes.' ;
    rdfs:domain ind:BuyingOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryAssociateId rdf:type rdf:Property ;
    rdfs:label 'Category Associate Id' ;
    rdfs:comment 'Reference to the merchandise planner responsible for assortment planning, OTB (Open to Buy) management, and inventory strategy for this category.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:categoryManagerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Category Manager Associate Id' ;
    rdfs:comment 'Reference to the category manager who owns strategic objectives, performance targets, and cross-functional coordination for this category.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:parentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Id' ;
    rdfs:comment 'Reference to the parent node in the merchandise hierarchy. Null for top-level departments.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:primaryComplianceProgramId rdf:type rdf:Property ;
    rdfs:label 'Primary Compliance Program Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_program. Business justification: Product categories are subject to regulatory compliance programs (food safety for grocery, toy safety for children\'s products, hazmat for chemicals, tobacco licensing). Category managers must understa' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceProgram .

ind:actualGmroi rdf:type rdf:Property ;
    rdfs:label 'Actual Gmroi' ;
    rdfs:comment 'Most recent actual GMROI (Gross Margin Return on Investment) achieved by the category.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSellThroughRate rdf:type rdf:Property ;
    rdfs:label 'Actual Sell Through Rate' ;
    rdfs:comment 'Most recent actual sell-through rate achieved by the category. Expressed as percentage (e.g., 82.30 = 82.3%).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assortmentGapFindings rdf:type rdf:Property ;
    rdfs:label 'Assortment Gap Findings' ;
    rdfs:comment 'Documented gaps in the current assortment identified during category review (e.g., missing price points, underrepresented styles, competitor advantages).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Business identifier code for the category used across systems and reporting. Unique within hierarchy level.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed description of the category scope, assortment strategy, and business purpose.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Human-readable name of the merchandise category (e.g., Women\'s Apparel, Consumer Electronics, Fresh Produce).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryRole rdf:type rdf:Property ;
    rdfs:label 'Category Role' ;
    rdfs:comment 'Strategic role of the category in the assortment (destination=traffic driver, routine=frequent purchase, convenience=fill-in, seasonal=time-bound, occasional=infrequent).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryStatus rdf:type rdf:Property ;
    rdfs:label 'Category Status' ;
    rdfs:comment 'Current lifecycle status of the category in the merchandise hierarchy.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:division rdf:type rdf:Property ;
    rdfs:label 'Division' ;
    rdfs:comment 'Top-level business division (e.g., Hardlines, Softlines, Grocery, Electronics). Applicable to department-level nodes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric level in the merchandise hierarchy (1=Department, 2=Category, 3=Subcategory, 4=Segment).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Full path from root to this node (e.g., /01/01-05/01-05-03) for efficient hierarchy traversal and reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLeafNode rdf:type rdf:Property ;
    rdfs:label 'Is Leaf Node' ;
    rdfs:comment 'Indicates whether this category is a leaf node (lowest level) in the hierarchy with no child categories. True for segments, false for departments and categories with children.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:merchandiseType rdf:type rdf:Property ;
    rdfs:label 'Merchandise Type' ;
    rdfs:comment 'High-level merchandise classification for strategic planning and reporting. [ENUM-REF-CANDIDATE: hardlines|softlines|grocery|electronics|home|health_beauty|seasonal|services — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakSeason rdf:type rdf:Property ;
    rdfs:label 'Peak Season' ;
    rdfs:comment 'Primary selling season for seasonal categories (e.g., Q4 Holiday, Spring, Back-to-School, Summer).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceVarianceNotes rdf:type rdf:Property ;
    rdfs:label 'Performance Variance Notes' ;
    rdfs:comment 'Narrative explanation of performance gaps between actual and target metrics, including root cause analysis and contributing factors.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelPenetrationTarget rdf:type rdf:Property ;
    rdfs:label 'Private Label Penetration Target' ;
    rdfs:comment 'Target percentage of category sales from private label (store brand) products. Expressed as percentage (e.g., 25.00 = 25%).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedActions rdf:type rdf:Property ;
    rdfs:label 'Recommended Actions' ;
    rdfs:comment 'Strategic and tactical recommendations from the most recent category review (e.g., expand assortment, rationalize SKUs, adjust pricing, increase promotions).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalityFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonality Flag' ;
    rdfs:comment 'Indicates whether the category exhibits significant seasonal demand patterns requiring seasonal planning and inventory strategies.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strategicObjective rdf:type rdf:Property ;
    rdfs:label 'Strategic Objective' ;
    rdfs:comment 'Current strategic goal for the category (e.g., market share growth, margin expansion, assortment rationalization, private label penetration).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetInventoryTurns rdf:type rdf:Property ;
    rdfs:label 'Target Inventory Turns' ;
    rdfs:comment 'Target number of inventory turns per year for the category (COGS divided by average inventory value).' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Target Margin Percent' ;
    rdfs:comment 'Target gross margin percentage for the category. Expressed as percentage (e.g., 42.50 = 42.5%).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSellThroughRate rdf:type rdf:Property ;
    rdfs:label 'Target Sell Through Rate' ;
    rdfs:comment 'Target sell-through rate (percentage of inventory sold within a period) for the category. Expressed as percentage (e.g., 85.00 = 85%).' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownEventId rdf:type rdf:Property ;
    rdfs:label 'Markdown Event Id' ;
    rdfs:comment 'Unique identifier for the markdown event record. Primary key.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Finding Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit_finding. Business justification: Markdowns triggered by compliance issues (expired food, product recalls, mislabeled goods, safety violations) reference the originating audit finding for financial reconciliation and root cause analys' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:effectivenessKpiDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Kpi Definition Id' ;
    rdfs:comment 'Foreign key linking to analytics.kpi_definition. Business justification: Markdown events measure effectiveness via KPIs (sell-through lift, revenue impact, margin impact). Markdown analysis reports reference KPI definitions for standardized metrics. Pricing teams use KPI-d' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiDefinition .

ind:primaryMarkdownAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Markdown Associate Id' ;
    rdfs:comment 'Identifier of the merchandising manager, buyer, or finance approver who authorized this markdown event. Null for markdowns not requiring approval or still pending approval. Critical for audit trail and accountability.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:tertiaryMarkdownModifiedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Markdown Modified By User Associate Id' ;
    rdfs:comment 'Identifier of the user who last modified this markdown event record. Used for change tracking and audit trail. Null if record has never been modified after creation.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:vendorAllowanceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Allowance Id' ;
    rdfs:comment 'Identifier linking to vendor markdown support or co-op agreement where the supplier shares markdown cost burden. Null when markdown is fully retailer-funded. Critical for vendor chargeback and Return to Vendor (RTV) processing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorAllowance .

ind:actualMarginImpact rdf:type rdf:Property ;
    rdfs:label 'Actual Margin Impact' ;
    rdfs:comment 'Realized gross margin dollar impact of the markdown event, calculated from actual sales and COGS data. Used for post-markdown profitability analysis and GMROI performance measurement. Null until markdown period completes.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualRevenueImpact rdf:type rdf:Property ;
    rdfs:label 'Actual Revenue Impact' ;
    rdfs:comment 'Realized total revenue impact of the markdown event, calculated from actual sales data. Used for post-markdown financial analysis and Return on Investment (ROI) measurement. Null until markdown period completes.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSellThroughLiftPercentage rdf:type rdf:Property ;
    rdfs:label 'Actual Sell Through Lift Percentage' ;
    rdfs:comment 'Realized increase in sell-through rate after the markdown was executed, expressed as a percentage. Measured post-markdown for effectiveness analysis and future markdown planning. Null until markdown period completes.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualUnitsSold rdf:type rdf:Property ;
    rdfs:label 'Actual Units Sold' ;
    rdfs:comment 'Realized quantity of units sold during the markdown period. Captured from Point of Sale (POS) transaction data for markdown effectiveness measurement. Null until markdown period completes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownAmount rdf:type rdf:Property ;
    rdfs:label 'Markdown Amount' ;
    rdfs:comment 'The absolute dollar value reduction per unit, calculated as original_price minus markdown_price. Used for total markdown dollar impact calculation and Gross Margin Return on Investment (GMROI) analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownNumber rdf:type rdf:Property ;
    rdfs:label 'Markdown Number' ;
    rdfs:comment 'Business identifier for the markdown event, typically formatted as MD-YYYYMMDD-NNNN for traceability and external reference.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownPercentage rdf:type rdf:Property ;
    rdfs:label 'Markdown Percentage' ;
    rdfs:comment 'The percentage reduction from original price to markdown price, calculated as ((original_price - markdown_price) / original_price) * 100. Key metric for promotional intensity and margin sacrifice analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownPrice rdf:type rdf:Property ;
    rdfs:label 'Markdown Price' ;
    rdfs:comment 'The new reduced retail price after the markdown is applied. Represents the new selling price point for the affected merchandise.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownReason rdf:type rdf:Property ;
    rdfs:label 'Markdown Reason' ;
    rdfs:comment 'Business rationale for initiating the markdown event. Seasonal clearance indicates end-of-season inventory reduction; slow seller indicates poor sell-through performance; competitive response indicates market-driven pricing adjustment; end-of-life indicates product discontinuation; damaged indicates impaired merchandise; obsolete indicates outdated or superseded products.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownStatus rdf:type rdf:Property ;
    rdfs:label 'Markdown Status' ;
    rdfs:comment 'Current lifecycle state of the markdown event. Draft indicates initial planning; pending approval indicates awaiting merchandising or finance authorization; approved indicates authorized but not yet effective; active indicates currently in effect; completed indicates markdown period has ended; cancelled indicates markdown was revoked before or during execution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownType rdf:type rdf:Property ;
    rdfs:label 'Markdown Type' ;
    rdfs:comment 'Classification of the markdown event indicating the nature and duration of the price reduction. Permanent markdowns are irreversible price changes; temporary markdowns are time-bound promotional reductions; clearance markdowns are end-of-season or end-of-life inventory liquidation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalPrice rdf:type rdf:Property ;
    rdfs:label 'Original Price' ;
    rdfs:comment 'The regular retail price before the markdown is applied. Represents the baseline Average Unit Retail (AUR) for margin impact calculation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedMarginImpact rdf:type rdf:Property ;
    rdfs:label 'Projected Margin Impact' ;
    rdfs:comment 'Forecasted gross margin dollar impact of the markdown event, accounting for Cost of Goods Sold (COGS) and markdown amount. Critical for Gross Margin Return on Investment (GMROI) target management and merchandising profitability planning.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedRevenueImpact rdf:type rdf:Property ;
    rdfs:label 'Projected Revenue Impact' ;
    rdfs:comment 'Forecasted total revenue impact of the markdown event, calculated as (markdown_price * projected_units_sold) minus baseline revenue. Negative values indicate revenue sacrifice; used for Profit and Loss (P&L) planning.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedSellThroughLiftPercentage rdf:type rdf:Property ;
    rdfs:label 'Projected Sell Through Lift Percentage' ;
    rdfs:comment 'Forecasted increase in sell-through rate as a result of the markdown, expressed as a percentage. Used for markdown effectiveness planning and inventory turn optimization. Based on historical markdown elasticity models.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedUnitsSold rdf:type rdf:Property ;
    rdfs:label 'Projected Units Sold' ;
    rdfs:comment 'Forecasted quantity of units expected to sell during the markdown period. Used for inventory planning and Open to Buy (OTB) budget impact assessment.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Vendor Contribution Amount' ;
    rdfs:comment 'Dollar amount contributed by the vendor toward the markdown cost as per vendor support agreement. Used for vendor chargeback processing and net markdown cost calculation. Zero or null when no vendor support exists.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchPlanId rdf:type rdf:Property ;
    rdfs:label 'Merch Plan Id' ;
    rdfs:comment 'Unique identifier for the merchandise financial plan record. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchPlan .

ind:primaryMerchAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Merch Associate Id' ;
    rdfs:comment 'Reference to the merchandise planner who created and maintains this financial plan.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:planNotes rdf:type rdf:Property ;
    rdfs:label 'Plan Notes' ;
    rdfs:comment 'Free-text notes and commentary about the merchandise plan, including strategic rationale, market conditions, and special considerations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedBeginningInventoryAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Beginning Inventory Amount' ;
    rdfs:comment 'Planned retail value of inventory at the start of the plan period.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Cost Amount' ;
    rdfs:comment 'Total planned cost of goods to be purchased under this merchandise plan.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEndingInventoryAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Ending Inventory Amount' ;
    rdfs:comment 'Planned retail value of inventory at the end of the plan period.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMarkdownAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Markdown Amount' ;
    rdfs:comment 'Anticipated markdown dollars to be taken during the plan period for price reductions and promotions.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMarkdownPercent rdf:type rdf:Property ;
    rdfs:label 'Planned Markdown Percent' ;
    rdfs:comment 'Target markdown rate as a percentage of planned sales.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReceiptAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Amount' ;
    rdfs:comment 'Total retail value of inventory receipts planned to arrive during the plan period.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Sales Amount' ;
    rdfs:comment 'Forecasted retail sales revenue expected to be generated during the plan period.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorYearMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Prior Year Margin Percent' ;
    rdfs:comment 'Actual gross margin percentage achieved during the comparable period in the prior year.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorYearSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Year Sales Amount' ;
    rdfs:comment 'Actual sales amount from the comparable period in the prior year, used for year-over-year comparison.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorYearUnits rdf:type rdf:Property ;
    rdfs:label 'Prior Year Units' ;
    rdfs:comment 'Actual units sold during the comparable period in the prior year.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sellThroughTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Sell Through Target Percent' ;
    rdfs:comment 'Target percentage of inventory expected to be sold during the plan period.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetOwnerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Budget Owner Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: OTB budgets require a designated budget owner/planner for accountability, approval workflows, and audit trails. Retail operations track who is responsible for managing each budget allocation. Existing' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:gmroiKpiDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Gmroi Kpi Definition Id' ;
    rdfs:comment 'Foreign key linking to analytics.kpi_definition. Business justification: OTB budget tracking measures performance against KPIs (gmroi_target, inventory_turn_target, sell_through_target_pct). Budget variance reports reference KPI definitions for standardized calculation for' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiDefinition .

ind:actualReceiptsAtCost rdf:type rdf:Property ;
    rdfs:label 'Actual Receipts At Cost' ;
    rdfs:comment 'The total actual merchandise receipts at cost that have been received into inventory during this budget period. Updated as goods receipts are posted from purchase orders.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableOtbBalance rdf:type rdf:Property ;
    rdfs:label 'Available Otb Balance' ;
    rdfs:comment 'The remaining budget balance available for new purchase commitments. Calculated as: Planned Receipts + Adjustments - Actual Receipts - Committed Amount. This is the authoritative field that determines whether a buyer can place new orders.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Adjustment Amount' ;
    rdfs:comment 'The cumulative net adjustment to the original planned receipts budget. Includes increases, decreases, and transfers from other budgets. Positive values increase available OTB; negative values decrease it.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetDecreaseAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Decrease Amount' ;
    rdfs:comment 'The total amount of budget decreases applied to this OTB budget. Decreases may occur due to lower-than-expected sales, inventory overstock, or strategic reallocation to other categories.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetEndDate rdf:type rdf:Property ;
    rdfs:label 'Budget End Date' ;
    rdfs:comment 'The effective end date of the OTB budget period. After this date, the budget is typically closed and no further commitments are allowed unless extended.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetIncreaseAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Increase Amount' ;
    rdfs:comment 'The total amount of budget increases applied to this OTB budget. Increases are typically approved by senior merchandising leadership to support higher-than-planned demand or strategic opportunities.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetStartDate rdf:type rdf:Property ;
    rdfs:label 'Budget Start Date' ;
    rdfs:comment 'The effective start date of the OTB budget period. Buyers can begin committing purchases on or after this date.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetTransferInAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Transfer In Amount' ;
    rdfs:comment 'The total amount of budget transferred into this OTB budget from other budgets. Transfers allow buyers to reallocate funds between categories or departments within the same season.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetTransferOutAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Transfer Out Amount' ;
    rdfs:comment 'The total amount of budget transferred out of this OTB budget to other budgets. Recorded as a positive value; reduces the available OTB balance of this budget.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownBudgetPct rdf:type rdf:Property ;
    rdfs:label 'Markdown Budget Pct' ;
    rdfs:comment 'The planned markdown percentage allocated for this OTB budget. Represents the expected price reductions as a percentage of planned receipts at retail. Used for margin planning and promotional strategy.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReceiptsAtCost rdf:type rdf:Property ;
    rdfs:label 'Planned Receipts At Cost' ;
    rdfs:comment 'The total planned merchandise receipts at cost for this budget period. Represents the initial budget allocation before any adjustments or commitments. Expressed in the budget currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellThroughTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sell Through Target Pct' ;
    rdfs:comment 'The target sell-through rate (as a percentage) for merchandise purchased under this OTB budget. Represents the percentage of inventory expected to be sold during the budget period.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchandisingPlanogramId rdf:type rdf:Property ;
    rdfs:label 'Merchandising Planogram Id' ;
    rdfs:comment 'Unique identifier for the planogram record. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchandisingPlanogram .

ind:primaryMerchandisingAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Merchandising Associate Id' ;
    rdfs:comment 'Reference to the merchandiser or category manager responsible for creating and maintaining this planogram.' ;
    rdfs:domain ind:MerchandisingPlanogram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:complianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Required Flag' ;
    rdfs:comment 'Indicates whether strict compliance to this planogram is mandatory for stores, or if local merchandising teams have flexibility to adapt the layout.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Compliance Tolerance Pct' ;
    rdfs:comment 'Acceptable deviation percentage from the planogram specification before a store is considered non-compliant. Used in compliance audits and store execution scoring.' ;
    rdfs:domain ind:MerchandisingPlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixtureDepthCm rdf:type rdf:Property ;
    rdfs:label 'Fixture Depth Cm' ;
    rdfs:comment 'Depth of the fixture in centimeters, determining how far products can be placed from the front edge.' ;
    rdfs:domain ind:MerchandisingPlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixtureHeightCm rdf:type rdf:Property ;
    rdfs:label 'Fixture Height Cm' ;
    rdfs:comment 'Total height of the fixture in centimeters, defining the vertical space available across all shelves.' ;
    rdfs:domain ind:MerchandisingPlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixtureType rdf:type rdf:Property ;
    rdfs:label 'Fixture Type' ;
    rdfs:comment 'Type of physical merchandising fixture that this planogram is designed for, determining the layout constraints and display capabilities.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixtureWidthCm rdf:type rdf:Property ;
    rdfs:label 'Fixture Width Cm' ;
    rdfs:comment 'Total width of the fixture in centimeters, defining the horizontal space available for product placement.' ;
    rdfs:domain ind:MerchandisingPlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationInstructions rdf:type rdf:Property ;
    rdfs:label 'Implementation Instructions' ;
    rdfs:comment 'Detailed instructions for store teams on how to implement the planogram, including reset procedures, product placement guidelines, and special handling requirements.' ;
    rdfs:domain ind:MerchandisingPlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastResetDate rdf:type rdf:Property ;
    rdfs:label 'Last Reset Date' ;
    rdfs:comment 'Date when stores last executed a full reset to this planogram, used to track implementation currency and compliance timing.' ;
    rdfs:domain ind:MerchandisingPlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:merchandisingPlanogramStatus rdf:type rdf:Property ;
    rdfs:label 'Merchandising Planogram Status' ;
    rdfs:comment 'Current lifecycle status of the planogram indicating whether it is in development, approved for deployment, actively in use in stores, or retired from use.' ;
    rdfs:domain ind:MerchandisingPlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledResetDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Reset Date' ;
    rdfs:comment 'Date when the next planogram reset or refresh is scheduled, supporting forward planning and resource allocation for store operations.' ;
    rdfs:domain ind:MerchandisingPlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planogramCode rdf:type rdf:Property ;
    rdfs:label 'Planogram Code' ;
    rdfs:comment 'Externally-known unique business identifier for the planogram, typically following a POG- prefix convention used in space planning systems and merchandising communications.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramName rdf:type rdf:Property ;
    rdfs:label 'Planogram Name' ;
    rdfs:comment 'Human-readable descriptive name of the planogram, typically including category and fixture type for easy identification by merchandising teams.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Flag' ;
    rdfs:comment 'Indicates whether this planogram is designed for a specific season or promotional period, requiring periodic reset and rotation.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfCount rdf:type rdf:Property ;
    rdfs:label 'Shelf Count' ;
    rdfs:comment 'Total number of shelves or levels in the fixture, determining the vertical product capacity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spaceAllocationSqft rdf:type rdf:Property ;
    rdfs:label 'Space Allocation Sqft' ;
    rdfs:comment 'Total square footage of selling space allocated to this planogram, calculated from fixture dimensions and used for space productivity analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spacePlanningSystemCode rdf:type rdf:Property ;
    rdfs:label 'Space Planning System Code' ;
    rdfs:comment 'External identifier from the space planning or planogram software system (e.g., JDA Space Planning, Apollo, Shelf Logic) used to create this planogram, enabling integration and synchronization.' ;
    rdfs:domain ind:MerchandisingPlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSalesPerSqft rdf:type rdf:Property ;
    rdfs:label 'Target Sales Per Sqft' ;
    rdfs:comment 'Target sales revenue per square foot of shelf space allocated to this planogram, used to measure space productivity and merchandising effectiveness.' ;
    rdfs:domain ind:MerchandisingPlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFacings rdf:type rdf:Property ;
    rdfs:label 'Total Facings' ;
    rdfs:comment 'Total number of product facings (individual product positions visible to customers) allocated across all shelves in the planogram. Key metric for assortment breadth and inventory capacity.' ;
    rdfs:domain ind:MerchandisingPlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSkuCount rdf:type rdf:Property ;
    rdfs:label 'Total Sku Count' ;
    rdfs:comment 'Total number of unique SKUs included in the planogram, representing the assortment depth for the category.' ;
    rdfs:domain ind:MerchandisingPlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visualMerchandisingNotes rdf:type rdf:Property ;
    rdfs:label 'Visual Merchandising Notes' ;
    rdfs:comment 'Additional notes on visual merchandising principles, color blocking, brand adjacencies, and aesthetic considerations for this planogram.' ;
    rdfs:domain ind:MerchandisingPlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramPositionId rdf:type rdf:Property ;
    rdfs:label 'Planogram Position Id' ;
    rdfs:comment 'Primary key for planogram_position' ;
    rdfs:domain ind:PlanogramPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bayNumber rdf:type rdf:Property ;
    rdfs:label 'Bay Number' ;
    rdfs:comment 'The bay or section number within the planogram where this position is located. Defines horizontal segmentation of the fixture.' ;
    rdfs:domain ind:PlanogramPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityUnits rdf:type rdf:Property ;
    rdfs:label 'Capacity Units' ;
    rdfs:comment 'The total number of product units that can be stocked at this position based on the allocated space and product dimensions. Drives replenishment planning.' ;
    rdfs:domain ind:PlanogramPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displayOrientation rdf:type rdf:Property ;
    rdfs:label 'Display Orientation' ;
    rdfs:comment 'The orientation in which the product should be displayed at this position (e.g., front-facing, side-facing, top-facing). Impacts visual merchandising and brand presentation.' ;
    rdfs:domain ind:PlanogramPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facingCount rdf:type rdf:Property ;
    rdfs:label 'Facing Count' ;
    rdfs:comment 'The number of product facings (front-facing units visible to the customer) allocated to this SKU at this position. Drives shelf capacity and visual prominence.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isHeroPosition rdf:type rdf:Property ;
    rdfs:label 'Is Hero Position' ;
    rdfs:comment 'Flag indicating whether this is a hero or focal position within the planogram. Hero positions receive maximum visibility and are typically assigned to top-performing or strategic SKUs.' ;
    rdfs:domain ind:PlanogramPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNewItem rdf:type rdf:Property ;
    rdfs:label 'Is New Item' ;
    rdfs:comment 'Flag indicating whether this position is designated for new product introductions. Used to highlight new SKUs and drive trial purchases.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumFacings rdf:type rdf:Property ;
    rdfs:label 'Maximum Facings' ;
    rdfs:comment 'The maximum number of facings allowed for this SKU at this position. Prevents over-allocation and ensures balanced assortment presentation.' ;
    rdfs:domain ind:PlanogramPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:merchandisingZone rdf:type rdf:Property ;
    rdfs:label 'Merchandising Zone' ;
    rdfs:comment 'The vertical merchandising zone classification for this position (eye level, reach level, stoop level, stretch level). Eye-level positions typically drive higher sales velocity.' ;
    rdfs:domain ind:PlanogramPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumFacings rdf:type rdf:Property ;
    rdfs:label 'Minimum Facings' ;
    rdfs:comment 'The minimum number of facings required for this SKU to maintain adequate shelf presence and avoid out-of-stock appearance. Used for compliance auditing.' ;
    rdfs:domain ind:PlanogramPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positionDepthCm rdf:type rdf:Property ;
    rdfs:label 'Position Depth Cm' ;
    rdfs:comment 'The depth in centimeters from the front of the shelf to the back, allocated to this position. Determines how many units can be stocked front-to-back.' ;
    rdfs:domain ind:PlanogramPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionHeightCm rdf:type rdf:Property ;
    rdfs:label 'Position Height Cm' ;
    rdfs:comment 'The vertical height in centimeters allocated to this position. Defines the vertical space occupied by the product at this shelf location.' ;
    rdfs:domain ind:PlanogramPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionSequence rdf:type rdf:Property ;
    rdfs:label 'Position Sequence' ;
    rdfs:comment 'Sequential ordering of this position within the planogram. Used to define left-to-right or top-to-bottom placement order on the shelf.' ;
    rdfs:domain ind:PlanogramPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positionWidthCm rdf:type rdf:Property ;
    rdfs:label 'Position Width Cm' ;
    rdfs:comment 'The horizontal width in centimeters allocated to this position on the shelf. Used for space productivity analysis and fixture capacity planning.' ;
    rdfs:domain ind:PlanogramPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesVelocityRank rdf:type rdf:Property ;
    rdfs:label 'Sales Velocity Rank' ;
    rdfs:comment 'The sales velocity ranking of the SKU at this position relative to other positions in the same planogram. Used to optimize high-performing SKU placement.' ;
    rdfs:domain ind:PlanogramPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shelfNumber rdf:type rdf:Property ;
    rdfs:label 'Shelf Number' ;
    rdfs:comment 'The shelf level number where this SKU is positioned. Typically numbered from bottom (1) to top, defining vertical placement within the gondola or fixture.' ;
    rdfs:domain ind:PlanogramPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signageRequired rdf:type rdf:Property ;
    rdfs:label 'Signage Required' ;
    rdfs:comment 'Flag indicating whether special signage (price, promotional, informational) is required at this position. Drives in-store execution and compliance auditing.' ;
    rdfs:domain ind:PlanogramPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spaceProductivityIndex rdf:type rdf:Property ;
    rdfs:label 'Space Productivity Index' ;
    rdfs:comment 'A calculated index measuring the revenue or profit generated per unit of shelf space allocated to this position. Used to optimize space allocation and maximize category GMROI.' ;
    rdfs:domain ind:PlanogramPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:privateLabelProgramId rdf:type rdf:Property ;
    rdfs:label 'Private Label Program Id' ;
    rdfs:comment 'Unique identifier for the private label program. Primary key.' ;
    rdfs:domain ind:PrivateLabelProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:launchCampaignId rdf:type rdf:Property ;
    rdfs:label 'Launch Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Private label launches require dedicated marketing campaigns for brand awareness and customer acquisition. Retailers track launch campaign performance to measure private label program ROI and market p' ;
    rdfs:domain ind:PrivateLabelProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:primaryPrivateAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Private Associate Id' ;
    rdfs:comment 'Reference to the merchandising manager or buyer responsible for managing this private label program.' ;
    rdfs:domain ind:PrivateLabelProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:programCertificationId rdf:type rdf:Property ;
    rdfs:label 'Program Certification Id' ;
    rdfs:comment 'Foreign key linking to compliance.certification. Business justification: Private label programs require certifications (USDA Organic, Fair Trade, Non-GMO, GFSI food safety) to support marketing claims and regulatory compliance. Quality assurance validates certification sco' ;
    rdfs:domain ind:PrivateLabelProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certification .

ind:competitivePositioning rdf:type rdf:Property ;
    rdfs:label 'Competitive Positioning' ;
    rdfs:comment 'Strategic market positioning of the private label program relative to national brand competitors.' ;
    rdfs:domain ind:PrivateLabelProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusive Flag' ;
    rdfs:comment 'Indicates whether this private label program is exclusive to this retailer (True) or shared with other retailers (False).' ;
    rdfs:domain ind:PrivateLabelProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownStrategy rdf:type rdf:Property ;
    rdfs:label 'Markdown Strategy' ;
    rdfs:comment 'Pricing and markdown strategy applied to this private label program (EDLP = Everyday Low Price, Hi-Lo = High-Low promotional pricing).' ;
    rdfs:domain ind:PrivateLabelProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingInvestmentUsd rdf:type rdf:Property ;
    rdfs:label 'Marketing Investment Usd' ;
    rdfs:comment 'Allocated marketing and promotional investment budget in USD for launching and supporting this private label program.' ;
    rdfs:domain ind:PrivateLabelProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingSpecification rdf:type rdf:Property ;
    rdfs:label 'Packaging Specification' ;
    rdfs:comment 'Detailed packaging design specifications including materials, dimensions, labeling requirements, and branding guidelines for the private label program.' ;
    rdfs:domain ind:PrivateLabelProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlProtocol rdf:type rdf:Property ;
    rdfs:label 'Quality Control Protocol' ;
    rdfs:comment 'Description of the quality control and inspection protocols applied to products in this private label program to ensure brand standards.' ;
    rdfs:domain ind:PrivateLabelProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityTier rdf:type rdf:Property ;
    rdfs:label 'Quality Tier' ;
    rdfs:comment 'Quality positioning tier of the private label program relative to national brands and competitive offerings.' ;
    rdfs:domain ind:PrivateLabelProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertificationType rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification Type' ;
    rdfs:comment 'Type of sustainability certification held by products in this private label program (e.g., USDA Organic, Fair Trade Certified, Rainforest Alliance).' ;
    rdfs:domain ind:PrivateLabelProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certified Flag' ;
    rdfs:comment 'Indicates whether products in this private label program carry sustainability certifications (e.g., organic, fair trade, carbon neutral).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetMarginPremiumPct rdf:type rdf:Property ;
    rdfs:label 'Target Margin Premium Pct' ;
    rdfs:comment 'Target gross margin premium percentage over comparable national brand products, representing the strategic margin advantage goal.' ;
    rdfs:domain ind:PrivateLabelProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPricePointUsd rdf:type rdf:Property ;
    rdfs:label 'Target Price Point Usd' ;
    rdfs:comment 'Strategic target retail price point in USD for the core SKUs in this private label program, positioned relative to national brand competitors.' ;
    rdfs:domain ind:PrivateLabelProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSellThroughRatePct rdf:type rdf:Property ;
    rdfs:label 'Target Sell Through Rate Pct' ;
    rdfs:comment 'Target sell-through rate percentage goal for inventory turnover efficiency in this private label program.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorManagedInventoryFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Managed Inventory Flag' ;
    rdfs:comment 'Indicates whether this private label program operates under a VMI (Vendor Managed Inventory) agreement where the supplier manages replenishment.' ;
    rdfs:domain ind:PrivateLabelProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buyDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Buy Deadline Date' ;
    rdfs:comment 'The final date by which all purchase orders for the season must be committed to vendors. Ensures timely receipt of merchandise for season launch.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceExitDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Exit Date' ;
    rdfs:comment 'The target date by which all seasonal merchandise should be sold through or removed from active selling floor. Marks the end of clearance activities.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstReceiptDate rdf:type rdf:Property ;
    rdfs:label 'First Receipt Date' ;
    rdfs:comment 'The target date for the first merchandise receipts to arrive at distribution centers or stores for the season. Marks the beginning of inventory flow.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineReviewDate rdf:type rdf:Property ;
    rdfs:label 'Line Review Date' ;
    rdfs:comment 'Key milestone date when the merchandising team reviews and approves the product line assortment for the season. Critical gate for buying decisions.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:markdownEntryDate rdf:type rdf:Property ;
    rdfs:label 'Markdown Entry Date' ;
    rdfs:comment 'The date when initial markdown pricing strategies are activated to accelerate sell-through of seasonal merchandise. Signals transition to promotional phase.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Start Date' ;
    rdfs:comment 'The date when pre-season planning activities begin, including assortment planning, OTB (Open to Buy) budget allocation, and category strategy development.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonCode rdf:type rdf:Property ;
    rdfs:label 'Season Code' ;
    rdfs:comment 'Short alphanumeric code representing the season (e.g., SS24 for Spring/Summer 2024, FW24 for Fall/Winter 2024). Used as the business identifier across merchandising systems.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonName rdf:type rdf:Property ;
    rdfs:label 'Season Name' ;
    rdfs:comment 'Full descriptive name of the season (e.g., Spring/Summer 2024, Holiday 2024, Back-to-School 2024). Human-readable label for business users.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonStatus rdf:type rdf:Property ;
    rdfs:label 'Season Status' ;
    rdfs:comment 'Current lifecycle status of the season. Planning: pre-season planning phase. Open-to-Buy: OTB budgets active, buying in progress. In-Season: merchandise on floor, active selling. Post-Season: season ended, analysis and clearance. Closed: season archived.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonType rdf:type rdf:Property ;
    rdfs:label 'Season Type' ;
    rdfs:comment 'Classification of the season by merchandising cycle (e.g., spring/summer, fall/winter, holiday, back-to-school). Drives assortment planning and buying strategies.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorNegotiationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Negotiation Id' ;
    rdfs:comment 'Unique identifier for the vendor negotiation event. Primary key for this data product.' ;
    rdfs:domain ind:VendorNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorAuditCorrectiveActionId rdf:type rdf:Property ;
    rdfs:label 'Vendor Audit Corrective Action Id' ;
    rdfs:comment 'Foreign key linking to compliance.corrective_action. Business justification: Ethical sourcing programs conduct vendor audits (labor practices, safety, environmental). When violations are found, corrective action plans are negotiated into supply agreements with cost/term adjust' ;
    rdfs:domain ind:VendorNegotiation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveAction .

ind:allowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Allowance Amount' ;
    rdfs:comment 'Total allowance or rebate amount negotiated with the supplier, typically as a lump sum or per-unit credit. Used to calculate net cost and GMROI.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allowanceType rdf:type rdf:Property ;
    rdfs:label 'Allowance Type' ;
    rdfs:comment 'Classification of the allowance indicating its purpose and accounting treatment. Supports revenue recognition and vendor compliance tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coopAdvertisingFund rdf:type rdf:Property ;
    rdfs:label 'Coop Advertising Fund' ;
    rdfs:comment 'Cooperative advertising funds committed by the supplier to support joint marketing and promotional campaigns. Tracked separately for marketing budget allocation.' ;
    rdfs:domain ind:VendorNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Change Percentage' ;
    rdfs:comment 'Percentage change from old cost to new cost, calculated as ((new_cost - old_cost) / old_cost) * 100. Positive values indicate cost increases, negative indicate decreases.' ;
    rdfs:domain ind:VendorNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costChangeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cost Change Reason Code' ;
    rdfs:comment 'Standardized reason code explaining the driver of the cost change. Critical for cost variance analysis and procurement strategy. [ENUM-REF-CANDIDATE: commodity_inflation|contract_renewal|tariff_change|volume_discount|quality_upgrade|currency_fluctuation|freight_adjustment|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costChangeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Change Reason Description' ;
    rdfs:comment 'Free-text detailed explanation of the cost change rationale provided by the buyer or supplier. Supplements the reason code with context.' ;
    rdfs:domain ind:VendorNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillRateCommitmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Commitment Percentage' ;
    rdfs:comment 'Supplier\'s committed fill rate percentage (order completion rate) as part of the service level agreement. Measured as percentage of ordered quantity delivered on time.' ;
    rdfs:domain ind:VendorNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'International commercial terms defining the responsibilities, costs, and risks between buyer and supplier for shipment. Standard codes such as FOB, CIF, DDP. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownSupportAmount rdf:type rdf:Property ;
    rdfs:label 'Markdown Support Amount' ;
    rdfs:comment 'Specific amount committed by the supplier to support markdown or clearance activities. Critical for margin protection and sell-through rate optimization.' ;
    rdfs:domain ind:VendorNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moqUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Moq Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the MOQ field (e.g., each, case, pallet). Ensures correct interpretation of MOQ constraints.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationEndDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation End Date' ;
    rdfs:comment 'Date when the negotiation was concluded, either through agreement, rejection, or cancellation. Nullable for ongoing negotiations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiationNotes rdf:type rdf:Property ;
    rdfs:label 'Negotiation Notes' ;
    rdfs:comment 'Free-text notes capturing key discussion points, special conditions, or context from the negotiation. Supports knowledge transfer and future negotiations.' ;
    rdfs:domain ind:VendorNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationNumber rdf:type rdf:Property ;
    rdfs:label 'Negotiation Number' ;
    rdfs:comment 'Business-facing unique identifier for the vendor negotiation event, typically formatted as VN-YYYYMMDD or similar pattern used in Oracle Retail Merchandising System (ORMS).' ;
    rdfs:domain ind:VendorNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationStartDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Start Date' ;
    rdfs:comment 'Date when the negotiation discussions formally commenced. Represents the beginning of the negotiation lifecycle.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiationStatus rdf:type rdf:Property ;
    rdfs:label 'Negotiation Status' ;
    rdfs:comment 'Current lifecycle status of the negotiation event. Tracks progression from draft through approval to execution or cancellation. [ENUM-REF-CANDIDATE: draft|in_progress|pending_approval|approved|rejected|executed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationType rdf:type rdf:Property ;
    rdfs:label 'Negotiation Type' ;
    rdfs:comment 'Classification of the negotiation event indicating the primary purpose: initial contract establishment, contract renewal, cost change request, markdown support negotiation, promotional allowance, or annual review.' ;
    rdfs:domain ind:VendorNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newCostPrice rdf:type rdf:Property ;
    rdfs:label 'New Cost Price' ;
    rdfs:comment 'Newly negotiated cost price per unit effective from the effective_date. Single source of truth for supplier commercial terms. Stored in base currency.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oldCostPrice rdf:type rdf:Property ;
    rdfs:label 'Old Cost Price' ;
    rdfs:comment 'Previous cost price per unit before the negotiation. Used to calculate cost change impact and COGS variance. Stored in base currency.' ;
    rdfs:domain ind:VendorNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationId rdf:type rdf:Property ;
    rdfs:label 'Cancellation Id' ;
    rdfs:comment 'Unique identifier for the cancellation event. Primary key for the cancellation record.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationAssociateId rdf:type rdf:Property ;
    rdfs:label 'Cancellation Associate Id' ;
    rdfs:comment 'Reference to the customer service agent or employee who processed or approved the cancellation. Null for system-initiated cancellations.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:cancellationNumber rdf:type rdf:Property ;
    rdfs:label 'Cancellation Number' ;
    rdfs:comment 'Business-facing unique cancellation reference number used for customer communication and tracking. Format: CXL-XXXXXXXXXX.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationStatus rdf:type rdf:Property ;
    rdfs:label 'Cancellation Status' ;
    rdfs:comment 'Current processing status of the cancellation request. Tracks the cancellation through its approval and execution workflow.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledAmount rdf:type rdf:Property ;
    rdfs:label 'Cancelled Amount' ;
    rdfs:comment 'Total order or line value that was cancelled, including product cost, taxes, and fees. Represents the gross cancelled transaction value.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Administrative or processing fee charged for the cancellation. Zero if no cancellation fee applies per business policy or customer segment.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiatorType rdf:type rdf:Property ;
    rdfs:label 'Initiator Type' ;
    rdfs:comment 'Category of entity that initiated the cancellation. Distinguishes between customer-initiated, system-initiated, agent-initiated, and automated rule-based cancellations.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inventory Release Timestamp' ;
    rdfs:comment 'Date and time when allocated inventory was released back to available stock following the cancellation. Null if inventory was never allocated or not yet released.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inventoryReleasedFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Released Flag' ;
    rdfs:comment 'Indicates whether inventory allocated to the cancelled order or line has been released back to available stock. True if inventory release confirmed.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingSystemCode rdf:type rdf:Property ;
    rdfs:label 'Processing System Code' ;
    rdfs:comment 'Identifier of the system or automated process that executed the cancellation. Used for system-initiated cancellations to track which rule engine or service triggered the action.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code representing the reason for cancellation. [ENUM-REF-CANDIDATE: customer_request|out_of_stock|pricing_error|duplicate_order|payment_declined|fraud_suspected|delivery_delay|product_unavailable|customer_changed_mind|incorrect_item_ordered|found_better_price|shipping_cost_too_high|delivery_time_too_long|order_placed_by_mistake|item_no_longer_needed|quality_concerns|other — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text description or additional details provided by the initiator explaining the reason for cancellation. Captures customer comments or agent notes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Refund Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the refund amount. Indicates the currency in which the refund will be processed.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Refund Eligible Flag' ;
    rdfs:comment 'Indicates whether the cancelled order or line is eligible for a refund based on payment status and business rules. True if refund should be processed.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundMethod rdf:type rdf:Property ;
    rdfs:label 'Refund Method' ;
    rdfs:comment 'Method by which the refund will be issued to the customer. Typically matches the original payment method but may differ based on business rules.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundProcessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Processed Timestamp' ;
    rdfs:comment 'Date and time when the refund was successfully processed and submitted to the payment gateway or finance system. Null if refund not yet processed.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restockingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Amount' ;
    rdfs:comment 'Fee charged to the customer for cancelling the order after certain fulfillment stages. Zero if no restocking fee applies per business policy.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Order fulfillment stage at which the cancellation occurred. Indicates how far the order progressed before cancellation and impacts inventory release and refund processing.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountId rdf:type rdf:Property ;
    rdfs:label 'Discount Id' ;
    rdfs:comment 'Primary key for discount' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountAssociateId rdf:type rdf:Property ;
    rdfs:label 'Discount Associate Id' ;
    rdfs:comment 'Reference to the user (manager or supervisor) who approved the discount application. Null if auto-applied or pending approval.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:discountCashierAssociateId rdf:type rdf:Property ;
    rdfs:label 'Discount Cashier Associate Id' ;
    rdfs:comment 'Reference to the cashier or sales associate who applied the discount at the Point of Sale (POS). Null for online or automated discount applications.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:posTerminalId rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Id' ;
    rdfs:comment 'The identifier of the Point of Sale (POS) terminal or register where the discount was applied. Null for online channels.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosTerminal .

ind:appliedAtLevel rdf:type rdf:Property ;
    rdfs:label 'Applied At Level' ;
    rdfs:comment 'Indicates whether the discount was applied at the order header level (affecting the entire order) or at the line item level (affecting a specific product).' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Applied Timestamp' ;
    rdfs:comment 'The date and time when the discount was applied to the order or line item. Represents the business event time of discount application.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discountCode rdf:type rdf:Property ;
    rdfs:label 'Discount Code' ;
    rdfs:comment 'The promotional code, coupon code, or discount identifier entered or applied by the customer or system. Examples include promo codes, loyalty reward codes, employee discount codes.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountMethod rdf:type rdf:Property ;
    rdfs:label 'Discount Method' ;
    rdfs:comment 'The calculation method used to determine the discount value. Indicates whether the discount is a percentage off, fixed dollar amount, tiered based on quantity or spend, Buy One Get One (BOGO) offer, or free shipping.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalPrice rdf:type rdf:Property ;
    rdfs:label 'Final Price' ;
    rdfs:comment 'The final price after the discount has been applied. Represents the net amount the customer pays for the discounted item or order.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentage rdf:type rdf:Property ;
    rdfs:label 'Percentage' ;
    rdfs:comment 'The percentage discount applied to the order or line item. Populated when discount_method is percentage. Expressed as a decimal (e.g., 15.00 for 15% off).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemDiscountCode rdf:type rdf:Property ;
    rdfs:label 'Source System Discount Code' ;
    rdfs:comment 'The unique identifier for this discount record in the source system. Used for traceability and reconciliation with upstream systems.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackableFlag rdf:type rdf:Property ;
    rdfs:label 'Stackable Flag' ;
    rdfs:comment 'Indicates whether this discount can be combined (stacked) with other discounts on the same order or line item. True if stackable, False if exclusive.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxTreatmentFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment Flag' ;
    rdfs:comment 'Indicates whether the discount is applied before tax calculation (pre-tax) or after tax calculation (post-tax). Affects the taxable amount and final tax computation.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableAmountAdjustment rdf:type rdf:Property ;
    rdfs:label 'Taxable Amount Adjustment' ;
    rdfs:comment 'The adjustment to the taxable base amount resulting from this discount. Used to recalculate sales tax when discount affects the tax basis.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftCardId rdf:type rdf:Property ;
    rdfs:label 'Gift Card Id' ;
    rdfs:comment 'Unique identifier for the gift card record. Primary key.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GiftCard .

ind:primaryGiftProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Gift Profile Id' ;
    rdfs:comment 'Identifier of the customer who purchased the gift card. May differ from the recipient. Nullable if purchased anonymously or by guest.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:replacementForCardGiftCardId rdf:type rdf:Property ;
    rdfs:label 'Replacement For Card Gift Card Id' ;
    rdfs:comment 'Identifier of the original gift card that this card replaces (e.g., lost or damaged card replacement). Nullable for original issuances. Balance is typically transferred from original card.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GiftCard .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'Barcode value encoded on physical gift cards for scanning at Point of Sale (POS). May be UPC (Universal Product Code), EAN (European Article Number), or proprietary format.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardNumber rdf:type rdf:Property ;
    rdfs:label 'Card Number' ;
    rdfs:comment 'Unique card number printed or encoded on the gift card. Typically 16-19 digits. Used for identification and redemption at Point of Sale (POS) or e-commerce checkout.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardStatus rdf:type rdf:Property ;
    rdfs:label 'Card Status' ;
    rdfs:comment 'Current lifecycle status of the gift card. Inactive: issued but not yet activated; Active: available for use; Suspended: temporarily blocked; Expired: past validity period; Depleted: balance fully redeemed; Cancelled: voided or returned.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardType rdf:type rdf:Property ;
    rdfs:label 'Card Type' ;
    rdfs:comment 'Type of gift card instrument. Physical cards are tangible plastic cards; digital/virtual cards are delivered electronically via email or app; mobile wallet cards are provisioned into digital wallets (Apple Pay, Google Pay).' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escheatmentDate rdf:type rdf:Property ;
    rdfs:label 'Escheatment Date' ;
    rdfs:comment 'Date when the gift card balance was escheated (transferred) to state unclaimed property authority. Nullable if not yet escheated.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escheatmentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Escheatment Eligible Flag' ;
    rdfs:comment 'Indicates whether the gift card balance is eligible for escheatment (transfer to state unclaimed property) based on dormancy period and state regulations. True: eligible; False: not eligible.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudReasonCode rdf:type rdf:Property ;
    rdfs:label 'Fraud Reason Code' ;
    rdfs:comment 'Code indicating the reason for fraud flag (e.g., STOLEN, COUNTERFEIT, BALANCE_TAMPERING, SUSPICIOUS_ACTIVITY). Nullable if fraud_flag is false.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialBalance rdf:type rdf:Property ;
    rdfs:label 'Initial Balance' ;
    rdfs:comment 'Original monetary value loaded onto the gift card at the time of issuance or purchase. Represents the starting balance before any redemptions or adjustments.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuingChannel rdf:type rdf:Property ;
    rdfs:label 'Issuing Channel' ;
    rdfs:comment 'Sales channel through which the gift card was originally issued or purchased. Store: in-store POS; Ecommerce: online storefront; Mobile App: mobile commerce; Call Center: phone order; Corporate Sales: bulk B2B sales; Third Party: external marketplace or partner.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinCode rdf:type rdf:Property ;
    rdfs:label 'Pin Code' ;
    rdfs:comment 'Personal Identification Number (PIN) required for online redemption or balance inquiry. Typically 4-8 digits. Stored encrypted in production systems.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qrCode rdf:type rdf:Property ;
    rdfs:label 'Qr Code' ;
    rdfs:comment 'Quick Response (QR) code data for mobile wallet provisioning or contactless redemption. Encoded with card number and validation data.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientEmail rdf:type rdf:Property ;
    rdfs:label 'Recipient Email' ;
    rdfs:comment 'Email address of the gift card recipient. Used for digital card delivery and balance notifications. Required for digital/virtual cards.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reloadCount rdf:type rdf:Property ;
    rdfs:label 'Reload Count' ;
    rdfs:comment 'Total number of times the gift card has been reloaded with additional funds since issuance. Zero for non-reloadable or never-reloaded cards.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reloadableFlag rdf:type rdf:Property ;
    rdfs:label 'Reloadable Flag' ;
    rdfs:comment 'Indicates whether the gift card can be reloaded with additional funds after initial issuance. True: reloadable; False: single-load only.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsAndConditionsVersion rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Version' ;
    rdfs:comment 'Version identifier of the terms and conditions that govern this gift card (e.g., expiration policy, fee schedule, usage restrictions). Used for compliance and customer service.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFeesCharged rdf:type rdf:Property ;
    rdfs:label 'Total Fees Charged' ;
    rdfs:comment 'Cumulative fees deducted from the gift card balance (e.g., dormancy fees, maintenance fees, replacement fees). Subject to regulatory restrictions (e.g., CARD Act limits dormancy fees).' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRedeemedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Redeemed Amount' ;
    rdfs:comment 'Cumulative monetary value redeemed from the gift card across all transactions since activation. Equals initial_balance + total_reloaded_amount - current_balance - total_fees.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReloadedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Reloaded Amount' ;
    rdfs:comment 'Cumulative monetary value added to the gift card through all reload transactions since issuance. Excludes initial balance.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftCardTransactionId rdf:type rdf:Property ;
    rdfs:label 'Gift Card Transaction Id' ;
    rdfs:comment 'Unique identifier for the gift card transaction record.' ;
    rdfs:domain ind:GiftCardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalTransactionGiftCardTransactionId rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Gift Card Transaction Id' ;
    rdfs:comment 'Reference to the original gift card transaction that is being reversed or refunded.' ;
    rdfs:domain ind:GiftCardTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GiftCardTransaction .

ind:activationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Activation Fee Amount' ;
    rdfs:comment 'Fee charged to the customer for activating or loading the gift card, if applicable.' ;
    rdfs:domain ind:GiftCardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceAfter rdf:type rdf:Property ;
    rdfs:label 'Balance After' ;
    rdfs:comment 'Gift card balance immediately after this transaction was applied.' ;
    rdfs:domain ind:GiftCardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceBefore rdf:type rdf:Property ;
    rdfs:label 'Balance Before' ;
    rdfs:comment 'Gift card balance immediately before this transaction was applied.' ;
    rdfs:domain ind:GiftCardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessDate rdf:type rdf:Property ;
    rdfs:label 'Business Date' ;
    rdfs:comment 'Fiscal business date on which the transaction is recorded for accounting and reporting purposes.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escheatmentFlag rdf:type rdf:Property ;
    rdfs:label 'Escheatment Flag' ;
    rdfs:comment 'Indicates whether this transaction represents an escheatment event where unclaimed gift card funds are transferred to state authorities.' ;
    rdfs:domain ind:GiftCardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escheatmentJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Escheatment Jurisdiction' ;
    rdfs:comment 'State or jurisdiction to which unclaimed gift card funds were escheated, if applicable.' ;
    rdfs:domain ind:GiftCardTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudDecision rdf:type rdf:Property ;
    rdfs:label 'Fraud Decision' ;
    rdfs:comment 'Fraud system decision for this transaction (approved, declined, manual review required, customer challenge required).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Processor Reference Code' ;
    rdfs:comment 'Unique transaction identifier assigned by the third-party gift card processor or payment gateway.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Source System Transaction Code' ;
    rdfs:comment 'Unique transaction identifier in the source operational system for traceability and reconciliation.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcePurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Source Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to supplychain.purchase_order. Business justification: Retail drop-ship orders where vendor ships directly to customer require tracking the source supplier PO for cost reconciliation, vendor chargeback processing, and fulfillment exception handling. Essen' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'First line of the billing address associated with the payment method.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Second line of the billing address for apartment, suite, or unit number.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City or municipality for the billing address.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State, province, or region for the billing address.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grandTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Grand Total Amount' ;
    rdfs:comment 'Final order total including subtotal, tax, shipping, minus discounts. Amount charged to customer payment method.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locale rdf:type rdf:Property ;
    rdfs:label 'Locale' ;
    rdfs:comment 'Language and regional locale for the order (e.g., en_US, fr_CA). Used for localized content and formatting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omsReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Oms Reference Code' ;
    rdfs:comment 'External reference identifier from the Order Management System for end-to-end order orchestration and tracking.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Customer-requested target delivery date. Used for scheduling and SLA tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line1' ;
    rdfs:comment 'First line of the shipping address including street number and name. Primary delivery location identifier.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line2' ;
    rdfs:comment 'Second line of the shipping address for apartment, suite, or unit number. Optional address detail.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCity rdf:type rdf:Property ;
    rdfs:label 'Shipping City' ;
    rdfs:comment 'City or municipality for the shipping address.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the shipping address (e.g., USA, CAN, GBR).' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the shipping address. Critical for carrier routing and delivery zone determination.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Shipping State Province' ;
    rdfs:comment 'State, province, or region for the shipping address. Used for tax jurisdiction and carrier routing.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdId rdf:type rdf:Property ;
    rdfs:label 'Hold Id' ;
    rdfs:comment 'Unique identifier for the order hold record. Primary key.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryReservationId rdf:type rdf:Property ;
    rdfs:label 'Inventory Reservation Id' ;
    rdfs:comment 'Reference to the inventory reservation record associated with this hold, particularly for Buy Online Pick Up In Store (BOPIS) or Reserve Online Pick Up In Store (ROPIS) orders.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Reservation .

ind:pickupLocationId rdf:type rdf:Property ;
    rdfs:label 'Pickup Location Id' ;
    rdfs:comment 'Reference to the store or fulfillment node where the customer will pick up the order for Buy Online Pick Up In Store (BOPIS) or Reserve Online Pick Up In Store (ROPIS) holds.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:addressVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Address Verification Status' ;
    rdfs:comment 'Result of the address verification process indicating whether the shipping address passed validation checks. Relevant for address verification failure holds.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedToTeamCode rdf:type rdf:Property ;
    rdfs:label 'Assigned To Team Code' ;
    rdfs:comment 'Code identifying the team or department responsible for resolving this hold (e.g., fraud team, payment operations, customer service).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoReleaseEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Release Eligible Flag' ;
    rdfs:comment 'Indicates whether the hold is eligible for automatic release by system rules without manual intervention.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Auto Release Timestamp' ;
    rdfs:comment 'Scheduled date and time when the system will automatically release the hold if no manual action is taken. Nullable if auto-release is not configured.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerNotificationChannel rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Channel' ;
    rdfs:comment 'The communication channel used to notify the customer about the hold status (email, SMS, push notification, phone call, or in-app message).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Calculated duration of the hold in minutes from start to end timestamp. Used for performance analysis and SLA compliance reporting.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedResolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expected Resolution Timestamp' ;
    rdfs:comment 'Anticipated date and time when the hold is expected to be resolved based on business rules and Service Level Agreement (SLA) targets.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdNumber rdf:type rdf:Property ;
    rdfs:label 'Hold Number' ;
    rdfs:comment 'Business-readable unique identifier for the hold, used for tracking and customer service reference.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle status of the hold indicating whether it is active, resolved, expired, cancelled, or escalated for further review.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Classification of the hold indicating the reason category for the suspension. Includes fraud review, payment issues, pickup reservations (BOPIS/ROPIS), and compliance holds. [ENUM-REF-CANDIDATE: fraud_review|payment_authorization_failure|address_verification_failure|inventory_reservation|bopis_pickup_reservation|ropis_pickup_reservation|credit_limit_exceeded|compliance_review — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manualReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Manual Review Required Flag' ;
    rdfs:comment 'Indicates whether the hold requires manual review and approval by a customer service agent or fraud analyst before release.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentAuthorizationCode rdf:type rdf:Property ;
    rdfs:label 'Payment Authorization Code' ;
    rdfs:comment 'Authorization code from the payment processor associated with this hold. Relevant for payment authorization failure holds.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProcessorResponse rdf:type rdf:Property ;
    rdfs:label 'Payment Processor Response' ;
    rdfs:comment 'Response message or code returned by the payment processor explaining the reason for payment authorization failure.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupExpirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pickup Expiration Timestamp' ;
    rdfs:comment 'Date and time after which the pickup reservation expires and the order may be cancelled or returned to inventory if not collected.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickupReadyTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pickup Ready Timestamp' ;
    rdfs:comment 'Date and time when the order is ready for customer pickup at the designated location. Relevant for Buy Online Pick Up In Store (BOPIS) and Reserve Online Pick Up In Store (ROPIS) holds.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaTargetTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Target Timestamp' ;
    rdfs:comment 'The deadline by which the hold must be resolved to meet Service Level Agreement (SLA) commitments to the customer.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystemHoldCode rdf:type rdf:Property ;
    rdfs:label 'Source System Hold Code' ;
    rdfs:comment 'The unique identifier for this hold in the originating source system, used for cross-system reconciliation and traceability.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backorderFlag rdf:type rdf:Property ;
    rdfs:label 'Backorder Flag' ;
    rdfs:comment 'Indicates whether this line item is on backorder due to insufficient inventory at order time. True if the item will be shipped when inventory becomes available.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costOfGoodsSold rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods Sold' ;
    rdfs:comment 'Unit cost of the product at the time of order fulfillment. Used for margin analysis and profitability reporting. Business-confidential financial data.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedShipDate rdf:type rdf:Property ;
    rdfs:label 'Expected Ship Date' ;
    rdfs:comment 'Planned date when this line item is expected to ship from the fulfillment node. Used for customer communication and Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extendedPrice rdf:type rdf:Property ;
    rdfs:label 'Extended Price' ;
    rdfs:comment 'Total price for this line item before discounts and taxes. Calculated as ordered_quantity multiplied by unit_retail_price.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Flag' ;
    rdfs:comment 'Indicates whether this line item is marked as a gift. True if the customer designated this item for gift wrapping, gift messaging, or special handling.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marginAmount rdf:type rdf:Property ;
    rdfs:label 'Margin Amount' ;
    rdfs:comment 'Gross margin for this line item calculated as line_total minus cost_of_goods_sold. Key metric for profitability analysis and Gross Margin Return on Investment (GMROI) calculations.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:personalizationNotes rdf:type rdf:Property ;
    rdfs:label 'Personalization Notes' ;
    rdfs:comment 'Special instructions for product personalization such as monogramming, engraving, or custom text. Captured at order time and passed to fulfillment operations.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized code indicating why this line was returned by the customer. Populated when returned_quantity is greater than zero. Supports Return Merchandise Authorization (RMA) processing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnedQuantity rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity' ;
    rdfs:comment 'Quantity returned by the customer after delivery. Supports partial returns and links to Return Merchandise Authorization (RMA) processing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Quantity' ;
    rdfs:comment 'Actual quantity shipped to the customer. May differ from ordered_quantity due to partial fulfillment, substitutions, or inventory constraints.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:total rdf:type rdf:Property ;
    rdfs:label 'Total' ;
    rdfs:comment 'Final total amount for this line item after discounts and taxes. Calculated as extended_price minus discount_amount plus tax_amount.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Line Status History Id' ;
    rdfs:comment 'Unique identifier for each status transition event in the order line lifecycle. Primary key for the status history log.' ;
    rdfs:domain ind:LineStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLineAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Line Associate Id' ;
    rdfs:comment 'Identifier of the warehouse associate who picked this line. Populated when status transitions to picked. Enables picker productivity and accuracy analysis.' ;
    rdfs:domain ind:LineStatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:tertiaryLineUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Line User Associate Id' ;
    rdfs:comment 'Identifier of the user (customer service rep, warehouse manager, system admin) who manually triggered this status change, if applicable. Null for automated system transitions.' ;
    rdfs:domain ind:LineStatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:transactionId rdf:type rdf:Property ;
    rdfs:label 'Transaction Id' ;
    rdfs:comment 'The unique transaction or message identifier from the source system that triggered this status change. Enables end-to-end traceability and troubleshooting.' ;
    rdfs:domain ind:LineStatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosTransaction .

ind:carrierServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Level' ;
    rdfs:comment 'The shipping service level selected for this line (e.g., standard ground, 2-day air, overnight). Impacts delivery SLA and cost.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentStatus rdf:type rdf:Property ;
    rdfs:label 'Current Status' ;
    rdfs:comment 'The new status that the order line transitioned TO at this event. Represents the current state of the line after this transition. [ENUM-REF-CANDIDATE: pending|confirmed|allocated|picked|packed|shipped|in_transit|out_for_delivery|delivered|cancelled|returned|refunded — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LineStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCategory rdf:type rdf:Property ;
    rdfs:label 'Exception Category' ;
    rdfs:comment 'High-level categorization of the exception type when exception_flag is True. Enables aggregated exception reporting and trend analysis. [ENUM-REF-CANDIDATE: inventory_shortage|customer_cancellation|quality_issue|carrier_delay|address_issue|payment_failure|system_error — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Indicates whether this status transition represents an exception or deviation from normal fulfillment flow (e.g., cancellation, return, inventory shortage). True if exception, False if normal progression.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fulfillmentNodeType rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Node Type' ;
    rdfs:comment 'The type of fulfillment location handling this line. Enables analysis of fulfillment performance by node type (e.g., ship-from-store vs DC).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Line Sequence Number' ;
    rdfs:comment 'The line item number within the parent order (e.g., line 1, line 2). Denormalized for quick identification without joining to order_line.' ;
    rdfs:domain ind:LineStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The status that the order line transitioned FROM. Enables reconstruction of the full status flow and identification of status reversals or exceptions. [ENUM-REF-CANDIDATE: pending|confirmed|allocated|picked|packed|shipped|in_transit|out_for_delivery|delivered|cancelled|returned|refunded — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LineStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'The timestamp when this status history record was last modified in the data platform. Supports change data capture and data quality auditing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:statusReasonCode rdf:type rdf:Property ;
    rdfs:label 'Status Reason Code' ;
    rdfs:comment 'Standardized code explaining WHY the status transition occurred (e.g., CUST_CANCEL, INV_SHORTAGE, CARRIER_DELAY, QUALITY_ISSUE). Critical for root-cause analysis of fulfillment exceptions.' ;
    rdfs:domain ind:LineStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Status Reason Description' ;
    rdfs:comment 'Human-readable explanation of the status transition reason. Provides additional context beyond the reason code for customer service and operations teams.' ;
    rdfs:domain ind:LineStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusTransitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Status Transition Timestamp' ;
    rdfs:comment 'The precise date and time when the order line transitioned to the current status. Business event timestamp for SLA measurement and fulfillment analytics.' ;
    rdfs:domain ind:LineStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:systemSource rdf:type rdf:Property ;
    rdfs:label 'System Source' ;
    rdfs:comment 'The source system that generated this status transition event (e.g., OMS, WMS, TMS, carrier API). Enables data lineage tracking and system integration monitoring. [ENUM-REF-CANDIDATE: oms|wms|tms|pos|ecommerce|customer_service|carrier_api|manual — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LineStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promiseId rdf:type rdf:Property ;
    rdfs:label 'Promise Id' ;
    rdfs:comment 'Unique identifier for the order promise record. Primary key.' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accuracyFlag rdf:type rdf:Property ;
    rdfs:label 'Accuracy Flag' ;
    rdfs:comment 'Indicates whether the delivery was completed within the promised window (true = on-time, false = missed).' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculationEngineVersion rdf:type rdf:Property ;
    rdfs:label 'Calculation Engine Version' ;
    rdfs:comment 'Version identifier of the promise calculation engine or algorithm used.' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationSource rdf:type rdf:Property ;
    rdfs:label 'Calculation Source' ;
    rdfs:comment 'System or method used to calculate the delivery promise (carrier API, static SLA table, DOM engine, manual override).' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutoffTimeApplied rdf:type rdf:Property ;
    rdfs:label 'Cutoff Time Applied' ;
    rdfs:comment 'Order cutoff time applied for same-day or next-day promise calculation (e.g., 2:00 PM local time).' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryAvailabilityTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inventory Availability Timestamp' ;
    rdfs:comment 'Timestamp when inventory availability was confirmed for promise calculation.' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastRevisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Revision Timestamp' ;
    rdfs:comment 'Timestamp of the most recent revision to the delivery promise.' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:peakSeasonFlag rdf:type rdf:Property ;
    rdfs:label 'Peak Season Flag' ;
    rdfs:comment 'Indicates whether the promise was made during a peak season (e.g., holiday shopping period) affecting delivery times.' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promiseNumber rdf:type rdf:Property ;
    rdfs:label 'Promise Number' ;
    rdfs:comment 'Business-readable identifier for the delivery promise, used for customer communication and tracking.' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promiseStatus rdf:type rdf:Property ;
    rdfs:label 'Promise Status' ;
    rdfs:comment 'Current lifecycle status of the delivery promise.' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promiseType rdf:type rdf:Property ;
    rdfs:label 'Promise Type' ;
    rdfs:comment 'Type of delivery promise made to the customer at checkout or order confirmation.' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedDeliveryDateEnd rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date End' ;
    rdfs:comment 'End date of the promised delivery window communicated to the customer.' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promisedDeliveryDateStart rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date Start' ;
    rdfs:comment 'Start date of the promised delivery window communicated to the customer.' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promisedDeliveryTimeEnd rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Time End' ;
    rdfs:comment 'Precise end timestamp of the promised delivery window for time-specific promises.' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:promisedDeliveryTimeStart rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Time Start' ;
    rdfs:comment 'Precise start timestamp of the promised delivery window for time-specific promises.' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revisionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Revision Reason Code' ;
    rdfs:comment 'Code indicating the reason for promise revision (e.g., inventory delay, carrier delay, weather).' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Revision Reason Description' ;
    rdfs:comment 'Detailed description of why the delivery promise was revised.' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAddressCountryCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the delivery destination.' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAddressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Postal Code' ;
    rdfs:comment 'Postal code of the delivery destination, used for promise calculation and carrier routing.' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceHours rdf:type rdf:Property ;
    rdfs:label 'Variance Hours' ;
    rdfs:comment 'Difference in hours between actual delivery and promised delivery (positive = late, negative = early).' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatherImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Weather Impact Flag' ;
    rdfs:comment 'Indicates whether weather conditions were factored into the promise calculation or caused a delay.' ;
    rdfs:domain ind:Promise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Status History Id' ;
    rdfs:comment 'Unique identifier for each status transition record in the order lifecycle. Primary key for the immutable audit trail.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryStatusAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Status Associate Id' ;
    rdfs:comment 'Identifier of the user or service account that triggered the status change. Null for automated system transitions. Supports audit and accountability requirements.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:createdByProcess rdf:type rdf:Property ;
    rdfs:label 'Created By Process' ;
    rdfs:comment 'Identifier of the ETL job, API call, or data ingestion process that created this record in the lakehouse. Supports data lineage and troubleshooting.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationInPreviousStatusMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration In Previous Status Minutes' ;
    rdfs:comment 'The number of minutes the order spent in the previous status before this transition. Enables stage-level performance analysis.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousStatusCode rdf:type rdf:Property ;
    rdfs:label 'Previous Status Code' ;
    rdfs:comment 'The status that the order was in immediately before this transition. Enables tracking of status flow and identifying invalid state transitions. [ENUM-REF-CANDIDATE: CREATED|CONFIRMED|ALLOCATED|PICKED|PACKED|SHIPPED|IN_TRANSIT|OUT_FOR_DELIVERY|DELIVERED|CANCELLED|RETURNED|REFUNDED|FAILED|ON_HOLD|BACKORDERED — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Resolution Required Flag' ;
    rdfs:comment 'Indicator of whether this status transition requires manual resolution or intervention. True for exceptions that cannot be auto-resolved.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaBreachDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Duration Minutes' ;
    rdfs:comment 'The number of minutes by which the SLA was breached. Null if no breach occurred. Enables quantitative analysis of service failures.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceOrderChannel rdf:type rdf:Property ;
    rdfs:label 'Source Order Channel' ;
    rdfs:comment 'The originating channel through which the order was placed. Denormalized for performance in channel-specific SLA analysis. [ENUM-REF-CANDIDATE: WEB|MOBILE_APP|STORE|CALL_CENTER|MARKETPLACE|SOCIAL|KIOSK — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusCode rdf:type rdf:Property ;
    rdfs:label 'Status Code' ;
    rdfs:comment 'The new status that the order transitioned to at this point in time. Represents the current state in the order fulfillment lifecycle. [ENUM-REF-CANDIDATE: CREATED|CONFIRMED|ALLOCATED|PICKED|PACKED|SHIPPED|IN_TRANSIT|OUT_FOR_DELIVERY|DELIVERED|CANCELLED|RETURNED|REFUNDED|FAILED|ON_HOLD|BACKORDERED — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Code' ;
    rdfs:comment 'Standardized code explaining why the status transition occurred. Enables root cause analysis for exceptions and delays. [ENUM-REF-CANDIDATE: CUSTOMER_REQUEST|INVENTORY_UNAVAILABLE|PAYMENT_FAILED|ADDRESS_INVALID|CARRIER_DELAY|SYSTEM_ERROR|FRAUD_DETECTED|QUALITY_ISSUE|DAMAGED_IN_TRANSIT|CUSTOMER_REFUSED|BUSINESS_RULE|MANUAL_OVERRIDE|AUTOMATED_PROCESS — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Description' ;
    rdfs:comment 'Free-text explanation providing additional context for the status transition. Captures details not covered by the standardized reason code.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Timestamp' ;
    rdfs:comment 'The exact date and time when the order status changed to the new status. Critical for SLA (Service Level Agreement) tracking and customer-facing order tracking.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:triggeringSystemCode rdf:type rdf:Property ;
    rdfs:label 'Triggering System Code' ;
    rdfs:comment 'Identifier of the system or application that initiated this status transition. Enables system-level performance analysis and troubleshooting. [ENUM-REF-CANDIDATE: OMS|WMS|TMS|POS|ECOM|CARRIER_API|PAYMENT_GATEWAY|FRAUD_ENGINE|CSR_PORTAL|BATCH_JOB|EDI|MOBILE_APP — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringUserName rdf:type rdf:Property ;
    rdfs:label 'Triggering User Name' ;
    rdfs:comment 'Display name of the user who triggered the status change. Provides human-readable context for manual interventions.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Unique identifier for the payment tender record. Primary key.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bnplInstallmentPlanId rdf:type rdf:Property ;
    rdfs:label 'Bnpl Installment Plan Id' ;
    rdfs:comment 'Unique identifier for the BNPL installment plan associated with this payment. Used for tracking payment schedules and reconciliation with BNPL provider.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:digitalWalletType rdf:type rdf:Property ;
    rdfs:label 'Digital Wallet Type' ;
    rdfs:comment 'Type of digital wallet used for this payment tender (e.g., Apple Pay, Google Pay, Samsung Pay, PayPal, Venmo). Applicable only when payment method type is digital wallet.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maskedPan rdf:type rdf:Property ;
    rdfs:label 'Masked Pan' ;
    rdfs:comment 'Masked or truncated version of the payment card Primary Account Number (PAN), typically showing only the last four digits (e.g., ****1234). Used for display and customer service without exposing full card number.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodType rdf:type rdf:Property ;
    rdfs:label 'Method Type' ;
    rdfs:comment 'Type of payment instrument used for this tender. Includes credit card, debit card, gift card, loyalty points, BNPL (Buy Now Pay Later), cash, digital wallet (e.g., Apple Pay, Google Pay), or check. [ENUM-REF-CANDIDATE: credit_card|debit_card|gift_card|loyalty_points|bnpl|cash|digital_wallet|check — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Settlement Timestamp' ;
    rdfs:comment 'Date and time when the payment was settled and funds were transferred from the customer\'s account to the merchant\'s account. Final step in payment lifecycle.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tenderSequence rdf:type rdf:Property ;
    rdfs:label 'Tender Sequence' ;
    rdfs:comment 'Sequence number indicating the order in which this payment tender was applied in a split-tender scenario. First tender is 1, second is 2, etc.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:threeDsAuthenticationResult rdf:type rdf:Property ;
    rdfs:label 'Three Ds Authentication Result' ;
    rdfs:comment 'Result of 3-D Secure (3DS) authentication protocol for card-not-present transactions. Indicates whether cardholder was successfully authenticated, reducing fraud liability.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidTimestamp rdf:type rdf:Property ;
    rdfs:label 'Void Timestamp' ;
    rdfs:comment 'Date and time when the payment authorization was voided (cancelled before capture). Applicable when order is cancelled before fulfillment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalTransactionPosTransactionId rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Pos Transaction Id' ;
    rdfs:comment 'Reference to the original POS transaction being returned or exchanged when transaction_type is return or exchange.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosTransaction .

ind:primaryPosAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Pos Associate Id' ;
    rdfs:comment 'Identifier of the store associate or cashier who processed the transaction.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:storeLocationId rdf:type rdf:Property ;
    rdfs:label 'Store Location Id' ;
    rdfs:comment 'FK to store.store_location.store_location_id — POS transaction to store location is required for all store-level sales reporting, comparable sales calculations, and store P&L. Every retail operational report needs this join.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:changeAmount rdf:type rdf:Property ;
    rdfs:label 'Change Amount' ;
    rdfs:comment 'Cash change returned to the customer when tender_amount exceeds total_amount.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:couponCount rdf:type rdf:Property ;
    rdfs:label 'Coupon Count' ;
    rdfs:comment 'Number of coupons redeemed in the transaction including manufacturer coupons and store coupons.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Fiscal Receipt Number' ;
    rdfs:comment 'Government-mandated fiscal receipt identifier for tax compliance and audit purposes. Required in jurisdictions with fiscal receipt regulations.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyCardNumber rdf:type rdf:Property ;
    rdfs:label 'Loyalty Card Number' ;
    rdfs:comment 'Loyalty program card number scanned during the transaction for points accrual and customer identification.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Manager Override Flag' ;
    rdfs:comment 'Indicates whether a manager override was required during the transaction for actions such as large discounts, voids, or policy exceptions.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentMethodCount rdf:type rdf:Property ;
    rdfs:label 'Payment Method Count' ;
    rdfs:comment 'Number of distinct payment methods used in the transaction. Supports split-tender analysis.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Method' ;
    rdfs:comment 'Primary payment instrument used for the transaction. For split-tender transactions, this is the method with the largest payment amount. [ENUM-REF-CANDIDATE: cash|credit_card|debit_card|gift_card|mobile_payment|check|store_credit — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionCount rdf:type rdf:Property ;
    rdfs:label 'Promotion Count' ;
    rdfs:comment 'Number of distinct promotions applied to the transaction. Used for promotional effectiveness analysis.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receiptEmail rdf:type rdf:Property ;
    rdfs:label 'Receipt Email' ;
    rdfs:comment 'Email address provided by the customer for digital receipt delivery.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptPhone rdf:type rdf:Property ;
    rdfs:label 'Receipt Phone' ;
    rdfs:comment 'Phone number provided by the customer for SMS receipt delivery or order pickup notifications.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registerNumber rdf:type rdf:Property ;
    rdfs:label 'Register Number' ;
    rdfs:comment 'Physical register or checkout lane number within the store where the transaction was processed.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderAmount rdf:type rdf:Property ;
    rdfs:label 'Tender Amount' ;
    rdfs:comment 'Total amount tendered by the customer across all payment methods. May exceed total_amount when cash change is given.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingModeFlag rdf:type rdf:Property ;
    rdfs:label 'Training Mode Flag' ;
    rdfs:comment 'Indicates whether the transaction was processed in training mode for new cashier onboarding. Training transactions are excluded from financial reporting.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:voidReasonCode rdf:type rdf:Property ;
    rdfs:label 'Void Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for voiding the transaction when transaction_status is voided. Used for fraud detection and operational quality monitoring.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posTransactionLineId rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Line Id' ;
    rdfs:comment 'Unique identifier for the individual line item within a POS transaction. Primary key for the transaction line detail record.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Human-readable description of the product as it appears on the receipt. Includes brand, product name, size, and variant details.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netLineAmount rdf:type rdf:Property ;
    rdfs:label 'Net Line Amount' ;
    rdfs:comment 'Net amount for this line item after markdown but before tax. Calculated as extended price minus markdown amount.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantitySold rdf:type rdf:Property ;
    rdfs:label 'Quantity Sold' ;
    rdfs:comment 'Number of units sold for this line item. Supports fractional quantities for variable-weight items such as produce and deli products.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnFlag rdf:type rdf:Property ;
    rdfs:label 'Return Flag' ;
    rdfs:comment 'Indicates whether this line item represents a product return. True for returned items, false for normal sales.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scannedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scanned Timestamp' ;
    rdfs:comment 'Date and time when this item was scanned or entered at the point of sale. Used for transaction timing analysis and basket sequence.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalLineAmount rdf:type rdf:Property ;
    rdfs:label 'Total Line Amount' ;
    rdfs:comment 'Final total amount for this line item including tax. Sum of net line amount and tax amount.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidedFlag rdf:type rdf:Property ;
    rdfs:label 'Voided Flag' ;
    rdfs:comment 'Indicates whether this line item was voided or cancelled during the transaction. True for voided items, false for completed sales.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightActual rdf:type rdf:Property ;
    rdfs:label 'Weight Actual' ;
    rdfs:comment 'Actual weight of variable-weight items measured at point of sale. Captured for produce, deli, meat, and bakery items sold by weight.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subscriptionId rdf:type rdf:Property ;
    rdfs:label 'Subscription Id' ;
    rdfs:comment 'Unique identifier for the subscription record. Primary key for the subscription entity.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Revenue Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Subscription revenue recognition requires GL account assignment for deferred revenue, recognized revenue, and ASC 606 compliance. Role-prefixed to distinguish from potential expense or liability GL ac' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the subscription automatically renews at the end of its term. True for auto-renewing subscriptions, false for subscriptions that require manual renewal.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'Frequency at which the customer is charged for the subscription: per_delivery for charges with each order, monthly for monthly billing regardless of delivery frequency, quarterly for every 3 months, annual for yearly billing, or upfront for prepaid subscriptions.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date when the subscription was cancelled by the customer or system. Null for active subscriptions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Description' ;
    rdfs:comment 'Free-text explanation of the subscription cancellation reason, providing additional context beyond the standardized code.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFrequency rdf:type rdf:Property ;
    rdfs:label 'Delivery Frequency' ;
    rdfs:comment 'Cadence at which subscription orders are automatically generated and fulfilled: weekly for every 7 days, biweekly for every 14 days, monthly for every 30 days, quarterly for every 90 days, or custom for non-standard intervals.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Frequency Days' ;
    rdfs:comment 'Numeric representation of the delivery interval in days. Used for custom frequencies and precise scheduling calculations.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalSubscriptionCode rdf:type rdf:Property ;
    rdfs:label 'External Subscription Code' ;
    rdfs:comment 'Subscription identifier from the source system or external platform, used for cross-system reconciliation and integration.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftSubscriptionFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Subscription Flag' ;
    rdfs:comment 'Indicates whether this subscription was purchased as a gift for another person. True for gift subscriptions, false for self-purchased subscriptions.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Last Delivery Date' ;
    rdfs:comment 'Date when the most recent subscription order was delivered to the customer. Null if no deliveries have occurred yet.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Next Delivery Date' ;
    rdfs:comment 'Date when the next subscription order is scheduled to be fulfilled and shipped to the customer.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pauseEndDate rdf:type rdf:Property ;
    rdfs:label 'Pause End Date' ;
    rdfs:comment 'Date when a paused subscription is scheduled to resume. Null for indefinite pauses or active subscriptions.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pauseStartDate rdf:type rdf:Property ;
    rdfs:label 'Pause Start Date' ;
    rdfs:comment 'Date when the subscription was paused. Null if the subscription has never been paused or is currently active.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:skipNextDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Skip Next Delivery Flag' ;
    rdfs:comment 'Indicates whether the customer has requested to skip the next scheduled delivery. True when the upcoming order should be skipped, false for normal delivery processing.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subscriptionNumber rdf:type rdf:Property ;
    rdfs:label 'Subscription Number' ;
    rdfs:comment 'Human-readable business identifier for the subscription, used in customer communications and service interactions.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionType rdf:type rdf:Property ;
    rdfs:label 'Subscription Type' ;
    rdfs:comment 'Classification of the subscription model: subscribe-and-save for recurring product delivery, auto-replenishment for inventory-triggered orders, meal kit for prepared meal subscriptions, curated box for personalized selections, membership for access-based subscriptions, or service plan for ongoing service contracts.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDeliveriesCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Deliveries Completed' ;
    rdfs:comment 'Cumulative count of subscription orders that have been successfully delivered to the customer since subscription inception.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDeliveriesSkipped rdf:type rdf:Property ;
    rdfs:label 'Total Deliveries Skipped' ;
    rdfs:comment 'Cumulative count of scheduled deliveries that were skipped at the customer\'s request or due to system holds.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitivePriceId rdf:type rdf:Property ;
    rdfs:label 'Competitive Price Id' ;
    rdfs:comment 'Unique surrogate identifier for each competitive price observation record in the pricing domain. Primary key for the competitive_price data product.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitorChannel rdf:type rdf:Property ;
    rdfs:label 'Competitor Channel' ;
    rdfs:comment 'Sales channel through which the competitor price was observed. Distinguishes between in-store shelf prices, e-commerce website prices, mobile app prices, and third-party marketplace listings to support omnichannel competitive analysis.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorInStockFlag rdf:type rdf:Property ;
    rdfs:label 'Competitor In Stock Flag' ;
    rdfs:comment 'Indicates whether the competitor had the product in stock at the time of the price observation (True = in stock, False = out of stock). Out-of-stock competitor observations may reduce the urgency of a price response.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Name of the competing retailer or marketplace whose price was observed (e.g., Walmart, Target, Amazon). Used for competitive index tracking and Hi-Lo / EDLP strategy calibration.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorPackSize rdf:type rdf:Property ;
    rdfs:label 'Competitor Pack Size' ;
    rdfs:comment 'Numeric pack size or quantity of the competitor\'s product offering (e.g., 12 for a 12-pack, 1.5 for 1.5 liters). Combined with competitor_unit_of_measure to normalize prices to a common unit for accurate like-for-like competitive comparisons.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorProductName rdf:type rdf:Property ;
    rdfs:label 'Competitor Product Name' ;
    rdfs:comment 'Product name or description as listed by the competitor for the observed item. Used for like-for-like and comparable match validation, especially when GTIN-based exact matching is not available.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorPromoEndDate rdf:type rdf:Property ;
    rdfs:label 'Competitor Promo End Date' ;
    rdfs:comment 'Date on which the competitor\'s promotional price is expected to expire, if known. Enables time-sensitive pricing response planning and markdown optimization scheduling.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitorPromoFlag rdf:type rdf:Property ;
    rdfs:label 'Competitor Promo Flag' ;
    rdfs:comment 'Indicates whether the observed competitor price is a promotional or temporary price (True) rather than the regular everyday price (False). Critical for distinguishing Hi-Lo promotional pricing from EDLP baseline prices in competitive analysis.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitorPromoType rdf:type rdf:Property ;
    rdfs:label 'Competitor Promo Type' ;
    rdfs:comment 'Type of promotional pricing mechanism observed at the competitor when competitor_promo_flag is True. Includes Temporary Price Reduction (TPR), clearance markdown, loyalty card price, bundle deal, coupon redemption, or rollback. Supports Hi-Lo strategy calibration and promotional response planning. [ENUM-REF-CANDIDATE: tpr|clearance|loyalty_price|bundle|coupon|rollback — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorSkuCode rdf:type rdf:Property ;
    rdfs:label 'Competitor Sku Code' ;
    rdfs:comment 'The competitor\'s own SKU or item code for the observed product. Supports cross-reference mapping between own assortment and competitor assortment for comparable product matching.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Competitor Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the competitor\'s observed price (e.g., each, lb, kg, liter). Required for unit-price normalization when comparing products sold in different pack sizes or weights to ensure valid price-per-unit competitive comparisons. [ENUM-REF-CANDIDATE: each|lb|kg|oz|liter|ml|pack|case — promote to reference product if additional UOMs are needed]' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorUrl rdf:type rdf:Property ;
    rdfs:label 'Competitor Url' ;
    rdfs:comment 'Web URL of the competitor\'s product listing page where the price was observed for online channel observations. Provides a direct audit trail link to the source of the competitive price data for web scrape and third-party feed validations.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceVendor rdf:type rdf:Property ;
    rdfs:label 'Data Source Vendor' ;
    rdfs:comment 'Name of the third-party competitive intelligence provider or data feed vendor supplying the price observation (e.g., Profitero, Nielsen, Numerator, Wiser). Null for internally collected observations (manual survey, mystery shop).' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicMarket rdf:type rdf:Property ;
    rdfs:label 'Geographic Market' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country/market code where the competitive observation was made. Supports multi-market competitive intelligence aggregation and cross-border pricing strategy governance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Match Confidence Score' ;
    rdfs:comment 'Numeric score (0.00–100.00) representing the confidence level that the competitor product is a true comparable match to the retailer\'s own SKU. Derived from GTIN exact match, product attribute similarity, or algorithmic matching. Higher scores indicate stronger comparability for pricing decisions.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchType rdf:type rdf:Property ;
    rdfs:label 'Match Type' ;
    rdfs:comment 'Classification of how the competitor product was matched to the retailer\'s own SKU. Exact GTIN/UPC matches carry the highest confidence; like-for-like and comparable matches involve attribute-based similarity; private label equivalent matches compare store brand to national brand. Drives weighting in competitive index calculations.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:normalizedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Normalized Unit Price' ;
    rdfs:comment 'Competitor price normalized to a standard unit of measure (e.g., price per kg, price per liter) to enable valid cross-pack-size competitive comparisons. Computed from competitor_price, competitor_pack_size, and competitor_unit_of_measure. Essential for grocery and FMCG category competitive analysis.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:observationDate rdf:type rdf:Property ;
    rdfs:label 'Observation Date' ;
    rdfs:comment 'Calendar date on which the competitor price was observed or collected. The principal business event date for this record. Used for time-series competitive trend analysis and markdown optimization timing.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Observation Quality Flag' ;
    rdfs:comment 'Data quality assessment status for the competitive price observation. Verified observations have been validated against a secondary source; unverified are raw inputs; suspect observations have anomalies flagged for review; rejected observations are excluded from competitive index calculations.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Observation Timestamp' ;
    rdfs:comment 'Precise date and time at which the competitor price was captured, including timezone offset. Provides intraday granularity for dynamic pricing use cases and web-scrape frequency analysis. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:previousCompetitorPrice rdf:type rdf:Property ;
    rdfs:label 'Previous Competitor Price' ;
    rdfs:comment 'The competitor\'s price from the immediately preceding observation for the same SKU and competitor. Enables point-in-time price change detection and price gap trend calculation without requiring a self-join on historical records.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousObservationDate rdf:type rdf:Property ;
    rdfs:label 'Previous Observation Date' ;
    rdfs:comment 'Date of the immediately preceding competitive price observation for the same SKU and competitor. Used alongside previous_competitor_price to compute price gap trend direction and velocity.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceGap rdf:type rdf:Property ;
    rdfs:label 'Price Gap' ;
    rdfs:comment 'Absolute monetary difference between the retailer\'s own retail price and the competitor\'s observed price (own_retail_price minus competitor_price). A positive value indicates the retailer is priced higher; negative indicates the retailer is priced lower. Core metric for competitive index tracking and price war early warning.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceGapPct rdf:type rdf:Property ;
    rdfs:label 'Price Gap Pct' ;
    rdfs:comment 'Price gap expressed as a percentage of the retailer\'s own retail price ((own_retail_price - competitor_price) / own_retail_price * 100). Enables normalized cross-category competitive index tracking and Hi-Lo / EDLP strategy calibration independent of absolute price levels.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceGapTrend rdf:type rdf:Property ;
    rdfs:label 'Price Gap Trend' ;
    rdfs:comment 'Directional trend of the price gap compared to the previous observation for the same SKU and competitor. Indicates whether the competitive position is improving (narrowing), deteriorating (widening), stable, or has reversed polarity. Supports price war early warning detection.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceIndex rdf:type rdf:Property ;
    rdfs:label 'Price Index' ;
    rdfs:comment 'Ratio of the retailer\'s own retail price to the competitor\'s observed price (own_retail_price / competitor_price). A value above 1.0 indicates the retailer is priced higher than the competitor; below 1.0 indicates a price advantage. Core KPI for competitive pricing governance and EDLP positioning.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseAction rdf:type rdf:Property ;
    rdfs:label 'Response Action' ;
    rdfs:comment 'System-recommended or analyst-assigned pricing response action based on the competitive observation. Options include: match competitor price, undercut competitor price, hold current price, continue monitoring, or escalate to pricing manager. Feeds competitive pricing rules in Oracle Retail Price Management (RPM).' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseImplementedDate rdf:type rdf:Property ;
    rdfs:label 'Response Implemented Date' ;
    rdfs:comment 'Date on which the recommended pricing response action was implemented in the retailer\'s own pricing system. Used for measuring response latency and audit trail completeness.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Current workflow status of the recommended pricing response action. Tracks whether the response has been reviewed, approved, rejected, implemented in Oracle Retail Price Management (RPM), or has expired without action. Supports price change audit trail requirements.' ;
    rdfs:domain ind:CompetitivePrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costZoneId rdf:type rdf:Property ;
    rdfs:label 'Cost Zone Id' ;
    rdfs:comment 'Reference to the geographic or operational cost zone for which this cost applies. Cost zones allow differentiated landed costs by region, distribution center, or market.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostZone .

ind:baseCost rdf:type rdf:Property ;
    rdfs:label 'Base Cost' ;
    rdfs:comment 'The unit purchase cost of the SKU as invoiced by the supplier before any additional charges such as freight, duty, or handling. Represents the ex-works or FOB (Free on Board) cost. Core input for COGS (Cost of Goods Sold) and GMROI (Gross Margin Return on Investment) calculations.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costChangePct rdf:type rdf:Property ;
    rdfs:label 'Cost Change Pct' ;
    rdfs:comment 'The percentage change in total landed cost compared to the prior cost record for this SKU-supplier combination. Calculated as ((landed_cost - prior_landed_cost) / prior_landed_cost) * 100. Supports cost variance alerting, procurement performance KPIs, and margin impact analysis.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costChangeReason rdf:type rdf:Property ;
    rdfs:label 'Cost Change Reason' ;
    rdfs:comment 'Business reason code explaining why this cost record was created or why the cost changed from the prior record. Supports cost change audit trails, markdown optimization analysis, and procurement performance reporting. [ENUM-REF-CANDIDATE: new_item|supplier_negotiation|commodity_change|fx_adjustment|tariff_change|deal_activation|deal_expiry — promote to reference product]' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the cost components are denominated (e.g., USD, EUR, GBP, CNY). Essential for multi-currency cost management and foreign exchange (FX) rate application in landed cost calculations.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costNotes rdf:type rdf:Property ;
    rdfs:label 'Cost Notes' ;
    rdfs:comment 'Free-text field for buyer or finance team annotations regarding this cost record. May include negotiation context, exception justifications, or temporary cost arrangement details. Supports operational transparency and audit trail completeness.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerInnerPack rdf:type rdf:Property ;
    rdfs:label 'Cost Per Inner Pack' ;
    rdfs:comment 'The landed cost allocated to each inner pack unit within a case or master carton. Supports cost breakdown for items sold in multiple pack configurations (e.g., a case of 12 inner packs). Used in assortment planning and margin analysis at the inner pack level.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Status' ;
    rdfs:comment 'Current lifecycle status of the cost record. Active records are used in margin calculations. Pending records are approved but not yet effective. Expired records have passed their end date. Superseded records have been replaced by a newer cost. Cancelled records were voided before activation.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costType rdf:type rdf:Property ;
    rdfs:label 'Cost Type' ;
    rdfs:comment 'Classification of the cost record indicating the pricing arrangement: standard (catalogue cost), contract (negotiated agreement cost), promotional (temporary supplier deal cost), spot (one-time market cost), or transfer (inter-company transfer cost). Drives cost-plus margin calculations and GMROI analysis.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costUom rdf:type rdf:Property ;
    rdfs:label 'Cost Uom' ;
    rdfs:comment 'The unit of measure to which the cost components apply (e.g., EA=Each, CS=Case, PK=Pack, LB=Pound, KG=Kilogram). Ensures cost-per-unit calculations are correctly interpreted across different pack configurations and ordering units. [ENUM-REF-CANDIDATE: EA|CS|PK|LB|KG|OZ|L|M|FT — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyAmount rdf:type rdf:Property ;
    rdfs:label 'Duty Amount' ;
    rdfs:comment 'Per-unit import duty, customs tariff, and trade compliance charges applied to the SKU upon importation. Varies by country of origin, product classification (HTS code), and applicable trade agreements. Critical for landed cost accuracy on imported merchandise.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutyRatePct rdf:type rdf:Property ;
    rdfs:label 'Duty Rate Pct' ;
    rdfs:comment 'The applicable import duty rate expressed as a percentage of the base cost or customs value. Used to calculate the duty_amount component of landed cost. Varies by HTS code, country of origin, and applicable trade agreements (e.g., USMCA, CAFTA).' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingCost rdf:type rdf:Property ;
    rdfs:label 'Handling Cost' ;
    rdfs:comment 'Per-unit warehousing, distribution center handling, and processing charges allocated to the SKU. Includes DC (Distribution Center) receiving, put-away, and value-added services such as ticketing or re-packaging.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:htsCode rdf:type rdf:Property ;
    rdfs:label 'Hts Code' ;
    rdfs:comment 'The Harmonized Tariff Schedule code classifying the SKU for customs and import duty purposes. Determines the applicable duty rate and trade compliance requirements. Required for accurate duty cost calculation in the landed cost model.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'The International Chamber of Commerce (ICC) Incoterm governing the transfer of risk and cost responsibility between the supplier and the retailer (e.g., FOB=Free on Board, DDP=Delivered Duty Paid, CIF=Cost Insurance Freight). Determines which cost components are borne by the retailer versus the supplier. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrent rdf:type rdf:Property ;
    rdfs:label 'Is Current' ;
    rdfs:comment 'Boolean flag indicating whether this is the currently active cost record for the SKU-supplier-cost zone combination. True for the single active record; False for historical or superseded records. Simplifies queries for current cost without requiring date range filtering.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landedCostLocal rdf:type rdf:Property ;
    rdfs:label 'Landed Cost Local' ;
    rdfs:comment 'Total landed cost converted to the retailer\'s functional (home) currency using the applied exchange rate. Used for domestic P&L (Profit and Loss) reporting, GMROI calculations, and financial planning in the reporting currency.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherCost rdf:type rdf:Property ;
    rdfs:label 'Other Cost' ;
    rdfs:comment 'Per-unit miscellaneous cost components not captured in freight, duty, or handling. May include insurance, inspection fees, compliance testing charges, or supplier surcharges. Provides a catch-all bucket for complete landed cost assembly.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorLandedCost rdf:type rdf:Property ;
    rdfs:label 'Prior Landed Cost' ;
    rdfs:comment 'The total landed cost from the immediately preceding active cost record for this SKU-supplier combination. Enables cost variance analysis, markdown optimization, and audit trail review without requiring a self-join to the history table.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemCostCode rdf:type rdf:Property ;
    rdfs:label 'Source System Cost Code' ;
    rdfs:comment 'The native identifier of this cost record in the originating source system (e.g., ORMS cost record number, SAP condition record number). Enables reconciliation between the Silver Layer data product and the operational system of record.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Code' ;
    rdfs:comment 'Alphanumeric code identifying the supplier. Denormalized for audit trail integrity and operational reporting. Sourced from SAP S/4HANA Retail vendor master.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierDealCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Deal Code' ;
    rdfs:comment 'The identifier for the supplier deal, allowance, or promotional agreement that underpins this cost record. Links to vendor deal management in Oracle Retail Merchandising System (ORMS). Applicable when cost_type is \'promotional\' or \'contract\'.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcategoryId rdf:type rdf:Property ;
    rdfs:label 'Subcategory Id' ;
    rdfs:comment 'Reference to the product subcategory within the category (e.g., Jackets within Men\'s Outerwear) for which this margin target is set. Enables granular margin guardrail enforcement at the subcategory level.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:aspTarget rdf:type rdf:Property ;
    rdfs:label 'Asp Target' ;
    rdfs:comment 'Planned Average Selling Price (ASP) for the category or subcategory during the planning period, in the denominated currency. ASP accounts for all promotional and markdown events and may differ from AUR when mix effects are significant.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aurTarget rdf:type rdf:Property ;
    rdfs:label 'Aur Target' ;
    rdfs:comment 'Planned Average Unit Retail (AUR) price point for the category or subcategory during the planning period, in the denominated currency. AUR is a key retail KPI representing the average selling price per unit and is used to validate margin targets against pricing strategy.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandClassification rdf:type rdf:Property ;
    rdfs:label 'Brand Classification' ;
    rdfs:comment 'Classifies the brand type for which this margin target applies. \'private_label\' refers to store-owned brands; \'national_brand\' refers to manufacturer brands; \'exclusive_brand\' refers to retailer-exclusive third-party brands; \'licensed_brand\' refers to licensed intellectual property brands. Supports private label vs. national brand differential margin targeting.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Budget Utilization Pct' ;
    rdfs:comment 'Percentage of the total markdown budget that has been consumed, expressed as a decimal (e.g., 0.6500 = 65.00%). Calculated as consumed markdown budget divided by total markdown budget. Used to monitor markdown pacing against plan.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cogsRatePct rdf:type rdf:Property ;
    rdfs:label 'Cogs Rate Pct' ;
    rdfs:comment 'Planned Cost of Goods Sold (COGS) as a percentage of net sales for the planning period, expressed as a decimal (e.g., 0.5800 = 58.00%). Complements the gross margin target and is used for cost-plus margin validation in Oracle Retail Price Management (RPM).' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownBudgetConsumed rdf:type rdf:Property ;
    rdfs:label 'Markdown Budget Consumed' ;
    rdfs:comment 'Actual markdown dollars consumed against the total markdown budget as of the last refresh. Tracks cumulative markdown spend to date within the planning period, enabling real-time budget utilization monitoring.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownBudgetRemaining rdf:type rdf:Property ;
    rdfs:label 'Markdown Budget Remaining' ;
    rdfs:comment 'Remaining markdown budget available for the planning period, calculated as total markdown budget minus consumed markdown budget. Provides planners with real-time visibility into available markdown capacity.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownBudgetTotal rdf:type rdf:Property ;
    rdfs:label 'Markdown Budget Total' ;
    rdfs:comment 'Total planned markdown budget in currency units allocated for the planning period, equivalent to the Open-to-Buy (OTB) markdown dollars. Represents the maximum allowable markdown spend to achieve sell-through targets without breaching margin floors.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownOptimizationStrategy rdf:type rdf:Property ;
    rdfs:label 'Markdown Optimization Strategy' ;
    rdfs:comment 'The pricing and markdown strategy governing how markdowns are applied within this margin target. \'edlp\' = Everyday Low Price (EDLP); \'hi_lo\' = High-Low promotional pricing; \'clearance\' = end-of-season clearance markdown; \'dynamic\' = algorithmic dynamic pricing; \'cost_plus\' = cost-plus margin-based pricing.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumMarginFloorPct rdf:type rdf:Property ;
    rdfs:label 'Minimum Margin Floor Pct' ;
    rdfs:comment 'The absolute minimum acceptable gross margin percentage below which pricing decisions must not fall, expressed as a decimal (e.g., 0.2500 = 25.00%). Acts as a hard pricing guardrail to prevent margin erosion during markdowns or promotional events.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningPeriodLabel rdf:type rdf:Property ;
    rdfs:label 'Planning Period Label' ;
    rdfs:comment 'Business label identifying the specific planning period, such as \'Spring 2025\', \'Q3 FY2025\', \'October 2025\', or \'FY2025\'. Used for display and reporting in merchandise planning and financial P&L reviews.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodType rdf:type rdf:Property ;
    rdfs:label 'Planning Period Type' ;
    rdfs:comment 'Granularity of the planning horizon for this margin target. Determines whether the target applies to a retail season (e.g., Spring/Summer), fiscal quarter, calendar month, week, or full fiscal year. Aligns with Open-to-Buy (OTB) planning cycles.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelMarginPremiumPct rdf:type rdf:Property ;
    rdfs:label 'Private Label Margin Premium Pct' ;
    rdfs:comment 'The incremental gross margin percentage premium targeted for private label (store brand) products over national brand equivalents, expressed as a decimal (e.g., 0.0800 = 8.00% premium). Supports private label vs. national brand differential margin strategy.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemRefCode rdf:type rdf:Property ;
    rdfs:label 'Source System Ref Code' ;
    rdfs:comment 'The native identifier of this margin target record in the originating operational system (e.g., Oracle RPM plan ID, SAP cost center plan number). Enables cross-system traceability and reconciliation.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCode rdf:type rdf:Property ;
    rdfs:label 'Target Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the margin target record, used in Oracle Retail Price Management (RPM) and SAP S/4HANA for cross-system reference and audit trail linkage.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGrossMarginPct rdf:type rdf:Property ;
    rdfs:label 'Target Gross Margin Pct' ;
    rdfs:comment 'Planned gross margin percentage for the defined scope and planning period, expressed as a decimal (e.g., 0.4200 = 42.00%). Calculated as (Net Sales - COGS) / Net Sales. Serves as the primary pricing guardrail for category managers and merchandise planners.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetName rdf:type rdf:Property ;
    rdfs:label 'Target Name' ;
    rdfs:comment 'Human-readable descriptive name for the margin target plan, such as \'Q2 FY2025 Electronics Gross Margin Target\' or \'Holiday Season Apparel Markdown Budget\'. Used by category managers and merchandise planners for identification.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStatus rdf:type rdf:Property ;
    rdfs:label 'Target Status' ;
    rdfs:comment 'Current lifecycle state of the margin target record. \'draft\' indicates under construction; \'active\' means currently governing pricing decisions; \'approved\' means signed off by finance/merchandising leadership; \'superseded\' means replaced by a revised target; \'closed\' means the planning period has ended; \'cancelled\' means the target was voided.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleId rdf:type rdf:Property ;
    rdfs:label 'Rule Id' ;
    rdfs:comment 'Foreign key linking to pricing.pricing_rule. Business justification: Markdowns may be triggered by pricing rules (e.g., automated clearance rules based on weeks of supply, sell-through targets). Adding pricing_rule_id FK distinguishes rule-driven markdowns from manual ' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rule .

ind:actualExitDate rdf:type rdf:Property ;
    rdfs:label 'Actual Exit Date' ;
    rdfs:comment 'The actual date on which all inventory units subject to this markdown were fully cleared, returned, or liquidated. Compared against planned_exit_date to measure markdown execution efficiency.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceClosureDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Closure Date' ;
    rdfs:comment 'The date on which the clearance event was formally closed, indicating all inventory has been disposed of or the clearance program has ended. Used for clearance lifecycle reporting and dead stock elimination tracking.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceInitiationDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Initiation Date' ;
    rdfs:comment 'The date on which the clearance event was formally initiated for this SKU and location. Marks the start of the clearance lifecycle, distinct from the markdown effective start date which may precede formal clearance designation.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceStage rdf:type rdf:Property ;
    rdfs:label 'Clearance Stage' ;
    rdfs:comment 'Indicates the progression stage within a clearance event lifecycle. Not applicable for non-clearance markdowns. First Reduction: initial clearance price cut; Second Reduction: intermediate further reduction; Final Reduction: last price before disposition or liquidation.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionMethod rdf:type rdf:Property ;
    rdfs:label 'Disposition Method' ;
    rdfs:comment 'The planned or actual method for final inventory disposition after markdown. In-Store Clearance: sold through physical store; Online Clearance: sold through e-commerce channel; RTV (Return to Vendor): returned to supplier; Liquidation: sold to third-party liquidator; Donation: donated to charity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCompetitiveResponse rdf:type rdf:Property ;
    rdfs:label 'Is Competitive Response' ;
    rdfs:comment 'Flag indicating whether this markdown was triggered by a competitive pricing event (e.g., a competitor price reduction requiring a matching response). Supports competitive pricing analytics and FTC pricing transparency compliance.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markedDownPrice rdf:type rdf:Property ;
    rdfs:label 'Marked Down Price' ;
    rdfs:comment 'The new retail price after the markdown is applied. This is the price presented to customers at POS (Point of Sale) or on the e-commerce platform during the markdown event.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandUnitsAtInitiation rdf:type rdf:Property ;
    rdfs:label 'On Hand Units At Initiation' ;
    rdfs:comment 'The number of inventory units on hand at the time the markdown was initiated. Establishes the baseline inventory position for sell-through rate calculation and markdown ROI assessment.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Original Retail Price' ;
    rdfs:comment 'The full regular retail price of the SKU before any markdown is applied. Represents the AUR (Average Unit Retail) baseline used to calculate markdown depth and GMROI (Gross Margin Return on Investment) impact.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percent rdf:type rdf:Property ;
    rdfs:label 'Percent' ;
    rdfs:comment 'The markdown expressed as a percentage of the original retail price (markdown_amount / original_retail_price * 100). Used for category management reporting, markdown depth analysis, and sell-through optimization.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedExitDate rdf:type rdf:Property ;
    rdfs:label 'Planned Exit Date' ;
    rdfs:comment 'The target date by which all inventory units subject to this markdown are expected to be sold, returned, or otherwise disposed of. Used for OTB (Open to Buy) planning and clearance lifecycle management.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sellThroughActualPct rdf:type rdf:Property ;
    rdfs:label 'Sell Through Actual Pct' ;
    rdfs:comment 'The actual sell-through rate achieved as of the most recent data refresh (units sold / on_hand_units_at_initiation * 100). Compared against sell_through_target_pct to determine if further markdown action is required.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsRemaining rdf:type rdf:Property ;
    rdfs:label 'Units Remaining' ;
    rdfs:comment 'The current number of unsold inventory units still subject to this markdown event. Calculated as on_hand_units_at_initiation minus units_sold. Drives replenishment suppression and dead stock elimination decisions.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsSold rdf:type rdf:Property ;
    rdfs:label 'Units Sold' ;
    rdfs:comment 'The cumulative number of units sold at the marked-down price since the markdown became effective. Used to calculate actual sell-through rate and markdown revenue impact.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceApprovalId rdf:type rdf:Property ;
    rdfs:label 'Price Approval Id' ;
    rdfs:comment 'Unique system-generated identifier for each price approval workflow record. Primary key for the price_approval data product.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceApproval .

ind:primaryPriceAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Price Associate Id' ;
    rdfs:comment 'Identifier of the employee or system user who initiated the price change or markdown approval request. Supports segregation of duties and audit trail requirements.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:approvalChannel rdf:type rdf:Property ;
    rdfs:label 'Approval Channel' ;
    rdfs:comment 'The channel or interface through which the approver submitted their decision. Supports audit trail completeness and governance reporting on approval workflow efficiency.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Free-text notes or comments entered by the requestor or approver to provide additional business context for the price change request. May include competitive intelligence, promotional rationale, or supplier negotiation context.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Number' ;
    rdfs:comment 'Externally-known, human-readable reference number for the price approval workflow record. Used in communications, audit reports, and cross-system references. Format: PA-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTier rdf:type rdf:Property ;
    rdfs:label 'Approval Tier' ;
    rdfs:comment 'Organizational approval tier currently responsible for acting on this request. Reflects the segregation-of-duties hierarchy: Category Manager for routine markdowns, Merchandise Director for material price changes, VP Merchandising or CFO for strategic pricing decisions. [ENUM-REF-CANDIDATE: category_manager|merchandise_director|vp_merchandising|cfo|auto_approved — promote to reference product]' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalType rdf:type rdf:Property ;
    rdfs:label 'Approval Type' ;
    rdfs:comment 'Classification of the pricing action requiring approval. Distinguishes between standard price changes, markdowns (temporary or permanent), price list activations, promotional pricing, and clearance events. [ENUM-REF-CANDIDATE: price_change|markdown|price_list_activation|promotional_price|clearance — promote to reference product]' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitivePriceRef rdf:type rdf:Property ;
    rdfs:label 'Competitive Price Ref' ;
    rdfs:comment 'The competitor\'s observed price that is being used to justify a competitive pricing action. Captured at the time of the approval request to document the market intelligence basis for the price change.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'The date and time when the approver rendered a final decision (approved, rejected, or escalated) on the price change request. Null if the approval is still pending. Critical for SLA measurement and audit trail.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalationTier rdf:type rdf:Property ;
    rdfs:label 'Escalation Tier' ;
    rdfs:comment 'The approval tier to which this request was escalated. Populated only when is_escalated = True. Tracks the escalation path for audit and governance reporting.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'The date and time when the approval request was escalated to a higher approval tier due to timeout, threshold breach, or manual escalation. Null if no escalation occurred.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:grossMarginPct rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Pct' ;
    rdfs:comment 'The projected gross margin percentage at the proposed price, calculated as ((proposed_price - cost_price) / proposed_price) * 100. Validates that the proposed price meets minimum margin floor requirements before approval.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAutoApproved rdf:type rdf:Property ;
    rdfs:label 'Is Auto Approved' ;
    rdfs:comment 'Indicates whether this price change was automatically approved by the system based on pre-configured rules (e.g., price change below threshold, EDLP adjustment within margin floor). True = system auto-approved; False = requires human approval.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEscalated rdf:type rdf:Property ;
    rdfs:label 'Is Escalated' ;
    rdfs:comment 'Indicates whether this approval request has been escalated to a higher approval tier. True = escalated; False = not escalated. Complements approval_status to enable efficient filtering of escalated approvals for management review.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceChangePct rdf:type rdf:Property ;
    rdfs:label 'Price Change Pct' ;
    rdfs:comment 'The percentage change between the current price and the proposed price. Calculated as ((proposed_price - current_price) / current_price) * 100. Used to determine approval tier routing thresholds — larger percentage changes require higher-tier approval.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceZoneCode rdf:type rdf:Property ;
    rdfs:label 'Price Zone Code' ;
    rdfs:comment 'The price zone identifier to which this approval applies. Price zones group stores or regions with the same pricing strategy in Oracle Retail Price Management (RPM). A single approval may govern pricing across all stores within a zone.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'The pricing strategy governing the requested price change. EDLP (Everyday Low Price) indicates a stable low-price approach; Hi-Lo (High-Low) indicates promotional cycling; competitive pricing is driven by market benchmarks; cost-plus is margin-based; dynamic pricing is algorithm-driven. Aligns with Oracle Retail Price Management (RPM) strategy configuration.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedPrice rdf:type rdf:Property ;
    rdfs:label 'Proposed Price' ;
    rdfs:comment 'The new retail selling price being requested for approval. Compared against current_price to determine the magnitude of the price change and route to the appropriate approval tier.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Requested Timestamp' ;
    rdfs:comment 'The date and time when the price change or markdown approval request was formally submitted by the requestor. Principal business event timestamp for the approval workflow lifecycle.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rpmEventCode rdf:type rdf:Property ;
    rdfs:label 'Rpm Event Code' ;
    rdfs:comment 'The source system event identifier from Oracle Retail Price Management (RPM) that triggered this approval workflow. Enables traceability back to the originating RPM pricing event for reconciliation and audit purposes.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapChangeDocNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Change Doc Number' ;
    rdfs:comment 'The SAP S/4HANA change document number generated when the approved price change is posted to the SD (Sales and Distribution) or MM (Materials Management) module. Populated after approval and downstream activation. Supports cross-system audit trail.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Hours' ;
    rdfs:comment 'The maximum number of hours within which the assigned approver must respond to the price approval request per the pricing governance SLA (Service Level Agreement). Drives escalation logic when decision_timestamp exceeds requested_timestamp + sla_response_hours.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceAuditLogId rdf:type rdf:Property ;
    rdfs:label 'Price Audit Log Id' ;
    rdfs:comment 'Unique identifier for the price audit log entry. Primary key for immutable audit trail of all price change approvals, overrides, and system-generated price adjustments.' ;
    rdfs:domain ind:PriceAuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Approver User Associate Id' ;
    rdfs:comment 'Identifier for the user who approved the price change, if approval was required. Null for auto-approved or system-generated changes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:actorRole rdf:type rdf:Property ;
    rdfs:label 'Actor Role' ;
    rdfs:comment 'Business role or job function of the actor at the time of the price change (e.g., Pricing Manager, Store Manager, System Administrator).' ;
    rdfs:domain ind:PriceAuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actorType rdf:type rdf:Property ;
    rdfs:label 'Actor Type' ;
    rdfs:comment 'Type of actor that initiated or executed the price change. Distinguishes between human users, automated systems, and external integrations.' ;
    rdfs:domain ind:PriceAuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actorUsername rdf:type rdf:Property ;
    rdfs:label 'Actor Username' ;
    rdfs:comment 'Username or login ID of the person who performed the action. Captured for audit trail and accountability.' ;
    rdfs:domain ind:PriceAuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverUsername rdf:type rdf:Property ;
    rdfs:label 'Approver Username' ;
    rdfs:comment 'Username of the approver who authorized the price change. Part of the approval chain audit trail.' ;
    rdfs:domain ind:PriceAuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditAction rdf:type rdf:Property ;
    rdfs:label 'Audit Action' ;
    rdfs:comment 'Specific action taken in this audit event. Captures the decision or system action that was recorded. [ENUM-REF-CANDIDATE: created|approved|rejected|overridden|reverted|escalated|auto_approved|manually_adjusted|system_generated — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PriceAuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditEventType rdf:type rdf:Property ;
    rdfs:label 'Audit Event Type' ;
    rdfs:comment 'Classification of the audit event type that triggered this log entry. Distinguishes between approvals, overrides, system adjustments, and other price change actions. [ENUM-REF-CANDIDATE: price_approval|price_override|price_rejection|system_adjustment|manual_correction|markdown_approval|cost_change|competitive_response|emergency_override|batch_update — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PriceAuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Notes' ;
    rdfs:comment 'Additional free-text notes or comments added by auditors, reviewers, or system administrators for compliance documentation and investigation support.' ;
    rdfs:domain ind:PriceAuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the price change (e.g., COMP_MATCH, MARKDOWN, COST_INCREASE, PROMO_END, CLEARANCE).' ;
    rdfs:domain ind:PriceAuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveReferencePrice rdf:type rdf:Property ;
    rdfs:label 'Competitive Reference Price' ;
    rdfs:comment 'Competitor price that triggered or justified this price change, if applicable. Used for competitive pricing strategy audit trail.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isMarginBreach rdf:type rdf:Property ;
    rdfs:label 'Is Margin Breach' ;
    rdfs:comment 'Flag indicating whether the price change resulted in a margin percentage below the defined floor threshold for the category or zone.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverride rdf:type rdf:Property ;
    rdfs:label 'Is Override' ;
    rdfs:comment 'Flag indicating whether this audit entry represents a manual override of system-recommended or rule-based pricing.' ;
    rdfs:domain ind:PriceAuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marginImpact rdf:type rdf:Property ;
    rdfs:label 'Margin Impact' ;
    rdfs:comment 'Change in margin percentage resulting from the price change. Positive indicates margin improvement, negative indicates margin erosion.' ;
    rdfs:domain ind:PriceAuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newMarginPercent rdf:type rdf:Property ;
    rdfs:label 'New Margin Percent' ;
    rdfs:comment 'Gross margin percentage after the price change. Critical for margin governance and markdown optimization analysis.' ;
    rdfs:domain ind:PriceAuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newRetailPrice rdf:type rdf:Property ;
    rdfs:label 'New Retail Price' ;
    rdfs:comment 'The retail price after the change was applied. Represents the approved or overridden price value.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Explanation for why a manual override was necessary, required for governance and compliance review of exception handling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Price Change Amount' ;
    rdfs:comment 'Absolute monetary difference between prior and new retail price. Positive for price increases, negative for decreases.' ;
    rdfs:domain ind:PriceAuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangePercent rdf:type rdf:Property ;
    rdfs:label 'Price Change Percent' ;
    rdfs:comment 'Percentage change in retail price, calculated as (new_price - prior_price) / prior_price * 100. Used for variance analysis and threshold monitoring.' ;
    rdfs:domain ind:PriceAuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingStrategyType rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy Type' ;
    rdfs:comment 'The pricing strategy that governed this price change. Includes EDLP (Everyday Low Price), Hi-Lo pricing, competitive pricing, and markdown strategies. [ENUM-REF-CANDIDATE: edlp|hi_lo|competitive|cost_plus|dynamic|markdown|clearance|promotional — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorCostPrice rdf:type rdf:Property ;
    rdfs:label 'Prior Cost Price' ;
    rdfs:comment 'The cost price before the change. Captured when cost changes trigger price adjustments or for margin impact analysis.' ;
    rdfs:domain ind:PriceAuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Prior Margin Percent' ;
    rdfs:comment 'Gross margin percentage before the price change, calculated as (prior_retail_price - prior_cost_price) / prior_retail_price * 100. Used for GMROI (Gross Margin Return on Investment) tracking.' ;
    rdfs:domain ind:PriceAuditLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Prior Retail Price' ;
    rdfs:comment 'The retail price before the change was applied. Captured for before/after comparison and variance analysis.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemEventCode rdf:type rdf:Property ;
    rdfs:label 'Source System Event Code' ;
    rdfs:comment 'Unique identifier for the price change event in the source system. Used for cross-system reconciliation and traceability.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceRuleId rdf:type rdf:Property ;
    rdfs:label 'Price Rule Id' ;
    rdfs:comment 'Reference to the pricing rule or pricing strategy definition in Oracle RPM that generated or governs this price change event. Links to the EDLP, Hi-Lo, cost-plus, or competitive pricing rule configuration.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rule .

ind:changeCategory rdf:type rdf:Property ;
    rdfs:label 'Change Category' ;
    rdfs:comment 'High-level classification of the change event: retail_price_change (consumer-facing price), supplier_cost_change (vendor invoice cost), landed_cost_adjustment (total delivered cost including duties/tariffs), or freight_surcharge (transportation cost component).' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Nature of the price change: permanent (indefinite retail price reset), temporary (time-bounded promotional price), markdown (clearance or end-of-season price reduction), or automated (algorithm-driven dynamic pricing adjustment).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionMode rdf:type rdf:Property ;
    rdfs:label 'Execution Mode' ;
    rdfs:comment 'Method by which the price change was executed: manual (user-initiated via RPM UI), batch (scheduled overnight or periodic bulk update), or real_time (event-driven immediate execution, e.g., dynamic pricing engine).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCostChange rdf:type rdf:Property ;
    rdfs:label 'Is Cost Change' ;
    rdfs:comment 'Indicates whether this price change event includes a supplier or landed cost change component (True) or is a retail-price-only change (False). Enables efficient filtering for COGS recalculation and GMROI impact workflows.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newCost rdf:type rdf:Property ;
    rdfs:label 'New Cost' ;
    rdfs:comment 'The supplier or landed cost of the SKU after this change event is applied. Drives COGS recalculation, margin impact assessment, and GMROI analysis.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newMarginPct rdf:type rdf:Property ;
    rdfs:label 'New Margin Pct' ;
    rdfs:comment 'Projected gross margin percentage on the SKU after this change event is applied, calculated as ((new_retail_price - new_cost) / new_retail_price) * 100. Used for margin impact assessment, GMROI recalculation triggers, and pricing governance.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorCost rdf:type rdf:Property ;
    rdfs:label 'Prior Cost' ;
    rdfs:comment 'The supplier or landed cost of the SKU immediately before this change event. Used for COGS (Cost of Goods Sold) baseline and GMROI (Gross Margin Return on Investment) impact assessment.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorMarginPct rdf:type rdf:Property ;
    rdfs:label 'Prior Margin Pct' ;
    rdfs:comment 'Gross margin percentage on the SKU immediately before this change event, calculated as ((prior_retail_price - prior_cost) / prior_retail_price) * 100. Baseline for margin impact assessment and GMROI analysis.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retailPriceChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Retail Price Change Amount' ;
    rdfs:comment 'Absolute monetary difference between new_retail_price and prior_retail_price. Negative values indicate a price decrease (markdown); positive values indicate a price increase. Used for markdown optimization and pricing governance reporting.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retailPriceChangePct rdf:type rdf:Property ;
    rdfs:label 'Retail Price Change Pct' ;
    rdfs:comment 'Percentage change in retail price relative to the prior retail price. Calculated as ((new_retail_price - prior_retail_price) / prior_retail_price) * 100. Used for markdown depth analysis and Hi-Lo pricing strategy reporting.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Reference Number' ;
    rdfs:comment 'The supplier-provided reference number associated with a cost change event, such as a vendor cost notification letter number, EDI (Electronic Data Interchange) transaction reference, or contract amendment identifier. Null for retail-only price changes.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerSignal rdf:type rdf:Property ;
    rdfs:label 'Trigger Signal' ;
    rdfs:comment 'The specific signal or event that initiated an automated or algorithm-driven price change. Examples include competitive_price_match, demand_surge, inventory_clearance_threshold, cost_feed_update, or promotional_calendar_event. Null for manually initiated changes. [ENUM-REF-CANDIDATE: competitive_price_match|demand_surge|inventory_clearance_threshold|cost_feed_update|promotional_calendar_event|replenishment_signal — promote to reference product]' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseMarginPct rdf:type rdf:Property ;
    rdfs:label 'Base Margin Pct' ;
    rdfs:comment 'Target gross margin percentage applied as the baseline for cost-plus pricing calculations within this price list. Expressed as a percentage (e.g., 35.00 = 35%). Used in GMROI (Gross Margin Return on Investment) analysis and OTB (Open to Buy) planning. Confidential as it reveals internal margin strategy.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveIndex rdf:type rdf:Property ;
    rdfs:label 'Competitive Index' ;
    rdfs:comment 'Ratio of this price list\'s average price level relative to key competitors, expressed as an index (e.g., 100.00 = price parity; 95.00 = 5% below market; 105.00 = 5% above market). Used in competitive pricing strategy analysis and EDLP positioning validation.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'The price list identifier as it exists in the originating source system (e.g., Oracle RPM price list ID, SAP SD pricing condition group). Enables cross-system reconciliation and EDI integration with supplier systems.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Indicates whether prices in this price list are tax-inclusive (True) or tax-exclusive (False). Tax-inclusive pricing is common in international markets; tax-exclusive is standard in US retail. Drives tax calculation logic at POS and e-commerce checkout.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listType rdf:type rdf:Property ;
    rdfs:label 'List Type' ;
    rdfs:comment 'Classification of the pricing strategy this list represents. EDLP = Everyday Low Price stable baseline; HI_LO = High-Low promotional cadence; PROMOTIONAL = time-limited campaign price; CLEARANCE = markdown/end-of-life pricing; CLUB_MEMBER = loyalty or membership tier pricing; COMPETITIVE = market-response pricing. Drives price resolution logic at POS and e-commerce checkout. [ENUM-REF-CANDIDATE: EDLP|HI_LO|PROMOTIONAL|CLEARANCE|CLUB_MEMBER|COMPETITIVE|COST_PLUS|DYNAMIC — promote to reference product]' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyTierCode rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier Code' ;
    rdfs:comment 'Code identifying the customer loyalty tier (e.g., GOLD, PLATINUM, CLUB_MEMBER) for which this price list is exclusively applicable. Null for price lists that apply to all customers regardless of loyalty status. Links to the CRM loyalty program configuration for member-specific pricing.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownPct rdf:type rdf:Property ;
    rdfs:label 'Markdown Pct' ;
    rdfs:comment 'Default markdown percentage applied to AUR (Average Unit Retail) for clearance or promotional price lists. Expressed as a percentage reduction from the regular retail price (e.g., 20.00 = 20% off). Drives markdown optimization and end-of-season clearance planning.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Max Selling Price' ;
    rdfs:comment 'Ceiling price above which no SKU within this price list may be sold, ensuring competitive positioning and consumer protection compliance. Expressed in the price list\'s currency. Used in dynamic pricing guardrails to prevent price gouging.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Min Selling Price' ;
    rdfs:comment 'Floor price below which no SKU within this price list may be sold, protecting minimum margin thresholds and preventing below-cost selling. Enforced at POS and e-commerce checkout via Oracle RPM price guardrails. Expressed in the price list\'s currency.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceListCode rdf:type rdf:Property ;
    rdfs:label 'Price List Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the price list within Oracle Retail Price Management (RPM) and SAP S/4HANA SD module. Used as the business key in EDI transactions, POS price resolution, and e-commerce checkout. Examples: EDLP_BASE, HILO_PROMO_Q4, ECOM_MEMBER.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListDescription rdf:type rdf:Property ;
    rdfs:label 'Price List Description' ;
    rdfs:comment 'Detailed business description of the price list\'s purpose, scope, and intended use. Captures the pricing strategy rationale (e.g., EDLP everyday low price baseline, Hi-Lo promotional cadence, competitive response pricing).' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListName rdf:type rdf:Property ;
    rdfs:label 'Price List Name' ;
    rdfs:comment 'Human-readable name of the price list as displayed in Oracle RPM and merchandising systems. Examples: \'EDLP Base Price List\', \'Hi-Lo Promotional Q4 2024\', \'E-Commerce Club Member Pricing\'.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListStatus rdf:type rdf:Property ;
    rdfs:label 'Price List Status' ;
    rdfs:comment 'Current lifecycle state of the price list within Oracle RPM. DRAFT = under construction, not yet approved; ACTIVE = currently in use for price resolution; SUSPENDED = temporarily deactivated; EXPIRED = past effective end date; ARCHIVED = retired and no longer available for assignment.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceOverrideId rdf:type rdf:Property ;
    rdfs:label 'Price Override Id' ;
    rdfs:comment 'Unique system-generated identifier for each price override record applied at the point-of-sale or e-commerce transaction level. Primary key for this entity.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether this override type or amount threshold required explicit manager authorization before being applied at the Point of Sale (POS). Drives workflow routing in Oracle Retail Price Management (RPM) and supports discount abuse detection controls.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceedsThreshold rdf:type rdf:Property ;
    rdfs:label 'Exceeds Threshold' ;
    rdfs:comment 'Indicates whether the override amount or percentage exceeded the authorizing employee\'s configured override limit threshold. True triggers escalation workflow and flags the record for discount abuse review.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideAmount rdf:type rdf:Property ;
    rdfs:label 'Override Amount' ;
    rdfs:comment 'The absolute monetary value of the price reduction applied by the override, calculated as original_price minus override_price. Used for markdown optimization, shrinkage monitoring, and Gross Margin Return on Investment (GMROI) impact analysis.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideLimitThreshold rdf:type rdf:Property ;
    rdfs:label 'Override Limit Threshold' ;
    rdfs:comment 'The maximum monetary amount or percentage discount that the authorizing employee\'s role is permitted to apply without escalation, as configured in Oracle Retail Price Management (RPM). Used to flag overrides that exceeded authorization limits for discount abuse detection.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overridePercentage rdf:type rdf:Property ;
    rdfs:label 'Override Percentage' ;
    rdfs:comment 'The price override expressed as a percentage discount relative to the original price (override_amount / original_price * 100). Used for threshold-based discount abuse detection rules and override variance reporting.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overridePrice rdf:type rdf:Property ;
    rdfs:label 'Override Price' ;
    rdfs:comment 'The final selling price applied to the item after the override, as recorded at the Point of Sale (POS) or e-commerce checkout. This is the price the customer was charged and the value recognized for revenue reporting under FASB ASC 606.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Override Reference Number' ;
    rdfs:comment 'Externally visible alphanumeric reference number assigned to this price override event, used for audit trail tracking, customer receipts, and reconciliation with Point of Sale (POS) systems and Oracle Retail Price Management (RPM).' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideStatus rdf:type rdf:Property ;
    rdfs:label 'Override Status' ;
    rdfs:comment 'Current lifecycle state of the price override record. \'applied\' indicates the override was executed at POS; \'pending_approval\' indicates it awaits manager authorization; \'rejected\' indicates it was denied; \'voided\' indicates it was cancelled before completion; \'reversed\' indicates a post-transaction correction was made.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideTimestamp rdf:type rdf:Property ;
    rdfs:label 'Override Timestamp' ;
    rdfs:comment 'The exact date and time when the price override was applied at the Point of Sale (POS) terminal or e-commerce checkout. This is the principal business event timestamp for this transaction record, recorded in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:overrideType rdf:type rdf:Property ;
    rdfs:label 'Override Type' ;
    rdfs:comment 'Classification of the business reason driving the price override. \'manager_discount\' is a discretionary reduction authorized by a supervisor; \'price_match\' is a competitive price adjustment; \'damaged_goods\' is a markdown for defective or impaired merchandise; \'loyalty_benefit\' is a discount applied via a customer loyalty program; \'error_correction\' is a fix for a pricing system error.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shrinkageRelated rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Related' ;
    rdfs:comment 'Indicates whether this price override is associated with a shrinkage event (e.g., damaged goods markdown, theft-related adjustment). Used for inventory shrinkage monitoring and loss prevention analytics.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemOverrideCode rdf:type rdf:Property ;
    rdfs:label 'Source System Override Code' ;
    rdfs:comment 'The native identifier assigned to this price override record in the originating operational system (e.g., SAP CAR document number, RPM override ID). Enables cross-system reconciliation and data lineage tracing.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOverrideImpact rdf:type rdf:Property ;
    rdfs:label 'Total Override Impact' ;
    rdfs:comment 'The total monetary impact of the price override across all units in the transaction line, calculated as override_amount multiplied by quantity. Represents the gross markdown exposure for financial reporting and Gross Margin Return on Investment (GMROI) analysis.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidReason rdf:type rdf:Property ;
    rdfs:label 'Void Reason' ;
    rdfs:comment 'Free-text or coded explanation for why the price override was voided or reversed. Supports audit trail completeness and post-transaction correction analysis.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceSensitivityId rdf:type rdf:Property ;
    rdfs:label 'Price Sensitivity Id' ;
    rdfs:comment 'Unique identifier for the price sensitivity record. Primary key for this entity.' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyTierId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier. Business justification: Price elasticity analysis is routinely segmented by loyalty tier (high-value members less price-sensitive, entry-tier more elastic). Supports tier-specific pricing optimization, dynamic pricing strate' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:primaryPriceSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Price Sku Id' ;
    rdfs:comment 'Identifier for the SKU being analyzed for price sensitivity. Links to the product master.' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:analysisNotes rdf:type rdf:Property ;
    rdfs:label 'Analysis Notes' ;
    rdfs:comment 'Free-text notes providing additional context, assumptions, or observations about the price sensitivity analysis and its business implications.' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Period End Date' ;
    rdfs:comment 'End date of the period over which price sensitivity was measured and calculated.' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Period Start Date' ;
    rdfs:comment 'Start date of the period over which price sensitivity was measured and calculated.' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisStatus rdf:type rdf:Property ;
    rdfs:label 'Analysis Status' ;
    rdfs:comment 'Current lifecycle status of the price sensitivity analysis record (draft, validated, approved for use, active in pricing systems, or archived).' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineDemandUnits rdf:type rdf:Property ;
    rdfs:label 'Baseline Demand Units' ;
    rdfs:comment 'The observed or forecasted demand in units at the current retail price, serving as the reference point for elasticity calculations.' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveResponseFactor rdf:type rdf:Property ;
    rdfs:label 'Competitive Response Factor' ;
    rdfs:comment 'A coefficient representing the expected competitive pricing response to this SKU\'s price changes, used in dynamic pricing algorithms.' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossPriceElasticity rdf:type rdf:Property ;
    rdfs:label 'Cross Price Elasticity' ;
    rdfs:comment 'Measures the responsiveness of demand for this SKU to price changes in related SKUs (substitutes or complements). Positive values indicate substitutes, negative values indicate complements.' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Current Retail Price' ;
    rdfs:comment 'The current retail price of the SKU at the time of analysis, used as a baseline for sensitivity calculations.' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandCurveIntercept rdf:type rdf:Property ;
    rdfs:label 'Demand Curve Intercept' ;
    rdfs:comment 'The intercept parameter of the linear demand curve model (quantity = intercept + slope * price), representing theoretical demand at zero price.' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandCurveSlope rdf:type rdf:Property ;
    rdfs:label 'Demand Curve Slope' ;
    rdfs:comment 'The slope parameter of the linear demand curve model, representing the rate of change in quantity demanded per unit change in price.' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elasticityClassification rdf:type rdf:Property ;
    rdfs:label 'Elasticity Classification' ;
    rdfs:comment 'Categorical classification of price elasticity: elastic (>1), inelastic (<1), unitary (=1), perfectly elastic (infinite), or perfectly inelastic (0).' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elasticityCoefficient rdf:type rdf:Property ;
    rdfs:label 'Elasticity Coefficient' ;
    rdfs:comment 'The price elasticity of demand coefficient, representing the percentage change in quantity demanded for a 1% change in price. Negative values indicate normal demand behavior (price increase reduces demand).' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownSensitivityScore rdf:type rdf:Property ;
    rdfs:label 'Markdown Sensitivity Score' ;
    rdfs:comment 'A normalized score (0-1) indicating how responsive demand is to markdown pricing, used for clearance and markdown optimization strategies.' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimalPricePoint rdf:type rdf:Property ;
    rdfs:label 'Optimal Price Point' ;
    rdfs:comment 'The calculated optimal retail price that maximizes revenue or profit based on the elasticity model and cost structure.' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Price Change Threshold Pct' ;
    rdfs:comment 'The minimum percentage price change required to trigger a measurable demand response, representing the threshold of consumer price awareness.' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitMaximizingPrice rdf:type rdf:Property ;
    rdfs:label 'Profit Maximizing Price' ;
    rdfs:comment 'The price point that maximizes gross profit (revenue minus cost of goods sold) based on the demand curve and cost structure.' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalElasticity rdf:type rdf:Property ;
    rdfs:label 'Promotional Elasticity' ;
    rdfs:comment 'The elasticity coefficient specifically measured during promotional periods, often higher than regular elasticity due to increased price awareness.' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rSquared rdf:type rdf:Property ;
    rdfs:label 'R Squared' ;
    rdfs:comment 'The coefficient of determination (R²) indicating the proportion of variance in demand explained by price changes, measuring model fit quality (0-1 scale).' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueMaximizingPrice rdf:type rdf:Property ;
    rdfs:label 'Revenue Maximizing Price' ;
    rdfs:comment 'The price point that maximizes total revenue (price × quantity) based on the demand curve, ignoring cost considerations.' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalityAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Seasonality Adjustment Factor' ;
    rdfs:comment 'A multiplier applied to elasticity calculations to account for seasonal variations in price sensitivity (e.g., holiday periods, back-to-school).' ;
    rdfs:domain ind:PriceSensitivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Pct' ;
    rdfs:comment 'Percentage change in price above which manual approval is required, regardless of the price_change_approval_required flag. Price changes below this threshold may be auto-approved. Null if all changes require approval.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aurFloor rdf:type rdf:Property ;
    rdfs:label 'Aur Floor' ;
    rdfs:comment 'Minimum AUR (Average Unit Retail) price point allowed for any SKU governed by this strategy. Prevents pricing below a defined floor that would erode brand equity or violate supplier MAP (Minimum Advertised Price) agreements.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelScope rdf:type rdf:Property ;
    rdfs:label 'Channel Scope' ;
    rdfs:comment 'Retail channel(s) to which this pricing strategy applies. ALL covers omnichannel; IN_STORE applies to physical POS (Point of Sale) transactions; ECOMMERCE applies to Salesforce Commerce Cloud digital storefront; BOPIS (Buy Online Pick Up In Store) covers click-and-collect; MARKETPLACE covers third-party platform listings.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveIndexTarget rdf:type rdf:Property ;
    rdfs:label 'Competitive Index Target' ;
    rdfs:comment 'Target price index relative to the primary competitor set (e.g., 0.980 means 2% below market average). Used for COMPETITIVE_INDEX strategy type. Drives automated price rule generation in Oracle RPM competitive pricing module.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorBenchmarkSet rdf:type rdf:Property ;
    rdfs:label 'Competitor Benchmark Set' ;
    rdfs:comment 'Comma-delimited list of competitor retailer identifiers or names used as the reference set for competitive index pricing calculations. Defines which competitors are monitored for price intelligence feeds in Oracle RPM.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPlusMarkupPct rdf:type rdf:Property ;
    rdfs:label 'Cost Plus Markup Pct' ;
    rdfs:comment 'Fixed percentage markup applied over COGS (Cost of Goods Sold) to derive the retail price when strategy_type is COST_PLUS. Null for non-cost-plus strategies. Sourced from SAP S/4HANA CO module standard cost calculations.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dynamicPricingEnabled rdf:type rdf:Property ;
    rdfs:label 'Dynamic Pricing Enabled' ;
    rdfs:comment 'Indicates whether real-time algorithmic dynamic pricing rules are active for this strategy. When True, prices may be adjusted intraday based on demand signals from SAP Customer Activity Repository (CAR) and competitive data feeds.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hiloPromoDepthPct rdf:type rdf:Property ;
    rdfs:label 'Hilo Promo Depth Pct' ;
    rdfs:comment 'For HI_LO strategy type: the average percentage discount depth applied during promotional price events (e.g., 25.00 means 25% off regular price). Governs markdown depth parameters in Oracle RPM. Null for non-Hi-Lo strategies.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hiloSwingFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Hilo Swing Frequency Days' ;
    rdfs:comment 'For HI_LO strategy type: the number of days between promotional price events (the cadence of the high-to-low price swing cycle). Governs how frequently items cycle between regular and promotional price points. Null for non-Hi-Lo strategies.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mapEnforcementEnabled rdf:type rdf:Property ;
    rdfs:label 'Map Enforcement Enabled' ;
    rdfs:comment 'Indicates whether Minimum Advertised Price (MAP) supplier agreements are enforced as a hard floor within this pricing strategy. When True, Oracle RPM prevents any price rule from setting a price below the supplier-defined MAP.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownOptimizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Markdown Optimization Enabled' ;
    rdfs:comment 'Indicates whether automated markdown optimization (via Blue Yonder Demand Planning or Oracle RPM markdown module) is active for merchandise governed by this strategy. When True, system-generated markdown recommendations are applied automatically.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceChangeApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Price Change Approval Required' ;
    rdfs:comment 'Indicates whether price changes generated under this strategy require manual approval by a pricing manager before activation. Supports governance and audit trail requirements in Oracle RPM workflow.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Price Review Frequency' ;
    rdfs:comment 'Cadence at which pricing analysts review and potentially update prices governed by this strategy. Drives workflow scheduling in Oracle RPM and aligns with category management review cycles.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceStrategyDescription rdf:type rdf:Property ;
    rdfs:label 'Price Strategy Description' ;
    rdfs:comment 'Free-text narrative describing the business rationale, objectives, and scope of this pricing strategy. Used by pricing analysts and category managers for context and documentation within Oracle RPM.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceStrategyStatus rdf:type rdf:Property ;
    rdfs:label 'Price Strategy Status' ;
    rdfs:comment 'Current lifecycle state of the pricing strategy. DRAFT indicates the strategy is under configuration; ACTIVE means it is governing live pricing rules; SUSPENDED means temporarily paused; EXPIRED means the effective period has lapsed; ARCHIVED means retired from use.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelDifferentialPct rdf:type rdf:Property ;
    rdfs:label 'Private Label Differential Pct' ;
    rdfs:comment 'Configured percentage by which private label (store brand) products are priced below national brand equivalents within this strategy scope (e.g., -15.00 means 15% below national brand AUR). Supports private label vs. national brand pricing differential policy.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rpmStrategyCode rdf:type rdf:Property ;
    rdfs:label 'Rpm Strategy Code' ;
    rdfs:comment 'Native strategy identifier from Oracle Retail Price Management (RPM) source system. Enables lineage tracing and reconciliation between the silver layer lakehouse record and the RPM operational system of record.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellThroughRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sell Through Rate Target Pct' ;
    rdfs:comment 'Target sell-through rate (percentage of inventory sold within a defined period) that this pricing strategy is designed to achieve. Used to calibrate markdown depth and timing in markdown optimization workflows.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategyCode rdf:type rdf:Property ;
    rdfs:label 'Strategy Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this pricing strategy within Oracle Retail Price Management (RPM) and SAP S/4HANA SD module. Used for cross-system reference and EDI integration.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyName rdf:type rdf:Property ;
    rdfs:label 'Strategy Name' ;
    rdfs:comment 'Human-readable name describing the pricing strategy (e.g., \'Grocery EDLP FY2025\', \'Apparel Hi-Lo Seasonal\'). Used in reporting dashboards and pricing governance workflows.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyType rdf:type rdf:Property ;
    rdfs:label 'Strategy Type' ;
    rdfs:comment 'Primary pricing strategy classification applied to the scoped merchandise hierarchy. EDLP (Everyday Low Price) maintains stable low prices; HI_LO (High-Low) cycles between regular and promotional prices; COST_PLUS applies a fixed margin over COGS; COMPETITIVE_INDEX tracks competitor price positions; VALUE_BASED prices to perceived customer value; DYNAMIC adjusts prices algorithmically in real time.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarginMaxPct rdf:type rdf:Property ;
    rdfs:label 'Target Margin Max Pct' ;
    rdfs:comment 'Maximum acceptable gross margin percentage for merchandise governed by this strategy. Acts as a pricing ceiling guardrail to prevent consumer price gouging and maintain competitive positioning. Monitored against FTC pricing transparency standards.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMarginMinPct rdf:type rdf:Property ;
    rdfs:label 'Target Margin Min Pct' ;
    rdfs:comment 'Minimum acceptable gross margin percentage (as a percentage of net sales) for merchandise governed by this strategy. Acts as a pricing floor guardrail. Used in GMROI (Gross Margin Return on Investment) monitoring and markdown optimization.' ;
    rdfs:domain ind:PriceStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentZonePriceZoneId rdf:type rdf:Property ;
    rdfs:label 'Parent Zone Price Zone Id' ;
    rdfs:comment 'Self-referencing identifier pointing to a parent price zone in a zone hierarchy. Enables multi-tier zone structures (e.g., a national zone containing regional sub-zones). Null for top-level zones with no parent. Used in Oracle Retail Price Management (RPM) zone inheritance for pricing rule cascades.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceZone .

ind:basePriceMultiplier rdf:type rdf:Property ;
    rdfs:label 'Base Price Multiplier' ;
    rdfs:comment 'Zone-level multiplier applied to the national base price to derive the zone-specific retail price. A value of 1.0000 means no adjustment; 0.9500 means a 5% reduction; 1.0500 means a 5% premium. Used in Oracle Retail Price Management (RPM) zone pricing calculations to support Hi-Lo and EDLP strategies.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentNodeCount rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Node Count' ;
    rdfs:comment 'Current number of e-commerce fulfillment nodes (dark stores, micro-fulfillment centers, distribution centers) assigned to this price zone. Supports omnichannel pricing governance for BOPIS (Buy Online Pick Up In Store) and Ship-from-Store (SFS) operations.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCompetitiveZone rdf:type rdf:Property ;
    rdfs:label 'Is Competitive Zone' ;
    rdfs:comment 'Indicates whether this zone is subject to active competitive price monitoring and response rules. When True, Oracle Retail Price Management (RPM) applies competitive pricing overrides based on competitor intelligence feeds, enabling dynamic Hi-Lo or EDLP adjustments.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultZone rdf:type rdf:Property ;
    rdfs:label 'Is Default Zone' ;
    rdfs:comment 'Indicates whether this zone serves as the fallback default pricing zone when a store or fulfillment node has no explicit zone assignment. Only one zone per country should carry this flag as True. Prevents pricing gaps in Oracle Retail Price Management (RPM).' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEcommerceEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Ecommerce Enabled' ;
    rdfs:comment 'Indicates whether this price zone\'s pricing rules are applied to digital commerce channels via Salesforce Commerce Cloud. When True, zone prices are broadcast to the e-commerce storefront and govern online GMV (Gross Merchandise Value) pricing.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketTier rdf:type rdf:Property ;
    rdfs:label 'Market Tier' ;
    rdfs:comment 'Market size and competitive intensity classification for the zone. Tier 1 represents major metropolitan markets with high competitive density; Tier 4 represents rural or low-competition markets. Drives GMROI (Gross Margin Return on Investment) targets and markdown depth thresholds per zone.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxMarkdownPct rdf:type rdf:Property ;
    rdfs:label 'Max Markdown Pct' ;
    rdfs:comment 'The maximum allowable markdown depth (as a percentage of the original retail price) permitted for any SKU within this zone. Governs markdown optimization rules in Oracle Retail Price Management (RPM) to protect zone-level profitability and prevent excessive sell-through distortion.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minMarginPct rdf:type rdf:Property ;
    rdfs:label 'Min Margin Pct' ;
    rdfs:comment 'The minimum acceptable gross margin percentage (COGS-based) enforced for all SKUs priced within this zone. Prevents markdown rules from eroding profitability below the zone\'s GMROI (Gross Margin Return on Investment) floor. Expressed as a percentage (e.g., 18.50 = 18.5%).' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Override Allowed' ;
    rdfs:comment 'Indicates whether store managers or regional pricing teams are permitted to apply local price overrides beyond the zone\'s standard pricing rules. When False, all prices are centrally governed with no local deviation permitted. Supports pricing compliance and FTC advertising standards.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Price Approval Required' ;
    rdfs:comment 'Indicates whether price changes within this zone require explicit managerial approval before activation in Oracle Retail Price Management (RPM). Supports pricing governance workflows and audit trail requirements for high-sensitivity competitive or promotional zones.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceChangeLeadDays rdf:type rdf:Property ;
    rdfs:label 'Price Change Lead Days' ;
    rdfs:comment 'Minimum number of calendar days required between a price change approval and its effective implementation at POS (Point of Sale) for stores in this zone. Accounts for shelf label reprinting, planogram updates, and EDI broadcast lead times to store systems.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rpmZoneCode rdf:type rdf:Property ;
    rdfs:label 'Rpm Zone Code' ;
    rdfs:comment 'Native zone identifier from Oracle Retail Price Management (RPM) source system. Preserved for cross-system reconciliation, EDI integration, and audit trail linkage back to the operational pricing system of record.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPricingConditionGroup rdf:type rdf:Property ;
    rdfs:label 'Sap Pricing Condition Group' ;
    rdfs:comment 'SAP S/4HANA SD module pricing condition group code associated with this price zone. Used to apply zone-specific pricing conditions (VK11/VK12) in SAP for sales order pricing, ensuring consistency between Oracle RPM zone definitions and SAP transactional pricing.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCount rdf:type rdf:Property ;
    rdfs:label 'Store Count' ;
    rdfs:comment 'Current number of physical store locations assigned to this price zone. Used in zone-level Comp Sales (Comparable Store Sales) and SSS (Same-Store Sales) reporting. Updated automatically when store-to-zone assignments change.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the price zone within Oracle Retail Price Management (RPM) and SAP S/4HANA. Used in EDI transactions, pricing rule references, and cross-system integrations. Example: \'PZ_NORTHEAST_01\', \'COMP_URBAN_W\'.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneDescription rdf:type rdf:Property ;
    rdfs:label 'Zone Description' ;
    rdfs:comment 'Free-text business description of the price zone\'s purpose, geographic scope, competitive rationale, and any special pricing governance rules. Used by category management and merchandise planning teams for zone strategy documentation.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Zone Hierarchy Level' ;
    rdfs:comment 'Numeric depth of this zone within the price zone hierarchy (1 = top-level national zone, 2 = regional zone, 3 = sub-regional or competitive cluster). Used to resolve pricing rule inheritance and override precedence in Oracle Retail Price Management (RPM).' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zoneName rdf:type rdf:Property ;
    rdfs:label 'Zone Name' ;
    rdfs:comment 'Human-readable business name for the price zone used in reporting, planogram management, and pricing governance communications. Example: \'Northeast Competitive Urban Zone\', \'Rural EDLP Cluster South\'.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneStatus rdf:type rdf:Property ;
    rdfs:label 'Zone Status' ;
    rdfs:comment 'Current lifecycle status of the price zone within Oracle Retail Price Management (RPM). \'active\' zones are live and applied to store pricing; \'pending\' zones are approved but not yet effective; \'inactive\' zones are suspended; \'archived\' zones are retained for historical audit and markdown optimization analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneType rdf:type rdf:Property ;
    rdfs:label 'Zone Type' ;
    rdfs:comment 'Categorical classification of the price zone indicating the market segmentation strategy applied. \'regional\' zones group stores by geography; \'competitive\' zones respond to local competitor pricing; \'urban\'/\'rural\' zones reflect demographic cost structures; \'omnichannel\' zones unify in-store and digital pricing; \'ecommerce\' zones apply exclusively to digital fulfillment nodes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentMethod rdf:type rdf:Property ;
    rdfs:label 'Adjustment Method' ;
    rdfs:comment 'Specifies the mathematical method used to compute the price adjustment. \'percentage\' = apply a % change to the base price (e.g., 15% markdown); \'absolute\' = apply a fixed monetary amount change (e.g., reduce by $5.00); \'index_based\' = adjust relative to a reference index (e.g., competitor price index, CPI).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentValue rdf:type rdf:Property ;
    rdfs:label 'Adjustment Value' ;
    rdfs:comment 'The numeric magnitude of the price adjustment as defined by the adjustment_method. For \'percentage\', this is the rate (e.g., 15.00 = 15%); for \'absolute\', this is the currency amount (e.g., 5.0000 = $5.00); for \'index_based\', this is the index multiplier. Negative values represent price reductions (markdowns); positive values represent increases.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:algorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Algorithm Version' ;
    rdfs:comment 'Version identifier of the dynamic pricing algorithm or rule engine logic applied by this rule. Used for reproducibility, audit, and A/B testing of pricing models. Example: \'v2.1.0\', \'v3.0\'. Applicable for rule_type = \'dynamic_trigger\', \'demand_based\', or \'inventory_based\'. Null for static manual rules.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableDaysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Applicable Days Of Week' ;
    rdfs:comment 'Comma-separated list of days of the week on which this pricing rule is active. Enables day-parting and weekly promotional cadence (e.g., \'MON,TUE,WED,THU,FRI\' for weekday rules; \'SAT,SUN\' for weekend Hi-Lo swings). Null if the rule applies every day within the effective date range. Format: MON|TUE|WED|THU|FRI|SAT|SUN.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorPriceIndex rdf:type rdf:Property ;
    rdfs:label 'Competitor Price Index' ;
    rdfs:comment 'The reference competitor price index value used as the benchmark for competitive match ceiling or competitive pricing rules. A value of 1.0000 = price parity; values below 1.0 indicate undercutting strategy; values above 1.0 indicate premium positioning. Sourced from competitive intelligence feeds integrated with Oracle RPM.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPlusMarginPct rdf:type rdf:Property ;
    rdfs:label 'Cost Plus Margin Pct' ;
    rdfs:comment 'The gross margin percentage applied above COGS (Cost of Goods Sold) when the rule_type is \'cost_plus_floor\'. Defines the minimum acceptable margin to protect GMROI (Gross Margin Return on Investment) targets. Example: 35.0000 = 35% margin above cost. Sourced from SAP S/4HANA CO (Controlling) module.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyExclusive rdf:type rdf:Property ;
    rdfs:label 'Loyalty Exclusive' ;
    rdfs:comment 'Indicates whether this pricing rule applies exclusively to loyalty program members. True = price adjustment is only available to enrolled loyalty customers (e.g., member-only pricing); False = rule applies to all customers regardless of loyalty status. Integrates with CRM (Customer Relationship Management) loyalty program data.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownDepthPct rdf:type rdf:Property ;
    rdfs:label 'Markdown Depth Pct' ;
    rdfs:comment 'The maximum allowable markdown percentage from the AUR (Average Unit Retail) or original retail price for markdown and clearance rules. Prevents excessive margin erosion. Example: 40.0000 = maximum 40% markdown. Used in markdown optimization workflows within Oracle RPM and Blue Yonder Demand Planning.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxPrice rdf:type rdf:Property ;
    rdfs:label 'Max Price' ;
    rdfs:comment 'The absolute ceiling price above which this rule must not raise the selling price. Prevents price gouging and ensures compliance with FTC consumer protection standards. Used in competitive match ceiling rules to cap price increases. Expressed in the operating currency (USD). Corresponds to the \'price ceiling\' concept in Oracle RPM.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minPrice rdf:type rdf:Property ;
    rdfs:label 'Min Price' ;
    rdfs:comment 'The absolute floor price below which this rule must not reduce the selling price, regardless of adjustment logic. Protects against below-cost selling and ensures compliance with FTC pricing transparency and predatory pricing regulations. Expressed in the operating currency (USD). Corresponds to the \'price floor\' concept in Oracle RPM.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Override Approval Required' ;
    rdfs:comment 'Indicates whether a manual price override for this rule requires supervisory approval before taking effect. True = approval workflow triggered in Oracle RPM; False = override can be applied immediately by authorized users. Relevant only when override_permitted = True.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overridePermitted rdf:type rdf:Property ;
    rdfs:label 'Override Permitted' ;
    rdfs:comment 'Indicates whether a merchant or store manager is permitted to manually override this pricing rule at the POS (Point of Sale) or in Oracle RPM. True = override allowed with appropriate role-based authorization; False = rule is locked and cannot be overridden (common for EDLP lock and regulatory compliance rules).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemRuleCode rdf:type rdf:Property ;
    rdfs:label 'Source System Rule Code' ;
    rdfs:comment 'The native identifier of this pricing rule in the originating operational system of record (Oracle Retail Price Management RPM). Enables bidirectional traceability between the lakehouse silver layer and the RPM source system for audit and reconciliation purposes.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackable rdf:type rdf:Property ;
    rdfs:label 'Stackable' ;
    rdfs:comment 'Indicates whether this pricing rule can be combined (stacked) with other active pricing rules or promotions for the same SKU. True = rule can stack with other discounts/promotions; False = rule is exclusive and prevents other rules from applying simultaneously. Critical for promotion conflict management in Oracle RPM.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeOfDayEnd rdf:type rdf:Property ;
    rdfs:label 'Time Of Day End' ;
    rdfs:comment 'The daily end time (HH:MM in 24-hour format) at which this rule ceases to be active for intraday pricing windows. Paired with time_of_day_start to define the active window. Null if the rule applies all day.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeOfDayStart rdf:type rdf:Property ;
    rdfs:label 'Time Of Day Start' ;
    rdfs:comment 'The daily start time (HH:MM in 24-hour format) from which this rule is active, applicable when trigger_type = \'time_based\' or rule_type = \'time_of_day\'. Enables intraday dynamic pricing (e.g., happy hour markdowns, peak-hour surcharges). Null if the rule applies all day.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Trigger Threshold Value' ;
    rdfs:comment 'The numeric threshold value that must be breached to activate the trigger condition. Interpretation depends on trigger_type: for \'inventory_threshold\' this is the WOS (Weeks of Supply) or unit count; for \'demand_surge\' this is the demand index multiplier; for \'sell_through_rate\' this is the percentage. Sourced from Blue Yonder Demand Planning signals.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelPriceVariance rdf:type rdf:Property ;
    rdfs:label 'Channel Price Variance' ;
    rdfs:comment 'The absolute price difference between this channel-specific price and the base in-store retail price for the same SKU, price list, and zone. Quantifies omnichannel price differentiation (e.g., e-commerce price vs. in-store price).' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelPriceVarianceReason rdf:type rdf:Property ;
    rdfs:label 'Channel Price Variance Reason' ;
    rdfs:comment 'Business justification for any price variance between this channel price and the base retail price. Required for compliance with FTC pricing transparency guidelines and internal pricing governance. Examples: \'Online-only promotion\', \'Marketplace fee offset\', \'BOPIS incentive\'.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialMarkupPct rdf:type rdf:Property ;
    rdfs:label 'Initial Markup Pct' ;
    rdfs:comment 'The Initial Markup (IMU) percentage calculated as (retail_price - cost_price) / retail_price * 100. Represents the planned gross margin at the time of price setting before any markdowns.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDynamicPricingEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Dynamic Pricing Enabled' ;
    rdfs:comment 'Indicates whether dynamic pricing rules are active for this SKU in this price list, zone, and channel context. When True, the price may be algorithmically adjusted within price_floor and price_ceiling bounds based on demand signals from SAP Customer Activity Repository (CAR).' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPriceLocked rdf:type rdf:Property ;
    rdfs:label 'Is Price Locked' ;
    rdfs:comment 'Indicates whether this price record is locked and protected from automated price changes or markdown optimization algorithms. When True, the price can only be changed through a manual approval workflow in Oracle Retail Price Management (RPM).' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minAdvertisedPrice rdf:type rdf:Property ;
    rdfs:label 'Min Advertised Price' ;
    rdfs:comment 'The Minimum Advertised Price (MAP) floor set by the supplier or brand for this SKU. The retail_price must not be advertised below this threshold. Enforced for compliance with supplier MAP agreements and FTC advertising standards.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceCeiling rdf:type rdf:Property ;
    rdfs:label 'Price Ceiling' ;
    rdfs:comment 'The maximum allowable retail price for this SKU in this zone and channel. Prevents price gouging and ensures compliance with consumer protection regulations. Used in dynamic pricing guardrails.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeReason rdf:type rdf:Property ;
    rdfs:label 'Price Change Reason' ;
    rdfs:comment 'Business reason code or description explaining why this price was set or changed. Examples: \'Competitive match\', \'Seasonal markdown\', \'Clearance\', \'Cost increase\', \'Promotional event\'. Supports price change audit trail and markdown optimization analysis.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceFloor rdf:type rdf:Property ;
    rdfs:label 'Price Floor' ;
    rdfs:comment 'The minimum allowable retail price for this SKU in this zone and channel, below which the price cannot be set without executive override. Protects gross margin and prevents below-cost selling. Distinct from MAP which is a supplier-imposed advertising constraint.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePerUnitDisplay rdf:type rdf:Property ;
    rdfs:label 'Price Per Unit Display' ;
    rdfs:comment 'The normalized price per standard unit (e.g., price per 100g, price per litre) used for shelf-edge price comparison display. Required by consumer protection regulations for grocery and FMCG categories to enable fair price comparison.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePerUnitUom rdf:type rdf:Property ;
    rdfs:label 'Price Per Unit Uom' ;
    rdfs:comment 'The unit of measure denominator for the price_per_unit_display field (e.g., \'100G\', \'1L\', \'1OZ\'). Required alongside price_per_unit_display for regulatory shelf-edge unit pricing compliance.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceResolutionPriority rdf:type rdf:Property ;
    rdfs:label 'Price Resolution Priority' ;
    rdfs:comment 'Numeric priority rank used by the price resolution engine to determine which price list takes precedence when multiple price lists apply to the same SKU-zone-channel combination. Lower integer = higher priority. Drives POS and digital channel price resolution logic.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Classification of the pricing strategy applied to this SKU-price-list-zone-channel binding. Supports EDLP (Everyday Low Price), Hi-Lo (High-Low Pricing Strategy), clearance, competitive match, markdown, and promotional pricing. [ENUM-REF-CANDIDATE: edlp|hi_lo|clearance|competitive_match|markdown|promotional — promote to reference product]' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemPriceCode rdf:type rdf:Property ;
    rdfs:label 'Source System Price Code' ;
    rdfs:comment 'The native price record identifier from the originating operational system (e.g., Oracle RPM Price Event ID, SAP condition record number). Enables bi-directional traceability between the Silver Layer and the system of record for audit and reconciliation.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomCode rdf:type rdf:Property ;
    rdfs:label 'Uom Code' ;
    rdfs:comment 'The unit of measure for which the retail_price applies (e.g., EA = Each, KG = Kilogram, LB = Pound, L = Litre). Critical for price-per-unit display compliance and weight-based pricing at POS. [ENUM-REF-CANDIDATE: EA|KG|LB|L|ML|M|FT|OZ|PK|CS — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gtinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Gtin Registry Id' ;
    rdfs:comment 'Unique identifier for the GTIN registry record. Primary key for the GTIN registry product.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataStewardAssociateId rdf:type rdf:Property ;
    rdfs:label 'Data Steward Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: GTIN registry maintenance requires data stewards to ensure GS1 compliance, barcode accuracy, and GDSN synchronization. Essential for master data governance, supply chain integration, and point-of-sale' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:barcodeImageUrl rdf:type rdf:Property ;
    rdfs:label 'Barcode Image Url' ;
    rdfs:comment 'URL reference to the digital barcode image asset (PNG, SVG, or EPS format). Used for printing labels, packaging artwork, and digital commerce applications. Points to asset management system or CDN location.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeSymbology rdf:type rdf:Property ;
    rdfs:label 'Barcode Symbology' ;
    rdfs:comment 'The barcode encoding standard used to represent this GTIN. EAN (European Article Number bars), UPC (Universal Product Code bars), ITF-14 (Interleaved 2 of 5 for cases), GS1-128 (application identifier barcodes), QR (2D matrix code). Determines scanner compatibility.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkDigit rdf:type rdf:Property ;
    rdfs:label 'Check Digit' ;
    rdfs:comment 'The final digit of the GTIN calculated using GS1 check digit algorithm (modulo 10). Used to validate GTIN integrity during scanning and data entry. Automatically calculated but stored for validation purposes.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childGtinQuantity rdf:type rdf:Property ;
    rdfs:label 'Child Gtin Quantity' ;
    rdfs:comment 'Number of child GTINs (next lower packaging level) contained within this GTIN. For example, a case GTIN with child_gtin_quantity=24 contains 24 unit GTINs. Null for unit-level GTINs. Used to calculate inventory at different packaging levels.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countryOfSale rdf:type rdf:Property ;
    rdfs:label 'Country Of Sale' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where this GTIN is authorized for sale. A single SKU may have different GTINs for different countries due to regulatory labeling requirements. For example, USA, CAN, MEX, GBR, DEU, FRA.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsnLastSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gdsn Last Sync Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful synchronization of this GTIN data to the GDSN data pool. Used to track data freshness and identify GTINs requiring re-publication after attribute changes.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdsnPublicationStatus rdf:type rdf:Property ;
    rdfs:label 'Gdsn Publication Status' ;
    rdfs:comment 'Status of this GTIN in the GS1 Global Data Synchronization Network. Published (live in GDSN data pool), unpublished (not yet shared), pending (awaiting data pool validation), synchronized (confirmed by trading partners), rejected (validation errors). Required for supplier collaboration and EDI.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightUnit rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Unit' ;
    rdfs:comment 'Unit of measure for gross_weight_value. Typically g (gram), kg (kilogram), oz (ounce), or lb (pound). Must be consistent across supply chain for accurate logistics planning.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightValue rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Value' ;
    rdfs:comment 'Total weight of the packaged item including product and packaging materials. Used for shipping calculations, freight costing, and warehouse capacity planning. Measured in gross_weight_unit.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gs1CompanyPrefix rdf:type rdf:Property ;
    rdfs:label 'Gs1 Company Prefix' ;
    rdfs:comment 'The GS1-issued company prefix portion of the GTIN. Identifies the brand owner or manufacturer who registered this GTIN with GS1. Typically 6-12 digits depending on the company size and GS1 member organization.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gtinType rdf:type rdf:Property ;
    rdfs:label 'Gtin Type' ;
    rdfs:comment 'The specific GTIN format type. UPC-A (12-digit North America standard), UPC-E (8-digit compressed UPC), EAN-13 (13-digit international standard), EAN-8 (8-digit short EAN), GTIN-14 (14-digit case/pallet level), ITF-14 (Interleaved 2 of 5 barcode for GTIN-14).' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBaseUnit rdf:type rdf:Property ;
    rdfs:label 'Is Base Unit' ;
    rdfs:comment 'Indicates whether this GTIN is the base unit of measure for inventory tracking. Typically true for the smallest sellable unit (each). All other packaging levels are multiples of the base unit. Used for inventory conversion calculations.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConsumerUnit rdf:type rdf:Property ;
    rdfs:label 'Is Consumer Unit' ;
    rdfs:comment 'Indicates whether this GTIN represents a consumer-facing unit sold at POS. True for retail each units. False for case/pallet GTINs used only in supply chain. Determines whether GTIN should appear in e-commerce catalog and POS systems.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrderableUnit rdf:type rdf:Property ;
    rdfs:label 'Is Orderable Unit' ;
    rdfs:comment 'Indicates whether this GTIN can be ordered directly via EDI purchase orders. True for case and pallet GTINs typically ordered from suppliers. False for unit GTINs that are only sold at retail. Controls EDI transaction validation.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVariableMeasure rdf:type rdf:Property ;
    rdfs:label 'Is Variable Measure' ;
    rdfs:comment 'Indicates whether this GTIN represents a variable measure item (e.g., meat, produce, cheese sold by weight). True for items where price varies by weight/quantity. Affects POS scanning behavior and pricing logic.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netContentUnit rdf:type rdf:Property ;
    rdfs:label 'Net Content Unit' ;
    rdfs:comment 'The unit of measure for net_content_value. Standard units: g (gram), kg (kilogram), mg (milligram), oz (ounce), lb (pound), mL (milliliter), L (liter), gal (gallon), qt (quart), pt (pint), ea (each), ct (count). Must align with regulatory labeling requirements. [ENUM-REF-CANDIDATE: g|kg|mg|oz|lb|mL|L|gal|qt|pt|ea|ct — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netContentValue rdf:type rdf:Property ;
    rdfs:label 'Net Content Value' ;
    rdfs:comment 'The numeric quantity of product contained in this GTIN package. For example, 500 (when unit is mL), 12 (when unit is oz), 1.5 (when unit is kg). Used with net_content_unit to describe package size. Required for GDSN synchronization.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageDepthValue rdf:type rdf:Property ;
    rdfs:label 'Package Depth Value' ;
    rdfs:comment 'Depth dimension of the package. Used with height and width for cubic volume calculations. Essential for warehouse bin sizing and transportation load planning. Measured in package_dimension_unit.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageDimensionUnit rdf:type rdf:Property ;
    rdfs:label 'Package Dimension Unit' ;
    rdfs:comment 'Unit of measure for package dimensions (height, width, depth). Standard units: mm (millimeter), cm (centimeter), m (meter), in (inch), ft (foot). Must be consistent for all three dimensions.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageHeightValue rdf:type rdf:Property ;
    rdfs:label 'Package Height Value' ;
    rdfs:comment 'Height dimension of the package. Used with package_width_value and package_depth_value to calculate cubic volume for warehouse slotting, transportation planning, and shelf space allocation. Measured in package_dimension_unit.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageWidthValue rdf:type rdf:Property ;
    rdfs:label 'Package Width Value' ;
    rdfs:comment 'Width dimension of the package. Critical for planogram design, shelf allocation, and transportation cube optimization. Measured in package_dimension_unit.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingLevel rdf:type rdf:Property ;
    rdfs:label 'Packaging Level' ;
    rdfs:comment 'The packaging hierarchy level this GTIN represents. Unit (each/consumer unit), inner pack (multi-pack sold as one), case (shipping carton), pallet (full pallet load), display (retail display shipper). Critical for warehouse receiving and inventory management.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentGtin rdf:type rdf:Property ;
    rdfs:label 'Parent Gtin' ;
    rdfs:comment 'Self-referencing GTIN that represents the next higher packaging level in the hierarchy. For example, a unit GTIN\'s parent would be the case GTIN. Null for the highest packaging level (typically pallet). Enables resolution of case receipts to constituent unit GTINs.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of this GTIN registration. Active (in use), inactive (temporarily disabled), pending (awaiting approval), suspended (compliance issue), retired (permanently discontinued). Controls whether the GTIN can be used in transactions.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Status' ;
    rdfs:comment 'Indicates whether this GTIN meets all applicable regulatory requirements for its country of sale. Compliant (approved for sale), non_compliant (blocked), pending_review (under evaluation), exempt (not subject to specific regulations). Enforced by quality assurance and legal teams.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementGtin rdf:type rdf:Property ;
    rdfs:label 'Replacement Gtin' ;
    rdfs:comment 'The new GTIN that supersedes this one when discontinued. Used for packaging changes, reformulations, or product transitions. Enables automatic substitution in ordering systems and maintains continuity in assortment planning.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemBundleId rdf:type rdf:Property ;
    rdfs:label 'Item Bundle Id' ;
    rdfs:comment 'Unique identifier for the item bundle configuration. Primary key.' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bundleSkuId rdf:type rdf:Property ;
    rdfs:label 'Bundle Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: item_bundle.bundle_sku (STRING) should be normalized to a proper FK. The bundle itself is a SKU in the catalog. This links the bundle definition to its SKU master record. bundle_gtin can be retrieved ' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:assortmentCategory rdf:type rdf:Property ;
    rdfs:label 'Assortment Category' ;
    rdfs:comment 'The merchandising category or department this bundle belongs to for assortment planning and category management (e.g., Grocery, Apparel, Electronics).' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleDescription rdf:type rdf:Property ;
    rdfs:label 'Bundle Description' ;
    rdfs:comment 'Detailed description of the bundle contents and value proposition for merchandising and marketing purposes.' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleName rdf:type rdf:Property ;
    rdfs:label 'Bundle Name' ;
    rdfs:comment 'The customer-facing name of the bundle (e.g., \'Summer BBQ Pack\', \'Family Meal Deal\', \'Holiday Gift Set\').' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundlePriceAmount rdf:type rdf:Property ;
    rdfs:label 'Bundle Price Amount' ;
    rdfs:comment 'The selling price of the bundle when pricing_method is bundle_price. Represents the total customer-facing price.' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bundleStatus rdf:type rdf:Property ;
    rdfs:label 'Bundle Status' ;
    rdfs:comment 'Current lifecycle status of the bundle: active (available for sale), inactive (temporarily unavailable), pending (awaiting approval), discontinued (permanently removed), seasonal (available during specific periods).' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleType rdf:type rdf:Property ;
    rdfs:label 'Bundle Type' ;
    rdfs:comment 'Classification of the bundle configuration: fixed_bundle (pre-defined components), mix_and_match (customer selects from options), gift_set (curated gift collection), kit (assembly required), variety_pack (multiple flavors/variants), multi_pack (quantity of same item).' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentQuantity rdf:type rdf:Property ;
    rdfs:label 'Component Quantity' ;
    rdfs:comment 'The quantity of the component SKU included in one unit of the bundle. Supports fractional quantities for weight-based items.' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentSequence rdf:type rdf:Property ;
    rdfs:label 'Component Sequence' ;
    rdfs:comment 'The display order or assembly sequence of this component within the bundle. Used for kit assembly instructions and merchandising display.' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentSku rdf:type rdf:Property ;
    rdfs:label 'Component Sku' ;
    rdfs:comment 'The SKU of an individual component item included in this bundle. References the product master catalog.' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentSubstitutionAllowed rdf:type rdf:Property ;
    rdfs:label 'Component Substitution Allowed' ;
    rdfs:comment 'Indicates whether this component can be substituted with an equivalent item during fulfillment (e.g., out-of-stock scenarios, mix-and-match bundles).' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryDeductionMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Deduction Method' ;
    rdfs:comment 'Defines how inventory is tracked and decremented: component_level (deduct each component SKU), bundle_level (track bundle as single inventory unit), hybrid (track both bundle and components).' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyPointsEligible rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Eligible' ;
    rdfs:comment 'Indicates whether customers can earn loyalty program points on bundle purchases.' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumPurchaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Purchase Quantity' ;
    rdfs:comment 'The maximum number of bundle units a customer can purchase in a single transaction. Used to prevent stockouts and ensure fair distribution of limited-time offers.' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumPurchaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Purchase Quantity' ;
    rdfs:comment 'The minimum number of bundle units a customer must purchase in a single transaction. Typically 1, but may be higher for wholesale or bulk bundles.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingMethod rdf:type rdf:Property ;
    rdfs:label 'Pricing Method' ;
    rdfs:comment 'Defines how the bundle price is calculated: bundle_price (fixed price for entire bundle), component_sum (sum of individual component prices), discount_percentage (percentage off component sum), discount_amount (fixed dollar discount off component sum).' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionEligible rdf:type rdf:Property ;
    rdfs:label 'Promotion Eligible' ;
    rdfs:comment 'Indicates whether this bundle can be included in additional promotional offers or discounts beyond its configured bundle pricing.' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Return Policy Code' ;
    rdfs:comment 'Reference code to the specific return policy applicable to this bundle (e.g., standard 30-day, final sale, exchange only).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnable rdf:type rdf:Property ;
    rdfs:label 'Returnable' ;
    rdfs:comment 'Indicates whether the bundle can be returned. Some bundles (e.g., opened gift sets, perishable meal kits) may not be returnable.' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCrossReferenceId rdf:type rdf:Property ;
    rdfs:label 'Item Cross Reference Id' ;
    rdfs:comment 'Unique identifier for the item cross reference record. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItemCrossReference .

ind:internalSkuId rdf:type rdf:Property ;
    rdfs:label 'Internal Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: item_cross_reference.internal_sku (STRING) should be normalized to a proper FK. This table maps external system identifiers to internal SKUs - the internal_sku is the core link to the authoritative SK' ;
    rdfs:domain ind:ItemCrossReference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:supersededByReferenceItemCrossReferenceId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Reference Item Cross Reference Id' ;
    rdfs:comment 'The item_cross_reference_id of the newer mapping that replaces this one when status is superseded. Creates a chain of reference history for audit and troubleshooting.' ;
    rdfs:domain ind:ItemCrossReference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItemCrossReference .

ind:conversionFactor rdf:type rdf:Property ;
    rdfs:label 'Conversion Factor' ;
    rdfs:comment 'Numeric conversion factor used when the external system uses different units of measure than the internal system. For example, if internal system tracks in eaches but external system tracks in cases, this would be the case pack quantity.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossReferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Cross Reference Status' ;
    rdfs:comment 'Current lifecycle status of the cross reference mapping. Active indicates the mapping is currently in use, inactive means it is no longer valid, pending indicates awaiting approval, deprecated means phasing out, and superseded means replaced by a newer mapping.' ;
    rdfs:domain ind:ItemCrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossReferenceType rdf:type rdf:Property ;
    rdfs:label 'Cross Reference Type' ;
    rdfs:comment 'Classification of the cross reference relationship. Indicates the nature of the external identifier such as supplier part number, legacy item number from a retired system, marketplace ASIN for Amazon or other platforms, vendor-specific SKU, distributor code, or manufacturer code.' ;
    rdfs:domain ind:ItemCrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalItemDescription rdf:type rdf:Property ;
    rdfs:label 'External Item Description' ;
    rdfs:comment 'The item description as it appears in the external system. Useful for reconciliation and troubleshooting when descriptions differ across systems.' ;
    rdfs:domain ind:ItemCrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalItemNumber rdf:type rdf:Property ;
    rdfs:label 'External Item Number' ;
    rdfs:comment 'The item identifier used by the external system. This could be a supplier part number, legacy item code, marketplace ASIN, or system-specific SKU.' ;
    rdfs:domain ind:ItemCrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSystemInstance rdf:type rdf:Property ;
    rdfs:label 'External System Instance' ;
    rdfs:comment 'Specific instance or environment of the external system when multiple instances exist (e.g., SAP Production, SAP QA, ORMS US, ORMS EU). Helps disambiguate cross references when the same system is deployed in multiple regions or environments.' ;
    rdfs:domain ind:ItemCrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'External Unit Of Measure' ;
    rdfs:comment 'The unit of measure used by the external system for this item (e.g., EACH, CASE, PALLET, KG, LB). Used in conjunction with conversion factor for accurate quantity translation.' ;
    rdfs:domain ind:ItemCrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Internal Unit Of Measure' ;
    rdfs:comment 'The unit of measure used internally by the retailer for this item. Provides context for the conversion factor calculation.' ;
    rdfs:domain ind:ItemCrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryReference rdf:type rdf:Property ;
    rdfs:label 'Is Primary Reference' ;
    rdfs:comment 'Indicates whether this is the primary or preferred cross reference for the given external system. True means this is the authoritative mapping when multiple mappings exist for the same system.' ;
    rdfs:domain ind:ItemCrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mappingConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Mapping Confidence Score' ;
    rdfs:comment 'A score from 0 to 100 indicating the confidence level in the accuracy of this cross reference mapping. Higher scores indicate greater certainty. Used for automated mappings that may require validation.' ;
    rdfs:domain ind:ItemCrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mappingSource rdf:type rdf:Property ;
    rdfs:label 'Mapping Source' ;
    rdfs:comment 'Indicates how this cross reference mapping was created. Values include manual entry, EDI transaction, API integration, file import, system migration, supplier catalog load, or MDM system synchronization. [ENUM-REF-CANDIDATE: MANUAL|EDI|API|FILE_IMPORT|SYSTEM_MIGRATION|SUPPLIER_CATALOG|MDM — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ItemCrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerName rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Name' ;
    rdfs:comment 'Name of the trading partner organization associated with this cross reference. Provides human-readable context for the trading partner.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upcEanGtin rdf:type rdf:Property ;
    rdfs:label 'Upc Ean Gtin' ;
    rdfs:comment 'The standard barcode identifier (UPC, EAN, or GTIN) associated with this cross reference. Used for point-of-sale scanning and global product identification.' ;
    rdfs:domain ind:ItemCrossReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'The date when this cross reference mapping was last validated for accuracy. Used to track data quality assurance activities.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentHierarchyNodeItemHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Parent Hierarchy Node Item Hierarchy Id' ;
    rdfs:comment 'Foreign key reference to the parent node in the hierarchy tree. Self-referencing relationship enabling tree traversal and roll-up aggregations. Null for top-level division nodes.' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItemHierarchy .

ind:allowsDirectSkuAssignment rdf:type rdf:Property ;
    rdfs:label 'Allows Direct Sku Assignment' ;
    rdfs:comment 'Boolean flag indicating whether SKUs can be directly assigned to this hierarchy node. Typically True for leaf nodes (subcategory, segment, class) and False for parent nodes (division, department, category). Controls data quality and hierarchy integrity in PIM (Product Information Management) systems.' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoryManagerName rdf:type rdf:Property ;
    rdfs:label 'Category Manager Name' ;
    rdfs:comment 'Name of the category manager responsible for strategic category management, assortment optimization, and category P&L performance. Category managers define assortment breadth and depth targets and drive GMROI (Gross Margin Return on Investment).' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyDescription rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Description' ;
    rdfs:comment 'Detailed description of the hierarchy node purpose, scope, and business rules. Includes category definition, inclusion/exclusion criteria, and merchandising guidelines. Used for training, onboarding, and cross-functional alignment.' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyNodeName rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node Name' ;
    rdfs:comment 'Human-readable name of the hierarchy node. Examples: Electronics, Home Appliances, Televisions, 4K Smart TVs. Used in reporting, planograms, and category management dashboards.' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current lifecycle state of the hierarchy node. Active nodes are in use for assortment planning and reporting. Inactive nodes are temporarily disabled. Pending nodes are awaiting approval. Deprecated nodes are being phased out. Archived nodes are retained for historical reporting only.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownCadence rdf:type rdf:Property ;
    rdfs:label 'Markdown Cadence' ;
    rdfs:comment 'Frequency and timing of planned price markdowns for this category. Weekly and biweekly cadences support fast fashion and perishables. Monthly cadences support durable goods. Seasonal cadences align with end-of-season clearance. Event-driven markdowns respond to competitive pressure or excess inventory. Managed in Oracle Retail Price Management (RPM).' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omnichannelEnabled rdf:type rdf:Property ;
    rdfs:label 'Omnichannel Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this category is available across all channels (stores, e-commerce, mobile app, BOPIS, ship-from-store). True for omnichannel categories, False for channel-specific categories. Supports unified commerce strategy and cross-channel inventory visibility.' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannerName rdf:type rdf:Property ;
    rdfs:label 'Planner Name' ;
    rdfs:comment 'Name of the merchandise planner responsible for demand forecasting, inventory planning, and replenishment for this category. Planners use Blue Yonder Demand Planning to optimize inventory levels and minimize stockouts and overstock.' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelPenetrationTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Private Label Penetration Target Percent' ;
    rdfs:comment 'Target percentage of category sales from private label (store brand) products. Private label products typically offer higher margins than national brands. Used in assortment planning and supplier negotiations to optimize category profitability.' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentMethod rdf:type rdf:Property ;
    rdfs:label 'Replenishment Method' ;
    rdfs:comment 'Inventory replenishment method for this category. Auto uses system-driven replenishment based on demand forecasting. Manual requires planner intervention. Vendor Managed Inventory (VMI) delegates replenishment to suppliers. Cross-docking transfers inventory directly from receiving to shipping. Drop ship sends directly from vendor to customer.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockWeeks rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Weeks' ;
    rdfs:comment 'Target safety stock level expressed in weeks of supply (WOS). Buffer inventory to protect against demand variability and supply chain disruptions. Calculated based on service level targets and lead time variability in Blue Yonder Demand Planning.' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalityIndicator rdf:type rdf:Property ;
    rdfs:label 'Seasonality Indicator' ;
    rdfs:comment 'Seasonal demand pattern classification for this category. Non-seasonal categories have consistent year-round demand. Seasonal categories have predictable demand peaks tied to calendar periods. Used in demand forecasting, markdown planning, and inventory optimization. [ENUM-REF-CANDIDATE: non_seasonal|spring|summer|fall|winter|holiday|back_to_school — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicClassification rdf:type rdf:Property ;
    rdfs:label 'Strategic Classification' ;
    rdfs:comment 'Strategic role of the category in the overall merchandising strategy. Destination categories drive store traffic and differentiation. Routine categories are frequently purchased staples. Convenience categories are impulse or fill-in purchases. Seasonal categories have time-bound demand. Private label vs. national brand classification supports margin optimization.' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGrossMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Target Gross Margin Percent' ;
    rdfs:comment 'Target gross margin percentage for this category, expressed as a percentage of net sales. Used in pricing strategy, markdown planning, and category performance evaluation. Supports GMROI (Gross Margin Return on Investment) optimization.' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Item Lifecycle Event Id' ;
    rdfs:comment 'Unique identifier for each item lifecycle event record. Primary key for the item lifecycle event log.' ;
    rdfs:domain ind:ItemLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryItemAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Item Associate Id' ;
    rdfs:comment 'The system user identifier of the person or automated process that initiated this lifecycle event. Used for accountability and audit purposes.' ;
    rdfs:domain ind:ItemLifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:actualLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Actual Launch Date' ;
    rdfs:comment 'The actual date when the SKU became active and available for sale. Used to measure performance against target launch date and track new item setup SLA compliance.' ;
    rdfs:domain ind:ItemLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Compliance Reference Number' ;
    rdfs:comment 'External reference number for regulatory compliance documentation (e.g., FDA submission number, CPSC recall number). Supports audit trails for regulatory compliance.' ;
    rdfs:domain ind:ItemLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The lifecycle status of the SKU after this event was applied. Represents the current state following the transition. [ENUM-REF-CANDIDATE: draft|pending_approval|active|seasonal_inactive|markdown|clearance|discontinued — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ItemLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Status' ;
    rdfs:comment 'The lifecycle status of the SKU immediately before this event occurred. Enables tracking of state transitions and audit trails. [ENUM-REF-CANDIDATE: draft|pending_approval|active|seasonal_inactive|markdown|clearance|discontinued — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ItemLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether this lifecycle event was triggered by or requires regulatory compliance action (e.g., Food and Drug Administration (FDA) labeling change, Consumer Product Safety Commission (CPSC) recall, safety standard update).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestorName rdf:type rdf:Property ;
    rdfs:label 'Requestor Name' ;
    rdfs:comment 'The name of the person or team who originally requested this lifecycle event. Used for new item setup workflow tracking and accountability.' ;
    rdfs:domain ind:ItemLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingNotes rdf:type rdf:Property ;
    rdfs:label 'Supporting Notes' ;
    rdfs:comment 'Additional free-text notes and comments providing context, instructions, or documentation for this lifecycle event. Used for knowledge transfer and audit trail completeness.' ;
    rdfs:domain ind:ItemLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Target Launch Date' ;
    rdfs:comment 'The planned date for the SKU to become active and available for sale. Applicable primarily to new item introduction and seasonal activation events. Used for new item setup Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:ItemLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workflowStage rdf:type rdf:Property ;
    rdfs:label 'Workflow Stage' ;
    rdfs:comment 'The current stage in the new item setup or lifecycle change workflow. Tracks progression through the approval chain from initial submission to final approval or rejection.' ;
    rdfs:domain ind:ItemLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemNutritionalId rdf:type rdf:Property ;
    rdfs:label 'Item Nutritional Id' ;
    rdfs:comment 'Unique identifier for the nutritional information record. Primary key for the item nutritional data product.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validatedByAssociateId rdf:type rdf:Property ;
    rdfs:label 'Validated By Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Nutritional labeling requires validation by qualified associates (dietitians, compliance specialists) for FDA compliance, allergen accuracy, and regulatory audit trails. Critical for food safety, liab' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:addedSugarsG rdf:type rdf:Property ;
    rdfs:label 'Added Sugars G' ;
    rdfs:comment 'Added sugar content per serving measured in grams. Required under updated FDA nutrition facts label rules.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allergenDeclaration rdf:type rdf:Property ;
    rdfs:label 'Allergen Declaration' ;
    rdfs:comment 'Declaration of major food allergens present in the product. Must identify milk, eggs, fish, crustacean shellfish, tree nuts, peanuts, wheat, and soybeans per FALCPA requirements.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calciumMg rdf:type rdf:Property ;
    rdfs:label 'Calcium Mg' ;
    rdfs:comment 'Calcium content per serving measured in milligrams. Required under updated FDA nutrition facts label.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caloriesFromFat rdf:type rdf:Property ;
    rdfs:label 'Calories From Fat' ;
    rdfs:comment 'Number of calories derived from fat per serving. Optional field under updated FDA labeling rules.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:caloriesPerServing rdf:type rdf:Property ;
    rdfs:label 'Calories Per Serving' ;
    rdfs:comment 'Total caloric content per serving, measured in kilocalories (kcal). Required on FDA nutrition facts label.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cholesterolMg rdf:type rdf:Property ;
    rdfs:label 'Cholesterol Mg' ;
    rdfs:comment 'Cholesterol content per serving measured in milligrams. Required FDA nutrition facts component.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containsEggs rdf:type rdf:Property ;
    rdfs:label 'Contains Eggs' ;
    rdfs:comment 'Boolean flag indicating whether the product contains eggs or egg-derived ingredients. Supports allergen filtering and dietary restriction compliance.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containsFish rdf:type rdf:Property ;
    rdfs:label 'Contains Fish' ;
    rdfs:comment 'Boolean flag indicating whether the product contains fish or fish-derived ingredients. Supports allergen filtering and dietary restriction compliance.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containsMilk rdf:type rdf:Property ;
    rdfs:label 'Contains Milk' ;
    rdfs:comment 'Boolean flag indicating whether the product contains milk or milk-derived ingredients. Supports allergen filtering and dietary restriction compliance.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containsPeanuts rdf:type rdf:Property ;
    rdfs:label 'Contains Peanuts' ;
    rdfs:comment 'Boolean flag indicating whether the product contains peanuts or peanut-derived ingredients. Supports allergen filtering and dietary restriction compliance.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containsShellfish rdf:type rdf:Property ;
    rdfs:label 'Contains Shellfish' ;
    rdfs:comment 'Boolean flag indicating whether the product contains crustacean shellfish or shellfish-derived ingredients. Supports allergen filtering and dietary restriction compliance.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containsSoybeans rdf:type rdf:Property ;
    rdfs:label 'Contains Soybeans' ;
    rdfs:comment 'Boolean flag indicating whether the product contains soybeans or soy-derived ingredients. Supports allergen filtering and dietary restriction compliance.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containsTreeNuts rdf:type rdf:Property ;
    rdfs:label 'Contains Tree Nuts' ;
    rdfs:comment 'Boolean flag indicating whether the product contains tree nuts or tree nut-derived ingredients. Supports allergen filtering and dietary restriction compliance.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containsWheat rdf:type rdf:Property ;
    rdfs:label 'Contains Wheat' ;
    rdfs:comment 'Boolean flag indicating whether the product contains wheat or wheat-derived ingredients. Supports allergen filtering and dietary restriction compliance.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dietaryFiberG rdf:type rdf:Property ;
    rdfs:label 'Dietary Fiber G' ;
    rdfs:comment 'Dietary fiber content per serving measured in grams. Required FDA nutrition facts component.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingredientStatement rdf:type rdf:Property ;
    rdfs:label 'Ingredient Statement' ;
    rdfs:comment 'Complete list of ingredients in descending order of predominance by weight as required by FDA labeling regulations. Includes sub-ingredients for compound ingredients.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ironMg rdf:type rdf:Property ;
    rdfs:label 'Iron Mg' ;
    rdfs:comment 'Iron content per serving measured in milligrams. Required under updated FDA nutrition facts label.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isGlutenFree rdf:type rdf:Property ;
    rdfs:label 'Is Gluten Free' ;
    rdfs:comment 'Boolean flag indicating whether the product meets FDA gluten-free labeling standards (less than 20 ppm gluten). Supports dietary restriction filtering.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHalalCertified rdf:type rdf:Property ;
    rdfs:label 'Is Halal Certified' ;
    rdfs:comment 'Boolean flag indicating whether the product is certified halal by a recognized halal certification body. Supports dietary and religious preference filtering.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKosherCertified rdf:type rdf:Property ;
    rdfs:label 'Is Kosher Certified' ;
    rdfs:comment 'Boolean flag indicating whether the product is certified kosher by a recognized kosher certification agency. Supports dietary and religious preference filtering.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNonGmoVerified rdf:type rdf:Property ;
    rdfs:label 'Is Non Gmo Verified' ;
    rdfs:comment 'Boolean flag indicating whether the product is verified as non-GMO by the Non-GMO Project or equivalent verification program. Supports dietary preference filtering.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrganicCertified rdf:type rdf:Property ;
    rdfs:label 'Is Organic Certified' ;
    rdfs:comment 'Boolean flag indicating whether the product is certified organic by USDA or equivalent certifying body. Supports organic product filtering and merchandising.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVegan rdf:type rdf:Property ;
    rdfs:label 'Is Vegan' ;
    rdfs:comment 'Boolean flag indicating whether the product contains no animal-derived ingredients or by-products. Supports dietary preference filtering.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVegetarian rdf:type rdf:Property ;
    rdfs:label 'Is Vegetarian' ;
    rdfs:comment 'Boolean flag indicating whether the product contains no meat, poultry, or fish ingredients. May contain dairy or eggs. Supports dietary preference filtering.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monounsaturatedFatG rdf:type rdf:Property ;
    rdfs:label 'Monounsaturated Fat G' ;
    rdfs:comment 'Monounsaturated fat content per serving measured in grams. Optional voluntary declaration.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nutritionalDataEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Nutritional Data Effective Date' ;
    rdfs:comment 'Date when this nutritional information became effective for the product. Supports version control and regulatory compliance tracking.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nutritionalDataExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Nutritional Data Expiration Date' ;
    rdfs:comment 'Date when this nutritional information expires or is superseded by updated data. Null if currently active. Supports version control and compliance tracking.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nutritionalDataSource rdf:type rdf:Property ;
    rdfs:label 'Nutritional Data Source' ;
    rdfs:comment 'Source of the nutritional information (laboratory analysis, USDA database, supplier-provided, calculated from ingredients, third-party database). Supports data quality and compliance auditing.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicCertificationBody rdf:type rdf:Property ;
    rdfs:label 'Organic Certification Body' ;
    rdfs:comment 'Name of the organization that certified the product as organic (e.g., USDA, CCOF, Oregon Tilth). Null if product is not organic certified.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:polyunsaturatedFatG rdf:type rdf:Property ;
    rdfs:label 'Polyunsaturated Fat G' ;
    rdfs:comment 'Polyunsaturated fat content per serving measured in grams. Optional voluntary declaration.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:potassiumMg rdf:type rdf:Property ;
    rdfs:label 'Potassium Mg' ;
    rdfs:comment 'Potassium content per serving measured in milligrams. Required under updated FDA nutrition facts label.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proteinG rdf:type rdf:Property ;
    rdfs:label 'Protein G' ;
    rdfs:comment 'Protein content per serving measured in grams. Required FDA nutrition facts component.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saturatedFatG rdf:type rdf:Property ;
    rdfs:label 'Saturated Fat G' ;
    rdfs:comment 'Saturated fat content per serving measured in grams. Required FDA nutrition facts component.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:servingSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Serving Size Unit' ;
    rdfs:comment 'Unit of measure for the serving size (grams, milliliters, ounces, cups, pieces, etc.). [ENUM-REF-CANDIDATE: g|mg|kg|ml|l|oz|fl oz|cup|tbsp|tsp|piece|slice|container — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servingSizeValue rdf:type rdf:Property ;
    rdfs:label 'Serving Size Value' ;
    rdfs:comment 'Numeric value representing the standard serving size for this product as defined by FDA regulations.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:servingsPerContainer rdf:type rdf:Property ;
    rdfs:label 'Servings Per Container' ;
    rdfs:comment 'Number of servings contained in the package. May be approximate for variable-weight items.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sodiumMg rdf:type rdf:Property ;
    rdfs:label 'Sodium Mg' ;
    rdfs:comment 'Sodium content per serving measured in milligrams. Required FDA nutrition facts component.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCarbohydrateG rdf:type rdf:Property ;
    rdfs:label 'Total Carbohydrate G' ;
    rdfs:comment 'Total carbohydrate content per serving measured in grams. Includes dietary fiber, sugars, and other carbohydrates.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFatG rdf:type rdf:Property ;
    rdfs:label 'Total Fat G' ;
    rdfs:comment 'Total fat content per serving measured in grams. Includes saturated, trans, monounsaturated, and polyunsaturated fats.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSugarsG rdf:type rdf:Property ;
    rdfs:label 'Total Sugars G' ;
    rdfs:comment 'Total sugar content per serving measured in grams. Includes naturally occurring and added sugars.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transFatG rdf:type rdf:Property ;
    rdfs:label 'Trans Fat G' ;
    rdfs:comment 'Trans fat content per serving measured in grams. Must be declared per FDA regulations.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vitaminDMcg rdf:type rdf:Property ;
    rdfs:label 'Vitamin D Mcg' ;
    rdfs:comment 'Vitamin D content per serving measured in micrograms. Required under updated FDA nutrition facts label.' ;
    rdfs:domain ind:ItemNutritional ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemVariantId rdf:type rdf:Property ;
    rdfs:label 'Item Variant Id' ;
    rdfs:comment 'Unique identifier for the item variant relationship record. Primary key.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryItemSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Item Sku Id' ;
    rdfs:comment 'Reference to the parent or source SKU in the variant or substitution relationship. For variant relationships, this is the parent style or base item. For substitution relationships, this is the original SKU being substituted.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:targetItemSkuId rdf:type rdf:Property ;
    rdfs:label 'Target Item Sku Id' ;
    rdfs:comment 'Reference to the child or target SKU in the variant or substitution relationship. For variant relationships, this is the child SKU (specific size, color, flavor). For substitution relationships, this is the replacement SKU.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:autoSubstituteFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Substitute Flag' ;
    rdfs:comment 'Indicates whether this substitution can be applied automatically by fulfillment systems without manual intervention. True enables automatic substitution during picking when the source item is out of stock. False requires manual approval or customer consent.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerConsentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Consent Required Flag' ;
    rdfs:comment 'Indicates whether explicit customer consent is required before applying this substitution. True means the customer must approve the substitution (e.g., for price upgrades or significant product differences). False means the substitution can be applied automatically (e.g., for equivalent items). Applicable primarily for substitution relationships.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displaySequence rdf:type rdf:Property ;
    rdfs:label 'Display Sequence' ;
    rdfs:comment 'Numeric order for displaying variants in e-commerce product pages, mobile apps, and digital catalogs. Lower numbers appear first. Used to control the presentation order of size-color grids and variant selectors.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryInterchangeableFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Interchangeable Flag' ;
    rdfs:comment 'Indicates whether the source and target items can be treated as interchangeable for inventory allocation and fulfillment purposes. True means inventory of either item can fulfill demand for the other. False means they must be tracked separately. Relevant for substitution relationships.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceDifferentialAmount rdf:type rdf:Property ;
    rdfs:label 'Price Differential Amount' ;
    rdfs:comment 'The price difference between the source and target items. Positive values indicate the target is more expensive (upgrade). Negative values indicate the target is less expensive (downgrade). Zero or null indicates equivalent pricing. Used for substitution cost impact analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current lifecycle status of the variant or substitution relationship. Active means the relationship is in use. Inactive means temporarily disabled. Pending means awaiting approval or activation. Discontinued means permanently retired.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Type of relationship between source and target items. Variant indicates parent-child SKU relationship (e.g., style to size-color). Substitution indicates approved replacement for out-of-stock scenarios. Cross-sell and upsell support merchandising. Bundle and accessory support product associations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Substitution Priority Rank' ;
    rdfs:comment 'Numeric rank indicating the priority order for substitution when multiple substitutes are available. Lower numbers indicate higher priority. Used by fulfillment systems to select the best substitute when the source item is out of stock.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substitutionType rdf:type rdf:Property ;
    rdfs:label 'Substitution Type' ;
    rdfs:comment 'Classification of the substitution relationship. Equivalent indicates same quality and price point. Upgrade indicates higher quality or price. Downgrade indicates lower quality or price. Alternative indicates different but acceptable replacement. Applicable only when relationship_type is substitution.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantDimensionType rdf:type rdf:Property ;
    rdfs:label 'Variant Dimension Type' ;
    rdfs:comment 'The dimension along which the variant differs from the parent item. Applicable only when relationship_type is variant. Examples: size for apparel, flavor for beverages, scent for personal care, pack configuration for multi-packs. [ENUM-REF-CANDIDATE: size|color|flavor|scent|pack_configuration|material|style|fit|length|width — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantDimensionValue rdf:type rdf:Property ;
    rdfs:label 'Variant Dimension Value' ;
    rdfs:comment 'The specific value of the variant dimension for the target item. Examples: Small, Medium, Large for size; Red, Blue, Green for color; Vanilla, Chocolate for flavor; 6-pack, 12-pack for pack configuration.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variantEan rdf:type rdf:Property ;
    rdfs:label 'Variant Ean' ;
    rdfs:comment 'The 13-digit EAN barcode assigned to the target variant item. Used internationally for product identification and scanning. Common in European and global retail operations.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantGroupCode rdf:type rdf:Property ;
    rdfs:label 'Variant Group Code' ;
    rdfs:comment 'A code that groups related variants together under a common parent style or product family. Used to aggregate sales, inventory, and performance metrics across all variants of a base item. Supports category management and assortment planning.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantGtin rdf:type rdf:Property ;
    rdfs:label 'Variant Gtin' ;
    rdfs:comment 'The Global Trade Item Number assigned to the target variant item. GTIN is the umbrella term for UPC, EAN, and other GS1 product identifiers. Used for global supply chain and EDI transactions.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantUpc rdf:type rdf:Property ;
    rdfs:label 'Variant Upc' ;
    rdfs:comment 'The 12-digit UPC barcode assigned to the target variant item. Used for point-of-sale scanning and inventory tracking. Each variant SKU typically has its own unique UPC.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributeId rdf:type rdf:Property ;
    rdfs:label 'Attribute Id' ;
    rdfs:comment 'Unique identifier for the product attribute record. Primary key for the product_attribute entity.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributeGroup rdf:type rdf:Property ;
    rdfs:label 'Attribute Group' ;
    rdfs:comment 'Logical grouping or category of the attribute (e.g., \'physical\', \'technical\', \'descriptive\', \'nutritional\', \'environmental\', \'regulatory\', \'marketing\', \'quality\', \'packaging\', \'pricing\'). Enables faceted search and attribute organization in PIM systems. [ENUM-REF-CANDIDATE: physical|technical|descriptive|nutritional|environmental|regulatory|marketing|quality|packaging|pricing — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributeName rdf:type rdf:Property ;
    rdfs:label 'Attribute Name' ;
    rdfs:comment 'The name or label of the product attribute (e.g., \'color\', \'size\', \'fabric\', \'flavor\', \'wattage\', \'nutritional_info\'). Represents the semantic key in the entity-attribute-value (EAV) pattern.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributeStatus rdf:type rdf:Property ;
    rdfs:label 'Attribute Status' ;
    rdfs:comment 'Current lifecycle status of this attribute record (e.g., \'active\', \'inactive\', \'pending_approval\', \'deprecated\', \'archived\'). Supports attribute governance and PIM workflow management.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributeValue rdf:type rdf:Property ;
    rdfs:label 'Attribute Value' ;
    rdfs:comment 'The actual value of the product attribute (e.g., \'Red\', \'Large\', \'100% Cotton\', \'Vanilla\', \'60W\', \'15g protein per serving\'). Stores the descriptive, technical, or measurement data for the attribute.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isComparable rdf:type rdf:Property ;
    rdfs:label 'Is Comparable' ;
    rdfs:comment 'Boolean flag indicating whether this attribute should be displayed in product comparison views (True) or not (False). Supports side-by-side product comparison features in e-commerce.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryRequired rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Required' ;
    rdfs:comment 'Boolean flag indicating whether this attribute is required by regulatory or legal mandate (e.g., FDA nutritional labeling, CPSC safety warnings, FTC advertising disclosures). True if mandated, False otherwise.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRequired rdf:type rdf:Property ;
    rdfs:label 'Is Required' ;
    rdfs:comment 'Boolean flag indicating whether this attribute is mandatory for the product (True) or optional (False). Used for data completeness scoring and GS1 GDSN readiness checks.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationRule rdf:type rdf:Property ;
    rdfs:label 'Validation Rule' ;
    rdfs:comment 'Business rule or regex pattern used to validate the attribute value (e.g., \'must be positive integer\', \'must match color palette\', \'must be ISO 8601 date\'). Enforces data quality at attribute capture time.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Average Margin Percent' ;
    rdfs:comment 'Average gross margin percentage achieved across all SKUs (Stock Keeping Units) under this brand. Calculated as (Average Unit Retail - Cost of Goods Sold) / Average Unit Retail * 100. Critical for brand profitability analysis and private label vs. national brand comparison.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandDescription rdf:type rdf:Property ;
    rdfs:label 'Brand Description' ;
    rdfs:comment 'Detailed narrative describing the brand positioning, value proposition, target customer segment, and key differentiators. Used for internal merchandising guidance and external marketing content.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOriginCode rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the primary country where products under this brand are manufactured or sourced. Required for customs compliance and consumer transparency.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLicensed rdf:type rdf:Property ;
    rdfs:label 'Is Licensed' ;
    rdfs:comment 'Boolean flag indicating whether this brand operates under a licensing agreement using third-party intellectual property (e.g., character brands, celebrity brands, sports team brands). True for licensed brands, false otherwise. Impacts royalty payments and contract management.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'License Expiration Date' ;
    rdfs:comment 'Date when the licensing agreement for this brand expires. Null for non-licensed brands. Used for contract renewal planning and inventory liquidation strategy for expiring licenses.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:logoAssetUrl rdf:type rdf:Property ;
    rdfs:label 'Logo Asset Url' ;
    rdfs:comment 'Reference URL or path to the digital brand logo asset stored in the Product Information Management (PIM) or Digital Asset Management (DAM) system. Used for e-commerce product pages, marketing materials, and mobile app display.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerCountryCode rdf:type rdf:Property ;
    rdfs:label 'Owner Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country where the brand owner is headquartered. Used for country-of-origin reporting and supplier diversity analytics.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioGroup rdf:type rdf:Property ;
    rdfs:label 'Portfolio Group' ;
    rdfs:comment 'Higher-level grouping of related brands under a common portfolio or brand family. Enables portfolio-level margin analysis, vendor negotiations, and strategic assortment planning across brand families.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Internal quality assessment score for the brand based on product defect rates, customer returns, and quality audits. Scale of 0.00 to 5.00. Used for vendor scorecard evaluation and assortment quality management.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnRatePercent rdf:type rdf:Property ;
    rdfs:label 'Return Rate Percent' ;
    rdfs:comment 'Percentage of units sold under this brand that are returned by customers. Calculated as (units returned / units sold) * 100. High return rates may indicate quality issues or misaligned customer expectations.' ;
    rdfs:domain ind:ProductBrand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityCertification rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification' ;
    rdfs:comment 'Environmental or social responsibility certifications held by the brand (e.g., Fair Trade, Organic, B Corp, Carbon Neutral). Supports ESG reporting and consumer filtering on e-commerce platforms for sustainable products.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productComplianceId rdf:type rdf:Property ;
    rdfs:label 'Product Compliance Id' ;
    rdfs:comment 'Unique identifier for the product compliance record. Primary key.' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedCarrierServiceId rdf:type rdf:Property ;
    rdfs:label 'Approved Carrier Service Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.carrier_service. Business justification: Specific carrier service levels have distinct compliance capabilities (e.g., ground hazmat vs air hazmat, refrigerated vs ambient). Retail compliance teams pre-approve specific carrier services for re' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierService .

ind:fulfillmentCarrierId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Carrier Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.carrier. Business justification: Retail operations require matching product compliance requirements (hazmat certification, temperature control, age-restricted handling) to carrier capabilities. Hazmat-certified products can only ship' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:officerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Officer Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Regulatory compliance management requires designated compliance officers (associates) responsible for maintaining certifications, audit records, and regulatory submissions. Essential for FDA, CPSC, an' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:ageRestrictionRequired rdf:type rdf:Property ;
    rdfs:label 'Age Restriction Required' ;
    rdfs:comment 'Indicates whether the product requires age verification at point of sale due to regulatory restrictions (e.g., alcohol, tobacco, certain chemicals).' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenDeclarationCompliant rdf:type rdf:Property ;
    rdfs:label 'Allergen Declaration Compliant' ;
    rdfs:comment 'Indicates whether the product labeling complies with allergen disclosure requirements (e.g., contains milk, eggs, peanuts, tree nuts, fish, shellfish, soy, wheat).' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceType rdf:type rdf:Property ;
    rdfs:label 'Compliance Type' ;
    rdfs:comment 'Category of regulatory compliance requirement (e.g., food safety, product safety, hazardous material classification, age restriction, import/export, labeling, environmental). [ENUM-REF-CANDIDATE: food_safety|product_safety|hazmat|age_restriction|import_export|labeling|environmental — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOriginCompliant rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Compliant' ;
    rdfs:comment 'Indicates whether the product labeling meets country-of-origin marking requirements for customs and consumer disclosure.' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fdaFoodFacilityRegistration rdf:type rdf:Property ;
    rdfs:label 'Fda Food Facility Registration' ;
    rdfs:comment 'FDA registration number for the manufacturing facility where food products are produced. Required for food safety compliance. Null for non-food items.' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatClassification rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classification' ;
    rdfs:comment 'Classification code for hazardous materials according to transportation and storage regulations (e.g., UN number, DOT hazard class). Null if product is not hazardous.' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Import License Number' ;
    rdfs:comment 'Government-issued import license or permit number required for cross-border trade of regulated products. Null if not applicable.' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAgeYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Age Years' ;
    rdfs:comment 'Minimum age in years required to purchase this product. Null if no age restriction applies.' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nutritionLabelingCompliant rdf:type rdf:Property ;
    rdfs:label 'Nutrition Labeling Compliant' ;
    rdfs:comment 'Indicates whether the product meets FDA nutrition labeling requirements (Nutrition Facts panel). Applicable to food and beverage products.' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organicCertification rdf:type rdf:Property ;
    rdfs:label 'Organic Certification' ;
    rdfs:comment 'Organic certification number or designation (e.g., USDA Organic, EU Organic). Null if product is not certified organic.' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prop65ChemicalList rdf:type rdf:Property ;
    rdfs:label 'Prop 65 Chemical List' ;
    rdfs:comment 'Comma-separated list of Prop 65 chemicals present in the product that trigger warning requirements. Null if no Prop 65 warning required.' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prop65WarningRequired rdf:type rdf:Property ;
    rdfs:label 'Prop 65 Warning Required' ;
    rdfs:comment 'Indicates whether the product requires a California Prop 65 warning label due to presence of chemicals known to cause cancer, birth defects, or reproductive harm.' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallDate rdf:type rdf:Property ;
    rdfs:label 'Recall Date' ;
    rdfs:comment 'Date when the product recall was initiated. Null if no recall has been issued.' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallReason rdf:type rdf:Property ;
    rdfs:label 'Recall Reason' ;
    rdfs:comment 'Detailed explanation of the reason for the product recall (e.g., contamination, safety hazard, labeling error). Null if no recall.' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallSeverityLevel rdf:type rdf:Property ;
    rdfs:label 'Recall Severity Level' ;
    rdfs:comment 'FDA classification of recall severity: Class 1 (serious health hazard or death), Class 2 (temporary health problem), Class 3 (unlikely to cause adverse health effects). Null if no recall.' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallStatus rdf:type rdf:Property ;
    rdfs:label 'Recall Status' ;
    rdfs:comment 'Current recall status of the product indicating whether it is subject to a safety or quality recall.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyContact rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Contact' ;
    rdfs:comment 'Contact information (phone or email) for the responsible party. Used for regulatory inquiries and recall coordination.' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Tariff Classification Code' ;
    rdfs:comment 'Harmonized Tariff Schedule (HTS) code used for customs classification and duty calculation for imported products.' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReportNumber rdf:type rdf:Property ;
    rdfs:label 'Test Report Number' ;
    rdfs:comment 'Unique identifier for the compliance test report issued by the testing laboratory. Null if no test report available.' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingLaboratory rdf:type rdf:Property ;
    rdfs:label 'Testing Laboratory' ;
    rdfs:comment 'Name of the accredited third-party laboratory that conducted compliance testing (e.g., UL, Intertek, SGS, Bureau Veritas). Null if no third-party testing performed.' ;
    rdfs:domain ind:ProductCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imageId rdf:type rdf:Property ;
    rdfs:label 'Image Id' ;
    rdfs:comment 'Unique identifier for the product image asset record.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uploadedByAssociateId rdf:type rdf:Property ;
    rdfs:label 'Uploaded By Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Retail digital asset management requires tracking which associate uploaded/approved each product image for content workflow, quality control, audit trails, and accountability. Critical for e-commerce ' ;
    rdfs:domain ind:Image ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:aspectRatio rdf:type rdf:Property ;
    rdfs:label 'Aspect Ratio' ;
    rdfs:comment 'The proportional relationship between width and height (e.g., 1:1, 4:3, 16:9). Used for responsive design and layout planning.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundColor rdf:type rdf:Property ;
    rdfs:label 'Background Color' ;
    rdfs:comment 'The hexadecimal color code of the image background (e.g., #FFFFFF for white). Used for consistent product presentation and dynamic background replacement.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caption rdf:type rdf:Property ;
    rdfs:label 'Caption' ;
    rdfs:comment 'Optional marketing or descriptive caption displayed alongside the image in certain contexts (e.g., lifestyle images with usage tips).' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnAssetReference rdf:type rdf:Property ;
    rdfs:label 'Cdn Asset Reference' ;
    rdfs:comment 'The unique identifier or key used by the Content Delivery Network to cache and serve this image asset globally.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorProfile rdf:type rdf:Property ;
    rdfs:label 'Color Profile' ;
    rdfs:comment 'The color space or profile used in the image (sRGB, Adobe RGB, ProPhoto RGB, CMYK). Critical for color accuracy across web, print, and in-store displays.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copyrightHolder rdf:type rdf:Property ;
    rdfs:label 'Copyright Holder' ;
    rdfs:comment 'The legal entity or individual who holds the copyright to this image asset. Critical for rights management and legal compliance.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpi rdf:type rdf:Property ;
    rdfs:label 'Dpi' ;
    rdfs:comment 'The resolution of the image in dots per inch. Typically 72 DPI for web and 300 DPI for print. Used to determine print quality suitability.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'The digital file format of the image asset (JPEG, PNG, GIF, WEBP, SVG, TIFF).' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasTransparency rdf:type rdf:Property ;
    rdfs:label 'Has Transparency' ;
    rdfs:comment 'Boolean flag indicating whether the image contains transparent pixels (alpha channel). Relevant for PNG and GIF formats used in layered designs.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imageType rdf:type rdf:Property ;
    rdfs:label 'Image Type' ;
    rdfs:comment 'Classification of the image purpose: hero (primary product shot), alternate (additional angles), swatch (color/material sample), lifestyle (in-use context), packaging (box/container), detail (close-up feature).' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileOptimized rdf:type rdf:Property ;
    rdfs:label 'Mobile Optimized' ;
    rdfs:comment 'Boolean flag indicating whether this image has been optimized for mobile device display (compressed, resized, or formatted for mobile bandwidth and screen size).' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photographerCredit rdf:type rdf:Property ;
    rdfs:label 'Photographer Credit' ;
    rdfs:comment 'Attribution to the photographer or content creator who produced the image. Used for rights management and licensing compliance.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramEligible rdf:type rdf:Property ;
    rdfs:label 'Planogram Eligible' ;
    rdfs:comment 'Boolean flag indicating whether this image is suitable for use in planogram design and shelf layout planning. Typically requires consistent background and perspective.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:printReady rdf:type rdf:Property ;
    rdfs:label 'Print Ready' ;
    rdfs:comment 'Boolean flag indicating whether this image meets the resolution and color profile requirements for print media (catalogs, circulars, in-store signage).' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'A computed or manually assigned quality score (0.00 to 5.00) representing the technical and aesthetic quality of the image. Used for quality control and merchandising decisions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionHeight rdf:type rdf:Property ;
    rdfs:label 'Resolution Height' ;
    rdfs:comment 'The height of the image in pixels. Used to determine image quality and suitability for different channels (web, mobile, print).' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionWidth rdf:type rdf:Property ;
    rdfs:label 'Resolution Width' ;
    rdfs:comment 'The width of the image in pixels. Used to determine image quality and suitability for different channels (web, mobile, print).' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seoKeywords rdf:type rdf:Property ;
    rdfs:label 'Seo Keywords' ;
    rdfs:comment 'Comma-separated list of keywords associated with this image for search engine optimization and internal search relevance.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'The display order of this image within the product\'s image gallery. Lower numbers appear first in the carousel or gallery view.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uploadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upload Timestamp' ;
    rdfs:comment 'The date and time when this image was first uploaded to the digital asset management system.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:usageRightsNotes rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Notes' ;
    rdfs:comment 'Free-text field capturing any special terms, restrictions, or notes regarding the usage rights of this image (e.g., geographic restrictions, channel limitations, attribution requirements).' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorImageCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Image Code' ;
    rdfs:comment 'The unique identifier assigned to this image by the vendor or supplier who provided it. Used for cross-reference and vendor collaboration.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewAngle rdf:type rdf:Property ;
    rdfs:label 'View Angle' ;
    rdfs:comment 'The perspective or angle from which the product is photographed (front, back, left, right, top, bottom, angle). Helps customers understand product dimensions and features. [ENUM-REF-CANDIDATE: front|back|left|right|top|bottom|angle — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoomEnabled rdf:type rdf:Property ;
    rdfs:label 'Zoom Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this image supports zoom functionality on the e-commerce platform. High-resolution images typically enable zoom for detailed product inspection.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallId rdf:type rdf:Property ;
    rdfs:label 'Recall Id' ;
    rdfs:comment 'Unique identifier for the product recall event. Primary key for the product recall record.' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coordinatorAssociateId rdf:type rdf:Property ;
    rdfs:label 'Coordinator Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Product recall management requires designated recall coordinators to manage regulatory notifications, customer communications, and recovery operations. Critical for FDA/CPSC compliance and liability m' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:affectedDateRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Affected Date Range End' ;
    rdfs:comment 'End date of the production or distribution period for affected products. Used to identify inventory within the recall scope.' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedDateRangeStart rdf:type rdf:Property ;
    rdfs:label 'Affected Date Range Start' ;
    rdfs:comment 'Start date of the production or distribution period for affected products. Used to identify inventory within the recall scope.' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedLotNumbers rdf:type rdf:Property ;
    rdfs:label 'Affected Lot Numbers' ;
    rdfs:comment 'Comma-separated list of production lot numbers or batch codes affected by the recall. Used to identify specific inventory units.' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinatorEmail rdf:type rdf:Property ;
    rdfs:label 'Coordinator Email' ;
    rdfs:comment 'Email address of the recall coordinator for internal and external communication regarding the recall event.' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinatorPhone rdf:type rdf:Property ;
    rdfs:label 'Coordinator Phone' ;
    rdfs:comment 'Phone number of the recall coordinator for urgent communication and escalation regarding the recall event.' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Method' ;
    rdfs:comment 'Comma-separated list of methods used to notify customers of the recall: email, direct mail, phone, in-store signage, website, social media, press release.' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFinancialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact Amount' ;
    rdfs:comment 'Estimated total financial impact of the recall in USD, including product costs, logistics, customer remedies, and regulatory penalties.' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiationDate rdf:type rdf:Property ;
    rdfs:label 'Initiation Date' ;
    rdfs:comment 'Date when the recall was officially initiated and communicated to internal teams and external stakeholders.' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pressReleaseUrl rdf:type rdf:Property ;
    rdfs:label 'Press Release Url' ;
    rdfs:comment 'URL link to the official press release or public announcement document for the recall event, hosted on company or regulatory body website.' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicAnnouncementDate rdf:type rdf:Property ;
    rdfs:label 'Public Announcement Date' ;
    rdfs:comment 'Date when the recall was publicly announced through press releases, website postings, or regulatory body publications.' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Detailed description of the reason for the recall, including safety hazard, contamination, labeling error, or quality defect.' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallClass rdf:type rdf:Property ;
    rdfs:label 'Recall Class' ;
    rdfs:comment 'FDA recall classification indicating severity: Class I (serious health hazard or death), Class II (temporary health problem), Class III (unlikely to cause adverse health reaction).' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallScope rdf:type rdf:Property ;
    rdfs:label 'Recall Scope' ;
    rdfs:comment 'Geographic scope of the recall: national (all locations), regional (specific regions or states), or store-specific (individual store locations).' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallType rdf:type rdf:Property ;
    rdfs:label 'Recall Type' ;
    rdfs:comment 'Classification of the recall action: mandatory (regulatory-mandated), voluntary (company-initiated), or market withdrawal (removal without regulatory involvement).' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryRatePercent rdf:type rdf:Property ;
    rdfs:label 'Recovery Rate Percent' ;
    rdfs:comment 'Percentage of affected units successfully recovered, calculated as (units_recovered / units_affected) * 100. Key performance indicator for recall effectiveness.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'External recall reference number assigned by regulatory body or internal quality team. Used for tracking and reporting to CPSC, FDA, or other governing bodies.' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Case Number' ;
    rdfs:comment 'Case or docket number assigned by the regulatory body (CPSC, FDA) for tracking and official correspondence related to the recall.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remedyType rdf:type rdf:Property ;
    rdfs:label 'Remedy Type' ;
    rdfs:comment 'Type of remedy offered to customers for the recalled product: refund (money back), replacement (new product), repair (fix defect), or disposal (safe destruction).' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Summary of the root cause analysis findings identifying the underlying cause of the product defect or safety issue that triggered the recall.' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsAffected rdf:type rdf:Property ;
    rdfs:label 'Units Affected' ;
    rdfs:comment 'Total number of product units subject to the recall across all channels (stores, distribution centers, customer hands).' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsInCustomerHands rdf:type rdf:Property ;
    rdfs:label 'Units In Customer Hands' ;
    rdfs:comment 'Estimated number of recalled units that were sold to customers and remain outstanding (not yet returned or recovered).' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsRecovered rdf:type rdf:Property ;
    rdfs:label 'Units Recovered' ;
    rdfs:comment 'Number of recalled product units successfully recovered from stores, distribution centers, and customers through return or disposal.' ;
    rdfs:domain ind:Recall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cube rdf:type rdf:Property ;
    rdfs:label 'Cube' ;
    rdfs:comment 'Cubic volume of the SKU package calculated as length × width × height. Used for warehouse space planning and transportation optimization. Measured in cubic feet or cubic meters.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dimensionUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Dimension Unit Of Measure' ;
    rdfs:comment 'Unit of measure for length, width, and height fields. IN (Inch), CM (Centimeter), FT (Foot), M (Meter).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeight rdf:type rdf:Property ;
    rdfs:label 'Gross Weight' ;
    rdfs:comment 'Total weight of the SKU including packaging, measured in the unit specified by weight_unit_of_measure. Used for shipping and logistics calculations.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hi rdf:type rdf:Property ;
    rdfs:label 'Hi' ;
    rdfs:comment 'Number of layers (tiers) that can be stacked on a pallet. Part of the Ti-Hi pallet configuration used in warehouse and distribution center operations.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalItemNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Item Number' ;
    rdfs:comment 'Retailer-specific internal product identifier used in legacy systems and internal operations. May differ from external GTIN/UPC.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:length rdf:type rdf:Property ;
    rdfs:label 'Length' ;
    rdfs:comment 'Length dimension of the SKU package, measured in the unit specified by dimension_unit_of_measure. Used for space planning and logistics.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumAgeRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Age Requirement' ;
    rdfs:comment 'Minimum age in years required to purchase this SKU. Null if no age restriction applies. Typically 18 or 21 for restricted products.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netWeight rdf:type rdf:Property ;
    rdfs:label 'Net Weight' ;
    rdfs:comment 'Weight of the product contents excluding packaging, measured in the unit specified by weight_unit_of_measure. Used for regulatory compliance and consumer information.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skuDescription rdf:type rdf:Property ;
    rdfs:label 'Sku Description' ;
    rdfs:comment 'Detailed textual description of the SKU including key product attributes, features, and specifications. Used for product information management and customer-facing displays.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRequirement rdf:type rdf:Property ;
    rdfs:label 'Temperature Requirement' ;
    rdfs:comment 'Storage and transportation temperature requirement for the SKU. AMBIENT (room temperature), REFRIGERATED (32-40°F), FROZEN (below 0°F), CONTROLLED (specific temperature range).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ti rdf:type rdf:Property ;
    rdfs:label 'Ti' ;
    rdfs:comment 'Number of units per layer on a pallet. Part of the Ti-Hi pallet configuration used in warehouse and distribution center operations.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorItemNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Item Number' ;
    rdfs:comment 'The supplier\'s own product identifier for this SKU. Used for purchase orders and vendor communication.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volume rdf:type rdf:Property ;
    rdfs:label 'Volume' ;
    rdfs:comment 'Volume or capacity of the product, measured in the unit specified by volume_unit_of_measure. Relevant for liquid and bulk products.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Volume Unit Of Measure' ;
    rdfs:comment 'Unit of measure for volume field. GAL (Gallon), LTR (Liter), ML (Milliliter), OZ (Fluid Ounce), QT (Quart).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Weight Unit Of Measure' ;
    rdfs:comment 'Unit of measure for gross_weight and net_weight fields. LB (Pound), KG (Kilogram), OZ (Ounce), G (Gram).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gs1UomCode rdf:type rdf:Property ;
    rdfs:label 'Gs1 Uom Code' ;
    rdfs:comment 'Standardized GS1 unit of measure code used for Electronic Data Interchange (EDI) and global supply chain interoperability. Maps internal UOM codes to GS1 standards.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inverseConversionFactor rdf:type rdf:Property ;
    rdfs:label 'Inverse Conversion Factor' ;
    rdfs:comment 'Reciprocal of the conversion factor, used for reverse conversions from base unit to this unit. Calculated as 1 divided by conversion_factor.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFractionalAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Fractional Allowed' ;
    rdfs:comment 'Boolean flag indicating whether fractional quantities are permitted for this unit of measure (True for weight/volume units like pounds or liters, False for discrete count units like cases or pallets).' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInventoryTracked rdf:type rdf:Property ;
    rdfs:label 'Is Inventory Tracked' ;
    rdfs:comment 'Boolean flag indicating whether inventory quantities are tracked and managed in this unit of measure (True if used in Warehouse Management System (WMS) and inventory systems, False if conversion-only).' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrderable rdf:type rdf:Property ;
    rdfs:label 'Is Orderable' ;
    rdfs:comment 'Boolean flag indicating whether this unit of measure can be used for purchase order creation and supplier ordering (True if valid for procurement, False if display-only or internal-use).' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoUomCode rdf:type rdf:Property ;
    rdfs:label 'Iso Uom Code' ;
    rdfs:comment 'International Organization for Standardization (ISO) unit code per ISO 80000 and ISO 31 standards, ensuring global consistency in measurement representation.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precisionDecimalPlaces rdf:type rdf:Property ;
    rdfs:label 'Precision Decimal Places' ;
    rdfs:comment 'Number of decimal places to which quantities in this unit of measure should be rounded for display and calculation purposes (e.g., 0 for whole units like cases, 2 for currency-like precision, 3 for weight measurements).' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByUomCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Uom Code' ;
    rdfs:comment 'Code of the replacement unit of measure that supersedes this one when deprecated. Used to maintain continuity during UOM transitions and system migrations.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:symbol rdf:type rdf:Property ;
    rdfs:label 'Symbol' ;
    rdfs:comment 'Standard abbreviated symbol for the unit of measure (e.g., kg for kilogram, lb for pound, L for liter, oz for ounce). Used in labels, reports, and user interfaces.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uneceCode rdf:type rdf:Property ;
    rdfs:label 'Unece Code' ;
    rdfs:comment 'United Nations Economic Commission for Europe (UN/ECE) Recommendation 20 unit code, widely used in international trade and customs documentation.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomClass rdf:type rdf:Property ;
    rdfs:label 'Uom Class' ;
    rdfs:comment 'Classification of the unit of measure by measurement type: weight (mass), volume (capacity), count (discrete units), length (distance), area (surface), or time (duration).' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomDescription rdf:type rdf:Property ;
    rdfs:label 'Uom Description' ;
    rdfs:comment 'Detailed description of the unit of measure, including usage context and business rules for application across retail operations.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomName rdf:type rdf:Property ;
    rdfs:label 'Uom Name' ;
    rdfs:comment 'Full descriptive name of the unit of measure (e.g., Each, Case, Pound, Kilogram, Liter, Ounce, Pallet).' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomType rdf:type rdf:Property ;
    rdfs:label 'Uom Type' ;
    rdfs:comment 'Functional type indicating the primary business context where this UOM is used: base (fundamental unit), alternate (conversion unit), display (customer-facing), ordering (procurement), inventory (stock tracking), pricing (selling unit), or shipping (logistics). [ENUM-REF-CANDIDATE: base|alternate|display|ordering|inventory|pricing|shipping — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageContext rdf:type rdf:Property ;
    rdfs:label 'Usage Context' ;
    rdfs:comment 'Textual description of the business contexts and operational scenarios where this unit of measure is typically applied (e.g., used for bulk ordering of dry goods, used for pricing fresh produce, used for shipping pallet quantities).' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circularAdId rdf:type rdf:Property ;
    rdfs:label 'Circular Ad Id' ;
    rdfs:comment 'Unique identifier for the circular advertisement. Primary key for the circular ad entity.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CircularAd .

ind:complianceReviewComplianceProgramId rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Compliance Program Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_program. Business justification: Retail advertising circulars require pre-publication compliance review against FTC advertising guidelines, state deceptive practices laws, and pricing accuracy regulations. Links circular to complianc' ;
    rdfs:domain ind:CircularAd ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceProgram .

ind:primaryCircularAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Circular Associate Id' ;
    rdfs:comment 'Reference to the user or manager who provided final approval for the circular to proceed to production.' ;
    rdfs:domain ind:CircularAd ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:promoBudgetId rdf:type rdf:Property ;
    rdfs:label 'Promo Budget Id' ;
    rdfs:comment 'Foreign key linking to promotion.promo_budget. Business justification: Circular ads have production costs (production_cost_amount, production_cost_currency_code) that are funded from promotional budgets. While circular_ad.promo_campaign_id links to campaign, the specific' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoBudget .

ind:promoCalendarId rdf:type rdf:Property ;
    rdfs:label 'Promo Calendar Id' ;
    rdfs:comment 'Foreign key linking to promotion.promo_calendar. Business justification: Circular ads are published according to promotional calendar periods. The circular_ad has effective_start_date and effective_end_date that align with promotional periods defined in promo_calendar (e.g' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoCalendar .

ind:tertiaryCircularModifiedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Circular Modified By User Associate Id' ;
    rdfs:comment 'Reference to the user who most recently modified the circular record, supporting audit and accountability requirements.' ;
    rdfs:domain ind:CircularAd ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:circularName rdf:type rdf:Property ;
    rdfs:label 'Circular Name' ;
    rdfs:comment 'Marketing name or title of the circular advertisement, such as \'Weekly Savings\', \'Holiday Spectacular\', or \'Back to School Event\'.' ;
    rdfs:domain ind:CircularAd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circularNumber rdf:type rdf:Property ;
    rdfs:label 'Circular Number' ;
    rdfs:comment 'Business identifier for the circular advertisement, typically a human-readable code or number used for reference in marketing and merchandising operations.' ;
    rdfs:domain ind:CircularAd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circularType rdf:type rdf:Property ;
    rdfs:label 'Circular Type' ;
    rdfs:comment 'Classification of the circular advertisement based on its purpose and timing, such as weekly promotional circular, seasonal event, holiday special, clearance sale, or grand opening.' ;
    rdfs:domain ind:CircularAd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Flag' ;
    rdfs:comment 'Indicates whether the circular has undergone legal and regulatory compliance review for advertising standards, pricing transparency, and consumer protection requirements. True if reviewed, false otherwise.' ;
    rdfs:domain ind:CircularAd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverImageUrl rdf:type rdf:Property ;
    rdfs:label 'Cover Image Url' ;
    rdfs:comment 'URL or file path to the cover image or hero graphic for the circular, used for digital display and thumbnail previews.' ;
    rdfs:domain ind:CircularAd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalImpressionsTarget rdf:type rdf:Property ;
    rdfs:label 'Digital Impressions Target' ;
    rdfs:comment 'Target number of digital impressions or views for the circular across digital channels, used for campaign planning and performance measurement.' ;
    rdfs:domain ind:CircularAd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'Primary channel through which the circular is distributed to customers, including print mail, digital web, email, mobile app, social media, or in-store display.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:editionNumber rdf:type rdf:Property ;
    rdfs:label 'Edition Number' ;
    rdfs:comment 'Edition or version number of the circular, used to track revisions and multiple releases within a campaign period.' ;
    rdfs:domain ind:CircularAd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isVendorFunded rdf:type rdf:Property ;
    rdfs:label 'Is Vendor Funded' ;
    rdfs:comment 'Indicates whether the circular includes vendor-funded promotional offers or co-op advertising agreements. True if vendor funding is involved, false otherwise.' ;
    rdfs:domain ind:CircularAd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'Total number of pages in the circular advertisement, used for production planning and cost management.' ;
    rdfs:domain ind:CircularAd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pdfFileUrl rdf:type rdf:Property ;
    rdfs:label 'Pdf File Url' ;
    rdfs:comment 'URL or file path to the complete PDF version of the circular, used for digital distribution and archival purposes.' ;
    rdfs:domain ind:CircularAd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printQuantity rdf:type rdf:Property ;
    rdfs:label 'Print Quantity' ;
    rdfs:comment 'Total number of physical copies printed for distribution, used for production cost tracking and circulation analysis. Null for digital-only circulars.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Production Cost Amount' ;
    rdfs:comment 'Total cost to produce and distribute the circular, including design, printing, mailing, and digital distribution expenses. Used for marketing ROI analysis.' ;
    rdfs:domain ind:CircularAd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Production Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the production cost amount, such as USD, CAD, or EUR.' ;
    rdfs:domain ind:CircularAd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionStatus rdf:type rdf:Property ;
    rdfs:label 'Production Status' ;
    rdfs:comment 'Current lifecycle status of the circular in the production workflow, from initial draft through review, approval, production, publication, and archival.' ;
    rdfs:domain ind:CircularAd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theme rdf:type rdf:Property ;
    rdfs:label 'Theme' ;
    rdfs:comment 'Marketing theme or creative concept for the circular, such as \'Summer Savings\', \'Holiday Gift Guide\', or \'Spring Refresh\', used for brand consistency and customer engagement.' ;
    rdfs:domain ind:CircularAd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorFundingAmount rdf:type rdf:Property ;
    rdfs:label 'Vendor Funding Amount' ;
    rdfs:comment 'Total amount of vendor co-op funding or promotional allowances applied to this circular, used for cost allocation and vendor settlement.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:couponId rdf:type rdf:Property ;
    rdfs:label 'Coupon Id' ;
    rdfs:comment 'Unique identifier for the coupon instrument. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Coupon .

ind:promotionStackId rdf:type rdf:Property ;
    rdfs:label 'Promotion Stack Id' ;
    rdfs:comment 'Foreign key linking to promotion.promotion_stack. Business justification: Coupons can be part of promotion stacks enabling multi-coupon stacking scenarios. The coupon has stackable_flag indicating it CAN stack, but doesn\'t indicate WHICH stack it belongs to. Adding promotio' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromotionStack .

ind:couponStatus rdf:type rdf:Property ;
    rdfs:label 'Coupon Status' ;
    rdfs:comment 'Current lifecycle state of the coupon. active means available for redemption, inactive means not yet released, expired means past expiration_date, suspended means temporarily disabled, redeemed means fully used (for single-use coupons).' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponType rdf:type rdf:Property ;
    rdfs:label 'Coupon Type' ;
    rdfs:comment 'Classification of coupon by issuing authority and format. Manufacturer coupons are vendor-funded, store coupons are retailer-funded, digital coupons are app/email-based, paper coupons are physical print, loyalty coupons are tied to loyalty programs, vendor_funded are supplier co-op promotions.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalDistributionQuantity rdf:type rdf:Property ;
    rdfs:label 'Digital Distribution Quantity' ;
    rdfs:comment 'Total number of digital coupon codes issued via email, app, or SMS. Null for paper-only coupons.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:digitalWalletEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Wallet Enabled Flag' ;
    rdfs:comment 'Indicates whether this coupon can be stored in a digital wallet (mobile app, Apple Wallet, Google Pay) for redemption (True) or is paper-only (False).' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleChannel rdf:type rdf:Property ;
    rdfs:label 'Eligible Channel' ;
    rdfs:comment 'Sales channels where the coupon can be redeemed. all_channels means omnichannel, pos is in-store only, ecommerce is online only, mobile_app is app-only, bopis is buy-online-pickup-in-store.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleProductScope rdf:type rdf:Property ;
    rdfs:label 'Eligible Product Scope' ;
    rdfs:comment 'Defines the breadth of products to which the coupon applies. all_products means store-wide, category restricts to a product category, brand restricts to a specific brand, sku restricts to specific SKUs, basket applies to entire cart total.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionList rdf:type rdf:Property ;
    rdfs:label 'Exclusion List' ;
    rdfs:comment 'Comma-separated list of product SKUs, categories, or brands explicitly excluded from coupon eligibility. Null if no exclusions apply.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faceValue rdf:type rdf:Property ;
    rdfs:label 'Face Value' ;
    rdfs:comment 'Nominal discount value of the coupon. For fixed_amount coupons, this is the dollar discount. For percentage coupons, this is the percentage (e.g., 15.00 for 15% off). For BOGO, may represent the value of the free item.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issueChannel rdf:type rdf:Property ;
    rdfs:label 'Issue Channel' ;
    rdfs:comment 'Distribution channel through which the coupon was issued to customers. Circular refers to weekly print ads, mobile_app and email are digital channels, in_store_kiosk is physical print at store, website is online portal, social_media includes Facebook/Instagram ads, direct_mail is postal delivery, SMS is text message. [ENUM-REF-CANDIDATE: circular|mobile_app|email|in_store_kiosk|website|social_media|direct_mail|sms — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionLimitPerCustomer rdf:type rdf:Property ;
    rdfs:label 'Redemption Limit Per Customer' ;
    rdfs:comment 'Maximum number of times a single customer can redeem this coupon. Null or 0 indicates unlimited redemptions per customer.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:singleUseFlag rdf:type rdf:Property ;
    rdfs:label 'Single Use Flag' ;
    rdfs:comment 'Indicates whether the coupon can only be used once (True) or multiple times (False) by the same customer, subject to redemption_limit_per_customer.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalRedemptionLimit rdf:type rdf:Property ;
    rdfs:label 'Total Redemption Limit' ;
    rdfs:comment 'Maximum total number of redemptions allowed across all customers for this coupon. Null or 0 indicates unlimited total redemptions.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financeCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Finance Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Promotion budgets are allocated to finance cost centers for accounting and budget tracking. The cost_center_code column becomes redundant as it can be joined from finance.cost_center. This links promo' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:budgetOwnerType rdf:type rdf:Property ;
    rdfs:label 'Budget Owner Type' ;
    rdfs:comment 'Classification of the organizational unit responsible for managing and executing this promotional budget. Department indicates merchandising department ownership; category indicates product category team ownership; brand indicates brand management team ownership; channel indicates channel-specific ownership (e-commerce, stores); region indicates geographic region ownership; store cluster indicates store group ownership.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the promotional budget source and purpose. Internal marketing budgets are company-funded campaigns; vendor co-op budgets are supplier-funded promotional agreements; markdown allowance budgets cover planned price reductions; clearance reserve budgets are set aside for end-of-season inventory liquidation; trade promotion budgets support B2B channel incentives; digital advertising budgets fund online and mobile promotional campaigns.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circularAdAllocation rdf:type rdf:Property ;
    rdfs:label 'Circular Ad Allocation' ;
    rdfs:comment 'Portion of the total budget allocated specifically for circular advertising and weekly ad production, including print circulars, digital circulars, and featured promotional items in weekly ad campaigns.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ecommerceChannelAllocation rdf:type rdf:Property ;
    rdfs:label 'Ecommerce Channel Allocation' ;
    rdfs:comment 'Portion of the total budget allocated specifically for e-commerce and digital promotional activities, including online discounts, digital coupons, email campaigns, and website promotional banners. Supports omnichannel budget planning and digital channel ROI tracking.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mobileChannelAllocation rdf:type rdf:Property ;
    rdfs:label 'Mobile Channel Allocation' ;
    rdfs:comment 'Portion of the total budget allocated specifically for mobile app promotional activities, including app-exclusive offers, push notification campaigns, and mobile wallet coupons. Supports omnichannel budget planning and mobile channel ROI tracking.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otbIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Otb Integration Flag' ;
    rdfs:comment 'Boolean indicator of whether this promotional budget is integrated with the Open to Buy (OTB) merchandise planning system. When true, promotional markdowns and clearance budgets are factored into inventory purchasing decisions and margin planning.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posChannelAllocation rdf:type rdf:Property ;
    rdfs:label 'Pos Channel Allocation' ;
    rdfs:comment 'Portion of the total budget allocated specifically for in-store point-of-sale promotional activities, including store markdowns, in-store coupons, and physical promotional displays. Supports omnichannel budget planning and channel-specific ROI tracking.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Budget Amount' ;
    rdfs:comment 'Available budget remaining for new promotional activities, calculated as total budget amount minus actual spend amount minus committed amount. Represents the unallocated budget available for additional promotional planning.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Budget Amount' ;
    rdfs:comment 'Total allocated budget amount for the promotional plan in the budget currency. Represents the maximum authorized spend for this promotional budget across all channels and activities.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Amount' ;
    rdfs:comment 'Absolute amount threshold for budget variance alerts. When actual spend deviates from planned spend by more than this amount, automated alerts are triggered to budget owners and finance teams. Used in conjunction with or as an alternative to percentage-based thresholds.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percent' ;
    rdfs:comment 'Percentage threshold for budget variance alerts. When actual spend deviates from planned spend by more than this percentage, automated alerts are triggered to budget owners and finance teams. Typical values range from 5% to 20%.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorFundedAmount rdf:type rdf:Property ;
    rdfs:label 'Vendor Funded Amount' ;
    rdfs:comment 'Portion of the total budget that is funded by vendor co-op agreements, trade promotion allowances, or supplier marketing development funds. Represents external funding contribution to the promotional budget.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableBannerCodes rdf:type rdf:Property ;
    rdfs:label 'Applicable Banner Codes' ;
    rdfs:comment 'Comma-separated list of banner codes to which this promotional period applies. Populated only when banner_applicability is \'banner_specific\'.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableMarketCodes rdf:type rdf:Property ;
    rdfs:label 'Applicable Market Codes' ;
    rdfs:comment 'Comma-separated list of market or region codes to which this promotional period applies. Populated when market_applicability is \'regional\' or \'local\'.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bannerApplicability rdf:type rdf:Property ;
    rdfs:label 'Banner Applicability' ;
    rdfs:comment 'Indicates whether this promotional period applies across all retail banners (enterprise-wide) or is specific to individual banners (banner-specific). Supports multi-banner coordination.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutReason rdf:type rdf:Property ;
    rdfs:label 'Blackout Reason' ;
    rdfs:comment 'Business justification for why this period is designated as a promotional blackout (e.g., inventory transition, system maintenance, post-holiday recovery).' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circularProductionDeadline rdf:type rdf:Property ;
    rdfs:label 'Circular Production Deadline' ;
    rdfs:comment 'The deadline by which all promotional circular materials (print ads, digital circulars) must be finalized for production and distribution.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitiveResponseFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Response Flag' ;
    rdfs:comment 'Indicates whether this promotional period was created as a competitive response to rival retailer promotions (true) or is part of the planned calendar (false).' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitiveTriggerDescription rdf:type rdf:Property ;
    rdfs:label 'Competitive Trigger Description' ;
    rdfs:comment 'Description of the competitive market event or rival promotion that triggered this promotional period. Populated when competitive_response_flag is true.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedSalesLiftPct rdf:type rdf:Property ;
    rdfs:label 'Expected Sales Lift Pct' ;
    rdfs:comment 'Forecasted percentage increase in sales revenue expected during this promotional period compared to baseline or prior year.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedTrafficLiftPct rdf:type rdf:Property ;
    rdfs:label 'Expected Traffic Lift Pct' ;
    rdfs:comment 'Forecasted percentage increase in customer traffic (footfall and digital visits) expected during this promotional period compared to baseline.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Month' ;
    rdfs:comment 'The fiscal month (1-12) to which this promotional period belongs.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryBuildStartDate rdf:type rdf:Property ;
    rdfs:label 'Inventory Build Start Date' ;
    rdfs:comment 'The date when inventory positioning and build-up for this promotional period should begin to ensure adequate stock levels.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isBlackoutPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Blackout Period' ;
    rdfs:comment 'Flag indicating whether this period is a promotional blackout window where no new promotions should be launched (true) or a normal promotional period (false).' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketApplicability rdf:type rdf:Property ;
    rdfs:label 'Market Applicability' ;
    rdfs:comment 'Geographic scope of the promotional period indicating whether it applies nationally, regionally, or to specific local markets.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningLockDate rdf:type rdf:Property ;
    rdfs:label 'Planning Lock Date' ;
    rdfs:comment 'The date by which all promotional planning for this period must be finalized and locked. After this date, changes require executive approval.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Planning Owner Email' ;
    rdfs:comment 'Email address of the planning owner for coordination and communication regarding this promotional period.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningOwnerName rdf:type rdf:Property ;
    rdfs:label 'Planning Owner Name' ;
    rdfs:comment 'Name of the merchandising or marketing manager responsible for planning and executing this promotional period.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningStatus rdf:type rdf:Property ;
    rdfs:label 'Planning Status' ;
    rdfs:comment 'Current lifecycle status of the promotional calendar period (draft - under development, locked - finalized for execution, active - currently running, archived - completed and historical).' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:themeDescription rdf:type rdf:Property ;
    rdfs:label 'Theme Description' ;
    rdfs:comment 'Marketing theme or creative concept for the promotional period (e.g., \'Summer Savings\', \'Holiday Gift Guide\', \'New Year New You\').' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorNegotiationDeadline rdf:type rdf:Property ;
    rdfs:label 'Vendor Negotiation Deadline' ;
    rdfs:comment 'The deadline by which all vendor-funded promotional agreements and co-op advertising commitments must be finalized.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:circularAdFlag rdf:type rdf:Property ;
    rdfs:label 'Circular Ad Flag' ;
    rdfs:comment 'Indicates whether the campaign is featured in printed or digital circular advertisements.' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSegmentTarget rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Target' ;
    rdfs:comment 'Target customer segment or persona for the promotional campaign (e.g., loyalty members, new customers, high-value).' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalPromotionFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Promotion Flag' ;
    rdfs:comment 'Indicates whether the campaign includes digital promotions delivered via e-commerce, mobile app, or email.' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountStrategy rdf:type rdf:Property ;
    rdfs:label 'Discount Strategy' ;
    rdfs:comment 'Primary discount mechanism used in the campaign (percentage off, fixed amount, BOGO, bundle pricing, tiered discounts, rebate).' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventClassification rdf:type rdf:Property ;
    rdfs:label 'Event Classification' ;
    rdfs:comment 'Specific promotional event type within the campaign (e.g., Flash Sale, Doorbuster, BOGO). [ENUM-REF-CANDIDATE: flash_sale|doorbuster|holiday_sale|weekly_circular|bogo|markdown|rebate — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyExclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Loyalty Exclusive Flag' ;
    rdfs:comment 'Indicates whether the campaign offers are exclusive to loyalty program members.' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promoCampaignStatus rdf:type rdf:Property ;
    rdfs:label 'Promo Campaign Status' ;
    rdfs:comment 'Current lifecycle status of the promotional campaign.' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCustomerReach rdf:type rdf:Property ;
    rdfs:label 'Target Customer Reach' ;
    rdfs:comment 'Number of unique customers the campaign aims to reach or engage.' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetRevenue rdf:type rdf:Property ;
    rdfs:label 'Target Revenue' ;
    rdfs:comment 'Expected revenue target for the promotional campaign period.' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetUnitsSold rdf:type rdf:Property ;
    rdfs:label 'Target Units Sold' ;
    rdfs:comment 'Target number of units expected to be sold during the promotional campaign.' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorFundedFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Funded Flag' ;
    rdfs:comment 'Indicates whether the promotional campaign is partially or fully funded by vendor cooperative marketing agreements.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promoConflictRuleId rdf:type rdf:Property ;
    rdfs:label 'Promo Conflict Rule Id' ;
    rdfs:comment 'Unique identifier for the promotion conflict rule configuration record.' ;
    rdfs:domain ind:PromoConflictRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conflictingPromoGroupId rdf:type rdf:Property ;
    rdfs:label 'Conflicting Promo Group Id' ;
    rdfs:comment 'Identifier for a group of promotions that are mutually exclusive or have defined interaction rules. Used to define which promotion pairs or sets this rule governs.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoGroup .

ind:primaryPromoAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Promo Associate Id' ;
    rdfs:comment 'Identifier of the user or system account that created this conflict rule configuration.' ;
    rdfs:domain ind:PromoConflictRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:primaryPromoCampaignId rdf:type rdf:Property ;
    rdfs:label 'Primary Promo Campaign Id' ;
    rdfs:comment 'Reference to the primary promotion in a conflict pair or hierarchy. Used in explicit exclusion and priority override scenarios.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoCampaign .

ind:tertiaryPromoApprovedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Promo Approved By User Associate Id' ;
    rdfs:comment 'Identifier of the business user who approved this conflict rule for production deployment.' ;
    rdfs:domain ind:PromoConflictRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:appliesToScope rdf:type rdf:Property ;
    rdfs:label 'Applies To Scope' ;
    rdfs:comment 'Granularity level at which the conflict rule operates: SKU (Stock Keeping Unit) level for individual products, category level for product groups, brand level, vendor level for supplier-funded promotions, transaction level for cart-wide rules, or customer segment for loyalty-tier specific rules.' ;
    rdfs:domain ind:PromoConflictRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditLogRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Log Required Flag' ;
    rdfs:comment 'Indicates whether all applications and overrides of this rule must be logged for compliance and audit purposes.' ;
    rdfs:domain ind:PromoConflictRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSegmentRestriction rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Restriction' ;
    rdfs:comment 'Comma-separated list of customer segment codes to which this conflict rule applies. Used for loyalty-tier specific or demographic-specific conflict resolution.' ;
    rdfs:domain ind:PromoConflictRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country or region code where this rule applies, supporting jurisdiction-specific regulatory requirements such as Australian Trade Practices Act best-price requirements or EU Omnibus Directive lowest-prior-price rules.' ;
    rdfs:domain ind:PromoConflictRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Max Discount Amount' ;
    rdfs:comment 'Maximum cumulative discount amount in local currency when multiple promotions stack, used for margin protection and fraud prevention.' ;
    rdfs:domain ind:PromoConflictRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Max Discount Percentage' ;
    rdfs:comment 'Maximum cumulative discount percentage allowed when multiple promotions stack, used for margin protection. Expressed as a percentage (e.g., 50.00 for 50%).' ;
    rdfs:domain ind:PromoConflictRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxStackCount rdf:type rdf:Property ;
    rdfs:label 'Max Stack Count' ;
    rdfs:comment 'Maximum number of promotions that can be combined (stacked) on a single transaction or SKU when stackability is allowed. Null if unlimited or not applicable.' ;
    rdfs:domain ind:PromoConflictRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:omsSystemFlag rdf:type rdf:Property ;
    rdfs:label 'Oms System Flag' ;
    rdfs:comment 'Indicates whether this rule is loaded into OMS (Order Management System) for e-commerce and omnichannel order conflict resolution.' ;
    rdfs:domain ind:PromoConflictRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Override Allowed Flag' ;
    rdfs:comment 'Indicates whether store managers or customer service representatives are permitted to manually override this conflict rule at checkout or during order processing.' ;
    rdfs:domain ind:PromoConflictRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideAuthorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Override Authorization Level' ;
    rdfs:comment 'Minimum authorization level required to override this conflict rule: none (no override allowed), cashier, supervisor, store manager, regional manager, or corporate only.' ;
    rdfs:domain ind:PromoConflictRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posSystemFlag rdf:type rdf:Property ;
    rdfs:label 'Pos System Flag' ;
    rdfs:comment 'Indicates whether this rule is loaded into POS (Point of Sale) systems for in-store checkout conflict resolution.' ;
    rdfs:domain ind:PromoConflictRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Resolution Method' ;
    rdfs:comment 'Specific algorithm used to resolve conflicts when multiple promotions qualify: highest discount wins (best value for customer), first applied wins (temporal precedence), last applied wins (most recent), priority hierarchy (rank-based), explicit block (hard exclusion), customer choice (manual selection at POS), or vendor priority (supplier-funded promo takes precedence). [ENUM-REF-CANDIDATE: highest_discount_wins|first_applied_wins|last_applied_wins|priority_hierarchy|explicit_block|customer_choice|vendor_priority — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PromoConflictRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoForecastId rdf:type rdf:Property ;
    rdfs:label 'Promo Forecast Id' ;
    rdfs:comment 'Unique identifier for the promotional forecast record. Primary key for the promo_forecast product.' ;
    rdfs:domain ind:PromoForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineSalesForecastUnits rdf:type rdf:Property ;
    rdfs:label 'Baseline Sales Forecast Units' ;
    rdfs:comment 'The forecasted sales units for the SKU-store-week without any promotional activity. Represents the expected demand under normal, non-promotional conditions.' ;
    rdfs:domain ind:PromoForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Forecast Adjustment Factor' ;
    rdfs:comment 'A manual adjustment factor applied to the system-generated forecast by demand planners. A value of 1.0 indicates no adjustment; values above 1.0 indicate upward adjustment; values below 1.0 indicate downward adjustment.' ;
    rdfs:domain ind:PromoForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAdjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Forecast Adjustment Reason' ;
    rdfs:comment 'Free-text explanation for any manual adjustment applied to the system-generated forecast. Captures planner judgment and business context.' ;
    rdfs:domain ind:PromoForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastConfidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Forecast Confidence Level' ;
    rdfs:comment 'The confidence level assigned to this promotional forecast by the demand planning system. Indicates the reliability of the forecast based on historical data quality, model accuracy, and market volatility.' ;
    rdfs:domain ind:PromoForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Forecast Confidence Score' ;
    rdfs:comment 'Numeric confidence score (0-100) representing the statistical confidence in the forecast accuracy. Higher scores indicate greater confidence.' ;
    rdfs:domain ind:PromoForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastErrorPercentage rdf:type rdf:Property ;
    rdfs:label 'Forecast Error Percentage' ;
    rdfs:comment 'The historical forecast error percentage for similar promotions using the same forecasting model. Used to assess forecast reliability and set safety stock levels.' ;
    rdfs:domain ind:PromoForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastGenerationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Forecast Generation Timestamp' ;
    rdfs:comment 'The date and time when this promotional forecast was generated by the demand planning system. Represents the principal business event timestamp for this operational planning record.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:forecastScenario rdf:type rdf:Property ;
    rdfs:label 'Forecast Scenario' ;
    rdfs:comment 'The scenario name or identifier for this forecast. Enables comparison of multiple forecast scenarios (e.g., optimistic, pessimistic, baseline) for the same promotion.' ;
    rdfs:domain ind:PromoForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Status' ;
    rdfs:comment 'The current lifecycle status of the promotional forecast. Indicates whether the forecast is in draft, has been approved for use in replenishment planning, has been rejected, or has been superseded by a newer forecast.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastWeekEndDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Week End Date' ;
    rdfs:comment 'The end date of the week for which this promotional forecast is generated.' ;
    rdfs:domain ind:PromoForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastWeekStartDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Week Start Date' ;
    rdfs:comment 'The start date of the week for which this promotional forecast is generated. Forecasts are typically generated at weekly granularity.' ;
    rdfs:domain ind:PromoForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastedDiscountCostAmount rdf:type rdf:Property ;
    rdfs:label 'Forecasted Discount Cost Amount' ;
    rdfs:comment 'The total forecasted cost of the promotional discount for the SKU-store-week. Represents the revenue foregone due to the promotional price reduction.' ;
    rdfs:domain ind:PromoForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Forecasted Revenue Amount' ;
    rdfs:comment 'The total forecasted revenue for the SKU-store-week during the promotion, calculated using the promotional price and total forecasted units.' ;
    rdfs:domain ind:PromoForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incrementalLiftUnits rdf:type rdf:Property ;
    rdfs:label 'Incremental Lift Units' ;
    rdfs:comment 'The estimated additional sales units expected due to the promotional activity. Represents the incremental demand lift above the baseline forecast.' ;
    rdfs:domain ind:PromoForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openToBuyImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Open To Buy Impact Amount' ;
    rdfs:comment 'The impact of this promotional forecast on the Open To Buy (OTB) budget for the category. Represents the additional inventory investment required to support the forecasted promotional demand.' ;
    rdfs:domain ind:PromoForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Promotional Price Amount' ;
    rdfs:comment 'The promotional price per unit for the SKU during the forecast period. Used to calculate forecasted revenue and discount cost.' ;
    rdfs:domain ind:PromoForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regularPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Regular Price Amount' ;
    rdfs:comment 'The regular (non-promotional) price per unit for the SKU. Used to calculate the discount cost and promotional lift.' ;
    rdfs:domain ind:PromoForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Replenishment Triggered Flag' ;
    rdfs:comment 'Indicates whether this promotional forecast has triggered inventory replenishment orders. True if replenishment has been initiated, False otherwise.' ;
    rdfs:domain ind:PromoForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalForecastedUnits rdf:type rdf:Property ;
    rdfs:label 'Total Forecasted Units' ;
    rdfs:comment 'The total forecasted sales units for the SKU-store-week including promotional lift. Calculated as baseline_sales_forecast_units plus incremental_lift_units.' ;
    rdfs:domain ind:PromoForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activationTrigger rdf:type rdf:Property ;
    rdfs:label 'Activation Trigger' ;
    rdfs:comment 'Event or condition that activates this offer for a customer. manual = customer enters code; cart_threshold = automatically applied when cart meets criteria; login = activated upon customer login; geofence = triggered by location; time_based = activated at specific time; event_based = triggered by business event.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelEligibility rdf:type rdf:Property ;
    rdfs:label 'Channel Eligibility' ;
    rdfs:comment 'Sales channels where this offer is valid. POS = in-store Point of Sale; ecommerce = online web storefront; mobile = mobile app; BOPIS = Buy Online Pick Up In Store; ROPIS = Reserve Online Pick Up In Store; all_channels = valid across all channels. [ENUM-REF-CANDIDATE: POS|ecommerce|mobile|BOPIS|ROPIS|call_center|kiosk — promote to reference product]' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Share Percentage' ;
    rdfs:comment 'Percentage of promotional discount cost borne by the vendor (0-100). Null if not applicable or fully retailer-funded.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerSegmentEligibility rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Eligibility' ;
    rdfs:comment 'Defines which customer segments are eligible to redeem this offer. all_customers = no restrictions; loyalty_members = requires loyalty program membership; VIP = high-value customers only; new_customers = first-time buyers; targeted_segment = specific marketing segment.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Delivery Flag' ;
    rdfs:comment 'Indicates whether this offer is delivered digitally (e.g., via email, mobile app push notification, personalized web banner). True = digital delivery; False = traditional circular/print or in-store signage only.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayMessage rdf:type rdf:Property ;
    rdfs:label 'Display Message' ;
    rdfs:comment 'Customer-facing promotional message displayed at Point of Sale (POS), e-commerce checkout, and mobile app. Concise marketing copy highlighting the offer value.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndTime rdf:type rdf:Property ;
    rdfs:label 'Effective End Time' ;
    rdfs:comment 'Precise timestamp when this promotional offer expires, supporting time-of-day specific promotions. Null indicates no specific end time constraint.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveStartTime rdf:type rdf:Property ;
    rdfs:label 'Effective Start Time' ;
    rdfs:comment 'Precise timestamp when this promotional offer becomes active, supporting time-of-day specific promotions (e.g., happy hour deals, flash sales).' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:jurisdictionRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Restriction Flag' ;
    rdfs:comment 'Indicates whether this offer has jurisdiction-specific restrictions (e.g., state-level promotional laws, EU consumer protection price display requirements). True = restrictions apply; False = no jurisdiction restrictions.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumRedemptionPerCustomer rdf:type rdf:Property ;
    rdfs:label 'Maximum Redemption Per Customer' ;
    rdfs:comment 'Maximum number of times a single customer can redeem this offer. Null indicates unlimited redemptions per customer.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumRedemptionTotal rdf:type rdf:Property ;
    rdfs:label 'Maximum Redemption Total' ;
    rdfs:comment 'Maximum total number of redemptions allowed across all customers for this offer. Null indicates unlimited total redemptions.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerPriority rdf:type rdf:Property ;
    rdfs:label 'Offer Priority' ;
    rdfs:comment 'Priority ranking for offer application when multiple offers are eligible. Lower numbers indicate higher priority. Used by Point of Sale (POS) and e-commerce checkout engines to resolve offer conflicts.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:personalizationFlag rdf:type rdf:Property ;
    rdfs:label 'Personalization Flag' ;
    rdfs:comment 'Indicates whether this offer is personalized to individual customers based on purchase history, preferences, or predictive analytics. True = personalized; False = mass-market offer.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productEligibilityScope rdf:type rdf:Property ;
    rdfs:label 'Product Eligibility Scope' ;
    rdfs:comment 'Defines which products are eligible for this offer. all_products = applies to entire catalog; category = applies to specific product categories; SKU_list = applies to specific Stock Keeping Units (SKUs); brand = applies to specific brands; excluded_products = applies to all products except specified exclusions.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedJurisdictions rdf:type rdf:Property ;
    rdfs:label 'Restricted Jurisdictions' ;
    rdfs:comment 'Comma-separated list of jurisdiction codes (ISO 3166-1 alpha-3 country codes or state/province codes) where this offer is restricted or prohibited due to regulatory compliance requirements. Null if no restrictions.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeEligibilityScope rdf:type rdf:Property ;
    rdfs:label 'Store Eligibility Scope' ;
    rdfs:comment 'Defines the scope of store eligibility for this offer. all_stores = valid at all retail locations; store_group = valid at a defined group of stores; individual_store = valid at specific stores only; excluded_stores = valid everywhere except specified stores.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Promo Performance Id' ;
    rdfs:comment 'Unique identifier for the promotion performance record. Primary key for this operational performance measurement entity.' ;
    rdfs:domain ind:PromoPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageTransactionValue rdf:type rdf:Property ;
    rdfs:label 'Average Transaction Value' ;
    rdfs:comment 'Average basket value for transactions that included this promoted item. Measures promotion impact on overall basket size.' ;
    rdfs:domain ind:PromoPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineUnits rdf:type rdf:Property ;
    rdfs:label 'Baseline Units' ;
    rdfs:comment 'Estimated units that would have sold without the promotion, based on historical trends. Used to calculate incremental lift.' ;
    rdfs:domain ind:PromoPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cannibalizationEstimate rdf:type rdf:Property ;
    rdfs:label 'Cannibalization Estimate' ;
    rdfs:comment 'Estimated units of related non-promoted products that lost sales due to this promotion. Measures negative cross-product impact.' ;
    rdfs:domain ind:PromoPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cogs rdf:type rdf:Property ;
    rdfs:label 'Cogs' ;
    rdfs:comment 'Total cost of goods sold during the promotion period. Used to calculate gross margin and promotional ROI.' ;
    rdfs:domain ind:PromoPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAccuracyPercent rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Percent' ;
    rdfs:comment 'Accuracy of the promotional forecast compared to actual performance. Calculated as 100 minus absolute percentage error. Used to improve future forecasting.' ;
    rdfs:domain ind:PromoPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossMargin rdf:type rdf:Property ;
    rdfs:label 'Gross Margin' ;
    rdfs:comment 'Gross profit generated during the promotion. Calculated as net_revenue minus COGS. Critical for assessing promotion profitability.' ;
    rdfs:domain ind:PromoPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Percent' ;
    rdfs:comment 'Gross margin as a percentage of net revenue. Expressed as a percentage value (e.g., 25.50 for 25.5%). Measures promotion profitability rate.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossRevenue rdf:type rdf:Property ;
    rdfs:label 'Gross Revenue' ;
    rdfs:comment 'Total revenue generated from units sold at regular price before promotional discounts. Denominated in local store currency.' ;
    rdfs:domain ind:PromoPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incrementalUnits rdf:type rdf:Property ;
    rdfs:label 'Incremental Units' ;
    rdfs:comment 'Additional units sold above baseline due to the promotion. Calculated as units_sold minus baseline_units. Key measure of promotion effectiveness.' ;
    rdfs:domain ind:PromoPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRevenue rdf:type rdf:Property ;
    rdfs:label 'Net Revenue' ;
    rdfs:comment 'Revenue after promotional discounts. Calculated as gross_revenue minus discount_amount. Actual revenue realized from the promotion.' ;
    rdfs:domain ind:PromoPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newCustomerCount rdf:type rdf:Property ;
    rdfs:label 'New Customer Count' ;
    rdfs:comment 'Number of customers who purchased this SKU for the first time during the promotion. Measures customer acquisition effectiveness.' ;
    rdfs:domain ind:PromoPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outOfStockDays rdf:type rdf:Property ;
    rdfs:label 'Out Of Stock Days' ;
    rdfs:comment 'Number of days during the promotion period when the SKU was out of stock at this store. Indicates lost sales opportunity.' ;
    rdfs:domain ind:PromoPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceWeekEndDate rdf:type rdf:Property ;
    rdfs:label 'Performance Week End Date' ;
    rdfs:comment 'The end date of the week for which this promotion performance is measured. Defines the weekly measurement window.' ;
    rdfs:domain ind:PromoPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceWeekStartDate rdf:type rdf:Property ;
    rdfs:label 'Performance Week Start Date' ;
    rdfs:comment 'The start date of the week for which this promotion performance is measured. Promotion performance is captured at weekly grain for trend analysis.' ;
    rdfs:domain ind:PromoPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalRoi rdf:type rdf:Property ;
    rdfs:label 'Promotional Roi' ;
    rdfs:comment 'Return on investment for the promotion, calculated as incremental gross margin divided by promotional investment. Expressed as ratio (e.g., 2.50 means $2.50 return per $1 invested).' ;
    rdfs:domain ind:PromoPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repeatCustomerCount rdf:type rdf:Property ;
    rdfs:label 'Repeat Customer Count' ;
    rdfs:comment 'Number of customers who had previously purchased this SKU and bought again during the promotion. Measures loyalty reinforcement.' ;
    rdfs:domain ind:PromoPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retailerFundedAmount rdf:type rdf:Property ;
    rdfs:label 'Retailer Funded Amount' ;
    rdfs:comment 'Dollar amount funded by the retailer for this promotion. Combined with vendor_funded_amount gives total promotional investment.' ;
    rdfs:domain ind:PromoPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uniqueCustomerCount rdf:type rdf:Property ;
    rdfs:label 'Unique Customer Count' ;
    rdfs:comment 'Number of distinct customers who purchased the promoted item during the period. Measures promotion reach.' ;
    rdfs:domain ind:PromoPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Units Per Transaction' ;
    rdfs:comment 'Average number of units of the promoted SKU purchased per transaction. Indicates promotion-driven purchase intensity.' ;
    rdfs:domain ind:PromoPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promoRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Promo Redemption Id' ;
    rdfs:comment 'Unique identifier for each promotional offer redemption instance. Primary key for the promo_redemption product.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoRedemption .

ind:rebateId rdf:type rdf:Property ;
    rdfs:label 'Rebate Id' ;
    rdfs:comment 'Foreign key linking to promotion.rebate. Business justification: Redemptions can be for rebate offers specifically. A customer may redeem a rebate offer at transaction time (e.g., instant rebate applied at POS), and tracking which rebate was redeemed is essential f' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rebate .

ind:chargebackStatus rdf:type rdf:Property ;
    rdfs:label 'Chargeback Status' ;
    rdfs:comment 'Status of the vendor chargeback claim for vendor-funded promotions. Tracks the lifecycle from pending submission through payment receipt.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingSystem rdf:type rdf:Property ;
    rdfs:label 'Processing System' ;
    rdfs:comment 'The system or platform that processed and validated the promotion redemption. Identifies the source system for audit and reconciliation purposes.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionTier rdf:type rdf:Property ;
    rdfs:label 'Promotion Tier' ;
    rdfs:comment 'The tier or level of the promotion when tiered discount structures are used (e.g., spend $50 get 10% off, spend $100 get 20% off). Indicates which threshold was achieved.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRedeemed rdf:type rdf:Property ;
    rdfs:label 'Quantity Redeemed' ;
    rdfs:comment 'The number of units or items to which the promotion was applied. For BOGO offers, represents the number of qualifying item sets. For single-item discounts, typically 1.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionChannel rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel' ;
    rdfs:comment 'The sales channel through which the promotion was redeemed. Distinguishes between in-store POS, e-commerce platforms, mobile apps, and other customer touchpoints.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionLimitType rdf:type rdf:Property ;
    rdfs:label 'Redemption Limit Type' ;
    rdfs:comment 'The scope of redemption limits enforced for this promotion. Indicates whether limits apply per customer, per transaction, per day, or across the entire campaign period.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionMechanism rdf:type rdf:Property ;
    rdfs:label 'Redemption Mechanism' ;
    rdfs:comment 'Method by which the promotion was applied to the transaction. Indicates whether the discount was automatically triggered by system rules, manually entered via coupon code, applied through loyalty program, or activated through other channels. [ENUM-REF-CANDIDATE: automatic_system_triggered|coupon_code_entry|loyalty_auto_apply|cart_rule|manual_cashier_apply|mobile_app_clip|digital_wallet — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Redemption Sequence Number' ;
    rdfs:comment 'The sequential count of this redemption within the applicable limit scope. For example, if limit is per_customer, this tracks which redemption number this is for that customer (1st, 2nd, 3rd, etc.).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stackSequence rdf:type rdf:Property ;
    rdfs:label 'Stack Sequence' ;
    rdfs:comment 'The order in which this promotion was applied within a stacked promotion scenario. Determines calculation precedence when multiple discounts are layered.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationErrorCode rdf:type rdf:Property ;
    rdfs:label 'Validation Error Code' ;
    rdfs:comment 'System error code returned when a redemption attempt fails validation. Provides technical detail for troubleshooting invalid redemptions. Null for successful redemptions.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Validation Error Message' ;
    rdfs:comment 'Human-readable error message explaining why a redemption was rejected. Displayed to customers or cashiers. Null for successful redemptions.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Associate Id' ;
    rdfs:comment 'Identifier of the system user who last modified the rebate program record.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:exclusionProductList rdf:type rdf:Property ;
    rdfs:label 'Exclusion Product List' ;
    rdfs:comment 'Comma-separated list of Stock Keeping Unit (SKU) codes or product categories explicitly excluded from the rebate program.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicEligibility rdf:type rdf:Property ;
    rdfs:label 'Geographic Eligibility' ;
    rdfs:comment 'Comma-separated list of three-letter ISO country codes or region codes where the rebate is valid (e.g., USA, CAN, GBR). Null if available in all operating regions.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumRebateAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Rebate Amount' ;
    rdfs:comment 'Cap on the total rebate value that can be claimed per transaction or per customer. Null if no cap applies.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentProcessingDays rdf:type rdf:Property ;
    rdfs:label 'Payment Processing Days' ;
    rdfs:comment 'Expected number of business days from rebate approval to payment issuance. Used for customer Service Level Agreement (SLA) communication.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingProductList rdf:type rdf:Property ;
    rdfs:label 'Qualifying Product List' ;
    rdfs:comment 'Comma-separated list of Stock Keeping Unit (SKU) codes, Universal Product Code (UPC) numbers, or product category codes that qualify for the rebate. Null if rebate applies to all products.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateDescription rdf:type rdf:Property ;
    rdfs:label 'Rebate Description' ;
    rdfs:comment 'Detailed internal description of the rebate program purpose, target audience, and business objectives. Used for internal planning and reporting.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateName rdf:type rdf:Property ;
    rdfs:label 'Rebate Name' ;
    rdfs:comment 'Marketing name of the rebate program displayed to customers and used in promotional materials.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateNumber rdf:type rdf:Property ;
    rdfs:label 'Rebate Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the rebate program, used in customer communications and vendor agreements.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateStatus rdf:type rdf:Property ;
    rdfs:label 'Rebate Status' ;
    rdfs:comment 'Current lifecycle state of the rebate program: draft (being configured), active (live and accepting submissions), paused (temporarily suspended), expired (past end date), cancelled (terminated early), or completed (ended successfully).' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateType rdf:type rdf:Property ;
    rdfs:label 'Rebate Type' ;
    rdfs:comment 'Classification of the rebate mechanism: instant rebate (applied at Point of Sale), mail-in rebate (customer submits proof of purchase), vendor-funded rebate (supplier-sponsored), digital rebate (online redemption), promotional allowance (trade promotion), or volume rebate (quantity-based incentive).' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionLimitPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Redemption Limit Per Transaction' ;
    rdfs:comment 'Maximum number of rebate instances that can be applied in a single transaction. Null if no limit applies.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresProofOfPurchase rdf:type rdf:Property ;
    rdfs:label 'Requires Proof Of Purchase' ;
    rdfs:comment 'Indicates whether customers must submit receipt or purchase documentation to claim the rebate. True for mail-in rebates, false for instant rebates applied at Point of Sale.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stackableWithOtherPromotions rdf:type rdf:Property ;
    rdfs:label 'Stackable With Other Promotions' ;
    rdfs:comment 'Indicates whether this rebate can be combined with other promotional offers (coupons, markdowns, Buy One Get One (BOGO) deals) in the same transaction.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline Date' ;
    rdfs:comment 'Final date by which customers must submit rebate claims for purchases made during the effective period. Typically extends beyond the effective end date for mail-in rebates.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorFundingPercentage rdf:type rdf:Property ;
    rdfs:label 'Vendor Funding Percentage' ;
    rdfs:comment 'Percentage of the rebate cost funded by the vendor in co-op promotional agreements (e.g., 75.00 means vendor pays 75%, retailer pays 25%). Null for fully retailer-funded rebates.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateClaimId rdf:type rdf:Property ;
    rdfs:label 'Rebate Claim Id' ;
    rdfs:comment 'Unique identifier for the rebate claim transaction. Primary key for the rebate claim entity.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'Dollar amount of rebate approved for payment after claim review and validation. May differ from claimed amount if adjustments are made.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the rebate claim, used for customer and vendor communication and tracking.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle status of the rebate claim in the processing workflow. Tracks progression from submission through final disposition.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantEmail rdf:type rdf:Property ;
    rdfs:label 'Claimant Email' ;
    rdfs:comment 'Primary email address of the claimant for claim status notifications and correspondence.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantName rdf:type rdf:Property ;
    rdfs:label 'Claimant Name' ;
    rdfs:comment 'Full legal name of the individual or organization submitting the rebate claim. Used for correspondence and payment processing.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantPhone rdf:type rdf:Property ;
    rdfs:label 'Claimant Phone' ;
    rdfs:comment 'Primary contact phone number for the claimant. Used for claim verification and issue resolution.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantType rdf:type rdf:Property ;
    rdfs:label 'Claimant Type' ;
    rdfs:comment 'Classification of the party submitting the rebate claim. Distinguishes between customer rebates, vendor-funded rebates, and supplier chargebacks.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimedAmount rdf:type rdf:Property ;
    rdfs:label 'Claimed Amount' ;
    rdfs:comment 'Dollar amount of rebate being claimed by the claimant. Subject to validation against promotion terms and purchase amount.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysToApproval rdf:type rdf:Property ;
    rdfs:label 'Days To Approval' ;
    rdfs:comment 'Actual number of calendar days from claim submission to approval decision. Used for SLA performance measurement and process optimization.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentationStatus rdf:type rdf:Property ;
    rdfs:label 'Documentation Status' ;
    rdfs:comment 'Status of required supporting documentation (receipts, proof of purchase, UPC codes) for the rebate claim. Determines claim processing readiness.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingSlaDays rdf:type rdf:Property ;
    rdfs:label 'Processing Sla Days' ;
    rdfs:comment 'Number of business days allowed for claim processing per the rebate program terms. Used to track SLA compliance and processing efficiency.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productSku rdf:type rdf:Property ;
    rdfs:label 'Product Sku' ;
    rdfs:comment 'Internal SKU identifier of the qualifying product. Links to product master for eligibility validation and rebate calculation.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Purchase Amount' ;
    rdfs:comment 'Total purchase amount of the qualifying transaction. Used to calculate rebate entitlement and validate claim eligibility.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseDate rdf:type rdf:Property ;
    rdfs:label 'Purchase Date' ;
    rdfs:comment 'Date of the qualifying purchase transaction that triggered rebate eligibility. Used to validate claim timing against promotion period.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptUploaded rdf:type rdf:Property ;
    rdfs:label 'Receipt Uploaded' ;
    rdfs:comment 'Indicates whether the claimant has uploaded a digital copy of the purchase receipt as supporting documentation.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for claim rejection. Supports rejection pattern analysis and process improvement.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Description' ;
    rdfs:comment 'Detailed explanation of why the rebate claim was rejected. Provided to claimant for transparency and potential resubmission guidance.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date when the rebate claim was reviewed by claims processing team. Marks transition from submitted to under review status.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:upcCode rdf:type rdf:Property ;
    rdfs:label 'Upc Code' ;
    rdfs:comment '12-digit UPC barcode of the qualifying product purchased. Used to validate product eligibility for the rebate program.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorChargebackStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Chargeback Status' ;
    rdfs:comment 'Status of the chargeback claim submitted to the vendor for reimbursement of the rebate payment. Tracks vendor-funded rebate reconciliation.' ;
    rdfs:domain ind:RebateClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPromoAgreementId rdf:type rdf:Property ;
    rdfs:label 'Vendor Promo Agreement Id' ;
    rdfs:comment 'Unique identifier for the vendor-funded promotional agreement record. Primary key.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorPromoAgreement .

ind:primaryVendorAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Vendor Associate Id' ;
    rdfs:comment 'Identifier of the internal user or manager who approved this promotional agreement.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:accrualMethod rdf:type rdf:Property ;
    rdfs:label 'Accrual Method' ;
    rdfs:comment 'Method used to calculate promotional funding accrual. Purchase-based: accrues on retailer purchase volume. Sales-based: accrues on consumer sales (scan data). Display-based: accrues on compliance with display requirements. Hybrid: combination of methods.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adPlacementRequired rdf:type rdf:Property ;
    rdfs:label 'Ad Placement Required' ;
    rdfs:comment 'Indicates whether the retailer must feature the product in circular ads, digital promotions, or other marketing materials to qualify for co-op advertising funding.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Human-readable descriptive name for the promotional agreement, typically including campaign theme or product category.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Penalty Amount' ;
    rdfs:comment 'Fixed monetary penalty amount per chargeback incident for vendor non-compliance, in the agreement currency. Nullable if chargeback is not eligible or penalty is variable.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the signed legal contract or agreement document stored in the document management system.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Display Compliance Required' ;
    rdfs:comment 'Indicates whether the retailer must meet specific in-store display requirements (endcap placement, planogram compliance, shelf positioning) to qualify for funding.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fundingAmount rdf:type rdf:Property ;
    rdfs:label 'Funding Amount' ;
    rdfs:comment 'Total monetary value of vendor promotional funding committed under this agreement, in the agreement currency.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Funding Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the funding amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingPercentage rdf:type rdf:Property ;
    rdfs:label 'Funding Percentage' ;
    rdfs:comment 'Percentage of qualifying costs or sales that the vendor will fund, expressed as a decimal (e.g., 15.00 for 15%). Used for co-op advertising and scan-based allowances.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceObligationDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Description' ;
    rdfs:comment 'Detailed narrative of the retailer\'s obligations under this agreement, including display requirements, advertising commitments, volume targets, and reporting duties.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingProductScope rdf:type rdf:Property ;
    rdfs:label 'Qualifying Product Scope' ;
    rdfs:comment 'Defines which products are eligible for promotional funding under this agreement. Specific SKU: single item. Product category: all items in a category. Brand: all items of a vendor brand. Private label: retailer-branded items.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTerms rdf:type rdf:Property ;
    rdfs:label 'Settlement Terms' ;
    rdfs:comment 'Defines how and when the vendor funding will be paid or credited. Upfront credit: applied at purchase. Monthly accrual: credited monthly. Quarterly settlement: paid quarterly. Post-event claim: retailer submits claim after promotion ends. Scan-based settlement: paid based on POS scan data.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAccruedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Accrued Amount' ;
    rdfs:comment 'Cumulative amount of promotional funding accrued to date under this agreement, in the agreement currency. Updated as qualifying events occur.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSettledAmount rdf:type rdf:Property ;
    rdfs:label 'Total Settled Amount' ;
    rdfs:comment 'Cumulative amount of promotional funding that has been paid or credited to the retailer to date, in the agreement currency.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorPromoAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Promo Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the promotional agreement. Draft: under negotiation. Pending approval: awaiting internal sign-off. Active: in effect and accruing. Suspended: temporarily paused. Completed: ended normally. Terminated: ended early. Settled: financially reconciled. [ENUM-REF-CANDIDATE: draft|pending approval|active|suspended|completed|terminated|settled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPromoClaimId rdf:type rdf:Property ;
    rdfs:label 'Vendor Promo Claim Id' ;
    rdfs:comment 'Unique identifier for the vendor promotional funding claim. Primary key.' ;
    rdfs:domain ind:VendorPromoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimDate rdf:type rdf:Property ;
    rdfs:label 'Claim Date' ;
    rdfs:comment 'Date on which the promotional funding claim was created or initiated by the retailer.' ;
    rdfs:domain ind:VendorPromoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimNotes rdf:type rdf:Property ;
    rdfs:label 'Claim Notes' ;
    rdfs:comment 'Free-text notes or comments regarding the claim, including internal notes, vendor communications, or special circumstances.' ;
    rdfs:domain ind:VendorPromoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Claim Period End Date' ;
    rdfs:comment 'End date of the promotional period or sales period covered by this claim.' ;
    rdfs:domain ind:VendorPromoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Claim Period Start Date' ;
    rdfs:comment 'Start date of the promotional period or sales period covered by this claim.' ;
    rdfs:domain ind:VendorPromoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Claim Source System' ;
    rdfs:comment 'Name or identifier of the source system that originated the claim data, such as Oracle Retail Price Management (RPM), SAP Customer Activity Repository (CAR), or manual entry.' ;
    rdfs:domain ind:VendorPromoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Type of vendor promotional funding claim: scan allowance (per-unit sold), bill-back (post-event invoice), co-op reimbursement (shared marketing cost), markdown allowance (price reduction funding), volume rebate (tier-based incentive), or slotting fee (shelf placement fee recovery).' ;
    rdfs:domain ind:VendorPromoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'Date on which a disputed claim was resolved through negotiation, arbitration, or mutual agreement.' ;
    rdfs:domain ind:VendorPromoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'Monetary amount under dispute between the retailer and vendor, representing the difference between claimed and approved amounts.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAutomatedClaim rdf:type rdf:Property ;
    rdfs:label 'Is Automated Claim' ;
    rdfs:comment 'Boolean flag indicating whether the claim was generated automatically by the system based on Point of Sale (POS) scan data and agreement rules (True) or manually created by a user (False).' ;
    rdfs:domain ind:VendorPromoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesRevenue rdf:type rdf:Property ;
    rdfs:label 'Sales Revenue' ;
    rdfs:comment 'Total gross sales revenue generated during the claim period for products covered by the vendor promotional agreement, used as supporting evidence for the claim.' ;
    rdfs:domain ind:VendorPromoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settledAmount rdf:type rdf:Property ;
    rdfs:label 'Settled Amount' ;
    rdfs:comment 'Actual monetary amount received from the vendor as final settlement of the claim, reflecting any adjustments or deductions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Reference' ;
    rdfs:comment 'Reference identifier or URI to supporting documentation such as Point of Sale (POS) transaction reports, sales summaries, or promotional performance reports submitted with the claim.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Acknowledgment Date' ;
    rdfs:comment 'Date on which the vendor formally acknowledged receipt of the claim submission.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorResponseDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Response Date' ;
    rdfs:comment 'Date on which the vendor provided their formal response (approval, partial approval, dispute, or rejection) to the claim.' ;
    rdfs:domain ind:VendorPromoClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchId rdf:type rdf:Property ;
    rdfs:label 'Batch Id' ;
    rdfs:comment 'Batch identifier grouping multiple disposition records processed together. Used for bulk RTV shipments, liquidation lots, or mass restocking operations.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LiquidationBatch .

ind:inventoryStockLedgerId rdf:type rdf:Property ;
    rdfs:label 'Inventory Stock Ledger Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_ledger. Business justification: Return dispositions (restock, liquidate, destroy) generate inventory transactions that should be tracked in the stock ledger. This links returns disposition decisions to inventory accounting. No visib' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockLedger .

ind:liquidationPartnerVendorId rdf:type rdf:Property ;
    rdfs:label 'Liquidation Partner Vendor Id' ;
    rdfs:comment 'Identifier of the third-party liquidation partner if disposition type is liquidation. Tracks which liquidator handled the item for recovery value reconciliation.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:responsibleAssociateId rdf:type rdf:Property ;
    rdfs:label 'Responsible Associate Id' ;
    rdfs:comment 'Identifier of the warehouse associate or returns processor who made or approved the disposition decision. Used for accountability and quality tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:rmaLineId rdf:type rdf:Property ;
    rdfs:label 'Rma Line Id' ;
    rdfs:comment 'Reference to the specific return line item that this disposition decision applies to. Links disposition to the originating return merchandise authorization line.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RmaLine .

ind:supplierRtvRequestId rdf:type rdf:Property ;
    rdfs:label 'Supplier Rtv Request Id' ;
    rdfs:comment 'Foreign key linking to supplier.rtv_request. Business justification: Disposition decisions (restock/RTV/liquidate) directly trigger supplier RTV requests. Loss prevention teams measure recovery rates by linking disposition outcomes to vendor credit receipts. Enables cl' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RtvRequest .

ind:actualRecoveryValue rdf:type rdf:Property ;
    rdfs:label 'Actual Recovery Value' ;
    rdfs:comment 'Realized financial recovery value after disposition execution. Populated after liquidation sale, vendor credit, or restock completion. Used for variance analysis against estimates.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionGrade rdf:type rdf:Property ;
    rdfs:label 'Condition Grade' ;
    rdfs:comment 'Quality assessment grade assigned during inspection. A=New/Unopened, B=Like New/Minor Packaging Damage, C=Good/Visible Wear, D=Fair/Functional Defects, F=Unsellable/Damaged. Drives disposition type and recovery value estimation.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'The date when the disposition decision was made by the returns processing team or system. Key timestamp for cycle time analytics.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:defectCode rdf:type rdf:Property ;
    rdfs:label 'Defect Code' ;
    rdfs:comment 'Standardized code identifying the specific defect or damage type found during inspection. Used for quality analytics and vendor chargeback justification.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Disposition Status' ;
    rdfs:comment 'Current lifecycle status of the disposition action. Tracks progress from decision through execution.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionType rdf:type rdf:Property ;
    rdfs:label 'Disposition Type' ;
    rdfs:comment 'The final fate decision for the returned item. Determines the next step in the reverse logistics workflow and impacts inventory valuation and recovery value.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRecoveryValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Recovery Value' ;
    rdfs:comment 'Projected financial recovery value for the item based on disposition type and condition grade. Used for shrinkage forecasting and reverse logistics ROI analysis.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isSerialized rdf:type rdf:Property ;
    rdfs:label 'Is Serialized' ;
    rdfs:comment 'Flag indicating whether the item has a unique serial number requiring individual tracking through disposition process. Common for electronics and high-value goods.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restockLocationCode rdf:type rdf:Property ;
    rdfs:label 'Restock Location Code' ;
    rdfs:comment 'Specific inventory location code where the item will be restocked if disposition type is restock_sellable or restock_clearance. May be a bin, aisle, or zone identifier within the facility.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockingFeeApplied rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Applied' ;
    rdfs:comment 'Flag indicating whether a restocking fee was charged to the customer for this return. Impacts refund amount and customer satisfaction metrics.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exchangeOrderId rdf:type rdf:Property ;
    rdfs:label 'Exchange Order Id' ;
    rdfs:comment 'Unique identifier for the exchange order. Primary key.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryExchangeHeaderId rdf:type rdf:Property ;
    rdfs:label 'Primary Exchange Header Id' ;
    rdfs:comment 'Reference to the original order from which the returned item originated.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:replacementSkuId rdf:type rdf:Property ;
    rdfs:label 'Replacement Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Exchange fulfillment requires direct replacement SKU reference for inventory allocation, ATP (available-to-promise) checking, and like-for-like exchange policy enforcement. Essential for retail exchan' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:rmaId rdf:type rdf:Property ;
    rdfs:label 'Rma Id' ;
    rdfs:comment 'Reference to the originating RMA that triggered this exchange order.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rma .

ind:additionalPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Additional Payment Method' ;
    rdfs:comment 'Payment method used by the customer to cover any price differential for an upgrade exchange.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:additionalPaymentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Additional Payment Required Flag' ;
    rdfs:comment 'Indicates whether the customer must provide additional payment due to a price differential (upgrade scenario).' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exchangeApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exchange Approved Timestamp' ;
    rdfs:comment 'Date and time when the exchange request was approved by the returns management system or customer service representative.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exchange Completed Timestamp' ;
    rdfs:comment 'Date and time when the entire exchange transaction was finalized, including receipt of returned item and delivery of replacement.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeDeliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exchange Delivered Timestamp' ;
    rdfs:comment 'Date and time when the replacement item was successfully delivered to the customer.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Initiated Date' ;
    rdfs:comment 'Date when the customer first requested the exchange, typically when the RMA was created.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Exchange Order Number' ;
    rdfs:comment 'Human-readable business identifier for the exchange order, used for customer communication and tracking.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Exchange Order Status' ;
    rdfs:comment 'Current lifecycle status of the exchange order in the fulfillment workflow. [ENUM-REF-CANDIDATE: pending|approved|processing|shipped|delivered|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Exchange Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason the customer requested an exchange rather than a refund.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Exchange Reason Description' ;
    rdfs:comment 'Free-text description providing additional context about why the customer requested an exchange.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeShippedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exchange Shipped Timestamp' ;
    rdfs:comment 'Date and time when the replacement item was shipped to the customer.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeSourceChannel rdf:type rdf:Property ;
    rdfs:label 'Exchange Source Channel' ;
    rdfs:comment 'Channel through which the customer initiated the exchange request.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeType rdf:type rdf:Property ;
    rdfs:label 'Exchange Type' ;
    rdfs:comment 'Classification of the exchange based on the relationship between returned and replacement items.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expeditedShippingFlag rdf:type rdf:Property ;
    rdfs:label 'Expedited Shipping Flag' ;
    rdfs:comment 'Indicates whether expedited shipping was used for the replacement item delivery.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceDifferentialCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Price Differential Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the price differential amount.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementQuantity rdf:type rdf:Property ;
    rdfs:label 'Replacement Quantity' ;
    rdfs:comment 'Number of units of the replacement SKU being sent to the customer.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnedSku rdf:type rdf:Property ;
    rdfs:label 'Returned Sku' ;
    rdfs:comment 'SKU of the product being returned by the customer as part of the exchange.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCostWaivedFlag rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost Waived Flag' ;
    rdfs:comment 'Indicates whether shipping costs for the replacement item have been waived as a customer service gesture.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liquidationGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Liquidation Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Liquidation batches require GL postings for inventory write-offs, loss recognition, and recovery proceeds. The existing gl_posting_reference indicates financial posting but lacks proper FK. Essential ' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:primaryLiquidationAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Liquidation Associate Id' ;
    rdfs:comment 'Reference to the user who created the liquidation batch record, supporting audit trail and accountability requirements.' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:batchApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Batch Approval Date' ;
    rdfs:comment 'Date when the liquidation batch was approved for release to the liquidation partner, marking the transition from internal review to external sale process.' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchCreationDate rdf:type rdf:Property ;
    rdfs:label 'Batch Creation Date' ;
    rdfs:comment 'Date when the liquidation batch record was initially created in the system and merchandise consolidation began.' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle status of the liquidation batch indicating its position in the reverse logistics workflow from creation through final sale completion. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|in_transit|received|sold|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerFeedback rdf:type rdf:Property ;
    rdfs:label 'Buyer Feedback' ;
    rdfs:comment 'Feedback provided by the liquidation partner or buyer regarding the batch quality, accuracy, and condition upon receipt, used for continuous improvement.' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryMix rdf:type rdf:Property ;
    rdfs:label 'Category Mix' ;
    rdfs:comment 'Summary description of the product categories and merchandise types included in this liquidation batch, helping buyers assess assortment fit.' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionGradeMix rdf:type rdf:Property ;
    rdfs:label 'Condition Grade Mix' ;
    rdfs:comment 'Summary description of the mix of merchandise condition grades (A-New through F-Unsellable) included in this batch, providing buyers with quality expectations.' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalSalePrice rdf:type rdf:Property ;
    rdfs:label 'Final Sale Price' ;
    rdfs:comment 'Actual price at which the liquidation batch was sold to the liquidation partner or buyer, representing the gross recovery amount before fees and expenses.' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glPostingReference rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Reference' ;
    rdfs:comment 'Reference to the general ledger journal entry or posting that recorded the Cost of Goods Sold (COGS) write-off and recovery accounting for this liquidation batch.' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidationChannel rdf:type rdf:Property ;
    rdfs:label 'Liquidation Channel' ;
    rdfs:comment 'The distribution channel or method through which the returned merchandise in this batch is being liquidated, determining the sales approach and partner type.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidationFees rdf:type rdf:Property ;
    rdfs:label 'Liquidation Fees' ;
    rdfs:comment 'Total fees charged by the liquidation partner, auction house, or marketplace for handling the sale, including commission, listing fees, and transaction charges.' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidationPartnerReference rdf:type rdf:Property ;
    rdfs:label 'Liquidation Partner Reference' ;
    rdfs:comment 'External reference number or identifier provided by the liquidation partner for tracking this batch in their system.' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Manifest Document Url' ;
    rdfs:comment 'URL link to the detailed item-level manifest document listing all SKUs (Stock Keeping Units), quantities, and condition grades in the liquidation batch.' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netRecoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Net Recovery Amount' ;
    rdfs:comment 'Net proceeds from the liquidation sale after deducting all fees, transportation costs, and other expenses from the final sale price. Used for shrinkage and loss accounting.' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:palletCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Count' ;
    rdfs:comment 'Number of pallets used to consolidate and ship the liquidation batch merchandise, supporting logistics planning and handling requirements.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresDataDestruction rdf:type rdf:Property ;
    rdfs:label 'Requires Data Destruction' ;
    rdfs:comment 'Flag indicating whether the batch contains electronic devices or media requiring certified data destruction before liquidation to protect customer privacy and comply with data protection regulations.' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reservePrice rdf:type rdf:Property ;
    rdfs:label 'Reserve Price' ;
    rdfs:comment 'Minimum acceptable sale price set for the liquidation batch, below which the merchandise will not be sold. Used primarily in auction and negotiated sale scenarios.' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saleDate rdf:type rdf:Property ;
    rdfs:label 'Sale Date' ;
    rdfs:comment 'Date when the liquidation batch was sold to the final buyer, marking the completion of the liquidation transaction and triggering financial settlement.' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxWriteOffAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Write Off Amount' ;
    rdfs:comment 'Amount eligible for tax deduction related to the liquidation loss, calculated as the difference between cost value and recovery amount, supporting tax accounting and compliance.' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCostValue rdf:type rdf:Property ;
    rdfs:label 'Total Cost Value' ;
    rdfs:comment 'Aggregate Cost of Goods Sold (COGS) value for all merchandise units in the batch, representing the original acquisition cost basis for accounting and write-off calculations.' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportationCost rdf:type rdf:Property ;
    rdfs:label 'Transportation Cost' ;
    rdfs:comment 'Cost incurred for shipping and transporting the liquidation batch from the originating distribution center to the liquidation partner or buyer location.' ;
    rdfs:domain ind:LiquidationBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic Meters' ;
    rdfs:comment 'Total volume of the liquidation batch merchandise in cubic meters, used for warehouse space planning and transportation capacity requirements.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidationItemId rdf:type rdf:Property ;
    rdfs:label 'Liquidation Item Id' ;
    rdfs:comment 'Unique identifier for the liquidation item line within a liquidation batch. Primary key.' ;
    rdfs:domain ind:LiquidationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualRecoveryValuePerUnit rdf:type rdf:Property ;
    rdfs:label 'Actual Recovery Value Per Unit' ;
    rdfs:comment 'Actual amount recovered per unit after liquidation sale completion. Used for variance analysis and recovery rate tracking.' ;
    rdfs:domain ind:LiquidationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualTotalRecoveryValue rdf:type rdf:Property ;
    rdfs:label 'Actual Total Recovery Value' ;
    rdfs:comment 'Total actual recovery amount for this line item (quantity × actual recovery value per unit). Used for final P&L impact calculation.' ;
    rdfs:domain ind:LiquidationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'Final disposition decision that led to liquidation. Indicates why this item was routed to liquidation rather than restocking or vendor return.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRecoveryValuePerUnit rdf:type rdf:Property ;
    rdfs:label 'Estimated Recovery Value Per Unit' ;
    rdfs:comment 'Projected recovery amount per unit based on condition grade and market conditions at time of liquidation planning. Used for financial forecasting.' ;
    rdfs:domain ind:LiquidationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTotalRecoveryValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Recovery Value' ;
    rdfs:comment 'Total projected recovery amount for this line item (quantity × estimated recovery value per unit). Used for P&L forecasting.' ;
    rdfs:domain ind:LiquidationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lossAmount rdf:type rdf:Property ;
    rdfs:label 'Loss Amount' ;
    rdfs:comment 'Net loss on this line item (total cost minus actual total recovery value). Used for COGS write-off and shrinkage reporting.' ;
    rdfs:domain ind:LiquidationItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseLocationCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Code' ;
    rdfs:comment 'Distribution center or warehouse location where the item was held prior to liquidation. Used for facility-level liquidation tracking.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundId rdf:type rdf:Property ;
    rdfs:label 'Refund Id' ;
    rdfs:comment 'Primary key for refund' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refundApprovedByEmployeeAssociateId rdf:type rdf:Property ;
    rdfs:label 'Refund Approved By Employee Associate Id' ;
    rdfs:comment 'Reference to the manager or authorized employee who approved the refund, if approval was required. Used for compliance and authorization audit trail.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:refundAssociateId rdf:type rdf:Property ;
    rdfs:label 'Refund Associate Id' ;
    rdfs:comment 'Reference to the employee or customer service representative who processed the refund transaction. Used for audit trail and performance tracking.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:actualSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Actual Settlement Date' ;
    rdfs:comment 'Actual date when the refund funds were confirmed as settled and available to the customer. Used for SLA compliance measurement and financial reconciliation. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Additional positive or negative adjustment applied to the refund for reasons such as damage, missing components, promotional credits, or goodwill gestures.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Expected Settlement Date' ;
    rdfs:comment 'Anticipated date when the refund funds will be available to the customer in their account. Used for customer communication and service level agreement (SLA) tracking. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:merchandiseAmount rdf:type rdf:Property ;
    rdfs:label 'Merchandise Amount' ;
    rdfs:comment 'The gross value of returned merchandise being refunded, before any fees, taxes, or adjustments. Represents the base product value from the original transaction.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'Date and time when the refund was submitted to the payment processor for execution. Indicates when the financial transaction was initiated. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processorResponseCode rdf:type rdf:Property ;
    rdfs:label 'Processor Response Code' ;
    rdfs:comment 'Standardized response code returned by the payment processor indicating success, failure, or specific error condition. Used for operational monitoring and troubleshooting.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorResponseMessage rdf:type rdf:Property ;
    rdfs:label 'Processor Response Message' ;
    rdfs:comment 'Human-readable message from the payment processor providing additional context about the transaction result. Used for customer service and technical support.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundNumber rdf:type rdf:Property ;
    rdfs:label 'Refund Number' ;
    rdfs:comment 'Human-readable business identifier for the refund transaction. Used for customer communication, customer service lookup, and external reporting. Format: RFN-XXXXXXXXXX.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundStatus rdf:type rdf:Property ;
    rdfs:label 'Refund Status' ;
    rdfs:comment 'Current lifecycle status of the refund transaction. Tracks progression from initiation through final settlement or failure. Used for operational monitoring and customer service inquiries. [ENUM-REF-CANDIDATE: pending|approved|processing|completed|failed|reversed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundType rdf:type rdf:Property ;
    rdfs:label 'Refund Type' ;
    rdfs:comment 'Classification of the refund based on the portion of the original transaction being refunded and any adjustments applied.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockingFee rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee' ;
    rdfs:comment 'Fee deducted from the refund amount to cover costs of processing, inspecting, and restocking returned merchandise. Applied per return policy terms.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Total Refund Amount' ;
    rdfs:comment 'The final net amount refunded to the customer after all fees, taxes, and adjustments. This is the actual monetary value transferred back to the customer.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restockEventId rdf:type rdf:Property ;
    rdfs:label 'Restock Event Id' ;
    rdfs:comment 'Unique identifier for the restock event. Primary key for this operational record capturing the restocking of a returned item back into sellable or clearance inventory.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restockLocationId rdf:type rdf:Property ;
    rdfs:label 'Restock Location Id' ;
    rdfs:comment 'Reference to the specific store, distribution center, or fulfillment node where the item was restocked into inventory. Links to the location master data.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:restockedByAssociateId rdf:type rdf:Property ;
    rdfs:label 'Restocked By Associate Id' ;
    rdfs:comment 'Reference to the warehouse or store associate who performed the restocking action. Links to the workforce master data for accountability and productivity tracking.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:aisleNumber rdf:type rdf:Property ;
    rdfs:label 'Aisle Number' ;
    rdfs:comment 'The aisle identifier where the restocked item was placed on the sales floor or in the warehouse. Supports store operations and inventory locating.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'The specific bin, shelf, or storage location identifier within the warehouse or store where the item was placed during restocking. Used for precise inventory tracking and picking operations.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCompleted rdf:type rdf:Property ;
    rdfs:label 'Inspection Completed' ;
    rdfs:comment 'Boolean flag indicating whether required quality inspection has been completed for the restocked item. True when inspection is finished and item is cleared for sale.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Required' ;
    rdfs:comment 'Boolean flag indicating whether the restocked item requires additional quality inspection before being made available for sale. True for items with condition concerns or regulatory requirements.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'The date and time when quality inspection was completed for the restocked item. Null if no inspection was required or inspection is still pending.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inventoryAdjustmentPosted rdf:type rdf:Property ;
    rdfs:label 'Inventory Adjustment Posted' ;
    rdfs:comment 'Boolean flag indicating whether the inventory adjustment transaction has been successfully posted to the warehouse management system and inventory ledger. True when the on-hand quantity has been updated.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryAdjustmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inventory Adjustment Timestamp' ;
    rdfs:comment 'The date and time when the inventory adjustment transaction was posted to the WMS and inventory systems. May differ from restock_timestamp if there is a processing delay.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalCost rdf:type rdf:Property ;
    rdfs:label 'Original Cost' ;
    rdfs:comment 'The original cost of goods sold (COGS) for the restocked item. Used for inventory valuation and financial reconciliation of returned merchandise.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRestocked rdf:type rdf:Property ;
    rdfs:label 'Quantity Restocked' ;
    rdfs:comment 'The quantity of units restocked back into inventory in this event. Supports fractional quantities for items sold by weight or volume.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restockLocationType rdf:type rdf:Property ;
    rdfs:label 'Restock Location Type' ;
    rdfs:comment 'The type of facility where the item was restocked. Indicates whether restocking occurred at a retail store, distribution center (DC), micro-fulfillment center (MFC), dark store, or was returned to vendor.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockReasonCode rdf:type rdf:Property ;
    rdfs:label 'Restock Reason Code' ;
    rdfs:comment 'The reason code explaining why this item was restocked. Distinguishes between customer returns that passed inspection, vendor returns, warranty exchanges, and other restock scenarios.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockTimestamp rdf:type rdf:Property ;
    rdfs:label 'Restock Timestamp' ;
    rdfs:comment 'The date and time when the restocking action was completed and the item was placed back into available inventory. This is the principal business event timestamp for the restock transaction.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restockedValue rdf:type rdf:Property ;
    rdfs:label 'Restocked Value' ;
    rdfs:comment 'The inventory value assigned to the restocked item after any markdown or condition adjustment. Represents the expected recoverable value of the returned merchandise.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfPosition rdf:type rdf:Property ;
    rdfs:label 'Shelf Position' ;
    rdfs:comment 'The specific shelf or position identifier within the aisle where the item was restocked. Enables precise planogram compliance and inventory locating.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Reference' ;
    rdfs:comment 'The unique transaction identifier from the source system that generated this restock event. Enables traceability back to the originating system record for audit and reconciliation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLocationId rdf:type rdf:Property ;
    rdfs:label 'Detection Location Id' ;
    rdfs:comment 'Store or fulfillment center where the suspected fraud was detected or where the fraudulent return was attempted.' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:primaryReturnAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Return Associate Id' ;
    rdfs:comment 'Identifier of the loss prevention or fraud investigation employee assigned to this case.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:caseClosedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Case Closed Timestamp' ;
    rdfs:comment 'Date and time when the fraud investigation case was formally closed with a final disposition.' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:caseOpenedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Case Opened Timestamp' ;
    rdfs:comment 'Date and time when the formal fraud investigation case was opened and assigned for review.' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:civilRecoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Civil Recovery Amount' ;
    rdfs:comment 'Monetary amount sought or recovered through civil demand letter or restitution process.' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerReturnCount90d rdf:type rdf:Property ;
    rdfs:label 'Customer Return Count 90d' ;
    rdfs:comment 'Total number of returns initiated by this customer in the 90 days prior to case detection, used to identify serial returner patterns.' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerReturnValue90d rdf:type rdf:Property ;
    rdfs:label 'Customer Return Value 90d' ;
    rdfs:comment 'Total monetary value of returns initiated by this customer in the 90 days prior to case detection.' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Date and time when the suspected fraud was first detected or flagged in the system.' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:enforcementActionTaken rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Taken' ;
    rdfs:comment 'Action taken by the retailer in response to confirmed fraud. None indicates no action; RMA denial means return was rejected; account restriction limits future returns; account suspension temporarily blocks account; account termination permanently closes account; law enforcement referral involves police; civil demand letter seeks restitution; store ban prohibits physical store access. [ENUM-REF-CANDIDATE: none|rma_denial|account_restriction|account_suspension|account_termination|law_enforcement_referral|civil_demand_letter|store_ban — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFraudValueAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Fraud Value Amount' ;
    rdfs:comment 'Estimated monetary value of the fraudulent activity in the transaction currency, used for shrinkage reporting and loss quantification.' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceDescription rdf:type rdf:Property ;
    rdfs:label 'Evidence Description' ;
    rdfs:comment 'Detailed narrative description of evidence collected during the investigation, including witness statements, video surveillance references, receipt analysis, product inspection findings, and other supporting documentation.' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudIndicators rdf:type rdf:Property ;
    rdfs:label 'Fraud Indicators' ;
    rdfs:comment 'Comma-separated list of specific fraud indicators or red flags that triggered the investigation, such as high return frequency, missing tags, altered receipts, mismatched serial numbers, or suspicious timing patterns.' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudTypology rdf:type rdf:Property ;
    rdfs:label 'Fraud Typology' ;
    rdfs:comment 'Classification of the type of return fraud detected. Wardrobing refers to purchasing items for temporary use and returning them; receipt fraud involves fraudulent or altered receipts; empty box is returning packaging without merchandise; stolen merchandise return is attempting to return stolen goods; serial returner pattern indicates abuse through excessive returns; refund abuse involves exploiting return policies; price switching is manipulating price tags; counterfeit return is returning fake merchandise. [ENUM-REF-CANDIDATE: wardrobing|receipt_fraud|empty_box|stolen_merchandise_return|serial_returner_pattern|refund_abuse|price_switching|counterfeit_return — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationOutcome rdf:type rdf:Property ;
    rdfs:label 'Investigation Outcome' ;
    rdfs:comment 'Final determination of the fraud investigation. Fraud confirmed means evidence supports fraudulent intent; fraud unsubstantiated means insufficient evidence; customer error indicates unintentional mistake; policy misunderstanding means customer misinterpreted return policy; system error indicates operational or technical issue; pending means investigation incomplete.' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationPriority rdf:type rdf:Property ;
    rdfs:label 'Investigation Priority' ;
    rdfs:comment 'Priority level assigned to the fraud case based on estimated value, customer history, and fraud typology. Critical cases involve high-value fraud or organized retail crime; high priority involves significant loss or repeat offenders; medium priority is standard investigation; low priority is minor suspected abuse.' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigatorNotes rdf:type rdf:Property ;
    rdfs:label 'Investigator Notes' ;
    rdfs:comment 'Internal notes and observations recorded by the assigned investigator during the case review process.' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Case Number' ;
    rdfs:comment 'Official case number assigned by law enforcement agency if the fraud case was referred for criminal prosecution.' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedRmaCount rdf:type rdf:Property ;
    rdfs:label 'Linked Rma Count' ;
    rdfs:comment 'Total number of RMA records associated with this fraud investigation, used to identify patterns across multiple return transactions.' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managementReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Management Review Required Flag' ;
    rdfs:comment 'Indicates whether the case requires senior management or legal review before enforcement action, typically true for high-value cases or law enforcement referrals.' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relatedCaseIds rdf:type rdf:Property ;
    rdfs:label 'Related Case Ids' ;
    rdfs:comment 'Comma-separated list of other fraud case IDs that are related to this case, used to track organized retail crime rings or coordinated fraud patterns across multiple customers or locations.' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Date and time when management review was completed and case disposition was approved.' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:thirdPartyFraudServiceCode rdf:type rdf:Property ;
    rdfs:label 'Third Party Fraud Service Code' ;
    rdfs:comment 'External fraud detection service case identifier if the case was flagged or validated by a third-party fraud prevention vendor.' ;
    rdfs:domain ind:ReturnFraudCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnPolicyId rdf:type rdf:Property ;
    rdfs:label 'Return Policy Id' ;
    rdfs:comment 'Unique identifier for the return policy record. Primary key.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compliancePolicyId rdf:type rdf:Property ;
    rdfs:label 'Compliance Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: Return policies must align with corporate compliance policies governing consumer protection laws, FTC regulations, and state-specific return rights. Real business process: policy governance ensures re' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:acceptedCondition rdf:type rdf:Property ;
    rdfs:label 'Accepted Condition' ;
    rdfs:comment 'Required condition of merchandise for return acceptance. Defines whether items must be unopened, unused, or can be returned in any condition.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Customer segment or loyalty tier to which this return policy applies. Premium members may receive extended return windows.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeAllowed rdf:type rdf:Property ;
    rdfs:label 'Exchange Allowed' ;
    rdfs:comment 'Indicates whether direct product exchanges (size, color, model) are permitted under this policy without requiring a full return and repurchase.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extendedWindowDays rdf:type rdf:Property ;
    rdfs:label 'Extended Window Days' ;
    rdfs:comment 'Extended return window duration for premium loyalty tier members or special promotional periods. Nullable if no extension applies.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holidayExtensionApplicable rdf:type rdf:Property ;
    rdfs:label 'Holiday Extension Applicable' ;
    rdfs:comment 'Indicates whether this policy includes extended return windows for holiday season purchases (e.g., purchases made in November-December returnable through mid-January).' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionSlaHours rdf:type rdf:Property ;
    rdfs:label 'Inspection Sla Hours' ;
    rdfs:comment 'Target time in hours for completing merchandise inspection and condition assessment after return receipt. Used for operational SLA measurement.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:liquidationEligible rdf:type rdf:Property ;
    rdfs:label 'Liquidation Eligible' ;
    rdfs:comment 'Indicates whether returned merchandise under this policy can be sent to liquidation channels (discount outlets, bulk resellers) for recovery.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonReturnableItemExceptions rdf:type rdf:Property ;
    rdfs:label 'Non Returnable Item Exceptions' ;
    rdfs:comment 'Comma-separated list of item types or SKU patterns that are explicitly excluded from returns under this policy (e.g., perishables, intimate apparel, custom orders, clearance items).' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalPackagingRequired rdf:type rdf:Property ;
    rdfs:label 'Original Packaging Required' ;
    rdfs:comment 'Indicates whether the item must be returned in its original packaging for acceptance. Common for electronics and high-value items.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyUrl rdf:type rdf:Property ;
    rdfs:label 'Policy Url' ;
    rdfs:comment 'Web URL where the full return policy terms are published for customer reference. Required for e-commerce compliance.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfPurchaseRequired rdf:type rdf:Property ;
    rdfs:label 'Proof Of Purchase Required' ;
    rdfs:comment 'Indicates whether proof of purchase (receipt, order confirmation, transaction lookup) is mandatory for return processing.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundProcessingSlaHours rdf:type rdf:Property ;
    rdfs:label 'Refund Processing Sla Hours' ;
    rdfs:comment 'Target time in hours for completing refund processing from return acceptance to funds disbursement. Used for operational SLA measurement.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restockingFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Applicable' ;
    rdfs:comment 'Indicates whether a restocking fee is charged for returns under this policy. Common for high-value electronics and special-order items.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restockingFeeFlatAmount rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Flat Amount' ;
    rdfs:comment 'Fixed dollar amount charged as a restocking fee, regardless of purchase price. Nullable if percentage-based or no fee applies.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restockingFeePercent rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Percent' ;
    rdfs:comment 'Percentage of the original purchase price charged as a restocking fee. Nullable if no restocking fee applies. Typical range is 10-25%.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restockingSlaHours rdf:type rdf:Property ;
    rdfs:label 'Restocking Sla Hours' ;
    rdfs:comment 'Target time in hours for restocking accepted returned merchandise back into available inventory. Used for operational SLA measurement.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnPolicyStatus rdf:type rdf:Property ;
    rdfs:label 'Return Policy Status' ;
    rdfs:comment 'Current lifecycle status of the return policy. Only active policies are applied to new transactions.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnShippingPaidBy rdf:type rdf:Property ;
    rdfs:label 'Return Shipping Paid By' ;
    rdfs:comment 'Party responsible for paying return shipping costs. Retailer-paid shipping is common for defective items or retailer errors; customer-paid for buyer remorse.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnWindowDays rdf:type rdf:Property ;
    rdfs:label 'Return Window Days' ;
    rdfs:comment 'Number of days from purchase date during which a return is accepted under this policy. Standard retail windows range from 14 to 90 days.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmaAutoApprovalEnabled rdf:type rdf:Property ;
    rdfs:label 'Rma Auto Approval Enabled' ;
    rdfs:comment 'Indicates whether RMA requests are automatically approved based on policy rules without manual review. Drives automated return authorization logic.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'Sales channel(s) to which this return policy applies. Policies may vary by channel (e.g., online purchases may have different return windows than in-store). [ENUM-REF-CANDIDATE: in_store|online|mobile_app|bopis|ropis|call_center|all_channels — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCreditExpiryDays rdf:type rdf:Property ;
    rdfs:label 'Store Credit Expiry Days' ;
    rdfs:comment 'Number of days until store credit issued for returns expires. Nullable if store credit does not expire. Subject to state-specific gift card laws.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorReturnEligible rdf:type rdf:Property ;
    rdfs:label 'Vendor Return Eligible' ;
    rdfs:comment 'Indicates whether merchandise returned under this policy is eligible for Return to Vendor (RTV) processing to recover costs from suppliers.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnReceiptId rdf:type rdf:Property ;
    rdfs:label 'Return Receipt Id' ;
    rdfs:comment 'Unique identifier for the return receipt record. Primary key.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectorAssociateId rdf:type rdf:Property ;
    rdfs:label 'Inspector Associate Id' ;
    rdfs:comment 'Identifier of the associate who performed the detailed quality inspection. Null if inspection not required or not yet performed.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:receivingLocationId rdf:type rdf:Property ;
    rdfs:label 'Receiving Location Id' ;
    rdfs:comment 'Identifier of the store, distribution center, or micro-fulfillment center where the returned merchandise was received.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:authorizedQuantity rdf:type rdf:Property ;
    rdfs:label 'Authorized Quantity' ;
    rdfs:comment 'Total quantity of items authorized for return in the original RMA. Used to detect over-returns and under-returns.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Tracking Number' ;
    rdfs:comment 'Tracking number from the shipping carrier for mail-in or shipped returns. Used to reconcile carrier delivery events with physical receipt.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionAssessment rdf:type rdf:Property ;
    rdfs:label 'Condition Assessment' ;
    rdfs:comment 'Assessment of the physical condition of the returned merchandise at the time of receipt. Drives disposition decision and restocking eligibility. [ENUM-REF-CANDIDATE: new_unopened|like_new|good|fair|poor|damaged|defective|unsellable — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Free-text notes describing the nature of the discrepancy. Provides context for exception resolution and audit trail.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionRecommendation rdf:type rdf:Property ;
    rdfs:label 'Disposition Recommendation' ;
    rdfs:comment 'Recommended disposition action for the returned merchandise based on condition, value, and business rules. May be overridden by final disposition decision. [ENUM-REF-CANDIDATE: restock|liquidate|donate|destroy|rtv|repair|pending — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Completed Timestamp' ;
    rdfs:comment 'Date and time when detailed quality inspection was completed. Null if inspection not required or not yet performed.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packagingCondition rdf:type rdf:Property ;
    rdfs:label 'Packaging Condition' ;
    rdfs:comment 'Condition of the product packaging at receipt. Impacts resale value and disposition options.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the quantity fields. Ensures consistent interpretation of quantity values across different product types. [ENUM-REF-CANDIDATE: each|case|pallet|pound|kilogram|liter|gallon — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Receipt Source System' ;
    rdfs:comment 'Name of the operational system that captured the return receipt event. Supports data lineage and reconciliation.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptSourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Receipt Source System Code' ;
    rdfs:comment 'Unique identifier of this receipt record in the source operational system. Enables traceability and reconciliation.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingLocationType rdf:type rdf:Property ;
    rdfs:label 'Receiving Location Type' ;
    rdfs:comment 'Type of facility that received the returned merchandise. Determines downstream processing workflows and disposition options.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Recovery Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated recovery value. Supports multi-currency operations.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundHoldReason rdf:type rdf:Property ;
    rdfs:label 'Refund Hold Reason' ;
    rdfs:comment 'Reason why customer refund is being held pending resolution. Null or none if refund processed immediately upon receipt.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Refund Triggered Flag' ;
    rdfs:comment 'Indicates whether the receipt event triggered a customer refund workflow. Links physical receipt to financial refund processing.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restockingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Restocking Eligible Flag' ;
    rdfs:comment 'Indicates whether the returned merchandise is eligible for restocking and resale. Based on condition assessment and business rules.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnMethod rdf:type rdf:Property ;
    rdfs:label 'Return Method' ;
    rdfs:comment 'Method by which the customer returned the merchandise. Determines receipt workflow and processing requirements.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupAddressId rdf:type rdf:Property ;
    rdfs:label 'Pickup Address Id' ;
    rdfs:comment 'Identifier of the address from which the return items should be picked up, if pickup was requested.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:customerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Email' ;
    rdfs:comment 'Email address provided by the customer for communication regarding this return request.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Phone' ;
    rdfs:comment 'Phone number provided by the customer for communication regarding this return request.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReasonCode rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for denial if the return request was rejected (e.g., outside return window, final sale item, missing proof of purchase, item condition not acceptable).' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Description' ;
    rdfs:comment 'Detailed explanation provided to the customer explaining why the return request was denied.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialTimestamp rdf:type rdf:Property ;
    rdfs:label 'Denial Timestamp' ;
    rdfs:comment 'Date and time when the return request was denied, if applicable.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Refund Amount' ;
    rdfs:comment 'Estimated monetary value of the refund if the return request is approved, calculated based on original purchase price and applicable return policy rules.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudRiskScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Risk Score' ;
    rdfs:comment 'Calculated risk score (0-100) indicating the likelihood that this return request is fraudulent, based on customer history, return patterns, and fraud detection algorithms.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isWithinReturnWindow rdf:type rdf:Property ;
    rdfs:label 'Is Within Return Window' ;
    rdfs:comment 'Boolean flag indicating whether the return request was submitted within the eligible return window defined by the applicable return policy.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Original Purchase Date' ;
    rdfs:comment 'Date when the original order was placed, used to validate return eligibility against return window policies.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pickupRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Pickup Requested Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer has requested carrier pickup of the return items from their location.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredResolutionType rdf:type rdf:Property ;
    rdfs:label 'Preferred Resolution Type' ;
    rdfs:comment 'Customer-indicated preference for how they would like the return to be resolved (refund to original payment method, exchange for different item, store credit, or replacement of same item).' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestChannel rdf:type rdf:Property ;
    rdfs:label 'Request Channel' ;
    rdfs:comment 'Channel through which the customer submitted the return request (e-commerce portal, mobile app, call center, in-store associate, chatbot, email).' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Date and time when the customer initiated the return request. Represents the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Return Reason Description' ;
    rdfs:comment 'Detailed free-text description provided by the customer explaining the reason for the return.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnWindowExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Return Window Expiry Date' ;
    rdfs:comment 'Last date by which the return request must be submitted to be eligible under the applicable return policy (typically 30, 60, or 90 days from purchase).' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Internal notes added by the returns specialist during the review process, documenting decision rationale, policy exceptions, or special handling instructions.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseDueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Response Due Timestamp' ;
    rdfs:comment 'Target date and time by which the return request must be reviewed and responded to, based on applicable SLA (Service Level Agreement) commitments.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalItemsRequested rdf:type rdf:Property ;
    rdfs:label 'Total Items Requested' ;
    rdfs:comment 'Total count of distinct line items included in this return request.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalQuantityRequested rdf:type rdf:Property ;
    rdfs:label 'Total Quantity Requested' ;
    rdfs:comment 'Total quantity of units across all line items requested for return.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnShipmentId rdf:type rdf:Property ;
    rdfs:label 'Return Shipment Id' ;
    rdfs:comment 'Unique identifier for the return shipment record. Primary key for the return shipment entity.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originAddressId rdf:type rdf:Property ;
    rdfs:label 'Origin Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Return shipments require customer\'s origin address for carrier pickup scheduling and routing in reverse logistics. While return_shipment has origin_location_id for facilities, customer-initiated retur' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:originLocationId rdf:type rdf:Property ;
    rdfs:label 'Origin Location Id' ;
    rdfs:comment 'Reference to the specific location where the return shipment originates. May link to store, DC, or customer address depending on origin_type.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:deliverySignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Delivery Signature Required' ;
    rdfs:comment 'Indicates whether a signature is required upon delivery. Typically true for high-value RTV shipments to vendors.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Amount' ;
    rdfs:comment 'Declared value for shipment insurance coverage. Used for high-value RTV shipments to protect against loss or damage.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Insurance Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the insurance amount. Enables multi-currency insurance value tracking.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelCostAmount rdf:type rdf:Property ;
    rdfs:label 'Label Cost Amount' ;
    rdfs:comment 'Cost of the prepaid return shipping label. Used for customer return cost analysis and vendor RTV cost allocation.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labelCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Label Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the return label cost. Enables multi-currency label cost tracking.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originType rdf:type rdf:Property ;
    rdfs:label 'Origin Type' ;
    rdfs:comment 'Classification of the shipment origin location. Identifies whether the return is initiated from customer, store, distribution center, or vendor.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryUrl rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Url' ;
    rdfs:comment 'Link to the carrier-provided proof of delivery document. Used for RTV confirmation and dispute resolution.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnLabelNumber rdf:type rdf:Property ;
    rdfs:label 'Return Label Number' ;
    rdfs:comment 'Prepaid return shipping label identifier. Used to match customer-initiated returns to the original order.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtvReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rtv Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for returning merchandise to the vendor. Used for vendor performance tracking and chargeback justification.' ;
    rdfs:domain ind:ReturnShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Classification of the return shipment flow. Identifies the origin and destination pattern for reverse logistics routing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnLocationId rdf:type rdf:Property ;
    rdfs:label 'Return Location Id' ;
    rdfs:comment 'Reference to the store or distribution center where the returned merchandise will be received and processed.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:rmaAssociateId rdf:type rdf:Property ;
    rdfs:label 'Rma Associate Id' ;
    rdfs:comment 'Reference to the employee or system user who authorized the RMA.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:rmaProcessedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Rma Processed By User Associate Id' ;
    rdfs:comment 'Reference to the employee who physically processed and inspected the returned merchandise.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'The date when the return merchandise authorization was approved and issued to the customer.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerComments rdf:type rdf:Property ;
    rdfs:label 'Customer Comments' ;
    rdfs:comment 'Free-text comments provided by the customer explaining the reason for return or providing additional details about the issue.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReturnValueAmount rdf:type rdf:Property ;
    rdfs:label 'Expected Return Value Amount' ;
    rdfs:comment 'The total monetary value of merchandise expected to be returned under this RMA, calculated from the original order line items.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundProcessedDate rdf:type rdf:Property ;
    rdfs:label 'Refund Processed Date' ;
    rdfs:comment 'The date when the refund payment was processed and issued to the customer.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnChannel rdf:type rdf:Property ;
    rdfs:label 'Return Channel' ;
    rdfs:comment 'The channel through which the customer initiated the return request. BOPIS = Buy Online Pick Up In Store, ROPIS = Reserve Online Pick Up In Store.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnShippingCost rdf:type rdf:Property ;
    rdfs:label 'Return Shipping Cost' ;
    rdfs:comment 'Cost of shipping the returned merchandise back to the retailer, which may be borne by customer or retailer depending on return reason and policy.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnType rdf:type rdf:Property ;
    rdfs:label 'Return Type' ;
    rdfs:comment 'The type of resolution requested or authorized for this return: full refund to original payment method, exchange for different item, store credit, or replacement of defective item.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaStatus rdf:type rdf:Property ;
    rdfs:label 'Rma Status' ;
    rdfs:comment 'Current lifecycle status of the RMA. Tracks progression from initial request through final disposition. [ENUM-REF-CANDIDATE: pending|authorized|received|inspected|approved|denied|closed|cancelled|expired — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCreditIssuedAmount rdf:type rdf:Property ;
    rdfs:label 'Store Credit Issued Amount' ;
    rdfs:comment 'The amount of store credit issued to the customer as part of the return resolution.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Original Order Line Id' ;
    rdfs:comment 'Reference to the specific line item on the original sales order. Enables precise traceability from return to original purchase.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:conditionCode rdf:type rdf:Property ;
    rdfs:label 'Condition Code' ;
    rdfs:comment 'Physical condition of the item upon receipt at the returns facility. Determines restocking eligibility and disposition path.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Extended Cost Amount' ;
    rdfs:comment 'Total cost value for this line (quantity × unit cost). Used for inventory and cost of goods sold adjustments.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extendedRetailAmount rdf:type rdf:Property ;
    rdfs:label 'Extended Retail Amount' ;
    rdfs:comment 'Total retail value for this line (quantity × unit retail price). Represents the total refund exposure for this line item.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidationSaleAmount rdf:type rdf:Property ;
    rdfs:label 'Liquidation Sale Amount' ;
    rdfs:comment 'Amount recovered from selling the returned item through liquidation channels (discount outlets, third-party liquidators, online auctions). Used to calculate net return loss.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityAuthorized rdf:type rdf:Property ;
    rdfs:label 'Quantity Authorized' ;
    rdfs:comment 'Number of units authorized for return on this RMA line. Represents the maximum quantity the customer is permitted to return.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'Actual number of units physically received back from the customer for this line item. May differ from quantity authorized.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rtvAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Rtv Authorization Number' ;
    rdfs:comment 'Vendor-issued authorization number permitting the return of defective or excess merchandise back to the supplier. Required for vendor chargeback processing.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Vendor Credit Amount' ;
    rdfs:comment 'Credit amount expected or received from the vendor for this returned item. Used in accounts payable adjustments and vendor chargeback reconciliation.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rtvLineId rdf:type rdf:Property ;
    rdfs:label 'Rtv Line Id' ;
    rdfs:comment 'Unique identifier for the RTV line item. Primary key for this entity.' ;
    rdfs:domain ind:RtvLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rtvRequestId rdf:type rdf:Property ;
    rdfs:label 'Rtv Request Id' ;
    rdfs:comment 'Foreign key reference to the parent RTV header document. Links this line item to the overall RTV transaction.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RtvRequest .

ind:warehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Id' ;
    rdfs:comment 'Foreign key reference to the warehouse or distribution center location where the returned merchandise is staged. Links to the facility master data.' ;
    rdfs:domain ind:RtvLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:chargebackReasonCode rdf:type rdf:Property ;
    rdfs:label 'Chargeback Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for the vendor chargeback. Used for vendor performance tracking and compliance enforcement. [ENUM-REF-CANDIDATE: quality_defect|packaging_violation|labeling_error|late_delivery|quantity_shortage|unauthorized_substitution|compliance_violation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Issued Date' ;
    rdfs:comment 'Date when the vendor issued the credit for this returned merchandise. Marks completion of the financial settlement for this line.' ;
    rdfs:domain ind:RtvLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Vendor-issued credit memo document number for this return. Links the RTV line to the vendor\'s accounts payable credit transaction.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Variance Amount' ;
    rdfs:comment 'Difference between expected and actual vendor credit amounts. Calculated as actual credit total minus expected credit total. Used for vendor credit reconciliation and dispute management.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalPoNumber rdf:type rdf:Property ;
    rdfs:label 'Original Po Number' ;
    rdfs:comment 'Purchase order number under which this item was originally received. Links the return to the original procurement transaction for traceability.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Original Receipt Date' ;
    rdfs:comment 'Date when this merchandise was originally received from the vendor. Used to calculate return window compliance and aging analysis.' ;
    rdfs:domain ind:RtvLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnQuantity rdf:type rdf:Property ;
    rdfs:label 'Return Quantity' ;
    rdfs:comment 'Quantity of units being returned to the vendor. Represents the number of items shipped back in this line.' ;
    rdfs:domain ind:RtvLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Tracking Number' ;
    rdfs:comment 'Carrier tracking number for the shipment containing this returned item. Enables tracking of merchandise in transit back to vendor.' ;
    rdfs:domain ind:RtvLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedDate rdf:type rdf:Property ;
    rdfs:label 'Shipped Date' ;
    rdfs:comment 'Date when this line item was physically shipped back to the vendor. Marks the beginning of the return transit period.' ;
    rdfs:domain ind:RtvLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorCreditActualPerUnit rdf:type rdf:Property ;
    rdfs:label 'Vendor Credit Actual Per Unit' ;
    rdfs:comment 'Actual credit amount per unit that the vendor issued. Represents the confirmed reimbursement value per item received from vendor.' ;
    rdfs:domain ind:RtvLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorCreditActualTotal rdf:type rdf:Property ;
    rdfs:label 'Vendor Credit Actual Total' ;
    rdfs:comment 'Total actual credit amount for this line received from the vendor. Represents the confirmed total vendor reimbursement for this line item.' ;
    rdfs:domain ind:RtvLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorCreditExpectedPerUnit rdf:type rdf:Property ;
    rdfs:label 'Vendor Credit Expected Per Unit' ;
    rdfs:comment 'Expected credit amount per unit that the vendor should issue. Represents the anticipated reimbursement value per item based on return agreement terms.' ;
    rdfs:domain ind:RtvLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorCreditExpectedTotal rdf:type rdf:Property ;
    rdfs:label 'Vendor Credit Expected Total' ;
    rdfs:comment 'Total expected credit amount for this line calculated as return quantity multiplied by expected credit per unit. Represents the total anticipated vendor reimbursement.' ;
    rdfs:domain ind:RtvLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Received Date' ;
    rdfs:comment 'Date when the vendor confirmed receipt of the returned merchandise. Used to calculate transit time and trigger credit processing.' ;
    rdfs:domain ind:RtvLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storeCreditId rdf:type rdf:Property ;
    rdfs:label 'Store Credit Id' ;
    rdfs:comment 'Unique identifier for the store credit instrument. Primary key.' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryStoreAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Store Associate Id' ;
    rdfs:comment 'Reference to the employee who processed the store credit issuance. Supports audit trail and employee performance tracking.' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:breakageEstimateAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Breakage Estimate Applied Flag' ;
    rdfs:comment 'Indicates whether a breakage revenue estimate (expected non-redemption) has been applied to this store credit for financial reporting purposes under ASC 606.' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditCode rdf:type rdf:Property ;
    rdfs:label 'Credit Code' ;
    rdfs:comment 'Externally-visible unique alphanumeric code printed on the store credit instrument or provided digitally. Used for redemption at POS or e-commerce checkout.' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditType rdf:type rdf:Property ;
    rdfs:label 'Credit Type' ;
    rdfs:comment 'Classification of the reason or business context for issuing this store credit. Distinguishes between return-driven credits, promotional incentives, and service recovery gestures.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuedAmount rdf:type rdf:Property ;
    rdfs:label 'Issued Amount' ;
    rdfs:comment 'Original monetary value of the store credit at the time of issuance. Represents the full stored-value balance before any redemptions.' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionChannelRestriction rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel Restriction' ;
    rdfs:comment 'Policy constraint on where the store credit can be redeemed. Supports business rules for channel-specific credits.' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance' ;
    rdfs:comment 'Current unredeemed monetary value available on the store credit. Decreases with each partial redemption until fully redeemed or expired.' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storeCreditStatus rdf:type rdf:Property ;
    rdfs:label 'Store Credit Status' ;
    rdfs:comment 'Current lifecycle state of the store credit. Tracks progression from issuance through redemption, expiration, or voiding. [ENUM-REF-CANDIDATE: issued|active|partially_redeemed|fully_redeemed|expired|voided|suspended — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferableFlag rdf:type rdf:Property ;
    rdfs:label 'Transferable Flag' ;
    rdfs:comment 'Indicates whether the store credit can be transferred or gifted to another customer. False means the credit is locked to the original recipient.' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:voidDate rdf:type rdf:Property ;
    rdfs:label 'Void Date' ;
    rdfs:comment 'Calendar date on which the store credit was voided. Null if the credit has not been voided.' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorCreditId rdf:type rdf:Property ;
    rdfs:label 'Vendor Credit Id' ;
    rdfs:comment 'Unique identifier for the vendor credit memo record. Primary key for the vendor credit entity.' ;
    rdfs:domain ind:VendorCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quaternaryVendorLastModifiedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Vendor Last Modified By User Associate Id' ;
    rdfs:comment 'User ID of the system user who last modified this vendor credit record. Provides audit trail for record changes.' ;
    rdfs:domain ind:VendorCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:tertiaryVendorCreatedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Vendor Created By User Associate Id' ;
    rdfs:comment 'User ID of the system user who created this vendor credit record. Provides audit trail for record creation.' ;
    rdfs:domain ind:VendorCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:apDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Ap Document Number' ;
    rdfs:comment 'Reference to the accounts payable document or transaction where this vendor credit was applied. Links the credit to the financial system posting.' ;
    rdfs:domain ind:VendorCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Chargeback Reference Number' ;
    rdfs:comment 'Reference to any vendor compliance chargeback that this credit is offsetting or related to. Links credits to vendor penalty reversals.' ;
    rdfs:domain ind:VendorCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'The total monetary value of the credit issued by the vendor. Represents the amount to be credited to the retailer\'s accounts payable or applied against future purchases.' ;
    rdfs:domain ind:VendorCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditAppliedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Applied Date' ;
    rdfs:comment 'The date on which the credit was applied to the retailer\'s accounts payable ledger or offset against vendor invoices.' ;
    rdfs:domain ind:VendorCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditDate rdf:type rdf:Property ;
    rdfs:label 'Credit Date' ;
    rdfs:comment 'The date on which the vendor issued the credit memo. This is the official credit issuance date from the vendor\'s perspective.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Credit Expiration Date' ;
    rdfs:comment 'The date by which the vendor credit must be utilized or applied. After this date, the credit may no longer be valid per vendor terms.' ;
    rdfs:domain ind:VendorCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Received Date' ;
    rdfs:comment 'The date on which the retailer received notification or documentation of the vendor credit. May differ from the credit issuance date.' ;
    rdfs:domain ind:VendorCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Description' ;
    rdfs:comment 'Detailed text description of the dispute reason. Provides additional context for credit disputes requiring vendor negotiation or resolution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Expected Credit Amount' ;
    rdfs:comment 'The credit amount that the retailer expected to receive based on the RTV request and vendor agreement. Used for variance analysis when actual credit differs from expected.' ;
    rdfs:domain ind:VendorCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Number' ;
    rdfs:comment 'The vendor invoice number that this credit is being applied against. Provides traceability to the original purchase transaction.' ;
    rdfs:domain ind:VendorCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Email' ;
    rdfs:comment 'Email address of the vendor contact for this credit memo. Used for communication regarding credit status, disputes, or reconciliation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactName rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Name' ;
    rdfs:comment 'Name of the vendor representative who issued or authorized this credit memo. Provides a point of contact for credit inquiries or disputes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Phone' ;
    rdfs:comment 'Phone number of the vendor contact for this credit memo. Provides an alternative communication channel for urgent credit issues.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comparableSalesId rdf:type rdf:Property ;
    rdfs:label 'Comparable Sales Id' ;
    rdfs:comment 'Primary key for comparable_sales' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closureDays rdf:type rdf:Property ;
    rdfs:label 'Closure Days' ;
    rdfs:comment 'Number of days the store was closed during the reporting period. Used to adjust comp sales calculations for partial-period operations.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closureFlag rdf:type rdf:Property ;
    rdfs:label 'Closure Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether the store was temporarily closed for any portion of the reporting period (e.g., due to weather, emergency, renovation). Impacts comp sales qualification and interpretation.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compSalesGrowthRate rdf:type rdf:Property ;
    rdfs:label 'Comp Sales Growth Rate' ;
    rdfs:comment 'The year-over-year growth rate of comparable store sales expressed as a percentage. Synonymous with comp_sales_variance_percent but emphasizes growth perspective. Key performance indicator for executive reporting.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compSalesVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Comp Sales Variance Amount' ;
    rdfs:comment 'The absolute dollar variance between current period net sales and prior period net sales. Calculated as current_period_net_sales minus prior_period_net_sales.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compSalesVariancePercent rdf:type rdf:Property ;
    rdfs:label 'Comp Sales Variance Percent' ;
    rdfs:comment 'The percentage variance between current period net sales and prior period net sales. Calculated as ((current_period_net_sales - prior_period_net_sales) / prior_period_net_sales) * 100. Primary metric for store performance evaluation.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compStoreQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Comp Store Qualification Status' ;
    rdfs:comment 'Indicates whether the store qualifies for inclusion in comparable sales (SSS - Same-Store Sales) reporting for this period. Typically requires the store to have been open for a minimum qualifying period (e.g., 13+ months) and not have undergone significant remodeling or format changes.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentPeriodAtv rdf:type rdf:Property ;
    rdfs:label 'Current Period Atv' ;
    rdfs:comment 'Average Transaction Value (ATV) for the current reporting period. Calculated as current_period_net_sales divided by current_period_transaction_count. Measures the average dollar amount spent per transaction.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentPeriodConversionRate rdf:type rdf:Property ;
    rdfs:label 'Current Period Conversion Rate' ;
    rdfs:comment 'Conversion Rate (CR) for the current reporting period. Calculated as (current_period_transaction_count / current_period_footfall) * 100. Measures the percentage of store visitors who complete a purchase.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentPeriodFootfall rdf:type rdf:Property ;
    rdfs:label 'Current Period Footfall' ;
    rdfs:comment 'Total number of customer visits (store traffic count) during the current reporting period. Measured via traffic counters at store entrances. Used to calculate conversion rate.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentPeriodNetSales rdf:type rdf:Property ;
    rdfs:label 'Current Period Net Sales' ;
    rdfs:comment 'Total net sales revenue for the store during the current reporting period, after returns, discounts, and allowances. Represents the actual sales performance for the period.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentPeriodTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Current Period Transaction Count' ;
    rdfs:comment 'Total number of completed Point of Sale (POS) transactions at the store during the current reporting period. Used to calculate Average Transaction Value (ATV).' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentPeriodUnitsSold rdf:type rdf:Property ;
    rdfs:label 'Current Period Units Sold' ;
    rdfs:comment 'Total number of product units (SKUs) sold at the store during the current reporting period. Used to calculate Units Per Transaction (UPT).' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentPeriodUpt rdf:type rdf:Property ;
    rdfs:label 'Current Period Upt' ;
    rdfs:comment 'Units Per Transaction (UPT) for the current reporting period. Calculated as current_period_units_sold divided by current_period_transaction_count. Measures the average number of items purchased per transaction.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthsInOperation rdf:type rdf:Property ;
    rdfs:label 'Months In Operation' ;
    rdfs:comment 'The number of complete months the store has been in operation as of the end of the current reporting period. Used to determine comp store qualification (typically 13+ months required).' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorPeriodAtv rdf:type rdf:Property ;
    rdfs:label 'Prior Period Atv' ;
    rdfs:comment 'Average Transaction Value (ATV) for the comparable prior period. Used as baseline for ATV performance comparison.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodConversionRate rdf:type rdf:Property ;
    rdfs:label 'Prior Period Conversion Rate' ;
    rdfs:comment 'Conversion Rate (CR) for the comparable prior period. Used as baseline for conversion rate performance comparison.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodFootfall rdf:type rdf:Property ;
    rdfs:label 'Prior Period Footfall' ;
    rdfs:comment 'Total number of customer visits (store traffic count) during the comparable prior period. Used for year-over-year footfall comparison.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorPeriodNetSales rdf:type rdf:Property ;
    rdfs:label 'Prior Period Net Sales' ;
    rdfs:comment 'Total net sales revenue for the store during the comparable prior period (same period in the previous year), after returns, discounts, and allowances. Used as the baseline for comp sales calculation.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Prior Period Transaction Count' ;
    rdfs:comment 'Total number of completed Point of Sale (POS) transactions at the store during the comparable prior period. Used for year-over-year transaction count comparison.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorPeriodUnitsSold rdf:type rdf:Property ;
    rdfs:label 'Prior Period Units Sold' ;
    rdfs:comment 'Total number of product units (SKUs) sold at the store during the comparable prior period. Used for year-over-year unit sales comparison.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorPeriodUpt rdf:type rdf:Property ;
    rdfs:label 'Prior Period Upt' ;
    rdfs:comment 'Units Per Transaction (UPT) for the comparable prior period. Used as baseline for UPT performance comparison.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remodelFlag rdf:type rdf:Property ;
    rdfs:label 'Remodel Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether the store underwent significant remodeling or format change during or immediately prior to the reporting period. Stores with recent remodels may be excluded from comp sales calculations.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingDistrict rdf:type rdf:Property ;
    rdfs:label 'Reporting District' ;
    rdfs:comment 'The district or sub-region to which this store belongs within the reporting region. Used for district-level comp sales aggregation and performance management.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingRegion rdf:type rdf:Property ;
    rdfs:label 'Reporting Region' ;
    rdfs:comment 'The geographic region or market to which this store belongs for reporting purposes (e.g., Northeast, Southwest, EMEA, APAC). Used for regional comp sales aggregation and analysis.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesPerSqft rdf:type rdf:Property ;
    rdfs:label 'Sales Per Sqft' ;
    rdfs:comment 'Current period net sales divided by store size in square feet. Key productivity metric measuring revenue efficiency per unit of retail space.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storeOpenDate rdf:type rdf:Property ;
    rdfs:label 'Store Open Date' ;
    rdfs:comment 'The date the store first opened for business. Used to determine eligibility for comparable sales reporting based on minimum operating period requirements.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storeSizeSqft rdf:type rdf:Property ;
    rdfs:label 'Store Size Sqft' ;
    rdfs:comment 'The total retail floor space of the store in square feet. Used for sales per square foot analysis and store productivity metrics.' ;
    rdfs:domain ind:ComparableSales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dsdReceivingId rdf:type rdf:Property ;
    rdfs:label 'Dsd Receiving Id' ;
    rdfs:comment 'Unique identifier for the DSD receiving transaction. Primary key for the DSD receiving record.' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionInboundShipmentId rdf:type rdf:Property ;
    rdfs:label 'Distribution Inbound Shipment Id' ;
    rdfs:comment 'Foreign key linking to supplychain.inbound_shipment. Business justification: DSD store deliveries are often part of larger multi-stop vendor shipment manifests managed by supply chain. Links store-level receipt to shipment-level tracking for freight reconciliation, multi-locat' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundShipment .

ind:receivingInventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Receiving Inventory Node Id' ;
    rdfs:comment 'Foreign key linking to inventory.inventory_node. Business justification: DSD receiving at stores must link to inventory_node for stock positioning, ATP calculation, and replenishment planning. Store location alone doesn\'t provide network-level inventory visibility required' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:chargebackReason rdf:type rdf:Property ;
    rdfs:label 'Chargeback Reason' ;
    rdfs:comment 'Description of the reason for the chargeback assessment. Common reasons include short shipment, damaged goods, temperature violations, or late delivery.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costVariance rdf:type rdf:Property ;
    rdfs:label 'Cost Variance' ;
    rdfs:comment 'Difference between invoiced cost and received cost (invoiced minus received). Positive values indicate over-billing; negative values indicate pricing discrepancies.' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryManifestNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Manifest Number' ;
    rdfs:comment 'Supplier-provided manifest or delivery ticket number that accompanies the DSD shipment. Used for reconciliation and chargeback processing.' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End' ;
    rdfs:comment 'Scheduled end time of the delivery window for this DSD shipment. Used to track on-time delivery performance and assess late delivery chargebacks.' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryWindowStart rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start' ;
    rdfs:comment 'Scheduled start time of the delivery window for this DSD shipment. Used to track on-time delivery performance.' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:driverName rdf:type rdf:Property ;
    rdfs:label 'Driver Name' ;
    rdfs:comment 'Name of the supplier driver who delivered the DSD shipment. Used for security and accountability purposes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverSignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Driver Signature Captured' ;
    rdfs:comment 'Indicates whether the driver signature was captured electronically at the time of delivery. Required for proof of delivery documentation.' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Match Status' ;
    rdfs:comment 'Status indicating whether the supplier invoice matches the received quantities and costs. Critical for three-way match (PO, receipt, invoice) and accounts payable processing.' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Flag' ;
    rdfs:comment 'Indicates whether the DSD delivery arrived within the scheduled delivery window. Used for supplier performance scorecarding.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:putawayCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Putaway Completed Flag' ;
    rdfs:comment 'Indicates whether the received DSD merchandise has been put away to its final storage or sales floor location. Used for inventory accuracy and workflow tracking.' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:putawayTimestamp rdf:type rdf:Property ;
    rdfs:label 'Putaway Timestamp' ;
    rdfs:comment 'Date and time when the DSD merchandise was put away to its final location. Used to measure receiving cycle time and labor productivity.' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'Difference between quantity invoiced and quantity received (invoiced minus received). Positive values indicate over-billing; negative values indicate under-delivery.' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingLocation rdf:type rdf:Property ;
    rdfs:label 'Receiving Location' ;
    rdfs:comment 'Physical location within the store where the DSD delivery was received and initially staged. Used for inventory tracking and workflow optimization.' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionNotes rdf:type rdf:Property ;
    rdfs:label 'Rejection Notes' ;
    rdfs:comment 'Free-text notes providing additional detail about the rejection or quality issue. Supports chargeback documentation and supplier dispute resolution.' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanBasedTradingFlag rdf:type rdf:Property ;
    rdfs:label 'Scan Based Trading Flag' ;
    rdfs:comment 'Indicates whether this DSD delivery is part of a scan-based trading arrangement where the supplier retains ownership until the product is sold at POS.' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Temperature Check Required' ;
    rdfs:comment 'Indicates whether temperature verification was required for this DSD delivery due to perishable goods (dairy, refrigerated, frozen items).' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureCheckResult rdf:type rdf:Property ;
    rdfs:label 'Temperature Check Result' ;
    rdfs:comment 'Result of the temperature verification check for perishable DSD deliveries. Failed checks may trigger rejection per FDA FSMA requirements.' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureReading rdf:type rdf:Property ;
    rdfs:label 'Temperature Reading' ;
    rdfs:comment 'Actual temperature reading in Fahrenheit recorded during the DSD receiving inspection for perishable goods. Required for FDA FSMA compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCostInvoiced rdf:type rdf:Property ;
    rdfs:label 'Total Cost Invoiced' ;
    rdfs:comment 'Total cost as stated on the supplier invoice. Used for three-way match validation and variance analysis.' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCostReceived rdf:type rdf:Property ;
    rdfs:label 'Total Cost Received' ;
    rdfs:comment 'Total cost of goods received based on purchase order or contract pricing. Represents the expected accounts payable liability.' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalQuantityInvoiced rdf:type rdf:Property ;
    rdfs:label 'Total Quantity Invoiced' ;
    rdfs:comment 'Total quantity of units invoiced by the supplier across all SKUs in this DSD delivery. Used for variance detection and chargeback calculation.' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalQuantityReceived rdf:type rdf:Property ;
    rdfs:label 'Total Quantity Received' ;
    rdfs:comment 'Total quantity of units received across all SKUs in this DSD delivery. Aggregated from line-level detail.' ;
    rdfs:domain ind:DsdReceiving ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixtureId rdf:type rdf:Property ;
    rdfs:label 'Fixture Id' ;
    rdfs:comment 'Unique identifier for the store fixture. Primary key.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ada Compliant Flag' ;
    rdfs:comment 'Indicates whether the fixture meets ADA accessibility requirements for height, reach range, and clearance. True indicates compliant, false indicates non-compliant or exempted.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustableShelvesFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustable Shelves Flag' ;
    rdfs:comment 'Indicates whether the fixture has adjustable shelf heights. True enables flexible merchandising for varying product sizes, false indicates fixed shelf positions.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bayPosition rdf:type rdf:Property ;
    rdfs:label 'Bay Position' ;
    rdfs:comment 'Specific bay or section position within the aisle (e.g., Bay 1, Bay 2). Provides granular location tracking for planogram compliance and inventory audits.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depthInches rdf:type rdf:Property ;
    rdfs:label 'Depth Inches' ;
    rdfs:comment 'Depth of the fixture measured in inches. Important for aisle width planning, product capacity calculation, and customer navigation.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalDisplayFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Display Flag' ;
    rdfs:comment 'Indicates whether the fixture includes digital signage or electronic shelf labels (ESL) for dynamic pricing and promotions. True indicates digital capability, false indicates traditional static signage.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finishColor rdf:type rdf:Property ;
    rdfs:label 'Finish Color' ;
    rdfs:comment 'Color or finish of the fixture exterior (e.g., white, black, chrome, wood grain). Used for visual merchandising consistency and brand alignment across store fleet.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixtureCategory rdf:type rdf:Property ;
    rdfs:label 'Fixture Category' ;
    rdfs:comment 'Categorization of the fixture based on its intended duration and purpose. Permanent fixtures are long-term store infrastructure, seasonal fixtures support recurring seasonal merchandising, promotional fixtures are used for short-term campaigns, and temporary fixtures are ad-hoc displays.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixtureCode rdf:type rdf:Property ;
    rdfs:label 'Fixture Code' ;
    rdfs:comment 'Business identifier code for the fixture, used for asset tracking and inventory management. Typically alphanumeric code assigned by merchandising or facilities team.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixtureStatus rdf:type rdf:Property ;
    rdfs:label 'Fixture Status' ;
    rdfs:comment 'Current lifecycle status of the fixture. Active indicates in-use and operational, inactive indicates temporarily not in use, maintenance indicates undergoing repair or refurbishment, retired indicates permanently removed from service, damaged indicates requiring repair, and pending installation indicates purchased but not yet deployed.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightInches rdf:type rdf:Property ;
    rdfs:label 'Height Inches' ;
    rdfs:comment 'Height of the fixture measured in inches. Critical for vertical space utilization, sight line planning, and compliance with accessibility standards.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date the fixture was installed in its current store location. Used for age tracking, depreciation calculation, and maintenance scheduling.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRefurbishmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Refurbishment Date' ;
    rdfs:comment 'Date of the most recent refurbishment, repair, or significant maintenance performed on the fixture. Null if never refurbished since installation.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lightingIntegratedFlag rdf:type rdf:Property ;
    rdfs:label 'Lighting Integrated Flag' ;
    rdfs:comment 'Indicates whether the fixture has built-in lighting to highlight merchandise. True indicates integrated lighting system, false indicates no built-in lighting.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialComposition rdf:type rdf:Property ;
    rdfs:label 'Material Composition' ;
    rdfs:comment 'Primary materials used in fixture construction (e.g., steel, wood, laminate, glass, acrylic). Impacts durability, maintenance requirements, and aesthetic alignment with store design.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilityType rdf:type rdf:Property ;
    rdfs:label 'Mobility Type' ;
    rdfs:comment 'Indicates whether the fixture is permanently installed (fixed), easily movable (mobile with casters), or requires tools to relocate (semi-mobile). Impacts flexibility for store resets and seasonal merchandising changes.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:comment 'Planned date for the next preventive maintenance or inspection. Used for maintenance scheduling and compliance with safety standards.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:powerRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Power Required Flag' ;
    rdfs:comment 'Indicates whether the fixture requires electrical power for operation (e.g., refrigeration, lighting, digital displays). True requires power connection, false indicates passive fixture.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refrigerationType rdf:type rdf:Property ;
    rdfs:label 'Refrigeration Type' ;
    rdfs:comment 'Temperature control classification for the fixture. Ambient indicates no refrigeration, chilled indicates 32-40°F range for dairy and produce, frozen indicates below 0°F for frozen foods, multi-temp indicates multiple temperature zones, and none indicates non-refrigerated fixtures.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Enabled Flag' ;
    rdfs:comment 'Indicates whether the fixture is equipped with RFID readers for automated inventory tracking and shrinkage prevention. True indicates RFID capability, false indicates no RFID integration.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityFeatures rdf:type rdf:Property ;
    rdfs:label 'Security Features' ;
    rdfs:comment 'Description of anti-theft or security features integrated into the fixture (e.g., locking doors, security hooks, EAS tag compatibility, camera integration). Used for shrinkage prevention and loss prevention planning.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightCapacityLbs rdf:type rdf:Property ;
    rdfs:label 'Weight Capacity Lbs' ;
    rdfs:comment 'Maximum weight load the fixture can safely support, measured in pounds. Critical for safety compliance and preventing structural failure when merchandising heavy products.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:widthInches rdf:type rdf:Property ;
    rdfs:label 'Width Inches' ;
    rdfs:comment 'Width of the fixture measured in inches. Used for space planning, planogram design, and store layout optimization.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:barcodeScannerType rdf:type rdf:Property ;
    rdfs:label 'Barcode Scanner Type' ;
    rdfs:comment 'Type of barcode scanner peripheral attached to the POS terminal. Determines scanning workflow and throughput capabilities.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashDrawerEnabled rdf:type rdf:Property ;
    rdfs:label 'Cash Drawer Enabled' ;
    rdfs:comment 'Indicates whether the terminal is connected to a cash drawer for handling cash transactions. False for self-checkout kiosks and mobile POS devices that do not accept cash.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactlessEnabled rdf:type rdf:Property ;
    rdfs:label 'Contactless Enabled' ;
    rdfs:comment 'Indicates whether the terminal supports Near Field Communication (NFC) contactless payments (tap-to-pay, mobile wallets like Apple Pay, Google Pay).' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerDisplayType rdf:type rdf:Property ;
    rdfs:label 'Customer Display Type' ;
    rdfs:comment 'Type of customer-facing display device attached to the terminal. Shows transaction details, pricing, and promotional messages to the customer during checkout.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebtSnapEnabled rdf:type rdf:Property ;
    rdfs:label 'Ebt Snap Enabled' ;
    rdfs:comment 'Indicates whether the terminal is certified to accept Electronic Benefits Transfer (EBT) and Supplemental Nutrition Assistance Program (SNAP) payments. Required for grocery retailers serving SNAP recipients.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emvChipEnabled rdf:type rdf:Property ;
    rdfs:label 'Emv Chip Enabled' ;
    rdfs:comment 'Indicates whether the terminal supports EMV chip card transactions (contact chip reading). Required for PCI DSS compliance and fraud reduction.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encryptionEnabled rdf:type rdf:Property ;
    rdfs:label 'Encryption Enabled' ;
    rdfs:comment 'Indicates whether the terminal encrypts payment card data at the point of interaction (P2PE - Point-to-Point Encryption). Required for PCI DSS compliance and fraud prevention.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hardwareModel rdf:type rdf:Property ;
    rdfs:label 'Hardware Model' ;
    rdfs:comment 'Manufacturer model number or identifier for the POS terminal hardware (e.g., \'NCR RealPOS 82XRT\', \'Toshiba TCx Sky\', \'Zebra TC52\'). Critical for maintenance planning and compatibility management.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardwareSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Hardware Serial Number' ;
    rdfs:comment 'Manufacturer-assigned unique serial number for the physical POS terminal device. Used for warranty tracking, asset management, and theft prevention.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneNumber rdf:type rdf:Property ;
    rdfs:label 'Lane Number' ;
    rdfs:comment 'Physical lane or checkout position number within the store layout. Used for customer wayfinding and operational reporting. Null for mobile POS devices.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent preventive maintenance or repair service performed on the terminal. Used for maintenance schedule compliance tracking.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTransactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Timestamp' ;
    rdfs:comment 'Timestamp of the most recent transaction processed by this terminal. Used for terminal utilization analysis and anomaly detection (e.g., identifying inactive terminals).' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:macAddress rdf:type rdf:Property ;
    rdfs:label 'Mac Address' ;
    rdfs:comment 'Media Access Control (MAC) address of the POS terminal network interface. Unique hardware identifier used for network access control and device authentication.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileWalletEnabled rdf:type rdf:Property ;
    rdfs:label 'Mobile Wallet Enabled' ;
    rdfs:comment 'Indicates whether the terminal supports mobile wallet payment methods (Apple Pay, Google Pay, Samsung Pay, etc.). Typically requires NFC hardware.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkZone rdf:type rdf:Property ;
    rdfs:label 'Network Zone' ;
    rdfs:comment 'Network security zone or segment where the POS terminal is deployed. Cardholder Data Environment (CDE) terminals are subject to stricter PCI DSS controls.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date when the next preventive maintenance service is scheduled for the terminal. Used for proactive maintenance planning and resource allocation.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pciDssCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Certification Date' ;
    rdfs:comment 'Date when the terminal last passed Payment Card Industry Data Security Standard (PCI DSS) compliance certification. Must be renewed annually to maintain payment acceptance capabilities.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pciDssCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Certification Expiry Date' ;
    rdfs:comment 'Date when the current PCI DSS certification expires. Terminals must be recertified before this date to continue processing payment card transactions.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pinDebitEnabled rdf:type rdf:Property ;
    rdfs:label 'Pin Debit Enabled' ;
    rdfs:comment 'Indicates whether the terminal supports PIN-based debit card transactions. Requires secure PIN pad hardware.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qrCodePaymentEnabled rdf:type rdf:Property ;
    rdfs:label 'Qr Code Payment Enabled' ;
    rdfs:comment 'Indicates whether the terminal supports QR code-based payment methods (e.g., Alipay, WeChat Pay, retailer-specific QR payment apps).' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptPrinterModel rdf:type rdf:Property ;
    rdfs:label 'Receipt Printer Model' ;
    rdfs:comment 'Model identifier for the receipt printer peripheral attached to the POS terminal. Used for consumables ordering and maintenance scheduling.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteManagementEnabled rdf:type rdf:Property ;
    rdfs:label 'Remote Management Enabled' ;
    rdfs:comment 'Indicates whether the terminal can be remotely monitored, configured, and updated from a central management system. Enables efficient fleet management and rapid issue resolution.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scaleIntegrated rdf:type rdf:Property ;
    rdfs:label 'Scale Integrated' ;
    rdfs:comment 'Indicates whether the terminal has an integrated scale for weighing produce, bulk items, or other variable-weight merchandise. Common in grocery checkout lanes.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureCaptureEnabled rdf:type rdf:Property ;
    rdfs:label 'Signature Capture Enabled' ;
    rdfs:comment 'Indicates whether the terminal supports electronic signature capture for credit card transactions and delivery confirmations.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:softwareVersion rdf:type rdf:Property ;
    rdfs:label 'Software Version' ;
    rdfs:comment 'Version number of the POS application software currently installed on the terminal. Critical for security patch management and feature compatibility.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalName rdf:type rdf:Property ;
    rdfs:label 'Terminal Name' ;
    rdfs:comment 'Human-readable name or label for the POS terminal, often indicating its location or purpose within the store (e.g., \'Lane 5\', \'Customer Service Desk\', \'Pharmacy Register\').' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalNumber rdf:type rdf:Property ;
    rdfs:label 'Terminal Number' ;
    rdfs:comment 'Business identifier for the POS terminal, typically displayed on the terminal and used in operational communications. Unique within a store location.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalStatus rdf:type rdf:Property ;
    rdfs:label 'Terminal Status' ;
    rdfs:comment 'Current operational status of the POS terminal. Determines whether the terminal is available for transaction processing. Active terminals are in production use; offline terminals are temporarily unavailable; maintenance terminals are undergoing service; decommissioned terminals are permanently retired.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalType rdf:type rdf:Property ;
    rdfs:label 'Terminal Type' ;
    rdfs:comment 'Classification of the POS terminal based on its operational function and staffing model. Determines transaction workflows and customer interaction patterns.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Tokenization Enabled' ;
    rdfs:comment 'Indicates whether the terminal supports payment tokenization, replacing sensitive card data with non-sensitive tokens for storage and transmission. Reduces PCI DSS scope.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sfsFulfillmentNodeId rdf:type rdf:Property ;
    rdfs:label 'Sfs Fulfillment Node Id' ;
    rdfs:comment 'Unique identifier for the ship-from-store fulfillment node. Primary key for this entity.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averagePackTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Pack Time Minutes' ;
    rdfs:comment 'Average time in minutes required to pack a standard order at this fulfillment node. Used for capacity planning and throughput estimation.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averagePickTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Pick Time Minutes' ;
    rdfs:comment 'Average time in minutes required to pick a standard order at this fulfillment node. Used for capacity planning and Service Level Agreement (SLA) estimation.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Account Number' ;
    rdfs:comment 'Account number or identifier used for billing and tracking with the primary carrier. Business-confidential information used for shipment processing.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerOrder rdf:type rdf:Property ;
    rdfs:label 'Cost Per Order' ;
    rdfs:comment 'Average operational cost in local currency to fulfill one order from this node, including labor, packaging, and overhead. Used for profitability analysis and routing optimization.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyCapacityOrders rdf:type rdf:Property ;
    rdfs:label 'Daily Capacity Orders' ;
    rdfs:comment 'Maximum number of orders this fulfillment node can process per day, based on staffing, space, and operational constraints. Used by OMS for capacity-based order routing.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dailyCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Daily Capacity Units' ;
    rdfs:comment 'Maximum number of individual units (SKUs) this fulfillment node can pick, pack, and ship per day. Complements order capacity for more granular planning.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventorySyncFrequencyMinutes rdf:type rdf:Property ;
    rdfs:label 'Inventory Sync Frequency Minutes' ;
    rdfs:comment 'Frequency in minutes at which inventory positions at this fulfillment node are synchronized with the central inventory system. Lower values enable more accurate real-time inventory visibility.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextDayCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Next Day Cutoff Time' ;
    rdfs:comment 'Local time cutoff (HH:MM format) by which orders must be placed to qualify for next-day delivery from this node. Null if next-day delivery is not supported.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:omsIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Oms Integration Enabled' ;
    rdfs:comment 'Indicates whether this fulfillment node is integrated with the Order Management System (OMS) for automated order routing and status updates. True if OMS integration is active; false otherwise.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours for fulfillment operations at this node, typically in format \'Mon-Fri: 08:00-20:00, Sat-Sun: 09:00-18:00\'. Used for capacity planning and order routing.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickingZoneCount rdf:type rdf:Property ;
    rdfs:label 'Picking Zone Count' ;
    rdfs:comment 'Number of active picking zones configured within this fulfillment node. Zones organize inventory by category or location to optimize picking efficiency.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickingZoneIdentifiers rdf:type rdf:Property ;
    rdfs:label 'Picking Zone Identifiers' ;
    rdfs:comment 'Comma-separated list of picking zone codes or identifiers active in this fulfillment node (e.g., \'ZONE-A,ZONE-B,ZONE-C\'). Used for WMS integration and picker assignment.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sameDayCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Same Day Cutoff Time' ;
    rdfs:comment 'Local time cutoff (HH:MM format) by which orders must be placed to qualify for same-day delivery from this node. Null if same-day delivery is not supported.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:secondaryCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Secondary Carrier Code' ;
    rdfs:comment 'Code identifying the secondary or backup carrier assigned to this fulfillment node. Used when primary carrier is unavailable or for specific delivery types.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePostalCodes rdf:type rdf:Property ;
    rdfs:label 'Service Postal Codes' ;
    rdfs:comment 'Comma-separated list of postal codes or postal code prefixes this fulfillment node serves. Used for zone-based order routing when radius-based routing is insufficient.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRadiusKm rdf:type rdf:Property ;
    rdfs:label 'Service Radius Km' ;
    rdfs:comment 'Geographic service radius in kilometers from this fulfillment node. Orders within this radius are eligible for fulfillment from this node. Used by OMS for proximity-based routing.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportsBopis rdf:type rdf:Property ;
    rdfs:label 'Supports Bopis' ;
    rdfs:comment 'Indicates whether this fulfillment node supports Buy Online Pick Up In Store (BOPIS) service. True if BOPIS is available; false otherwise.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsCurbsidePickup rdf:type rdf:Property ;
    rdfs:label 'Supports Curbside Pickup' ;
    rdfs:comment 'Indicates whether this fulfillment node offers curbside pickup service where customers can collect orders without entering the store. True if curbside pickup is available; false otherwise.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsNextDayDelivery rdf:type rdf:Property ;
    rdfs:label 'Supports Next Day Delivery' ;
    rdfs:comment 'Indicates whether this fulfillment node offers next-day delivery service. True if next-day delivery is available; false otherwise.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsSameDayDelivery rdf:type rdf:Property ;
    rdfs:label 'Supports Same Day Delivery' ;
    rdfs:comment 'Indicates whether this fulfillment node offers same-day delivery service. True if same-day delivery is available; false otherwise.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier for this fulfillment node (e.g., \'America/New_York\', \'Europe/London\'). Used to interpret cutoff times and operating hours in local time.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Wms Integration Enabled' ;
    rdfs:comment 'Indicates whether this fulfillment node is integrated with the Warehouse Management System (WMS) for automated pick/pack/ship workflows. True if WMS integration is active; false if manual processes are used.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shrinkageEventId rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Event Id' ;
    rdfs:comment 'Unique identifier for the shrinkage event record. Primary key.' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryShrinkageAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Shrinkage Associate Id' ;
    rdfs:comment 'Identifier of the employee involved in or responsible for the shrinkage event (for internal theft or administrative error cases). Confidential and used only for internal investigations.' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:costValueLost rdf:type rdf:Property ;
    rdfs:label 'Cost Value Lost' ;
    rdfs:comment 'The total cost value (COGS - Cost of Goods Sold) of inventory lost in this shrinkage event. Used for financial accounting and inventory valuation adjustments.' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentReportFiled rdf:type rdf:Property ;
    rdfs:label 'Incident Report Filed' ;
    rdfs:comment 'Indicates whether a formal incident report was filed with Loss Prevention or law enforcement for this shrinkage event.' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policeReportNumber rdf:type rdf:Property ;
    rdfs:label 'Police Report Number' ;
    rdfs:comment 'Law enforcement report number if the shrinkage event involved external theft and was reported to police.' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityLost rdf:type rdf:Property ;
    rdfs:label 'Quantity Lost' ;
    rdfs:comment 'The quantity of units lost in the shrinkage event. May include fractional units for weight-based or bulk items.' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Amount' ;
    rdfs:comment 'The monetary value recovered from the shrinkage event through restitution, insurance claims, vendor credits, or merchandise recovery. Null or zero if no recovery occurred.' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryMethod rdf:type rdf:Property ;
    rdfs:label 'Recovery Method' ;
    rdfs:comment 'The method by which value was recovered: merchandise physically recovered, restitution from perpetrator, insurance claim payout, vendor credit (RTV - Return to Vendor), chargeback to vendor, or none.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The date on which the shrinkage event case was resolved or closed. Null if still open or under investigation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current status of the shrinkage event case: open (newly identified), under investigation, resolved (cause identified and addressed), closed unresolved, or recovered (merchandise or value recovered).' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyType rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Type' ;
    rdfs:comment 'Classification of the party responsible for the shrinkage: external (customer/shoplifter), employee (internal theft), vendor (fraud/error), unknown, or not applicable (e.g., damage, administrative error).' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shrinkageType rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Type' ;
    rdfs:comment 'Classification of the root cause of the shrinkage event: external theft (shoplifting), internal theft (employee), administrative error (paperwork/system), vendor fraud, damage (spoilage/breakage), or unknown.' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRetailValueLost rdf:type rdf:Property ;
    rdfs:label 'Total Retail Value Lost' ;
    rdfs:comment 'The total estimated retail value of inventory lost in this shrinkage event (quantity_lost × unit_retail_value). Directly impacts store P&L (Profit and Loss).' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitRetailValue rdf:type rdf:Property ;
    rdfs:label 'Unit Retail Value' ;
    rdfs:comment 'The retail price per unit of the product at the time of the shrinkage event. Used to calculate total estimated loss.' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneLocation rdf:type rdf:Property ;
    rdfs:label 'Zone Location' ;
    rdfs:comment 'Specific zone, aisle, or area within the store where the shrinkage event was detected (e.g., Aisle 12, Backroom, Checkout Lane 5).' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Unique identifier for the store audit record. Primary key.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousAuditId rdf:type rdf:Property ;
    rdfs:label 'Previous Audit Id' ;
    rdfs:comment 'Identifier of the previous audit of the same type conducted at this store, enabling trend analysis. Null for first audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Full name of the auditor or system that performed the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorType rdf:type rdf:Property ;
    rdfs:label 'Auditor Type' ;
    rdfs:comment 'Classification of the entity that performed the audit: internal LP (Loss Prevention) team, third-party auditor, regulatory inspector (FDA/OSHA/fire marshal), automated image recognition system, district manager, or corporate compliance team.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citationIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Citation Issued Flag' ;
    rdfs:comment 'Boolean flag indicating whether a formal citation, violation notice, or warning letter was issued by a regulatory agency.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:districtManagerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'District Manager Notified Flag' ;
    rdfs:comment 'Boolean flag indicating whether the district manager was formally notified of the audit results.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Timestamp when the audit fieldwork was completed at the store.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fineAmount rdf:type rdf:Property ;
    rdfs:label 'Fine Amount' ;
    rdfs:comment 'Monetary fine or penalty amount assessed by regulatory agency in USD. Null if no fine was issued.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followUpAuditDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Date' ;
    rdfs:comment 'Scheduled date for the follow-up audit to verify corrective actions. Null if no follow-up is required.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether a follow-up audit is required to verify corrective action completion.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallScorePercent rdf:type rdf:Property ;
    rdfs:label 'Overall Score Percent' ;
    rdfs:comment 'Overall audit score expressed as a percentage (0.00 to 100.00), representing the store\'s compliance level across all audited items.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:photographicEvidenceCount rdf:type rdf:Property ;
    rdfs:label 'Photographic Evidence Count' ;
    rdfs:comment 'Number of photographs or images captured during the audit to document findings and conditions.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousAuditScorePercent rdf:type rdf:Property ;
    rdfs:label 'Previous Audit Score Percent' ;
    rdfs:comment 'Overall score from the previous audit of the same type, enabling period-over-period comparison. Null for first audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency' ;
    rdfs:comment 'Name of the regulatory agency that conducted the inspection (e.g., \'FDA\', \'OSHA\', \'Local Fire Marshal\', \'Health Department\'). Null for internal audits.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoreVariancePercent rdf:type rdf:Property ;
    rdfs:label 'Score Variance Percent' ;
    rdfs:comment 'Percentage point change in audit score compared to previous audit (current score minus previous score). Null for first audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Timestamp when the audit fieldwork began at the store.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:storeManagerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Store Manager Notified Flag' ;
    rdfs:comment 'Boolean flag indicating whether the store manager was formally notified of the audit results.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:summary rdf:type rdf:Property ;
    rdfs:label 'Summary' ;
    rdfs:comment 'Executive summary of the audit findings, key observations, and overall assessment.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalItemsAudited rdf:type rdf:Property ;
    rdfs:label 'Total Items Audited' ;
    rdfs:comment 'Total number of positions, items, or checkpoints evaluated during the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentClusterId rdf:type rdf:Property ;
    rdfs:label 'Parent Cluster Id' ;
    rdfs:comment 'Reference to a parent cluster if this cluster is part of a hierarchical clustering structure (e.g., sub-clusters within a regional cluster). Null for top-level clusters.' ;
    rdfs:domain ind:Cluster ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cluster .

ind:allowsOverlap rdf:type rdf:Property ;
    rdfs:label 'Allows Overlap' ;
    rdfs:comment 'Indicates whether a store can belong to multiple clusters of this type simultaneously. True for concurrent clustering schemes (e.g., a store can be in both an assortment cluster and a pricing zone cluster); false for mutually exclusive schemes.' ;
    rdfs:domain ind:Cluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assortmentDepthStrategy rdf:type rdf:Property ;
    rdfs:label 'Assortment Depth Strategy' ;
    rdfs:comment 'Planned depth of product assortment for this cluster. Deep assortment offers extensive variety within categories; moderate offers balanced selection; shallow offers limited SKU count; curated offers highly selective premium assortment. Drives OTB planning and space allocation.' ;
    rdfs:domain ind:Cluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageAnnualSalesUsd rdf:type rdf:Property ;
    rdfs:label 'Average Annual Sales Usd' ;
    rdfs:comment 'Average annual sales volume in USD for stores in this cluster. Used for performance tier clustering and benchmarking. Business-confidential financial metric.' ;
    rdfs:domain ind:Cluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageStoreSizeSqft rdf:type rdf:Property ;
    rdfs:label 'Average Store Size Sqft' ;
    rdfs:comment 'Average selling floor area in square feet of stores in this cluster. Used for format-based clustering and space productivity benchmarking.' ;
    rdfs:domain ind:Cluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:climateZone rdf:type rdf:Property ;
    rdfs:label 'Climate Zone' ;
    rdfs:comment 'Predominant climate classification for stores in this cluster. Used for climate-based clustering to drive seasonal assortment and inventory planning (e.g., winter apparel depth, cooling appliances).' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterCode rdf:type rdf:Property ;
    rdfs:label 'Cluster Code' ;
    rdfs:comment 'Business-friendly alphanumeric code for the store cluster, used in reporting and operational systems. Typically follows a pattern like REGION-TYPE-SEQ (e.g., NE-ASSORT-01, SW-PRICE-03).' ;
    rdfs:domain ind:Cluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterDescription rdf:type rdf:Property ;
    rdfs:label 'Cluster Description' ;
    rdfs:comment 'Detailed business description of the cluster purpose, characteristics, and intended use. Explains the rationale for grouping these stores together.' ;
    rdfs:domain ind:Cluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterLevel rdf:type rdf:Property ;
    rdfs:label 'Cluster Level' ;
    rdfs:comment 'Depth level in the cluster hierarchy. Level 1 is top-level (e.g., national or regional); higher numbers indicate more granular sub-clusters. Supports hierarchical rollup and drill-down analysis.' ;
    rdfs:domain ind:Cluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clusterName rdf:type rdf:Property ;
    rdfs:label 'Cluster Name' ;
    rdfs:comment 'Human-readable name of the store cluster, used for display and business communication (e.g., Northeast Urban High-Income, Southwest Discount Tier 1).' ;
    rdfs:domain ind:Cluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterStatus rdf:type rdf:Property ;
    rdfs:label 'Cluster Status' ;
    rdfs:comment 'Current lifecycle status of the cluster. Active clusters are in operational use; inactive clusters are temporarily disabled; pending clusters are awaiting approval; archived clusters are historical; under_review clusters are being evaluated for changes.' ;
    rdfs:domain ind:Cluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterType rdf:type rdf:Property ;
    rdfs:label 'Cluster Type' ;
    rdfs:comment 'Classification of the clustering scheme. Assortment clusters drive localized product mix; pricing zone clusters enable zone-based pricing strategies; demographic clusters group by customer profile; performance tier clusters segment by sales volume or profitability; climate clusters address seasonal/weather-driven needs; geographic clusters group by region; format clusters group by store format (hypermarket, discount, dark store); omnichannel clusters optimize fulfillment network. [ENUM-REF-CANDIDATE: assortment|pricing_zone|demographic|performance_tier|climate|geographic|format|omnichannel — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Cluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusteringCriteria rdf:type rdf:Property ;
    rdfs:label 'Clustering Criteria' ;
    rdfs:comment 'Business rules or data attributes used to assign stores to this cluster (e.g., sales volume > $10M, urban location, customer income > $75K, climate zone = temperate). Supports transparency and auditability of cluster logic.' ;
    rdfs:domain ind:Cluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalClusterCode rdf:type rdf:Property ;
    rdfs:label 'External Cluster Code' ;
    rdfs:comment 'Cluster identifier from the source system of record. Used for cross-system reconciliation and data lineage tracking.' ;
    rdfs:domain ind:Cluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberStoreCount rdf:type rdf:Property ;
    rdfs:label 'Member Store Count' ;
    rdfs:comment 'Total number of store locations currently assigned to this cluster. Updated as stores join or leave the cluster.' ;
    rdfs:domain ind:Cluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBusinessPurpose rdf:type rdf:Property ;
    rdfs:label 'Primary Business Purpose' ;
    rdfs:comment 'Primary operational use case for this cluster (e.g., localized assortment planning, zone pricing strategy, promotional targeting, operational benchmarking, fulfillment network optimization).' ;
    rdfs:domain ind:Cluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalIntensity rdf:type rdf:Property ;
    rdfs:label 'Promotional Intensity' ;
    rdfs:comment 'Frequency and depth of promotional activity targeted at this cluster. High intensity clusters receive frequent deep discounts; low intensity clusters have minimal promotions; none indicates EDLP strategy with no promotions.' ;
    rdfs:domain ind:Cluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeFormatMix rdf:type rdf:Property ;
    rdfs:label 'Store Format Mix' ;
    rdfs:comment 'Comma-separated list of store formats included in this cluster (e.g., hypermarket, discount, dark_store, MFC). Used for format-based clustering and omnichannel fulfillment optimization.' ;
    rdfs:domain ind:Cluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsOmnichannel rdf:type rdf:Property ;
    rdfs:label 'Supports Omnichannel' ;
    rdfs:comment 'Indicates whether stores in this cluster are enabled for omnichannel fulfillment capabilities (BOPIS, ROPIS, ship-from-store, curbside pickup). True if cluster is designed for omnichannel operations.' ;
    rdfs:domain ind:Cluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:urbanizationLevel rdf:type rdf:Property ;
    rdfs:label 'Urbanization Level' ;
    rdfs:comment 'Population density classification for stores in this cluster. Urban stores serve high-density city centers; suburban stores serve residential areas; rural stores serve low-density regions; exurban stores serve outer suburban fringe areas.' ;
    rdfs:domain ind:Cluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentStatus rdf:type rdf:Property ;
    rdfs:label 'Department Status' ;
    rdfs:comment 'Current operational status of the department. Active departments are open for business; inactive departments are closed or not yet operational.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentType rdf:type rdf:Property ;
    rdfs:label 'Department Type' ;
    rdfs:comment 'Classification of the department by merchandise category. Determines merchandising strategy, planogram standards, and operational procedures. [ENUM-REF-CANDIDATE: grocery|apparel|electronics|household|pharmacy|bakery|deli|produce|frozen|health_beauty|seasonal|home_garden|automotive|sporting_goods|toys|jewelry|furniture — 17 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endcapCount rdf:type rdf:Property ;
    rdfs:label 'Endcap Count' ;
    rdfs:comment 'Number of endcap display positions (end-of-aisle promotional displays) available in the department. Prime real estate for high-margin or promotional items.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fixtureCount rdf:type rdf:Property ;
    rdfs:label 'Fixture Count' ;
    rdfs:comment 'Total number of fixtures (gondolas, endcaps, shelving units, display cases) assigned to the department. Used for planogram capacity planning.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:floorNumber rdf:type rdf:Property ;
    rdfs:label 'Floor Number' ;
    rdfs:comment 'Floor level where the department is located within the store. Ground floor is typically 1, basement levels may be 0 or negative.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gondolaCount rdf:type rdf:Property ;
    rdfs:label 'Gondola Count' ;
    rdfs:comment 'Number of gondola shelving units (freestanding double-sided shelving) in the department. Key metric for planogram assignment and merchandising capacity.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossMarginTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Target Percent' ;
    rdfs:comment 'Target gross margin percentage for the department. Used to measure profitability and pricing effectiveness.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborBudgetMonthly rdf:type rdf:Property ;
    rdfs:label 'Labor Budget Monthly' ;
    rdfs:comment 'Monthly labor budget allocation for the department in local currency. Used for workforce scheduling and labor-to-sales ratio management.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licensedDepartmentFlag rdf:type rdf:Property ;
    rdfs:label 'Licensed Department Flag' ;
    rdfs:comment 'Indicates whether the department requires special licensing or regulatory compliance (e.g., pharmacy, alcohol, tobacco, firearms). True if licensing is required.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:omnichannelFulfillmentEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Omnichannel Fulfillment Enabled Flag' ;
    rdfs:comment 'Indicates whether the department supports omnichannel fulfillment operations (BOPIS, ROPIS, ship-from-store). True if omnichannel fulfillment is enabled.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planogramCount rdf:type rdf:Property ;
    rdfs:label 'Planogram Count' ;
    rdfs:comment 'Number of active planograms (shelf layout diagrams) assigned to the department. Each planogram defines product placement and facings for a fixture or section.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:posTerminalCount rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Count' ;
    rdfs:comment 'Number of POS terminals or checkout lanes assigned to or located within the department. Relevant for departments with dedicated checkout (e.g., pharmacy, jewelry).' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesTargetMonthly rdf:type rdf:Property ;
    rdfs:label 'Sales Target Monthly' ;
    rdfs:comment 'Monthly sales target or quota for the department in local currency. Used for performance management and comp sales (SSS) analysis.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellingAreaSqFt rdf:type rdf:Property ;
    rdfs:label 'Selling Area Sq Ft' ;
    rdfs:comment 'Total selling floor space allocated to the department measured in square feet. Used to calculate sales per square foot and space productivity metrics.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shrinkageRatePercent rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Rate Percent' ;
    rdfs:comment 'Historical shrinkage rate (inventory loss due to theft, damage, spoilage) for the department expressed as a percentage of sales. Used for loss prevention planning.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMaxF rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max F' ;
    rdfs:comment 'Maximum temperature threshold in Fahrenheit for temperature-controlled departments. Null for non-temperature-controlled departments.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinF rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min F' ;
    rdfs:comment 'Minimum temperature threshold in Fahrenheit for temperature-controlled departments. Null for non-temperature-controlled departments.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visualMerchandisingStandard rdf:type rdf:Property ;
    rdfs:label 'Visual Merchandising Standard' ;
    rdfs:comment 'Code or reference to the visual merchandising standard or guideline applied to the department. Defines display aesthetics, signage, and presentation rules.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assortmentBreadthLevel rdf:type rdf:Property ;
    rdfs:label 'Assortment Breadth Level' ;
    rdfs:comment 'Typical range of product categories carried by this format. Narrow = few categories (e.g., convenience); broad = many categories (e.g., hypermarket).' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assortmentDepthLevel rdf:type rdf:Property ;
    rdfs:label 'Assortment Depth Level' ;
    rdfs:comment 'Typical variety within each product category for this format. Shallow = limited SKU (Stock Keeping Unit) variety per category; deep = extensive SKU variety per category.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bopisCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Bopis Capable Flag' ;
    rdfs:comment 'Indicates whether stores of this format are capable of supporting BOPIS (Buy Online Pick Up In Store) fulfillment. True if BOPIS is supported; false otherwise.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientelingServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Clienteling Service Flag' ;
    rdfs:comment 'Indicates whether stores of this format offer clienteling (personalized in-store service) to customers. True if clienteling is offered; false otherwise.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dsdReceivingFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Receiving Flag' ;
    rdfs:comment 'Indicates whether stores of this format receive DSD (Direct Store Delivery) shipments directly from vendors, bypassing the DC (Distribution Center). True if DSD receiving is supported; false otherwise.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endcapCountTypical rdf:type rdf:Property ;
    rdfs:label 'Endcap Count Typical' ;
    rdfs:comment 'Typical number of endcaps (end-of-aisle displays) available for promotional merchandising in stores of this format.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formatDescription rdf:type rdf:Property ;
    rdfs:label 'Format Description' ;
    rdfs:comment 'Detailed description of the store format including its purpose, target customer segment, and operational characteristics.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatName rdf:type rdf:Property ;
    rdfs:label 'Format Name' ;
    rdfs:comment 'Full descriptive name of the store format (e.g., Hypermarket, Superstore, Department Store, Discount Outlet, Convenience Store, Dark Store, Micro-Fulfillment Center, Ship-from-Store Node).' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatStatus rdf:type rdf:Property ;
    rdfs:label 'Format Status' ;
    rdfs:comment 'Current lifecycle status of the store format. Active formats are in use across the banner portfolio; deprecated formats are being phased out; pilot formats are under testing.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatType rdf:type rdf:Property ;
    rdfs:label 'Format Type' ;
    rdfs:comment 'High-level classification of the format: physical_retail (customer-facing), fulfillment_only (dark store, MFC), or hybrid (ship-from-store capable retail location).' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gondolaConfigurationType rdf:type rdf:Property ;
    rdfs:label 'Gondola Configuration Type' ;
    rdfs:comment 'Typical gondola (shelving unit) configuration used in stores of this format. Defines the standard shelving layout and fixture type.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyProgramParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Participation Flag' ;
    rdfs:comment 'Indicates whether stores of this format participate in the enterprise loyalty program. True if loyalty program is active; false otherwise.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHoursType rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Type' ;
    rdfs:comment 'Typical operating hours pattern for stores of this format. 24_7 = open 24 hours; extended = long hours (e.g., 6am-midnight); standard = typical retail hours; limited = short hours; variable = hours vary by location.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingCapacityTypical rdf:type rdf:Property ;
    rdfs:label 'Parking Capacity Typical' ;
    rdfs:comment 'Typical number of parking spaces available at stores of this format. Null for formats without customer parking (e.g., dark stores, MFCs).' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planogramTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Planogram Template Code' ;
    rdfs:comment 'Code identifying the standard planogram (POG - Shelf Layout Diagram) template used for visual merchandising in stores of this format. Links to master planogram library.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posTerminalCountMax rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Count Max' ;
    rdfs:comment 'Maximum number of POS (Point of Sale) terminals typically deployed in stores of this format. Defines the upper bound of checkout capacity.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:posTerminalCountMin rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Count Min' ;
    rdfs:comment 'Minimum number of POS (Point of Sale) terminals typically deployed in stores of this format. Defines the lower bound of checkout capacity.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ropisCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Ropis Capable Flag' ;
    rdfs:comment 'Indicates whether stores of this format are capable of supporting ROPIS (Reserve Online Pick Up In Store) fulfillment. True if ROPIS is supported; false otherwise.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sfsCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Sfs Capable Flag' ;
    rdfs:comment 'Indicates whether stores of this format are capable of serving as SFS (Ship-from-Store) fulfillment nodes for e-commerce orders. True if SFS is supported; false otherwise.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sizeBandMaxSqft rdf:type rdf:Property ;
    rdfs:label 'Size Band Max Sqft' ;
    rdfs:comment 'Maximum store size in square feet for this format. Defines the upper bound of the typical size range.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sizeBandMinSqft rdf:type rdf:Property ;
    rdfs:label 'Size Band Min Sqft' ;
    rdfs:comment 'Minimum store size in square feet for this format. Defines the lower bound of the typical size range.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:staffingModelType rdf:type rdf:Property ;
    rdfs:label 'Staffing Model Type' ;
    rdfs:comment 'Typical staffing and service model for this format. Full service = high staff-to-customer ratio with personalized assistance; self-service = minimal staff, customer-driven; automated = robotic/automated fulfillment.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalSkuCountMax rdf:type rdf:Property ;
    rdfs:label 'Typical Sku Count Max' ;
    rdfs:comment 'Maximum number of SKUs (Stock Keeping Units) typically carried by stores of this format. Defines the upper bound of product assortment size.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:typicalSkuCountMin rdf:type rdf:Property ;
    rdfs:label 'Typical Sku Count Min' ;
    rdfs:comment 'Minimum number of SKUs (Stock Keeping Units) typically carried by stores of this format. Defines the lower bound of product assortment size.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wmsIntegrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Wms Integration Required Flag' ;
    rdfs:comment 'Indicates whether stores of this format require integration with WMS (Warehouse Management System) for inventory management. True for fulfillment-heavy formats (dark stores, MFCs, SFS nodes); false for traditional retail-only formats.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseId rdf:type rdf:Property ;
    rdfs:label 'License Id' ;
    rdfs:comment 'Unique identifier for the store license record. Primary key. Role: MASTER_AGREEMENT.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Months' ;
    rdfs:comment 'Number of months between required regulatory inspections. Used to calculate next inspection due dates.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastViolationDate rdf:type rdf:Property ;
    rdfs:label 'Last Violation Date' ;
    rdfs:comment 'Date of the most recent violation or citation issued for this license. Used for risk assessment and compliance monitoring.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reinstatementConditions rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Conditions' ;
    rdfs:comment 'Conditions or requirements that must be met for the license to be reinstated after suspension or revocation.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Eligible Flag' ;
    rdfs:comment 'Indicates whether the license is eligible for reinstatement after suspension or revocation. True if reinstatement is possible, False otherwise.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Lead Time Days' ;
    rdfs:comment 'Number of days before expiration that the renewal process must be initiated to ensure continuity. Supports automated renewal alerting.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'Date the license suspension is scheduled to end or was lifted. Nullable if suspension is indefinite.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'Date the license suspension became effective. Populated only when license_status is suspended.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:violationCount rdf:type rdf:Property ;
    rdfs:label 'Violation Count' ;
    rdfs:comment 'Total number of violations or citations issued against this license since its issue date. Tracks compliance history.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Dc Facility Id' ;
    rdfs:comment 'Foreign key linking to supplychain.dc_facility. Business justification: Every store has a primary DC assignment for standard replenishment routing. Fundamental retail supply chain topology required for: replenishment order routing, freight cost allocation, lead time calcu' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:accessibilityCertified rdf:type rdf:Property ;
    rdfs:label 'Accessibility Certified' ;
    rdfs:comment 'Indicates whether the store location is certified as fully accessible for customers with disabilities, meeting ADA (Americans with Disabilities Act) or equivalent local accessibility standards. True = certified accessible; False = not certified or non-compliant.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assortmentBreadthNorm rdf:type rdf:Property ;
    rdfs:label 'Assortment Breadth Norm' ;
    rdfs:comment 'Standard assortment breadth (range of categories) for this store format. Narrow = limited category count (convenience); Moderate = balanced category mix; Broad = wide category range; Very Broad = full-line assortment (hypermarket). Used for merchandising strategy.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assortmentDepthNorm rdf:type rdf:Property ;
    rdfs:label 'Assortment Depth Norm' ;
    rdfs:comment 'Standard assortment depth (variety within a category) for this store format. Shallow = limited SKU count per category; Moderate = balanced SKU selection; Deep = extensive SKU variety; Very Deep = maximum SKU variety. Used for category management and space planning.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bannerBrand rdf:type rdf:Property ;
    rdfs:label 'Banner Brand' ;
    rdfs:comment 'The retail banner or brand under which this location operates (e.g., \'Retail Hypermarket\', \'Retail Discount\', \'Retail Express\'). Used for brand segmentation, assortment planning, and marketing strategy.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bopisCapable rdf:type rdf:Property ;
    rdfs:label 'Bopis Capable' ;
    rdfs:comment 'Indicates whether this store location supports BOPIS (Buy Online Pick Up In Store) fulfillment. True = BOPIS enabled with dedicated pickup area; False = BOPIS not available. Used for omnichannel order routing and customer service.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dsdReceiving rdf:type rdf:Property ;
    rdfs:label 'Dsd Receiving' ;
    rdfs:comment 'Indicates whether this store location accepts Direct Store Delivery (DSD) from vendors, bypassing the distribution center (DC). True = DSD receiving enabled; False = all inventory flows through DC. Common for beverages, snacks, and bread.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formatSizeBand rdf:type rdf:Property ;
    rdfs:label 'Format Size Band' ;
    rdfs:comment 'Size classification band for the store format, used for assortment planning and operational benchmarking. Small = <20K sq ft; Medium = 20K-50K sq ft; Large = 50K-100K sq ft; Extra Large = >100K sq ft. Bands are format-specific.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRemodelDate rdf:type rdf:Property ;
    rdfs:label 'Last Remodel Date' ;
    rdfs:comment 'The date of the most recent major remodel or renovation of this store location. Used for capital expenditure tracking, store refresh planning, and performance analysis post-remodel.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'The legal entity name under which this store location operates. Used for regulatory filings, tax reporting, and legal compliance. May differ from the trading name.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfFloors rdf:type rdf:Property ;
    rdfs:label 'Number Of Floors' ;
    rdfs:comment 'Total number of customer-accessible floors in the store location. Used for store layout planning, accessibility compliance, and customer flow analysis.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'The date this store location first opened for business. Used for comp sales (SSS - Same-Store Sales) calculations, anniversary planning, and store maturity analysis. Null for planned stores not yet opened.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parkingCapacity rdf:type rdf:Property ;
    rdfs:label 'Parking Capacity' ;
    rdfs:comment 'Total number of customer parking spaces available at the store location. Used for site selection, customer convenience analysis, and BOPIS/ROPIS pickup planning. Null for urban locations without dedicated parking.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ropisCapable rdf:type rdf:Property ;
    rdfs:label 'Ropis Capable' ;
    rdfs:comment 'Indicates whether this store location supports ROPIS (Reserve Online Pick Up In Store) fulfillment, where customers reserve items online and complete purchase in-store. True = ROPIS enabled; False = ROPIS not available.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sellingSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Selling Square Footage' ;
    rdfs:comment 'Square footage of customer-accessible selling floor space, excluding back-of-house, storage, and office areas. Used for sales per square foot calculations, planogram (POG) planning, and merchandising density analysis.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sfsCapable rdf:type rdf:Property ;
    rdfs:label 'Sfs Capable' ;
    rdfs:comment 'Indicates whether this store location is enabled as a Ship-from-Store (SFS) fulfillment node, capable of picking, packing, and shipping e-commerce orders directly from store inventory. True = SFS enabled; False = SFS not available.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storeName rdf:type rdf:Property ;
    rdfs:label 'Store Name' ;
    rdfs:comment 'The trading name or display name of the store location as it appears to customers (e.g., \'Retail Superstore Downtown\', \'Retail Express Market Hill\'). Used for customer communications, receipts, and marketing materials.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Total Square Footage' ;
    rdfs:comment 'Total building square footage of the store location, including selling floor, back-of-house, storage, and office space. Used for productivity metrics (sales per square foot), lease accounting, and facility management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plId rdf:type rdf:Property ;
    rdfs:label 'Pl Id' ;
    rdfs:comment 'Unique identifier for the store-level profit and loss record. Primary key for the store P&L data product.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atvAmount rdf:type rdf:Property ;
    rdfs:label 'Atv Amount' ;
    rdfs:comment 'Average dollar value per transaction, calculated as net sales divided by transaction count. Key metric for store performance and basket analysis.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compSalesFlag rdf:type rdf:Property ;
    rdfs:label 'Comp Sales Flag' ;
    rdfs:comment 'Indicates whether this store qualifies for comparable store sales (SSS - Same-Store Sales) analysis for the period. Typically true if the store has been open for at least 12 months.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compSalesGrowthPercent rdf:type rdf:Property ;
    rdfs:label 'Comp Sales Growth Percent' ;
    rdfs:comment 'Year-over-year percentage change in net sales for this store during the period, used for same-store sales (SSS) performance tracking.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Depreciation Amount' ;
    rdfs:comment 'Depreciation expense for store fixtures, equipment, POS terminals, gondolas, and other fixed assets allocated to the store for the period.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountsAmount rdf:type rdf:Property ;
    rdfs:label 'Discounts Amount' ;
    rdfs:comment 'Total value of markdowns, promotional discounts, and price reductions applied to merchandise sales during the period.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebitdaAmount rdf:type rdf:Property ;
    rdfs:label 'Ebitda Amount' ;
    rdfs:comment 'Store contribution to enterprise EBITDA, calculated as gross margin minus operating expenses (excluding depreciation). Key metric for store-level profitability and GMROI analysis.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebitdaPercent rdf:type rdf:Property ;
    rdfs:label 'Ebitda Percent' ;
    rdfs:comment 'EBITDA as a percentage of net sales. Used for store performance benchmarking and profitability comparison across locations.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalizedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Finalized Timestamp' ;
    rdfs:comment 'Date and time when this store P&L record was marked as final and locked for audit purposes. Null if still preliminary.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:grossSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Sales Amount' ;
    rdfs:comment 'Total merchandise sales at the store before deducting returns, allowances, and discounts. Used to calculate return rates and discount penetration.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Amount' ;
    rdfs:comment 'Total store labor expenses including wages, salaries, benefits, payroll taxes, and overtime for store associates and management during the period.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Marketing Expense Amount' ;
    rdfs:comment 'Store-level marketing and advertising expenses including local promotions, signage, endcap displays, and community engagement costs for the period.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Net Sales Amount' ;
    rdfs:comment 'Total revenue from merchandise sales at the store during the period, net of returns, allowances, and discounts. Represents the top line of the store P&L.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:occupancyCostAmount rdf:type rdf:Property ;
    rdfs:label 'Occupancy Cost Amount' ;
    rdfs:comment 'Total store occupancy expenses including rent, common area maintenance (CAM) charges, property taxes, utilities, and facility maintenance costs for the period.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherOperatingExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Other Operating Expense Amount' ;
    rdfs:comment 'Miscellaneous operating expenses not classified in other categories, including bank fees, credit card processing fees, security services, and other store-level costs.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plStatus rdf:type rdf:Property ;
    rdfs:label 'Pl Status' ;
    rdfs:comment 'Current status of the P&L record indicating whether the figures are preliminary estimates, final audited values, or restated corrections.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingEntity rdf:type rdf:Property ;
    rdfs:label 'Reporting Entity' ;
    rdfs:comment 'Legal entity or business unit responsible for this store P&L record, used for consolidated financial reporting and intercompany reconciliation.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnsAmount rdf:type rdf:Property ;
    rdfs:label 'Returns Amount' ;
    rdfs:comment 'Total value of merchandise returned by customers during the period. Subtracted from gross sales to arrive at net sales.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shrinkageAmount rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Amount' ;
    rdfs:comment 'Total inventory loss due to theft, damage, spoilage, or administrative errors during the period. Recorded as an operating expense.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Supply Expense Amount' ;
    rdfs:comment 'Total cost of store supplies including bags, packaging materials, cleaning supplies, POS consumables, and other operational supplies consumed during the period.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOperatingExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Total Operating Expense Amount' ;
    rdfs:comment 'Sum of all operating expenses including shrinkage, occupancy, labor, supplies, marketing, depreciation, and other operating costs for the period.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCount rdf:type rdf:Property ;
    rdfs:label 'Transaction Count' ;
    rdfs:comment 'Total number of POS transactions completed at the store during the period. Used to calculate average transaction value (ATV) and units per transaction (UPT).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upt rdf:type rdf:Property ;
    rdfs:label 'Upt' ;
    rdfs:comment 'Average number of units sold per transaction, calculated as units sold divided by transaction count. Indicates basket size and cross-selling effectiveness.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storePlanogramId rdf:type rdf:Property ;
    rdfs:label 'Store Planogram Id' ;
    rdfs:comment 'Unique identifier for the store planogram record. Primary key.' ;
    rdfs:domain ind:StorePlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Compliance Tolerance Percent' ;
    rdfs:comment 'Acceptable variance percentage from the planogram specification before a compliance violation is flagged. Typically 5-10% for facing count or placement accuracy.' ;
    rdfs:domain ind:StorePlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compliantStoreCount rdf:type rdf:Property ;
    rdfs:label 'Compliant Store Count' ;
    rdfs:comment 'Number of stores that are currently in compliance with this planogram based on the most recent audit or compliance check.' ;
    rdfs:domain ind:StorePlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deployedStoreCount rdf:type rdf:Property ;
    rdfs:label 'Deployed Store Count' ;
    rdfs:comment 'Number of stores where this planogram has been deployed and is currently active. Used for rollout tracking and compliance monitoring.' ;
    rdfs:domain ind:StorePlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxOnShelfQuantity rdf:type rdf:Property ;
    rdfs:label 'Max On Shelf Quantity' ;
    rdfs:comment 'Maximum total quantity of products that can be displayed on the shelf for this planogram. Prevents overstocking and ensures visual merchandising standards.' ;
    rdfs:domain ind:StorePlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:merchandisingStrategy rdf:type rdf:Property ;
    rdfs:label 'Merchandising Strategy' ;
    rdfs:comment 'Strategic approach used in this planogram layout. Category Dominance = maximize category presence; Brand Blocking = group by brand; Price Point Segmentation = organize by price tier; Cross-Merchandising = complementary products together; Impulse = high-margin impulse items.' ;
    rdfs:domain ind:StorePlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minOnShelfQuantity rdf:type rdf:Property ;
    rdfs:label 'Min On Shelf Quantity' ;
    rdfs:comment 'Minimum total quantity of products that should be maintained on the shelf for this planogram. Used for replenishment triggers and out-of-stock prevention.' ;
    rdfs:domain ind:StorePlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planogramStatus rdf:type rdf:Property ;
    rdfs:label 'Planogram Status' ;
    rdfs:comment 'Current lifecycle status of the planogram. Draft = under development; Approved = ready for deployment; Active = currently in use in stores; Retired = no longer in use; Suspended = temporarily inactive.' ;
    rdfs:domain ind:StorePlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramType rdf:type rdf:Property ;
    rdfs:label 'Planogram Type' ;
    rdfs:comment 'Classification of the planogram by purpose. Standard = ongoing core assortment; Seasonal = time-bound seasonal layout; Promotional = temporary promotional display; Reset = major category reset; Test = pilot or A/B test layout.' ;
    rdfs:domain ind:StorePlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySkuCount rdf:type rdf:Property ;
    rdfs:label 'Primary Sku Count' ;
    rdfs:comment 'Number of SKUs designated as primary placements (core assortment) in this planogram, excluding promotional or secondary placements.' ;
    rdfs:domain ind:StorePlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalSkuCount rdf:type rdf:Property ;
    rdfs:label 'Promotional Sku Count' ;
    rdfs:comment 'Number of SKUs designated as promotional or temporary placements in this planogram. Used for promotional execution tracking.' ;
    rdfs:domain ind:StorePlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skuCount rdf:type rdf:Property ;
    rdfs:label 'Sku Count' ;
    rdfs:comment 'Total number of unique SKUs (Stock Keeping Units) included in this planogram. Measures assortment depth for the fixture or category.' ;
    rdfs:domain ind:StorePlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetSalesPerLinearFoot rdf:type rdf:Property ;
    rdfs:label 'Target Sales Per Linear Foot' ;
    rdfs:comment 'Target sales revenue per linear foot of shelf space for this planogram. Key space productivity metric for category management and assortment optimization.' ;
    rdfs:domain ind:StorePlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLinearFeet rdf:type rdf:Property ;
    rdfs:label 'Total Linear Feet' ;
    rdfs:comment 'Total linear shelf space in feet covered by this planogram. Used for space productivity analysis and category management.' ;
    rdfs:domain ind:StorePlanogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remodelId rdf:type rdf:Property ;
    rdfs:label 'Remodel Id' ;
    rdfs:comment 'Unique identifier for the store remodel project record. Primary key for the store remodel entity.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractorVendorId rdf:type rdf:Property ;
    rdfs:label 'Contractor Vendor Id' ;
    rdfs:comment 'Foreign key linking to supplier.vendor. Business justification: Remodel projects are executed by general contractors who are vendors. Linking the contractor vendor enables payment processing via AP, warranty claim tracking, contractor performance evaluation, and p' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:launchPromoCampaignId rdf:type rdf:Property ;
    rdfs:label 'Launch Promo Campaign Id' ;
    rdfs:comment 'Foreign key linking to promotion.promo_campaign. Business justification: Store remodels are often launched with grand reopening promotional campaigns—retailers coordinate remodel completion with campaign timing for maximum traffic impact. Real estate and marketing teams tr' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoCampaign .

ind:previousStoreFormatId rdf:type rdf:Property ;
    rdfs:label 'Previous Store Format Id' ;
    rdfs:comment 'Foreign key linking to store.store_format. Business justification: Store remodels may involve format changes (e.g., converting a discount outlet to a hypermarket). The store_remodel record currently denormalizes previous_format as a STRING. Adding FK to store_format ' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Format .

ind:capitalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Capital Budget Amount' ;
    rdfs:comment 'Approved capital expenditure budget allocated for the remodel project. Includes construction, fixtures, equipment, and technology costs. Denominated in USD.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closureEndDate rdf:type rdf:Property ;
    rdfs:label 'Closure End Date' ;
    rdfs:comment 'Date when the store reopens to customers after remodel completion. Null if store remains open during remodel. Used to calculate closure duration and resume comp sales tracking.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closureStartDate rdf:type rdf:Property ;
    rdfs:label 'Closure Start Date' ;
    rdfs:comment 'Date when the store temporarily closes to customers for remodel work. Null if store remains open during remodel. Critical for comp sales (SSS) exclusion logic.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compSalesExclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Comp Sales Exclusion Flag' ;
    rdfs:comment 'Indicates whether this store should be excluded from Same-Store Sales (SSS) or Comparable Store Sales (Comp Sales) calculations during the remodel period. True means exclude from comp sales; false means include. Stores under significant remodel are typically excluded to avoid distorting performance metrics.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contractor Reference Number' ;
    rdfs:comment 'External reference identifier or contract number assigned by the contractor for this remodel project. Used for invoice reconciliation and vendor coordination.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Format Change Flag' ;
    rdfs:comment 'Indicates whether the remodel includes a change in store format or concept (e.g., converting from discount format to hypermarket, or introducing new department layouts). True means format conversion; false means format unchanged.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactedDepartments rdf:type rdf:Property ;
    rdfs:label 'Impacted Departments' ;
    rdfs:comment 'Comma-separated list of store departments or categories affected by the remodel (e.g., grocery, apparel, electronics, pharmacy). Used for merchandising planning and assortment adjustments during remodel.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Completion Date' ;
    rdfs:comment 'Date when final building inspections and occupancy certifications were completed and approved by local authorities. Required before store can reopen to customers.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:newFixtureCount rdf:type rdf:Property ;
    rdfs:label 'New Fixture Count' ;
    rdfs:comment 'Total number of new fixtures (gondolas, endcaps, display units) installed during the remodel. Used for asset tracking and visual merchandising planning.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newFormat rdf:type rdf:Property ;
    rdfs:label 'New Format' ;
    rdfs:comment 'Store format or concept classification after the remodel (e.g., hypermarket, discount store, department store, neighborhood market). Null if no format change occurred.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Number' ;
    rdfs:comment 'Government-issued building permit or construction permit number required for the remodel work. Used for regulatory compliance and inspection tracking.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectManagerName rdf:type rdf:Property ;
    rdfs:label 'Project Manager Name' ;
    rdfs:comment 'Name of the internal project manager or capital projects lead responsible for overseeing the remodel execution, vendor coordination, and budget management.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectNumber rdf:type rdf:Property ;
    rdfs:label 'Project Number' ;
    rdfs:comment 'Business-facing unique identifier for the remodel project, used for tracking and reporting across finance, operations, and capital planning systems.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle state of the remodel project. Planned indicates initial scoping; approved means budget allocated; in-progress indicates active construction; completed means project closed and store reopened; cancelled means project terminated; on-hold indicates temporary suspension.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Projected Completion Date' ;
    rdfs:comment 'Forecasted date when remodel project is expected to be completed and store reopened. Updated throughout project lifecycle based on progress.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remodelType rdf:type rdf:Property ;
    rdfs:label 'Remodel Type' ;
    rdfs:comment 'Classification of the remodel scope. Full remodel involves comprehensive store renovation; department refresh targets specific categories; fixture replacement updates gondolas, endcaps, and shelving; technology upgrade installs new POS, digital signage, or self-checkout; accessibility improvement ensures ADA compliance; format conversion changes store concept or layout.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roiProjectionPercent rdf:type rdf:Property ;
    rdfs:label 'Roi Projection Percent' ;
    rdfs:comment 'Projected return on investment percentage for the remodel project, calculated during capital planning. Represents expected incremental sales lift or cost savings as a percentage of capital investment.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:squareFootageChange rdf:type rdf:Property ;
    rdfs:label 'Square Footage Change' ;
    rdfs:comment 'Net change in store selling square footage resulting from the remodel. Positive values indicate expansion; negative values indicate reduction. Zero indicates no size change. Measured in square feet.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sustainabilityFeatures rdf:type rdf:Property ;
    rdfs:label 'Sustainability Features' ;
    rdfs:comment 'Comma-separated list of sustainability or environmental improvements included in the remodel (e.g., LED lighting, energy-efficient HVAC, solar panels, water conservation fixtures, recycled materials, LEED certification).' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyUpgrades rdf:type rdf:Property ;
    rdfs:label 'Technology Upgrades' ;
    rdfs:comment 'Comma-separated list of technology systems upgraded or installed during remodel (e.g., POS terminals, self-checkout kiosks, digital signage, RFID readers, electronic shelf labels, mobile POS).' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temporaryClosureFlag rdf:type rdf:Property ;
    rdfs:label 'Temporary Closure Flag' ;
    rdfs:comment 'Indicates whether the store will be temporarily closed to customers during the remodel period. True means full closure; false means store remains open with partial operations.' ;
    rdfs:domain ind:Remodel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trafficCountId rdf:type rdf:Property ;
    rdfs:label 'Traffic Count Id' ;
    rdfs:comment 'Primary key for traffic_count' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accuracyConfidencePercent rdf:type rdf:Property ;
    rdfs:label 'Accuracy Confidence Percent' ;
    rdfs:comment 'Estimated accuracy confidence level of the measurement as a percentage (e.g., 95.5 indicates 95.5% confidence). Provided by advanced sensor systems with built-in quality scoring.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDwellTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Dwell Time Minutes' ;
    rdfs:comment 'Average time in minutes that customers spent in the counting zone during the measurement interval. Calculated from inbound/outbound timing data. Indicates customer engagement and shopping behavior.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Date' ;
    rdfs:comment 'Date when the sensor device was last calibrated or validated for accuracy. Sensors require periodic calibration to maintain measurement precision; this attribute supports data quality auditing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countingZoneCode rdf:type rdf:Property ;
    rdfs:label 'Counting Zone Code' ;
    rdfs:comment 'Code identifying the specific zone or area within the store where traffic was measured (e.g., MAIN_ENTRANCE, DEPT_ELECTRONICS, CHECKOUT_AREA, ENDCAP_A1). Enables zone-level footfall analysis.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countingZoneName rdf:type rdf:Property ;
    rdfs:label 'Counting Zone Name' ;
    rdfs:comment 'Human-readable name of the counting zone (e.g., Main Entrance, Electronics Department, Checkout Area 1). Provides business-friendly identification of the measurement location.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Indicator of the reliability and completeness of the traffic count measurement. Used to filter or adjust analytics based on data quality issues.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Day Of Week' ;
    rdfs:comment 'Day of the week when the measurement was taken. Footfall patterns vary significantly by day of week; this attribute supports day-of-week trend analysis and staffing optimization. [ENUM-REF-CANDIDATE: monday|tuesday|wednesday|thursday|friday|saturday|sunday — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hourOfDay rdf:type rdf:Property ;
    rdfs:label 'Hour Of Day' ;
    rdfs:comment 'Hour of the day (0-23) when the measurement was taken. Enables intraday footfall pattern analysis and peak-hour identification for workforce scheduling.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inboundCount rdf:type rdf:Property ;
    rdfs:label 'Inbound Count' ;
    rdfs:comment 'Number of customers or individuals entering the counting zone during the measurement interval. Core footfall metric for traffic volume analysis.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isPromotionalEvent rdf:type rdf:Property ;
    rdfs:label 'Is Promotional Event' ;
    rdfs:comment 'Flag indicating whether a store-level promotional event or special sale was active during the measurement period. Used to isolate promotional lift in footfall analysis.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStoreOpen rdf:type rdf:Property ;
    rdfs:label 'Is Store Open' ;
    rdfs:comment 'Flag indicating whether the store was open for business during the measurement interval. Distinguishes operational footfall from after-hours activity (e.g., restocking, maintenance).' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementIntervalMinutes rdf:type rdf:Property ;
    rdfs:label 'Measurement Interval Minutes' ;
    rdfs:comment 'Duration of the measurement interval in minutes (e.g., 15, 60, 1440 for daily). Defines the time window over which traffic counts were aggregated.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netOccupancyEstimate rdf:type rdf:Property ;
    rdfs:label 'Net Occupancy Estimate' ;
    rdfs:comment 'Estimated number of customers present in the zone at the end of the measurement interval, calculated as cumulative inbound minus outbound. Used for real-time capacity management and safety compliance.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outboundCount rdf:type rdf:Property ;
    rdfs:label 'Outbound Count' ;
    rdfs:comment 'Number of customers or individuals exiting the counting zone during the measurement interval. Used to calculate net occupancy and dwell time.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peakOccupancy rdf:type rdf:Property ;
    rdfs:label 'Peak Occupancy' ;
    rdfs:comment 'Maximum number of customers simultaneously present in the zone during the measurement interval. Used for capacity planning, safety compliance, and staffing optimization.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sensorDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Sensor Device Code' ;
    rdfs:comment 'Unique identifier of the people-counting sensor or camera system that captured the measurement. Used for device performance tracking and data quality auditing.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorType rdf:type rdf:Property ;
    rdfs:label 'Sensor Type' ;
    rdfs:comment 'Technology type of the counting sensor (e.g., thermal imaging, video analytics with AI, infrared beam, RFID, WiFi tracking, Bluetooth beacon). Impacts measurement accuracy and privacy considerations.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Temperature Fahrenheit' ;
    rdfs:comment 'Outdoor temperature in degrees Fahrenheit at the time of measurement. Used for weather-adjusted footfall modeling and seasonal trend analysis.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatherConditionCode rdf:type rdf:Property ;
    rdfs:label 'Weather Condition Code' ;
    rdfs:comment 'Weather condition at the time of measurement. Footfall is highly correlated with weather; this attribute enables weather-adjusted traffic forecasting and comp sales analysis. [ENUM-REF-CANDIDATE: clear|rain|snow|fog|storm|extreme_heat|extreme_cold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackId rdf:type rdf:Property ;
    rdfs:label 'Chargeback Id' ;
    rdfs:comment 'Unique identifier for the vendor compliance chargeback penalty record.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routingGuideId rdf:type rdf:Property ;
    rdfs:label 'Routing Guide Id' ;
    rdfs:comment 'Reference to the specific routing guide rule or compliance policy that was violated, enabling traceability to the governing standard.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoutingGuide .

ind:violationLocationId rdf:type rdf:Property ;
    rdfs:label 'Violation Location Id' ;
    rdfs:comment 'Foreign key linking to store.store_location. Business justification: Chargebacks for routing guide violations, labeling errors, or receiving discrepancies originate at specific receiving locations (stores or DCs). Tracking the violation location supports root cause ana' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:affectedUnits rdf:type rdf:Property ;
    rdfs:label 'Affected Units' ;
    rdfs:comment 'The number of units (SKUs, cartons, or pallets) impacted by the compliance violation.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargebackNumber rdf:type rdf:Property ;
    rdfs:label 'Chargeback Number' ;
    rdfs:comment 'Externally visible business identifier for the chargeback penalty, used in vendor communications and dispute resolution.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackType rdf:type rdf:Property ;
    rdfs:label 'Chargeback Type' ;
    rdfs:comment 'High-level category of the compliance violation that triggered the chargeback penalty. [ENUM-REF-CANDIDATE: routing_guide_violation|labeling_non_compliance|edi_failure|late_shipment|fill_rate_shortfall|asn_error|packaging_defect|quality_defect|documentation_error|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Debit Memo Number' ;
    rdfs:comment 'The external document number of the debit memo issued to the vendor for the chargeback penalty, if applicable.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionDate rdf:type rdf:Property ;
    rdfs:label 'Detection Date' ;
    rdfs:comment 'The date on which the compliance violation was formally identified and logged in the system, which may differ from the violation date.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'The date on which the vendor formally disputed the chargeback penalty.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isRepeatViolation rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Violation' ;
    rdfs:comment 'Flag indicating whether this chargeback represents a repeat violation of the same compliance rule by the vendor within a defined time window.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'The communication channel used to notify the vendor of the chargeback penalty.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Penalty Calculation Method' ;
    rdfs:comment 'The method used to calculate the chargeback penalty amount, such as a fixed flat fee or a percentage of the order value.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyPercentage rdf:type rdf:Property ;
    rdfs:label 'Penalty Percentage' ;
    rdfs:comment 'The percentage rate applied to the order or shipment value when the penalty calculation method is percentage-based.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousViolationCount rdf:type rdf:Property ;
    rdfs:label 'Previous Violation Count' ;
    rdfs:comment 'The number of prior chargebacks issued to this vendor for the same violation category within the trailing 12-month period.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recoveryDate rdf:type rdf:Property ;
    rdfs:label 'Recovery Date' ;
    rdfs:comment 'The date on which the chargeback penalty amount was successfully recovered from the vendor through the specified recovery method.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorScorecardImpact rdf:type rdf:Property ;
    rdfs:label 'Vendor Scorecard Impact' ;
    rdfs:comment 'The negative impact score applied to the vendors performance scorecard as a result of this chargeback, used in vendor relationship management and future sourcing decisions.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:violationCategory rdf:type rdf:Property ;
    rdfs:label 'Violation Category' ;
    rdfs:comment 'Detailed classification of the specific compliance rule or requirement that was violated, such as GS1-128 labeling failure, RFID tag missing, or incorrect pallet configuration.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediConfigId rdf:type rdf:Property ;
    rdfs:label 'Edi Config Id' ;
    rdfs:comment 'Unique identifier for the EDI configuration record. Primary key for the EDI configuration entity.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EdiConfig .

ind:tradingPartnerVendorId rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Vendor Id' ;
    rdfs:comment 'Unique identifier assigned to the trading partner in the EDI network. Used in EDI envelope segments to identify sender and receiver.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:alertEmailAddresses rdf:type rdf:Property ;
    rdfs:label 'Alert Email Addresses' ;
    rdfs:comment 'Comma-separated list of email addresses to notify when EDI errors, SLA violations, or integration health issues occur. Used for operational alerting.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Authentication Method' ;
    rdfs:comment 'The authentication mechanism used to secure the EDI connection. Certificate-based authentication is standard for AS2; SSH keys are common for SFTP.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Chargeback Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the chargeback penalty amount. Example: USD, EUR, GBP.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationProtocol rdf:type rdf:Property ;
    rdfs:label 'Communication Protocol' ;
    rdfs:comment 'The technical protocol used to transmit EDI documents between trading partners. AS2 is the most common secure protocol; VAN refers to Value-Added Network services.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceThresholdErrorRate rdf:type rdf:Property ;
    rdfs:label 'Compliance Threshold Error Rate' ;
    rdfs:comment 'The maximum acceptable error rate (as a percentage) for EDI transactions before compliance penalties or chargebacks are triggered. Example: 2.00 means 2% error rate threshold.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:connectionEndpoint rdf:type rdf:Property ;
    rdfs:label 'Connection Endpoint' ;
    rdfs:comment 'The URL, IP address, or network address used to connect to the trading partner for EDI transmission. May be an AS2 URL, SFTP host, or VAN mailbox identifier.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionPort rdf:type rdf:Property ;
    rdfs:label 'Connection Port' ;
    rdfs:comment 'The network port number used for EDI communication. Common ports: 22 for SFTP, 443 for AS2 over HTTPS.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ediVersion rdf:type rdf:Property ;
    rdfs:label 'Edi Version' ;
    rdfs:comment 'The EDI standard version supported by this configuration. Examples: 4010, 5010 for ANSI X12; D96A, D01B for EDIFACT.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentType rdf:type rdf:Property ;
    rdfs:label 'Environment Type' ;
    rdfs:comment 'Indicates whether this EDI configuration is for production use or a non-production environment (test, development, staging). Test environments are used during EDI onboarding and integration testing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faSlaHours rdf:type rdf:Property ;
    rdfs:label 'Fa Sla Hours' ;
    rdfs:comment 'The maximum number of hours allowed to send a functional acknowledgment (997) after receiving an EDI document. Failure to meet this SLA may trigger compliance chargebacks.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:functionalAcknowledgmentRequired rdf:type rdf:Property ;
    rdfs:label 'Functional Acknowledgment Required' ;
    rdfs:comment 'Indicates whether the trading partner requires a 997 Functional Acknowledgment to be sent in response to received EDI documents. True if FA is mandatory per trading partner agreement.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gsQualifier rdf:type rdf:Property ;
    rdfs:label 'Gs Qualifier' ;
    rdfs:comment 'GS qualifier code that identifies the type of identification being used in the functional group envelope. Defines how the sender/receiver codes are interpreted.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundEnabled rdf:type rdf:Property ;
    rdfs:label 'Inbound Enabled' ;
    rdfs:comment 'Indicates whether this configuration is enabled to receive inbound EDI documents from the trading partner. True if inbound processing is active.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:integrationHealthStatus rdf:type rdf:Property ;
    rdfs:label 'Integration Health Status' ;
    rdfs:comment 'Current operational health status of the EDI integration. Derived from recent transmission success rates, error rates, and SLA compliance. Used for proactive monitoring.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isaQualifier rdf:type rdf:Property ;
    rdfs:label 'Isa Qualifier' ;
    rdfs:comment 'ISA qualifier code that identifies the type of identification being used in the EDI interchange envelope. Common values: 01=DUNS, 14=DUNS+4, ZZ=Mutually Defined. [ENUM-REF-CANDIDATE: 01|14|20|27|28|29|30|33|ZZ — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastErrorCode rdf:type rdf:Property ;
    rdfs:label 'Last Error Code' ;
    rdfs:comment 'The error code or identifier for the most recent EDI processing failure. Used in conjunction with last_error_timestamp for diagnostics.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastErrorDescription rdf:type rdf:Property ;
    rdfs:label 'Last Error Description' ;
    rdfs:comment 'Human-readable description of the most recent EDI error. Provides context for troubleshooting and resolution.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastErrorTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Error Timestamp' ;
    rdfs:comment 'The timestamp of the most recent EDI transmission or processing error. Used for troubleshooting and error resolution tracking.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastSuccessfulTransmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Successful Transmission Timestamp' ;
    rdfs:comment 'The timestamp of the most recent successful EDI document transmission (inbound or outbound). Used for integration health monitoring and alerting.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxRetryAttempts rdf:type rdf:Property ;
    rdfs:label 'Max Retry Attempts' ;
    rdfs:comment 'The maximum number of times a failed EDI transmission will be retried before being marked as permanently failed and requiring manual intervention.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onboardingStartDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Start Date' ;
    rdfs:comment 'The date when EDI onboarding activities began for this trading partner. Marks the start of the integration project.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outboundEnabled rdf:type rdf:Property ;
    rdfs:label 'Outbound Enabled' ;
    rdfs:comment 'Indicates whether this configuration is enabled to send outbound EDI documents to the trading partner. True if outbound processing is active.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retryPolicy rdf:type rdf:Property ;
    rdfs:label 'Retry Policy' ;
    rdfs:comment 'The retry strategy applied when EDI transmission failures occur. Defines how and when failed transmissions are retried.' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedTransactionSets rdf:type rdf:Property ;
    rdfs:label 'Supported Transaction Sets' ;
    rdfs:comment 'Comma-separated list of EDI transaction set codes supported by this trading partner. Common retail sets: 850 (Purchase Order), 855 (PO Acknowledgment), 856 (Advance Ship Notice), 810 (Invoice), 832 (Price/Sales Catalog), 846 (Inventory Inquiry/Advice), 997 (Functional Acknowledgment).' ;
    rdfs:domain ind:EdiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeAgreementId rdf:type rdf:Property ;
    rdfs:label 'Lead Time Agreement Id' ;
    rdfs:comment 'Unique identifier for the lead time agreement record. Primary key.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeadTimeAgreement .

ind:destinationInventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Inventory Node Id' ;
    rdfs:comment 'Foreign key linking to inventory.inventory_node. Business justification: Lead time agreements specify delivery terms to specific DCs, stores, or cross-dock facilities. Essential for replenishment planning, inbound appointment scheduling, and on-time delivery SLA measuremen' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the lead time agreement.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compliancePenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Compliance Penalty Rate' ;
    rdfs:comment 'Percentage rate applied as chargeback penalty for vendor non-compliance with lead time or delivery terms.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryWindowEndTime rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End Time' ;
    rdfs:comment 'End time of the agreed delivery window at distribution center (HH:MM format).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryWindowStartTime rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start Time' ;
    rdfs:comment 'Start time of the agreed delivery window at distribution center (HH:MM format).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ediEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Enabled Flag' ;
    rdfs:comment 'Indicates whether purchase orders and ASNs are exchanged via EDI for this agreement.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expeditedLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Expedited Lead Time Days' ;
    rdfs:comment 'Reduced lead time in days available for rush or expedited orders, typically at premium cost.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fillRateSlaPercent rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Sla Percent' ;
    rdfs:comment 'Target percentage of ordered quantity that vendor must deliver to meet order completion SLA.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:innerPackQuantity rdf:type rdf:Property ;
    rdfs:label 'Inner Pack Quantity' ;
    rdfs:comment 'Number of consumer units in an inner pack within the master case, used for store-level replenishment.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onTimeDeliverySlaPercent rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Sla Percent' ;
    rdfs:comment 'Target percentage of deliveries that must arrive within the agreed lead time window to meet SLA.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderIncrementQuantity rdf:type rdf:Property ;
    rdfs:label 'Order Increment Quantity' ;
    rdfs:comment 'Quantity increment in which orders must be placed above the MOQ (e.g., must order in multiples of 12 units).' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originLocation rdf:type rdf:Property ;
    rdfs:label 'Origin Location' ;
    rdfs:comment 'Geographic location or facility from which vendor ships products (city, state, country).' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletQuantity rdf:type rdf:Property ;
    rdfs:label 'Pallet Quantity' ;
    rdfs:comment 'Standard number of cases or units per pallet for warehouse receiving and cross-docking operations.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days advance notice required before agreement renewal or termination.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scopeLevel rdf:type rdf:Property ;
    rdfs:label 'Scope Level' ;
    rdfs:comment 'Granularity level at which this lead time agreement applies: vendor-wide, product category, subcategory, individual SKU, or product group.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalLeadTimeAdjustmentDays rdf:type rdf:Property ;
    rdfs:label 'Seasonal Lead Time Adjustment Days' ;
    rdfs:comment 'Additional days added to standard lead time during peak seasonal periods (e.g., holiday season, back-to-school).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal Period End Date' ;
    rdfs:comment 'End date of the seasonal period when lead time adjustments apply.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonalPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal Period Start Date' ;
    rdfs:comment 'Start date of the seasonal period when lead time adjustments apply.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standardLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Standard Lead Time Days' ;
    rdfs:comment 'Standard number of days from purchase order placement to goods receipt at distribution center under normal operating conditions.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportationMode rdf:type rdf:Property ;
    rdfs:label 'Transportation Mode' ;
    rdfs:comment 'Primary mode of transportation used for shipments under this agreement.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Enabled Flag' ;
    rdfs:comment 'Indicates whether this agreement operates under a VMI model where vendor manages inventory replenishment.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onboardingRequestId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Request Id' ;
    rdfs:comment 'Unique identifier for the vendor onboarding request record.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedBuyerId rdf:type rdf:Property ;
    rdfs:label 'Assigned Buyer Id' ;
    rdfs:comment 'Identifier of the procurement buyer or category manager responsible for managing this onboarding request and the vendor relationship.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Buyer .

ind:applicationSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Application Submitted Date' ;
    rdfs:comment 'Date when the vendor onboarding application was initially submitted for review.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:diversityCertification rdf:type rdf:Property ;
    rdfs:label 'Diversity Certification' ;
    rdfs:comment 'Diversity certification status of the vendor: MBE (Minority Business Enterprise), WBE (Women Business Enterprise), VBE (Veteran Business Enterprise), DBE (Disadvantaged Business Enterprise), LGBTBE (LGBT Business Enterprise), SDVOSB (Service-Disabled Veteran-Owned Small Business), HUBZone, or none. [ENUM-REF-CANDIDATE: mbe|wbe|vbe|dbe|lgbtbe|sdvosb|hubzone|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediSetupCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Setup Completed Flag' ;
    rdfs:comment 'Indicates whether the EDI connection and transaction sets have been successfully configured and tested with the vendor.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'First line of the vendor\'s headquarters street address (street number and name).' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the vendor\'s headquarters is located.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the vendor\'s headquarters location (e.g., USA, CAN, MEX, GBR).' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal code or ZIP code of the vendor\'s headquarters location.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State or province where the vendor\'s headquarters is located.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Received Flag' ;
    rdfs:comment 'Indicates whether the required insurance certificate has been received and validated during the onboarding process.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceCertificateRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Required Flag' ;
    rdfs:comment 'Indicates whether the vendor is required to provide proof of insurance (general liability, product liability, workers compensation) as part of the onboarding process.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moqUnits rdf:type rdf:Property ;
    rdfs:label 'Moq Units' ;
    rdfs:comment 'The minimum order quantity in units that the vendor requires for purchase orders, as agreed during onboarding negotiations.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Completion Date' ;
    rdfs:comment 'Date when all onboarding activities were completed, including EDI setup, item setup, and first purchase order issuance.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingStage rdf:type rdf:Property ;
    rdfs:label 'Onboarding Stage' ;
    rdfs:comment 'Current stage in the vendor onboarding workflow: application submitted, document review in progress, compliance check, EDI (Electronic Data Interchange) setup, item setup in PIM, first PO (Purchase Order) issued, completed, or rejected. [ENUM-REF-CANDIDATE: application|document_review|compliance_check|edi_setup|item_setup|first_po|completed|rejected — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary contact person at the vendor organization.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary contact person at the vendor organization for onboarding coordination and ongoing relationship management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Phone number of the primary contact person at the vendor organization.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Score' ;
    rdfs:comment 'Quantitative risk score assigned during the vendor qualification process, typically on a scale of 0-100, with higher scores indicating higher risk.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskTier rdf:type rdf:Property ;
    rdfs:label 'Risk Tier' ;
    rdfs:comment 'Risk classification of the vendor based on factors such as spend volume, product category criticality, geographic location, and compliance history. Used to determine the level of due diligence and ongoing monitoring required.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorDbaName rdf:type rdf:Property ;
    rdfs:label 'Vendor Dba Name' ;
    rdfs:comment 'The trade name or DBA name under which the vendor operates, if different from the legal name.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorLegalName rdf:type rdf:Property ;
    rdfs:label 'Vendor Legal Name' ;
    rdfs:comment 'The full legal name of the vendor organization as it appears on official registration documents and contracts.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:w9FormReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'W9 Form Received Flag' ;
    rdfs:comment 'Indicates whether the IRS Form W-9 (Request for Taxpayer Identification Number and Certification) has been received from the vendor for US tax reporting purposes.' ;
    rdfs:domain ind:OnboardingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Unique identifier for the vendor risk assessment record. Primary key.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessorAssociateId rdf:type rdf:Property ;
    rdfs:label 'Assessor Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Supplier risk assessment workflows require tracking which associate conducted the evaluation for accountability, expertise validation, and workload balancing. Replaces denormalized assessor_name/depar' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:assessmentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Expiry Date' ;
    rdfs:comment 'Date when this risk assessment expires and is no longer valid for vendor management decisions. Expired assessments require immediate reassessment before continuing business.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assessment Notes' ;
    rdfs:comment 'Free-text field for additional context, observations, qualitative risk factors, assessor commentary, or special considerations not captured in structured risk scores.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRiskScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Risk Score' ;
    rdfs:comment 'Score evaluating vendor\'s adherence to regulatory requirements, industry standards, contractual obligations, and history of chargebacks (vendor compliance penalties), RTV (Return to Vendor) incidents, and audit findings.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cybersecurityRiskScore rdf:type rdf:Property ;
    rdfs:label 'Cybersecurity Risk Score' ;
    rdfs:comment 'Score evaluating vendor\'s cybersecurity posture, data protection practices, incident history, compliance with PCI DSS (Payment Card Industry Data Security Standard), ISO 27001, and ability to protect shared data and EDI (Electronic Data Interchange) integrations.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esgRiskScore rdf:type rdf:Property ;
    rdfs:label 'Esg Risk Score' ;
    rdfs:comment 'Composite score assessing vendor\'s environmental practices, social responsibility, labor standards, ethical governance, and sustainability certifications. Evaluates ESG compliance and reputational risk.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialStabilityScore rdf:type rdf:Property ;
    rdfs:label 'Financial Stability Score' ;
    rdfs:comment 'Quantitative score evaluating the vendor\'s financial health, creditworthiness, liquidity ratios, and solvency. Typically scored 0-100 or 0-10 scale based on financial statement analysis and credit ratings.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geopoliticalRiskScore rdf:type rdf:Property ;
    rdfs:label 'Geopolitical Risk Score' ;
    rdfs:comment 'Score assessing exposure to geopolitical instability, trade restrictions, sanctions, tariffs, political unrest, or regulatory changes in vendor\'s operating regions.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mitigationActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Mitigation Actions Required' ;
    rdfs:comment 'Detailed description of risk mitigation actions, controls, or remediation steps required to reduce identified risks to acceptable levels. May include contract amendments, additional insurance, dual sourcing, enhanced monitoring, or capability improvements.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationDueDate rdf:type rdf:Property ;
    rdfs:label 'Mitigation Due Date' ;
    rdfs:comment 'Target completion date for mitigation actions. Used to track remediation progress and escalate overdue items.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mitigationOwner rdf:type rdf:Property ;
    rdfs:label 'Mitigation Owner' ;
    rdfs:comment 'Name or role of the individual or team responsible for executing and tracking mitigation actions (e.g., Category Manager, Supplier Quality Engineer, Procurement Director).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationStatus rdf:type rdf:Property ;
    rdfs:label 'Mitigation Status' ;
    rdfs:comment 'Current status of mitigation action execution: not started, in progress, completed, on hold pending vendor response, or cancelled if risk is accepted or vendor relationship terminated.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Date' ;
    rdfs:comment 'Scheduled date for the next periodic risk assessment. Calculated based on reassessment schedule and current assessment date.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallRiskScore rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Score' ;
    rdfs:comment 'Composite quantitative risk score calculated from weighted individual risk category scores. Used to rank vendors and prioritize risk mitigation efforts.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRiskTier rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Tier' ;
    rdfs:comment 'Aggregated risk classification tier derived from individual risk category scores. Determines vendor management intensity, monitoring frequency, and escalation protocols: low (minimal oversight), medium (standard monitoring), high (enhanced controls), critical (executive attention and mitigation required).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRiskScore rdf:type rdf:Property ;
    rdfs:label 'Quality Risk Score' ;
    rdfs:comment 'Score assessing product quality consistency, defect rates, recall history, quality acceptance rate percentage, and adherence to quality management standards such as ISO 9001.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reassessmentSchedule rdf:type rdf:Property ;
    rdfs:label 'Reassessment Schedule' ;
    rdfs:comment 'Frequency at which this vendor must be reassessed based on risk tier. Critical and high-risk vendors typically require quarterly or semi-annual reassessment; low-risk vendors may be assessed annually or biennially.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAppetiteThreshold rdf:type rdf:Property ;
    rdfs:label 'Risk Appetite Threshold' ;
    rdfs:comment 'Enterprise-defined risk appetite threshold score for this vendor category or spend tier. Vendors scoring above this threshold require executive approval or enhanced mitigation before continuing business.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskScoringMethodology rdf:type rdf:Property ;
    rdfs:label 'Risk Scoring Methodology' ;
    rdfs:comment 'Name or version of the risk scoring framework, algorithm, or methodology applied (e.g., weighted average, Monte Carlo simulation, proprietary enterprise risk model version 2.1).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:singleSourceDependencyScore rdf:type rdf:Property ;
    rdfs:label 'Single Source Dependency Score' ;
    rdfs:comment 'Risk score evaluating the business impact if this vendor is the sole or primary source for critical SKUs (Stock Keeping Units), categories, or services. Higher score indicates higher dependency risk.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyContinuityRiskScore rdf:type rdf:Property ;
    rdfs:label 'Supply Continuity Risk Score' ;
    rdfs:comment 'Score assessing the vendor\'s ability to maintain continuous supply, including manufacturing capacity, inventory buffers, lead time (supplier delivery duration) reliability, disaster recovery plans, and business continuity preparedness.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thirdPartyAssessmentFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Assessment Flag' ;
    rdfs:comment 'Indicates whether a third-party risk assessment firm or auditor was engaged to conduct or validate the assessment. True if external assessment was performed, False if internal only.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyAssessorName rdf:type rdf:Property ;
    rdfs:label 'Third Party Assessor Name' ;
    rdfs:comment 'Name of the external firm or auditor that conducted the third-party risk assessment, if applicable (e.g., Deloitte, EcoVadis, Dun & Bradstreet).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Defines the scope of vendors to which this routing guide applies: all vendors, a vendor group, or a specific vendor.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Appointment Required Flag' ;
    rdfs:comment 'Indicates whether vendors must schedule a delivery appointment with the DC before shipment.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appointmentSchedulingRule rdf:type rdf:Property ;
    rdfs:label 'Appointment Scheduling Rule' ;
    rdfs:comment 'Instructions for scheduling delivery appointments including booking windows, contact information, and scheduling system details.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Asn Lead Time Hours' ;
    rdfs:comment 'Minimum number of hours before delivery that the ASN must be transmitted to the DC for compliance.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:asnTimingRequirement rdf:type rdf:Property ;
    rdfs:label 'Asn Timing Requirement' ;
    rdfs:comment 'Mandatory timing for ASN transmission, specifying the pre-receipt window (e.g., 24-48 hours before delivery) required for DC planning.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierSelectionRule rdf:type rdf:Property ;
    rdfs:label 'Carrier Selection Rule' ;
    rdfs:comment 'Mandatory carrier selection instructions specifying which carriers or carrier types must be used for shipments under this guide.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casePackQuantity rdf:type rdf:Property ;
    rdfs:label 'Case Pack Quantity' ;
    rdfs:comment 'Required number of units per case for shipments under this routing guide.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargebackAmountPerViolation rdf:type rdf:Property ;
    rdfs:label 'Chargeback Amount Per Violation' ;
    rdfs:comment 'Standard chargeback amount assessed per routing guide violation, used to calculate vendor compliance penalties.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceEnforcementDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Enforcement Date' ;
    rdfs:comment 'Date from which non-compliance penalties and chargebacks will be enforced for violations of this routing guide.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dockDoorAssignmentRule rdf:type rdf:Property ;
    rdfs:label 'Dock Door Assignment Rule' ;
    rdfs:comment 'Instructions for dock door assignment at the DC, including any vendor-specific or product-category-specific door assignments.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionApprovalNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Approval Notes' ;
    rdfs:comment 'Detailed notes documenting approved exceptions, including scope, duration, and conditions of the exception.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Approval Status' ;
    rdfs:comment 'Status of any exception requests submitted by the vendor for deviations from standard routing guide requirements.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gs1128RequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gs1 128 Required Flag' ;
    rdfs:comment 'Indicates whether GS1-128 compliant carton labels are mandatory for shipments under this routing guide.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guideName rdf:type rdf:Property ;
    rdfs:label 'Guide Name' ;
    rdfs:comment 'Descriptive name of the routing guide for internal reference and vendor portal display.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guideNumber rdf:type rdf:Property ;
    rdfs:label 'Guide Number' ;
    rdfs:comment 'Externally-known business identifier for the routing guide, used in vendor communications and supplier portal.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guideStatus rdf:type rdf:Property ;
    rdfs:label 'Guide Status' ;
    rdfs:comment 'Current lifecycle status of the routing guide indicating its operational state.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guideVersion rdf:type rdf:Property ;
    rdfs:label 'Guide Version' ;
    rdfs:comment 'Version number of the routing guide, incremented with each revision to track changes over time.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingRequirement rdf:type rdf:Property ;
    rdfs:label 'Labeling Requirement' ;
    rdfs:comment 'Detailed labeling requirements including GS1-128 carton label specifications, RFID/EPC tag mandates, and placement instructions.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingStandard rdf:type rdf:Property ;
    rdfs:label 'Packing Standard' ;
    rdfs:comment 'Mandatory packing standards including case pack quantities, pallet build configurations, and stacking requirements.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletConfiguration rdf:type rdf:Property ;
    rdfs:label 'Pallet Configuration' ;
    rdfs:comment 'Specifications for pallet build including dimensions, weight limits, and stacking patterns required for DC receiving.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltySchedule rdf:type rdf:Property ;
    rdfs:label 'Penalty Schedule' ;
    rdfs:comment 'Detailed penalty schedule defining chargeback amounts for non-compliance with routing guide requirements, organized by violation type.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'Date on which this routing guide was published to the supplier portal.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publishedToPortalFlag rdf:type rdf:Property ;
    rdfs:label 'Published To Portal Flag' ;
    rdfs:comment 'Indicates whether this routing guide has been published to the supplier portal for vendor access.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivingHours rdf:type rdf:Property ;
    rdfs:label 'Receiving Hours' ;
    rdfs:comment 'DC receiving hours during which deliveries are accepted, specified by day of week and time ranges.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Required Flag' ;
    rdfs:comment 'Indicates whether RFID or EPC tags are required on cartons or pallets for automated receiving and inventory tracking.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shippingMode rdf:type rdf:Property ;
    rdfs:label 'Shipping Mode' ;
    rdfs:comment 'Required shipping mode or transportation method for shipments covered by this routing guide.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorAcknowledgmentStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Acknowledgment Status' ;
    rdfs:comment 'Status indicating whether the vendor has acknowledged receipt and acceptance of this routing guide via the supplier portal.' ;
    rdfs:domain ind:RoutingGuide ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingReturnsRmaId rdf:type rdf:Property ;
    rdfs:label 'Originating Returns Rma Id' ;
    rdfs:comment 'Foreign key linking to returns.rma. Business justification: Supplier RTVs are frequently triggered by customer returns. Buyers analyze which customer return reasons drive vendor RTVs to negotiate better contract terms and identify systemic quality issues. Enab' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rma .

ind:requestorAssociateId rdf:type rdf:Property ;
    rdfs:label 'Requestor Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Return-to-vendor workflows require tracking which retail associate initiated the request for accountability, performance metrics, and training needs analysis. Replaces denormalized requestor_name/emai' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:ediControlNumber rdf:type rdf:Property ;
    rdfs:label 'Edi Control Number' ;
    rdfs:comment 'The unique control number assigned to the EDI transmission of this RTV request for tracking and reconciliation purposes.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightResponsibility rdf:type rdf:Property ;
    rdfs:label 'Freight Responsibility' ;
    rdfs:comment 'Indicates which party (vendor or retailer) is responsible for paying the freight costs associated with returning the merchandise.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecallRelated rdf:type rdf:Property ;
    rdfs:label 'Is Recall Related' ;
    rdfs:comment 'Boolean flag indicating whether this RTV request is related to a product recall mandated by regulatory authorities or the manufacturer.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Boolean flag indicating whether the vendor requires a quality inspection of the returned merchandise before issuing credit or replacement.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Number' ;
    rdfs:comment 'The official recall identification number issued by the regulatory body or manufacturer if this RTV is recall-related.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'The date when the RTV request was initiated by the retailer. This is the principal business event timestamp for the transaction.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rtvStatus rdf:type rdf:Property ;
    rdfs:label 'Rtv Status' ;
    rdfs:comment 'Current lifecycle status of the RTV request indicating its position in the return workflow from draft through final credit or closure. [ENUM-REF-CANDIDATE: draft|submitted|approved|rejected|in_transit|received|credited|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalReturnQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Return Quantity' ;
    rdfs:comment 'The total quantity of units being returned to the vendor across all SKUs in this RTV request, measured in the base unit of measure.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReturnValue rdf:type rdf:Property ;
    rdfs:label 'Total Return Value' ;
    rdfs:comment 'The total monetary value of the merchandise being returned, calculated at cost basis. Represents the expected credit or reimbursement amount.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acknowledgmentCode rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Code' ;
    rdfs:comment 'ANSI X12 acknowledgment code from the 997/999 FA: A=Accepted, E=Accepted with Errors, R=Rejected, P=Partially Accepted, M=Rejected due to Missing Data, W=Rejected due to Wrong Data, X=Rejected due to Unrecognized Transaction Set. [ENUM-REF-CANDIDATE: A|E|R|P|M|W|X — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SupplierEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Timestamp' ;
    rdfs:comment 'Date and time when the functional acknowledgment (997/999) was received or sent for this transaction.' ;
    rdfs:domain ind:SupplierEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:archiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archive Timestamp' ;
    rdfs:comment 'Date and time when this EDI transaction was archived to long-term storage.' ;
    rdfs:domain ind:SupplierEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:archivedFlag rdf:type rdf:Property ;
    rdfs:label 'Archived Flag' ;
    rdfs:comment 'Boolean flag indicating whether this EDI transaction has been archived to long-term storage and purged from active operational tables.' ;
    rdfs:domain ind:SupplierEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Business Document Reference' ;
    rdfs:comment 'Reference to the underlying business document (e.g., purchase order number, invoice number, shipment number) that this EDI transaction represents.' ;
    rdfs:domain ind:SupplierEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Error code returned by the EDI translator or validation engine if the transaction failed processing. May reference ANSI X12 syntax error codes or internal error codes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorDescription rdf:type rdf:Property ;
    rdfs:label 'Error Description' ;
    rdfs:comment 'Human-readable description of the error encountered during EDI processing, including segment, element, and validation failure details.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'Name of the EDI file as received or sent, used for file-based EDI transmissions.' ;
    rdfs:domain ind:SupplierEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the EDI file in bytes, used for transmission monitoring and capacity planning.' ;
    rdfs:domain ind:SupplierEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:functionalAcknowledgmentStatus rdf:type rdf:Property ;
    rdfs:label 'Functional Acknowledgment Status' ;
    rdfs:comment 'Status of the 997 or 999 functional acknowledgment received or sent for this transaction, indicating whether the EDI message was accepted, rejected, or accepted with errors.' ;
    rdfs:domain ind:SupplierEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalGroupControlNumber rdf:type rdf:Property ;
    rdfs:label 'Functional Group Control Number' ;
    rdfs:comment 'Control number assigned to the functional group (GS segment) within the EDI interchange.' ;
    rdfs:domain ind:SupplierEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeControlNumber rdf:type rdf:Property ;
    rdfs:label 'Interchange Control Number' ;
    rdfs:comment 'Unique control number assigned to the EDI interchange envelope (ISA segment) for tracking and reconciliation purposes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxRetryCount rdf:type rdf:Property ;
    rdfs:label 'Max Retry Count' ;
    rdfs:comment 'Maximum number of retry attempts allowed for this transaction type before escalation or manual intervention is required.' ;
    rdfs:domain ind:SupplierEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Current processing status of the EDI transaction within the internal EDI pipeline (received, parsed, validated, processed, failed, retrying, archived). [ENUM-REF-CANDIDATE: received|parsed|validated|processed|failed|retrying|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Timestamp' ;
    rdfs:comment 'Date and time when the EDI transaction was processed by the internal EDI translation and integration engine.' ;
    rdfs:domain ind:SupplierEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiverCode rdf:type rdf:Property ;
    rdfs:label 'Receiver Code' ;
    rdfs:comment 'EDI receiver identifier from the ISA08 segment, typically the retailer\'s EDI ID or DUNS number.' ;
    rdfs:domain ind:SupplierEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverQualifier rdf:type rdf:Property ;
    rdfs:label 'Receiver Qualifier' ;
    rdfs:comment 'Qualifier code identifying the type of receiver ID (e.g., 01=DUNS, 08=UCC/EAN, 12=Phone, 14=DUNS+4, ZZ=Mutually Defined). [ENUM-REF-CANDIDATE: 01|02|08|09|10|11|12|13|14|15|16|20|27|28|29|30|33|ZZ — 18 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SupplierEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'Number of times the EDI transaction has been retried after initial processing failure. Used to track retry attempts and enforce retry limits.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentCount rdf:type rdf:Property ;
    rdfs:label 'Segment Count' ;
    rdfs:comment 'Total number of EDI segments in the transaction set, used for validation and completeness checks.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:senderQualifier rdf:type rdf:Property ;
    rdfs:label 'Sender Qualifier' ;
    rdfs:comment 'Qualifier code identifying the type of sender ID (e.g., 01=DUNS, 08=UCC/EAN, 12=Phone, 14=DUNS+4, ZZ=Mutually Defined). [ENUM-REF-CANDIDATE: 01|02|08|09|10|11|12|13|14|15|16|20|27|28|29|30|33|ZZ — 18 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SupplierEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testIndicator rdf:type rdf:Property ;
    rdfs:label 'Test Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this is a test/sandbox EDI transaction (true) or a production transaction (false).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionSetControlNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Set Control Number' ;
    rdfs:comment 'Control number assigned to the individual transaction set (ST segment) for unique identification within the functional group.' ;
    rdfs:domain ind:SupplierEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionSetType rdf:type rdf:Property ;
    rdfs:label 'Transaction Set Type' ;
    rdfs:comment 'The ANSI X12 transaction set identifier (e.g., 850=Purchase Order, 810=Invoice, 856=Advance Ship Notice, 860=Purchase Order Change, 997/999=Functional Acknowledgment, 846=Inventory Inquiry, 855=Purchase Order Acknowledgment, 875=Grocery Products Purchase Order, 204=Motor Carrier Load Tender, 214=Transportation Carrier Shipment Status). [ENUM-REF-CANDIDATE: 850|810|856|860|997|999|846|855|875|204|214 — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SupplierEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiry Date' ;
    rdfs:comment 'Expiration date of the current master supply agreement or contract with this vendor. Used for contract renewal planning and vendor relationship management.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ediIdentifier rdf:type rdf:Property ;
    rdfs:label 'Edi Identifier' ;
    rdfs:comment 'Unique EDI identifier or interchange ID used to route electronic documents to this vendor in EDI transactions (e.g., ISA ID, GS1 GLN).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillRatePct rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Pct' ;
    rdfs:comment 'Vendor performance metric representing the percentage of ordered quantity that the vendor successfully delivers (order completion percentage). A fill rate of 100% indicates all ordered items were delivered in full.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Expiry Date' ;
    rdfs:comment 'Expiration date of the vendor\'s general liability and product liability insurance certificate. Used to ensure vendors maintain required insurance coverage as per contract terms.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPurchaseOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Order Date' ;
    rdfs:comment 'Date of the most recent purchase order issued to this vendor. Used to identify inactive vendors and support vendor rationalization initiatives.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onTimeDeliveryRatePct rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate Pct' ;
    rdfs:comment 'Vendor performance metric representing the percentage of orders delivered on or before the requested delivery date. Used in vendor scorecards and supplier performance management.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date when the vendor was officially onboarded and approved for transactions in the vendor master system. Represents the start of the vendor relationship.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityAcceptanceRatePct rdf:type rdf:Property ;
    rdfs:label 'Quality Acceptance Rate Pct' ;
    rdfs:comment 'Vendor performance metric representing the percentage of received goods that pass quality inspection and are accepted into inventory without rejection or return. Used to monitor product quality and vendor compliance.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceEmail rdf:type rdf:Property ;
    rdfs:label 'Remittance Email' ;
    rdfs:comment 'Email address for sending payment remittance advice and electronic payment notifications to the vendor\'s accounts receivable department.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Classification' ;
    rdfs:comment 'Tax classification of the vendor for withholding and reporting purposes. W-9 US person indicates a domestic US entity, W-8 foreign entity indicates a non-US entity subject to withholding, exempt organization indicates tax-exempt status, and government entity indicates a governmental body.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'The full legal name of the vendor or supplier as registered with governing authorities. Used for contracts, purchase orders, and legal documentation.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Status' ;
    rdfs:comment 'Current operational status of the vendor in the vendor lifecycle. Active vendors are approved for transactions, inactive vendors are not currently used but remain in the system, suspended vendors are temporarily blocked due to performance or compliance issues, pending approval vendors are undergoing onboarding qualification, blocked vendors cannot transact due to critical issues, and terminated vendors have ended their relationship with the business.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorType rdf:type rdf:Property ;
    rdfs:label 'Vendor Type' ;
    rdfs:comment 'Classification of the vendor based on the type of goods or services provided. National brand manufacturers supply branded products, private label producers manufacture store-brand products, DSD (Direct Store Delivery) vendors deliver directly to stores bypassing distribution centers, 3PL (Third-Party Logistics) partners provide logistics and fulfillment services, service providers offer non-product services, and raw material suppliers provide ingredients or components for private label manufacturing.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorAddressId rdf:type rdf:Property ;
    rdfs:label 'Vendor Address Id' ;
    rdfs:comment 'Unique identifier for the vendor address record. Primary key.' ;
    rdfs:domain ind:VendorAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressLine3 rdf:type rdf:Property ;
    rdfs:label 'Address Line 3' ;
    rdfs:comment 'Tertiary address line for complex addresses requiring additional location specification. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:VendorAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressName rdf:type rdf:Property ;
    rdfs:label 'Address Name' ;
    rdfs:comment 'Descriptive name or label for the address location (e.g., \'Main Distribution Center\', \'Corporate HQ\', \'Returns Processing Facility\').' ;
    rdfs:domain ind:VendorAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for the address location, used for EDI transmission or document exchange with vendors. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDsdLocation rdf:type rdf:Property ;
    rdfs:label 'Is Dsd Location' ;
    rdfs:comment 'Flag indicating whether this address is a DSD (Direct Store Delivery) origin location where vendors deliver directly to retail stores bypassing distribution centers. True if DSD location, False otherwise.' ;
    rdfs:domain ind:VendorAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryAddress rdf:type rdf:Property ;
    rdfs:label 'Is Primary Address' ;
    rdfs:comment 'Flag indicating whether this is the primary or default address for the vendor. True if primary, False otherwise.' ;
    rdfs:domain ind:VendorAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRemittanceAddress rdf:type rdf:Property ;
    rdfs:label 'Is Remittance Address' ;
    rdfs:comment 'Flag indicating whether this address is used for payment remittance and accounts payable processing. True if remittance address, False otherwise.' ;
    rdfs:domain ind:VendorAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRtvAddress rdf:type rdf:Property ;
    rdfs:label 'Is Rtv Address' ;
    rdfs:comment 'Flag indicating whether this address is designated for RTV (Return to Vendor) processing and merchandise returns. True if RTV address, False otherwise. Critical for reverse logistics and vendor compliance.' ;
    rdfs:domain ind:VendorAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationSource rdf:type rdf:Property ;
    rdfs:label 'Validation Source' ;
    rdfs:comment 'Name of the service or system used to validate the address (e.g., USPS Address Validation API, Canada Post AddressComplete, UPS Address Validation, manual verification).' ;
    rdfs:domain ind:VendorAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accruedAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Amount' ;
    rdfs:comment 'Total monetary value of allowances earned but not yet settled or paid by the vendor.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allowanceDescription rdf:type rdf:Property ;
    rdfs:label 'Allowance Description' ;
    rdfs:comment 'Detailed narrative description of the allowance terms, purpose, and business rationale.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowanceNumber rdf:type rdf:Property ;
    rdfs:label 'Allowance Number' ;
    rdfs:comment 'Business identifier or agreement number for the vendor allowance as referenced in contracts and supplier communications.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowancePercentage rdf:type rdf:Property ;
    rdfs:label 'Allowance Percentage' ;
    rdfs:comment 'Percentage rate applied to qualifying purchase volume or sales to calculate the allowance value.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allowanceStatus rdf:type rdf:Property ;
    rdfs:label 'Allowance Status' ;
    rdfs:comment 'Current lifecycle status of the vendor allowance agreement.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastClaimDate rdf:type rdf:Property ;
    rdfs:label 'Last Claim Date' ;
    rdfs:comment 'Most recent date when an allowance claim was submitted to the vendor.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Last Settlement Date' ;
    rdfs:comment 'Most recent date when the vendor made a payment or credit against the allowance.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingCondition rdf:type rdf:Property ;
    rdfs:label 'Qualifying Condition' ;
    rdfs:comment 'Business rules and criteria that must be met to earn or claim the allowance, such as minimum order quantity (MOQ), purchase volume thresholds, promotional participation, or compliance requirements.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionEndDate rdf:type rdf:Property ;
    rdfs:label 'Redemption End Date' ;
    rdfs:comment 'Final date by which accrued allowances must be claimed or they expire.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:redemptionStartDate rdf:type rdf:Property ;
    rdfs:label 'Redemption Start Date' ;
    rdfs:comment 'Earliest date when accrued allowances can be claimed or redeemed from the vendor.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Current state of financial settlement for the allowance: pending claim, partially paid, fully paid, under dispute, or written off.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuList rdf:type rdf:Property ;
    rdfs:label 'Sku List' ;
    rdfs:comment 'Comma-separated or structured list of specific SKUs (Stock Keeping Units) eligible for the allowance, if restricted to specific items.' ;
    rdfs:domain ind:VendorAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCertificationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Certification Id' ;
    rdfs:comment 'Unique identifier for the vendor certification record. Primary key.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceLevel rdf:type rdf:Property ;
    rdfs:label 'Compliance Level' ;
    rdfs:comment 'The level of compliance achieved by the vendor for this certification, indicating whether all requirements are met or if there are outstanding conditions.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalNonConformanceCount rdf:type rdf:Property ;
    rdfs:label 'Critical Non Conformance Count' ;
    rdfs:comment 'The number of critical non-conformances identified during the most recent audit that require immediate corrective action.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Document Reference Number' ;
    rdfs:comment 'The internal or external reference number for the certification document stored in the document management system or vendor portal.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityLocationCovered rdf:type rdf:Property ;
    rdfs:label 'Facility Location Covered' ;
    rdfs:comment 'The specific vendor facility, manufacturing plant, or distribution center (DC) location covered by this certification.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this certification is mandatory for the vendor to do business with the retailer. True if required, False if optional or preferred.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRenewable rdf:type rdf:Property ;
    rdfs:label 'Is Renewable' ;
    rdfs:comment 'Indicates whether the certification is renewable. True if the certification can be renewed upon expiration, False if it is a one-time certification.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonConformanceCount rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Count' ;
    rdfs:comment 'The number of non-conformances or deficiencies identified during the most recent audit.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productCategoryCovered rdf:type rdf:Property ;
    rdfs:label 'Product Category Covered' ;
    rdfs:comment 'The product categories or SKU (Stock Keeping Unit) groups that are covered under this certification (e.g., fresh produce, dairy, electronics).' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNotificationDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Days' ;
    rdfs:comment 'The number of days before expiration that the system should trigger a renewal notification to the vendor and procurement team.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isEscalationContact rdf:type rdf:Property ;
    rdfs:label 'Is Escalation Contact' ;
    rdfs:comment 'Indicates whether this contact should be included in escalation workflows for critical issues such as compliance violations, quality failures, or delivery delays.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is the primary point of contact for the vendor. Used for default routing of communications and escalations.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'The official job title or position of the contact within the vendor organization (e.g., Account Manager, Supply Chain Director, Compliance Officer).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeLocation rdf:type rdf:Property ;
    rdfs:label 'Office Location' ;
    rdfs:comment 'The physical office location or site where this contact is based (e.g., headquarters, regional office, manufacturing plant).' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s preferred method for receiving business communications. Supports personalized engagement and improved response rates.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryAssociateId rdf:type rdf:Property ;
    rdfs:label 'Signatory Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Contract management requires tracking which retail associate has signing authority for legal compliance, delegation of authority verification, and audit trails. Replaces denormalized signatory_name/ti' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:chargebackTerms rdf:type rdf:Property ;
    rdfs:label 'Chargeback Terms' ;
    rdfs:comment 'Description of vendor compliance penalties and chargeback conditions. Defines scenarios where the buyer may deduct fees from vendor payments for non-compliance (late delivery, incorrect labeling, missing ASN, pallet configuration errors).' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationsRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications Required' ;
    rdfs:comment 'List of regulatory and industry certifications the vendor must maintain to fulfill this contract. Examples include FDA registration for food suppliers, CPSC compliance for consumer products, organic certifications, fair trade certifications, and safety standards.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Contract Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the contract value and payment terms. All financial terms in this contract are denominated in this currency.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'Uniform Resource Locator pointing to the digitally stored contract document. Links to the document management system or secure file repository where the full contract PDF or scanned image is stored.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the vendor contract. National brand contracts cover branded merchandise from manufacturers. Private label contracts govern store-brand product manufacturing. DSD (Direct Store Delivery) contracts define vendor-managed delivery terms. Master service agreements cover ongoing services. Blanket orders establish terms for recurring purchases. Framework agreements set umbrella terms for multiple purchase orders.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValueAmount rdf:type rdf:Property ;
    rdfs:label 'Contract Value Amount' ;
    rdfs:comment 'Total monetary value committed under this vendor contract. Represents the aggregate purchase commitment or spending cap over the contract term. Used for budget planning and vendor performance tracking.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediQualifier rdf:type rdf:Property ;
    rdfs:label 'Edi Qualifier' ;
    rdfs:comment 'EDI interchange identifier qualifier for the vendor. Examples include 01 (DUNS number), 12 (phone number), 14 (UPC), ZZ (mutually defined). Used to route EDI messages to the correct vendor system.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether this contract grants the vendor exclusive rights to supply specific products or categories. True if the buyer commits to purchasing exclusively from this vendor for the covered scope. False for non-exclusive agreements.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Description of the product categories, geographic regions, or channels covered by the exclusivity clause. Applicable only when exclusivity_flag is true. Defines the boundaries of the exclusive supply arrangement.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International Commercial Terms code defining the division of costs and risks between buyer and seller. EXW (Ex Works) - buyer collects from vendor premises. FOB (Free On Board) - vendor delivers to shipping vessel. DDP (Delivered Duty Paid) - vendor delivers to buyer location with all duties paid. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirements rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirements' ;
    rdfs:comment 'Minimum insurance coverage the vendor must carry to fulfill this contract. Typically includes general liability, product liability, and cargo insurance with specified coverage limits.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAssuranceTerms rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Terms' ;
    rdfs:comment 'Quality standards and inspection requirements for goods supplied under this contract. Defines acceptable quality levels, sampling procedures, defect rates, and vendor quality certifications required.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingLocationCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Location Code' ;
    rdfs:comment 'Buyer distribution center, warehouse, or store location designated to receive shipments under this contract. Used for routing purchase orders and coordinating inbound logistics.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Duration in months for each automatic renewal period. Applicable only when auto_renewal_flag is true. Contract extends by this duration at each renewal.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnToVendorPolicy rdf:type rdf:Property ;
    rdfs:label 'Return To Vendor Policy' ;
    rdfs:comment 'Terms governing the return of defective, damaged, or unsold merchandise to the vendor. Defines RTV authorization process, restocking fees, return shipping responsibility, and credit issuance timeline.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingPoint rdf:type rdf:Property ;
    rdfs:label 'Shipping Point' ;
    rdfs:comment 'Vendor facility or distribution center from which goods are shipped under this contract. Used for logistics planning, freight cost calculation, and delivery time estimation.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'Date when the contract was signed by the authorized buyer representative. Used for contract validity verification and audit trail.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Vendor Signatory Name' ;
    rdfs:comment 'Full name of the authorized representative who signed the contract on behalf of the vendor organization. Used for contract validation and audit trail.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Vendor Signatory Title' ;
    rdfs:comment 'Job title or role of the vendor authorized signatory. Examples include CEO, VP Sales, Director of Business Development. Used to verify vendor signing authority.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Signature Date' ;
    rdfs:comment 'Date when the contract was signed by the authorized vendor representative. Used for contract validity verification and audit trail.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorDisputeId rdf:type rdf:Property ;
    rdfs:label 'Vendor Dispute Id' ;
    rdfs:comment 'Unique identifier for the vendor dispute record. Primary key.' ;
    rdfs:domain ind:VendorDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agingDays rdf:type rdf:Property ;
    rdfs:label 'Aging Days' ;
    rdfs:comment 'Number of days the dispute has been open since submission date. Used for tracking dispute resolution performance and identifying overdue disputes.' ;
    rdfs:domain ind:VendorDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Credit Amount' ;
    rdfs:comment 'Monetary amount approved for credit or refund to the vendor as a result of the dispute resolution. May be equal to, less than, or zero relative to the disputed amount depending on the resolution decision.' ;
    rdfs:domain ind:VendorDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditIssueDate rdf:type rdf:Property ;
    rdfs:label 'Credit Issue Date' ;
    rdfs:comment 'Date when the approved credit was formally issued to the vendor in the accounts payable system.' ;
    rdfs:domain ind:VendorDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeCategory rdf:type rdf:Property ;
    rdfs:label 'Dispute Category' ;
    rdfs:comment 'High-level business category for grouping and reporting disputes (e.g., Financial, Operational, Quality, Compliance). Used for analytics and trend analysis.' ;
    rdfs:domain ind:VendorDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeClosureDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Closure Date' ;
    rdfs:comment 'Date when the dispute was formally closed and no further action is required. Represents the end of the dispute lifecycle.' ;
    rdfs:domain ind:VendorDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'Business-facing unique dispute reference number used for tracking and communication with vendors.' ;
    rdfs:domain ind:VendorDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeSubmissionChannel rdf:type rdf:Property ;
    rdfs:label 'Dispute Submission Channel' ;
    rdfs:comment 'Channel through which the vendor submitted the dispute (vendor portal, email, EDI message, phone call, physical mail).' ;
    rdfs:domain ind:VendorDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Submission Date' ;
    rdfs:comment 'Date when the vendor formally submitted the dispute to the retailer for review.' ;
    rdfs:domain ind:VendorDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Category of dispute raised by the vendor. Chargeback disputes contest vendor compliance penalties; invoice deduction disputes contest unauthorized deductions; short payment disputes contest partial payments; compliance penalty disputes contest fines for non-compliance; pricing discrepancy disputes contest incorrect pricing applied; quantity discrepancy disputes contest received quantity variances.' ;
    rdfs:domain ind:VendorDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Date' ;
    rdfs:comment 'Date when the original disputed transaction occurred (e.g., invoice date, chargeback date, payment date).' ;
    rdfs:domain ind:VendorDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Reference' ;
    rdfs:comment 'Reference number or identifier of the original business transaction that is the subject of the dispute (e.g., invoice number, purchase order number, chargeback reference, payment reference).' ;
    rdfs:domain ind:VendorDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDecision rdf:type rdf:Property ;
    rdfs:label 'Resolution Decision' ;
    rdfs:comment 'Final decision made by the internal reviewer regarding the dispute. Approved indicates full acceptance of vendor claim; rejected indicates denial of vendor claim; partially approved indicates acceptance of a portion of the claim.' ;
    rdfs:domain ind:VendorDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'Date when the internal review of the dispute was completed and a resolution decision was made.' ;
    rdfs:domain ind:VendorDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Start Date' ;
    rdfs:comment 'Date when internal review of the dispute officially began.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaResolutionDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Due Date' ;
    rdfs:comment 'Target date by which the dispute should be fully resolved according to internal service level agreements or vendor contract terms.' ;
    rdfs:domain ind:VendorDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Response Due Date' ;
    rdfs:comment 'Target date by which the retailer is contractually or operationally committed to provide an initial response to the vendor regarding the dispute, based on service level agreements.' ;
    rdfs:domain ind:VendorDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportingDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Reference' ;
    rdfs:comment 'Reference identifier or file path to supporting documentation provided by the vendor (e.g., proof of delivery, corrected invoices, shipping manifests, quality certificates). May contain multiple document references separated by delimiters.' ;
    rdfs:domain ind:VendorDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Cost Effective Date' ;
    rdfs:comment 'The date from which the current unit cost is effective. Used for cost change tracking and historical cost analysis.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Cost Expiration Date' ;
    rdfs:comment 'The date through which the current unit cost remains valid. Null indicates open-ended pricing.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dsdEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Eligible Flag' ;
    rdfs:comment 'Indicates whether this item can be delivered directly to stores by the vendor, bypassing the DC (Distribution Center). Common for beverages, bread, and snacks.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCostChangeDate rdf:type rdf:Property ;
    rdfs:label 'Last Cost Change Date' ;
    rdfs:comment 'The date when the unit cost was last modified. Used for cost trend analysis and vendor negotiation tracking.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:palletHi rdf:type rdf:Property ;
    rdfs:label 'Pallet Hi' ;
    rdfs:comment 'Number of layers (tiers) stacked on a pallet. Part of the TI/HI pallet configuration used in warehouse and DC operations.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:palletTi rdf:type rdf:Property ;
    rdfs:label 'Pallet Ti' ;
    rdfs:comment 'Number of cases per layer on a pallet. Part of the TI/HI pallet configuration used in warehouse and DC (Distribution Center) operations.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Indicates whether this vendor is the preferred source for this item when multiple vendors supply the same product. Used in automated sourcing decisions.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorItemCategory rdf:type rdf:Property ;
    rdfs:label 'Vendor Item Category' ;
    rdfs:comment 'The vendor\'s product category classification for this item. May differ from internal merchandising hierarchy.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorItemDescription rdf:type rdf:Property ;
    rdfs:label 'Vendor Item Description' ;
    rdfs:comment 'The vendor\'s description of the item as it appears in their catalog. May differ from internal product description.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorItemStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Item Status' ;
    rdfs:comment 'Current lifecycle status of this vendor-item relationship. Active items are available for ordering; discontinued items are being phased out.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPackConfiguration rdf:type rdf:Property ;
    rdfs:label 'Vendor Pack Configuration' ;
    rdfs:comment 'Description of how the vendor packages this item (e.g., case pack, master carton, pallet). Defines the vendor\'s standard shipping unit.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorScorecardId rdf:type rdf:Property ;
    rdfs:label 'Vendor Scorecard Id' ;
    rdfs:comment 'Unique identifier for the vendor scorecard record. Primary key. Role: TRANSACTION_HEADER (scorecard is a periodic performance evaluation event).' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluatorAssociateId rdf:type rdf:Property ;
    rdfs:label 'Evaluator Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Vendor performance evaluation in retail requires tracking which associate conducted the scorecard assessment for accountability, bias detection, and evaluator performance analysis. Replaces denormaliz' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:chargebackCount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Count' ;
    rdfs:comment 'Total number of chargebacks (vendor compliance penalties) issued to the vendor during the scoring period for violations such as late delivery, incorrect labeling, or packaging non-compliance.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compositeScore rdf:type rdf:Property ;
    rdfs:label 'Composite Score' ;
    rdfs:comment 'Weighted overall vendor performance score calculated from individual KPI values (on-time delivery, fill rate, quality, etc.). Scale typically 0-100. Used for vendor tier classification.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Edi Compliance Rate' ;
    rdfs:comment 'Percentage of transactions (purchase orders, ASNs, invoices) successfully transmitted via EDI without errors or manual intervention during the scoring period.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Date' ;
    rdfs:comment 'Date when the scorecard was completed and finalized by the evaluator.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fillRate rdf:type rdf:Property ;
    rdfs:label 'Fill Rate' ;
    rdfs:comment 'Percentage of ordered quantity that was fulfilled by the vendor during the scoring period. Measures vendor ability to meet demand without stockouts.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Invoice Accuracy Rate' ;
    rdfs:comment 'Percentage of invoices submitted without pricing, quantity, or calculation errors during the scoring period. Measures vendor billing quality.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimeAdherenceRate rdf:type rdf:Property ;
    rdfs:label 'Lead Time Adherence Rate' ;
    rdfs:comment 'Percentage of orders where the vendor met the agreed lead time from order placement to delivery during the scoring period.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderQuantityComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity Compliance Rate' ;
    rdfs:comment 'Percentage of orders where the vendor honored MOQ agreements without imposing additional fees or rejecting orders during the scoring period.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeDeliveryRate rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate' ;
    rdfs:comment 'Percentage of purchase orders or shipments delivered on or before the promised delivery date during the scoring period. Key KPI for vendor reliability.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodCompositeScore rdf:type rdf:Property ;
    rdfs:label 'Prior Period Composite Score' ;
    rdfs:comment 'Composite score from the previous scoring period, used to calculate trend and performance improvement or decline.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productQualityScore rdf:type rdf:Property ;
    rdfs:label 'Product Quality Score' ;
    rdfs:comment 'Composite quality score based on defect rates, customer returns, and quality inspection results for products supplied by the vendor during the scoring period. Scale typically 0-100.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnToVendorAmount rdf:type rdf:Property ;
    rdfs:label 'Return To Vendor Amount' ;
    rdfs:comment 'Total monetary value of goods returned to the vendor during the scoring period, typically in USD.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnToVendorCount rdf:type rdf:Property ;
    rdfs:label 'Return To Vendor Count' ;
    rdfs:comment 'Total number of RTV transactions initiated during the scoring period due to defects, overstock, or non-compliance.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scoreTrend rdf:type rdf:Property ;
    rdfs:label 'Score Trend' ;
    rdfs:comment 'Directional trend of vendor performance compared to the prior period (improving, stable, or declining).' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardNumber rdf:type rdf:Property ;
    rdfs:label 'Scorecard Number' ;
    rdfs:comment 'Business identifier for the scorecard, typically formatted as SC-YYYYMMDD or similar pattern for external reference and reporting.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardStatus rdf:type rdf:Property ;
    rdfs:label 'Scorecard Status' ;
    rdfs:comment 'Current lifecycle status of the scorecard indicating whether it is in draft, published for vendor review, under internal review, finalized, or archived.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoringPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Scoring Period End Date' ;
    rdfs:comment 'The end date of the evaluation period covered by this scorecard (e.g., end of quarter or month).' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scoringPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Scoring Period Start Date' ;
    rdfs:comment 'The start date of the evaluation period covered by this scorecard (e.g., beginning of quarter or month).' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalPurchaseOrderCount rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Order Count' ;
    rdfs:comment 'Total number of purchase orders issued to the vendor during the scoring period. Provides context for volume-based KPI interpretation.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPurchaseOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Order Value' ;
    rdfs:comment 'Total monetary value of purchase orders issued to the vendor during the scoring period, typically in USD. Provides spend context for scorecard evaluation.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Notification Date' ;
    rdfs:comment 'Date when the scorecard was shared with the vendor for review and discussion.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorTier rdf:type rdf:Property ;
    rdfs:label 'Vendor Tier' ;
    rdfs:comment 'Classification tier assigned to the vendor based on the composite score and strategic importance. Preferred vendors receive priority, probation vendors face restrictions, suspended vendors are blocked from new orders.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiConfigId rdf:type rdf:Property ;
    rdfs:label 'Vmi Config Id' ;
    rdfs:comment 'Unique identifier for the VMI configuration record. Primary key.' ;
    rdfs:domain ind:VmiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoReplenishmentEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Replenishment Enabled' ;
    rdfs:comment 'Indicates whether the vendor is authorized to automatically generate and fulfill replenishment orders without retailer approval.' ;
    rdfs:domain ind:VmiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:configName rdf:type rdf:Property ;
    rdfs:label 'Config Name' ;
    rdfs:comment 'Business-friendly name or label for this VMI configuration for identification and reporting purposes.' ;
    rdfs:domain ind:VmiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configNotes rdf:type rdf:Property ;
    rdfs:label 'Config Notes' ;
    rdfs:comment 'Free-text notes capturing special instructions, exceptions, or business context for this VMI configuration.' ;
    rdfs:domain ind:VmiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configStatus rdf:type rdf:Property ;
    rdfs:label 'Config Status' ;
    rdfs:comment 'Current lifecycle status of the VMI configuration indicating whether it is operational.' ;
    rdfs:domain ind:VmiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Consignment Flag' ;
    rdfs:comment 'Indicates whether this VMI arrangement operates under a consignment model where the vendor retains ownership until sale or consumption.' ;
    rdfs:domain ind:VmiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingFrequency rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Frequency' ;
    rdfs:comment 'The frequency at which inventory position and consumption data is shared with the vendor.' ;
    rdfs:domain ind:VmiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excessInventoryPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Excess Inventory Penalty Amount' ;
    rdfs:comment 'The financial penalty amount charged to the vendor for maintaining inventory levels above the maximum threshold.' ;
    rdfs:domain ind:VmiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReplenishmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Replenishment Date' ;
    rdfs:comment 'The date on which the vendor last executed a replenishment order under this VMI configuration.' ;
    rdfs:domain ind:VmiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxInventoryThreshold rdf:type rdf:Property ;
    rdfs:label 'Max Inventory Threshold' ;
    rdfs:comment 'The maximum stock level that the vendor should maintain at the location.' ;
    rdfs:domain ind:VmiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minInventoryThreshold rdf:type rdf:Property ;
    rdfs:label 'Min Inventory Threshold' ;
    rdfs:comment 'The minimum stock level that triggers a replenishment action by the vendor.' ;
    rdfs:domain ind:VmiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownershipTransferPoint rdf:type rdf:Property ;
    rdfs:label 'Ownership Transfer Point' ;
    rdfs:comment 'The point in the supply chain at which inventory ownership transfers from the vendor to the retailer.' ;
    rdfs:domain ind:VmiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'The inventory level at which the vendor initiates a replenishment order.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentModel rdf:type rdf:Property ;
    rdfs:label 'Replenishment Model' ;
    rdfs:comment 'The inventory replenishment strategy used by the vendor under this VMI configuration.' ;
    rdfs:domain ind:VmiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFormat rdf:type rdf:Property ;
    rdfs:label 'Reporting Format' ;
    rdfs:comment 'The technical format used for sharing inventory and consumption reports with the vendor.' ;
    rdfs:domain ind:VmiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Level' ;
    rdfs:comment 'The buffer inventory quantity maintained to protect against stockouts due to demand variability or supply delays.' ;
    rdfs:domain ind:VmiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockoutPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Stockout Penalty Amount' ;
    rdfs:comment 'The financial penalty amount charged to the vendor for each stockout incident under this VMI configuration.' ;
    rdfs:domain ind:VmiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetInventoryLevel rdf:type rdf:Property ;
    rdfs:label 'Target Inventory Level' ;
    rdfs:comment 'The optimal stock level that the vendor aims to maintain under normal operating conditions.' ;
    rdfs:domain ind:VmiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit Of Measure' ;
    rdfs:comment 'The unit of measure for all inventory threshold quantities (min, max, target, safety stock, reorder point). [ENUM-REF-CANDIDATE: EA|CS|PL|LB|KG|GAL|LTR — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VmiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Vendor Access Level' ;
    rdfs:comment 'The level of system access granted to the vendor for inventory visibility and replenishment management.' ;
    rdfs:domain ind:VmiConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossDockPlanId rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Plan Id' ;
    rdfs:comment 'Unique system-generated identifier for the cross-dock execution plan record. Primary key for this entity.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrossDockPlan .

ind:inboundAsnId rdf:type rdf:Property ;
    rdfs:label 'Inbound Asn Id' ;
    rdfs:comment 'Identifier of the inbound Advance Shipment Notice (ASN) from the supplier, confirming the shipment details and expected arrival of merchandise to be cross-docked.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asn .

ind:merchandiseCategoryId rdf:type rdf:Property ;
    rdfs:label 'Merchandise Category Id' ;
    rdfs:comment 'Identifier of the merchandise category (e.g., grocery, apparel, electronics) to which the cross-docked SKU belongs. Used for category-level cross-dock performance reporting and assortment planning alignment.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:outboundCarrierId rdf:type rdf:Property ;
    rdfs:label 'Outbound Carrier Id' ;
    rdfs:comment 'Identifier of the transportation carrier or Third-Party Logistics (3PL) provider responsible for delivering cross-docked merchandise from the DC to the destination store.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:plannerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Planner Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Cross-dock planners create plans for planning accountability and performance tracking. Supply chain tracks plan accuracy, dwell time, and execution success by planner for operational efficiency and KP' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:actualCartonQty rdf:type rdf:Property ;
    rdfs:label 'Actual Carton Qty' ;
    rdfs:comment 'The actual number of cartons processed through the cross-dock operation. Used to reconcile against planned carton count and measure DC handling accuracy.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualInboundDate rdf:type rdf:Property ;
    rdfs:label 'Actual Inbound Date' ;
    rdfs:comment 'The actual date on which inbound merchandise arrived at the Distribution Center (DC). Compared against planned inbound date to measure supplier on-time delivery performance.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualInboundTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Inbound Timestamp' ;
    rdfs:comment 'The precise date and time when inbound merchandise was received at the DC dock door. Used for dwell time calculation and cross-dock cycle time analytics.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualOutboundDate rdf:type rdf:Property ;
    rdfs:label 'Actual Outbound Date' ;
    rdfs:comment 'The actual date on which cross-docked merchandise departed the Distribution Center (DC) for the destination store. Used to measure DC throughput speed and cross-dock execution efficiency.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualOutboundTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Outbound Timestamp' ;
    rdfs:comment 'The precise date and time when cross-docked merchandise departed the DC on the outbound carrier. Used to calculate total DC dwell time and cross-dock cycle time.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualReceivedUnitQty rdf:type rdf:Property ;
    rdfs:label 'Actual Received Unit Qty' ;
    rdfs:comment 'The actual number of units received from the supplier at the DC inbound dock. Compared against planned quantity to identify short shipments, overages, or discrepancies.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualShippedUnitQty rdf:type rdf:Property ;
    rdfs:label 'Actual Shipped Unit Qty' ;
    rdfs:comment 'The actual number of units shipped outbound to the destination store after cross-docking. May differ from received quantity due to damage, quality holds, or allocation adjustments.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crossDockType rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Type' ;
    rdfs:comment 'Classification of the cross-docking method. Pre-allocated means merchandise is pre-sorted for specific stores before arrival; opportunistic (flow-through) means merchandise is sorted upon arrival based on real-time demand signals. [ENUM-REF-CANDIDATE: pre_allocated|opportunistic|flow_through|merge_in_transit|pool_distribution — promote to reference product]' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dwellTimeHours rdf:type rdf:Property ;
    rdfs:label 'Dwell Time Hours' ;
    rdfs:comment 'The total number of hours merchandise spent at the Distribution Center (DC) between inbound receipt and outbound shipment. A key cross-dock efficiency metric; target is typically under 24 hours for true cross-docking.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Handling Instructions' ;
    rdfs:comment 'Free-text operational instructions for DC associates handling the cross-dock merchandise, such as fragile handling, temperature requirements, sequencing rules, or special labeling requirements.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundDockDoor rdf:type rdf:Property ;
    rdfs:label 'Inbound Dock Door' ;
    rdfs:comment 'The assigned inbound dock door number or identifier at the Distribution Center where the supplier\'s truck will unload merchandise for cross-docking.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPromotionalMerchandise rdf:type rdf:Property ;
    rdfs:label 'Is Promotional Merchandise' ;
    rdfs:comment 'Indicates whether the merchandise in this cross-dock plan is associated with a promotional event. Promotional merchandise is a primary driver of cross-docking to accelerate store replenishment and reduce DC handling costs.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outboundDockDoor rdf:type rdf:Property ;
    rdfs:label 'Outbound Dock Door' ;
    rdfs:comment 'The assigned outbound dock door number or identifier at the Distribution Center from which cross-docked merchandise will be loaded onto the outbound carrier for store delivery.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundTrailerNumber rdf:type rdf:Property ;
    rdfs:label 'Outbound Trailer Number' ;
    rdfs:comment 'The trailer or container number assigned for the outbound shipment of cross-docked merchandise to the destination store. Used for load tracking and carrier coordination.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known business identifier for the cross-dock plan, used in operational communications between DC teams, suppliers, and store operations. Follows the format CDP-YYYY-NNNNNN.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCartonQty rdf:type rdf:Property ;
    rdfs:label 'Planned Carton Qty' ;
    rdfs:comment 'The planned number of cartons (cases) of the SKU scheduled for cross-docking. Used for dock door capacity planning, pallet build, and outbound trailer loading.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedInboundDate rdf:type rdf:Property ;
    rdfs:label 'Planned Inbound Date' ;
    rdfs:comment 'The planned date on which inbound merchandise from the supplier is expected to arrive at the Distribution Center (DC) for cross-docking. Used for dock scheduling and labor planning.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedInboundTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Inbound Timestamp' ;
    rdfs:comment 'The precise planned date and time for inbound merchandise arrival at the DC dock door. Used for granular dock door scheduling and labor allocation within the WMS.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedOutboundDate rdf:type rdf:Property ;
    rdfs:label 'Planned Outbound Date' ;
    rdfs:comment 'The planned date on which cross-docked merchandise is scheduled to depart the Distribution Center (DC) for the destination store. Drives outbound dock scheduling and carrier booking.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedPalletQty rdf:type rdf:Property ;
    rdfs:label 'Planned Pallet Qty' ;
    rdfs:comment 'The planned number of pallets expected for this cross-dock plan. Used for outbound trailer capacity planning and dock door assignment.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedUnitQty rdf:type rdf:Property ;
    rdfs:label 'Planned Unit Qty' ;
    rdfs:comment 'The planned number of individual units (eaches) of the SKU scheduled for cross-docking under this plan. Drives inbound receiving expectations and outbound load planning.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceUnitQty rdf:type rdf:Property ;
    rdfs:label 'Variance Unit Qty' ;
    rdfs:comment 'The difference between planned unit quantity and actual shipped unit quantity for this cross-dock plan. Positive values indicate a shortfall; negative values indicate an overage. Used for supplier compliance and chargeback management.' ;
    rdfs:domain ind:CrossDockPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crossdockTransactionId rdf:type rdf:Property ;
    rdfs:label 'Crossdock Transaction Id' ;
    rdfs:comment 'Unique identifier for the cross-dock transaction event. Primary key.' ;
    rdfs:domain ind:CrossdockTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cartonCount rdf:type rdf:Property ;
    rdfs:label 'Carton Count' ;
    rdfs:comment 'Number of cartons or cases included in this cross-dock transaction.' ;
    rdfs:domain ind:CrossdockTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationDockDoor rdf:type rdf:Property ;
    rdfs:label 'Destination Dock Door' ;
    rdfs:comment 'Dock door number or identifier where the goods were staged for outbound shipment.' ;
    rdfs:domain ind:CrossdockTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dwellTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Dwell Time Minutes' ;
    rdfs:comment 'Total time in minutes that the goods spent in the cross-dock facility from inbound receipt to outbound staging, used to measure throughput efficiency.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inboundReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inbound Receipt Timestamp' ;
    rdfs:comment 'Date and time when the inbound shipment was received at the source dock door.' ;
    rdfs:domain ind:CrossdockTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isTemperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Is Temperature Controlled' ;
    rdfs:comment 'Indicates whether the cross-docked goods require temperature-controlled handling (e.g., refrigerated or frozen products).' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outboundStagingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Outbound Staging Timestamp' ;
    rdfs:comment 'Date and time when the goods were staged at the destination dock door for outbound shipment.' ;
    rdfs:domain ind:CrossdockTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorityFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Flag' ;
    rdfs:comment 'Indicates whether this cross-dock transaction was flagged as high-priority for expedited processing.' ;
    rdfs:domain ind:CrossdockTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityCrossDocked rdf:type rdf:Property ;
    rdfs:label 'Quantity Cross Docked' ;
    rdfs:comment 'Total quantity of units successfully transferred from inbound to outbound without entering reserve storage.' ;
    rdfs:domain ind:CrossdockTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceDockDoor rdf:type rdf:Property ;
    rdfs:label 'Source Dock Door' ;
    rdfs:comment 'Dock door number or identifier where the inbound shipment was received.' ;
    rdfs:domain ind:CrossdockTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sscc rdf:type rdf:Property ;
    rdfs:label 'Sscc' ;
    rdfs:comment 'Serial Shipping Container Code for the logistics unit being cross-docked, providing unique identification for tracking.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerNumber rdf:type rdf:Property ;
    rdfs:label 'Trailer Number' ;
    rdfs:comment 'Trailer or vehicle number assigned to the outbound shipment carrying the cross-docked goods.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transfer Timestamp' ;
    rdfs:comment 'Precise date and time when the goods were physically transferred from the inbound dock to the outbound staging area.' ;
    rdfs:domain ind:CrossdockTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bondedWarehouseFlag rdf:type rdf:Property ;
    rdfs:label 'Bonded Warehouse Flag' ;
    rdfs:comment 'Indicates whether the facility is a customs-bonded warehouse authorized to store imported goods before duties and taxes are paid, enabling deferred duty payment and re-export options.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Business-assigned unique alphanumeric code for the facility used in operational systems, shipping documents, and cross-system integration. Typically 4-12 characters.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Facility Email Address' ;
    rdfs:comment 'Primary email address for the facility used for operational communications, appointment confirmations, and document exchange.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityManagerName rdf:type rdf:Property ;
    rdfs:label 'Facility Manager Name' ;
    rdfs:comment 'Full name of the facility manager or site director responsible for day-to-day operations and performance.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Official business name of the distribution center or fulfillment facility (e.g., \'Northeast Regional DC\', \'Manhattan MFC-01\').' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Facility Phone Number' ;
    rdfs:comment 'Primary contact phone number for the facility used for carrier coordination, supplier communication, and operational inquiries.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityStatus rdf:type rdf:Property ;
    rdfs:label 'Facility Status' ;
    rdfs:comment 'Current operational lifecycle status of the facility. Active facilities are fully operational; planned facilities are approved but not yet built; under construction facilities are being built; decommissioned facilities are permanently closed; temporarily closed facilities are inactive but may reopen; seasonal facilities operate only during peak periods.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the facility based on its primary operational purpose: regional DC (large-scale distribution), micro-fulfillment center (MFC for rapid e-commerce), dark store (fulfillment-only, no retail), cross-dock hub (transshipment), returns center (reverse logistics), or forward stocking location (FSL).' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundDockDoorCount rdf:type rdf:Property ;
    rdfs:label 'Inbound Dock Door Count' ;
    rdfs:comment 'Number of dock doors dedicated to inbound receiving operations from suppliers and carriers.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiration Date' ;
    rdfs:comment 'Date when the current facility lease agreement expires. Null for owned facilities. Used for lease renewal planning and financial forecasting.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date when the facility first became operational and began processing inventory and orders.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outboundDockDoorCount rdf:type rdf:Property ;
    rdfs:label 'Outbound Dock Door Count' ;
    rdfs:comment 'Number of dock doors dedicated to outbound shipping operations to stores, customers, or other facilities.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:owningRegionCode rdf:type rdf:Property ;
    rdfs:label 'Owning Region Code' ;
    rdfs:comment 'Business region or geographic division code that owns and manages this facility (e.g., \'NORTHEAST\', \'WEST\', \'CENTRAL\'). Used for organizational hierarchy and P&L reporting.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'Two-letter ISO 3166-2 subdivision code for the state, province, or region (e.g., \'CA\' for California, \'ON\' for Ontario).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacityCubicFeet rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Cubic Feet' ;
    rdfs:comment 'Total volumetric storage capacity of the facility measured in cubic feet, accounting for vertical storage utilization.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCapacityPalletPositions rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Pallet Positions' ;
    rdfs:comment 'Maximum number of standard pallet positions available for inventory storage in racking and floor storage.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureZoneAmbientFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone Ambient Flag' ;
    rdfs:comment 'Indicates whether the facility has ambient temperature storage zones (room temperature, non-climate-controlled) for general merchandise.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureZoneChilledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone Chilled Flag' ;
    rdfs:comment 'Indicates whether the facility has refrigerated (chilled) storage zones typically maintained at 32-40°F for perishable goods like dairy and produce.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureZoneFrozenFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone Frozen Flag' ;
    rdfs:comment 'Indicates whether the facility has frozen storage zones typically maintained at 0°F or below for frozen foods and ice cream.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:twentyFourSevenOperationFlag rdf:type rdf:Property ;
    rdfs:label 'Twenty Four Seven Operation Flag' ;
    rdfs:comment 'Indicates whether the facility operates continuously 24 hours per day, 7 days per week to support high-volume or time-sensitive fulfillment requirements.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warehouseSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Warehouse Square Footage' ;
    rdfs:comment 'Square footage dedicated to warehouse operations including storage, picking, packing, and staging areas. Measured in square feet.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsInstanceCode rdf:type rdf:Property ;
    rdfs:label 'Wms Instance Code' ;
    rdfs:comment 'Identifier for the Manhattan WMS instance or system deployment that manages this facility\'s warehouse operations. Used for system integration and data routing.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineForecastUnits rdf:type rdf:Property ;
    rdfs:label 'Baseline Forecast Units' ;
    rdfs:comment 'The pure statistical baseline demand forecast in units before any adjustments for promotions, seasonality, or manual overrides. Provides the unadjusted demand signal for comparison against the final consensus forecast.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandCategory rdf:type rdf:Property ;
    rdfs:label 'Demand Category' ;
    rdfs:comment 'Classification of the SKU\'s demand pattern used to select the appropriate forecasting model. \'regular\' indicates stable, predictable demand; \'intermittent\' indicates sporadic demand (Croston model); \'lumpy\' indicates irregular high-volume spikes; \'new_item\' indicates insufficient history; \'end_of_life\' indicates declining/discontinuing SKU.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastBias rdf:type rdf:Property ;
    rdfs:label 'Forecast Bias' ;
    rdfs:comment 'The systematic directional error in the forecast, calculated as the mean of (forecasted units minus actual units) over a rolling period. Positive values indicate over-forecasting (excess inventory risk); negative values indicate under-forecasting (stockout risk). Critical for replenishment safety stock calibration.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastHorizonWeeks rdf:type rdf:Property ;
    rdfs:label 'Forecast Horizon Weeks' ;
    rdfs:comment 'The total number of weeks into the future covered by this forecast run, measured from the forecast generation date. Determines the planning horizon for replenishment, Open-to-Buy (OTB), and supply chain optimization.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastLowerBoundUnits rdf:type rdf:Property ;
    rdfs:label 'Forecast Lower Bound Units' ;
    rdfs:comment 'The lower bound of the forecast confidence interval in units at the specified confidence level. Represents the low-demand scenario used for minimum order quantity (MOQ) planning and markdown risk assessment.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Period End Date' ;
    rdfs:comment 'The last calendar date of the forecast horizon period covered by this record. Together with forecast_period_start_date, defines the time bucket granularity (daily, weekly, monthly).' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Period Start Date' ;
    rdfs:comment 'The first calendar date of the forecast horizon period covered by this record. Defines the beginning of the time bucket (day, week, or month) for which demand is forecasted.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastRunNumber rdf:type rdf:Property ;
    rdfs:label 'Forecast Run Number' ;
    rdfs:comment 'Identifier for the specific Blue Yonder Demand Planning batch run that generated this forecast record. Enables traceability back to the originating planning cycle and supports audit of forecast lineage.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastType rdf:type rdf:Property ;
    rdfs:label 'Forecast Type' ;
    rdfs:comment 'Classification of the demand forecast by its planning purpose. \'baseline\' is the statistical base demand without uplift; \'promotional\' incorporates promotion lift; \'seasonal\' reflects seasonal index adjustments; \'event_driven\' accounts for specific demand events; \'consensus\' is the final agreed forecast used for replenishment and Open-to-Buy (OTB) planning.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastUpperBoundUnits rdf:type rdf:Property ;
    rdfs:label 'Forecast Upper Bound Units' ;
    rdfs:comment 'The upper bound of the forecast confidence interval in units at the specified confidence level. Represents the high-demand scenario used for safety stock and maximum inventory planning to prevent stockouts.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastVersion rdf:type rdf:Property ;
    rdfs:label 'Forecast Version' ;
    rdfs:comment 'An incrementing integer version number for the forecast record for a given SKU-location-period combination. Enables tracking of forecast revisions across planning cycles and supports comparison of forecast evolution over time.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastedRevenue rdf:type rdf:Property ;
    rdfs:label 'Forecasted Revenue' ;
    rdfs:comment 'The projected revenue in the operating currency derived from the forecasted units multiplied by the expected selling price for the forecast period. Used in financial planning, Open-to-Buy (OTB) budgeting, and Gross Margin Return on Investment (GMROI) analysis.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedUnits rdf:type rdf:Property ;
    rdfs:label 'Forecasted Units' ;
    rdfs:comment 'The statistical model\'s predicted demand quantity in sellable units for the SKU at the specified location during the forecast period. This is the primary quantitative output of the demand planning engine and drives replenishment order quantities.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLatestVersion rdf:type rdf:Property ;
    rdfs:label 'Is Latest Version' ;
    rdfs:comment 'Indicates whether this forecast record is the most current version for the given SKU-location-period combination. True means this record is the active forecast used for replenishment and OTB planning; False means it has been superseded by a newer forecast run.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverrideApplied rdf:type rdf:Property ;
    rdfs:label 'Is Override Applied' ;
    rdfs:comment 'Indicates whether a demand planner has manually overridden the statistical forecast for this record. True means the final forecasted_units reflect a planner adjustment; False means the forecast is purely statistical. Critical for measuring forecast bias introduced by manual intervention.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPromotionalPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Promotional Period' ;
    rdfs:comment 'Indicates whether the forecast period overlaps with an active promotional event. When True, the promotional_lift_units field is expected to be populated and the forecast incorporates promotion-driven demand uplift.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mape rdf:type rdf:Property ;
    rdfs:label 'Mape' ;
    rdfs:comment 'Mean Absolute Percentage Error (MAPE) measuring the accuracy of the statistical forecast against actual sales for the equivalent prior period. Expressed as a decimal (e.g., 0.12 = 12% error). Lower values indicate higher forecast accuracy. Used as the primary KPI for demand planning performance.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otbImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Otb Impact Flag' ;
    rdfs:comment 'Indicates whether this forecast record has been incorporated into the Open-to-Buy (OTB) financial plan. When True, the forecasted revenue and units are reflected in the merchandise financial plan and buying budget for the relevant period.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReasonCode rdf:type rdf:Property ;
    rdfs:label 'Override Reason Code' ;
    rdfs:comment 'A standardized code indicating the business reason for the planner\'s manual override of the statistical forecast (e.g., new product launch, competitor action, supply constraint, market intelligence). Populated only when is_override_applied is True. [ENUM-REF-CANDIDATE: NEW_PRODUCT|COMPETITOR_ACTION|SUPPLY_CONSTRAINT|MARKET_INTEL|PROMO_CHANGE|STORE_EVENT|WEATHER — promote to reference product]' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideUnits rdf:type rdf:Property ;
    rdfs:label 'Override Units' ;
    rdfs:comment 'The manually adjusted demand quantity in units entered by a demand planner to replace or supplement the statistical forecast. Populated only when is_override_applied is True. Enables analysis of planner override magnitude and its impact on forecast accuracy.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningChannel rdf:type rdf:Property ;
    rdfs:label 'Planning Channel' ;
    rdfs:comment 'The retail fulfillment channel for which this demand forecast is generated. \'store\' covers brick-and-mortar POS demand; \'ecommerce\' covers digital commerce demand from Salesforce Commerce Cloud; \'omnichannel\' covers unified demand signals; \'dc_replenishment\' covers distribution center stock replenishment; \'bopis\' covers Buy Online Pick Up In Store (BOPIS) demand.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalLiftUnits rdf:type rdf:Property ;
    rdfs:label 'Promotional Lift Units' ;
    rdfs:comment 'The incremental demand units attributed to active promotions during the forecast period. Derived from promotion event modeling in Blue Yonder and used to isolate the promotional demand signal from baseline demand for Pricing and Promotions Management analysis.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentRecommendationUnits rdf:type rdf:Property ;
    rdfs:label 'Replenishment Recommendation Units' ;
    rdfs:comment 'The system-recommended replenishment order quantity in units derived from the demand forecast, current inventory position, safety stock targets, and lead time. Feeds directly into Oracle Retail Merchandising System (ORMS) purchase order generation and Open-to-Buy (OTB) planning.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalityIndex rdf:type rdf:Property ;
    rdfs:label 'Seasonality Index' ;
    rdfs:comment 'A multiplicative seasonal index applied to the baseline forecast to account for recurring seasonal demand patterns (e.g., holiday peaks, back-to-school). A value of 1.0 indicates no seasonal adjustment; values above 1.0 indicate above-average seasonal demand.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statisticalModelCode rdf:type rdf:Property ;
    rdfs:label 'Statistical Model Code' ;
    rdfs:comment 'The identifier or code of the statistical forecasting algorithm used by Blue Yonder Demand Planning to generate this forecast (e.g., ARIMA, Holt-Winters exponential smoothing, Croston for intermittent demand, machine learning ensemble). Enables model performance benchmarking and algorithm governance. [ENUM-REF-CANDIDATE: ARIMA|HOLT_WINTERS|CROSTON|ETS|MOVING_AVG|ML_ENSEMBLE|CAUSAL — promote to reference product]' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeBucketGranularity rdf:type rdf:Property ;
    rdfs:label 'Time Bucket Granularity' ;
    rdfs:comment 'The temporal granularity of the forecast period covered by this record. \'daily\' is used for short-horizon replenishment; \'weekly\' is the standard planning cadence; \'monthly\' is used for financial and Open-to-Buy (OTB) planning.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trendAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Trend Adjustment Factor' ;
    rdfs:comment 'A multiplicative factor representing the long-term demand trend applied to the forecast. Values above 1.0 indicate upward trend; values below 1.0 indicate declining demand trend. Used to capture secular demand shifts beyond seasonal patterns.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmape rdf:type rdf:Property ;
    rdfs:label 'Wmape' ;
    rdfs:comment 'Weighted Mean Absolute Percentage Error (WMAPE) measuring forecast accuracy weighted by sales volume, reducing the distortion caused by low-volume SKUs. Expressed as a decimal. Preferred accuracy metric for high-volume retail assortments where MAPE can be misleading.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualCartonCount rdf:type rdf:Property ;
    rdfs:label 'Actual Carton Count' ;
    rdfs:comment 'Actual number of cartons or cases handled during the dock appointment operation. Used to measure variance against expected quantities.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualPalletCount rdf:type rdf:Property ;
    rdfs:label 'Actual Pallet Count' ;
    rdfs:comment 'Actual number of pallets loaded or unloaded during the dock appointment operation. Used to measure variance against expected quantities.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualWeightKg rdf:type rdf:Property ;
    rdfs:label 'Actual Weight Kg' ;
    rdfs:comment 'Actual total weight in kilograms of the shipment handled during the dock appointment operation. Used to measure variance and validate freight charges.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appointmentDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Appointment Duration Minutes' ;
    rdfs:comment 'Planned duration in minutes allocated for the dock appointment from scheduled start to scheduled end. Used for dock capacity planning and scheduling optimization.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atDoorTimestamp rdf:type rdf:Property ;
    rdfs:label 'At Door Timestamp' ;
    rdfs:comment 'Date and time when the trailer was positioned at the assigned dock door and ready for loading or unloading operations to begin.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carrierScacCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Scac Code' ;
    rdfs:comment 'Four-letter unique identifier assigned by the National Motor Freight Traffic Association (NMFTA) to identify transportation carriers in North America.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check Out Timestamp' ;
    rdfs:comment 'Date and time when the carrier checked out of the facility and departed the yard.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dockDoorZone rdf:type rdf:Property ;
    rdfs:label 'Dock Door Zone' ;
    rdfs:comment 'Logical zone or area grouping for the dock door (e.g., inbound zone, outbound zone, cross-dock zone, refrigerated zone) used for operational planning and resource allocation.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Driver License Number' ;
    rdfs:comment 'Commercial driver license number of the driver. Captured for security verification and compliance with transportation regulations.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCartonCount rdf:type rdf:Property ;
    rdfs:label 'Expected Carton Count' ;
    rdfs:comment 'Anticipated number of cartons or cases to be handled during this dock appointment based on advance shipping notice or order information.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedPalletCount rdf:type rdf:Property ;
    rdfs:label 'Expected Pallet Count' ;
    rdfs:comment 'Anticipated number of pallets to be loaded or unloaded during this dock appointment based on advance shipping notice or order information.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Expected Weight Kg' ;
    rdfs:comment 'Anticipated total weight in kilograms of the shipment to be handled during this dock appointment. Used for capacity planning and equipment allocation.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateArrivalReason rdf:type rdf:Property ;
    rdfs:label 'Late Arrival Reason' ;
    rdfs:comment 'Free-text explanation or reason code for why the carrier arrived late outside the scheduled appointment window. Used for root cause analysis and carrier performance management.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadStatus rdf:type rdf:Property ;
    rdfs:label 'Load Status' ;
    rdfs:comment 'Current loading state of the trailer indicating whether it is empty, fully loaded, or partially loaded.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeArrivalFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Arrival Flag' ;
    rdfs:comment 'Boolean indicator of whether the carrier arrived within the scheduled appointment window. Used for carrier performance measurement and Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operation End Timestamp' ;
    rdfs:comment 'Date and time when the loading or unloading operation was completed and the trailer was ready for departure or yard staging.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operation Start Timestamp' ;
    rdfs:comment 'Date and time when the actual loading or unloading operation commenced at the dock door.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalScheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Original Scheduled Timestamp' ;
    rdfs:comment 'The initial scheduled start timestamp before any rescheduling occurred. Preserved for audit trail and performance analysis.' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rescheduleCount rdf:type rdf:Property ;
    rdfs:label 'Reschedule Count' ;
    rdfs:comment 'Number of times this dock appointment has been rescheduled. Used to track scheduling volatility and carrier reliability.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Timestamp' ;
    rdfs:comment 'Precise date and time when the dock appointment window ends. Defines the expected completion time for the loading or unloading operation.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Precise date and time when the dock appointment window begins. Used for dock scheduling optimization and carrier arrival planning.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Unique identifier of the security seal applied to the trailer door to ensure cargo integrity and prevent tampering during transit.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureReadingCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Reading Celsius' ;
    rdfs:comment 'Actual temperature reading in Celsius recorded for refrigerated or frozen trailers at check-in or during operations to ensure cold chain compliance.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trailerType rdf:type rdf:Property ;
    rdfs:label 'Trailer Type' ;
    rdfs:comment 'Classification of the trailer equipment type indicating the physical configuration and capabilities (dry van, refrigerated, flatbed, tanker, intermodal container).' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yardLocation rdf:type rdf:Property ;
    rdfs:label 'Yard Location' ;
    rdfs:comment 'Physical location identifier within the facility yard where the trailer is staged when not at a dock door (e.g., spot number, staging lane, holding area).' ;
    rdfs:domain ind:DockAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationDcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Destination Dc Facility Id' ;
    rdfs:comment 'Identifier of the destination entity (store, DC, customer, or vendor) where the handling unit is being shipped, interpreted based on destination_type.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:parentHandlingUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Handling Unit Id' ;
    rdfs:comment 'Reference to the parent handling unit in the containment hierarchy, enabling pallet-to-carton-to-each nested tracking.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HandlingUnit .

ind:consumedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consumed Timestamp' ;
    rdfs:comment 'Timestamp when the handling unit was fully consumed or broken down, marking the end of its lifecycle as a discrete tracking unit.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cubeM3 rdf:type rdf:Property ;
    rdfs:label 'Cube M3' ;
    rdfs:comment 'Total volumetric cube of the handling unit in cubic meters, calculated from dimensions and used for warehouse capacity and freight optimization.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingUnitStatus rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Status' ;
    rdfs:comment 'Current disposition status of the handling unit within the distribution center lifecycle, controlling operational workflows and quality holds.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingUnitType rdf:type rdf:Property ;
    rdfs:label 'Handling Unit Type' ;
    rdfs:comment 'Classification of the physical handling unit form factor used for warehouse operations and material handling.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMovementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Movement Timestamp' ;
    rdfs:comment 'Timestamp of the most recent physical movement or location change of the handling unit within the distribution center.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lpn rdf:type rdf:Property ;
    rdfs:label 'Lpn' ;
    rdfs:comment 'Unique barcode identifier assigned to the handling unit for tracking through the distribution center. The LPN is the foundational Manhattan WMS tracking identifier enabling unit-level traceability.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Flag' ;
    rdfs:comment 'Flag indicating whether the handling unit is under quality hold, preventing allocation or shipment until quality inspection is completed.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityHoldReasonCode rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Reason Code' ;
    rdfs:comment 'Code identifying the reason for quality hold, such as damage inspection, recall investigation, or expiry verification.' ;
    rdfs:domain ind:HandlingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledByAssociateId rdf:type rdf:Property ;
    rdfs:label 'Scheduled By Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Receiving coordinators schedule inbound appointments for operational accountability and performance tracking. Operations managers track coordinator productivity, appointment accuracy, and dock utiliza' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:actualUnloadEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Unload End Timestamp' ;
    rdfs:comment 'The actual date and time when physical unloading was completed and the dock door was cleared. Used to compute actual unload duration and dock utilization.' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualUnloadStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Unload Start Timestamp' ;
    rdfs:comment 'The actual date and time when physical unloading of the trailer or container began at the assigned dock door.' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:advanceShipNoticeNumber rdf:type rdf:Property ;
    rdfs:label 'Advance Ship Notice Number' ;
    rdfs:comment 'The Advance Ship Notice (ASN) number transmitted by the supplier via EDI 856 prior to shipment arrival. Enables pre-receiving, labor planning, and automated appointment creation.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentNotes rdf:type rdf:Property ;
    rdfs:label 'Appointment Notes' ;
    rdfs:comment 'Free-text notes or special instructions associated with the appointment, entered by DC staff, carriers, or the scheduling system. May include special handling requirements, access instructions, or exception details.' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalScheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Original Scheduled Start Timestamp' ;
    rdfs:comment 'The original planned appointment start timestamp before any rescheduling occurred. Preserved for compliance reporting and to measure the impact of rescheduling on DC operations.' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:schedulingSource rdf:type rdf:Property ;
    rdfs:label 'Scheduling Source' ;
    rdfs:comment 'Channel or method through which the appointment was originally created. Carrier portal: self-service web portal. EDI: Electronic Data Interchange automated scheduling. Manual: DC staff entered directly. API: programmatic integration from TMS or OMS.' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originFacilityDcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Dc Facility Id' ;
    rdfs:comment 'Identifier of the originating facility for inter-facility transfers. Null for supplier-direct shipments.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:primaryInboundDcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Inbound Dc Facility Id' ;
    rdfs:comment 'Identifier of the distribution center or micro-fulfillment center receiving this shipment. Determines facility-specific receiving workflows and capacity planning.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:crossDockFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Flag' ;
    rdfs:comment 'Indicates whether this shipment is designated for cross-docking operations, bypassing putaway and moving directly to outbound staging.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Timestamp' ;
    rdfs:comment 'Precise date and time the shipment is expected to arrive at the distribution center. Used for appointment scheduling and dock door allocation.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedCubeM3 rdf:type rdf:Property ;
    rdfs:label 'Expected Cube M3' ;
    rdfs:comment 'Total expected volume of the shipment in cubic meters. Used for warehouse space planning and transportation capacity optimization.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Amount' ;
    rdfs:comment 'Total freight transportation cost for this inbound shipment. Used for landed cost calculation and freight spend analysis.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the freight cost amount. Enables multi-currency freight cost tracking and consolidation.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateArrivalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Late Arrival Reason Code' ;
    rdfs:comment 'Standardized code explaining the reason for late arrival when on-time arrival flag is false. Used for root cause analysis and carrier accountability.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receiving Start Timestamp' ;
    rdfs:comment 'Date and time when receiving operations began for this shipment. Marks the start of unloading and inspection activities.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:temperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Celsius' ;
    rdfs:comment 'Maximum acceptable temperature in Celsius for temperature-controlled shipments. Used for cold chain compliance monitoring.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Celsius' ;
    rdfs:comment 'Minimum acceptable temperature in Celsius for temperature-controlled shipments. Used for cold chain compliance monitoring.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryTransferId rdf:type rdf:Property ;
    rdfs:label 'Inventory Transfer Id' ;
    rdfs:comment 'Unique identifier for the inventory transfer transaction. Primary key for the inventory transfer entity.' ;
    rdfs:domain ind:InventoryTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationFacilityDcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Dc Facility Id' ;
    rdfs:comment 'Identifier of the facility to which inventory is being transferred. Target location for the stock movement.' ;
    rdfs:domain ind:InventoryTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:originInventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Origin Inventory Node Id' ;
    rdfs:comment 'Foreign key linking to inventory.inventory_node. Business justification: Store-to-store and DC-to-store transfers require origin_inventory_node_id to track stock movement from specific nodes. Existing origin_facility_id targets dc_facility only; retail needs inventory_node' ;
    rdfs:domain ind:InventoryTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:primaryInventoryDcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Dc Facility Id' ;
    rdfs:comment 'Identifier of the facility from which inventory is being transferred. Source location for the stock movement.' ;
    rdfs:domain ind:InventoryTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:destinationFacilityType rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Type' ;
    rdfs:comment 'Type classification of the destination facility. Indicates whether the target is a Distribution Center (DC), Micro-Fulfillment Center (MFC), store, Third-Party Logistics (3PL) provider, or vendor location.' ;
    rdfs:domain ind:InventoryTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originFacilityType rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Type' ;
    rdfs:comment 'Type classification of the origin facility. Indicates whether the source is a Distribution Center (DC), Micro-Fulfillment Center (MFC), store, Third-Party Logistics (3PL) provider, or vendor location.' ;
    rdfs:domain ind:InventoryTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedShipDate rdf:type rdf:Property ;
    rdfs:label 'Requested Ship Date' ;
    rdfs:comment 'Date when the inventory is requested to be shipped from the origin facility. Represents the planned or desired shipment date for supply chain planning.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'Flag indicating whether the inventory requires temperature-controlled transportation and storage. True if temperature-sensitive, false otherwise.' ;
    rdfs:domain ind:InventoryTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalTransferValue rdf:type rdf:Property ;
    rdfs:label 'Total Transfer Value' ;
    rdfs:comment 'Total monetary value of the inventory transfer calculated as unit cost multiplied by transfer quantity. Used for financial reporting and inventory valuation.' ;
    rdfs:domain ind:InventoryTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Number' ;
    rdfs:comment 'Business-facing unique transfer order number used for tracking and reference across systems and facilities. Externally visible identifier for the transfer transaction.' ;
    rdfs:domain ind:InventoryTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandPlanId rdf:type rdf:Property ;
    rdfs:label 'Demand Plan Id' ;
    rdfs:comment 'Reference to the demand planning forecast or consensus demand plan that triggered this replenishment order. Links outbound execution to upstream planning.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:destinationAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Destination Address Line1' ;
    rdfs:comment 'Primary street address line for the shipment destination. Required for customer and store deliveries.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCity rdf:type rdf:Property ;
    rdfs:label 'Destination City' ;
    rdfs:comment 'City name for the shipment destination address.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStateProvince rdf:type rdf:Property ;
    rdfs:label 'Destination State Province' ;
    rdfs:comment 'State or province code for the shipment destination address.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDropShip rdf:type rdf:Property ;
    rdfs:label 'Is Drop Ship' ;
    rdfs:comment 'Boolean flag indicating whether this order is fulfilled via drop ship (vendor ships directly to customer, bypassing DC).' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replenishmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Replenishment Reason Code' ;
    rdfs:comment 'Code indicating the business reason for this replenishment order: stockout prevention, promotional support, seasonal refresh, new item introduction, etc.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentType rdf:type rdf:Property ;
    rdfs:label 'Replenishment Type' ;
    rdfs:comment 'For store replenishment orders: method used to determine replenishment quantities. Push (DC-initiated based on forecast), pull (store-requested), min-max (reorder point triggered), VMI (Vendor Managed Inventory), promotional (event-driven), seasonal (seasonal assortment), or new store (initial stock). [ENUM-REF-CANDIDATE: push|pull|min_max|vmi|promotional|seasonal|new_store — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the order must be delivered to the destination node to meet business commitments or replenishment schedules.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalCubeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Cube M3' ;
    rdfs:comment 'Total cubic volume of the outbound order in cubic meters. Used for trailer capacity planning and freight optimization.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLines rdf:type rdf:Property ;
    rdfs:label 'Total Lines' ;
    rdfs:comment 'Total number of distinct SKU line items included in this outbound order.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryOutboundLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Outbound Location Id' ;
    rdfs:comment 'Retail store or fulfillment node receiving this line item. Links to store master for address, capacity, and operational attributes.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:sourceLocationId rdf:type rdf:Property ;
    rdfs:label 'Source Location Id' ;
    rdfs:comment 'Warehouse storage location from which this line item was picked. Links to warehouse location master for zone, aisle, and bin tracking.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:allocatedQty rdf:type rdf:Property ;
    rdfs:label 'Allocated Qty' ;
    rdfs:comment 'Quantity of units allocated from available inventory to fulfill this line. May differ from ordered quantity due to stock availability constraints.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cartonNumber rdf:type rdf:Property ;
    rdfs:label 'Carton Number' ;
    rdfs:comment 'Shipping carton or container identifier containing this line item. Used for package-level tracking and multi-carton shipment management.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packedQty rdf:type rdf:Property ;
    rdfs:label 'Packed Qty' ;
    rdfs:comment 'Quantity of units packed into shipping containers for this line. Confirms units staged for outbound shipment and ready for carrier pickup.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickedQty rdf:type rdf:Property ;
    rdfs:label 'Picked Qty' ;
    rdfs:comment 'Actual quantity of units physically picked from warehouse storage locations. Reflects warehouse execution accuracy and inventory availability.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippedQty rdf:type rdf:Property ;
    rdfs:label 'Shipped Qty' ;
    rdfs:comment 'Final quantity of units shipped to the destination. Used for fill rate calculation, short-ship identification, and invoice reconciliation.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortShipQty rdf:type rdf:Property ;
    rdfs:label 'Short Ship Qty' ;
    rdfs:comment 'Quantity variance between ordered and shipped units. Represents unfulfilled demand due to stockouts, damage, or allocation constraints.' ;
    rdfs:domain ind:OutboundOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortShipReasonCode rdf:type rdf:Property ;
    rdfs:label 'Short Ship Reason Code' ;
    rdfs:comment 'Reason code explaining why this line was short-shipped. Used for root cause analysis, supplier performance tracking, and inventory planning improvement.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Primary key for plan' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority Rank' ;
    rdfs:comment 'Numeric rank (1 = highest priority) assigned to this DC for allocation of constrained supply for the SKU. Used by planners to prioritize distribution of limited inventory across DCs and stores during supply-constrained periods.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beginningOnHandQty rdf:type rdf:Property ;
    rdfs:label 'Beginning On Hand Qty' ;
    rdfs:comment 'Projected on-hand inventory quantity for the SKU at the DC at the start of the planning week, before any receipts or demand consumption. Used as the opening inventory position for supply-demand balancing calculations.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consensusDemandQty rdf:type rdf:Property ;
    rdfs:label 'Consensus Demand Qty' ;
    rdfs:comment 'Agreed demand quantity after S&OP consensus adjustments, incorporating planner overrides, promotional uplifts, and commercial inputs. This is the demand signal used for supply-demand balancing in the approved plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossdockQty rdf:type rdf:Property ;
    rdfs:label 'Crossdock Qty' ;
    rdfs:comment 'Quantity of the SKU planned for cross-docking at the DC, bypassing put-away storage and flowing directly from inbound receipt to outbound shipment. Supports DC throughput optimization and reduces handling costs for high-velocity items.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandForecastQty rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Qty' ;
    rdfs:comment 'Statistical demand forecast quantity for the SKU at the DC for the planning week, expressed in the SKU\'s unit of measure. Sourced from Blue Yonder Demand Planning and represents the baseline demand signal before supply constraints are applied.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excessInventoryFlag rdf:type rdf:Property ;
    rdfs:label 'Excess Inventory Flag' ;
    rdfs:comment 'Indicates whether the projected on-hand quantity exceeds the maximum inventory target for the SKU-DC combination in the planning week. When True, signals a potential dead stock or overstock situation requiring markdown or redistribution action.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxInventoryQty rdf:type rdf:Property ;
    rdfs:label 'Max Inventory Qty' ;
    rdfs:comment 'Maximum allowable on-hand inventory quantity for the SKU at the DC, representing the upper bound of the inventory target range. Projected on-hand quantities exceeding this threshold trigger the excess inventory flag.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minOrderQty rdf:type rdf:Property ;
    rdfs:label 'Min Order Qty' ;
    rdfs:comment 'Minimum Order Quantity (MOQ) required by the supplier for this SKU, representing the smallest quantity that can be ordered in a single purchase order. Constrains replenishment order quantities in the supply plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openPoQty rdf:type rdf:Property ;
    rdfs:label 'Open Po Qty' ;
    rdfs:comment 'Quantity on open, unfulfilled Purchase Orders (POs) for this SKU-DC combination expected to be received within the planning week. Sourced from SAP S/4HANA MM and ORMS to represent committed supply.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReceiptQty rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Qty' ;
    rdfs:comment 'Total quantity of the SKU planned to be received at the DC during the planning week from all supply sources (open POs, in-transit, cross-dock). Core output of the supply planning process used to assess coverage against demand.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannerNotes rdf:type rdf:Property ;
    rdfs:label 'Planner Notes' ;
    rdfs:comment 'Free-text notes entered by the supply chain planner to document assumptions, exceptions, override rationale, or action items associated with this supply plan record. Supports S&OP review discussions and audit trail.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizonWeeks rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Weeks' ;
    rdfs:comment 'Number of weeks forward from the plan week start date that this supply plan covers. Defines the rolling planning window used for demand-supply balancing and replenishment trigger decisions.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectedOnHandQty rdf:type rdf:Property ;
    rdfs:label 'Projected On Hand Qty' ;
    rdfs:comment 'Projected ending on-hand inventory quantity for the SKU at the DC at the end of the planning week, calculated as beginning on-hand plus planned receipts minus consensus demand. Key metric for identifying coverage gaps and excess inventory.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalUpliftQty rdf:type rdf:Property ;
    rdfs:label 'Promotional Uplift Qty' ;
    rdfs:comment 'Incremental demand quantity attributed to a promotional event for this SKU-DC-week, added on top of the baseline statistical forecast to derive the consensus demand quantity. Sourced from the promotions planning system.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentOrderQty rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Qty' ;
    rdfs:comment 'Recommended replenishment order quantity for the SKU-DC combination for the planning week, calculated by the planning system to bring projected on-hand to the target inventory level. Serves as the basis for generating new purchase orders.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellThroughRatePct rdf:type rdf:Property ;
    rdfs:label 'Sell Through Rate Pct' ;
    rdfs:comment 'Percentage of available inventory for this SKU that has been sold within the planning period, calculated as units sold divided by beginning inventory plus receipts. Used to assess demand velocity and identify slow-moving or dead stock.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockoutRiskScore rdf:type rdf:Property ;
    rdfs:label 'Stockout Risk Score' ;
    rdfs:comment 'Quantitative risk score (0-100) indicating the probability of a stockout event for the SKU at the DC within the planning horizon. Derived from demand variability, supply reliability, and projected on-hand versus safety stock. Used to prioritize replenishment actions.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierFillRatePct rdf:type rdf:Property ;
    rdfs:label 'Supplier Fill Rate Pct' ;
    rdfs:comment 'Historical fill rate percentage for this supplier-SKU combination, representing the percentage of ordered quantity actually delivered on time. Used as a supply reliability input to safety stock and risk score calculations.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Supplier Lead Time Days' ;
    rdfs:comment 'Number of days from purchase order placement to expected receipt at the DC for this SKU-supplier combination. Used in replenishment planning to determine order timing and assess supply pipeline coverage.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplyConstrainedFlag rdf:type rdf:Property ;
    rdfs:label 'Supply Constrained Flag' ;
    rdfs:comment 'Indicates whether the supply plan for this SKU-DC-week is constrained by supplier capacity, lead time, or minimum order quantity (MOQ) limitations. When True, planned receipt quantity is below unconstrained demand, triggering allocation prioritization.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weekEndDate rdf:type rdf:Property ;
    rdfs:label 'Week End Date' ;
    rdfs:comment 'The last day (Sunday) of the planning week for which this supply plan record applies. Used in conjunction with plan_week_start_date to define the weekly planning horizon bucket.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:weekStartDate rdf:type rdf:Property ;
    rdfs:label 'Week Start Date' ;
    rdfs:comment 'The first day (Monday) of the planning week for which this supply plan record applies. Defines the weekly time bucket used in S&OP reviews and demand-supply balancing at the SKU-DC-week granularity.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The delivery date confirmed by the supplier for this PO line. May differ from the requested delivery date; variance drives lead time compliance KPIs and supplier scorecards.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedQty rdf:type rdf:Property ;
    rdfs:label 'Confirmed Qty' ;
    rdfs:comment 'Quantity confirmed by the supplier as available and committed for shipment on this PO line. May differ from ordered quantity due to supplier capacity constraints or MOQ adjustments.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netCost rdf:type rdf:Property ;
    rdfs:label 'Net Cost' ;
    rdfs:comment 'Net cost per unit after applying all supplier allowances, discounts, and deductions to the unit cost. Represents the true landed cost basis for COGS and margin calculations.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderUomQty rdf:type rdf:Property ;
    rdfs:label 'Order Uom Qty' ;
    rdfs:comment 'Number of base selling units (eaches) contained within one purchase unit of measure. Enables conversion between purchase UOM and retail selling UOM for inventory and sales reporting (e.g., 12 eaches per case).' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otbConsumed rdf:type rdf:Property ;
    rdfs:label 'Otb Consumed' ;
    rdfs:comment 'Dollar value of Open to Buy (OTB) budget consumed by this PO line at the time of order placement. Used for merchandise financial planning and budget compliance monitoring.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uom rdf:type rdf:Property ;
    rdfs:label 'Uom' ;
    rdfs:comment 'Unit of measure in which the ordered, confirmed, shipped, and received quantities are expressed (e.g., EA=Each, CS=Case, PK=Pack, LB=Pound). Aligns with GS1 and SAP MM unit of measure codes. [ENUM-REF-CANDIDATE: EA|CS|PK|LB|KG|OZ|L|M|FT|DZ — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blanketPoPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Blanket Po Purchase Order Id' ;
    rdfs:comment 'Reference to the parent blanket or framework purchase order from which this release or call-off order was created. Null for standalone standard POs. Enables tracking of spend against blanket agreement limits.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:receivingCoordinatorAssociateId rdf:type rdf:Property ;
    rdfs:label 'Receiving Coordinator Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: DC receiving coordinators manage PO receipts for operational ownership and accountability. Operations tracks receipt accuracy, cycle time, and discrepancy resolution by coordinator for performance man' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:ediTransmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Transmission Status' ;
    rdfs:comment 'Status of the EDI (Electronic Data Interchange) transmission of this purchase order to the supplier. Not Sent = EDI not applicable or not yet initiated; Pending = queued for transmission; Transmitted = EDI 850 PO sent to supplier; Acknowledged = supplier returned EDI 855 acknowledgment; Failed = transmission error; Rejected = supplier rejected the PO via EDI.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Edi Transmitted Timestamp' ;
    rdfs:comment 'The timestamp when the purchase order was transmitted to the supplier via EDI (Electronic Data Interchange) as an EDI 850 transaction set. Null if EDI transmission has not occurred. Used for supplier communication SLA tracking.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'The named place or port associated with the Incoterms code, specifying the exact location where risk and cost transfer between buyer and seller (e.g., \'Port of Los Angeles\' for FOB). Corresponds to SAP EKKO.INCO2.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandiseCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Merchandise Category Code' ;
    rdfs:comment 'The merchandise category or department code associated with the primary goods on this purchase order, aligned with the retailer\'s category management hierarchy. Used for spend analytics by category, OTB (Open to Buy) tracking, and GMROI reporting.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPayableAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payable Amount' ;
    rdfs:comment 'The net amount payable to the supplier after applying all discounts, allowances, and adjustments to the gross total order amount. This is the financial commitment recorded in accounts payable. Expressed in the currency specified by currency_code.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle state of the purchase order from creation through closure. Draft = created but not submitted; Pending Approval = awaiting authorization; Approved = authorized for transmission; Sent = transmitted to supplier via EDI or portal; Partially Received = some goods received; Received = all goods received; Closed = fully processed and closed; Cancelled = voided. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|sent|partially_received|received|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order by procurement method. Standard = regular replenishment PO; Blanket = open-quantity framework agreement; DSD (Direct Store Delivery) = supplier delivers directly to store; Drop Ship = vendor ships direct to customer; Consignment = inventory owned by supplier until sold; RTV (Return to Vendor) = merchandise returned to supplier. [ENUM-REF-CANDIDATE: standard|blanket|direct_store_delivery|drop_ship|consignment|return_to_vendor — promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroupCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group Code' ;
    rdfs:comment 'Code identifying the buyer group or commodity team responsible for this purchase order within the purchasing organization. Used for spend analytics by category and buyer performance reporting. Corresponds to SAP EKKO.EKGRP.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrgCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Org Code' ;
    rdfs:comment 'SAP purchasing organization code representing the organizational unit responsible for procuring goods and services. Defines the legal entity and negotiation authority for the purchase order. Corresponds to SAP EKKO.EKORG.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierPoReference rdf:type rdf:Property ;
    rdfs:label 'Supplier Po Reference' ;
    rdfs:comment 'The supplier\'s own reference number or acknowledgment number for this purchase order, returned via EDI 855 or supplier portal. Used for cross-referencing in supplier invoices, ASNs (Advance Ship Notices), and dispute resolution.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Total Order Amount' ;
    rdfs:comment 'The gross total monetary value of the purchase order before any adjustments, representing the sum of all line item values. Expressed in the currency specified by currency_code. Used for open-to-buy (OTB) tracking, financial commitments, and accounts payable accruals.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderedUnits rdf:type rdf:Property ;
    rdfs:label 'Total Ordered Units' ;
    rdfs:comment 'The total quantity of units ordered across all line items on this purchase order. Used for fill rate calculation, receiving reconciliation, and inventory planning. Expressed in the base unit of measure.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReceivedUnits rdf:type rdf:Property ;
    rdfs:label 'Total Received Units' ;
    rdfs:comment 'The total quantity of units physically received and goods-receipted against this purchase order to date. Used to calculate fill rate (order completion percentage) and identify short shipments or over-deliveries.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityHoldId rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Id' ;
    rdfs:comment 'Unique identifier for the quality hold event. Primary key.' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryQualityAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Quality Associate Id' ;
    rdfs:comment 'Foreign key reference to the employee who initiated the quality hold and performed the initial inspection.' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:affectedEntityReference rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Reference' ;
    rdfs:comment 'Identifier of the specific entity under hold (e.g., LPN number, SSCC, location code, ASN number, lot number). The interpretation depends on affected_entity_type.' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedEntityType rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Type' ;
    rdfs:comment 'Type of entity subject to the quality hold: handling_unit (specific LPN or SSCC), storage_location (entire warehouse location or zone), inbound_shipment (entire ASN or shipment), pallet (pallet-level hold), carton (carton-level hold), lot (lot or batch number hold).' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Affected Quantity' ;
    rdfs:comment 'Quantity of inventory units placed under quality hold. Measured in the unit of measure specified.' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Chargeback Eligible Flag' ;
    rdfs:comment 'Indicates whether this quality hold event is eligible for supplier chargeback or cost recovery based on supplier accountability and contract terms.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'Date when the disposition decision was executed and inventory was released, returned, destroyed, or otherwise processed.' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'Final disposition decision for the held inventory: release (approved for use), return_to_vendor (RTV for credit or replacement), destroy (dispose per hazmat or food safety protocols), rework (repackage or relabel), donate (to food bank or charity), transfer (move to alternate facility).' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionNotes rdf:type rdf:Property ;
    rdfs:label 'Disposition Notes' ;
    rdfs:comment 'Free-text notes documenting the disposition process, including actions taken, approvals obtained, and any deviations from standard procedures.' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdDate rdf:type rdf:Property ;
    rdfs:label 'Hold Date' ;
    rdfs:comment 'Date when the quality hold was initiated and inventory was quarantined.' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Timestamp' ;
    rdfs:comment 'Precise timestamp when the quality hold was initiated, including time zone information. Used for SLA tracking and regulatory compliance.' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Reference number for regulatory agency communication, recall notice, or compliance inspection related to this quality hold (e.g., FDA recall number, CPSC case number).' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date when the quality hold was released and inventory was made available for use, if applicable. Null if hold is still active or resulted in disposition other than release.' ;
    rdfs:domain ind:QualityHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivingEventId rdf:type rdf:Property ;
    rdfs:label 'Receiving Event Id' ;
    rdfs:comment 'Unique identifier for the receiving event. Primary key for this product.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReceivingEvent .

ind:receivingSupervisorEmployeeAssociateId rdf:type rdf:Property ;
    rdfs:label 'Receiving Supervisor Employee Associate Id' ;
    rdfs:comment 'Reference to the warehouse supervisor who approved or oversaw the receiving event, particularly for exception handling.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:actualUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Unit Quantity' ;
    rdfs:comment 'The total number of individual units (eaches) physically received and verified during the receiving event.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cartonVarianceCount rdf:type rdf:Property ;
    rdfs:label 'Carton Variance Count' ;
    rdfs:comment 'The difference between expected and actual carton count (actual minus expected). Positive indicates overage, negative indicates shortage.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:damageFlag rdf:type rdf:Property ;
    rdfs:label 'Damage Flag' ;
    rdfs:comment 'Indicates whether any damaged goods were identified during the receiving event.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:damagedUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Damaged Unit Quantity' ;
    rdfs:comment 'The number of units identified as damaged during the receiving inspection.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discrepancyReasonCode rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Reason Code' ;
    rdfs:comment 'Code indicating the reason for any discrepancy between expected and actual quantities (e.g., supplier short ship, damaged in transit, incorrect ASN).' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Expected Unit Quantity' ;
    rdfs:comment 'The total number of individual units (eaches) expected to be received based on the advance shipment notice or purchase order.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overageFlag rdf:type rdf:Property ;
    rdfs:label 'Overage Flag' ;
    rdfs:comment 'Indicates whether the receiving event resulted in an overage (more units received than expected).' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:palletVarianceCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Variance Count' ;
    rdfs:comment 'The difference between expected and actual pallet count (actual minus expected). Positive indicates overage, negative indicates shortage.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:putawayTaskGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Putaway Task Generated Flag' ;
    rdfs:comment 'Indicates whether putaway tasks have been automatically generated in the WMS following the receiving event.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether the received goods require quality inspection before being made available for putaway or sale.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivingEventNumber rdf:type rdf:Property ;
    rdfs:label 'Receiving Event Number' ;
    rdfs:comment 'Business-readable unique identifier for the receiving event, used for tracking and reporting.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingNotes rdf:type rdf:Property ;
    rdfs:label 'Receiving Notes' ;
    rdfs:comment 'Free-text notes entered by the receiving clerk documenting any observations, issues, or special handling instructions.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingStatus rdf:type rdf:Property ;
    rdfs:label 'Receiving Status' ;
    rdfs:comment 'Current lifecycle status of the receiving event.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingType rdf:type rdf:Property ;
    rdfs:label 'Receiving Type' ;
    rdfs:comment 'Type of receiving operation: blind receiving (no advance shipment notice), directed receiving (with ASN), cross-dock, return to vendor, or inter-facility transfer.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealIntactFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Intact Flag' ;
    rdfs:comment 'Indicates whether the security seal was found intact upon arrival. False indicates potential tampering or security breach.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortageFlag rdf:type rdf:Property ;
    rdfs:label 'Shortage Flag' ;
    rdfs:comment 'Indicates whether the receiving event resulted in a shortage (fewer units received than expected).' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitVarianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Unit Variance Quantity' ;
    rdfs:comment 'The difference between expected and actual unit quantity (actual minus expected). Positive indicates overage, negative indicates shortage.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unloadDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Unload Duration Minutes' ;
    rdfs:comment 'Total time in minutes taken to unload the shipment, calculated from start to end timestamp.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unloadEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unload End Timestamp' ;
    rdfs:comment 'The timestamp when the unloading of the inbound shipment was completed.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unloadStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unload Start Timestamp' ;
    rdfs:comment 'The timestamp when the unloading of the inbound shipment began at the dock door.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvedOrderQty rdf:type rdf:Property ;
    rdfs:label 'Approved Order Qty' ;
    rdfs:comment 'The final order quantity approved by the buyer or auto-approved by the system after MOQ, order multiple, and buyer override adjustments. This is the quantity that will be transmitted to the supplier via EDI or purchase order.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyerOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Buyer Override Flag' ;
    rdfs:comment 'Indicates whether a buyer has manually overridden the system-generated planned order quantity or parameters. True = buyer override applied; False = system-generated values accepted as-is. Supports audit trail for manual interventions.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentOnHandQty rdf:type rdf:Property ;
    rdfs:label 'Current On Hand Qty' ;
    rdfs:comment 'The quantity of the SKU physically on hand at the supply node at the time the replenishment plan was generated. Sourced from Manhattan Associates WMS or SAP S/4HANA WM. Used as the starting inventory position for plan calculations.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandVariabilityFactor rdf:type rdf:Property ;
    rdfs:label 'Demand Variability Factor' ;
    rdfs:comment 'A statistical measure of demand variability (coefficient of variation or standard deviation of demand) used by the planning engine to size safety stock. Higher values indicate more volatile demand and result in larger safety stock buffers.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fillRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Target Pct' ;
    rdfs:comment 'The target order fill rate percentage (Fill Rate) for this replenishment plan, representing the percentage of demand that should be fulfilled from available inventory. Used as a supply chain performance KPI (KPI) target for this SKU-node combination.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedDemandQty rdf:type rdf:Property ;
    rdfs:label 'Forecasted Demand Qty' ;
    rdfs:comment 'The total forecasted demand quantity for the SKU at the supply node over the plan horizon, as generated by Blue Yonder Demand Planning. The primary input to the planned order quantity calculation.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minOrderValue rdf:type rdf:Property ;
    rdfs:label 'Min Order Value' ;
    rdfs:comment 'The minimum monetary value of a purchase order required by the supplier, expressed in the operating currency. Replenishment plans that do not meet the minimum order value threshold are consolidated or flagged for buyer action.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moqComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Moq Compliance Flag' ;
    rdfs:comment 'Indicates whether the planned order quantity meets or exceeds the supplier\'s Minimum Order Quantity (MOQ) constraint. True = compliant; False = below MOQ threshold and requires buyer review or order consolidation before release.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Order Release Date' ;
    rdfs:comment 'The date on which the replenishment plan is scheduled to be released as a purchase order to the supplier. Calculated by subtracting lead time from the planned receipt date. Drives the purchasing execution calendar.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planGenerationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Plan Generation Timestamp' ;
    rdfs:comment 'The date and time when the replenishment plan was generated by the planning engine (Blue Yonder or equivalent). Represents the principal business event timestamp for this transaction. Used for plan freshness assessment and demand signal alignment.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:planHorizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan Horizon End Date' ;
    rdfs:comment 'The end date of the planning horizon covered by this replenishment plan. Defines the end of the demand forecast window. Together with plan_horizon_start_date, bounds the coverage period for this plan.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planHorizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Horizon Start Date' ;
    rdfs:comment 'The start date of the planning horizon covered by this replenishment plan. Defines the beginning of the demand forecast window used to generate the planned order quantity.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedOrderQty rdf:type rdf:Property ;
    rdfs:label 'Planned Order Qty' ;
    rdfs:comment 'The quantity of units recommended by the planning engine to be ordered for this SKU at the specified supply node. Subject to MOQ and order multiple enforcement before release to purchasing.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedOrderValue rdf:type rdf:Property ;
    rdfs:label 'Planned Order Value' ;
    rdfs:comment 'The total monetary value of the planned replenishment order, calculated as planned_order_qty multiplied by unit_cost. Used for Open-to-Buy (OTB) budget management and financial planning.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Flag' ;
    rdfs:comment 'Indicates whether this replenishment plan was generated or adjusted to support a planned promotional event. True = promotion-driven uplift included in forecasted demand; False = baseline replenishment. Links to promotional demand lift in Blue Yonder.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyStockMethod rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Method' ;
    rdfs:comment 'The methodology used to calculate the safety stock quantity. Fixed uses a static buffer; Statistical uses demand variability and lead time variance; Days of Supply targets a coverage duration; Service Level Based derives buffer from the target service level percentage.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelTargetPct rdf:type rdf:Property ;
    rdfs:label 'Service Level Target Pct' ;
    rdfs:comment 'The target in-stock service level percentage used to calculate safety stock and replenishment parameters. Expressed as a percentage (e.g., 95.00 = 95%). Represents the probability of not experiencing a stockout during the replenishment lead time.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weeksOfSupplyTarget rdf:type rdf:Property ;
    rdfs:label 'Weeks Of Supply Target' ;
    rdfs:comment 'The target number of weeks of inventory coverage (Weeks of Supply / WOS) that the replenishment plan aims to achieve at the supply node after order receipt. Used as a planning horizon parameter for days-of-supply replenishment methods.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Id' ;
    rdfs:comment 'Primary key for sla_definition' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaDefinition .

ind:supersededBySlaSlaDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Sla Sla Definition Id' ;
    rdfs:comment 'Reference to the supply_chain_sla_id of the newer SLA definition that replaces this record when terms are renegotiated. Null if this is the current active version. Enables SLA version chain navigation.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaDefinition .

ind:autoPenaltyEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Penalty Enabled' ;
    rdfs:comment 'Indicates whether penalty assessment is automatically triggered upon SLA breach detection (True) or requires manual approval before issuance (False). Drives automated chargeback processing in SAP S/4HANA FI.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consecutiveBreachLimit rdf:type rdf:Property ;
    rdfs:label 'Consecutive Breach Limit' ;
    rdfs:comment 'Maximum number of consecutive measurement periods in which SLA performance may fall below the minimum threshold before triggering contract review or termination proceedings. Used in Blue Yonder performance monitoring workflows.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:counterpartyType rdf:type rdf:Property ;
    rdfs:label 'Counterparty Type' ;
    rdfs:comment 'Classification of the external party bound by this SLA. Supplier applies to vendor fill rate and lead time SLAs; 3PL Partner applies to third-party logistics SLAs; DC Operator applies to distribution center SLAs; Carrier applies to last-mile delivery SLAs.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dcScope rdf:type rdf:Property ;
    rdfs:label 'Dc Scope' ;
    rdfs:comment 'Identifies the specific Distribution Center (DC) or network of DCs to which this SLA applies. Null indicates the SLA applies to all DCs. Used in Manhattan Associates WMS for DC-level performance tracking.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Value' ;
    rdfs:comment 'Performance level at which an SLA breach triggers formal escalation to senior management or executive review, beyond standard penalty processing. Typically set below minimum_threshold_value for critical SLAs.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of calendar days after an SLA breach is detected before penalty assessment is initiated. Allows counterparty time to remediate without immediate financial consequence. Zero indicates no grace period.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadTimeEndEvent rdf:type rdf:Property ;
    rdfs:label 'Lead Time End Event' ;
    rdfs:comment 'For Lead Time SLAs, defines the business event that stops the lead time clock. DC Receipt is standard for supplier SLAs; Store Receipt applies to DSD (Direct Store Delivery); Customer Delivery applies to last-mile SLAs.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeStartEvent rdf:type rdf:Property ;
    rdfs:label 'Lead Time Start Event' ;
    rdfs:comment 'For Lead Time SLAs, defines the business event that starts the lead time clock. Purchase Order Issued is the standard start; Order Confirmed starts from supplier acknowledgement; Pick Released starts from warehouse pick; Ship Confirmed starts from carrier pickup.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'How often SLA performance is measured and evaluated against the target threshold. Per-shipment applies to individual delivery SLAs; Weekly/Monthly apply to aggregate fill rate and EDI compliance SLAs.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementWindowDays rdf:type rdf:Property ;
    rdfs:label 'Measurement Window Days' ;
    rdfs:comment 'Rolling number of calendar days over which SLA performance is aggregated for evaluation. For example, a 30-day rolling window for monthly fill rate measurement. Works in conjunction with measurement_frequency.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Threshold Value' ;
    rdfs:comment 'The floor performance level below which penalty clauses are automatically triggered. Distinct from target_threshold_value which is the aspirational goal. For example, target fill rate may be 98% while minimum acceptable is 95%.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:owningCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Owning Cost Center Code' ;
    rdfs:comment 'SAP S/4HANA FI/CO cost center code for the business unit responsible for this SLA. Used for financial allocation of penalty charges and SLA management costs.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCapAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Cap Amount' ;
    rdfs:comment 'Maximum financial penalty that can be assessed in a single measurement period, regardless of the degree of SLA breach. Expressed in the contract currency. Protects counterparty from unlimited liability. Confidential contract term.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyRate rdf:type rdf:Property ;
    rdfs:label 'Penalty Rate' ;
    rdfs:comment 'The rate applied to calculate the financial penalty when SLA performance falls below the minimum threshold. Expressed as a percentage of invoice value for chargeback SLAs or as a fixed rate per unit for volume-based penalties. Confidential contract term.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyStructureType rdf:type rdf:Property ;
    rdfs:label 'Penalty Structure Type' ;
    rdfs:comment 'The mechanism by which penalties are applied when SLA thresholds are breached. Chargeback deducts from supplier invoice; Credit Memo issues a financial credit; Service Credit applies to 3PL contract credits; None indicates no financial penalty.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategoryScope rdf:type rdf:Property ;
    rdfs:label 'Product Category Scope' ;
    rdfs:comment 'The merchandise category or department to which this SLA applies, e.g., \'Grocery\', \'Apparel\', \'Electronics\', \'Household Goods\'. Null indicates the SLA applies across all categories for the counterparty. Aligns with Oracle Retail Merchandising System category hierarchy.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Status' ;
    rdfs:comment 'Current lifecycle state of the SLA definition. Draft indicates under review; Active indicates currently enforced; Suspended indicates temporarily paused; Expired indicates past effective period; Terminated indicates cancelled before expiry.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Sla Performance Id' ;
    rdfs:comment 'Unique surrogate identifier for each SLA performance measurement record. Primary key for the sla_performance data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Flag' ;
    rdfs:comment 'Indicates whether the actual performance value failed to meet the contractual SLA target for this measurement period. True = SLA breach occurred; False = SLA target met or exceeded. Primary trigger for breach alerting workflows.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachSeverity rdf:type rdf:Property ;
    rdfs:label 'Breach Severity' ;
    rdfs:comment 'Severity classification of the SLA breach based on the magnitude of variance from target. Critical indicates severe underperformance requiring immediate escalation; none indicates no breach. Used to prioritize corrective action and chargeback processing.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consecutiveBreachCount rdf:type rdf:Property ;
    rdfs:label 'Consecutive Breach Count' ;
    rdfs:comment 'The number of consecutive measurement periods in which this SLA has been breached by the same supplier, as of this record. Used to identify chronic underperformers and trigger escalation or contract review.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:metricUnit rdf:type rdf:Property ;
    rdfs:label 'Metric Unit' ;
    rdfs:comment 'The unit of measure for the SLA metric values (target_value, actual_value, variance_value). Percentage applies to fill rate and accuracy SLAs; days/hours apply to lead time and on-time delivery SLAs; units/cases apply to quantity-based SLAs.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardPeriod rdf:type rdf:Property ;
    rdfs:label 'Scorecard Period' ;
    rdfs:comment 'The standardized scorecard period label for this SLA measurement, used in supplier performance scorecarding and reporting. Format: YYYY-Qn for quarterly, YYYY-Wnn for weekly, or YYYY-MM for monthly periods.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortShipQuantity rdf:type rdf:Property ;
    rdfs:label 'Short Ship Quantity' ;
    rdfs:comment 'The quantity shortfall between ordered_quantity and shipped_quantity. Represents units not fulfilled by the supplier. Used for chargeback calculation and supplier compliance reporting.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sla Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this SLA performance record, used in supplier communications, chargeback documentation, and audit trails. Format: SLA-YYYY-NNNNNN.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceValue rdf:type rdf:Property ;
    rdfs:label 'Variance Value' ;
    rdfs:comment 'The arithmetic difference between actual_value and target_value (actual minus target). Negative values indicate underperformance against the SLA commitment. Used for trend analysis and breach severity assessment.' ;
    rdfs:domain ind:SlaPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:senderVendorId rdf:type rdf:Property ;
    rdfs:label 'Sender Vendor Id' ;
    rdfs:comment 'The EDI interchange sender identifier (ISA06) as defined in the interchange control header. Identifies the originating party of the EDI transmission. May be the retailer\'s EDI ID (outbound) or the trading partner\'s EDI ID (inbound).' ;
    rdfs:domain ind:SupplychainEdiTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:documentSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Document Size Bytes' ;
    rdfs:comment 'The size of the raw EDI document payload in bytes. Used for VAN transmission cost allocation, integration platform capacity planning, and anomaly detection (e.g., unusually large or empty documents).' ;
    rdfs:domain ind:SupplychainEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ediStandard rdf:type rdf:Property ;
    rdfs:label 'Edi Standard' ;
    rdfs:comment 'The EDI messaging standard used for this transaction (e.g., ANSI X12 for North American retail, EDIFACT for international trading partners, TRADACOMS for UK retail). Determines parsing rules and compliance validation logic.' ;
    rdfs:domain ind:SupplychainEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAckStatus rdf:type rdf:Property ;
    rdfs:label 'Functional Ack Status' ;
    rdfs:comment 'The acknowledgment status returned in the 997 Functional Acknowledgment or 999 Implementation Acknowledgment for this transaction. Indicates whether the trading partner accepted, accepted with errors, or rejected the EDI document. Critical for EDI compliance monitoring and chargeback prevention.' ;
    rdfs:domain ind:SupplychainEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Functional Ack Timestamp' ;
    rdfs:comment 'The date and time when the 997 Functional Acknowledgment was received for this transaction. Used to calculate acknowledgment turnaround time and detect SLA breaches for late acknowledgments per retailer routing guide requirements.' ;
    rdfs:domain ind:SupplychainEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:groupControlNumber rdf:type rdf:Property ;
    rdfs:label 'Group Control Number' ;
    rdfs:comment 'The control number assigned to the functional group (GS06 segment) within the EDI interchange. Groups related transaction sets of the same type and enables functional acknowledgment (997) matching at the group level.' ;
    rdfs:domain ind:SupplychainEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingGuideVersion rdf:type rdf:Property ;
    rdfs:label 'Routing Guide Version' ;
    rdfs:comment 'The version of the retailer\'s EDI routing guide against which this transaction was validated (e.g., \'v2024.1\'). Enables compliance scoring to be evaluated against the correct version of requirements, supporting trading partner onboarding and annual routing guide updates.' ;
    rdfs:domain ind:SupplychainEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerDuns rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Duns' ;
    rdfs:comment 'The Dun & Bradstreet DUNS number of the trading partner, a 9-digit identifier used for supplier identity verification, credit risk assessment, and EDI partner onboarding validation.' ;
    rdfs:domain ind:SupplychainEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerGln rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Gln' ;
    rdfs:comment 'The GS1 Global Location Number (GLN) of the trading partner (supplier, 3PL, or DC) involved in this EDI exchange. A 13-digit GS1 identifier used to uniquely identify legal entities and physical locations in the supply chain. Required for GS1-compliant EDI routing.' ;
    rdfs:domain ind:SupplychainEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerQualifier rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Qualifier' ;
    rdfs:comment 'The ANSI X12 ISA qualifier code indicating the type of trading partner identifier used in the interchange (e.g., 01=DUNS, 08=UCC EDI Comm ID, 12=Phone, 14=DUNS+4, 20=Health Industry Number, ZZ=Mutually Defined). Required for EDI interchange routing.' ;
    rdfs:domain ind:SupplychainEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionControlNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Control Number' ;
    rdfs:comment 'The control number assigned to the individual transaction set (ST02 segment) within the functional group. Uniquely identifies a single transaction set for acknowledgment and error tracking.' ;
    rdfs:domain ind:SupplychainEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionSetCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Set Code' ;
    rdfs:comment 'The ANSI X12 or EDIFACT transaction set number identifying the document type exchanged (e.g., 850 Purchase Order, 855 PO Acknowledgment, 856 Advance Ship Notice, 810 Invoice, 860 PO Change Order, 997 Functional Acknowledgment, 832 Price/Sales Catalog, 846 Inventory Inquiry). [ENUM-REF-CANDIDATE: 850|855|856|810|860|997|832|846|753|754 — promote to reference product]' ;
    rdfs:domain ind:SupplychainEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionSetName rdf:type rdf:Property ;
    rdfs:label 'Transaction Set Name' ;
    rdfs:comment 'Human-readable name of the EDI transaction set type (e.g., \'Purchase Order\', \'Advance Ship Notice (ASN)\', \'Invoice\', \'Functional Acknowledgment\') corresponding to the transaction_set_id. Supports dashboards and reporting without requiring code lookups.' ;
    rdfs:domain ind:SupplychainEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmissionProtocol rdf:type rdf:Property ;
    rdfs:label 'Transmission Protocol' ;
    rdfs:comment 'The communication protocol used to transmit the EDI document (e.g., AS2, SFTP, FTP, HTTPS, VAN mailbox, AS4). Relevant for integration health dashboards and security compliance audits per ISO 27001.' ;
    rdfs:domain ind:SupplychainEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vanProvider rdf:type rdf:Property ;
    rdfs:label 'Van Provider' ;
    rdfs:comment 'The Value-Added Network (VAN) or direct EDI integration provider used to transmit this transaction (e.g., SPS Commerce, TrueCommerce, Sterling Commerce, OpenText, Direct AS2/SFTP). Supports integration health monitoring and VAN cost allocation.' ;
    rdfs:domain ind:SupplychainEdiTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseTaskId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Task Id' ;
    rdfs:comment 'Unique identifier for the warehouse task. Primary key for the warehouse task entity.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetLocationId rdf:type rdf:Property ;
    rdfs:label 'Target Location Id' ;
    rdfs:comment 'Warehouse location identifier where the task terminates or inventory is placed. For putaway tasks, this is the storage bin. For pick tasks, this is the staging or packing location.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:actualQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity' ;
    rdfs:comment 'The actual quantity of units completed or processed by the warehouse operator for this task. May differ from planned quantity in case of shorts or overages.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Type of material handling equipment required or used for this task: forklift (counterbalance lift), reach_truck (narrow aisle reach), pallet_jack (manual or powered), order_picker (vertical picker), conveyor (automated transport), AMR (Autonomous Mobile Robot), AGV (Automated Guided Vehicle), manual (no equipment), tugger (tow tractor), or clamp_truck (specialized forklift). [ENUM-REF-CANDIDATE: forklift|reach_truck|pallet_jack|order_picker|conveyor|amr|agv|manual|tugger|clamp_truck — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Exception Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for task exception: short_pick (insufficient inventory), damaged_product, location_blocked, equipment_failure, quality_hold, mispick, system_error, or other predefined exception types.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'The quantity of units originally planned or requested for this warehouse task as generated by the WMS.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceZone rdf:type rdf:Property ;
    rdfs:label 'Source Zone' ;
    rdfs:comment 'Logical warehouse zone classification for the source location (e.g., reserve storage, forward pick, receiving dock, returns area). Used for zone-based task assignment.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardLaborMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Labor Minutes' ;
    rdfs:comment 'Engineered labor standard time in minutes expected for this task type and quantity. Used for productivity variance analysis and incentive pay calculation.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetZone rdf:type rdf:Property ;
    rdfs:label 'Target Zone' ;
    rdfs:comment 'Logical warehouse zone classification for the target location. Used for labor planning and travel time optimization.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskAssignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Assigned Timestamp' ;
    rdfs:comment 'Date and time when the task was assigned to a warehouse operator. Used for measuring task queue time and labor allocation efficiency.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Completed Timestamp' ;
    rdfs:comment 'Date and time when the task was successfully completed or closed. Used for cycle time analysis and throughput measurement.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Created Timestamp' ;
    rdfs:comment 'Date and time when the warehouse task was originally generated by the WMS. Represents the business event timestamp for task creation.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Task Duration Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from task start to completion. Used for labor standards validation and engineered labor standards comparison.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taskStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Started Timestamp' ;
    rdfs:comment 'Date and time when the operator began actively working on the task. Used for calculating actual labor time and productivity metrics.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:travelDistanceFeet rdf:type rdf:Property ;
    rdfs:label 'Travel Distance Feet' ;
    rdfs:comment 'Calculated or measured travel distance in feet between source and target locations. Used for slotting optimization and labor planning.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseZoneId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Zone Id' ;
    rdfs:comment 'Unique identifier for the warehouse zone. Primary key for the warehouse zone entity.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aisleRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Aisle Range End' ;
    rdfs:comment 'Ending aisle identifier for the zone, defining the end of the physical aisle range contained within this zone for pick path optimization.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aisleRangeStart rdf:type rdf:Property ;
    rdfs:label 'Aisle Range Start' ;
    rdfs:comment 'Starting aisle identifier for the zone, defining the beginning of the physical aisle range contained within this zone for pick path optimization.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationType rdf:type rdf:Property ;
    rdfs:label 'Automation Type' ;
    rdfs:comment 'Level and type of automation deployed in the zone. ASRS = Automated Storage and Retrieval System, AMR = Autonomous Mobile Robot, AGV = Automated Guided Vehicle. [ENUM-REF-CANDIDATE: manual|conveyor|asrs|shuttle|amr|agv|robotic_pick — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeScanningRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Barcode Scanning Required Flag' ;
    rdfs:comment 'Indicates whether barcode scanning is mandatory for all inventory movements within the zone to ensure location accuracy and inventory integrity.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentOccupancyPct rdf:type rdf:Property ;
    rdfs:label 'Current Occupancy Pct' ;
    rdfs:comment 'Current space utilization percentage of the zone, calculated as occupied capacity divided by total capacity, used for capacity management and slotting decisions.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationCount rdf:type rdf:Property ;
    rdfs:label 'Location Count' ;
    rdfs:comment 'Total number of individual storage locations (bins, slots, shelves, pallet positions) contained within this zone for granular inventory tracking.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextScheduledCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Cycle Count Date' ;
    rdfs:comment 'Planned date for the next physical inventory cycle count in the zone, used for operational planning and resource scheduling.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pickMethod rdf:type rdf:Property ;
    rdfs:label 'Pick Method' ;
    rdfs:comment 'Primary order picking methodology used in the zone, determining workflow design and labor productivity metrics.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rackConfigurationType rdf:type rdf:Property ;
    rdfs:label 'Rack Configuration Type' ;
    rdfs:comment 'Type of racking system installed in the zone, determining storage density, accessibility, and material handling equipment requirements.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Replenishment Priority Rank' ;
    rdfs:comment 'Priority ranking for zone replenishment tasks, with lower numbers indicating higher priority for maintaining forward pick face availability.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Security classification of the zone determining access control requirements, used for high-value merchandise, controlled substances, or restricted inventory.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slottingStrategy rdf:type rdf:Property ;
    rdfs:label 'Slotting Strategy' ;
    rdfs:comment 'Inventory slotting methodology applied to the zone for optimizing pick efficiency, labor productivity, and space utilization.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureClassification rdf:type rdf:Property ;
    rdfs:label 'Temperature Classification' ;
    rdfs:comment 'Temperature control requirement for the zone, critical for grocery retail operations managing perishable goods and food safety compliance.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCapacityCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Cubic Meters' ;
    rdfs:comment 'Total volumetric storage capacity of the zone measured in cubic meters, used for space utilization analysis and capacity planning.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCapacityPalletPositions rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Pallet Positions' ;
    rdfs:comment 'Total number of standard pallet positions available in the zone, critical for slotting optimization and inventory capacity management.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Weight Capacity Kg' ;
    rdfs:comment 'Maximum weight capacity of the zone in kilograms, constrained by floor loading limits and rack weight ratings for safety compliance.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPickEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Pick End Timestamp' ;
    rdfs:comment 'Actual date and time when the last pick task in this wave was completed.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualPickStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Pick Start Timestamp' ;
    rdfs:comment 'Actual date and time when the first pick task in this wave was started by warehouse associates.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignedPickZones rdf:type rdf:Property ;
    rdfs:label 'Assigned Pick Zones' ;
    rdfs:comment 'Comma-separated list of warehouse pick zone identifiers assigned to this wave for zone-based picking strategies.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationLocation rdf:type rdf:Property ;
    rdfs:label 'Consolidation Location' ;
    rdfs:comment 'Warehouse staging area or dock door where picked items from this wave are consolidated for packing and shipping.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationMethod rdf:type rdf:Property ;
    rdfs:label 'Generation Method' ;
    rdfs:comment 'Method used to create this wave: scheduled (time-based automatic), manual (planner-initiated), demand_triggered (order volume threshold), threshold_based (inventory or capacity rule).' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborHoursActual rdf:type rdf:Property ;
    rdfs:label 'Labor Hours Actual' ;
    rdfs:comment 'Actual total labor hours consumed by warehouse associates to complete this wave, measured from task start to completion.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborHoursPlanned rdf:type rdf:Property ;
    rdfs:label 'Labor Hours Planned' ;
    rdfs:comment 'Estimated total labor hours required to complete picking, packing, and staging for this wave, used for workforce scheduling.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickedUnits rdf:type rdf:Property ;
    rdfs:label 'Picked Units' ;
    rdfs:comment 'Actual quantity of units successfully picked and confirmed for this wave.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedPickEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Pick End Timestamp' ;
    rdfs:comment 'Scheduled date and time for picking operations to complete for this wave.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedPickStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Pick Start Timestamp' ;
    rdfs:comment 'Scheduled date and time for picking operations to begin for this wave.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shortShipDisposition rdf:type rdf:Property ;
    rdfs:label 'Short Ship Disposition' ;
    rdfs:comment 'Business rule applied to handle short-picked units: cancel (remove from order), backorder (fulfill later), substitute (offer alternative SKU), split_shipment (ship partial now).' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortUnits rdf:type rdf:Property ;
    rdfs:label 'Short Units' ;
    rdfs:comment 'Quantity of units that could not be picked due to inventory shortage or location discrepancies.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Reference to the wave template configuration that defines the rules and parameters used to generate this wave.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrderLines rdf:type rdf:Property ;
    rdfs:label 'Total Order Lines' ;
    rdfs:comment 'Total count of order line items included in this wave batch for picking.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsPerHour rdf:type rdf:Property ;
    rdfs:label 'Units Per Hour' ;
    rdfs:comment 'Productivity metric calculated as picked_units divided by labor_hours_actual, measuring warehouse picking efficiency.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waveNumber rdf:type rdf:Property ;
    rdfs:label 'Wave Number' ;
    rdfs:comment 'Business-facing wave identifier used for operational tracking and communication across warehouse teams.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveStatus rdf:type rdf:Property ;
    rdfs:label 'Wave Status' ;
    rdfs:comment 'Current lifecycle state of the wave: planned (created but not released), released (available for picking), in-progress (actively being picked), short-closed (closed with shortages), complete (all lines picked), cancelled (wave aborted).' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveType rdf:type rdf:Property ;
    rdfs:label 'Wave Type' ;
    rdfs:comment 'Classification of wave picking strategy: single-order (discrete pick per order), multi-order (batch pick across orders), cluster (cart-based multi-order), zone (pick within assigned zones), wave-less (continuous release), demand-based (dynamic priority-driven release).' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectiveBargainingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Collective Bargaining Agreement Id' ;
    rdfs:comment 'Identifier of the collective bargaining agreement governing the associate\'s terms and conditions of employment. Null for non-union associates. Used for contract compliance and labor cost modeling.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollectiveBargainingAgreement .

ind:badgeNumber rdf:type rdf:Property ;
    rdfs:label 'Badge Number' ;
    rdfs:comment 'Physical badge or access card number used for facility access, time clock punches, and POS system login.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Name of the person to contact in case of workplace emergency or injury. Required for OSHA compliance and duty of care.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'Phone number of the emergency contact person. Required for OSHA compliance and duty of care.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current lifecycle status of the associate\'s employment. Active indicates currently working, leave-of-absence for approved absences (medical, parental, personal), suspended for disciplinary actions, terminated for ended employment.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of employment relationship defining work schedule expectations, benefits eligibility, and labor cost allocation. Full-time typically 35+ hours/week, part-time under 35 hours/week, seasonal for peak periods (holidays, back-to-school), temporary for fixed-duration assignments.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flsaStatus rdf:type rdf:Property ;
    rdfs:label 'Flsa Status' ;
    rdfs:comment 'Classification determining overtime eligibility under FLSA. Exempt employees are salaried and not eligible for overtime; non-exempt employees are eligible for overtime pay at 1.5x regular rate for hours over 40/week.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hrBusinessPartnerName rdf:type rdf:Property ;
    rdfs:label 'Hr Business Partner Name' ;
    rdfs:comment 'Name of the HR business partner assigned to support this associate. Used for HR case routing, employee relations, and policy guidance.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:i9DocumentType rdf:type rdf:Property ;
    rdfs:label 'I9 Document Type' ;
    rdfs:comment 'Type of documentation provided for I-9 verification. Examples: US Passport (List A), Driver\'s License + Social Security Card (List B+C), Permanent Resident Card (List A).' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:i9VerificationDate rdf:type rdf:Property ;
    rdfs:label 'I9 Verification Date' ;
    rdfs:comment 'Date the employer completed Section 2 of Form I-9 verifying the associate\'s identity and employment authorization. Required within 3 business days of hire date.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jobCode rdf:type rdf:Property ;
    rdfs:label 'Job Code' ;
    rdfs:comment 'Standardized code representing the job classification for compensation, workforce planning, and labor reporting. Maps to pay grade and FLSA status.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTrainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Last Training Completion Date' ;
    rdfs:comment 'Date the associate most recently completed a required training program. Used for compliance tracking (safety, harassment prevention, food safety) and skills development monitoring.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalFirstName rdf:type rdf:Property ;
    rdfs:label 'Legal First Name' ;
    rdfs:comment 'Legal first name as recorded on government-issued identification and payroll records. Used for tax reporting, benefits administration, and compliance documentation.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalLastName rdf:type rdf:Property ;
    rdfs:label 'Legal Last Name' ;
    rdfs:comment 'Legal last name (surname) as recorded on government-issued identification and payroll records. Used for tax reporting, benefits administration, and compliance documentation.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalMiddleName rdf:type rdf:Property ;
    rdfs:label 'Legal Middle Name' ;
    rdfs:comment 'Legal middle name or initial as recorded on government-issued identification. Optional field used for formal documentation.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'Compensation band or level within the organization\'s pay structure. Determines salary range or hourly rate range for the position.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payType rdf:type rdf:Property ;
    rdfs:label 'Pay Type' ;
    rdfs:comment 'Compensation structure indicating whether the associate is paid based on hours worked (hourly) or a fixed annual salary (salaried).' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'Name the associate prefers to be called in day-to-day work interactions. Used for name badges, internal communications, and scheduling displays.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryWorkLocationType rdf:type rdf:Property ;
    rdfs:label 'Primary Work Location Type' ;
    rdfs:comment 'Classification of the associate\'s primary work location. Used for labor cost allocation, workforce planning, and facility capacity management.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rehireEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rehire Eligible Flag' ;
    rdfs:comment 'Indicator of whether the associate is eligible for rehire based on their employment history and termination circumstances. True indicates eligible, False indicates not eligible.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Standard Hours Per Week' ;
    rdfs:comment 'Expected number of hours the associate is scheduled to work per week under normal conditions. Used for labor planning, benefits eligibility determination, and FTE calculations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionLocalCode rdf:type rdf:Property ;
    rdfs:label 'Union Local Code' ;
    rdfs:comment 'Identifier of the local union chapter to which the associate belongs. Null for non-union associates. Used for dues deduction, grievance processing, and contract administration.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionMembershipFlag rdf:type rdf:Property ;
    rdfs:label 'Union Membership Flag' ;
    rdfs:comment 'Indicator of whether the associate is a member of a labor union. True indicates union member, False indicates non-union. Used for collective bargaining compliance and labor relations reporting.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workAuthorizationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Expiration Date' ;
    rdfs:comment 'Expiration date of work authorization documentation for non-citizens. Null for citizens and permanent residents. Used to trigger reverification requirements.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Status' ;
    rdfs:comment 'Legal authorization status for employment in the jurisdiction. Used for I-9 compliance verification and work eligibility tracking.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayWorkerCode rdf:type rdf:Property ;
    rdfs:label 'Workday Worker Code' ;
    rdfs:comment 'External unique identifier from Workday HCM system. Golden record reference for workforce data integration.' ;
    rdfs:domain ind:Associate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Benefit Enrollment Id' ;
    rdfs:comment 'Unique identifier for the benefit enrollment record. Primary key for the benefit enrollment entity.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jobProfileId rdf:type rdf:Property ;
    rdfs:label 'Job Profile Id' ;
    rdfs:comment 'Foreign key linking to workforce.job_profile. Business justification: Benefit eligibility rules and plan offerings vary by job classification (full-time vs part-time, executive vs hourly, union vs non-union). Linking benefit_enrollment to job_profile enables benefits ad' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobProfile .

ind:aca1095cOfferCode rdf:type rdf:Property ;
    rdfs:label 'Aca 1095c Offer Code' ;
    rdfs:comment 'The IRS code indicating the type of health coverage offered to the employee for ACA reporting. Examples: 1A (qualifying offer), 1B (employee only), 1C (employee and dependents), 1E (no offer). Required for annual 1095-C filing.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aca1095cSafeHarborCode rdf:type rdf:Property ;
    rdfs:label 'Aca 1095c Safe Harbor Code' ;
    rdfs:comment 'The IRS code indicating the safe harbor method used to determine ACA affordability. Examples: 2A (W-2 wages), 2B (rate of pay), 2C (federal poverty line). Used to avoid employer shared responsibility penalties.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acaEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Aca Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for ACA-compliant health coverage based on full-time equivalent (FTE) hours worked during the measurement period. True if employee averaged 30+ hours per week. Used for 1095-C reporting.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acaMeasurementPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Aca Measurement Period End' ;
    rdfs:comment 'The end date of the measurement period used to determine ACA eligibility. Follows the start date by 12 months for standard measurement periods.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acaMeasurementPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Aca Measurement Period Start' ;
    rdfs:comment 'The start date of the measurement period used to determine ACA eligibility. Typically a 12-month lookback period (e.g., October 1 to September 30) used to calculate average hours worked.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acaStabilityPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Aca Stability Period End' ;
    rdfs:comment 'The end date of the stability period during which the employee\'s ACA eligibility determination remains in effect. Typically December 31 of the plan year.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acaStabilityPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Aca Stability Period Start' ;
    rdfs:comment 'The start date of the stability period during which the employee\'s ACA eligibility determination remains in effect. Typically follows the measurement period and aligns with the plan year (e.g., January 1).' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualElectionAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Election Amount' ;
    rdfs:comment 'For benefits with annual election limits (FSA, HSA, 401k), this is the total amount the employee elected to contribute for the plan year. Subject to IRS annual limits. Nullable for benefits without annual elections.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Name' ;
    rdfs:comment 'The full legal name of the primary beneficiary designated for life insurance or retirement benefits. Nullable for benefits without beneficiary designations (e.g., health insurance). Contains personally identifiable information.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryRelationship rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Relationship' ;
    rdfs:comment 'The relationship of the designated beneficiary to the employee. Used for life insurance and retirement plan beneficiary designations. Not applicable for health benefits. [ENUM-REF-CANDIDATE: spouse|child|parent|sibling|domestic_partner|other|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitType rdf:type rdf:Property ;
    rdfs:label 'Benefit Type' ;
    rdfs:comment 'Category of benefit plan enrolled. Includes medical, dental, vision, 401k retirement, FSA (Flexible Spending Account), HSA (Health Savings Account), life insurance, disability, ESPP (Employee Stock Purchase Plan), and commuter benefits. [ENUM-REF-CANDIDATE: medical|dental|vision|life_insurance|disability|401k|fsa|hsa|espp|commuter|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Policy Number' ;
    rdfs:comment 'The policy or group number assigned by the insurance carrier or benefit provider. Used for claims processing and coordination of benefits. Nullable for self-insured plans or benefits without external carriers.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobraEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Cobra Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for COBRA continuation coverage upon termination of employment or loss of coverage. True if the employee was enrolled in a group health plan and experienced a qualifying event.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'The level of coverage elected by the employee. Determines premium rates and dependent coverage. Not applicable for non-health benefits like 401k or FSA.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Amount' ;
    rdfs:comment 'The per-pay-period amount deducted from the employee\'s paycheck for this benefit. For percentage-based contributions (e.g., 401k), this is the dollar amount per pay period, not the percentage. Currency is USD unless otherwise specified in organizational standards.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employeeContributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Frequency' ;
    rdfs:comment 'The frequency at which employee contributions are deducted from payroll. Aligns with the organization\'s payroll schedule. Per pay period is the most common for retail associates with varying schedules.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Amount' ;
    rdfs:comment 'The per-pay-period amount contributed by the employer toward this benefit. For 401k, this may include employer match. For health insurance, this is the employer subsidy. Currency is USD unless otherwise specified.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Frequency' ;
    rdfs:comment 'The frequency at which employer contributions are made toward this benefit. Typically aligns with payroll frequency.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Confirmation Number' ;
    rdfs:comment 'A unique confirmation or transaction number generated when the employee completes the enrollment process. Used for audit trail and employee inquiries. May be system-generated or carrier-provided.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Effective Date' ;
    rdfs:comment 'The date on which the benefit coverage begins. For new hires, typically the hire date or first of the month following hire. For open enrollment, typically January 1st of the plan year.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentMethod rdf:type rdf:Property ;
    rdfs:label 'Enrollment Method' ;
    rdfs:comment 'The channel or method through which the employee completed the benefit enrollment. Online self-service is the most common for retail employees. Auto-enrollment applies to default 401k enrollments under safe harbor provisions.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Termination Date' ;
    rdfs:comment 'The date on which the benefit coverage ends. Nullable for active enrollments. Populated upon employee termination, plan change, or voluntary cancellation. For COBRA purposes, typically the last day of the month of termination.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planYear rdf:type rdf:Property ;
    rdfs:label 'Plan Year' ;
    rdfs:comment 'The calendar year for which this benefit enrollment is effective. Typically aligns with open enrollment periods and ACA measurement periods.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingLifeEventDate rdf:type rdf:Property ;
    rdfs:label 'Qualifying Life Event Date' ;
    rdfs:comment 'The date on which the qualifying life event occurred. Used to validate the 30-day or 60-day election window for mid-year changes. Nullable if not applicable.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingLifeEventType rdf:type rdf:Property ;
    rdfs:label 'Qualifying Life Event Type' ;
    rdfs:comment 'The specific type of qualifying life event that permitted mid-year enrollment change. Only populated when enrollment_source is qualifying_life_event. Examples include marriage, divorce, birth of child, adoption, death of dependent, loss of other coverage, or change in employment status. [ENUM-REF-CANDIDATE: marriage|divorce|birth|adoption|death|loss_of_coverage|employment_change|other|not_applicable — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The unique identifier for this enrollment record in the source system (e.g., Workday HCM). Used for reconciliation, data lineage, and troubleshooting. Enables traceability back to the operational system.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Total Premium Amount' ;
    rdfs:comment 'The total per-pay-period cost of the benefit, combining employee and employer contributions. Used for ACA affordability calculations and financial reporting. Currency is USD unless otherwise specified.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationChangeId rdf:type rdf:Property ;
    rdfs:label 'Compensation Change Id' ;
    rdfs:comment 'Unique identifier for the compensation change event. Primary key for the compensation change data product.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:meritCycleId rdf:type rdf:Property ;
    rdfs:label 'Merit Cycle Id' ;
    rdfs:comment 'Unique identifier of the annual merit review cycle during which this compensation change was processed. Null for off-cycle changes such as promotions or market adjustments.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeritCycle .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Foreign key linking to workforce.performance_review. Business justification: Merit increases are tied to performance review outcomes. The compensation_change table has performance_rating and merit_cycle_id attributes; linking to performance_review creates an audit trail from p' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceReview .

ind:primaryCompensationAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Compensation Associate Id' ;
    rdfs:comment 'Unique identifier of the employee receiving the compensation change. Links to the employee master record in Workday HCM.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:quaternaryCompensationModifiedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Compensation Modified By User Associate Id' ;
    rdfs:comment 'The system user ID or service account that last modified this compensation change record. Used for audit trail and data governance.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:tertiaryCompensationHrApproverAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Compensation Hr Approver Associate Id' ;
    rdfs:comment 'Unique identifier of the HR business partner or compensation analyst who reviewed and approved this compensation change.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:budgetImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Impact Amount' ;
    rdfs:comment 'The annualized financial impact of this compensation change on the department or cost center budget. Calculated based on the pay rate change and the employee\'s standard hours per year.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Change Effective Date' ;
    rdfs:comment 'The date on which the compensation change becomes effective and is reflected in payroll processing. This is the business event date for the compensation adjustment.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Detailed business justification for the compensation change. Provides context beyond the change type, such as specific performance achievements, market benchmarking results, or organizational restructuring rationale.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compaRatioAfter rdf:type rdf:Property ;
    rdfs:label 'Compa Ratio After' ;
    rdfs:comment 'The employee\'s compensation ratio (actual pay divided by pay grade midpoint) after this change takes effect. Used to ensure the new pay rate is within acceptable range for the grade.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compaRatioBefore rdf:type rdf:Property ;
    rdfs:label 'Compa Ratio Before' ;
    rdfs:comment 'The employee\'s compensation ratio (actual pay divided by pay grade midpoint) before this change. A compa-ratio of 1.00 means the employee is paid at the midpoint of their grade. Used to assess pay equity and positioning within grade.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hrApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Hr Approval Status' ;
    rdfs:comment 'Current approval status of the compensation change in the HR workflow. Pending: awaiting HR review. Approved: HR has approved and change will be processed. Rejected: HR denied the change. Cancelled: change request was withdrawn.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLumpSum rdf:type rdf:Property ;
    rdfs:label 'Is Lump Sum' ;
    rdfs:comment 'Indicates whether this compensation change includes a one-time lump sum payment in addition to or instead of a base pay rate increase. True if lump sum is included, False if only base pay rate change.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRetroactive rdf:type rdf:Property ;
    rdfs:label 'Is Retroactive' ;
    rdfs:comment 'Indicates whether this compensation change includes retroactive pay for a period prior to the change effective date. True if retroactive pay is owed, False otherwise.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lumpSumAmount rdf:type rdf:Property ;
    rdfs:label 'Lump Sum Amount' ;
    rdfs:comment 'The one-time lump sum payment amount awarded as part of this compensation change. Null if no lump sum is included. Used for merit bonuses or retention payments that do not increase base pay.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newPayGrade rdf:type rdf:Property ;
    rdfs:label 'New Pay Grade' ;
    rdfs:comment 'The employee\'s pay grade or salary band after this compensation change takes effect. Used to track career progression and ensure pay equity within grade ranges.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newPayRate rdf:type rdf:Property ;
    rdfs:label 'New Pay Rate' ;
    rdfs:comment 'The employee\'s base pay rate after this compensation change event takes effect. Expressed in the currency and frequency defined in the employee\'s job profile.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payFrequency rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency' ;
    rdfs:comment 'The frequency at which the employee is paid, defining the time unit for the pay rate. Hourly: rate per hour. Weekly: rate per week. Biweekly: rate per two weeks. Semimonthly: rate per half month. Monthly: rate per month. Annual: rate per year.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payRateChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Change Amount' ;
    rdfs:comment 'The absolute monetary difference between the new pay rate and the previous pay rate. Calculated as new_pay_rate minus previous_pay_rate. May be negative for demotions.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRateChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Change Percentage' ;
    rdfs:comment 'The percentage change in pay rate, calculated as (pay_rate_change_amount / previous_pay_rate) * 100. Used for merit budget tracking and compensation analysis.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousPayGrade rdf:type rdf:Property ;
    rdfs:label 'Previous Pay Grade' ;
    rdfs:comment 'The employee\'s pay grade or salary band immediately prior to this compensation change. Pay grades define the compensation range for a given job level.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousPayRate rdf:type rdf:Property ;
    rdfs:label 'Previous Pay Rate' ;
    rdfs:comment 'The employee\'s base pay rate immediately prior to this compensation change event. Expressed in the currency and frequency defined in the employee\'s job profile.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retroactiveAmount rdf:type rdf:Property ;
    rdfs:label 'Retroactive Amount' ;
    rdfs:comment 'The total retroactive pay amount owed to the employee for the period between the retroactive start date and the change effective date. Null if the change is not retroactive.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retroactiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Retroactive Start Date' ;
    rdfs:comment 'The start date of the period for which retroactive pay is calculated. Null if the change is not retroactive. Used to calculate back pay owed to the employee.' ;
    rdfs:domain ind:CompensationChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'The date and time when the compensation change request was initially submitted into the Workday HCM system for approval workflow.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:jobApplicationId rdf:type rdf:Property ;
    rdfs:label 'Job Application Id' ;
    rdfs:comment 'Unique identifier for the job application record. Primary key for the job application entity.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:candidateId rdf:type rdf:Property ;
    rdfs:label 'Candidate Id' ;
    rdfs:comment 'Reference to the candidate master record who submitted this application. A single candidate may have multiple applications over time.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Candidate .

ind:primaryJobAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Job Associate Id' ;
    rdfs:comment 'Reference to the HR recruiter or talent acquisition specialist assigned to manage this application and coordinate the hiring process.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:requisitionId rdf:type rdf:Property ;
    rdfs:label 'Requisition Id' ;
    rdfs:comment 'Reference to the open job requisition for which this application was submitted. Links to the job posting and hiring requirements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requisition .

ind:tertiaryJobModifiedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Job Modified By User Associate Id' ;
    rdfs:comment 'User ID of the recruiter or system user who last modified the application record. Used for audit trail and accountability.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'The date when the candidate submitted the application. Used to calculate time-to-hire and track recruiting funnel velocity.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationNotes rdf:type rdf:Property ;
    rdfs:label 'Application Notes' ;
    rdfs:comment 'Free-text notes and comments from recruiters, hiring managers, and interviewers regarding the candidate and application. Used to document interview feedback and hiring decisions.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Human-readable business identifier for the application, typically displayed to candidates and hiring managers. Format: APP-########.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle status of the application in the recruiting workflow. Tracks progression from initial submission through final disposition. [ENUM-REF-CANDIDATE: applied|screening|phone_screen|interview|offer|hired|rejected|withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Date' ;
    rdfs:comment 'Date when the background check was completed. Used to track pre-employment screening cycle time and ensure timely onboarding.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backgroundCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Background Check Status' ;
    rdfs:comment 'Current status of the pre-employment background check. Required for most retail positions to ensure workplace safety and regulatory compliance.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Disability Status' ;
    rdfs:comment 'Self-reported disability status of the candidate. Collected voluntarily for OFCCP compliance reporting and diversity analytics. Kept confidential from hiring managers.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugScreenDate rdf:type rdf:Property ;
    rdfs:label 'Drug Screen Date' ;
    rdfs:comment 'Date when the drug screening test was completed. Used to track pre-employment screening compliance and onboarding readiness.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drugScreenStatus rdf:type rdf:Property ;
    rdfs:label 'Drug Screen Status' ;
    rdfs:comment 'Current status of the pre-employment drug screening test. Required for safety-sensitive positions such as distribution center equipment operators and drivers.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewCount rdf:type rdf:Property ;
    rdfs:label 'Interview Count' ;
    rdfs:comment 'Total number of interviews conducted for this application. Used to analyze interview process efficiency and candidate experience.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewStage rdf:type rdf:Property ;
    rdfs:label 'Interview Stage' ;
    rdfs:comment 'Current interview stage or round (e.g., Phone Screen, First Interview, Panel Interview, Final Interview). Tracks candidate progression through multi-stage interview processes.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isInternalCandidate rdf:type rdf:Property ;
    rdfs:label 'Is Internal Candidate' ;
    rdfs:comment 'Indicates whether the candidate is a current employee applying for an internal transfer or promotion. True for internal candidates, False for external candidates.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRehire rdf:type rdf:Property ;
    rdfs:label 'Is Rehire' ;
    rdfs:comment 'Indicates whether the candidate is a former employee applying to return to the company. True for rehire candidates, False otherwise.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInterviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Interview Date' ;
    rdfs:comment 'Date of the most recent interview conducted with the candidate. Used to track time between interview stages and overall process velocity.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Offer Acceptance Date' ;
    rdfs:comment 'Date when the candidate formally accepted the job offer. Used to calculate offer-to-acceptance time and plan onboarding.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Offer Accepted Flag' ;
    rdfs:comment 'Indicates whether the candidate accepted the job offer. True if accepted, False if declined or pending.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offerAmount rdf:type rdf:Property ;
    rdfs:label 'Offer Amount' ;
    rdfs:comment 'The total compensation amount offered to the candidate, typically annual salary for salaried positions or hourly rate for hourly positions. Used for compensation benchmarking and budget planning.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offerCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Offer Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the offer amount (e.g., USD, CAD, MXN). Supports multi-country recruiting operations.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerDate rdf:type rdf:Property ;
    rdfs:label 'Offer Date' ;
    rdfs:comment 'Date when the job offer was formally extended to the candidate. Used to calculate time-to-offer and offer acceptance cycle time.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerExtendedFlag rdf:type rdf:Property ;
    rdfs:label 'Offer Extended Flag' ;
    rdfs:comment 'Indicates whether a formal job offer has been extended to the candidate. True if offer was made, False otherwise.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'The channel or medium through which the candidate discovered and applied for the position. Used to calculate CAC (Candidate Acquisition Cost) by channel and optimize recruiting spend.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDetail rdf:type rdf:Property ;
    rdfs:label 'Source Detail' ;
    rdfs:comment 'Additional detail about the application source, such as specific job board name (Indeed, LinkedIn), referrer employee ID, or agency name. Enables granular source attribution analysis.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeToHireDays rdf:type rdf:Property ;
    rdfs:label 'Time To Hire Days' ;
    rdfs:comment 'Number of calendar days from application submission to hire date. Key recruiting efficiency KPI used to optimize talent acquisition processes and reduce vacancy costs.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:veteranStatus rdf:type rdf:Property ;
    rdfs:label 'Veteran Status' ;
    rdfs:comment 'Self-reported veteran status of the candidate. Collected for OFCCP compliance reporting and veteran hiring program tracking.' ;
    rdfs:domain ind:JobApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eeocJobCategory rdf:type rdf:Property ;
    rdfs:label 'Eeoc Job Category' ;
    rdfs:comment 'Standard EEOC job category classification for this profile (e.g., Executive/Senior Level Officials and Managers, Professionals, Sales Workers, Service Workers). Used for EEO-1 reporting and compliance.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flsaClassification rdf:type rdf:Property ;
    rdfs:label 'Flsa Classification' ;
    rdfs:comment 'Classification under the Fair Labor Standards Act indicating whether the role is exempt or non-exempt from overtime pay requirements. Critical for payroll and labor cost compliance.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBonusEligible rdf:type rdf:Property ;
    rdfs:label 'Is Bonus Eligible' ;
    rdfs:comment 'Boolean flag indicating whether this role is eligible for performance-based bonuses or incentive compensation. Used for total compensation planning and performance management.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCommissionEligible rdf:type rdf:Property ;
    rdfs:label 'Is Commission Eligible' ;
    rdfs:comment 'Boolean flag indicating whether this role is eligible for sales commission or variable compensation based on sales performance. Used for sales compensation planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCorporate rdf:type rdf:Property ;
    rdfs:label 'Is Corporate' ;
    rdfs:comment 'Boolean flag indicating whether this role is a corporate or headquarters position. Used for organizational structure reporting and overhead cost allocation.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCustomerFacing rdf:type rdf:Property ;
    rdfs:label 'Is Customer Facing' ;
    rdfs:comment 'Boolean flag indicating whether this role involves direct interaction with customers (e.g., sales associates, customer service representatives). Used for customer experience planning and training programs.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDcFacing rdf:type rdf:Property ;
    rdfs:label 'Is Dc Facing' ;
    rdfs:comment 'Boolean flag indicating whether this role is primarily assigned to distribution center or warehouse locations. Used for supply chain workforce planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeadershipRole rdf:type rdf:Property ;
    rdfs:label 'Is Leadership Role' ;
    rdfs:comment 'Boolean flag indicating whether this job profile is a leadership or management position with direct reports. Used for leadership development programs and organizational structure analysis.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOvertimeEligible rdf:type rdf:Property ;
    rdfs:label 'Is Overtime Eligible' ;
    rdfs:comment 'Boolean flag indicating whether this role is eligible for overtime pay. Typically aligns with FLSA non-exempt classification. Used for payroll and labor cost forecasting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStoreFacing rdf:type rdf:Property ;
    rdfs:label 'Is Store Facing' ;
    rdfs:comment 'Boolean flag indicating whether this role is primarily assigned to retail store locations. Used for store headcount planning and labor cost allocation.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnionEligible rdf:type rdf:Property ;
    rdfs:label 'Is Union Eligible' ;
    rdfs:comment 'Boolean flag indicating whether this job profile is eligible for union membership or collective bargaining representation. Used for labor relations and compliance reporting.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobDescription rdf:type rdf:Property ;
    rdfs:label 'Job Description' ;
    rdfs:comment 'Detailed narrative description of the job profile including responsibilities, duties, and expectations. Used for job postings, performance management, and organizational documentation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobFamily rdf:type rdf:Property ;
    rdfs:label 'Job Family' ;
    rdfs:comment 'Broad occupational grouping that categorizes similar roles together (e.g., Retail Operations, Supply Chain, Finance, Technology, Merchandising). Used for career pathing and talent development.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobLevel rdf:type rdf:Property ;
    rdfs:label 'Job Level' ;
    rdfs:comment 'Hierarchical level or grade of the job within the organization (e.g., Entry Level, Mid-Level, Senior, Manager, Director, Executive). Used for compensation planning and organizational structure.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobProfileStatus rdf:type rdf:Property ;
    rdfs:label 'Job Profile Status' ;
    rdfs:comment 'Current lifecycle status of the job profile. Active profiles are available for hiring and assignment; inactive profiles are no longer used but retained for historical reporting.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPayRange rdf:type rdf:Property ;
    rdfs:label 'Maximum Pay Range' ;
    rdfs:comment 'Maximum annual or hourly compensation for this job profile. Used for compensation benchmarking, offer generation, and pay equity analysis.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPayRange rdf:type rdf:Property ;
    rdfs:label 'Minimum Pay Range' ;
    rdfs:comment 'Minimum annual or hourly compensation for this job profile. Used for compensation benchmarking, offer generation, and pay equity analysis.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumYearsExperience rdf:type rdf:Property ;
    rdfs:label 'Minimum Years Experience' ;
    rdfs:comment 'Minimum number of years of relevant work experience required for this job profile. Used for talent acquisition and career progression planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onetCode rdf:type rdf:Property ;
    rdfs:label 'Onet Code' ;
    rdfs:comment 'Standard occupational classification code from the O*NET database maintained by the U.S. Department of Labor. Used for labor market analysis, compensation benchmarking, and skills mapping.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalRequirements rdf:type rdf:Property ;
    rdfs:label 'Physical Requirements' ;
    rdfs:comment 'Description of physical demands and requirements for this job profile (e.g., ability to lift 50 lbs, prolonged standing, repetitive motion). Used for OSHA compliance, ADA accommodations, and safety planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCertifications rdf:type rdf:Property ;
    rdfs:label 'Required Certifications' ;
    rdfs:comment 'List of professional certifications, licenses, or credentials required for this job profile (e.g., forklift operator license, pharmacy technician license, food safety certification). Used for talent acquisition and compliance tracking.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Required Education Level' ;
    rdfs:comment 'Minimum education level required for this job profile. Used for talent acquisition screening and workforce development planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spanOfControlMax rdf:type rdf:Property ;
    rdfs:label 'Span Of Control Max' ;
    rdfs:comment 'Maximum number of direct reports typically managed by this role. Used for organizational design and management capacity planning. Null for individual contributor roles.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spanOfControlMin rdf:type rdf:Property ;
    rdfs:label 'Span Of Control Min' ;
    rdfs:comment 'Minimum number of direct reports typically managed by this role. Used for organizational design and management capacity planning. Null for individual contributor roles.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:successionPlanningTier rdf:type rdf:Property ;
    rdfs:label 'Succession Planning Tier' ;
    rdfs:comment 'Classification indicating the importance of this role for succession planning and talent pipeline development. Critical roles require active succession plans and talent bench strength.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelRequirementPercentage rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement Percentage' ;
    rdfs:comment 'Expected percentage of time this role requires business travel. Used for expense planning and candidate expectations management.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborBudgetId rdf:type rdf:Property ;
    rdfs:label 'Labor Budget Id' ;
    rdfs:comment 'Unique identifier for the labor budget record. Primary key for the labor budget entity.' ;
    rdfs:domain ind:LaborBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLaborAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Labor Associate Id' ;
    rdfs:comment 'Reference to the employee responsible for creating and maintaining this labor budget plan. Establishes accountability for workforce planning.' ;
    rdfs:domain ind:LaborBudget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:tertiaryLaborModifiedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Labor Modified By User Associate Id' ;
    rdfs:comment 'Identifier of the user who last modified this labor budget record. Provides accountability for data changes.' ;
    rdfs:domain ind:LaborBudget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:attritionAssumptionPercent rdf:type rdf:Property ;
    rdfs:label 'Attrition Assumption Percent' ;
    rdfs:comment 'Assumed employee attrition rate as a percentage for the planning period. Used to calculate net new hire targets and workforce replacement needs.' ;
    rdfs:domain ind:LaborBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetNotes rdf:type rdf:Property ;
    rdfs:label 'Budget Notes' ;
    rdfs:comment 'Free-text notes and comments regarding this labor budget. Captures planning assumptions, business justifications, and special considerations.' ;
    rdfs:domain ind:LaborBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersionCode rdf:type rdf:Property ;
    rdfs:label 'Budget Version Code' ;
    rdfs:comment 'Version status of the labor budget indicating the stage in the planning cycle. Tracks progression from baseline through final approved budget.' ;
    rdfs:domain ind:LaborBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetedLaborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Budgeted Labor Cost Amount' ;
    rdfs:comment 'Total budgeted labor cost in dollars for the planning period. Includes wages, overtime premiums, and shift differentials. Used for financial planning and variance analysis.' ;
    rdfs:domain ind:LaborBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedLaborCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budgeted Labor Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the budgeted labor cost amount. Supports multi-currency financial planning for international operations.' ;
    rdfs:domain ind:LaborBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetedLaborCostPercentOfSales rdf:type rdf:Property ;
    rdfs:label 'Budgeted Labor Cost Percent Of Sales' ;
    rdfs:comment 'Budgeted labor cost expressed as a percentage of forecasted sales revenue. Key performance indicator (KPI) for labor productivity and operational efficiency.' ;
    rdfs:domain ind:LaborBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedOvertimeHours rdf:type rdf:Property ;
    rdfs:label 'Budgeted Overtime Hours' ;
    rdfs:comment 'Total planned overtime hours for the planning period. Used for labor cost variance analysis and operational efficiency monitoring.' ;
    rdfs:domain ind:LaborBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedRegularHours rdf:type rdf:Property ;
    rdfs:label 'Budgeted Regular Hours' ;
    rdfs:comment 'Total planned regular work hours for the planning period. Excludes overtime and forms the basis for labor cost calculations.' ;
    rdfs:domain ind:LaborBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalTransferAssumption rdf:type rdf:Property ;
    rdfs:label 'Internal Transfer Assumption' ;
    rdfs:comment 'Assumed number of internal employee transfers into or out of this location or department during the planning period. Supports workforce mobility planning.' ;
    rdfs:domain ind:LaborBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netNewHireTarget rdf:type rdf:Property ;
    rdfs:label 'Net New Hire Target' ;
    rdfs:comment 'Target number of net new hires required for the planning period after accounting for attrition. Drives talent acquisition planning and requisition authorization.' ;
    rdfs:domain ind:LaborBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedFteCount rdf:type rdf:Property ;
    rdfs:label 'Planned Fte Count' ;
    rdfs:comment 'Planned full-time equivalent headcount for the planning period. Represents the total workforce capacity normalized to full-time hours.' ;
    rdfs:domain ind:LaborBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedFullTimeHeadcount rdf:type rdf:Property ;
    rdfs:label 'Planned Full Time Headcount' ;
    rdfs:comment 'Number of planned full-time employees for the planning period. Used for headcount capacity planning and requisition authorization.' ;
    rdfs:domain ind:LaborBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedPartTimeHeadcount rdf:type rdf:Property ;
    rdfs:label 'Planned Part Time Headcount' ;
    rdfs:comment 'Number of planned part-time employees for the planning period. Supports flexible staffing models and labor cost optimization.' ;
    rdfs:domain ind:LaborBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedSeasonalHeadcount rdf:type rdf:Property ;
    rdfs:label 'Planned Seasonal Headcount' ;
    rdfs:comment 'Number of planned seasonal or temporary employees for the planning period. Critical for seasonal workforce ramp planning during peak periods.' ;
    rdfs:domain ind:LaborBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaveRequestId rdf:type rdf:Property ;
    rdfs:label 'Leave Request Id' ;
    rdfs:comment 'Unique identifier for the leave request record. Primary key for the leave request entity.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLeaveAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Leave Associate Id' ;
    rdfs:comment 'Unique identifier of the employee submitting the leave request. Links to the employee master record in Workday HCM.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:shiftScheduleId rdf:type rdf:Property ;
    rdfs:label 'Shift Schedule Id' ;
    rdfs:comment 'Foreign key linking to workforce.shift_schedule. Business justification: Leave requests impact scheduled shifts and require coverage planning. When an associate requests leave, workforce scheduling systems need to identify which specific shifts are affected to trigger cove' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftSchedule .

ind:tertiaryLeaveHrReviewerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Leave Hr Reviewer Associate Id' ;
    rdfs:comment 'Unique identifier of the HR representative who reviewed the leave request. Links to the employee master record. Used for compliance audit trail and case management.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:workLocationId rdf:type rdf:Property ;
    rdfs:label 'Work Location Id' ;
    rdfs:comment 'Unique identifier of the employee\'s primary work location (store, distribution center, or corporate office) at the time of leave request. Used for workforce planning, coverage scheduling, and regional compliance reporting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:actualReturnDate rdf:type rdf:Property ;
    rdfs:label 'Actual Return Date' ;
    rdfs:comment 'The actual date the employee returned to work, as recorded in time and attendance systems. May differ from scheduled return to work date if leave was extended or employee returned early. Used for compliance tracking and leave reconciliation.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalComments rdf:type rdf:Property ;
    rdfs:label 'Approval Comments' ;
    rdfs:comment 'Free-text comments or notes entered by the approving manager or HR during the approval process. May include reasons for denial, conditions of approval, or special instructions.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedEndDate rdf:type rdf:Property ;
    rdfs:label 'Approved End Date' ;
    rdfs:comment 'The last date of absence as approved by the manager or HR. May differ from requested end date if the request was modified during approval process. May be null for open-ended or intermittent leave.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedStartDate rdf:type rdf:Property ;
    rdfs:label 'Approved Start Date' ;
    rdfs:comment 'The first date of absence as approved by the manager or HR. May differ from requested start date if the request was modified during approval process.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fmlaDesignationStatus rdf:type rdf:Property ;
    rdfs:label 'Fmla Designation Status' ;
    rdfs:comment 'Indicates whether the leave has been officially designated as FMLA-qualifying by HR. Not Applicable for non-FMLA leave types, Pending for under review, Designated for confirmed FMLA protection, Not Designated for ineligible requests.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmlaEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fmla Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for FMLA protection for this leave request. True if the employee meets FMLA eligibility criteria (12 months tenure, 1250 hours worked, employer size). Used for compliance reporting and employee rights protection.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hrReviewDate rdf:type rdf:Property ;
    rdfs:label 'Hr Review Date' ;
    rdfs:comment 'Date when the HR review was completed. Used for compliance tracking and SLA monitoring.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hrReviewNotes rdf:type rdf:Property ;
    rdfs:label 'Hr Review Notes' ;
    rdfs:comment 'Confidential notes entered by HR during the review process. May include compliance assessments, accommodation considerations, or legal consultation notes. Restricted access for HR personnel only.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hrReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Hr Review Status' ;
    rdfs:comment 'Indicates whether HR review is required and the current state of that review. Not Required for standard leave, Pending for awaiting HR input, Reviewed for completed HR assessment, Escalated for complex cases requiring senior HR intervention.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermittentLeaveFlag rdf:type rdf:Property ;
    rdfs:label 'Intermittent Leave Flag' ;
    rdfs:comment 'Indicates whether this is an intermittent leave request (sporadic absences rather than continuous block). True for intermittent FMLA, chronic condition management, or flexible leave arrangements. Affects scheduling and leave balance tracking.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaveBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Leave Balance After' ;
    rdfs:comment 'Employee\'s projected leave balance (in hours or days) after this leave request is approved and processed. Calculated as balance before minus approved hours/days. Used for employee self-service visibility and planning.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Leave Balance Before' ;
    rdfs:comment 'Employee\'s available leave balance (in hours or days) before this leave request is processed. Used for validation that sufficient balance exists and for audit trail of balance changes.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveReason rdf:type rdf:Property ;
    rdfs:label 'Leave Reason' ;
    rdfs:comment 'Free-text explanation or justification for the leave request provided by the employee. May contain sensitive personal or medical information. Used for HR review and compliance documentation.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Leave Request Number' ;
    rdfs:comment 'Human-readable business identifier for the leave request, typically generated by Workday HCM Absence Management module. Used for tracking and reference in HR communications.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveSubtype rdf:type rdf:Property ;
    rdfs:label 'Leave Subtype' ;
    rdfs:comment 'Detailed classification within the leave type. For example, FMLA may have subtypes like Birth/Adoption, Serious Health Condition, Military Caregiver. Provides granular categorization for compliance and reporting.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveType rdf:type rdf:Property ;
    rdfs:label 'Leave Type' ;
    rdfs:comment 'Category of leave being requested. PTO (Paid Time Off) for vacation, Sick for illness, FMLA (Family and Medical Leave Act) for qualifying medical/family reasons, Bereavement for family death, Jury Duty for court service, Military for service obligations, Personal for other approved absences. [ENUM-REF-CANDIDATE: PTO|Sick|FMLA|Bereavement|Jury Duty|Military|Personal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalCertificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Medical Certification Due Date' ;
    rdfs:comment 'Deadline by which medical certification must be submitted to HR. Typically 15 calendar days from leave request submission per FMLA regulations. Used for compliance tracking and employee notification.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalCertificationReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Certification Received Flag' ;
    rdfs:comment 'Indicates whether required medical certification has been received and validated by HR. True when documentation is on file and approved. Used for compliance audit trail and approval workflow gating.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Certification Required Flag' ;
    rdfs:comment 'Indicates whether medical certification documentation is required for this leave request. True for FMLA, medical leave, or extended sick leave requiring physician documentation. Used for compliance enforcement and case management.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paidLeaveFlag rdf:type rdf:Property ;
    rdfs:label 'Paid Leave Flag' ;
    rdfs:comment 'Indicates whether the leave is paid (using accrued PTO balance or paid leave benefits) or unpaid. True for paid leave, False for unpaid leave. Affects payroll processing and leave balance deductions.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reducedScheduleFlag rdf:type rdf:Property ;
    rdfs:label 'Reduced Schedule Flag' ;
    rdfs:comment 'Indicates whether this leave involves a reduced work schedule (working fewer hours per day or days per week) rather than full absence. True for part-time return-to-work arrangements or phased leave. Used for scheduling and labor cost allocation.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Submitted Timestamp' ;
    rdfs:comment 'Date and time when the leave request was originally submitted by the employee through Workday HCM self-service. Used for SLA tracking, audit trail, and advance notice compliance.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedEndDate rdf:type rdf:Property ;
    rdfs:label 'Requested End Date' ;
    rdfs:comment 'The last date of absence requested by the employee. Represents the end of the leave period as initially submitted. May be null for open-ended or intermittent leave.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedStartDate rdf:type rdf:Property ;
    rdfs:label 'Requested Start Date' ;
    rdfs:comment 'The first date of absence requested by the employee. Represents the beginning of the leave period as initially submitted.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnToWorkDate rdf:type rdf:Property ;
    rdfs:label 'Return To Work Date' ;
    rdfs:comment 'The date the employee is scheduled to return to work following the leave. May be the day after approved end date or a later date for extended leave. Used for workforce planning and scheduling.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalDaysApproved rdf:type rdf:Property ;
    rdfs:label 'Total Days Approved' ;
    rdfs:comment 'Total number of calendar or business days approved by the manager or HR for this leave. May differ from total days requested if the request was partially approved or modified. May include partial days for intermittent leave.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDaysRequested rdf:type rdf:Property ;
    rdfs:label 'Total Days Requested' ;
    rdfs:comment 'Total number of calendar or business days requested by the employee for this leave. Calculated based on requested start and end dates, accounting for work schedule and holidays. May include partial days for intermittent leave.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalHoursApproved rdf:type rdf:Property ;
    rdfs:label 'Total Hours Approved' ;
    rdfs:comment 'Total number of work hours approved for this leave. Used for leave balance deduction and payroll processing. May differ from total hours requested if the request was modified during approval.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalHoursRequested rdf:type rdf:Property ;
    rdfs:label 'Total Hours Requested' ;
    rdfs:comment 'Total number of work hours requested for this leave. Used for precise leave balance calculations and labor cost forecasting. Particularly important for part-time employees and intermittent leave.' ;
    rdfs:domain ind:LeaveRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Reference to the parent organizational unit in the hierarchy. Enables navigation of the org chart from department to store to district to region to division to company.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:primaryOrgAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Org Associate Id' ;
    rdfs:comment 'Reference to the employee who manages this organizational unit (store manager, regional director, department head, DC operations manager).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:departmentCategory rdf:type rdf:Property ;
    rdfs:label 'Department Category' ;
    rdfs:comment 'Merchandising category for department-level org units (e.g., \'Grocery\', \'Apparel\', \'Electronics\', \'Home & Garden\'). Null for non-department org units.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:districtName rdf:type rdf:Property ;
    rdfs:label 'District Name' ;
    rdfs:comment 'District name for store-level organizational units. Districts roll up to regions and are managed by district managers.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionName rdf:type rdf:Property ;
    rdfs:label 'Division Name' ;
    rdfs:comment 'Name of the division this organizational unit belongs to (e.g., \'Grocery\', \'Apparel\', \'Electronics\', \'Home Goods\'). Supports merchandising and category-based reporting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Gl Company Code' ;
    rdfs:comment 'SAP company code for general ledger posting and financial consolidation. Represents the legal entity for financial reporting purposes.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRevenueGenerating rdf:type rdf:Property ;
    rdfs:label 'Is Revenue Generating' ;
    rdfs:comment 'Indicates whether this organizational unit directly generates revenue (stores, e-commerce) or is a support function (corporate, DC). Used for P&L classification.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orgUnitCode rdf:type rdf:Property ;
    rdfs:label 'Org Unit Code' ;
    rdfs:comment 'Business identifier code for the organizational unit. Used in operational systems, reporting, and integrations. Unique within org unit type.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitLevel rdf:type rdf:Property ;
    rdfs:label 'Org Unit Level' ;
    rdfs:comment 'Numeric level in the organizational hierarchy (1=company, 2=division, 3=region, etc.). Supports depth-based queries and rollup calculations.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orgUnitName rdf:type rdf:Property ;
    rdfs:label 'Org Unit Name' ;
    rdfs:comment 'Full business name of the organizational unit (e.g., \'Northeast Region\', \'Store 1234 - Manhattan\', \'Apparel Department\', \'Distribution Center Operations\').' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitStatus rdf:type rdf:Property ;
    rdfs:label 'Org Unit Status' ;
    rdfs:comment 'Current operational status of the organizational unit. Active units are operational and incur costs; inactive units are historical; pending units are planned but not yet operational.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitType rdf:type rdf:Property ;
    rdfs:label 'Org Unit Type' ;
    rdfs:comment 'Classification of the organizational unit within the enterprise hierarchy. Determines the level and function of the unit in reporting and cost allocation structures. [ENUM-REF-CANDIDATE: company|division|region|district|store|department|cost_center|distribution_center|fulfillment_node|corporate_function — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaEstablishmentNumber rdf:type rdf:Property ;
    rdfs:label 'Osha Establishment Number' ;
    rdfs:comment 'OSHA establishment identifier for workplace safety reporting. Required for locations with 10+ employees. Null for small or non-physical org units.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionName rdf:type rdf:Property ;
    rdfs:label 'Region Name' ;
    rdfs:comment 'Geographic region name for this organizational unit (e.g., \'Northeast\', \'Southwest\', \'Midwest\'). Supports regional performance analysis and territory management.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCommitteeRequired rdf:type rdf:Property ;
    rdfs:label 'Safety Committee Required' ;
    rdfs:comment 'Indicates whether OSHA regulations require a safety committee for this organizational unit based on headcount and hazard classification.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storeFormat rdf:type rdf:Property ;
    rdfs:label 'Store Format' ;
    rdfs:comment 'Store format classification for retail locations. Determines assortment depth, pricing strategy, and operational model. Null for non-store org units.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionRepresentation rdf:type rdf:Property ;
    rdfs:label 'Union Representation' ;
    rdfs:comment 'Indicates whether employees in this organizational unit are represented by a labor union. Affects labor relations, scheduling rules, and compliance requirements.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRecordId rdf:type rdf:Property ;
    rdfs:label 'Payroll Record Id' ;
    rdfs:comment 'Unique identifier for the payroll record. Primary key for this entity.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payrollRunId rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Id' ;
    rdfs:comment 'Unique identifier for the payroll processing batch run. Groups all payroll records processed together in a single payroll cycle.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRun .

ind:primaryPayrollAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Payroll Associate Id' ;
    rdfs:comment 'Unique identifier for the employee receiving this payroll payment. Links to the employee master record in the workforce domain.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:bankAccountLastFourDigits rdf:type rdf:Property ;
    rdfs:label 'Bank Account Last Four Digits' ;
    rdfs:comment 'Last four digits of the employee\'s bank account number for direct deposit verification. Masked for security and PCI compliance.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusPayAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Pay Amount' ;
    rdfs:comment 'Discretionary or performance-based bonus compensation included in this pay period. Includes incentive bonuses, retention bonuses, and other one-time payments.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionPayAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Pay Amount' ;
    rdfs:comment 'Sales commission earnings for the pay period. Variable compensation based on sales performance or revenue generation.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:federalTaxWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'Federal Tax Withheld Amount' ;
    rdfs:comment 'Federal income tax withheld from gross pay based on employee W-4 elections and IRS withholding tables.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ficaMedicareWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'Fica Medicare Withheld Amount' ;
    rdfs:comment 'Medicare tax withheld under Federal Insurance Contributions Act (FICA). Employee portion of Medicare hospital insurance tax.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ficaSocialSecurityWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'Fica Social Security Withheld Amount' ;
    rdfs:comment 'Social Security tax withheld under Federal Insurance Contributions Act (FICA). Employee portion of OASDI tax.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:garnishmentAmount rdf:type rdf:Property ;
    rdfs:label 'Garnishment Amount' ;
    rdfs:comment 'Court-ordered wage garnishments deducted from pay. Includes child support, tax levies, creditor garnishments, and other legal withholdings.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossPayAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Pay Amount' ;
    rdfs:comment 'Total compensation before any deductions. Sum of regular pay, overtime pay, shift differential, bonuses, commissions, and other earnings.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthInsuranceDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Health Insurance Deduction Amount' ;
    rdfs:comment 'Employee contribution toward health insurance premiums deducted from gross pay. May be pre-tax or post-tax depending on plan type.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localTaxWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'Local Tax Withheld Amount' ;
    rdfs:comment 'Local or municipal income tax withheld from gross pay where applicable. Includes city, county, or district taxes.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Work location code where the employee performed work during this pay period. Store number, DC code, or corporate office identifier.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPayAmount rdf:type rdf:Property ;
    rdfs:label 'Net Pay Amount' ;
    rdfs:comment 'Take-home pay after all deductions. The actual amount disbursed to the employee via direct deposit or check.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherBenefitsDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Other Benefits Deduction Amount' ;
    rdfs:comment 'Total deductions for other voluntary benefits such as dental insurance, vision insurance, life insurance, disability insurance, and flexible spending accounts.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours Worked' ;
    rdfs:comment 'Total number of overtime hours worked during the pay period. Hours exceeding standard work week threshold requiring premium pay.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimePayAmount rdf:type rdf:Property ;
    rdfs:label 'Overtime Pay Amount' ;
    rdfs:comment 'Gross compensation for overtime hours worked, typically calculated at time-and-a-half or double-time premium rates.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payDate rdf:type rdf:Property ;
    rdfs:label 'Pay Date' ;
    rdfs:comment 'The date on which payment is issued or deposited to the employee. The actual disbursement date for compensation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'The last date of the pay period covered by this payroll record. Defines the end of the work period for which compensation is calculated.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'The first date of the pay period covered by this payroll record. Defines the beginning of the work period for which compensation is calculated.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollStatus rdf:type rdf:Property ;
    rdfs:label 'Payroll Status' ;
    rdfs:comment 'Current processing status of the payroll record in the payroll workflow lifecycle. Tracks progression from calculation through final payment.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regularHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Regular Hours Worked' ;
    rdfs:comment 'Total number of regular hours worked during the pay period, excluding overtime. Standard work hours at base pay rate.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regularPayAmount rdf:type rdf:Property ;
    rdfs:label 'Regular Pay Amount' ;
    rdfs:comment 'Gross compensation for regular hours worked at the employee\'s base pay rate. Does not include overtime, bonuses, or other supplemental pay.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirementContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Retirement Contribution Amount' ;
    rdfs:comment 'Employee contribution to retirement savings plan such as 401(k) or 403(b). Pre-tax deferral reducing taxable income.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDifferentialPayAmount rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Pay Amount' ;
    rdfs:comment 'Additional compensation paid for working non-standard shifts such as evening, night, or weekend shifts. Premium pay for less desirable work hours.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateTaxWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'State Tax Withheld Amount' ;
    rdfs:comment 'State income tax withheld from gross pay based on state withholding requirements and employee elections.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDeductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Deductions Amount' ;
    rdfs:comment 'Sum of all deductions from gross pay including taxes, benefits, garnishments, and other withholdings.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearToDateFederalTaxWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'Year To Date Federal Tax Withheld Amount' ;
    rdfs:comment 'Cumulative federal income tax withheld from the beginning of the calendar year through this pay period. Used for W-2 Box 2 reporting.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearToDateGrossPayAmount rdf:type rdf:Property ;
    rdfs:label 'Year To Date Gross Pay Amount' ;
    rdfs:comment 'Cumulative gross pay for the employee from the beginning of the calendar year through this pay period. Used for tax reporting and W-2 preparation.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryPerformanceAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Associate Id' ;
    rdfs:comment 'Unique identifier of the retail associate, manager, or corporate employee being reviewed or subject to disciplinary action.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:tertiaryPerformanceHrReviewerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Performance Hr Reviewer Associate Id' ;
    rdfs:comment 'Unique identifier of the HR business partner or HR manager who reviewed and approved the disciplinary action for compliance and consistency.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Status of the talent calibration process where ratings are reviewed and normalized across the organization to ensure fairness and consistency.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyRating rdf:type rdf:Property ;
    rdfs:label 'Competency Rating' ;
    rdfs:comment 'Rating of the employee\'s demonstration of core competencies (e.g., customer service, teamwork, leadership, communication) during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgment Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee has acknowledged receipt and understanding of the performance review or disciplinary action.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goalAchievementRating rdf:type rdf:Property ;
    rdfs:label 'Goal Achievement Rating' ;
    rdfs:comment 'Rating of the employee\'s achievement of performance goals and objectives set at the beginning of the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerComments rdf:type rdf:Property ;
    rdfs:label 'Manager Comments' ;
    rdfs:comment 'Detailed narrative comments from the manager regarding the employee\'s performance, strengths, areas for improvement, and development recommendations.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meritIncreaseEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Eligible Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee is eligible for a merit-based salary increase based on their performance rating.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meritIncreasePercentage rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Percentage' ;
    rdfs:comment 'Percentage salary increase awarded to the employee based on their performance rating (e.g., 3.50 for 3.5% increase).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'Overall performance rating assigned to the employee for the review period: exceeds expectations, meets expectations, needs improvement, or unsatisfactory.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRatingScore rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Score' ;
    rdfs:comment 'Numeric score corresponding to the overall rating (e.g., 1.00 to 5.00 scale) used for merit increase calculations and talent calibration.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Performance Review Status' ;
    rdfs:comment 'Current workflow status of the performance review or disciplinary action record: draft, submitted for approval, approved, completed, or cancelled.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipEndDate rdf:type rdf:Property ;
    rdfs:label 'Pip End Date' ;
    rdfs:comment 'Target end date of the Performance Improvement Plan by which the employee must demonstrate improvement.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pipFlag rdf:type rdf:Property ;
    rdfs:label 'Pip Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee has been placed on a Performance Improvement Plan due to unsatisfactory performance.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pipStartDate rdf:type rdf:Property ;
    rdfs:label 'Pip Start Date' ;
    rdfs:comment 'Start date of the Performance Improvement Plan if the employee has been placed on a PIP.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyViolationCategory rdf:type rdf:Property ;
    rdfs:label 'Policy Violation Category' ;
    rdfs:comment 'Category of policy violation that triggered the disciplinary action: attendance, conduct, safety (OSHA), theft/shrinkage, harassment, or insubordination.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorActionsCount rdf:type rdf:Property ;
    rdfs:label 'Prior Actions Count' ;
    rdfs:comment 'Count of prior disciplinary actions taken against this employee within the progressive discipline sequence (used to determine escalation level).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:progressiveDisciplineSequence rdf:type rdf:Property ;
    rdfs:label 'Progressive Discipline Sequence' ;
    rdfs:comment 'Sequence number in the progressive discipline process (1=first warning, 2=second warning, etc.) used to track escalation toward termination.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Recommended Flag' ;
    rdfs:comment 'Boolean indicator of whether the manager recommends the employee for promotion based on their performance and readiness for increased responsibility.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'End date of the performance period being evaluated (e.g., December 31 for annual reviews).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'Start date of the performance period being evaluated (e.g., January 1 for annual reviews).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'Type of performance review cycle: annual review, mid-year check-in, probationary review, 90-day new hire review, project-based review, or Performance Improvement Plan (PIP).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selfAssessmentComments rdf:type rdf:Property ;
    rdfs:label 'Self Assessment Comments' ;
    rdfs:comment 'Employee\'s self-assessment narrative describing their accomplishments, challenges, and development goals for the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Termination Recommended Flag' ;
    rdfs:comment 'Boolean indicator of whether the manager or HR recommends termination of employment based on the severity of the incident or failure to improve performance.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hiringLocationId rdf:type rdf:Property ;
    rdfs:label 'Hiring Location Id' ;
    rdfs:comment 'Reference to the physical location where the hired employee will be assigned (store, distribution center, corporate office, regional hub).' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:requisitionAssociateId rdf:type rdf:Property ;
    rdfs:label 'Requisition Associate Id' ;
    rdfs:comment 'Reference to the employee who is the hiring manager responsible for this requisition, including interview participation and final hiring decision.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:requisitionRecruiterAssociateId rdf:type rdf:Property ;
    rdfs:label 'Requisition Recruiter Associate Id' ;
    rdfs:comment 'Reference to the talent acquisition specialist or recruiter assigned to source, screen, and manage candidates for this requisition.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:approvedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Approved Headcount' ;
    rdfs:comment 'Number of positions approved to be filled under this requisition. Typically 1 for individual roles, may be higher for bulk seasonal hiring or store opening events.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetedSalaryMax rdf:type rdf:Property ;
    rdfs:label 'Budgeted Salary Max' ;
    rdfs:comment 'Maximum approved salary or hourly rate for this position based on compensation band and market benchmarking. Used for offer negotiation and budget compliance.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedSalaryMin rdf:type rdf:Property ;
    rdfs:label 'Budgeted Salary Min' ;
    rdfs:comment 'Minimum approved salary or hourly rate for this position based on compensation band and market benchmarking. Used for offer negotiation and budget compliance.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eeoJobCategory rdf:type rdf:Property ;
    rdfs:label 'Eeo Job Category' ;
    rdfs:comment 'EEO-1 Component 1 job category classification required for federal diversity and equal opportunity reporting to EEOC and OFCCP (e.g., Executive/Senior Officials, Professionals, Sales Workers, Service Workers).' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hiringLocationType rdf:type rdf:Property ;
    rdfs:label 'Hiring Location Type' ;
    rdfs:comment 'Classification of the hiring location to support location-specific recruiting strategies and labor market analysis.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRemoteEligible rdf:type rdf:Property ;
    rdfs:label 'Is Remote Eligible' ;
    rdfs:comment 'Indicates whether this position is eligible for remote or hybrid work arrangements. Used for candidate attraction and workspace planning.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Education Level' ;
    rdfs:comment 'Minimum educational attainment required for this position (e.g., high school diploma, bachelor\'s degree, master\'s degree). Used for candidate screening and compliance reporting.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Experience Years' ;
    rdfs:comment 'Minimum number of years of relevant work experience required for this position. Used for candidate screening and job level determination.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positionsFilled rdf:type rdf:Property ;
    rdfs:label 'Positions Filled' ;
    rdfs:comment 'Count of positions that have been successfully filled and closed under this requisition. Used to track progress toward approved headcount target.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postingTitle rdf:type rdf:Property ;
    rdfs:label 'Posting Title' ;
    rdfs:comment 'External-facing job title used in job postings and career site listings, may differ from internal job title for candidate attraction and SEO optimization.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresBackgroundCheck rdf:type rdf:Property ;
    rdfs:label 'Requires Background Check' ;
    rdfs:comment 'Indicates whether this position requires a pre-employment background check per company policy or regulatory requirements (e.g., roles with financial access, management positions).' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresDrugScreening rdf:type rdf:Property ;
    rdfs:label 'Requires Drug Screening' ;
    rdfs:comment 'Indicates whether this position requires pre-employment drug screening per company policy or safety-sensitive role designation (e.g., distribution center equipment operators, drivers).' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Externally-known business identifier for the job requisition, typically formatted as REQ- followed by numeric sequence. Used for tracking and communication with hiring managers and candidates.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle state of the requisition in the talent acquisition workflow. Tracks progression from draft through approval, active recruiting, and final disposition. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|open|on_hold|filled|cancelled|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the requisition indicating whether it is filling a vacated position (backfill), adding new headcount, seasonal hiring, temporary assignment, contractor engagement, or internship program.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Salary Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the budgeted salary range (e.g., USD, CAD, MXN) supporting multi-country retail operations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingChannels rdf:type rdf:Property ;
    rdfs:label 'Sourcing Channels' ;
    rdfs:comment 'Comma-separated list of authorized recruiting channels for this requisition (e.g., internal job board, LinkedIn, Indeed, campus recruiting, employee referral, staffing agency). Used for source-of-hire analytics.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Start Date' ;
    rdfs:comment 'Desired or planned start date for the new hire to begin employment. Used for workforce planning and onboarding preparation.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeToFillSlaDays rdf:type rdf:Property ;
    rdfs:label 'Time To Fill Sla Days' ;
    rdfs:comment 'Target number of days to fill this requisition from open date to offer acceptance, based on role complexity and labor market conditions. Used for recruiter performance tracking.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:travelRequirementPct rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement Pct' ;
    rdfs:comment 'Expected percentage of time the role requires business travel (0-100). Used for candidate expectation setting and travel budget planning.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageRequestId rdf:type rdf:Property ;
    rdfs:label 'Coverage Request Id' ;
    rdfs:comment 'Identifier of the coverage request if this schedule was created to fill an open shift posted by a manager or another associate. Null if the shift was not a coverage assignment.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoverageRequest .

ind:primaryShiftAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Shift Associate Id' ;
    rdfs:comment 'Unique identifier of the associate or employee assigned to this shift. Links to the employee master record in Workday HCM.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'Total duration of unpaid breaks in minutes scheduled during the shift. Required for compliance with state labor laws regarding meal and rest breaks.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Timestamp' ;
    rdfs:comment 'The date and time when the associate acknowledged or confirmed receipt of the shift schedule in Workday HCM.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:employeeAvailabilityMatch rdf:type rdf:Property ;
    rdfs:label 'Employee Availability Match' ;
    rdfs:comment 'Indicates how well the scheduled shift aligns with the associates stated availability preferences in Workday HCM. Full match means the shift is within preferred hours, partial match means some overlap, no match means the shift conflicts with availability, and not specified means no preference was recorded.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLaborCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Cost' ;
    rdfs:comment 'The estimated total labor cost for this shift in USD, including base pay, overtime premium, holiday premium, and benefits allocation. Used for labor budget planning and variance analysis.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHolidayShift rdf:type rdf:Property ;
    rdfs:label 'Is Holiday Shift' ;
    rdfs:comment 'Indicates whether the shift falls on a company-recognized holiday, which may qualify for premium pay or special scheduling rules.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborCostAllocationCode rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Allocation Code' ;
    rdfs:comment 'The cost center or general ledger account code to which the labor cost for this shift should be allocated. Used for financial planning and P&L reporting.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paidBreakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Paid Break Duration Minutes' ;
    rdfs:comment 'Total duration of paid rest breaks in minutes scheduled during the shift. Separate from unpaid meal breaks.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleNotes rdf:type rdf:Property ;
    rdfs:label 'Schedule Notes' ;
    rdfs:comment 'Free-text notes or special instructions related to the shift schedule. May include information about special tasks, training requirements, or operational considerations.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleSource rdf:type rdf:Property ;
    rdfs:label 'Schedule Source' ;
    rdfs:comment 'Indicates how the shift schedule was created. Auto-generated schedules are created by Workday HCM scheduling algorithms, manager-assigned schedules are manually created by supervisors, employee-requested schedules honor associate preferences, shift-swap schedules result from approved swaps, and coverage-request schedules fill open shifts.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleWeekStartDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Week Start Date' ;
    rdfs:comment 'The start date of the scheduling week for which this shift is planned. Typically Monday in a Monday-Sunday scheduling cycle.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Hours' ;
    rdfs:comment 'Total number of hours the associate is scheduled to work during this shift, excluding breaks. Used for labor cost planning and compliance with labor laws.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDate rdf:type rdf:Property ;
    rdfs:label 'Shift Date' ;
    rdfs:comment 'The calendar date on which the shift is scheduled to occur.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftPriority rdf:type rdf:Property ;
    rdfs:label 'Shift Priority' ;
    rdfs:comment 'Business priority level of the shift. Critical shifts are essential for operations (e.g., opening manager, security), high priority shifts support peak traffic, normal shifts are standard coverage, and low priority shifts are optional or training.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftSwapRequestId rdf:type rdf:Property ;
    rdfs:label 'Shift Swap Request Id' ;
    rdfs:comment 'Identifier of the shift swap request if this schedule resulted from an approved swap between two associates. Null if the shift was not swapped.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftType rdf:type rdf:Property ;
    rdfs:label 'Shift Type' ;
    rdfs:comment 'Classification of the shift based on time of day and operational role. Opening shifts start early morning, mid shifts cover midday, closing shifts end at store close, overnight shifts cover restocking and maintenance, split shifts have a break in the middle, and on-call shifts are standby assignments.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeEntryId rdf:type rdf:Property ;
    rdfs:label 'Time Entry Id' ;
    rdfs:comment 'Unique identifier for the time entry record. Primary key for the time entry data product.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payPeriodId rdf:type rdf:Property ;
    rdfs:label 'Pay Period Id' ;
    rdfs:comment 'Identifier for the pay period to which this time entry belongs. Used for payroll processing and labor cost allocation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayPeriod .

ind:primaryTimeAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Time Associate Id' ;
    rdfs:comment 'Unique identifier for the employee who recorded this time entry. Links to the employee master record in Workday HCM.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:actualHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Actual Hours Worked' ;
    rdfs:comment 'Total number of hours actually worked during this time entry, calculated from clock-in and clock-out timestamps minus break time. Used for payroll calculation.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Time Minutes' ;
    rdfs:comment 'Total minutes of unpaid break time taken during this shift. Deducted from total time to calculate actual hours worked.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clockInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock In Timestamp' ;
    rdfs:comment 'Exact date and time when the employee clocked in to start their work shift. Captured from POS-integrated time clock, mobile app, or Workday HCM.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clockOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock Out Timestamp' ;
    rdfs:comment 'Exact date and time when the employee clocked out to end their work shift. Nullable for in-progress shifts.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:doubleTimeHours rdf:type rdf:Property ;
    rdfs:label 'Double Time Hours' ;
    rdfs:comment 'Number of hours worked that qualify for double-time pay (typically 2x regular rate). Applicable in certain states or under specific conditions (e.g., working on holidays).' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHolidayWork rdf:type rdf:Property ;
    rdfs:label 'Is Holiday Work' ;
    rdfs:comment 'Indicates whether this time entry was performed on a company-recognized holiday. May qualify for premium pay.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mealBreakMinutes rdf:type rdf:Property ;
    rdfs:label 'Meal Break Minutes' ;
    rdfs:comment 'Total minutes of meal break time taken during this shift. Typically unpaid and required by state labor laws for shifts exceeding certain durations.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Number of hours worked beyond regular hours that qualify for overtime pay (typically 1.5x regular rate). Calculated based on FLSA rules and state labor laws.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidBreakMinutes rdf:type rdf:Property ;
    rdfs:label 'Paid Break Minutes' ;
    rdfs:comment 'Total minutes of paid rest breaks taken during this shift. Typically required for shifts of certain lengths and included in hours worked.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payRate rdf:type rdf:Property ;
    rdfs:label 'Pay Rate' ;
    rdfs:comment 'Hourly pay rate applicable to this time entry. Used for payroll calculation. Confidential compensation data.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payrollBatchCode rdf:type rdf:Property ;
    rdfs:label 'Payroll Batch Code' ;
    rdfs:comment 'Identifier for the payroll batch in which this time entry was processed. Used for payroll reconciliation and audit.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollProcessedFlag rdf:type rdf:Property ;
    rdfs:label 'Payroll Processed Flag' ;
    rdfs:comment 'Indicates whether this time entry has been processed in payroll. Used to prevent duplicate payment and ensure audit trail.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regularHours rdf:type rdf:Property ;
    rdfs:label 'Regular Hours' ;
    rdfs:comment 'Number of hours worked at regular pay rate (typically up to 40 hours per week for non-exempt employees). Used for payroll processing.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDifferentialEligible rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Eligible' ;
    rdfs:comment 'Indicates whether this time entry qualifies for shift differential pay (e.g., night shift, weekend shift premium). Used for payroll calculation.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shiftDifferentialRate rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Rate' ;
    rdfs:comment 'Additional pay rate (as a percentage or dollar amount) applied for shift differential. Used in payroll calculation.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDifferentialType rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Type' ;
    rdfs:comment 'Type of shift differential applicable to this time entry. Determines the premium pay rate to be applied.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeClockDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Time Clock Device Code' ;
    rdfs:comment 'Identifier for the physical time clock or terminal where the employee clocked in/out. Used for audit trail and device management.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeEntrySource rdf:type rdf:Property ;
    rdfs:label 'Time Entry Source' ;
    rdfs:comment 'The system or method used to capture this time entry. Indicates data quality and audit trail for time tracking.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeEntryType rdf:type rdf:Property ;
    rdfs:label 'Time Entry Type' ;
    rdfs:comment 'Classification of the time entry indicating the nature of work or absence. Used for payroll processing and labor analytics. [ENUM-REF-CANDIDATE: regular_shift|overtime|holiday|sick_leave|vacation|bereavement|jury_duty|training — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workDate rdf:type rdf:Property ;
    rdfs:label 'Work Date' ;
    rdfs:comment 'The calendar date on which the work was performed. Used for daily labor reporting and scheduling compliance.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Training Enrollment Id' ;
    rdfs:comment 'Unique identifier for the training enrollment record. Primary key.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationEarnedFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Earned Flag' ;
    rdfs:comment 'Indicates whether successful completion of this training results in a professional certification or license (True = certification earned, False = no certification).' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Current lifecycle status of the training enrollment (enrolled, in-progress, completed, failed, withdrawn, expired, waived). Tracks progression through the training lifecycle. [ENUM-REF-CANDIDATE: enrolled|in_progress|completed|failed|withdrawn|expired|waived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceTrainingFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Training Flag' ;
    rdfs:comment 'Indicates whether this training is required for regulatory compliance (True = compliance training, False = non-compliance training). Used for OSHA, FDA, and other regulatory audit trails.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feedbackComments rdf:type rdf:Property ;
    rdfs:label 'Feedback Comments' ;
    rdfs:comment 'Free-text comments provided by the employee about their training experience. Used for qualitative analysis and program improvement.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackRating rdf:type rdf:Property ;
    rdfs:label 'Feedback Rating' ;
    rdfs:comment 'Employee\'s satisfaction rating for the training program, typically on a scale of 1 to 5. Used for training program quality improvement.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:instructorName rdf:type rdf:Property ;
    rdfs:label 'Instructor Name' ;
    rdfs:comment 'Name of the instructor or facilitator who delivered the training. Null for self-paced e-learning programs.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryTrainingFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Training Flag' ;
    rdfs:comment 'Indicates whether this training is mandatory for the employee based on their role, location, or regulatory requirements (True = mandatory, False = optional).' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overdueFlag rdf:type rdf:Property ;
    rdfs:label 'Overdue Flag' ;
    rdfs:comment 'Indicates whether the training is past its due date and not yet completed (True = overdue, False = on time or completed).' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passFailIndicator rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Indicator' ;
    rdfs:comment 'Indicates whether the employee passed or failed the training program. Not applicable for non-assessed training.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Completion Date' ;
    rdfs:comment 'Target date by which the employee is expected to complete the training program. Used for compliance tracking and onboarding milestone monitoring.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date when the employee is expected to begin the training program.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingLocation rdf:type rdf:Property ;
    rdfs:label 'Training Location' ;
    rdfs:comment 'Physical or virtual location where the training was conducted (e.g., store number, distribution center, corporate training facility, online platform).' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingType rdf:type rdf:Property ;
    rdfs:label 'Training Type' ;
    rdfs:comment 'Category of training program indicating its primary purpose (onboarding, compliance, product knowledge, safety, leadership, POS operations, customer service, technical skills, soft skills). [ENUM-REF-CANDIDATE: onboarding|compliance|product_knowledge|safety|leadership|pos_operations|customer_service|technical_skills|soft_skills — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or employee ID of the manager or HR representative who approved the training waiver. Null if not waived.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wfCertificationId rdf:type rdf:Property ;
    rdfs:label 'Wf Certification Id' ;
    rdfs:comment 'Unique identifier for the workforce certification record. Primary key.' ;
    rdfs:domain ind:WfCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryWfAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Wf Associate Id' ;
    rdfs:comment 'Identifier of the associate who holds this certification. Links to the associate master record in Workday HCM.' ;
    rdfs:domain ind:WfCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:tertiaryWfModifiedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Wf Modified By User Associate Id' ;
    rdfs:comment 'Identifier of the user or system process that last modified this certification record.' ;
    rdfs:domain ind:WfCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:attachmentUrl rdf:type rdf:Property ;
    rdfs:label 'Attachment Url' ;
    rdfs:comment 'URL or file path to the digital copy of the certification document stored in the document management system.' ;
    rdfs:domain ind:WfCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'Full official name of the certification or credential as issued by the certifying body.' ;
    rdfs:domain ind:WfCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuingEducationHoursCompleted rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Hours Completed' ;
    rdfs:comment 'Number of continuing education hours the associate has completed toward renewal requirements.' ;
    rdfs:domain ind:WfCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:continuingEducationHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Hours Required' ;
    rdfs:comment 'Number of continuing education or professional development hours required to maintain or renew the certification.' ;
    rdfs:domain ind:WfCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Is Compliance Required' ;
    rdfs:comment 'Indicates whether this certification is required to meet regulatory or legal compliance obligations (e.g., OSHA, FDA, state licensing).' ;
    rdfs:domain ind:WfCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthorityType rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Type' ;
    rdfs:comment 'Classification of the certifying organization to distinguish regulatory vs. professional vs. internal credentials.' ;
    rdfs:domain ind:WfCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'Name of the organization, agency, or institution that issued the certification (e.g., State Health Department, OSHA, National Pharmacy Board).' ;
    rdfs:domain ind:WfCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Job Eligibility Flag' ;
    rdfs:comment 'Indicates whether this certification qualifies the associate for specific job roles or assignments (e.g., forklift operator, pharmacy technician).' ;
    rdfs:domain ind:WfCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reimbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Amount' ;
    rdfs:comment 'Amount reimbursed to the associate for certification costs, if applicable.' ;
    rdfs:domain ind:WfCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reimbursementEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Eligible Flag' ;
    rdfs:comment 'Indicates whether the associate is eligible for reimbursement of certification costs under company policy.' ;
    rdfs:domain ind:WfCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:campaignDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Campaign Deployment Id' ;
    rdfs:comment 'Unique identifier for this campaign deployment record. Primary key.' ;
    rdfs:domain ind:CampaignDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Deployment Status' ;
    rdfs:comment 'Current operational status of this campaign deployment on this storefront. Values: scheduled (planned but not yet active), active (currently running), paused (temporarily suspended), completed (ended as planned), cancelled (terminated early).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMetrics rdf:type rdf:Property ;
    rdfs:label 'Performance Metrics' ;
    rdfs:comment 'JSON or delimited string containing additional performance metrics specific to this campaign-storefront deployment, such as click-through rate, conversion rate, cost per acquisition, return on ad spend, or engagement scores.' ;
    rdfs:domain ind:CampaignDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyLaneId rdf:type rdf:Property ;
    rdfs:label 'Supply Lane Id' ;
    rdfs:comment 'Unique identifier for this vendor-DC supply lane relationship. Primary key.' ;
    rdfs:domain ind:SupplyLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laneStatus rdf:type rdf:Property ;
    rdfs:label 'Lane Status' ;
    rdfs:comment 'Current operational status of this supply lane (Active, Inactive, Suspended, Pending). Allows temporary suspension without deleting the relationship.' ;
    rdfs:domain ind:SupplyLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Min Order Quantity' ;
    rdfs:comment 'Minimum order quantity in units required for shipments on this supply lane. May differ from vendor-level MOQ based on DC-specific economics and transportation constraints.' ;
    rdfs:domain ind:SupplyLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ruleApplicationId rdf:type rdf:Property ;
    rdfs:label 'Rule Application Id' ;
    rdfs:comment 'Unique system-generated identifier for each pricing rule application record. Primary key for this association.' ;
    rdfs:domain ind:RuleApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Timestamp when this pricing rule application record was created in the system.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:executionSequence rdf:type rdf:Property ;
    rdfs:label 'Execution Sequence' ;
    rdfs:comment 'Sequential order in which this pricing rule is applied relative to other rules associated with the same promotional offer. Used by checkout engines to orchestrate multi-rule promotional pricing scenarios.' ;
    rdfs:domain ind:RuleApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Timestamp when this pricing rule application record was last modified.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerMembershipId rdf:type rdf:Property ;
    rdfs:label 'Customer Membership Id' ;
    rdfs:comment 'Primary key for customer_membership' ;
    rdfs:domain ind:CustomerMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Assignment Confidence Score' ;
    rdfs:comment 'Confidence score (0.00-100.00) indicating the strength of this customer\'s qualification for this segment. For rule-based assignments, reflects how strongly the customer meets qualification criteria. For ML-based assignments, reflects model prediction confidence. Used for prioritizing marketing outreach and identifying borderline members.' ;
    rdfs:domain ind:CustomerMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerMembershipStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Membership Status' ;
    rdfs:comment 'Current operational status of this segment membership. Active: customer currently qualifies and membership is in effect. Expired: membership ended due to disqualification or time-based expiry. Suspended: temporarily inactive due to business rules. PendingQualification: awaiting next refresh cycle to confirm eligibility.' ;
    rdfs:domain ind:CustomerMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastQualificationCheckDate rdf:type rdf:Property ;
    rdfs:label 'Last Qualification Check Date' ;
    rdfs:comment 'Timestamp of the most recent evaluation of this customer\'s eligibility for this segment. Updated during auto-refresh cycles or manual re-qualification checks. Used for audit trails and determining when next qualification check is due.' ;
    rdfs:domain ind:CustomerMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manualOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Manual Override Flag' ;
    rdfs:comment 'Boolean flag indicating whether this membership was manually assigned by a business user, overriding automated qualification rules. True: manual override in effect, customer may not meet standard qualification criteria. False: standard rule-based or automated assignment. Used for governance and audit purposes.' ;
    rdfs:domain ind:CustomerMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuanceId rdf:type rdf:Property ;
    rdfs:label 'Issuance Id' ;
    rdfs:comment 'Unique identifier for this coupon issuance record. Primary key.' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionLocationId rdf:type rdf:Property ;
    rdfs:label 'Redemption Location Id' ;
    rdfs:comment 'Store or channel location where this customer redeemed this coupon. Null if not yet redeemed. Foreign key to location/store master.' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:personalizationDiscountOverride rdf:type rdf:Property ;
    rdfs:label 'Personalization Discount Override' ;
    rdfs:comment 'Customer-specific discount value that overrides the coupon\'s standard face_value. Used for personalized promotional offers based on customer segment, loyalty tier, or campaign targeting.' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionDate rdf:type rdf:Property ;
    rdfs:label 'Redemption Date' ;
    rdfs:comment 'Date when this customer redeemed this coupon. Null if not yet redeemed. Tracks the per-customer redemption event.' ;
    rdfs:domain ind:Issuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetingId rdf:type rdf:Property ;
    rdfs:label 'Targeting Id' ;
    rdfs:comment 'Unique identifier for this segment-campaign targeting record. Primary key.' ;
    rdfs:domain ind:Targeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deactivationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deactivation Timestamp' ;
    rdfs:comment 'Date and time when this segment targeting was deactivated or completed. Null for currently active targeting.' ;
    rdfs:domain ind:Targeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:targetingStatus rdf:type rdf:Property ;
    rdfs:label 'Targeting Status' ;
    rdfs:comment 'Current operational status of this segment targeting within the campaign. Planned: scheduled but not yet active; Active: currently being executed; Paused: temporarily suspended; Completed: execution finished; Cancelled: targeting cancelled before completion.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorProgramEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Vendor Program Enrollment Id' ;
    rdfs:comment 'Unique identifier for this vendor-program enrollment record. Primary key.' ;
    rdfs:domain ind:VendorProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programComplianceProgramId rdf:type rdf:Property ;
    rdfs:label 'Program Compliance Program Id' ;
    rdfs:comment 'Foreign key linking to the compliance program master record' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceProgram .

ind:exemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exemption Flag' ;
    rdfs:comment 'Boolean indicator of whether this vendor has been granted an exemption from certain requirements of this compliance program. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:VendorProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'Business justification or regulatory basis for granting an exemption to this vendor for this program. Null if exemption_flag is false. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Date' ;
    rdfs:comment 'Date of the most recent compliance assessment or audit conducted for this vendor under this program. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:VendorProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programTier rdf:type rdf:Property ;
    rdfs:label 'Program Tier' ;
    rdfs:comment 'Program-specific compliance tier or risk classification assigned to this vendor within this program. Explicitly identified in detection phase relationship data. Values: Tier_1_Critical, Tier_2_High, Tier_3_Standard, Tier_4_Low, Not_Tiered.' ;
    rdfs:domain ind:VendorProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCampaignPlacementId rdf:type rdf:Property ;
    rdfs:label 'Category Campaign Placement Id' ;
    rdfs:comment 'Unique identifier for this category-campaign placement record. Primary key.' ;
    rdfs:domain ind:CategoryCampaignPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Sales Amount' ;
    rdfs:comment 'Actual sales revenue generated by this category during this campaign period. Used for post-campaign performance analysis and ROI calculation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placementStatus rdf:type rdf:Property ;
    rdfs:label 'Placement Status' ;
    rdfs:comment 'Current lifecycle status of this category placement within the campaign.' ;
    rdfs:domain ind:CategoryCampaignPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Target Sales Amount' ;
    rdfs:comment 'Sales revenue target set for this category within this specific campaign. Used to measure campaign effectiveness at the category level.' ;
    rdfs:domain ind:CategoryCampaignPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignStorefrontDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Campaign Storefront Deployment Id' ;
    rdfs:comment 'Unique identifier for this campaign-storefront deployment record. Primary key.' ;
    rdfs:domain ind:CampaignStorefrontDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storefrontBudgetAllocation rdf:type rdf:Property ;
    rdfs:label 'Storefront Budget Allocation' ;
    rdfs:comment 'The portion of the campaign\'s total budget allocated to this specific storefront, used for channel-specific promotional spend, incentives, or advertising.' ;
    rdfs:domain ind:CampaignStorefrontDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storefrontConversionRate rdf:type rdf:Property ;
    rdfs:label 'Storefront Conversion Rate' ;
    rdfs:comment 'The conversion rate (percentage) of enrolled members who became active participants on this specific storefront, calculated as (storefront_participation_count / storefront_enrollment_count) * 100.' ;
    rdfs:domain ind:CampaignStorefrontDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storefrontEndDate rdf:type rdf:Property ;
    rdfs:label 'Storefront End Date' ;
    rdfs:comment 'The date when this campaign concluded on this specific storefront. May differ from the campaign\'s global end_date to accommodate storefront-specific timing strategies.' ;
    rdfs:domain ind:CampaignStorefrontDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storefrontEnrollmentCount rdf:type rdf:Property ;
    rdfs:label 'Storefront Enrollment Count' ;
    rdfs:comment 'The number of members who enrolled or opted into the campaign through this specific storefront channel.' ;
    rdfs:domain ind:CampaignStorefrontDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storefrontLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Storefront Launch Date' ;
    rdfs:comment 'The date when this campaign was launched on this specific storefront. May differ from the campaign\'s global start_date to accommodate storefront-specific timing strategies.' ;
    rdfs:domain ind:CampaignStorefrontDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storefrontParticipationCount rdf:type rdf:Property ;
    rdfs:label 'Storefront Participation Count' ;
    rdfs:comment 'The number of members who actively participated in the campaign (completed qualifying actions) through this specific storefront channel.' ;
    rdfs:domain ind:CampaignStorefrontDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nodeAssortmentId rdf:type rdf:Property ;
    rdfs:label 'Node Assortment Id' ;
    rdfs:comment 'Unique surrogate identifier for this node-category assortment plan record' ;
    rdfs:domain ind:NodeAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualSkuCount rdf:type rdf:Property ;
    rdfs:label 'Actual Sku Count' ;
    rdfs:comment 'Current number of distinct SKUs from this category actively stocked at this location. Compared against target_sku_count for assortment compliance monitoring' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assortmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assortment Status' ;
    rdfs:comment 'Current lifecycle status of this category at this location. ACTIVE means category is currently stocked and sold; PLANNED means approved for future rollout; DISCONTINUED means category removed from location; SEASONAL_INACTIVE means temporarily not carried' ;
    rdfs:domain ind:NodeAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryManagerOverrideName rdf:type rdf:Property ;
    rdfs:label 'Category Manager Override Name' ;
    rdfs:comment 'Name of category manager responsible for this specific node-category combination when it differs from the hierarchy-level default. Used for regional or format-specific category ownership' ;
    rdfs:domain ind:NodeAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localAssortmentOverride rdf:type rdf:Property ;
    rdfs:label 'Local Assortment Override' ;
    rdfs:comment 'Boolean flag indicating whether this location has local merchandising authority to deviate from corporate assortment plan for this category. True for high-autonomy formats or test stores' ;
    rdfs:domain ind:NodeAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxPresentationQty rdf:type rdf:Property ;
    rdfs:label 'Max Presentation Qty' ;
    rdfs:comment 'Maximum number of units that can be displayed on shelf for this category at this location based on allocated space and planogram design' ;
    rdfs:domain ind:NodeAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minPresentationQty rdf:type rdf:Property ;
    rdfs:label 'Min Presentation Qty' ;
    rdfs:comment 'Minimum number of units that must be displayed on shelf for this category at this location to maintain acceptable customer presentation standards' ;
    rdfs:domain ind:NodeAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replenishmentPriority rdf:type rdf:Property ;
    rdfs:label 'Replenishment Priority' ;
    rdfs:comment 'Priority classification for replenishing this category at this location. CRITICAL for high-velocity destination categories; HIGH for key traffic drivers; MEDIUM for routine; LOW for convenience/impulse' ;
    rdfs:domain ind:NodeAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Shelf Capacity Units' ;
    rdfs:comment 'Total shelf capacity allocated to this category at this location, measured in unit facings or shelf positions. Drives maximum inventory display quantity' ;
    rdfs:domain ind:NodeAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetSkuCount rdf:type rdf:Property ;
    rdfs:label 'Target Sku Count' ;
    rdfs:comment 'Target number of distinct SKUs from this category that should be carried at this location. Drives assortment depth decisions based on node format and customer demographics' ;
    rdfs:domain ind:NodeAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryCampaignPlanId rdf:type rdf:Property ;
    rdfs:label 'Category Campaign Plan Id' ;
    rdfs:comment 'Unique identifier for this category-campaign plan record. Primary key.' ;
    rdfs:domain ind:CategoryCampaignPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Revenue Amount' ;
    rdfs:comment 'Actual revenue generated by this category during the campaign period. Used to calculate campaign effectiveness and ROI.' ;
    rdfs:domain ind:CategoryCampaignPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediaWeightPercent rdf:type rdf:Property ;
    rdfs:label 'Media Weight Percent' ;
    rdfs:comment 'Percentage of campaign media impressions, creative assets, or channel mix allocated to featuring this category. Indicates relative prominence in campaign messaging.' ;
    rdfs:domain ind:CategoryCampaignPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performancePriorityRank rdf:type rdf:Property ;
    rdfs:label 'Performance Priority Rank' ;
    rdfs:comment 'Relative priority ranking of this category within the campaign (1 = highest priority). Used to guide resource allocation and performance monitoring focus.' ;
    rdfs:domain ind:CategoryCampaignPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalDepthPercent rdf:type rdf:Property ;
    rdfs:label 'Promotional Depth Percent' ;
    rdfs:comment 'Average discount percentage or promotional intensity planned for this category within this campaign. Expressed as percentage off regular price.' ;
    rdfs:domain ind:CategoryCampaignPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetUnitsGoal rdf:type rdf:Property ;
    rdfs:label 'Target Units Goal' ;
    rdfs:comment 'Target number of units (SKUs) expected to sell for this category during the campaign period. Used for inventory planning and performance measurement.' ;
    rdfs:domain ind:CategoryCampaignPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kpiDimensionalityId rdf:type rdf:Property ;
    rdfs:label 'Kpi Dimensionality Id' ;
    rdfs:comment 'Unique identifier for this KPI-dimension configuration record. Primary key.' ;
    rdfs:domain ind:KpiDimensionality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aggregationLevel rdf:type rdf:Property ;
    rdfs:label 'Aggregation Level' ;
    rdfs:comment 'The aggregation method to apply when this KPI is sliced by this dimension (e.g., sum for additive metrics, average for ratios, none for pre-aggregated). Identified in detection phase relationship data.' ;
    rdfs:domain ind:KpiDimensionality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationNotes rdf:type rdf:Property ;
    rdfs:label 'Configuration Notes' ;
    rdfs:comment 'Free-text notes explaining why this dimension is configured for this KPI, any special handling, or business context.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configuredBy rdf:type rdf:Property ;
    rdfs:label 'Configured By' ;
    rdfs:comment 'Name or identifier of the BI team member or data steward who configured this KPI-dimension pairing.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultFilterValue rdf:type rdf:Property ;
    rdfs:label 'Default Filter Value' ;
    rdfs:comment 'Optional default filter value to apply for this dimension when this KPI is first loaded (e.g., current_year for time dimension, flagship_stores for store dimension). Identified in detection phase relationship data.' ;
    rdfs:domain ind:KpiDimensionality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dimensionValueFilter rdf:type rdf:Property ;
    rdfs:label 'Dimension Value Filter' ;
    rdfs:comment 'Optional filter expression limiting which dimension members are valid for this KPI (e.g., only active stores, only product categories with inventory). Identified in detection phase relationship data.' ;
    rdfs:domain ind:KpiDimensionality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionality rdf:type rdf:Property ;
    rdfs:label 'Dimensionality' ;
    rdfs:comment 'The business dimensions by which this KPI can be sliced and analyzed (e.g., Store, Product Category, Time Period, Customer Segment, Channel). Comma-separated list of applicable dimensions. [Moved from kpi_definition: The dimensionality attribute in kpi_definition is a text description of which dimensions apply to the KPI. This should be replaced by the explicit M:N relationship captured in kpi_dimensionality, where each valid dimension is a separate record with its own configuration.]' ;
    rdfs:domain ind:KpiDimensionality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRequiredDimension rdf:type rdf:Property ;
    rdfs:label 'Is Required Dimension' ;
    rdfs:comment 'Boolean flag indicating whether this dimension MUST be included when querying this KPI (e.g., time period is required for all temporal KPIs).' ;
    rdfs:domain ind:KpiDimensionality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportCompositionId rdf:type rdf:Property ;
    rdfs:label 'Report Composition Id' ;
    rdfs:comment 'Unique identifier for this report-KPI composition record. Primary key.' ;
    rdfs:domain ind:ReportComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addedDate rdf:type rdf:Property ;
    rdfs:label 'Added Date' ;
    rdfs:comment 'Date when this KPI was added to this report definition. Used for tracking report evolution and composition history.' ;
    rdfs:domain ind:ReportComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compositionStatus rdf:type rdf:Property ;
    rdfs:label 'Composition Status' ;
    rdfs:comment 'Current status of this KPI within this report: active (currently displayed), deprecated (scheduled for removal), testing (under evaluation). Supports report composition lifecycle management.' ;
    rdfs:domain ind:ReportComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillDownEnabled rdf:type rdf:Property ;
    rdfs:label 'Drill Down Enabled' ;
    rdfs:comment 'Flag indicating whether drill-down functionality is enabled for this KPI in this report context. The same KPI may allow drill-down in some reports but not others based on audience and use case.' ;
    rdfs:domain ind:ReportComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryMetric rdf:type rdf:Property ;
    rdfs:label 'Is Primary Metric' ;
    rdfs:comment 'Flag indicating whether this KPI is designated as a primary or headline metric for this report. Primary metrics may receive special visual treatment or positioning.' ;
    rdfs:domain ind:ReportComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:removedDate rdf:type rdf:Property ;
    rdfs:label 'Removed Date' ;
    rdfs:comment 'Date when this KPI was removed from this report definition. Nullable for active KPIs. Enables historical tracking of report composition changes.' ;
    rdfs:domain ind:ReportComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sectionName rdf:type rdf:Property ;
    rdfs:label 'Section Name' ;
    rdfs:comment 'The named section or tab within the report where this KPI is displayed (e.g., "Executive Summary", "Store Performance", "Financial Metrics"). Used to organize KPIs into logical groupings within multi-section reports.' ;
    rdfs:domain ind:ReportComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetThresholdOverride rdf:type rdf:Property ;
    rdfs:label 'Target Threshold Override' ;
    rdfs:comment 'Report-specific override of the KPI\'s default target threshold value. Allows different reports to apply different performance targets for the same KPI based on audience or business context. Nullable if using the KPI\'s default target.' ;
    rdfs:domain ind:ReportComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:staffingPlanId rdf:type rdf:Property ;
    rdfs:label 'Staffing Plan Id' ;
    rdfs:comment 'Unique identifier for this staffing plan allocation record. Primary key.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualHeadcount rdf:type rdf:Property ;
    rdfs:label 'Actual Headcount' ;
    rdfs:comment 'Current actual FTE headcount for this job profile within this organizational unit. Updated as employees are hired, transferred, or terminated.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualLaborBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Labor Budget' ;
    rdfs:comment 'Annual labor cost budget allocated to this organizational unit in local currency. Used for variance analysis and cost control. [Moved from org_unit: Labor budget is allocated by job profile within each org unit, not as a single lump sum. The total labor budget for an org unit is the SUM of staffing_plan.annual_labor_cost_budget across all job profile allocations. This should be removed from org_unit and calculated from the association.]' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualLaborCostBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Labor Cost Budget' ;
    rdfs:comment 'Total annual labor cost budget for this job profile allocation within this org unit. Calculated from FTE count and pay range.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date when this staffing allocation was formally approved through the workforce planning approval workflow.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetedFteCount rdf:type rdf:Property ;
    rdfs:label 'Budgeted Fte Count' ;
    rdfs:comment 'Budgeted full-time equivalent count for this job profile in this org unit. Used for labor budget planning and variance analysis.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headcountActual rdf:type rdf:Property ;
    rdfs:label 'Headcount Actual' ;
    rdfs:comment 'Current actual full-time equivalent (FTE) headcount assigned to this organizational unit. Updated from active employee assignments. [Moved from org_unit: Similar to headcount_planned, actual headcount is tracked at the org_unit × job_profile level in workforce planning systems. The actual headcount for an org unit is the SUM of staffing_plan.actual_headcount across all job profiles. This should be a derived metric, not stored on org_unit.]' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountAllocated rdf:type rdf:Property ;
    rdfs:label 'Headcount Allocated' ;
    rdfs:comment 'Planned or budgeted FTE headcount for this job profile within this organizational unit. This is the approved staffing level from the workforce planning cycle.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headcountPlanned rdf:type rdf:Property ;
    rdfs:label 'Headcount Planned' ;
    rdfs:comment 'Planned full-time equivalent (FTE) headcount for this organizational unit. Used for workforce planning and budget allocation. [Moved from org_unit: This attribute represents planned headcount at the org unit level, but in reality, headcount planning is done at the org_unit × job_profile granularity. The planned headcount for a store or department is the SUM of staffing_plan.headcount_allocated across all job profiles for that org unit. This attribute should be removed from org_unit and calculated from the association.]' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningCycle rdf:type rdf:Property ;
    rdfs:label 'Planning Cycle' ;
    rdfs:comment 'Identifier for the workforce planning cycle this allocation belongs to (e.g., FY2024-Q1, Annual-2024). Links staffing decisions to budget cycles.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffingPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Staffing Plan Status' ;
    rdfs:comment 'Lifecycle status of this staffing allocation. Tracks workflow state from draft through approval to active deployment. Values: draft, pending_approval, approved, active, historical, cancelled.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceFte rdf:type rdf:Property ;
    rdfs:label 'Variance Fte' ;
    rdfs:comment 'Variance between budgeted and actual FTE count (actual minus budgeted). Used for workforce planning variance reporting.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zonePriceListAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Zone Price List Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for this assignment record. Primary key enabling tracking of individual price list deployments to zones.' ;
    rdfs:domain ind:ZonePriceListAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedBy rdf:type rdf:Property ;
    rdfs:label 'Assigned By' ;
    rdfs:comment 'Name or employee identifier of the pricing analyst or merchandising manager who created this assignment. Supports accountability and workflow tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'Business reason for this specific price list assignment. Examples: NEW_MARKET_ENTRY, COMPETITIVE_RESPONSE, SEASONAL_STRATEGY, CLEARANCE_EVENT. Supports audit and pricing strategy analysis.' ;
    rdfs:domain ind:ZonePriceListAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyConversionRate rdf:type rdf:Property ;
    rdfs:label 'Currency Conversion Rate' ;
    rdfs:comment 'Exchange rate applied when the price list currency differs from the zone currency. Enables cross-border pricing strategies with zone-specific conversion rates that may differ from corporate treasury rates.' ;
    rdfs:domain ind:ZonePriceListAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideRules rdf:type rdf:Property ;
    rdfs:label 'Override Rules' ;
    rdfs:comment 'JSON or structured text defining zone-specific pricing rules that modify the base price list behavior. Examples include competitive match rules, minimum margin floors, or promotional restrictions unique to this zone-list combination.' ;
    rdfs:domain ind:ZonePriceListAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentBannerTargetingId rdf:type rdf:Property ;
    rdfs:label 'Segment Banner Targeting Id' ;
    rdfs:comment 'Unique identifier for this segment-banner targeting relationship. Primary key.' ;
    rdfs:domain ind:SegmentBannerTargeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:metricEntityDependencyId rdf:type rdf:Property ;
    rdfs:label 'Metric Entity Dependency Id' ;
    rdfs:comment 'Unique identifier for this metric-entity dependency record. Primary key.' ;
    rdfs:domain ind:MetricEntityDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aggregationRole rdf:type rdf:Property ;
    rdfs:label 'Aggregation Role' ;
    rdfs:comment 'The role this entity plays in the metric calculation: BASE_MEASURE (provides the fact to aggregate), DIMENSION (provides grouping/slicing attributes), FILTER (used only for filtering), GROUPING (defines the grain of aggregation).' ;
    rdfs:domain ind:MetricEntityDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationOrder rdf:type rdf:Property ;
    rdfs:label 'Calculation Order' ;
    rdfs:comment 'Numeric sequence indicating the order in which this entity is joined or processed in the metric calculation. Lower numbers are processed first. Used for complex multi-step metric calculations.' ;
    rdfs:domain ind:MetricEntityDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dependencyType rdf:type rdf:Property ;
    rdfs:label 'Dependency Type' ;
    rdfs:comment 'Classification of the dependency relationship: DIRECT (entity is explicitly referenced in metric definition), INDIRECT (entity is required through transitive dependency), DERIVED (entity is computed from other entities for this metric).' ;
    rdfs:domain ind:MetricEntityDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityAlias rdf:type rdf:Property ;
    rdfs:label 'Entity Alias' ;
    rdfs:comment 'The alias or reference name used for this entity within the metric calculation expression. Used when the same entity is referenced multiple times with different join paths or filters.' ;
    rdfs:domain ind:MetricEntityDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Is Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether this entity dependency is mandatory for the metric calculation. True = metric cannot be calculated without this entity; False = entity is optional or conditional.' ;
    rdfs:domain ind:MetricEntityDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:joinCondition rdf:type rdf:Property ;
    rdfs:label 'Join Condition' ;
    rdfs:comment 'SQL join condition or semantic layer join expression that defines how this entity is joined to other entities in the metric calculation. Captures the ON clause logic.' ;
    rdfs:domain ind:MetricEntityDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:joinType rdf:type rdf:Property ;
    rdfs:label 'Join Type' ;
    rdfs:comment 'SQL join type used to connect this entity to the metric calculation (INNER, LEFT, RIGHT, FULL, CROSS). Defines how the entity participates in the metric query generation.' ;
    rdfs:domain ind:MetricEntityDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assortmentId rdf:type rdf:Property ;
    rdfs:label 'Assortment Id' ;
    rdfs:comment 'Unique identifier for this SKU-to-node assortment assignment record. Primary key.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationPriority rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority' ;
    rdfs:comment 'Priority ranking for inventory allocation when supply is constrained. Lower numbers indicate higher priority (1 = highest priority). Used by allocation engines to determine which nodes receive inventory first during shortages. Typically based on sales velocity, strategic importance, or customer service level agreements.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Effective Date' ;
    rdfs:comment 'Date when this SKU was first authorized to be stocked at this node. Marks the beginning of the assortment assignment. Used for assortment history tracking and performance analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'Date when this SKU was removed from the authorized assortment at this node. Null for currently active assignments. Used for assortment history and discontinued product tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Last Received Date' ;
    rdfs:comment 'Date when this SKU was last received into inventory at this node. Used to identify slow-moving or stale inventory, support FIFO/FEFO rotation, and flag potential obsolescence. Updated by warehouse management system upon receipt confirmation.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stockingStatus rdf:type rdf:Property ;
    rdfs:label 'Stocking Status' ;
    rdfs:comment 'Current stocking status of this SKU at this specific node. ACTIVE (currently stocked and replenished), DISCONTINUED (no longer carried at this location), SEASONAL (stocked only during specific seasons), CLEARANCE (final inventory selldown), PENDING_SETUP (authorized but not yet received), TEMPORARY_OUT (temporarily not stocked). This is node-specific and can differ from the SKU\'s global lifecycle_status.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoStockAllocationId rdf:type rdf:Property ;
    rdfs:label 'Promo Stock Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for each promotional stock allocation record' ;
    rdfs:domain ind:PromoStockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Allocation Created By' ;
    rdfs:comment 'User ID or system identifier that created this promotional stock allocation' ;
    rdfs:domain ind:PromoStockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationCreatedDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Created Date' ;
    rdfs:comment 'Timestamp when this promotional stock allocation record was created by the promotion planning system' ;
    rdfs:domain ind:PromoStockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle status of this promotional stock allocation. planned: allocation created but offer not yet active; active: offer live and inventory allocated; depleted: reserved inventory exhausted; cancelled: allocation cancelled before completion; completed: offer period ended normally' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayLocationCode rdf:type rdf:Property ;
    rdfs:label 'Display Location Code' ;
    rdfs:comment 'Specific in-store display location code for this promotional stock allocation (e.g., ENDCAP_A1, FEATURE_TABLE_3, GONDOLA_END_B5), indicating where this SKU should be merchandised for this promotion' ;
    rdfs:domain ind:PromoStockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerEndDate rdf:type rdf:Property ;
    rdfs:label 'Offer End Date' ;
    rdfs:comment 'The date when this specific stock position is no longer eligible for this promotional offer at this location' ;
    rdfs:domain ind:PromoStockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerStartDate rdf:type rdf:Property ;
    rdfs:label 'Offer Start Date' ;
    rdfs:comment 'The date when this specific stock position becomes eligible for this promotional offer at this location (may differ from campaign-level dates due to inventory availability or regional rollout)' ;
    rdfs:domain ind:PromoStockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalInventoryReserveQty rdf:type rdf:Property ;
    rdfs:label 'Promotional Inventory Reserve Qty' ;
    rdfs:comment 'Quantity of inventory at this stock position reserved specifically for this promotional offer, ensuring adequate stock for the promotion duration and preventing depletion by non-promotional sales' ;
    rdfs:domain ind:PromoStockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalPrice rdf:type rdf:Property ;
    rdfs:label 'Promotional Price' ;
    rdfs:comment 'The specific promotional price for this SKU at this location under this offer, calculated based on the offer discount mechanics applied to the regular price' ;
    rdfs:domain ind:PromoStockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalQuantityThreshold rdf:type rdf:Property ;
    rdfs:label 'Promotional Quantity Threshold' ;
    rdfs:comment 'Minimum or target quantity threshold for this SKU-location to participate in the promotional offer (e.g., minimum display quantity, BOGO threshold)' ;
    rdfs:domain ind:PromoStockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalRevenue rdf:type rdf:Property ;
    rdfs:label 'Promotional Revenue' ;
    rdfs:comment 'Total revenue generated from sales of this SKU at this location under this promotional offer' ;
    rdfs:domain ind:PromoStockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clusterMembershipId rdf:type rdf:Property ;
    rdfs:label 'Cluster Membership Id' ;
    rdfs:comment 'Unique identifier for this store cluster membership record. Primary key for the association.' ;
    rdfs:domain ind:ClusterMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text notes providing additional context about this cluster membership assignment. Used to document special circumstances, exceptions, or business rationale.' ;
    rdfs:domain ind:ClusterMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of this cluster membership. Active = currently in operational use; Pending = scheduled for future activation; Suspended = temporarily inactive; Expired = past membership; Overridden = superseded by manual reassignment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterAssignmentReason rdf:type rdf:Property ;
    rdfs:label 'Cluster Assignment Reason' ;
    rdfs:comment 'Business justification or methodology for assigning this store to this cluster. Examples: algorithmic segmentation based on sales patterns, manual override by merchandising team, geographic proximity, demographic alignment, performance tier classification.' ;
    rdfs:domain ind:ClusterMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryCluster rdf:type rdf:Property ;
    rdfs:label 'Is Primary Cluster' ;
    rdfs:comment 'Indicates whether this cluster is the primary cluster assignment for this store location within this cluster type. Used when a store belongs to multiple clusters of the same type and one must be designated as primary for operational purposes.' ;
    rdfs:domain ind:ClusterMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:membershipEndDate rdf:type rdf:Property ;
    rdfs:label 'Membership End Date' ;
    rdfs:comment 'Date when this store location ceased to be a member of this cluster. Null indicates current active membership. Used for historical analysis of cluster composition changes.' ;
    rdfs:domain ind:ClusterMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipStartDate rdf:type rdf:Property ;
    rdfs:label 'Membership Start Date' ;
    rdfs:comment 'Date when this store location became a member of this cluster. Supports temporal tracking of cluster membership changes over time.' ;
    rdfs:domain ind:ClusterMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formatOfferEligibilityId rdf:type rdf:Property ;
    rdfs:label 'Format Offer Eligibility Id' ;
    rdfs:comment 'Unique identifier for this format-offer eligibility configuration record. Primary key.' ;
    rdfs:domain ind:FormatOfferEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Eligibility Flag' ;
    rdfs:comment 'Indicates whether this promotional offer is eligible for activation in stores of this format. False indicates the offer is explicitly excluded from this format type.' ;
    rdfs:domain ind:FormatOfferEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localizedDiscountValue rdf:type rdf:Property ;
    rdfs:label 'Localized Discount Value' ;
    rdfs:comment 'Format-specific discount value that overrides the base discount_value from promo_offer. Allows hypermarkets to offer deeper discounts than convenience stores for the same promotional campaign. Null indicates use of base offer discount_value.' ;
    rdfs:domain ind:FormatOfferEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localizedMinimumPurchase rdf:type rdf:Property ;
    rdfs:label 'Localized Minimum Purchase' ;
    rdfs:comment 'Format-specific minimum purchase amount required to qualify for this offer, overriding the base minimum_purchase_amount from promo_offer. Reflects typical basket size differences across formats—convenience stores may have lower thresholds than hypermarkets. Null indicates use of base offer threshold.' ;
    rdfs:domain ind:FormatOfferEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierAgreementId rdf:type rdf:Property ;
    rdfs:label 'Carrier Agreement Id' ;
    rdfs:comment 'Unique identifier for this store-carrier service agreement record. Primary key.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeStatus rdf:type rdf:Property ;
    rdfs:label 'Active Status' ;
    rdfs:comment 'Indicates whether this store-carrier agreement is currently active and available for use in carrier selection and routing logic. False indicates suspended or inactive agreement.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiatedRate rdf:type rdf:Property ;
    rdfs:label 'Negotiated Rate' ;
    rdfs:comment 'The store-specific negotiated shipping rate per unit (per pound or per shipment) that may differ from the carrier\'s standard rate card due to volume commitments or regional agreements.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickupFrequency rdf:type rdf:Property ;
    rdfs:label 'Pickup Frequency' ;
    rdfs:comment 'The frequency with which this carrier picks up shipments from this store location, defining the operational cadence of the store-carrier relationship.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelAgreement rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement' ;
    rdfs:comment 'The contracted service level commitment for this store-carrier relationship, defining expected delivery speed and service quality standards.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCommitmentMonthly rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Monthly' ;
    rdfs:comment 'The minimum number of shipments per month that this store location has committed to route through this carrier as part of the negotiated rate agreement. Null if no volume commitment exists.' ;
    rdfs:domain ind:CarrierAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storefrontFulfillmentNetworkId rdf:type rdf:Property ;
    rdfs:label 'Storefront Fulfillment Network Id' ;
    rdfs:comment 'Unique surrogate identifier for each storefront-to-DC fulfillment routing configuration record' ;
    rdfs:domain ind:StorefrontFulfillmentNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfillmentPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Priority Rank' ;
    rdfs:comment 'Integer ranking indicating the priority order in which this DC should be considered for fulfilling orders from this storefront (1 = highest priority). Lower numbers are attempted first in order routing logic.' ;
    rdfs:domain ind:StorefrontFulfillmentNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxDailyOrderCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Daily Order Capacity' ;
    rdfs:comment 'The maximum number of orders from this storefront that this DC can process per day under this routing configuration. Used for capacity-aware order routing to prevent DC overload.' ;
    rdfs:domain ind:StorefrontFulfillmentNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shippingCostTier rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost Tier' ;
    rdfs:comment 'The cost tier classification for shipping from this DC to customers in this storefront\'s primary market (e.g., TIER_1 for lowest cost local fulfillment, TIER_5 for highest cost cross-country fulfillment). Used in fulfillment cost optimization.' ;
    rdfs:domain ind:StorefrontFulfillmentNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityTrainingRequirementId rdf:type rdf:Property ;
    rdfs:label 'Facility Training Requirement Id' ;
    rdfs:comment 'Unique identifier for this facility-specific training requirement record. Primary key.' ;
    rdfs:domain ind:FacilityTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Compliance Rate Percentage' ;
    rdfs:comment 'Percentage of target associates at this facility who have completed this training program and are currently compliant. Calculated metric updated periodically.' ;
    rdfs:domain ind:FacilityTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilitySpecificContent rdf:type rdf:Property ;
    rdfs:label 'Facility Specific Content' ;
    rdfs:comment 'Description of any facility-specific training content, addendums, or customizations required for this DC (e.g., facility layout, local emergency procedures, site-specific equipment).' ;
    rdfs:domain ind:FacilityTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityTrainingCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Facility Training Coordinator Name' ;
    rdfs:comment 'Name of the individual at this facility responsible for coordinating and tracking completion of this training program.' ;
    rdfs:domain ind:FacilityTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Last Training Date' ;
    rdfs:comment 'Date when this training program was most recently delivered or completed by associates at this facility. Used to calculate next due date and compliance status.' ;
    rdfs:domain ind:FacilityTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requirementEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Requirement Effective Date' ;
    rdfs:comment 'Date when this training requirement became effective at this facility. Used to track when new training programs are rolled out to specific DCs.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requirementStatus rdf:type rdf:Property ;
    rdfs:label 'Requirement Status' ;
    rdfs:comment 'Current status of this training requirement at this facility. Active requirements are enforced; planned are scheduled for future deployment; suspended are temporarily paused; retired are no longer required.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAssociatesCompliant rdf:type rdf:Property ;
    rdfs:label 'Total Associates Compliant' ;
    rdfs:comment 'Number of associates at this facility who have completed this training and are currently compliant (certification not expired).' ;
    rdfs:domain ind:FacilityTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAssociatesRequired rdf:type rdf:Property ;
    rdfs:label 'Total Associates Required' ;
    rdfs:comment 'Total number of associates at this facility who are required to complete this training based on their job roles and the target audience definition.' ;
    rdfs:domain ind:FacilityTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorCategorySourcingId rdf:type rdf:Property ;
    rdfs:label 'Vendor Category Sourcing Id' ;
    rdfs:comment 'Unique identifier for this vendor-category sourcing relationship. Primary key.' ;
    rdfs:domain ind:VendorCategorySourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categorySpendAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Category Spend Allocation Pct' ;
    rdfs:comment 'Target percentage of category spend allocated to this vendor. Used in OTB planning and vendor negotiation. Sum across all vendors for a category should approach 100%.' ;
    rdfs:domain ind:VendorCategorySourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fillRateSlaPct rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Sla Pct' ;
    rdfs:comment 'Service level agreement for fill rate (percentage of ordered quantity delivered) specific to this vendor-category relationship. Negotiated based on category criticality and vendor capability.' ;
    rdfs:domain ind:VendorCategorySourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredVendorRank rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Rank' ;
    rdfs:comment 'Ranking of this vendor within the category\'s approved vendor list. Rank 1 indicates primary/preferred vendor. Used by buyers to prioritize sourcing decisions and PO allocation.' ;
    rdfs:domain ind:VendorCategorySourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourcingStatus rdf:type rdf:Property ;
    rdfs:label 'Sourcing Status' ;
    rdfs:comment 'Current status of the vendor-category sourcing relationship. Active=currently sourcing, Pending=approved but not yet active, Suspended=temporarily halted, Terminated=ended, Under Review=performance review in progress.' ;
    rdfs:domain ind:VendorCategorySourcing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorTrainingRequirementId rdf:type rdf:Property ;
    rdfs:label 'Vendor Training Requirement Id' ;
    rdfs:comment 'Unique identifier for this vendor training requirement record. Primary key for the association.' ;
    rdfs:domain ind:VendorTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionDeadline rdf:type rdf:Property ;
    rdfs:label 'Completion Deadline' ;
    rdfs:comment 'Date by which the vendor must complete this training program to maintain compliance. May be driven by contract effective dates, regulatory deadlines, or onboarding schedules.' ;
    rdfs:domain ind:VendorTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Last Completion Date' ;
    rdfs:comment 'Date when the vendor most recently completed this training program. Used to calculate compliance status and determine when renewal is required based on program completion frequency.' ;
    rdfs:domain ind:VendorTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredFlag rdf:type rdf:Property ;
    rdfs:label 'Required Flag' ;
    rdfs:comment 'Indicates whether this training program is mandatory for this vendor (true) or optional/recommended (false). Driven by regulatory requirements, contract terms, or risk assessment.' ;
    rdfs:domain ind:VendorTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requirementSource rdf:type rdf:Property ;
    rdfs:label 'Requirement Source' ;
    rdfs:comment 'Origin of this training requirement. Regulatory mandate: required by law (FSMA, OSHA, PCI-DSS). Contract term: specified in supply agreement. Risk assessment: identified through vendor risk review. Industry standard: best practice. Corporate policy: internal requirement.' ;
    rdfs:domain ind:VendorTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardAccessId rdf:type rdf:Property ;
    rdfs:label 'Dashboard Access Id' ;
    rdfs:comment 'Unique identifier for this dashboard access record. Primary key for the association.' ;
    rdfs:domain ind:DashboardAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessCount rdf:type rdf:Property ;
    rdfs:label 'Access Count' ;
    rdfs:comment 'Cumulative number of times this associate has accessed this specific dashboard. Usage analytics metric for measuring dashboard adoption per user.' ;
    rdfs:domain ind:DashboardAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessGrantedDate rdf:type rdf:Property ;
    rdfs:label 'Access Granted Date' ;
    rdfs:comment 'Date when access to this dashboard was provisioned for this associate. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:DashboardAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accessRevokedDate rdf:type rdf:Property ;
    rdfs:label 'Access Revoked Date' ;
    rdfs:comment 'Date when access to this dashboard was revoked or expired for this associate. Null for active access. Used for access audit trails.' ;
    rdfs:domain ind:DashboardAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accessStatus rdf:type rdf:Property ;
    rdfs:label 'Access Status' ;
    rdfs:comment 'Current lifecycle status of this access grant: active (currently valid), suspended (temporarily disabled), revoked (permanently removed), expired (time-limited access ended).' ;
    rdfs:domain ind:DashboardAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customFilterSettings rdf:type rdf:Property ;
    rdfs:label 'Custom Filter Settings' ;
    rdfs:comment 'JSON structure storing this associate\'s personalized filter preferences for this dashboard (e.g., default store selection, date range preferences). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:DashboardAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:favoriteFlag rdf:type rdf:Property ;
    rdfs:label 'Favorite Flag' ;
    rdfs:comment 'Boolean indicator of whether this associate has marked this dashboard as a favorite for quick access. User personalization setting. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:DashboardAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storefrontAssortmentId rdf:type rdf:Property ;
    rdfs:label 'Storefront Assortment Id' ;
    rdfs:comment 'Unique identifier for this storefront-specific assortment execution record. Primary key.' ;
    rdfs:domain ind:StorefrontAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publishedByAssociateId rdf:type rdf:Property ;
    rdfs:label 'Published By Associate Id' ;
    rdfs:comment 'Reference to the user (merchandiser or e-commerce manager) who published this assortment configuration to the storefront.' ;
    rdfs:domain ind:StorefrontAssortment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:localizedAssortmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Localized Assortment Strategy' ;
    rdfs:comment 'Detailed description of how the assortment plan is adapted for this storefront\'s market, including SKU selection rationale, depth/breadth adjustments, locale-specific product preferences, competitive positioning, and any regulatory or cultural considerations.' ;
    rdfs:domain ind:StorefrontAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizedOtbBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Localized Otb Budget Amount' ;
    rdfs:comment 'Open-to-Buy budget allocated specifically for this storefront\'s execution of the assortment plan. Represents the portion of the plan\'s total OTB budget allocated to this channel.' ;
    rdfs:domain ind:StorefrontAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skuCountTarget rdf:type rdf:Property ;
    rdfs:label 'Sku Count Target' ;
    rdfs:comment 'Target number of SKUs to be carried on this specific storefront for this assortment plan. May be a subset of the plan\'s global planned_sku_count due to locale preferences, regulatory restrictions, warehouse availability, or market size.' ;
    rdfs:domain ind:StorefrontAssortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storefrontResponsibilityId rdf:type rdf:Property ;
    rdfs:label 'Storefront Responsibility Id' ;
    rdfs:comment 'Unique surrogate identifier for each buyer-storefront responsibility assignment record. Primary key.' ;
    rdfs:domain ind:StorefrontResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalAuthorityOverride rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Override' ;
    rdfs:comment 'Optional override of the buyers standard buying_authority_limit specifically for this storefront. Null if the buyers default authority applies. Used when certain channels require different approval thresholds due to risk profile or business model differences.' ;
    rdfs:domain ind:StorefrontResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'The calendar date on which this buyer was assigned buying responsibility for this storefront. Used to track assignment history and tenure per channel.' ;
    rdfs:domain ind:StorefrontResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetAllocation rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation' ;
    rdfs:comment 'The portion of the buyers total OTB budget allocated specifically to this storefront for the current fiscal period. Enables tracking of multi-channel budget distribution and storefront-specific spending authority.' ;
    rdfs:domain ind:StorefrontResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:categoryList rdf:type rdf:Property ;
    rdfs:label 'Category List' ;
    rdfs:comment 'Comma-separated list of category codes for which this buyer has purchasing and assortment responsibility specifically for this storefront. May differ from the buyers overall assigned_category_codes if storefront-specific scope is narrower or different.' ;
    rdfs:domain ind:StorefrontResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceTarget rdf:type rdf:Property ;
    rdfs:label 'Performance Target' ;
    rdfs:comment 'JSON or structured text capturing storefront-specific performance targets for this buyer assignment, which may include GMROI, sell-through rate, inventory turn, and other KPIs that differ by channel due to different customer demographics, fulfillment models, or competitive dynamics.' ;
    rdfs:domain ind:StorefrontResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryResponsibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Responsibility Flag' ;
    rdfs:comment 'Indicates whether this storefront is the buyers primary channel responsibility. Used when a buyer manages multiple storefronts but one is their main focus or accountability center.' ;
    rdfs:domain ind:StorefrontResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibilityScope rdf:type rdf:Property ;
    rdfs:label 'Responsibility Scope' ;
    rdfs:comment 'Classification of the scope of buying responsibility for this buyer-storefront combination. Indicates whether the buyer manages the full assortment, a subset of categories/departments, or specific product types (private label, seasonal) for this storefront.' ;
    rdfs:domain ind:StorefrontResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storefrontResponsibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Storefront Responsibility Status' ;
    rdfs:comment 'Current operational status of this buyer-storefront responsibility assignment. ACTIVE indicates the buyer is currently responsible; INACTIVE indicates the assignment has ended; SUSPENDED indicates temporary removal of responsibility; PENDING indicates future-dated assignment.' ;
    rdfs:domain ind:StorefrontResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerProfitCenterAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Buyer Profit Center Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for this buyer-profit center assignment record. Primary key.' ;
    rdfs:domain ind:BuyerProfitCenterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedCategoryList rdf:type rdf:Property ;
    rdfs:label 'Assigned Category List' ;
    rdfs:comment 'Comma-separated list of category codes for which this buyer has purchasing responsibility within this specific profit center. Categories may vary by profit center based on channel strategy and assortment localization.' ;
    rdfs:domain ind:BuyerProfitCenterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otbAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Otb Allocation Amount' ;
    rdfs:comment 'Open-to-Buy budget amount allocated to this buyer for the assigned categories within this profit center for the current fiscal period. Represents the buyer\'s spending authority for this specific profit center.' ;
    rdfs:domain ind:BuyerProfitCenterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Flag' ;
    rdfs:comment 'Indicates whether this profit center represents the buyer\'s primary area of responsibility. Used for workload balancing and performance evaluation prioritization.' ;
    rdfs:domain ind:BuyerProfitCenterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:campaignFulfillmentId rdf:type rdf:Property ;
    rdfs:label 'Campaign Fulfillment Id' ;
    rdfs:comment 'Unique identifier for this campaign-to-DC fulfillment assignment record. Primary key.' ;
    rdfs:domain ind:CampaignFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedInventoryUnits rdf:type rdf:Property ;
    rdfs:label 'Allocated Inventory Units' ;
    rdfs:comment 'Number of inventory units (SKUs, cases, or pallets) allocated to this DC for fulfilling demand generated by this campaign. Represents pre-positioned or reserved inventory.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfillmentSlaHours rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Sla Hours' ;
    rdfs:comment 'Target number of hours from order placement to shipment for campaign orders fulfilled by this DC. Campaign-specific SLA may be tighter than standard DC SLA for high-priority campaigns.' ;
    rdfs:domain ind:CampaignFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicCoverageCodes rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Codes' ;
    rdfs:comment 'Comma-separated list of postal codes, regions, or zones that this DC is responsible for fulfilling within the context of this campaign. Defines the geographic split when multiple DCs support one campaign.' ;
    rdfs:domain ind:CampaignFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignPolicyComplianceId rdf:type rdf:Property ;
    rdfs:label 'Campaign Policy Compliance Id' ;
    rdfs:comment 'Unique identifier for this campaign-policy compliance record. Primary key.' ;
    rdfs:domain ind:CampaignPolicyCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Associate Id' ;
    rdfs:comment 'Identifier of the compliance team member who reviewed and verified this campaign against this policy. Explicitly identified in detection phase.' ;
    rdfs:domain ind:CampaignPolicyCompliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:complianceVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Verification Status' ;
    rdfs:comment 'Current status of compliance verification for this campaign-policy pair. Values: pending, verified, non_compliant, exception_granted, under_review. Explicitly identified in detection phase.' ;
    rdfs:domain ind:CampaignPolicyCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Exception Expiration Date' ;
    rdfs:comment 'Date when the granted policy exception expires and the campaign must come into full compliance. Nullable if no exception granted. Explicitly identified in detection phase.' ;
    rdfs:domain ind:CampaignPolicyCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exceptionGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Granted Flag' ;
    rdfs:comment 'Indicates whether an exception to this policy was granted for this campaign. Explicitly identified in detection phase.' ;
    rdfs:domain ind:CampaignPolicyCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionJustification rdf:type rdf:Property ;
    rdfs:label 'Exception Justification' ;
    rdfs:comment 'Business justification for why a policy exception was granted for this campaign-policy pair.' ;
    rdfs:domain ind:CampaignPolicyCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Notes' ;
    rdfs:comment 'Detailed notes describing any non-compliance issues identified during verification, including remediation steps required.' ;
    rdfs:domain ind:CampaignPolicyCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierFacilityContractId rdf:type rdf:Property ;
    rdfs:label 'Carrier Facility Contract Id' ;
    rdfs:comment 'Unique identifier for this carrier-facility service contract record. Primary key.' ;
    rdfs:domain ind:CarrierFacilityContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedDockDoors rdf:type rdf:Property ;
    rdfs:label 'Assigned Dock Doors' ;
    rdfs:comment 'Comma-separated list of dock door numbers or identifiers assigned to this carrier at this facility for loading operations.' ;
    rdfs:domain ind:CarrierFacilityContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyPickupSchedule rdf:type rdf:Property ;
    rdfs:label 'Daily Pickup Schedule' ;
    rdfs:comment 'Scheduled pickup times for this carrier at this facility, typically in format HH:MM or multiple times (e.g., 10:00,14:00,18:00), defining when the carrier collects outbound shipments.' ;
    rdfs:domain ind:CarrierFacilityContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Facility Discount Percentage' ;
    rdfs:comment 'Additional volume-based discount percentage negotiated specifically for this facility based on shipment volume commitments.' ;
    rdfs:domain ind:CarrierFacilityContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilitySpecificBaseRate rdf:type rdf:Property ;
    rdfs:label 'Facility Specific Base Rate' ;
    rdfs:comment 'Negotiated base shipping rate per pound for this specific carrier-facility combination, potentially different from the carrier\'s standard base rate due to facility volume or regional pricing.' ;
    rdfs:domain ind:CarrierFacilityContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxDailyVolumePackages rdf:type rdf:Property ;
    rdfs:label 'Max Daily Volume Packages' ;
    rdfs:comment 'Maximum number of packages this carrier commits to pick up daily from this facility under the service agreement.' ;
    rdfs:domain ind:CarrierFacilityContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateTier rdf:type rdf:Property ;
    rdfs:label 'Rate Tier' ;
    rdfs:comment 'Negotiated rate tier or pricing level for this specific facility, which may differ from the carrier\'s standard rates based on facility volume commitments.' ;
    rdfs:domain ind:CarrierFacilityContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelsEnabled rdf:type rdf:Property ;
    rdfs:label 'Service Levels Enabled' ;
    rdfs:comment 'Comma-separated list or JSON array of service levels enabled for this carrier-facility combination (e.g., ground, two_day, overnight), as not all carrier services may be available at all facilities.' ;
    rdfs:domain ind:CarrierFacilityContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaOnTimePercentage rdf:type rdf:Property ;
    rdfs:label 'Sla On Time Percentage' ;
    rdfs:comment 'Service level agreement percentage for on-time delivery performance that this carrier commits to for shipments originating from this facility.' ;
    rdfs:domain ind:CarrierFacilityContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedDate rdf:type rdf:Property ;
    rdfs:label 'Updated Date' ;
    rdfs:comment 'Timestamp when this carrier-facility contract record was last modified.' ;
    rdfs:domain ind:CarrierFacilityContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:categoryAccrualRuleId rdf:type rdf:Property ;
    rdfs:label 'Category Accrual Rule Id' ;
    rdfs:comment 'Unique identifier for this category-accrual rule assignment. Primary key.' ;
    rdfs:domain ind:CategoryAccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryAccrualRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Category Accrual Rule Status' ;
    rdfs:comment 'Current lifecycle status of this category-accrual rule assignment (active, inactive, scheduled, expired). Allows independent lifecycle management of category-rule assignments.' ;
    rdfs:domain ind:CategoryAccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circularAdCategoryFeatureId rdf:type rdf:Property ;
    rdfs:label 'Circular Ad Category Feature Id' ;
    rdfs:comment 'Unique identifier for this circular ad category feature placement. Primary key.' ;
    rdfs:domain ind:CircularAdCategoryFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedByAssociateId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By Associate Id' ;
    rdfs:comment 'Reference to the user who last modified this category feature record.' ;
    rdfs:domain ind:CircularAdCategoryFeature ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:allocatedSpaceSqin rdf:type rdf:Property ;
    rdfs:label 'Allocated Space Sqin' ;
    rdfs:comment 'Total space allocated to this category feature measured in square inches. Used for space allocation planning and cost allocation across categories.' ;
    rdfs:domain ind:CircularAdCategoryFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:categorySalesTarget rdf:type rdf:Property ;
    rdfs:label 'Category Sales Target' ;
    rdfs:comment 'Sales target amount for this category driven by this specific circular edition. Used to measure circular effectiveness and category-level promotional ROI.' ;
    rdfs:domain ind:CircularAdCategoryFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featureProminence rdf:type rdf:Property ;
    rdfs:label 'Feature Prominence' ;
    rdfs:comment 'Classification of the visual prominence and placement strategy for this category feature (e.g., front_cover, center_spread, endcap_feature, in_book). Drives promotional effectiveness analysis.' ;
    rdfs:domain ind:CircularAdCategoryFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureSequence rdf:type rdf:Property ;
    rdfs:label 'Feature Sequence' ;
    rdfs:comment 'Sequence or order in which this category appears within the circular layout. Supports customer journey analysis and circular flow optimization.' ;
    rdfs:domain ind:CircularAdCategoryFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:featuredSkuCount rdf:type rdf:Property ;
    rdfs:label 'Featured Sku Count' ;
    rdfs:comment 'Number of individual SKUs from this category featured in this circular. Supports assortment depth analysis and category representation metrics.' ;
    rdfs:domain ind:CircularAdCategoryFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pageNumber rdf:type rdf:Property ;
    rdfs:label 'Page Number' ;
    rdfs:comment 'Page number(s) where this category is featured within the circular. Supports planogram alignment and feature prominence analysis.' ;
    rdfs:domain ind:CircularAdCategoryFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesLiftPercent rdf:type rdf:Property ;
    rdfs:label 'Sales Lift Percent' ;
    rdfs:comment 'Percentage lift in category sales compared to baseline (non-circular period). Calculated post-campaign to measure incremental impact of the circular feature.' ;
    rdfs:domain ind:CircularAdCategoryFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Target Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the category sales target amount (e.g., USD, CAD, EUR).' ;
    rdfs:domain ind:CircularAdCategoryFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficAttributionPercent rdf:type rdf:Property ;
    rdfs:label 'Traffic Attribution Percent' ;
    rdfs:comment 'Estimated percentage of store traffic or digital visits attributed to this category feature based on customer surveys or digital analytics. Used for traffic driver analysis.' ;
    rdfs:domain ind:CircularAdCategoryFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorCoOpAmount rdf:type rdf:Property ;
    rdfs:label 'Vendor Co Op Amount' ;
    rdfs:comment 'Amount of vendor co-op funding allocated to this specific category feature within the circular. Null if vendor_co_op_flag is false.' ;
    rdfs:domain ind:CircularAdCategoryFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorCoOpFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Co Op Flag' ;
    rdfs:comment 'Indicates whether this category feature includes vendor co-op funding or promotional allowances. Supports cost allocation and vendor partnership tracking.' ;
    rdfs:domain ind:CircularAdCategoryFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityComplianceCertificationId rdf:type rdf:Property ;
    rdfs:label 'Facility Compliance Certification Id' ;
    rdfs:comment 'Unique identifier for this facility-program certification record. Primary key.' ;
    rdfs:domain ind:FacilityComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Facility Risk Level' ;
    rdfs:comment 'Assessed risk severity for this specific facility under this compliance program. May differ from the enterprise program risk level based on facility-specific factors (e.g., a frozen food DC has higher food safety risk than an apparel DC).' ;
    rdfs:domain ind:FacilityComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponDistributionId rdf:type rdf:Property ;
    rdfs:label 'Coupon Distribution Id' ;
    rdfs:comment 'Unique identifier for this coupon distribution event. Primary key.' ;
    rdfs:domain ind:CouponDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionCost rdf:type rdf:Property ;
    rdfs:label 'Distribution Cost' ;
    rdfs:comment 'Total cost incurred to distribute this coupon to this segment, including channel fees, printing costs, postage, or digital delivery costs. Used for ROI analysis.' ;
    rdfs:domain ind:CouponDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Date' ;
    rdfs:comment 'Date when this coupon was distributed to this audience segment. Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:CouponDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Status' ;
    rdfs:comment 'Current status of the distribution event: scheduled (planned but not yet executed), in_progress (actively distributing), completed (distribution finished), failed (distribution encountered errors), cancelled (distribution was cancelled before completion).' ;
    rdfs:domain ind:CouponDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityDistributed rdf:type rdf:Property ;
    rdfs:label 'Quantity Distributed' ;
    rdfs:comment 'Number of coupon codes or physical coupons distributed to members of this audience segment. Explicitly identified in detection reasoning as relationship data.' ;
    rdfs:domain ind:CouponDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Redemption Rate Percent' ;
    rdfs:comment 'Percentage of distributed coupons that were redeemed by this segment (redemption_count / quantity_distributed * 100). Explicitly identified in detection reasoning as relationship data. Key performance metric for targeting effectiveness.' ;
    rdfs:domain ind:CouponDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:catalogNodeInventoryId rdf:type rdf:Property ;
    rdfs:label 'Catalog Node Inventory Id' ;
    rdfs:comment 'Primary key for the catalog_node_inventory association' ;
    rdfs:domain ind:CatalogNodeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAvailableForBopis rdf:type rdf:Property ;
    rdfs:label 'Is Available For Bopis' ;
    rdfs:comment 'Indicates whether this catalog SKU is currently available for Buy Online Pick Up In Store (BOPIS) fulfillment at this specific node. Node-specific because not all nodes support BOPIS and availability depends on local inventory and operational capacity.' ;
    rdfs:domain ind:CatalogNodeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAvailableForShipFromStore rdf:type rdf:Property ;
    rdfs:label 'Is Available For Ship From Store' ;
    rdfs:comment 'Indicates whether this catalog SKU is currently available for Ship-From-Store (SFS) fulfillment at this specific node. Node-specific because SFS capability depends on node type, pack station availability, and carrier assignments at the node level.' ;
    rdfs:domain ind:CatalogNodeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBopisEligible rdf:type rdf:Property ;
    rdfs:label 'Is Bopis Eligible' ;
    rdfs:comment 'Indicates whether the SKU is eligible for the Buy Online Pick Up In Store (BOPIS) fulfillment option on this storefront. Supports omnichannel fulfillment routing and online-to-offline attribution analytics. [Moved from digital_catalog: BOPIS eligibility is not a global catalog attribute but varies by fulfillment node. A SKU may be BOPIS-eligible at nodes with BOPIS capability and sufficient inventory, but not at nodes lacking BOPIS infrastructure or stock. This belongs in the catalog-node association as is_available_for_bopis.]' ;
    rdfs:domain ind:CatalogNodeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isShipFromStoreEligible rdf:type rdf:Property ;
    rdfs:label 'Is Ship From Store Eligible' ;
    rdfs:comment 'Indicates whether this SKU can be fulfilled via the Ship-from-Store (SFS) model, where a physical retail store acts as the fulfillment center for online orders. Supports distributed fulfillment network optimization. [Moved from digital_catalog: Ship-from-store eligibility is not a global catalog attribute but varies by fulfillment node capabilities. A SKU may be SFS-eligible at stores with pack stations and carrier contracts, but not at dark stores or MFCs with different fulfillment models. This belongs in the catalog-node association as is_available_for_ship_from_store.]' ;
    rdfs:domain ind:CatalogNodeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInventoryUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Inventory Update Timestamp' ;
    rdfs:comment 'Timestamp of the most recent inventory quantity update for this catalog-node pairing. Used to monitor inventory data freshness and trigger reconciliation processes.' ;
    rdfs:domain ind:CatalogNodeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:poShipmentReceiptId rdf:type rdf:Property ;
    rdfs:label 'Po Shipment Receipt Id' ;
    rdfs:comment 'Unique identifier for this purchase order shipment receipt record. Primary key.' ;
    rdfs:domain ind:PoShipmentReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:locationAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Location Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each location assignment record. Primary key for the association.' ;
    rdfs:domain ind:LocationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nodeInventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Node Inventory Node Id' ;
    rdfs:comment 'Foreign key linking to the inventory node (store, DC, MFC, or other location) where the associate is assigned to work.' ;
    rdfs:domain ind:LocationAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'Date when the associate\'s assignment to this inventory node location began. Used for tracking assignment history, tenure at location, and temporal workforce deployment analysis.' ;
    rdfs:domain ind:LocationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classification of the assignment nature. PERMANENT indicates standard long-term assignment, TEMPORARY for defined-duration transfers, SEASONAL for holiday/peak period deployment, CROSS_TRAINING for skill development assignments, EMERGENCY_COVERAGE for short-term staffing needs. Drives scheduling rules and labor planning.' ;
    rdfs:domain ind:LocationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLocationFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Location Flag' ;
    rdfs:comment 'Indicates whether this inventory node is the associate\'s primary work location (true) or a secondary/cross-training location (false). Used for labor cost allocation, scheduling priority, and determining home base for workforce planning.' ;
    rdfs:domain ind:LocationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roleAtLocation rdf:type rdf:Property ;
    rdfs:label 'Role At Location' ;
    rdfs:comment 'Specific role or function the associate performs at this inventory node, which may differ from their primary job title. Examples: Floor Associate, Receiving Clerk, Shift Supervisor, Cross-Training, Seasonal Support. Used for location-specific scheduling, task assignment, and workforce capability tracking.' ;
    rdfs:domain ind:LocationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assortmentDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Assortment Deployment Id' ;
    rdfs:comment 'Unique identifier for this deployment record. Primary key.' ;
    rdfs:domain ind:AssortmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planogramId rdf:type rdf:Property ;
    rdfs:label 'Planogram Id' ;
    rdfs:comment 'Reference to the specific planogram (shelf layout) used to implement this assortment plan at this location. May vary by store format or size.' ;
    rdfs:domain ind:AssortmentDeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchandisingPlanogram .

ind:responsibleBuyerId rdf:type rdf:Property ;
    rdfs:label 'Responsible Buyer Id' ;
    rdfs:comment 'Reference to the merchandise buyer responsible for ensuring this deployment is executed successfully at this location.' ;
    rdfs:domain ind:AssortmentDeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Buyer .

ind:compliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Compliance Percentage' ;
    rdfs:comment 'Percentage of planned SKUs that are actually in stock at this location, calculated as (actual_sku_count / planned_sku_count) * 100. Key metric for assortment execution quality.' ;
    rdfs:domain ind:AssortmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deploymentCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Deployment Completion Date' ;
    rdfs:comment 'Date when the assortment was fully deployed and reached initial compliance at this location.' ;
    rdfs:domain ind:AssortmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deploymentStartDate rdf:type rdf:Property ;
    rdfs:label 'Deployment Start Date' ;
    rdfs:comment 'Date when deployment activities began at this location (receiving, stocking, planogram setup).' ;
    rdfs:domain ind:AssortmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastComplianceCheckDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Check Date' ;
    rdfs:comment 'Date of the most recent compliance measurement for this deployment. Compliance is typically measured weekly or monthly.' ;
    rdfs:domain ind:AssortmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:categoryKpiTargetId rdf:type rdf:Property ;
    rdfs:label 'Category Kpi Target Id' ;
    rdfs:comment 'Unique identifier for this category-KPI target configuration record. Primary key.' ;
    rdfs:domain ind:CategoryKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertThreshold rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold' ;
    rdfs:comment 'The threshold value at which alerts should be triggered for this category-KPI combination. When actual performance crosses this threshold, notifications are sent to responsible_role. Example: Alert when shrink exceeds 2.5% for Electronics.' ;
    rdfs:domain ind:CategoryKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaKpiMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Sla Kpi Measurement Id' ;
    rdfs:comment 'Unique surrogate identifier for this SLA-KPI measurement binding record. Primary key.' ;
    rdfs:domain ind:SlaKpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Value' ;
    rdfs:comment 'An early-warning threshold value that triggers alerts before the breach threshold is reached. Allows proactive intervention when KPI performance is trending toward SLA breach.' ;
    rdfs:domain ind:SlaKpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Breach Penalty Rate' ;
    rdfs:comment 'The penalty rate applied when this specific KPI breaches the threshold for this specific SLA. Expressed as a percentage or per-unit rate depending on the SLA\'s penalty structure type. Allows different KPIs measuring the same SLA to have different penalty consequences.' ;
    rdfs:domain ind:SlaKpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryKpi rdf:type rdf:Property ;
    rdfs:label 'Is Primary Kpi' ;
    rdfs:comment 'Indicates whether this KPI is the primary/lead metric for this SLA (true) or a supporting/secondary metric (false). Used to distinguish the main performance indicator from supplementary metrics.' ;
    rdfs:domain ind:SlaKpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'Current operational status of this KPI-SLA measurement binding. Active means currently in use; Suspended means temporarily disabled; Under Review means being evaluated for changes; Deprecated means no longer used but retained for historical reference.' ;
    rdfs:domain ind:SlaKpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementWeight rdf:type rdf:Property ;
    rdfs:label 'Measurement Weight' ;
    rdfs:comment 'The relative weight or importance of this KPI in the overall SLA performance scorecard, expressed as a decimal (e.g., 0.30 for 30%). Used when multiple KPIs contribute to a composite SLA score.' ;
    rdfs:domain ind:SlaKpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workforceKpiTargetId rdf:type rdf:Property ;
    rdfs:label 'Workforce Kpi Target Id' ;
    rdfs:comment 'Primary key for workforce_kpi_target' ;
    rdfs:domain ind:WorkforceKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kpiTargetId rdf:type rdf:Property ;
    rdfs:label 'Kpi Target Id' ;
    rdfs:comment 'Unique identifier for this KPI target assignment record. Primary key.' ;
    rdfs:domain ind:WorkforceKpiTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnalyticsKpiTarget .

ind:targetSetByAssociateId rdf:type rdf:Property ;
    rdfs:label 'Target Set By Associate Id' ;
    rdfs:comment 'Reference to the employee who set or approved this target for this org unit. Typically a regional VP, divisional leader, or performance management analyst.' ;
    rdfs:domain ind:WorkforceKpiTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:accountabilityLevel rdf:type rdf:Property ;
    rdfs:label 'Accountability Level' ;
    rdfs:comment 'The level of accountability this org unit has for this KPI. Primary = directly accountable and performance-reviewed on this metric. Secondary = contributes but not primary owner. Informational = tracked for visibility but not performance-managed.' ;
    rdfs:domain ind:WorkforceKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isStretchTarget rdf:type rdf:Property ;
    rdfs:label 'Is Stretch Target' ;
    rdfs:comment 'Indicates whether this is a stretch target (aspirational, above normal expectations) versus a standard target. Used for performance review calibration.' ;
    rdfs:domain ind:WorkforceKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetSetDate rdf:type rdf:Property ;
    rdfs:label 'Target Set Date' ;
    rdfs:comment 'The date when this target was established in the system. Used for audit trail and understanding when targets were locked for a performance period.' ;
    rdfs:domain ind:WorkforceKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:thresholdGreen rdf:type rdf:Property ;
    rdfs:label 'Threshold Green' ;
    rdfs:comment 'The performance threshold at or above which this org unit\'s KPI performance is considered green/on-target for this period. Used for dashboard color-coding.' ;
    rdfs:domain ind:WorkforceKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdRed rdf:type rdf:Property ;
    rdfs:label 'Threshold Red' ;
    rdfs:comment 'The performance threshold below which this org unit\'s KPI performance is considered red/critical for this period. Used for dashboard color-coding and alert triggering.' ;
    rdfs:domain ind:WorkforceKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdYellow rdf:type rdf:Property ;
    rdfs:label 'Threshold Yellow' ;
    rdfs:comment 'The performance threshold below which this org unit\'s KPI performance is considered yellow/warning for this period. Used for dashboard color-coding.' ;
    rdfs:domain ind:WorkforceKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightPercentage rdf:type rdf:Property ;
    rdfs:label 'Weight Percentage' ;
    rdfs:comment 'The weight of this KPI in the org unit\'s overall performance scorecard (0-100%). Used for calculating composite performance scores and bonus calculations. Weights vary by org unit type and role.' ;
    rdfs:domain ind:WorkforceKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workforceKpiTargetStatus rdf:type rdf:Property ;
    rdfs:label 'Workforce Kpi Target Status' ;
    rdfs:comment 'Current status of this KPI target assignment. Draft targets are being negotiated, approved targets are locked for the period, active targets are currently in measurement, suspended targets are temporarily paused, archived targets are historical.' ;
    rdfs:domain ind:WorkforceKpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitComplianceScopeId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Compliance Scope Id' ;
    rdfs:comment 'Unique identifier for this org unit-compliance program scope assignment. Primary key.' ;
    rdfs:domain ind:OrgUnitComplianceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'Name or employee identifier of the individual responsible for compliance program implementation and monitoring at this specific org unit. Often the org unit manager or a designated compliance coordinator.' ;
    rdfs:domain ind:OrgUnitComplianceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeStatus rdf:type rdf:Property ;
    rdfs:label 'Scope Status' ;
    rdfs:comment 'Current status of this compliance program scope for this specific org unit. Active: program is enforced. Suspended: temporarily not enforced. Pending: implementation in progress. Exempt: org unit has formal exemption. Under_review: scope applicability being reassessed.' ;
    rdfs:domain ind:OrgUnitComplianceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Rate' ;
    rdfs:comment 'Percentage of required employees at this org unit who have completed mandatory training for this compliance program. Calculated as (completed_employees / required_employees) * 100.' ;
    rdfs:domain ind:OrgUnitComplianceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Client Relationship Id' ;
    rdfs:comment 'Unique identifier for this client-associate relationship assignment. Primary key.' ;
    rdfs:domain ind:ClientRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryContactFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Flag' ;
    rdfs:comment 'Boolean flag indicating whether this associate is the primary/lead contact for this customer when multiple associates serve the same customer across departments. True indicates primary relationship manager, false indicates supporting specialist.' ;
    rdfs:domain ind:ClientRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promoInventoryAllocationId rdf:type rdf:Property ;
    rdfs:label 'Promo Inventory Allocation Id' ;
    rdfs:comment 'Unique identifier for this promotional inventory allocation record. Primary key.' ;
    rdfs:domain ind:PromoInventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Percentage of total promotional inventory allocated to this facility for this campaign. Enables proportional distribution planning across the DC network.' ;
    rdfs:domain ind:PromoInventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Facility Priority Rank' ;
    rdfs:comment 'Priority ranking of this facility for this promotional campaign (1=highest priority). Used to sequence inventory distribution when supply is constrained or to prioritize high-performing regions.' ;
    rdfs:domain ind:PromoInventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingAccountId rdf:type rdf:Property ;
    rdfs:label 'Billing Account Id' ;
    rdfs:comment 'Identifier of the billing account responsible for workspace-related charges.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:ownerDepartmentId rdf:type rdf:Property ;
    rdfs:label 'Owner Department Id' ;
    rdfs:comment 'Identifier of the department that owns and manages this workspace.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:archiveAfterDays rdf:type rdf:Property ;
    rdfs:label 'Archive After Days' ;
    rdfs:comment 'Number of days of inactivity after which workspace content is automatically archived.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:archivedDate rdf:type rdf:Property ;
    rdfs:label 'Archived Date' ;
    rdfs:comment 'Date when the workspace was archived and moved to inactive status.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetCount rdf:type rdf:Property ;
    rdfs:label 'Asset Count' ;
    rdfs:comment 'Total number of data assets, reports, dashboards, or other objects contained within this workspace.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoArchiveEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Archive Enabled' ;
    rdfs:comment 'Indicates whether automatic archiving of inactive workspace content is enabled.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdByUserCode rdf:type rdf:Property ;
    rdfs:label 'Created By User Code' ;
    rdfs:comment 'Identifier of the user who created this workspace.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataResidencyCountry rdf:type rdf:Property ;
    rdfs:label 'Data Residency Country' ;
    rdfs:comment 'Three-letter country code indicating where workspace data must be stored for compliance purposes.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed description of the workspace purpose, scope, and intended use cases.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTemplate rdf:type rdf:Property ;
    rdfs:label 'Is Template' ;
    rdfs:comment 'Indicates whether this workspace serves as a template for creating new workspaces.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxMemberLimit rdf:type rdf:Property ;
    rdfs:label 'Max Member Limit' ;
    rdfs:comment 'Maximum number of users allowed to be members of this workspace.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Modified By User Code' ;
    rdfs:comment 'Identifier of the user who last modified this workspace configuration.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerUserCode rdf:type rdf:Property ;
    rdfs:label 'Owner User Code' ;
    rdfs:comment 'Identifier of the user who owns and is responsible for this workspace.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionPolicyDays rdf:type rdf:Property ;
    rdfs:label 'Retention Policy Days' ;
    rdfs:comment 'Number of days that data within this workspace must be retained before it can be purged.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageQuotaGb rdf:type rdf:Property ;
    rdfs:label 'Storage Quota Gb' ;
    rdfs:comment 'Maximum storage capacity allocated to this workspace measured in gigabytes.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageUsedGb rdf:type rdf:Property ;
    rdfs:label 'Storage Used Gb' ;
    rdfs:comment 'Current amount of storage consumed by this workspace measured in gigabytes.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:templateSourceCode rdf:type rdf:Property ;
    rdfs:label 'Template Source Code' ;
    rdfs:comment 'Identifier of the template workspace from which this workspace was created, if applicable.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workspaceCode rdf:type rdf:Property ;
    rdfs:label 'Workspace Code' ;
    rdfs:comment 'Unique business identifier code for the workspace, used for external references and integrations.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workspaceName rdf:type rdf:Property ;
    rdfs:label 'Workspace Name' ;
    rdfs:comment 'Human-readable name of the workspace used for identification and display purposes.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workspaceStatus rdf:type rdf:Property ;
    rdfs:label 'Workspace Status' ;
    rdfs:comment 'Current lifecycle status of the workspace indicating its operational state.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workspaceType rdf:type rdf:Property ;
    rdfs:label 'Workspace Type' ;
    rdfs:comment 'Classification of the workspace based on its scope and intended use within the organization.' ;
    rdfs:domain ind:Workspace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableDepartments rdf:type rdf:Property ;
    rdfs:label 'Applicable Departments' ;
    rdfs:comment 'Comma-separated list of departments or business units to which this audit template applies (e.g., Food Safety, IT Security, Store Operations, Warehouse).' ;
    rdfs:domain ind:AuditChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageCompletionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Completion Time Minutes' ;
    rdfs:comment 'The average actual time in minutes taken to complete audits using this template, based on historical data.' ;
