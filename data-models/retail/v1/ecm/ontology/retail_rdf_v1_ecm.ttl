    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyType rdf:type rdf:Property ;
    rdfs:label 'Frequency Type' ;
    rdfs:comment 'The recommended or required frequency for conducting audits using this template (daily, weekly, monthly, quarterly, annual, ad-hoc, event-driven).' ;
    rdfs:domain ind:AuditChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryStandardReference rdf:type rdf:Property ;
    rdfs:label 'Industry Standard Reference' ;
    rdfs:comment 'Reference to the specific industry standard, regulation, or guideline this template is based on (e.g., ISO 22000:2018, FSMA Section 117).' ;
    rdfs:domain ind:AuditChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerContactEmail rdf:type rdf:Property ;
