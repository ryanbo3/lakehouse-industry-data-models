    rdfs:comment 'Email address of the primary contact or owner responsible for this template.' ;
    rdfs:domain ind:AuditChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerDepartment rdf:type rdf:Property ;
    rdfs:label 'Owner Department' ;
    rdfs:comment 'The department or business unit responsible for maintaining and updating this audit checklist template.' ;
    rdfs:domain ind:AuditChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCertification rdf:type rdf:Property ;
