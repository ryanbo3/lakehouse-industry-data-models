    rdfs:range xsd:dateTime .

ind:mergeFields rdf:type rdf:Property ;
    rdfs:label 'Merge Fields' ;
    rdfs:comment 'Comma-separated list of merge field placeholders available in this template for dynamic content insertion (e.g., customer_name, order_number, product_name).' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageCategory rdf:type rdf:Property ;
    rdfs:label 'Message Category' ;
    rdfs:comment 'Business category classification of the message template indicating its purpose and use case in the customer journey.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationEnabled rdf:type rdf:Property ;
