    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementName rdf:type rdf:Property ;
    rdfs:label 'Requirement Name' ;
    rdfs:comment 'Human-readable name or title of the compliance requirement.' ;
    rdfs:domain ind:Requirement ;
