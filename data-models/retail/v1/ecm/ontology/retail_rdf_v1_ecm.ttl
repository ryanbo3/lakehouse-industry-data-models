ind:lastSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Sent Timestamp' ;
    rdfs:comment 'Timestamp when a message was last sent using this template.' ;
    rdfs:domain ind:MessageTemplate ;
