    rdfs:domain ind:AuditChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Human-readable name of the audit checklist template describing its purpose and scope.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateStatus rdf:type rdf:Property ;
    rdfs:label 'Template Status' ;
    rdfs:comment 'Current lifecycle status of the audit checklist template indicating whether it is available for use in audits.' ;
    rdfs:domain ind:AuditChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalChecklistItems rdf:type rdf:Property ;
    rdfs:label 'Total Checklist Items' ;
    rdfs:comment 'The total number of individual checklist items or questions included in this template.' ;
