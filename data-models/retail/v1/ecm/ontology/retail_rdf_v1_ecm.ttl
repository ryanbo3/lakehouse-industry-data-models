    rdfs:range xsd:integer .

ind:dissolvedDate rdf:type rdf:Property ;
    rdfs:label 'Dissolved Date' ;
    rdfs:comment 'Date when the regulatory agency was dissolved, merged, or ceased operations (null if still active).' ;
