ind:averageClickThroughRatePercent rdf:type rdf:Property ;
    rdfs:label 'Average Click Through Rate Percent' ;
    rdfs:comment 'Historical average click-through rate percentage for messages sent using this template. Key performance indicator for engagement.' ;
    rdfs:domain ind:MessageTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageConversionRatePercent rdf:type rdf:Property ;
