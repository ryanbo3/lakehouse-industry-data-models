    rdfs:comment 'Number of days that compliance records and documentation must be retained to satisfy this requirement.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Reference Document Url' ;
