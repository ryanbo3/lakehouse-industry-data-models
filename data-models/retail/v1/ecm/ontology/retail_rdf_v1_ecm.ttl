ind:agencyShortName rdf:type rdf:Property ;
    rdfs:label 'Agency Short Name' ;
    rdfs:comment 'Commonly used abbreviation or acronym for the agency (e.g., FDA, OSHA, PCI SSC, FTC).' ;
