# RDFS Schema for Business: Retail

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/retail#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Retail ---
ind:Retail rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Retail' ;
    rdfs:comment 'Retail is a massive consumer-facing industry operating hypermarkets, department stores, discount outlets, and e-commerce platforms, offering groceries, apparel, electronics, and household goods at competitive prices to diverse demographics.' .

# --- Domain Classes ---
ind:Inventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Inventory' ;
    rdfs:comment 'Manages real-time and historical stock positions across all nodes including stores, DCs, and MFCs. Owns on-hand quantities, SKU-level tracking, shrinkage monitoring, dead stock identification, weeks of supply (WOS), sell-through rates, replenishment triggers, cycle counts, and RFID-based tracking. Supports VMI (Vendor Managed Inventory), inventory valuation (COGS), and real-time inventory visibility for omnichannel fulfillment.' .

ind:Customer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Customer' ;
    rdfs:comment 'Single source of truth for all customer identity, profiles, households, segments (B2C and B2B), contact information, preferences, and RFM (Recency Frequency Monetary) analytics. Manages customer lifecycle, NPS scores, CLTV (Customer Lifetime Value), CAC (Customer Acquisition Cost), consent/privacy preferences, and omnichannel interaction history. Supports personalized clienteling and customer recognition across POS, e-commerce, and mobile.' .

ind:Product rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Product' ;
    rdfs:comment 'Authoritative catalog of all merchandise including SKUs, UPCs, GTINs, EANs, product hierarchies (department, category, subcategory), attributes, descriptions, images, private label vs. national brands, and assortment depth and breadth classifications. Managed via PIM (Product Information Management) and MDM systems. Supports category management, new item setup, and product lifecycle from introduction to discontinuation.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Order' ;
    rdfs:comment 'Manages omnichannel order lifecycle from cart creation through fulfillment including online orders, in-store POS transactions, BOPIS (Buy Online Pick Up In Store), ROPIS, ship-from-store (SFS), and drop-ship orders. Tracks order headers, line items, payment methods, fulfillment status, delivery tracking, and RMA (Return Merchandise Authorization). Integrates with OMS for end-to-end order orchestration.' .

ind:Store rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Store' ;
    rdfs:comment 'Manages physical retail locations including hypermarkets, department stores, discount outlets, dark stores, and micro-fulfillment centers (MFC). Owns store master records, planograms (POG), gondola and endcap configurations, footfall metrics, comp sales (SSS - Same-Store Sales), visual merchandising standards, POS terminal inventory, and store-level P&L. Supports store operations and omnichannel fulfillment as ship-from-store nodes.' .

ind:Pricing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Pricing' ;
    rdfs:comment 'SSOT for all pricing strategies including EDLP (Everyday Low Price), Hi-Lo pricing, competitive pricing, markdowns, ASP (Average Selling Price), AUR (Average Unit Retail), dynamic pricing rules, price zones, and cost-plus margins. Tracks GMROI (Gross Margin Return on Investment), price change audit trails, and markdown optimization. Integrates with Oracle Retail Price Management (RPM) for enterprise-wide pricing governance.' .

ind:Promotion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Promotion' ;
    rdfs:comment 'Manages promotional campaigns, deals, coupons, rebates, BOGO offers, seasonal sales events, circular ads, and digital promotions across channels. Tracks promotion effectiveness, redemption rates, incremental lift, promotional ROI, and vendor-funded promotion agreements. Distinct from pricing — promotions are time-bound, event-driven incentives. Supports omnichannel promotion execution across POS, e-commerce, and mobile apps.' .

ind:Supplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'Authoritative source for supplier and vendor master data including contact information, contracts, compliance certifications, performance scorecards, chargebacks (vendor compliance penalties), RTV (Return to Vendor) processes, EDI integration, MOQ and lead time agreements, and VMI configurations. Manages supplier onboarding, qualification, risk assessment, and ongoing relationship management for national brands, private label manufacturers, and DSD vendors.' .

ind:Merchandising rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Merchandising' ;
    rdfs:comment 'Manages strategic merchandise planning, assortment management, category management, OTB (Open to Buy) budgets, buying decisions, vendor negotiations, and seasonal planning. Tracks sell-through rates, inventory turns, and assortment performance by category, department, and store cluster. Drives assortment depth and breadth decisions and GMROI targets. Integrates with Oracle Retail Merchandising System (ORMS).' .

ind:Loyalty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Loyalty' ;
    rdfs:comment 'Manages customer loyalty programs, membership tiers, points accrual and redemption, rewards catalogs, personalized offers, tier qualification rules, clienteling interaction records, and engagement campaigns. Tracks program enrollment, active members, points liability, and program ROI. Integrates with customer domain for unified customer view and supports omnichannel loyalty recognition across all touchpoints.' .

ind:Ecommerce rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Ecommerce' ;
    rdfs:comment 'Manages digital commerce operations including online storefronts, product catalogs, shopping carts, checkout flows, digital payment processing, session tracking, CTR (Click-Through Rate), CR (Conversion Rate), AOV (Average Order Value), and GMV (Gross Merchandise Value). Tracks digital customer journeys, abandoned carts, and online-to-offline attribution. Integrates with Salesforce Commerce Cloud for unified digital commerce platform.' .

ind:Fulfillment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Fulfillment' ;
    rdfs:comment 'Manages order picking, packing, ship-from-store, BOPIS/ROPIS processing, dark store fulfillment, last-mile delivery execution, carrier selection, route optimization, and fulfillment KPI tracking. Owns the operational execution layer between order capture and customer delivery, including transportation planning and last-mile logistics.' .

ind:Returns rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Returns' ;
    rdfs:comment 'Manages reverse logistics, RMA/RTV processing, restocking workflows, disposition of returned merchandise, refund processing, and return reason analytics. Owns the complete returns lifecycle from customer initiation through final disposition including vendor returns and liquidation.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Finance' ;
    rdfs:comment 'SSOT for financial accounting, general ledger, accounts payable/receivable, revenue recognition (ASC 606), P&L reporting, EBITDA tracking, budgeting, forecasting, COGS, gross margin, lease accounting (ASC 842), and financial close processes. Integrates with SAP S/4HANA FI/CO modules for enterprise financial management and FASB-compliant regulatory reporting.' .

ind:Supplychain rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Retail ;
    rdfs:label 'Supplychain' ;
    rdfs:comment 'Manages end-to-end supply chain planning and execution from demand forecasting through distribution center operations, including facility management, warehouse workflows, inbound/outbound logistics, replenishment planning, purchase order lifecycle, cross-docking, and supply chain performance monitoring.' .

# --- Data Product Classes (Tables) ---
ind:ReplenishmentPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Replenishment Plan' ;
    rdfs:comment 'Replenishment plans for SKUs across all supply chain nodes (stores, DCs, MFCs), generated by Blue Yonder or equivalent planning engine. Captures planned order quantities, replenishment triggers, reorder points, safety stock levels and policy parameters (calculation method, service level target, demand variability factor), weeks-of-supply targets, plan status, and MOQ enforcement rules (minimum order quantity, order multiples, minimum order value). SSOT for automated replenishment decisions including buffer stock governance and supplier ordering constraints.' .

ind:DemandForecast rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Demand Forecast' ;
    rdfs:comment 'SKU-level demand forecast records generated by Blue Yonder Demand Planning. Captures forecasted units, revenue, forecast horizon, statistical model used, override flags, forecast accuracy (MAPE/WMAPE), and demand signals including seasonality, promotions lift, and trend adjustments. Drives replenishment and OTB planning.' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Purchase order header records representing procurement commitments to suppliers, managed in SAP MM or Oracle RMS. Captures PO number, supplier reference, buyer, order and expected delivery dates, total value, currency, payment terms, incoterms, PO type (standard, blanket, DSD), approval status, and EDI transmission status. SSOT for the PO lifecycle from creation through closure.' .

ind:PoLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Po Line' ;
    rdfs:comment 'Line-item detail for each purchase order. Captures SKU/GTIN, ordered quantity, unit of measure, unit cost, extended cost, confirmed quantity, shipped quantity, received quantity, line status, MOQ compliance flag, and lead-time commitment. Enables granular PO tracking at the SKU level.' .

ind:Plan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Plan' ;
    rdfs:comment 'Aggregated supply plan at the SKU-DC-week level, reconciling demand forecasts with available supply, open POs, in-transit inventory, and supplier capacity constraints. Captures planned receipt quantities, projected on-hand, weeks-of-supply, stockout risk score, excess inventory flags, allocation priorities for constrained supply, and plan version/approval status. Master supply-demand balancing record used by planners in weekly S&OP reviews to identify coverage gaps, trigger replenishment actions, and prioritize allocation across stores and DCs.' .

ind:InboundAppointment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Inbound Appointment' ;
    rdfs:comment 'Dock appointment scheduling records for inbound shipments at DCs and stores. Captures appointment date/time, dock door assignment, carrier, expected shipment, appointment status (scheduled, confirmed, arrived, completed, no-show), appointment type (live unload, drop trailer), and scheduling source (carrier portal, EDI, manual). Coordinates inbound logistics flow.' .

ind:Storefront rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Storefront' ;
    rdfs:comment 'Master record for each digital storefront or online channel operated by Retail, including the main e-commerce site, mobile app storefronts, and marketplace presences. Captures storefront identity, locale, currency, domain URL, platform configuration (Salesforce Commerce Cloud site ID, channel-specific settings, feature flags, theme/template references), launch date, status, supported payment methods, and supported fulfillment modes (BOPIS, ship-to-home, drop-ship). SSOT for digital channel identity and configuration within the e-commerce domain. Domain ownership principle: the ecommerce domain owns digital commerce operations from storefront configuration through checkout completion. Customer identity is owned by the customer domain; post-checkout order lifecycle is owned by the order domain; promotional campaign definitions are owned by the promotion domain; product master data is owned by the product domain.' .

ind:DigitalCatalog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Digital Catalog' ;
    rdfs:comment 'E-commerce product catalog record representing the published, channel-specific view of merchandise available on a given storefront. Tracks which SKUs are active online, digital content completeness (images, descriptions, rich media), SEO metadata (title, meta description, canonical URL), online availability flags, digital-only pricing overrides, and publication status. This is the digital presentation layer — distinct from the master product catalog in the product domain which owns canonical SKU/UPC definitions and the master merchandise hierarchy.' .

ind:WebSession rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Web Session' ;
    rdfs:comment 'Tracks individual visitor sessions on digital storefronts, capturing session start/end timestamps, device type, browser, OS, referral source, UTM parameters, landing page, exit page, page view count, session duration, and whether the session resulted in a cart creation, checkout initiation, or completed order. Supports CTR, CR, and digital journey analytics. High-volume event data — recommend 90-day hot retention with archival to cold storage for historical trend analysis.' .

ind:Cart rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Cart' ;
    rdfs:comment 'Represents a shopping cart instance created during a customer\'s digital session on a storefront. Captures cart creation timestamp, last modified timestamp, cart status (active, abandoned, converted, expired), total item count, subtotal, applied promotion/coupon identifiers, discount amounts, estimated tax, estimated shipping, and the channel/storefront context. Includes digital promotion redemption details: promotion ID, coupon code, discount amount, redemption channel (web, mobile app, email link), redemption status (applied, validated, rejected, reversed), and customer identity reference. SSOT for cart-level data supporting abandoned cart recovery, AOV analysis, and promotion effectiveness measurement within the digital channel. Cart abandonment is determined by timeout or session expiry; recovery workflows are tracked in the abandoned_cart_recovery product.' .

ind:CartItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Cart Item' ;
    rdfs:comment 'Line-item level detail within a shopping cart, capturing the SKU/UPC added, quantity, unit price at time of add, any item-level promotion applied, item status (active, removed, saved-for-later), add-to-cart timestamp, and removal timestamp if applicable. Supports basket analysis, assortment affinity, and abandoned cart item-level recovery workflows.' .

ind:Checkout rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Checkout' ;
    rdfs:comment 'Captures the checkout funnel progression for a cart, recording each checkout step reached (cart review, address entry, shipping selection, payment entry, order review, order placed), step timestamps, step completion flags, abandonment step, selected shipping method, selected fulfillment mode (ship-to-home, BOPIS, ROPIS, drop-ship), and applied gift cards or store credits. Enables CR funnel analysis and checkout abandonment identification. Domain boundary: the checkout lifecycle ends at order placement — the order domain owns all post-placement order lifecycle (confirmation, fulfillment tracking, cancellation, modification). Digital return initiation is handed off to the returns domain.' .

ind:DigitalPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Digital Payment' ;
    rdfs:comment 'Records digital payment transactions processed during online checkout, including payment method type (credit card, debit card, PayPal, BNPL, gift card, store credit, Apple Pay, Google Pay), payment gateway used (Adyen, Stripe, PayPal), authorization code, transaction reference, payment status (authorized, captured, declined, voided, refunded, partially_refunded), payment amount, currency, fraud screening result (pass, review, reject), 3DS authentication status, and PCI DSS tokenization reference. Distinct from in-store POS payment processing. SSOT for digital payment transaction data within the e-commerce channel.' .

ind:PriceList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Price List' ;
    rdfs:comment 'Master record defining named price lists (e.g., EDLP base, Hi-Lo promotional, e-commerce, club member) with effective date ranges, currency, applicable channel, and price zone scope. Serves as the top-level pricing container from which individual SKU prices are derived. Each price list represents a distinct pricing context used in price resolution at POS and e-commerce checkout.' .

ind:PriceZone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Price Zone' ;
    rdfs:comment 'Defines geographic or store-cluster pricing zones used to differentiate retail prices by market, region, or competitive environment. Each zone groups stores or fulfillment nodes sharing the same pricing strategy. Includes zone code, name, type (regional, competitive, urban/rural), effective dates, and zone-to-store/node membership assignments with assignment effective dates, expiry dates, assignment reasons, override flags, and historical tracking of zone reassignments.' .

ind:SkuPrice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Sku Price' ;
    rdfs:comment 'Authoritative current and historical retail price for each SKU resolved by price list, price zone, and channel. Captures regular retail price (AUR), cost reference, initial markup (IMU), gross margin percentage, price type (EDLP, Hi-Lo, clearance, competitive match), channel type (in-store, e-commerce, mobile app, marketplace, BOPIS), channel price variance and justification, effective date range, priority for multi-list resolution, and approval status. This is the single source of truth for what a customer pays for any SKU in any pricing context — the granular SKU-to-price-list-to-zone-to-channel binding that drives price resolution at POS and across all digital channels.' .

ind:PriceChange rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Price Change' ;
    rdfs:comment 'Transactional record of every approved price or cost change event for a SKU. Captures before/after values, change category (retail price change, supplier cost change, landed cost adjustment, freight surcharge), reason code (competitive response, cost increase, seasonal adjustment, clearance initiation, tariff change, contract renegotiation, raw material increase), change type (permanent, temporary, markdown, automated/algorithm-driven), execution mode (manual, batch, real-time), effective/expiry dates, approver, supplier reference (for cost changes), cost change percentage, margin impact assessment, and trigger signal (for automated changes). Provides the single unified audit trail for ALL pricing-relevant changes — retail and cost-side — supporting governance, GMROI analysis, margin recalculation triggers, and regulatory compliance.' .

ind:Markdown rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Markdown' ;
    rdfs:comment 'Manages the full lifecycle of planned and unplanned markdowns and clearance events at the SKU, category, and location level. Captures markdown type (permanent, POS, clearance, end-of-season, end-of-life, dead stock), markdown amount (percentage or absolute), original and marked-down retail price, clearance stage progression (first/second/final reduction with price and sell-through at each stage), sell-through targets and actuals, disposition method (in-store clearance, online clearance, RTV, liquidation), planned and actual exit dates, markdown ROI, clearance initiation and closure dates, and dead stock elimination tracking. Tracks the complete reduction lifecycle from initial markdown through final clearance disposition and exit.' .

ind:CostPrice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Cost Price' ;
    rdfs:comment 'Authoritative record of landed cost and COGS for each SKU from each supplier. Includes base cost, freight, duty/tariff, handling charges, total landed cost, cost effective date, cost currency, and cost change reason. Supports cost-plus margin calculations, GMROI tracking, and margin management. This is the buy-side cost record distinct from the sell-side retail price in sku_price.' .

ind:Rule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Rule' ;
    rdfs:comment 'Defines all business logic and constraints governing how prices are calculated, adjusted, and enforced — covering manual policies, batch processes, and real-time algorithm-driven automation. Includes rule type (cost-plus floor, competitive match ceiling, EDLP lock, Hi-Lo swing limit, rounding, dynamic trigger, demand-based, inventory-based, time-of-day), priority, applicable SKU scope, channel (in-store, e-commerce, mobile app), execution mode (manual, batch, real-time/near-real-time), trigger conditions (inventory threshold, demand surge, competitor undercut, time-based, weather, event-driven), adjustment method (percentage, absolute, index-based), min/max price guardrails, effective dates, activation status, algorithm version reference, and override permissions. Serves as the unified policy engine for all pricing governance — from static business rules to real-time algorithmic adjustments.' .

ind:MarginTarget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Margin Target' ;
    rdfs:comment 'Defines planned gross margin targets, GMROI thresholds, and markdown budget allocations by department, category, subcategory, brand classification, buyer, and planning period (season, quarter, month). Includes target gross margin percentage, minimum margin floor, GMROI target, total markdown budget (OTB markdown dollars), consumed and remaining markdown budget, budget utilization percentage, budget revision history, and private label vs. national brand differential targets. Used by category managers and merchandise planners to set pricing guardrails, control markdown spend, and evaluate actual margin and markdown performance against plan.' .

ind:PriceOverride rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Price Override' ;
    rdfs:comment 'Records point-of-sale and e-commerce price overrides applied at the transaction level. Captures override type (manager discount, price match, damaged goods, loyalty benefit, error correction), original price, override price, override amount or percentage, reason code, authorizing employee, store or channel, and transaction reference. Supports shrinkage monitoring, discount abuse detection, and override variance analysis.' .

ind:StockPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Position' ;
    rdfs:comment 'Real-time on-hand stock position for every SKU at each inventory node (store, DC, MFC, dark store). Captures on-hand quantity, available-to-promise (ATP), reserved quantity, in-transit quantity, on-order quantity, damaged/quarantine quantity, and velocity indicators. Authoritative SSOT for current inventory levels consumed by omnichannel fulfillment (ATP/promising), replenishment triggers, and store operations. Updated by goods receipts, sales depletions, adjustments, transfers, and reservations.' .

ind:StockLedger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Ledger' ;
    rdfs:comment 'Perpetual inventory ledger capturing every stock movement transaction at the SKU-location-date level. Records receipts, sales depletions, transfers, adjustments, returns, and write-offs with quantity, unit cost (COGS), and extended value. Supports inventory valuation methods (FIFO, WAC, retail method), shrinkage tracking, and financial reconciliation with the general ledger. Authoritative SSOT for inventory value and movement history within the inventory domain.' .

ind:InventoryNode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Inventory Node' ;
    rdfs:comment 'Master record for every physical or logical inventory-holding location in the network: stores, distribution centers (DCs), micro-fulfillment centers (MFCs), dark stores, vendor-managed locations, and in-transit nodes. Captures node type, storage capacity, fulfillment capabilities (BOPIS, ship-from-store, ship-from-DC), operational status, geographic coordinates, and time zone. Serves as the SSOT for inventory location identity within the inventory domain; referenced by stock_position, stock_ledger, and all movement/receipt records as the location dimension.' .

ind:ReplenishmentOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Replenishment Order' ;
    rdfs:comment 'Replenishment order records generated by demand planning and replenishment systems to restock SKUs at stores or DCs. Captures order type (auto-replenishment, manual, VMI), source node, destination node, ordered quantity, approved quantity, expected delivery date, lead time, MOQ compliance, and fulfillment status. Tracks the full replenishment lifecycle from trigger (based on reorder_policy thresholds) through receipt at the destination node.' .

ind:CycleCount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Cycle Count' ;
    rdfs:comment 'Scheduled and ad-hoc physical inventory cycle count events at the SKU-location level. Captures count schedule, assigned counter, counted quantity, system quantity at time of count, variance quantity, variance percentage, count status (scheduled, in-progress, completed, reconciled), and approval workflow. Supports shrinkage investigation, inventory accuracy KPIs, and Sarbanes-Oxley inventory controls. Variances exceeding tolerance thresholds generate inventory_adjustment records for reconciliation.' .

ind:Adjustment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Adjustment' ;
    rdfs:comment 'Records all inventory quantity adjustments at the SKU-location level including shrinkage events, damage write-downs, cycle count corrections, receiving variances, expiry write-offs, and RTVs. Captures adjustment reason category, sub-reason (e.g., shoplifting, employee theft, admin error for shrinkage), adjusted quantity, cost impact, detection method, authorizing user, approval status, and loss prevention case reference where applicable. Feeds the stock_ledger and serves as the SSOT for all non-transactional inventory changes and shrinkage monitoring.' .

ind:StockTransfer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Transfer' ;
    rdfs:comment 'Inter-node stock transfer records capturing movement of inventory between stores, DCs, MFCs, and vendor locations. Captures transfer type (store-to-store, DC-to-store, cross-dock, RTV), source node, destination node, SKU, transfer quantity, shipment date, expected receipt date, actual receipt date, carrier, and transfer status. Supports omnichannel fulfillment (ship-from-store) and network balancing.' .

ind:GoodsReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Goods Receipt' ;
    rdfs:comment 'Records physical receipt of merchandise at DCs, stores, and MFCs against purchase orders, replenishment orders, or transfer orders. Captures receipt date, receiving node, supplier/source, PO/ASN reference, line-level received/accepted/rejected quantities with discrepancy details (shortage, overage, wrong SKU, damage), unit cost, receipt method (DSD, DC-to-store, cross-dock), quality inspection status, and discrepancy resolution status. Supports receiving workflows, vendor compliance chargebacks, and inventory accuracy at point of induction.' .

ind:Reservation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Reservation' ;
    rdfs:comment 'Records all inventory encumbrances that restrict stock from general availability — including soft-allocations (BOPIS reservation, ship-from-store allocation, e-commerce hold) and hard holds (quality hold, regulatory recall, legal hold, damage hold, price investigation). Captures encumbrance type, SKU, quantity, node, start/expiry timestamps, associated order or case reference, authorizing party, hold reason, authorizing department, release status, and resolution details. Single source of truth for all reserved and held stock, enabling accurate ATP calculation on stock_position.' .

ind:Asn rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Asn' ;
    rdfs:comment 'Advance Shipment Notice (ASN) records received from suppliers or DCs prior to physical goods arrival. Captures ASN number, sender (supplier or DC), destination node, expected arrival date, carrier, tracking number, total cartons, total units, SKU-level line details, and ASN status (sent, in-transit, received, discrepant). Enables pre-receiving workflows, dock scheduling, and receiving discrepancy detection against corresponding inventory_goods_receipt records. Received via EDI 856 or API from trading partners.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Master record for organizational cost centers used in SAP S/4HANA FI/CO for expense allocation, P&L reporting, and budget tracking. Each cost center represents a distinct organizational unit (store, DC, corporate department) responsible for incurring costs. Includes cost center hierarchy, responsible manager, controlling area, profit center assignment, and validity periods.' .

ind:ProfitCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Master record for profit centers representing autonomous business units (store, product line, channel, banner) for internal management accounting in SAP S/4HANA CO-PCA. Enables internal P&L reporting tracking revenue, COGS, gross margin, operating expenses, and EBITDA at the profit center level. Includes profit center hierarchy, controlling area, segment assignment, and responsible manager. Supports segment reporting per ASC 280, transfer pricing, and management decision-making.' .

ind:GlAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General ledger chart of accounts master data aligned to SAP S/4HANA FI-GL. Defines every account used in financial postings including P&L accounts (revenue, COGS, operating expenses), balance sheet accounts (assets, liabilities, equity), and statistical accounts. Includes account type, financial statement version assignment, tax category, and FASB/GAAP classification.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Core general ledger journal entry header capturing all financial postings in SAP S/4HANA FI-GL, including accrual entries, scheduled reversals, and period-end closing entries. Records accounting documents for sales revenue, COGS, expense accruals, revenue accruals, deferred revenue, adjustments, intercompany eliminations, depreciation, lease expense, and reclassifications. Includes document type, posting date, fiscal period, company code, document/local currency, FX rate, reference document, posting status, accrual/reversal indicators, source module (FI-AP, FI-AR, FI-AA, FI-TX), and business justification. FASB-compliant audit trail for all financial transactions supporting accurate period-end P&L, balance sheet, and EBITDA reporting.' .

ind:JournalEntryLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry Line' ;
    rdfs:comment 'Line-item detail for each general ledger journal entry, representing individual debit and credit postings to GL accounts. Captures GL account, cost center, profit center, amount in document and local currency, tax code, assignment field, and line item text. Enables drill-down from financial statements to source transactions. Aligns to SAP FI-GL line item table (BSEG).' .

ind:ApInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ap Invoice' ;
    rdfs:comment 'Accounts payable document lifecycle record capturing the full vendor invoice-to-payment cycle in SAP S/4HANA FI-AP. Encompasses invoice receipt, three-way match (PO/GR/Invoice), payment scheduling, payment execution (ACH, wire, check), discount capture, and settlement clearing. Includes vendor reference, purchase order linkage, payment terms, due dates, payment method, payment run details, bank account, remittance information, and clearing status. Supports vendor payment compliance, AP aging analysis, cash flow management, and period-end AP close.' .

ind:ArInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ar Invoice' ;
    rdfs:comment 'Accounts receivable document lifecycle record for B2B customer billing and cash collection in SAP S/4HANA FI-AR. Encompasses invoice creation, payment receipt, partial payment handling, cash discount processing, bank clearing, dunning activities, and collections management for wholesale accounts, franchise fees, and commercial receivables. Includes customer account, billing/due dates, payment terms, payment method, bank clearing date, applied amounts, dunning level, and ASC 606 revenue recognition flags. Supports AR aging analysis, cash application, collections workflow, and period-end AR close.' .

ind:Budget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Budget' ;
    rdfs:comment 'Comprehensive financial planning record encompassing annual budgets, periodic forecasts, rolling reforecasts, and forward-looking financial projections for retail business units, cost centers, and profit centers in SAP S/4HANA CO. Captures plan version (original budget, revised budget, monthly rolling forecast, quarterly reforecast, annual plan), fiscal year/period, category (CAPEX, OPEX, COGS, labor), GL account detail with line-item granularity (planned/committed/actual amounts per account and cost center), forecast method, variance analysis (budget vs. actual, forecast vs. prior forecast), revenue/COGS/gross margin/EBITDA projections by channel and business unit, approval workflow, and submission tracking. Supports OTB (Open to Buy) integration, budget vs. actual reporting, financial planning cycles, and investor financial guidance.' .

ind:FinancialPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Financial Period' ;
    rdfs:comment 'Fiscal calendar and financial period master defining the retail fiscal year structure (4-5-4 or 4-4-5 calendar), accounting periods, quarter boundaries, and year-end close dates. Includes period open/close status, period type (regular, adjustment, closing), and fiscal year variant. Controls posting periods in SAP S/4HANA FI and drives financial close scheduling.' .

ind:TaxPosting rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Tax Posting' ;
    rdfs:comment 'Tax transaction record capturing sales tax, VAT, use tax, and excise duty postings on retail transactions in SAP S/4HANA FI-TX. Includes tax code, tax jurisdiction (state/county/city/country), taxable base amount, tax amount, tax rate, tax type (input/output), tax determination date, reporting period, nexus indicator, exempt flag, and source document reference. Supports multi-jurisdiction sales tax compliance, Streamlined Sales Tax (SST) reporting, tax return preparation, tax audit defense, and regulatory reporting to federal, state, and local tax authorities.' .

ind:Header rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Header' ;
    rdfs:comment 'Core master record for every omnichannel order. Captures order number, channel origin (web, app, call center, marketplace), order date/time, customer reference, fulfillment node reference (FK to store/distribution domain), order status, currency, locale, totals (subtotal, tax, discount, shipping, grand total), OMS reference ID, source system, and audit timestamps. SSOT for order identity and lifecycle. Carrier and fulfillment node masters are owned by peer domains and referenced via cross-domain FK.' .

ind:OrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Order Line' ;
    rdfs:comment 'Individual line-item detail within an order header. Captures SKU/UPC/GTIN, product description snapshot, ordered quantity, unit retail price (AUR), extended price, discount amount, tax amount, line status, fulfillment method per line (ship, BOPIS, ROPIS, SFS, drop-ship), substitution flag, gift flag, personalization notes, and line-level cancellation reason. Supports split-fulfillment where different lines ship from different nodes.' .

ind:StatusHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Status History' ;
    rdfs:comment 'Immutable audit trail of every status transition for an order header throughout its lifecycle (e.g., CREATED → CONFIRMED → ALLOCATED → PICKED → SHIPPED → DELIVERED → RETURNED). Captures status code, previous status, transition timestamp, triggering system/user, reason code, and node identifier. Enables SLA tracking, exception management, and customer-facing order tracking.' .

ind:PosTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Pos Transaction' ;
    rdfs:comment 'Point-of-Sale transaction record for in-store purchase events at registers. Captures POS terminal ID, register number, cashier/associate ID, store number, transaction date/time, transaction type (sale, return, exchange, void), total tender, tax, discount, loyalty card number, basket metrics (item count, UPT, ATV), and fiscal receipt number. SSOT for brick-and-mortar register transactions. Complements order_header for transactions originating at physical registers rather than digital order flow. Payment tenders linked via the payment product.' .

ind:PosTransactionLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Pos Transaction Line' ;
    rdfs:comment 'Individual line-item detail within a POS transaction. Captures SKU, UPC, EAN, GTIN, item description, quantity sold, unit retail price, extended price, markdown amount, promotion code applied, tax code, tax amount, return reason (if applicable), serial number (for electronics), and weight (for variable-weight items). Supports basket analysis and sell-through rate calculations.' .

ind:Payment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Payment' ;
    rdfs:comment 'Payment tender record capturing each payment instrument applied to an order or POS transaction. Stores payment method type (credit card, debit, gift card, loyalty points, BNPL, cash, digital wallet), masked PAN/token, payment processor reference, authorization code, settlement status (authorized, captured, settled, declined, voided), payment amount, currency, tender sequence for split-tender scenarios, PCI DSS tokenization reference, fraud score, and 3DS authentication result. Supports split-tender where multiple payment methods cover a single order total. Integrates with PCI SSC compliance requirements and payment gateway APIs.' .

ind:Discount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Discount' ;
    rdfs:comment 'Discount and promotion application record at the order header or line level. Captures discount type (coupon, promo code, loyalty reward, markdown, BOGO, clearance, employee discount), discount code, discount amount or percentage, promotion campaign reference, stackability flag, applied-at level (header vs line), and approval status. Enables promotion attribution, markdown tracking, sell-through analysis, and P&L impact per order. Tax calculation attributes (taxable amount adjustment) included where discount affects tax basis.' .

ind:Cancellation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Cancellation' ;
    rdfs:comment 'Order or line-level cancellation event record capturing the full context of why and when an order or individual line was cancelled before shipment. Captures cancellation number, order/line reference, cancellation initiator (customer-initiated via web/app/call-center, system-initiated via OMS rules, fraud-hold auto-cancel, inventory allocation failure), cancellation reason code, cancellation timestamp, cancellation stage (pre-allocation, post-allocation-pre-pick, post-pick-pre-ship), refund eligibility flag, inventory release confirmation, and processing agent/system ID. Distinct from RMA which covers post-shipment returns.' .

ind:Profile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Profile' ;
    rdfs:comment 'Golden record for every customer (B2C and B2B) served by Retail. Stores core identity attributes sourced from Informatica MDM including full legal name, date of birth, gender, preferred language, nationality, customer type (individual/corporate), acquisition channel, CAC, CLTV score, NPS score, lifecycle stage, privacy consent flags (GDPR/CCPA), and golden-record confidence score. This is the single authoritative master entity for all customer identity data across POS, e-commerce, and mobile channels.' .

ind:Account rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account' ;
    rdfs:comment 'Commercial relationship record between a customer and Retail, distinct from profile (identity). Tracks account number, status (active/suspended/closed), open date, tier (standard/premium/VIP), credit limit, preferred store, preferred channel (in-store/online/mobile), default payment method reference, and account-level flags (employee discount eligibility, tax-exempt status, B2B pricing flag). One profile may have multiple accounts (e.g., personal + business). Supports account-level reporting, credit management, and omnichannel preference routing.' .

ind:Contact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Contact' ;
    rdfs:comment 'Stores all contact points for a customer profile or corporate account including email addresses, phone numbers, and social handles. Each row represents a single contact method with type (primary email, mobile, work phone, WhatsApp), verification status, opt-in/opt-out flags per channel, verification date, and source system. Supports omnichannel outreach, CRM campaigns via Salesforce Service Cloud, and GDPR/CCPA consent enforcement at the contact-method level.' .

ind:Address rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Address' ;
    rdfs:comment 'Physical and mailing addresses associated with a customer profile or corporate account. Stores address type (billing, shipping, store pickup, home, work), full address lines, city, state/province, postal code, country, geocoordinates (lat/lng), address validation status, USPS/postal standardization flag, and default shipping flag. Critical for last-mile delivery, BOPIS/ROPIS fulfillment, and tax jurisdiction determination.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Defines market segmentation classifications applied to customer profiles for targeted marketing, personalized pricing, and assortment decisions. Stores segment code, segment name, segment type (RFM tier, demographic, behavioral, psychographic, lifecycle stage, geographic, channel preference, value tier), segment description, qualification criteria summary, membership count, effective date range, auto-refresh flag, owning business unit, and profile-to-segment assignments with effective dates and expiry dates. Enables Retail to execute clienteling strategies, personalized promotions, and differentiated service levels across POS and e-commerce channels.' .

ind:Preference rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Preference' ;
    rdfs:comment 'Captures customer-declared and inferred preferences for personalization across all Retail channels. Stores preference category (communication channel, product category affinity, dietary restriction, brand preference, store preference, language, notification frequency), preference value, preference source (self-declared/behavioral/inferred), confidence level, and last updated timestamp. Feeds Salesforce Commerce Cloud personalization engine and in-store clienteling tools.' .

ind:Consent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Consent' ;
    rdfs:comment 'Authoritative audit trail of customer privacy consent decisions required for GDPR and CCPA compliance. Each row captures consent type (marketing email, SMS, data sharing, profiling, cookies), consent status (granted/withdrawn/pending), consent version, collection channel (web/POS/mobile/paper), collection timestamp, IP address at time of consent, the specific privacy policy version accepted, and the profile reference for the consenting customer. Immutable append-only records supporting regulatory reporting, right-to-erasure workflows, and consent proof during audits.' .

ind:ServiceCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Service Case' ;
    rdfs:comment 'Customer service and support case records managed through Salesforce Service Cloud. Stores case number, case type (return inquiry, billing dispute, product complaint, delivery issue, loyalty query), case status (open/in-progress/resolved/closed), priority, channel of origin (phone/chat/email/in-store), assigned agent, store or fulfillment node involved, resolution code, resolution timestamp, customer satisfaction rating, and RMA reference for return-related cases. Distinct from interaction (which captures all touchpoints) — service_case tracks formal support workflows with SLAs.' .

ind:PaymentMethod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Stores customer-saved payment instruments on file for recurring purchases, one-click checkout, and in-store clienteling. Stores payment method type (credit card, debit card, digital wallet, gift card, store credit, BNPL), tokenized card reference (PCI DSS compliant — no raw PAN), card brand, last four digits, expiry month/year, billing address reference, default flag, and active status. Managed in compliance with PCI DSS standards enforced by PCI SSC.' .

ind:Location rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Location' ;
    rdfs:comment 'Master record for every physical retail location operated by the business, including hypermarkets, department stores, discount outlets, dark stores, and micro-fulfillment centers (MFCs). Captures store number, banner/brand, format type (hypermarket, department, discount, dark store, MFC), format size band, assortment depth/breadth norms, staffing model type, fulfillment capability flags (BOPIS-capable, ROPIS-capable, SFS-capable, DSD-receiving), trading name, legal entity, opening date, closure date, remodel history, square footage (total and selling), number of floors, parking capacity, operating hours, time zone, locale, climate zone, accessibility certifications, and store lifecycle status. This is the SSOT for all store identity, classification, and format configuration data consumed by inventory, order, workforce, and finance domains.' .

ind:Format rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Format' ;
    rdfs:comment 'Reference classification of retail store formats used across the banner portfolio. Defines format codes and descriptions (hypermarket, superstore, department store, discount outlet, convenience, dark store, MFC, ship-from-store node), typical size bands (sq ft ranges), assortment depth/breadth norms, staffing model type, and fulfillment capability flags (BOPIS-capable, ROPIS-capable, SFS-capable, DSD-receiving). Used to drive operational standards, planogram templates, and omnichannel routing rules.' .

ind:PosTerminal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Pos Terminal' ;
    rdfs:comment 'Master record for every Point-of-Sale (POS) terminal deployed within a store location. Captures terminal ID, lane number, terminal type (staffed checkout lane, self-checkout kiosk, mobile POS, customer service desk, pharmacy register), hardware model, software version, payment acceptance capabilities (EMV chip, NFC/contactless, PIN debit, EBT/SNAP, mobile wallet), peripheral devices (scanner, scale, receipt printer), installation date, last maintenance date, next scheduled maintenance, terminal status (active, offline, maintenance, decommissioned), PCI DSS compliance certification date, and assigned department or zone within the store. Critical for POS transaction reconciliation, shrinkage investigation, lane productivity analysis, and omnichannel payment compliance.' .

ind:TrafficCount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Traffic Count' ;
    rdfs:comment 'Time-series record of customer traffic counts (footfall) measured at store entrances and internal zones, captured by people-counting sensors or RFID/camera systems. Records store location, counting zone (main entrance, department zone, checkout area), measurement interval (15-min, hourly, daily), inbound count, outbound count, net occupancy estimate, sensor device ID, data quality flag, and weather condition code at time of measurement. Footfall is a primary store operations KPI used for staffing optimization, conversion rate analysis, and trade area benchmarking.' .

ind:Pl rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Pl' ;
    rdfs:comment 'Store-level Profit & Loss (P&L) record capturing periodic financial performance for each retail location. Records store location, fiscal period (week/month/quarter/year), net sales, COGS (Cost of Goods Sold), gross margin, gross margin %, shrinkage expense, occupancy cost (rent, CAM, utilities), labor cost, supply expense, total operating expense, EBITDA contribution, and P&L status (preliminary, final, restated). Owned by the store domain as the operational P&L; the finance domain owns the consolidated GL. Enables GMROI analysis and store-level profitability benchmarking.' .

ind:ShrinkageEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Shrinkage Event' ;
    rdfs:comment 'Operational record of an identified inventory shrinkage event at a store location. Captures event date, store location, department/zone, shrinkage type (shoplifting/external theft, internal theft, administrative error, vendor fraud, damage), SKU(s) involved, quantity lost, estimated retail value lost, detection method (POS exception, cycle count, RFID, LP investigation), case reference number, resolution status, and recovery amount. Shrinkage is a critical retail KPI directly impacting store P&L and inventory accuracy. Supports LP (Loss Prevention) operations and CPSC/FTC compliance reporting.' .

ind:Department rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Department' ;
    rdfs:comment 'Master record for departments or selling zones within a store location — the primary sub-location operational unit in retail. Captures department ID, department name, department code, parent store location, floor number, zone coordinates, department type (grocery, apparel, electronics, household, pharmacy, bakery, deli, produce, frozen, health & beauty, seasonal, etc.), selling area (sq ft), number of fixtures, department manager assignment reference, labor budget allocation, and active status. Departments are the fundamental unit for planogram assignment, inventory allocation, staffing schedules, shrinkage attribution, and P&L sub-reporting within a store. Most operational KPIs (sales per sq ft, shrink rate, labor-to-sales ratio) are measured at department level.' .

ind:SfsFulfillmentNode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Sfs Fulfillment Node' ;
    rdfs:comment 'Master record designating a store location as a Ship-from-Store (SFS), dark store, or MFC fulfillment node within the omnichannel network. Captures node ID, store location reference, node type, daily fulfillment capacity (orders/day), active picking zones within the store, assigned carrier accounts, same-day/next-day cutoff times, geographic service radius, supported delivery SLAs, and node activation status. This is the SSOT for store-as-fulfillment-node configuration consumed by OMS and fulfillment domains. The fulfillment domain owns execution (pick/pack/ship); this product owns the node capability and capacity definition.' .

ind:Vendor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Vendor' ;
    rdfs:comment 'Master record for all suppliers and vendors including national brand manufacturers, private label producers, DSD vendors, and 3PL partners. Serves as the authoritative golden record for vendor identity, classification, tax identifiers (W-9/W-8), remittance details, business type, ownership structure, diversity certifications, DUNS number, and onboarding status. Contains embedded contact persons (account managers, EDI coordinators, compliance contacts, executive sponsors) with role types, communication preferences, and escalation paths. Contains embedded multi-address records (headquarters, remittance, ship-from, RTV addresses) with geo-coordinates, address validation status, and address type classification. Sourced from Informatica MDM and SAP S/4HANA MM vendor master.' .

ind:VendorContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Vendor Contact' ;
    rdfs:comment 'Contact persons associated with a vendor including account managers, EDI coordinators, compliance contacts, and executive sponsors. Tracks name, title, role type, phone, email, preferred communication channel, and active status. Supports relationship management and escalation workflows.' .

ind:VendorAddress rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Vendor Address' ;
    rdfs:comment 'Physical and mailing addresses for vendors including headquarters, remittance, ship-from, and returns (RTV) addresses. Tracks address type, street, city, state, postal code, country, geo-coordinates, and validation status. Supports procurement, logistics routing, and RTV processing.' .

ind:VendorContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Vendor Contract' ;
    rdfs:comment 'Supplier trading agreements and master vendor contracts including terms and conditions, payment terms, discount structures, exclusivity clauses, private label agreements, and contract validity periods. Tracks contract type (national brand, private label, DSD), effective and expiry dates, auto-renewal flags, and signatory details. Sourced from SAP S/4HANA SD/MM contract management.' .

ind:Chargeback rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Chargeback' ;
    rdfs:comment 'Vendor compliance penalty records issued to suppliers for violations of routing guides, labeling requirements (GS1-128, RFID/EPC), EDI non-compliance, late shipments, fill rate shortfalls, ASN failures, and packaging defects. Tracks chargeback type, violation category, violation date, penalty amount (flat fee or percentage), dispute status, resolution date, recovery method (AP deduction or separate debit memo), and linkage to the originating routing guide rule. Critical for vendor compliance enforcement, cost recovery, and feeds vendor scorecard KPIs. Supports automated penalty calculation and vendor portal notification workflows.' .

ind:RtvRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Rtv Request' ;
    rdfs:comment 'Return to Vendor (RTV) requests authorizing the return of merchandise to suppliers due to defects, overstock, seasonal clearance, product recalls, or quality failures. Tracks RMA number, return reason code, SKU and quantity, return authorization date, disposition method (credit, replacement, destroy), freight responsibility, and RTV status. Sourced from Salesforce Service Cloud and SAP MM.' .

ind:VendorScorecard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Vendor Scorecard' ;
    rdfs:comment 'Periodic vendor performance scorecards measuring KPIs including on-time delivery rate, fill rate, EDI compliance rate, invoice accuracy, chargeback frequency, product quality scores, and overall vendor rating. Tracks scoring period, individual KPI values, weighted composite score, tier classification (preferred, approved, probation), and trend vs prior period. Enables strategic vendor relationship management.' .

ind:LeadTimeAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Lead Time Agreement' ;
    rdfs:comment 'Documented lead time and MOQ (Minimum Order Quantity) agreements per vendor and product category or SKU. Captures standard lead time (days), expedited lead time, MOQ units, order increment, pack size, inner pack quantity, and seasonal lead time adjustments. Feeds Blue Yonder demand planning replenishment parameters and OTB calculations.' .

ind:VendorItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplier ;
    rdfs:label 'Vendor Item' ;
    rdfs:comment 'Vendor-specific item catalog linking vendor part numbers, UPCs, GTINs, and EANs to internal SKUs. Captures vendor item number, vendor pack configuration, case pack quantity, inner pack, pallet TI/HI, unit cost, cost effective date, country of origin, and item status. Includes lead time and MOQ agreements per vendor-item combination: standard lead time (days), expedited lead time, MOQ units, order increment, pack size, inner pack quantity, seasonal lead time adjustments, and category-level defaults. Serves as the cross-reference between vendor catalogs and the internal product master, and feeds Blue Yonder demand planning replenishment parameters and OTB calculations.' .

ind:MerchPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Merch Plan' ;
    rdfs:comment 'Master merchandise financial plan capturing OTB (Open to Buy) budgets, planned sales, planned inventory, planned margin, GMROI targets, and seasonal buying commitments by department, category, and season. Seasonal commitment detail includes planned units, planned cost, planned retail value, receipt flow by month, and comparison to prior year seasonal performance — serving as the single source of truth for aggregate seasonal buying decisions before individual buying orders are raised. The authoritative financial blueprint for buying decisions, assortment investments, and seasonal commitment tracking. Integrates with Oracle Retail Merchandising System (ORMS) merchandise planning module.' .

ind:AssortmentPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Assortment Plan' ;
    rdfs:comment 'Strategic assortment plan defining the breadth and depth of SKUs to be carried by category, subcategory, and season. Captures planned SKU count, assortment depth targets, private label vs. national brand mix, sell-through rate targets, and store cluster definitions (cluster ID, cluster name, clustering methodology such as sales volume, demographics, climate, or format, assigned stores, and cluster-level assortment strategy). Store clusters are owned within the assortment plan as the mechanism for localized assortment decisions. Drives buying decisions and planogram development.' .

ind:Category rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Category' ;
    rdfs:comment 'Authoritative master of the complete merchandise hierarchy from department level through category, subcategory, and segment. Each node captures its hierarchy level, parent node, code, name, and level-specific attributes: departments carry division, merchandise type (hardlines, softlines, grocery, electronics), and assigned buyer/planner; categories carry category manager ownership, category role (destination, routine, convenience, seasonal), strategic objectives, performance benchmarks, and periodic review outcomes (sell-through vs. plan, GMROI vs. target, assortment gap findings, recommended actions). The single source of truth for all merchandise classification, financial reporting hierarchies, and organizational ownership assignments.' .

ind:Buyer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Buyer' ;
    rdfs:comment 'Master record for merchandise buyers and category managers responsible for vendor negotiations, OTB management, assortment decisions, and purchase order approvals within assigned departments and categories. Captures buyer name, employee ID, assigned departments and categories, buying authority limit (dollar threshold), organizational reporting hierarchy, active/inactive status, and performance history. The accountable actor for all buying decisions, vendor commercial terms, and OTB consumption within their scope.' .

ind:Season rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Season' ;
    rdfs:comment 'Reference master for retail planning seasons and fiscal periods used to scope merchandise plans, OTB budgets, assortment plans, and buying commitments. Captures season code (e.g., SS24, FW24), season name, fiscal year, start and end dates, key milestone dates (line review, buy deadline, first receipt, markdown entry, clearance exit), and season status (planning, open-to-buy, in-season, post-season). Provides the temporal backbone for all merchandising planning and performance measurement.' .

ind:OtbBudget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Otb Budget' ;
    rdfs:comment 'Open to Buy (OTB) budget record representing the financial control mechanism that governs merchandise buying spend. Tracks planned receipts at cost, actual receipts, committed orders (on-order), available OTB balance, and budget adjustments (transfers, increases, decreases) by department, category, buyer, and season. Updated in near-real-time as buying orders are placed. The authoritative record for whether a buyer has remaining budget authority to commit new purchases. Sourced from ORMS and reconciled with SAP S/4HANA MM.' .

ind:BuyingOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Buying Order' ;
    rdfs:comment 'Merchandise buying order representing a committed purchase from a supplier for specific SKUs, quantities, and delivery windows. Captures order type (initial buy, reorder, opportunistic), planned receipt date, FOB terms, cost per unit, total order value, and approval status. Distinct from operational purchase orders — this is the buying decision record in ORMS.' .

ind:BuyingOrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Buying Order Line' ;
    rdfs:comment 'Line-level detail of a merchandise buying order capturing individual SKU commitments including SKU/UPC, ordered quantity, unit cost, retail price, planned margin, delivery date, and allocation by store cluster. Enables SKU-level OTB tracking and receipt planning.' .

ind:AssortmentItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Assortment Item' ;
    rdfs:comment 'Association record linking a specific SKU to an assortment plan for a given store cluster and season, serving as the single source of truth for the complete item lifecycle from onboarding through active selling to discontinuation. Captures inclusion/exclusion status, assortment role (core, seasonal, trend, clearance), planned sell-through rate, planned weeks of supply (WOS), planned AUR (Average Unit Retail), planned units. For new item onboarding: setup status, go-live date, required attributes checklist, compliance certifications (CPSC, FDA), UPC/GTIN registration status. For discontinuation: reason (low sell-through, supplier exit, assortment rationalization, dead stock), last order date, clearance strategy, and final disposition. The authoritative record of what is carried where and its complete lifecycle state.' .

ind:MarkdownEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandising ;
    rdfs:label 'Markdown Event' ;
    rdfs:comment 'Record of a planned or executed markdown decision capturing affected SKUs or category, store cluster scope, markdown type (permanent, temporary/POS), markdown percentage or new price point, effective and end dates, markdown reason (seasonal clearance, slow seller, competitive response, end-of-life, damaged), projected sell-through lift, actual sell-through result, and approval status. Represents the merchandising team\'s margin sacrifice decision distinct from pricing domain execution rules. Links to vendor markdown support agreements captured in vendor negotiations.' .

ind:Program rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Program' ;
    rdfs:comment 'Master record for each customer loyalty program operated by the retailer (e.g., tiered rewards club, co-branded credit card program, coalition program). Captures program name, type, enrollment rules, points currency definition, expiry policy, program status, launch/end dates, and omnichannel recognition configuration. SSOT for loyalty program definitions referenced by all downstream entities (membership, tiers, rules, rewards, campaigns). Supports multi-program retailers operating distinct programs for different banners or customer segments.' .

ind:LoyaltyMembership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Loyalty Membership' ;
    rdfs:comment 'Represents an individual customer\'s active enrollment in a loyalty program. Captures member number, enrollment date, enrollment channel (in-store, online, mobile, referral), current tier, tier qualification date, tier expiry date, previous tier (for downgrade tracking), membership status (active, suspended, lapsed, closed), opt-in preferences, linked customer reference, lifetime points earned, lifetime points redeemed, and tier change history summary. One customer may have memberships across multiple programs. Serves as the anchor entity for all member-level activity — points, redemptions, offers, interactions, and referrals link back here.' .

ind:Tier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Reference master defining the qualification tiers within a loyalty program (e.g., Silver, Gold, Platinum, Diamond). Captures tier name, tier rank/order, qualification threshold (spend or points), maintenance threshold, tier benefits summary, tier badge color, upgrade rules, downgrade rules, and tier validity period. Owned by the loyalty domain as the authoritative tier taxonomy.' .

ind:PointsLedger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Points Ledger' ;
    rdfs:comment 'Immutable append-only ledger recording every points movement for a loyalty membership, including tier-change qualification events. Each entry captures transaction type (earn, redeem, expire, adjust, bonus, transfer, reversal, tier_qualify), signed points amount, source reference (POS transaction, order, promotion, partner, tier evaluation), channel, location, timestamp, running balance, and optional tier-change metadata (previous tier, new tier, qualifying period). Serves as the financial-grade audit trail for points liability management, ASC 606 compliance evidence, tier history reporting, and CLTV calculation. No updates or deletes — corrections are posted as reversal entries. Tier qualification events include the qualifying spend/points amount and evaluation period for complete audit trail.' .

ind:AccrualRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Accrual Rule' ;
    rdfs:comment 'Defines the business rules governing how points are earned by members. Captures rule name, program association, earning rate (points per dollar spent, per unit purchased, per visit), applicable product categories or SKUs, applicable channels (in-store, online, BOPIS), minimum spend threshold, bonus multiplier conditions, rule effective dates, and rule priority for conflict resolution. Supports EDLP and Hi-Lo earning strategies.' .

ind:RedemptionRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Redemption Rule' ;
    rdfs:comment 'Defines the business rules governing how members can redeem points for rewards. Captures minimum redemption threshold, redemption rate (points to currency conversion), eligible reward types, blackout dates, channel restrictions, partial redemption flag, rounding rules, and rule effective dates. Distinct from accrual rules as redemption has its own approval workflow, liability impact, and POS integration requirements.' .

ind:Reward rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Reward' ;
    rdfs:comment 'Master catalog of all rewards available for redemption within a loyalty program. Captures reward name, reward type (discount voucher, free product, gift card, experience, charitable donation), points cost, monetary value equivalent, reward category, availability dates, quantity limit, channel availability (in-store, online), image URL, terms and conditions, and reward status (active, sold out, discontinued). Analogous to a PIM for the rewards catalog.' .

ind:Redemption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Redemption' ;
    rdfs:comment 'Transactional record of each redemption event by a loyalty member, covering both catalog reward redemptions and personalized offer activations. Captures membership reference, item redeemed (reward or offer), redemption type discriminator, points deducted, redemption channel, timestamp, associated order or POS transaction, voucher/coupon code issued, fulfillment status (issued, used, expired, cancelled), and monetary value. Drives points liability reduction, reward fulfillment workflows, and offer performance measurement.' .

ind:MemberOffer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Member Offer' ;
    rdfs:comment 'Personalized or segment-targeted offer assigned to a loyalty member or member cohort, distinct from promotion-domain deals which are broad-market. Captures offer name, offer type (bonus points, discount, free item, early access, experiential reward), target membership or segment, offer trigger (birthday, anniversary, win-back, RFM segment, tier upgrade celebration), points multiplier or discount value, minimum spend requirement, offer start/end dates, channel applicability, presentation priority, and offer status (pending, presented, activated, redeemed, expired, declined). SSOT for member-level offer assignments — the promotion domain owns the broad promotional mechanics while this product owns the 1:1 or segment-level loyalty offer lifecycle. Redemption of offers is recorded in the redemption product with type discriminator.' .

ind:MemberSegment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Member Segment' ;
    rdfs:comment 'Defines loyalty-specific behavioral segments and manages member-to-segment assignments for targeted offers, campaign eligibility, and tier management. Captures segment name, type (RFM-based, spend-based, lifecycle stage: new/active/at-risk/lapsed/win-back), definition criteria (rules or ML model reference), program association, segment size/member count, refresh frequency and last refresh timestamp, and individual member assignments with assignment method (rule-based, manual, ML-model), confidence score, effective/expiry dates, and override flag. Distinct from customer domain demographic segments — these are loyalty-program-specific behavioral cohorts derived exclusively from program activity data (points velocity, redemption patterns, engagement frequency).' .

ind:FulfillmentOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Fulfillment Order' ;
    rdfs:comment 'Core operational record representing a fulfillment work order created from a customer order. Tracks the end-to-end execution of picking, packing, and shipping activities for a single order or order subset. Captures fulfillment method (ship-from-store, dark store, DC, BOPIS, ROPIS, drop-ship), assigned fulfillment node, SLA commitment, promised delivery date, current fulfillment status, and carrier assignment. This is the primary entity in the fulfillment domain and the operational counterpart to the order domain\'s order record.' .

ind:FulfillmentLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Fulfillment Line' ;
    rdfs:comment 'Line-level detail of a fulfillment order, representing each SKU/UPC being fulfilled. Captures quantity requested, quantity picked, quantity packed, quantity shipped, unit of measure, pick location, substitution flag, and line-level fulfillment status. Enables granular tracking of partial fulfillments, substitutions, and out-of-stock exceptions at the item level.' .

ind:Shipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Shipment' ;
    rdfs:comment 'Master record for a physical shipment dispatched to a customer or transfer destination. Captures carrier, tracking number, ship date, estimated delivery date, actual delivery date, shipment weight, dimensions, number of packages, ship-from node, ship-to address, service level (ground, 2-day, overnight), and shipment status. Serves as the SSOT for all outbound shipment tracking across channels including e-commerce, BOPIS, and store-to-door.' .

ind:ShipmentPackage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Shipment Package' ;
    rdfs:comment 'Represents an individual physical package or carton within a shipment. Tracks package dimensions, weight, package type (box, poly bag, envelope), seal status, label printed flag, tracking barcode, contents summary, and package-level delivery confirmation. A single shipment may contain multiple packages, each with its own tracking and delivery status.' .

ind:PickTask rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Pick Task' ;
    rdfs:comment 'Unified operational task record for all fulfillment execution activities including picking, packing, quality checks, and value-added services. Captures task type (pick, pack, QC, VAS), assigned associate, work zone, location (aisle, bay, shelf, packing station), SKU/items, quantity requested vs actual, task method (single, batch, zone, wave), priority, status (assigned, in-progress, completed, exception), start time, completion time, quality check outcome, packing details (station ID, package type, void fill, label applied, packing slip printed), and substitution outcome (original SKU, substituted SKU, customer approval status). Supports wave-based task generation from WMS systems including Manhattan Associates and Blue Yonder. Enables associate productivity tracking, task queue management, and fulfillment throughput analytics across the entire pick-pack-QC workflow.' .

ind:PackTask rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Pack Task' ;
    rdfs:comment 'Operational task record for the packing station workflow. Captures packer assignment, packing station ID, items packed, package type selected, void fill used, packing slip printed flag, label applied flag, pack start time, pack end time, and quality check status. Tracks the transition from picked items to sealed, labeled packages ready for carrier handoff.' .

ind:Carrier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Carrier' ;
    rdfs:comment 'Master record for carrier and 3PL partners used for outbound shipment execution, encompassing carrier identity, service catalog, and contracted rate cards. Captures carrier name, carrier code, carrier type (parcel, LTL, FTL, last-mile, same-day), SCAC code, EDI/API integration capabilities. Service catalog includes service levels (ground, 2-day, overnight, same-day, BOPIS-ready), transit days by zone, cutoff times, max weight/dimensions, surcharge types, tracking capability, signature required flag, and geographic restrictions. Rate card includes base rates by zone/weight/service, dimensional weight factor, fuel surcharges, residential delivery surcharges, extended area surcharges, negotiated discount percentages, rate effective and expiry dates, and weight breaks. Serves as the single source of truth for all carrier master data, service definitions, and freight cost references within the fulfillment domain. Used in carrier selection logic during fulfillment order routing and freight cost estimation.' .

ind:CarrierService rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Carrier Service' ;
    rdfs:comment 'Defines specific service offerings provided by a carrier, such as ground, 2-day, overnight, same-day, or BOPIS-ready services. Captures service code, service name, transit days, cutoff time, max weight, max dimensions, surcharge types, tracking capability, signature required flag, and geographic restrictions. Used in carrier selection logic during fulfillment order routing.' .

ind:FulfillmentNode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Fulfillment Node' ;
    rdfs:comment 'Master record for all physical locations capable of fulfilling customer orders, including stores acting as ship-from-store nodes, dark stores, micro-fulfillment centers (MFCs), and distribution centers (DCs). Captures node type, address, fulfillment capabilities (BOPIS, ROPIS, SFS, dark store, MFC), active carrier assignments, operating hours, pick capacity (orders/hour), pack station count, dock door count, storage zones, node activation status, and geographic delivery zone coverage. Distinct from the store domain\'s store master — this entity focuses exclusively on fulfillment operational capabilities and capacity constraints. Note: PK naming (fulfillment_fulfillment_node_id) contains a double-prefix defect that should be corrected to fulfillment_node_id.' .

ind:Exception rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Exception' ;
    rdfs:comment 'Records operational exceptions encountered during the fulfillment lifecycle, including out-of-stock at pick, damaged item, mispick, carrier pickup missed, address validation failure, and delivery attempt failure. Captures exception type, exception code, affected fulfillment order and line, exception timestamp, resolution action taken, resolution timestamp, and exception owner (picker, packer, carrier, system). Drives exception management workflows and SLA breach tracking.' .

ind:Sla rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Sla' ;
    rdfs:comment 'Defines SLA (Service Level Agreement) rules and thresholds governing fulfillment performance commitments. Captures SLA type (BOPIS readiness, same-day ship cutoff, next-day delivery, standard ground), fulfillment method, order channel, node type, promised hours-to-ready, promised hours-to-ship, carrier cutoff time, breach threshold, and escalation rules. Used to evaluate fulfillment order compliance and trigger alerts when SLA risk is detected.' .

ind:CarrierRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Carrier Rate' ;
    rdfs:comment 'Contracted and published rate records for carrier services, capturing base rate, dimensional weight factor, fuel surcharge rate, residential delivery surcharge, extended area surcharge, rate effective date, rate expiry date, rate zone, weight break, and negotiated discount percentage. Used in carrier selection and freight cost estimation during fulfillment order routing. Distinct from pricing domain — this is carrier freight cost, not retail product pricing.' .

ind:PromoCampaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Promo Campaign' ;
    rdfs:comment 'Master record for a promotional campaign representing a time-bound marketing initiative encompassing both the strategic campaign wrapper and discrete promotional sales events (Flash Sales, Doorbuster Events, Holiday Sales). Captures campaign name, type, start/end dates, event classification, budget, and performance targets.' .

ind:PromoOffer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Promo Offer' ;
    rdfs:comment 'Defines a specific promotional offer within a campaign, representing the actual deal mechanics (BOGO, percent-off, dollar-off, free gift with purchase, bundle deal, threshold discount). Captures offer type, discount value, discount method (percentage vs. fixed), minimum purchase threshold, maximum redemption limit, stackability rules, offer priority, eligible SKUs/categories/product hierarchies (with inclusion/exclusion flags), channel eligibility (POS, e-commerce, mobile, BOPIS), store/store-group scope, digital delivery attributes (targeting segment, personalization, activation trigger) when applicable, effective date range, and jurisdictional compliance flags (e.g., state-level promotional restrictions, EU consumer protection price display requirements). This is the atomic unit of promotion logic executed at POS and e-commerce checkout engines. Encompasses SKU eligibility rules, channel assignments, store assignments, and digital offer mechanics as integral attributes. Supports international compliance by carrying jurisdiction-specific restriction flags that gate offer activation by market.' .

ind:Coupon rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Coupon' ;
    rdfs:comment 'Master record for a coupon instrument issued as part of a promotional campaign. Captures coupon code, barcode/UPC, coupon type (manufacturer, store, digital, paper), face value, discount type, issue channel (circular, app, email, in-store kiosk), expiration date, single-use vs. multi-use flag, maximum redemption count, stackability with other offers, issuing authority (store vs. vendor-funded), and print/digital distribution quantity. Supports both digital wallet coupons and physical paper formats across POS and e-commerce channels. Coupon redemption events are recorded in promo_redemption (the SSOT for all redemption activity).' .

ind:Rebate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Rebate' ;
    rdfs:comment 'Master record for a rebate program offered to customers or funded by vendors. Captures rebate name, rebate type (instant rebate, mail-in rebate, vendor-funded rebate), rebate amount or percentage, qualifying purchase conditions, submission deadline, payment method (check, store credit, digital credit), sponsoring vendor, and rebate program status. Supports both consumer-facing rebates and vendor-funded promotional allowances.' .

ind:VendorPromoAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Vendor Promo Agreement' ;
    rdfs:comment 'Master record for a vendor-funded promotional agreement (co-op advertising, promotional allowance, scan-based trading deal). Captures vendor identifier, agreement type (co-op ad, off-invoice allowance, bill-back, scan allowance, new item allowance), agreed funding amount, funding percentage, qualifying conditions (minimum volume, display compliance, ad placement), performance obligations, agreement start/end dates, settlement terms, and agreement status. Distinct from the supplier contract in the supplier domain — this is specifically the promotional funding arrangement that drives vendor chargeback and deduction management. Supports accounts receivable accrual and vendor compliance auditing.' .

ind:PromoRedemption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Promo Redemption' ;
    rdfs:comment 'Transactional record capturing each instance of a promotional offer being applied to a customer transaction at POS or e-commerce checkout. Records offer applied, redemption mechanism (automatic system-triggered, coupon code entry, loyalty auto-apply, cart rule), coupon reference (when coupon-based), transaction reference, store or channel, customer identifier, discount amount granted, redemption timestamp, redemption status (valid, invalid, duplicate, expired), and processing system. Serves as the single source of truth for all promotion redemption activity — including coupon redemptions, automatic BOGO applications, threshold discounts, and bundle deals. Critical for promotional ROI calculation, coupon fraud prevention, vendor chargeback evidence, and real-time redemption limit enforcement.' .

ind:PromoBudget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Promo Budget' ;
    rdfs:comment 'Master record for the promotional budget allocated to a campaign, promotional event, or category-level promotional plan. Captures total budget amount, budget type (internal marketing, vendor co-op, markdown allowance, clearance reserve), budget owner (department, category, or brand team), planned spend by channel, actual spend to date, committed but unspent amount, remaining budget, budget approval status, fiscal period, and variance threshold for alerts. Supports OTB (Open to Buy) integration, promotional P&L management, and real-time budget consumption monitoring. Distinct from finance domain general ledger — this is the operational promotional spend plan that feeds GL accruals.' .

ind:PromoCalendar rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Promo Calendar' ;
    rdfs:comment 'Master record for the retail promotional calendar defining planned promotional periods, key retail events, blackout dates, and competitive response windows for a fiscal year. Captures period name, period type (weekly ad cycle, seasonal event, holiday, clearance window, competitive response), start/end dates, fiscal week/month/quarter alignment, priority tier, planning lock date, planning status (draft, locked, active, archived), and banner/market applicability for multi-banner retailers. Used by merchandising, marketing, and supply chain teams to coordinate promotional activity, inventory positioning, and circular production timelines. Serves as the shared planning backbone that prevents promotional conflicts and ensures adequate lead time for vendor negotiations and inventory builds. Supports multi-banner coordination by allowing banner-specific or enterprise-wide calendar periods.' .

ind:DcFacility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Dc Facility' ;
    rdfs:comment 'Master record for each distribution center (DC) and micro-fulfillment center (MFC) operated by Retail. Captures facility type (regional DC, MFC, dark store, cross-dock hub, returns center), physical address, square footage, storage capacity (pallet positions, cubic feet), temperature zones (ambient, chilled, frozen), dock door count, operating hours, facility status (active, planned, decommissioned), owning region, and Manhattan WMS instance assignment. SSOT for DC/MFC identity referenced by all distribution operations including zone layout, dock scheduling, carrier assignments, and performance tracking.' .

ind:WarehouseZone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Warehouse Zone' ;
    rdfs:comment 'Defines the complete physical layout hierarchy within a DC or MFC, from zones (receiving, bulk storage, forward pick, packing, staging, dispatch, returns) down to individual storage locations (bin, slot, shelf, pallet position, floor stack). Zone-level attributes include zone code, type, temperature classification (ambient, chilled, frozen), aisle range, rack configuration (selective, drive-in, push-back, flow), automation type (manual, conveyor, AS/RS, shuttle, AMR), and zone capacity metrics. Location-level attributes include location code, aisle, bay, level, position, location type (bulk, pick face, reserve, floor, overflow), weight capacity, cubic capacity, RFID/barcode tag, and current occupancy status. SSOT for all physical space definitions within a facility — supports slotting optimization, pick path planning, capacity management, and location-level inventory tracking within Manhattan WMS.' .

ind:InboundShipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Inbound Shipment' ;
    rdfs:comment 'Tracks inbound shipments arriving at a DC or MFC from suppliers, vendors, or inter-facility transfers. Captures ASN (Advance Ship Notice) reference, carrier, trailer number, expected and actual arrival date/time, PO references, total carton and pallet counts, shipment status (in-transit, arrived, receiving, closed), and temperature compliance flag for cold chain shipments. Integrates with EDI 856 ASN feeds and Manhattan WMS receiving workflows. SSOT for all inbound freight visibility at the distribution center level.' .

ind:ReceivingEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Receiving Event' ;
    rdfs:comment 'Captures the physical receiving activity at a DC dock door when inbound shipments are unloaded and verified. Records dock door assignment, unload start/end timestamps, cartons received vs. expected, discrepancy flags (overage, shortage, damage), receiver employee ID, pallet count, and blind vs. directed receiving mode. Each receiving event is tied to an inbound shipment and drives put-away task generation in Manhattan WMS.' .

ind:WarehouseTask rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Warehouse Task' ;
    rdfs:comment 'Represents any directed warehouse task generated within Manhattan WMS, covering putaway, picking, replenishment, cycle count, and internal movement task types. Captures task type discriminator (putaway, discrete_pick, cluster_pick, batch_pick, zone_pick, replenishment, move), SKU, quantity, lot/expiry, source location, target location, assigned operator, equipment type (forklift, reach truck, conveyor, AMR), task priority, task status (pending, assigned, in-progress, completed, short, cancelled), creation timestamp, completion timestamp, substitution flag, and exception reason. Unified SSOT for all directed work within the DC — eliminates separate putaway and pick task entities in favor of a single task management model consistent with Manhattan WMS task interleaving and labor optimization.' .

ind:OutboundOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Outbound Order' ;
    rdfs:comment 'Represents a distribution outbound order directing the DC or MFC to fulfill and ship goods to a destination (store, customer, 3PL node). Captures order type (store replenishment, e-commerce, BOPIS, DSD bypass, inter-DC transfer), destination node, requested ship date, required delivery date, priority level, total lines/units/weight/cube, wave assignment, and order status lifecycle (released, waved, picking, packed, shipped, closed). For store replenishment: captures replenishment type (push, pull, min-max, VMI), replenishment reason, demand planning source reference, and replenishment frequency. Central transactional entity for all DC outbound execution including store replenishment, e-commerce fulfillment, and inter-facility transfers.' .

ind:Wave rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Wave' ;
    rdfs:comment 'A wave is a batch grouping of outbound order lines released together for coordinated picking within a DC. Captures wave number, wave type (single-order, multi-order, cluster, zone, demand-based), release timestamp, planned pick start/end, total lines, total units, assigned pick zones, wave status (planned, released, in-progress, short-closed, complete), fill rate, and short-ship disposition rule. Wave management is a core Manhattan WMS workflow that drives labor scheduling, equipment allocation, and pick zone sequencing for optimal DC throughput.' .

ind:OutboundShipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Outbound Shipment' ;
    rdfs:comment 'Represents a physical outbound shipment dispatched from a DC or MFC to a destination (store, customer, 3PL node). Captures shipment number, carrier and SCAC code, service level (ground, express, same-day, LTL, FTL), trailer/vehicle ID, seal number, manifest ID, total cartons, total pallets, total weight/cube, ship date/time, estimated and actual delivery dates, shipment status (manifested, loading, in-transit, delivered, exception), and tracking numbers. Includes carton-level packing detail: pack station ID, operator, carton/tote ID, items packed (SKU, quantity, lot), carton weight/dimensions, void fill, shipping label reference, packing slip, QC check result (pass/fail/repack), and pack completion timestamp. SSOT for outbound shipment execution, carton-level tracking, and carrier manifesting within the distribution domain.' .

ind:InventoryTransfer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supplychain ;
    rdfs:label 'Inventory Transfer' ;
    rdfs:comment 'Records inter-facility inventory transfer orders and movements between DCs, MFCs, stores, and 3PL nodes. Captures transfer order number, origin facility, destination facility, SKU, transfer quantity, unit of measure, lot/batch, transfer reason (rebalancing, store replenishment, returns consolidation), requested ship date, actual ship date, receipt confirmation date, and transfer status. Distinct from inbound supplier shipments — this entity owns internal stock movement.' .

ind:Sku rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Authoritative master record for every Stock Keeping Unit (SKU) in the retail assortment. This is the SSOT for all SKU-level product identity and physical characteristics across the enterprise. Captures the unique sellable unit identity including UPC, EAN, GTIN, internal item number, SKU description, brand reference, unit of measure, pack size, weight, dimensions (gross/net weight, length, width, height, volume, cube), ti-hi pallet configuration, temperature requirement, stackability, country of origin, hazmat flag, age-restriction flag, shelf life, product lifecycle status (active, discontinued, seasonal, clearance, pending setup), and creation/modification timestamps. Aligned with GS1 GDSN Trade Item standard. Sourced from Informatica MDM and Oracle Retail Merchandising System (ORMS). Central hub entity — all other product domain entities reference this record.' .

ind:ItemHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Item Hierarchy' ;
    rdfs:comment 'Defines the full merchandise hierarchy and category taxonomy used to organize SKUs into departments, categories, subcategories, and segments for both operational and strategic purposes. This is the SSOT for all product classification and category management taxonomy. Captures hierarchy node identity, node code, node name, level (department, category, subcategory, segment), parent node reference (self-referencing for tree traversal), hierarchy path, hierarchy type (operational, strategic/category management), buyer assignment, planner assignment, strategic classification (destination, routine, convenience, seasonal), assortment breadth/depth targets, category manager, and effective dates. Supports category management, assortment planning, planogram design, financial reporting roll-ups, and NRF ARTS merchandise hierarchy alignment. Managed in Oracle Retail Merchandising System (ORMS) and SAP S/4HANA MM module.' .

ind:Attribute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Attribute' ;
    rdfs:comment 'Stores extended descriptive, technical, and measurement attributes for each SKU beyond core identity fields using a flexible entity-attribute-value (EAV) pattern. Captures attribute name, attribute value, attribute group (e.g., fabric, color, size, flavor, nutritional supplement, technical spec, UOM conversion, environmental certification, data quality score), data type, unit of measure, conversion factor, validation rule, source system, and locale/language for multilingual and multi-market support. Enables faceted search on e-commerce platforms, product comparison, PIM-driven enrichment, multi-UOM transaction support across procurement/inventory/POS, data completeness scoring for GS1 GDSN readiness, and regulatory attribute capture. Sourced from Informatica MDM PIM module and Salesforce Commerce Cloud product catalog. Aligned with GS1 GDSN attribute standards for trade item data synchronization.' .

ind:Brand rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Brand' ;
    rdfs:comment 'Master record for all brands carried in the retail assortment, covering national brands, private label (store brand), exclusive, and licensed products. Captures brand name, brand owner, brand type (national, private label, exclusive, licensed), brand tier (premium, value, standard), country of origin, brand logo asset reference, brand status, launch date, and brand portfolio grouping. Supports private label vs. national brand assortment strategy, vendor brand negotiations, brand-level margin analysis, and consumer-facing brand filtering on e-commerce platforms.' .

ind:ItemVariant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Item Variant' ;
    rdfs:comment 'Captures all SKU-to-SKU relationships including variant relationships (parent style/base item to child SKUs across size, color, flavor, scent, pack configuration) and approved substitution relationships (equivalent, upgrade, downgrade, cross-sell for fulfillment and out-of-stock scenarios). This is the SSOT for all inter-SKU relationships within the product domain. Stores source SKU reference, target SKU reference, relationship type (variant, substitution), dimension type (size, color, flavor, etc.), dimension value, substitution priority rank, channel applicability (in-store, online, BOPIS), customer consent required flag, variant-level UPC, and effective dates. Critical for apparel size-color grids, grocery flavor/size variants, omnichannel fulfillment substitution, BOPIS/ROPIS picking, and reducing lost sales from stockouts. Enables parent-child item navigation in PIM and e-commerce.' .

ind:Image rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Image' ;
    rdfs:comment 'Manages digital image assets associated with each SKU including primary product images, alternate angles, lifestyle images, and swatch images. Captures image URL, image type (hero, alternate, swatch, lifestyle, packaging), resolution, file format, locale, channel applicability (web, mobile, print, in-store), CDN asset reference, and approval status. Sourced from Salesforce Commerce Cloud and PIM digital asset management. Supports e-commerce product display and planogram design.' .

ind:Compliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Compliance' ;
    rdfs:comment 'Tracks regulatory and safety compliance attributes for each SKU including FDA food labeling compliance, CPSC safety certifications, FTC advertising standards, hazardous material classification, age restriction requirements, country-specific import compliance, and recall status. Captures compliance type, certifying body, certification number, effective date, expiry date, compliance status, and last audit date. Supports regulatory reporting and product recall management.' .

ind:ItemBundle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Item Bundle' ;
    rdfs:comment 'Defines product bundle and kit configurations where multiple component SKUs are sold together as a single sellable unit. Captures bundle SKU reference (the parent sellable unit), component SKU references, component quantity, component sequence, bundle type (fixed bundle, mix-and-match, gift set, kit, variety pack, multi-pack), pricing method (bundle price, component sum, discount percentage), component substitution allowed flag, and effective dates. Supports promotional bundling, gift set creation, variety packs, multi-pack configurations, and meal deal combos across all channels. Critical for POS scanning (bundle has its own GTIN), inventory component deduction, and promotional planning.' .

ind:GtinRegistry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Gtin Registry' ;
    rdfs:comment 'Authoritative registry of all Global Trade Item Numbers (GTINs) including UPC-A, UPC-E, EAN-13, EAN-8, and ITF-14 barcodes associated with each SKU. Captures GTIN value, GTIN type (UPC, EAN, GTIN-14), SKU reference, issuing GS1 company prefix, barcode image reference, packaging level (unit, inner pack, case, pallet), parent GTIN reference (self-referencing for packaging hierarchy — e.g., case GTIN contains N unit GTINs), child GTIN count per parent, and registration status. Models the full GS1 packaging hierarchy enabling warehouse receiving at case level to resolve to constituent unit GTINs. Aligned with GS1 global standards. Supports EDI transactions (ASN, PO, invoice), warehouse receiving, POS scanning, and GDSN data synchronization.' .

ind:Rma rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Returns ;
    rdfs:label 'Rma' ;
    rdfs:comment 'Return Merchandise Authorization master record representing the formal authorization issued to a customer to return one or more items. Captures the RMA number, originating order reference, customer identity, return channel (in-store, online, BOPIS), authorization date, expiry date, return reason code, return type (refund, exchange, store credit), total expected return value, and current RMA status (pending, authorized, received, closed, denied). Primary master entity for the returns domain and the anchor for all downstream return processing workflows.' .

ind:RmaLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Returns ;
    rdfs:label 'Rma Line' ;
    rdfs:comment 'Individual line-item detail within an RMA, representing a single SKU being returned. Captures the SKU, UPC, GTIN, product description, quantity authorized versus quantity received, unit retail price, unit cost, return reason at the line level, condition code upon receipt (new, opened, damaged, defective), restocking eligibility flag, and disposition instruction. Enables granular tracking of each item in a multi-item return authorization.' .

ind:ReturnRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Returns ;
    rdfs:label 'Return Request' ;
    rdfs:comment 'Customer-initiated return request capturing the initial intent to return merchandise before formal RMA authorization. Records the request channel (e-commerce portal, store associate, call center), request timestamp, customer-stated reason, items and quantities requested for return, preferred resolution type (refund, exchange, store credit), and request status (submitted, under review, approved, denied). Serves as the intake record that triggers the RMA authorization workflow.' .

ind:ReturnReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Returns ;
    rdfs:label 'Return Receipt' ;
    rdfs:comment 'Physical or digital receipt record generated when returned merchandise is received at a store, DC, or MFC. Captures the receiving location, receiving associate, receipt timestamp, carrier tracking number (for mail-in returns), actual items and quantities received versus authorized, condition assessment at receipt, discrepancy flags (over-return, under-return, wrong item), and receipt status. Links the physical goods receipt event to the RMA and triggers downstream disposition and refund workflows.' .

ind:Disposition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Returns ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Disposition record governing the final fate of each returned item after receipt and inspection. Captures disposition type (restock to sellable inventory, restock to clearance, return to vendor via RTV, liquidation, donation, destruction/write-off), decision date, disposition location, responsible associate, estimated and actual recovery value, and disposition status. Central to reverse logistics cost recovery, shrinkage management, and inventory reintegration decisions. Now also carries condition grade assessment (A-New through F-Unsellable) previously in a separate reference table.' .

ind:Refund rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Returns ;
    rdfs:label 'Refund' ;
    rdfs:comment 'Financial refund transaction record representing the monetary reimbursement issued to a customer as resolution of a return. Captures refund method (original payment method, store credit, gift card, check), refund amount, restocking fee deducted, original transaction reference, refund authorization code, processing timestamp, refund status (pending, processed, failed, reversed), and payment processor response. Integrates with financial accounting for accounts payable and revenue reversal under ASC 606.' .

ind:ExchangeOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Returns ;
    rdfs:label 'Exchange Order' ;
    rdfs:comment 'Exchange order created when a return is resolved via product replacement rather than monetary refund. Captures the originating RMA reference, replacement SKU(s) and quantities, price differential (upgrade or downgrade), exchange order status, fulfillment channel (ship-to-home, in-store pickup, curbside), and the linked replacement order identifier. Enables tracking of exchange fulfillment as a distinct resolution path separate from standard order flow.' .

ind:ReturnPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Returns ;
    rdfs:label 'Return Policy' ;
    rdfs:comment 'Master record defining return policy rules by merchandise category, sales channel, and customer segment. Captures return window duration, restocking fee rules, accepted return conditions, proof-of-purchase requirements, non-returnable item exceptions, channel applicability (in-store, online, BOPIS), loyalty tier overrides (extended windows for premium members), SLA processing targets by return stage, and policy effective/expiry dates. Drives automated RMA authorization logic and operational SLA measurement.' .

ind:RestockEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Returns ;
    rdfs:label 'Restock Event' ;
    rdfs:comment 'Operational record capturing the restocking of a returned item back into sellable or clearance inventory. Records the SKU, quantity restocked, restocking location (store, DC, MFC), bin/shelf location, restocking timestamp, condition grade at restock, restocking associate, markdown applied (if any), and the originating RMA and disposition references. Triggers inventory adjustment transactions to update on-hand quantities in the warehouse management and inventory systems.' .

ind:StoreCredit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Returns ;
    rdfs:label 'Store Credit' ;
    rdfs:comment 'Store credit instrument issued as return resolution in lieu of cash or card refund. Functions as a stored-value financial instrument with its own lifecycle: issuance, partial redemption, full redemption, expiration, or voiding. Captures credit code, issued and remaining balance, issue/expiry dates, issuing channel and location, customer and originating RMA references. Integrates with POS and e-commerce systems for omnichannel redemption.' .

ind:License rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'License' ;
    rdfs:comment 'Master record for licenses, permits, and regulatory certifications held at each store location. Captures license ID, store location reference, license type (liquor license, pharmacy permit, tobacco license, food handling certification, business operating permit, fire occupancy permit, health department permit, controlled substance DEA registration, lottery retailer license, money services license), issuing authority, license number, issue date, expiration date, renewal lead time, renewal status (current, pending renewal, expired, suspended, revoked), annual fee, responsible associate reference, and supporting document references. Tracks multi-jurisdictional requirements (state, county, municipal) for stores operating across regulatory boundaries. Critical for compliance — operating with an expired license triggers fines, forced closure, and reputational damage. Supports automated renewal alerting and regulatory audit readiness.' .

ind:Uom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Uom' ;
    rdfs:comment 'Unit of measure reference master defining all valid units (each, case, pallet, pound, kilogram, liter, ounce) and conversion factors used across ordering, inventory, pricing, and distribution. Captures UOM code, description, UOM class (weight, volume, count, length), base UOM conversion factor, and GS1 standard mapping.' .

ind:GiftCard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Gift Card' ;
    rdfs:comment 'Master record for gift cards and stored-value instruments sold and redeemed across all channels. Captures card number, card type (physical, digital), initial balance, current balance, activation date, expiry date, and issuing channel.' .

ind:Subscription rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Subscription' ;
    rdfs:comment 'Master record for recurring subscription orders (subscribe-and-save, auto-replenishment, meal kit subscriptions). Captures subscription ID, customer, SKU list, delivery frequency, next delivery date, payment method, and subscription status.' .

ind:Lot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Lot' ;
    rdfs:comment 'Master record for inventory lot/batch tracking at the SKU level. Captures lot number, manufacture date, expiry date, supplier lot reference, and quality status. Supports traceability for food safety (FDA FSMA) and recall management.' .

ind:CustomerMembership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Customer Membership' ;
    rdfs:comment 'This association product represents the assignment of customer profiles to market segments for targeted marketing, personalized pricing, and differentiated service delivery. It captures the operational reality that customers can simultaneously belong to multiple segments (e.g., VIP Gold + High CLTV + Geographic Northeast) and that segments contain many customers. Each record links one profile to one segment with lifecycle attributes (start/end dates, status), assignment metadata (method, confidence, override flags), and qualification tracking that exist only in the context of this membership relationship.. Existence Justification: Customer segmentation in retail operates as a true many-to-many relationship where individual customer profiles are simultaneously assigned to multiple segments (e.g., a customer can be both \'VIP Gold Tier\' and \'High CLTV\' and \'Northeast Geographic\' at the same time), and each segment definition contains thousands of customer profiles. Marketing teams actively manage these memberships as operational business entities, tracking when customers enter/exit segments, how they were assigned (auto-refresh vs. manual override), and qualification confidence scores. The segment table currently has no FK relationships to profile—it is a definition table that requires an association product to operationalize the membership relationship.' .

ind:Assortment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Assortment' ;
    rdfs:comment 'This association product represents the operational assignment of SKUs to fulfillment nodes in the retail network. It captures which products are authorized to be stocked at which locations, along with node-specific inventory policies, allocation rules, and stocking parameters. Each record links one SKU to one fulfillment node with attributes that govern how that SKU is managed at that specific location. This is the authoritative source for product assortment decisions and location-specific inventory control parameters.. Existence Justification: In retail omnichannel operations, a single SKU is stocked across multiple fulfillment nodes (distribution centers, stores acting as ship-from-store locations, micro-fulfillment centers, dark stores), and each node carries thousands of different SKUs. The business actively manages these SKU-to-node assignments through assortment planning processes, setting node-specific inventory policies, allocation priorities, and stocking parameters for each SKU at each location. This is a core operational relationship managed by merchandising and supply chain teams.' .

ind:Ledger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ledger' ;
    rdfs:comment 'Master reference table for ledger. Referenced by ledger_id.' .

ind:CostZone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Cost Zone' ;
    rdfs:comment 'Master reference table for cost_zone. Referenced by cost_zone_id.' .

ind:MemberSegmentAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Member Segment Assignment' ;
    rdfs:comment 'This association product represents the Assignment between loyalty_membership and member_segment. It captures the operational record of a specific loyalty member being placed into a specific behavioral segment, including when the assignment was made, how it was determined (rule-based, ML model, or manual override), the confidence level of the assignment, and the effective date window during which the assignment is valid. Each record links one loyalty_membership to one member_segment with attributes that exist only in the context of this assignment relationship — enabling precise segment-based targeting, cohort analysis, campaign eligibility evaluation, and lifecycle tracking.. Existence Justification: In loyalty program operations, a single member (loyalty_membership) is actively assigned to multiple behavioral segments simultaneously (e.g., an \'at-risk\' lifecycle segment AND a \'high-spend RFM\' segment AND a \'win-back\' campaign cohort), while each segment contains thousands of members. This is not an analytical derivation — the business actively manages these assignments with assignment method, confidence scores, and effective date windows as first-class operational data. The relationship is a recognized business concept called \'segment membership\' or \'member segment assignment\' that drives offer targeting, campaign eligibility, and lifecycle management.' .

# --- Attribute Properties ---
ind:replenishmentPlanId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Plan Id' ;
    rdfs:comment 'Unique surrogate identifier for each replenishment plan record in the Silver layer lakehouse. Primary key for the replenishment_plan data product.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReplenishmentPlan .

ind:assortmentPlanId rdf:type rdf:Property ;
    rdfs:label 'Assortment Plan Id' ;
    rdfs:comment 'Foreign key linking to merchandising.assortment_plan. Business justification: Assortment plans define active SKUs, depth targets, and planned weeks of supply that directly govern replenishment logic. Retail replenishment systems must know which assortment plan authorized each S' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssortmentPlan .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.finance_budget. Business justification: Retail Open-to-Buy (OTB) budgeting requires replenishment plans to consume and track against finance_budget OTB allocations. replenishment_plan.otb_consumed and finance_budget.otb_amount are the two s' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:costPriceId rdf:type rdf:Property ;
    rdfs:label 'Cost Price Id' ;
    rdfs:comment 'Foreign key linking to pricing.cost_price. Business justification: Replenishment order valuation uses the current landed cost price to calculate planned_order_value and assess margin. Retail supply planners reference cost_price for accurate order economics. unit_cost' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostPrice .

ind:demandForecastId rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Id' ;
    rdfs:comment 'Reference to the demand forecast plan from Blue Yonder Demand Planning that drove the generation of this replenishment plan. Enables traceability from replenishment decision back to the underlying demand signal.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandForecast .

ind:inventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Inventory Node Id' ;
    rdfs:comment 'Reference to the supply chain node (store, Distribution Center (DC), or Micro-Fulfillment Center (MFC)) for which this replenishment plan is generated. Identifies the destination receiving location in the replenishment network.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:merchPlanId rdf:type rdf:Property ;
    rdfs:label 'Merch Plan Id' ;
    rdfs:comment 'Foreign key linking to merchandising.merch_plan. Business justification: Replenishment plans must reconcile against merchandise plan OTB budgets and planned receipt amounts. Retail S&OP process requires planners to validate that replenishment orders stay within merch plan ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchPlan .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Foreign key linking to supplychain.plan. Business justification: A replenishment plan for a specific SKU/node is generated within the context of a broader aggregated supply plan. Linking replenishment_plan.plan_id → plan.plan_id provides the parent-child traceabili' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:promoCampaignId rdf:type rdf:Property ;
    rdfs:label 'Promo Campaign Id' ;
    rdfs:comment 'Foreign key linking to promotion.promo_campaign. Business justification: Retail replenishment planners create promotional replenishment plans (event buys / inventory builds) tied to specific campaigns. The existing \'promotion_flag\' on replenishment_plan signals this need; ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoCampaign .

ind:seasonId rdf:type rdf:Property ;
    rdfs:label 'Season Id' ;
    rdfs:comment 'Foreign key linking to merchandising.season. Business justification: Replenishment plans in retail are season-scoped — seasonal items have distinct reorder points, safety stock levels, and plan horizon dates tied to season buy deadlines and clearance exit dates. Season' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Season .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Reference to the specific SKU (Stock Keeping Unit) for which this replenishment plan is generated. The SKU is the primary product-level identifier used in replenishment planning across stores, DCs, and MFCs.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Reference to the primary supplier responsible for fulfilling this replenishment plan. Links to the supplier master for MOQ enforcement, lead time, and EDI ordering constraints.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:approvedOrderQty rdf:type rdf:Property ;
    rdfs:label 'Approved Order Qty' ;
    rdfs:comment 'The final order quantity approved by the buyer or auto-approved by the system after MOQ, order multiple, and buyer override adjustments. This is the quantity that will be transmitted to the supplier via EDI or purchase order.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyerOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Buyer Override Flag' ;
    rdfs:comment 'Indicates whether a buyer has manually overridden the system-generated planned order quantity or parameters. True = buyer override applied; False = system-generated values accepted as-is. Supports audit trail for manual interventions.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Audit timestamp recording when this replenishment plan record was first persisted in the Silver layer lakehouse. Supports data lineage and audit trail requirements.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which the planned order value and unit cost are expressed (e.g., USD, GBP, EUR). Required for multi-currency retail operations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentOnHandQty rdf:type rdf:Property ;
    rdfs:label 'Current On Hand Qty' ;
    rdfs:comment 'The quantity of the SKU physically on hand at the supply node at the time the replenishment plan was generated. Sourced from Manhattan Associates WMS or SAP S/4HANA WM. Used as the starting inventory position for plan calculations.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandVariabilityFactor rdf:type rdf:Property ;
    rdfs:label 'Demand Variability Factor' ;
    rdfs:comment 'A statistical measure of demand variability (coefficient of variation or standard deviation of demand) used by the planning engine to size safety stock. Higher values indicate more volatile demand and result in larger safety stock buffers.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fillRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Target Pct' ;
    rdfs:comment 'The target order fill rate percentage (Fill Rate) for this replenishment plan, representing the percentage of demand that should be fulfilled from available inventory. Used as a supply chain performance KPI (KPI) target for this SKU-node combination.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedDemandQty rdf:type rdf:Property ;
    rdfs:label 'Forecasted Demand Qty' ;
    rdfs:comment 'The total forecasted demand quantity for the SKU at the supply node over the plan horizon, as generated by Blue Yonder Demand Planning. The primary input to the planned order quantity calculation.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'The number of calendar days from purchase order placement to expected receipt at the supply node, as defined in the supplier contract or purchasing info record. Used to calculate reorder points and plan order release dates.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minOrderValue rdf:type rdf:Property ;
    rdfs:label 'Min Order Value' ;
    rdfs:comment 'The minimum monetary value of a purchase order required by the supplier, expressed in the operating currency. Replenishment plans that do not meet the minimum order value threshold are consolidated or flagged for buyer action.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moq rdf:type rdf:Property ;
    rdfs:label 'Moq' ;
    rdfs:comment 'The minimum number of units that must be ordered from the supplier per purchase order line, as enforced by supplier contract terms. Replenishment plans with planned_order_qty below MOQ are rounded up or flagged for buyer review.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moqComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Moq Compliance Flag' ;
    rdfs:comment 'Indicates whether the planned order quantity meets or exceeds the supplier\'s Minimum Order Quantity (MOQ) constraint. True = compliant; False = below MOQ threshold and requires buyer review or order consolidation before release.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nodeType rdf:type rdf:Property ;
    rdfs:label 'Node Type' ;
    rdfs:comment 'Classifies the type of supply chain node receiving the replenishment. Values: store (retail store), dc (Distribution Center), mfc (Micro-Fulfillment Center), dark_store (fulfillment-only location). Drives replenishment logic and lead time parameters.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onOrderQty rdf:type rdf:Property ;
    rdfs:label 'On Order Qty' ;
    rdfs:comment 'The quantity of the SKU already on open purchase orders or in-transit to the supply node at the time of plan generation. Included in the net inventory position calculation to avoid over-ordering.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderMultiple rdf:type rdf:Property ;
    rdfs:label 'Order Multiple' ;
    rdfs:comment 'The unit increment in which the SKU must be ordered (e.g., case pack size, pallet quantity). Planned order quantities are rounded up to the nearest order multiple before purchase order generation.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Order Release Date' ;
    rdfs:comment 'The date on which the replenishment plan is scheduled to be released as a purchase order to the supplier. Calculated by subtracting lead time from the planned receipt date. Drives the purchasing execution calendar.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overrideReasonCode rdf:type rdf:Property ;
    rdfs:label 'Override Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why a buyer manually overrode the system-generated replenishment plan. Populated only when buyer_override_flag is True. Supports root cause analysis of planning accuracy and buyer behavior patterns.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planGenerationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Plan Generation Timestamp' ;
    rdfs:comment 'The date and time when the replenishment plan was generated by the planning engine (Blue Yonder or equivalent). Represents the principal business event timestamp for this transaction. Used for plan freshness assessment and demand signal alignment.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:planHorizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan Horizon End Date' ;
    rdfs:comment 'The end date of the planning horizon covered by this replenishment plan. Defines the end of the demand forecast window. Together with plan_horizon_start_date, bounds the coverage period for this plan.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planHorizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Horizon Start Date' ;
    rdfs:comment 'The start date of the planning horizon covered by this replenishment plan. Defines the beginning of the demand forecast window used to generate the planned order quantity.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle state of the replenishment plan within the planning and execution workflow. Drives automated ordering triggers and buyer review queues. [ENUM-REF-CANDIDATE: draft|proposed|approved|released|in_progress|completed|cancelled — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Categorizes the origin and nature of the replenishment plan. Automated plans are system-generated by Blue Yonder; manual plans are buyer-created; override plans supersede automated recommendations; emergency plans address urgent stockout risk.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedOrderQty rdf:type rdf:Property ;
    rdfs:label 'Planned Order Qty' ;
    rdfs:comment 'The quantity of units recommended by the planning engine to be ordered for this SKU at the specified supply node. Subject to MOQ and order multiple enforcement before release to purchasing.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedOrderValue rdf:type rdf:Property ;
    rdfs:label 'Planned Order Value' ;
    rdfs:comment 'The total monetary value of the planned replenishment order, calculated as planned_order_qty multiplied by unit_cost. Used for Open-to-Buy (OTB) budget management and financial planning.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Date' ;
    rdfs:comment 'The expected date on which the replenishment order is planned to be received at the supply node, calculated as the order release date plus supplier lead time. Used for inventory projection and DC scheduling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Flag' ;
    rdfs:comment 'Indicates whether this replenishment plan was generated or adjusted to support a planned promotional event. True = promotion-driven uplift included in forecasted demand; False = baseline replenishment. Links to promotional demand lift in Blue Yonder.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'The inventory level (in units) at the supply node at which a replenishment order is triggered. Calculated as safety stock plus expected demand during supplier lead time. Core parameter for reorder-point-based replenishment policies.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentMethod rdf:type rdf:Property ;
    rdfs:label 'Replenishment Method' ;
    rdfs:comment 'The replenishment policy calculation method applied to generate this plan. Min/Max triggers orders when inventory falls below minimum; Reorder Point (ROP) uses statistical triggers; Days of Supply targets coverage duration; Vendor Managed Inventory (VMI) delegates to supplier; Cross-Docking bypasses storage; Direct Store Delivery (DSD) is supplier-direct. [ENUM-REF-CANDIDATE: min_max|reorder_point|days_of_supply|vendor_managed|cross_dock|dsd — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockMethod rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Method' ;
    rdfs:comment 'The methodology used to calculate the safety stock quantity. Fixed uses a static buffer; Statistical uses demand variability and lead time variance; Days of Supply targets a coverage duration; Service Level Based derives buffer from the target service level percentage.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockQty rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Qty' ;
    rdfs:comment 'The buffer stock quantity maintained at the supply node to protect against demand variability and supply uncertainty. Represents the minimum inventory floor below which replenishment is urgently triggered. Also referred to as buffer stock.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevelTargetPct rdf:type rdf:Property ;
    rdfs:label 'Service Level Target Pct' ;
    rdfs:comment 'The target in-stock service level percentage used to calculate safety stock and replenishment parameters. Expressed as a percentage (e.g., 95.00 = 95%). Represents the probability of not experiencing a stockout during the replenishment lead time.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifies the operational system of record that generated or last updated this replenishment plan. Supports data lineage and Silver layer provenance tracking. Values: blue_yonder (Blue Yonder Demand Planning), sap_s4hana (SAP S/4HANA MM), orms (Oracle Retail Merchandising System), manual (buyer-created).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Audit timestamp recording when this replenishment plan record was last modified in the Silver layer lakehouse. Tracks buyer overrides, status transitions, and plan revisions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:weeksOfSupplyTarget rdf:type rdf:Property ;
    rdfs:label 'Weeks Of Supply Target' ;
    rdfs:comment 'The target number of weeks of inventory coverage (Weeks of Supply / WOS) that the replenishment plan aims to achieve at the supply node after order receipt. Used as a planning horizon parameter for days-of-supply replenishment methods.' ;
    rdfs:domain ind:ReplenishmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assortmentId rdf:type rdf:Property ;
    rdfs:label 'Assortment Id' ;
    rdfs:comment 'Foreign key linking to product.assortment. Business justification: Assortment-scoped demand forecasting: demand forecasts are only generated for SKU-location combinations that are active in the assortment. Linking demand_forecast to assortment enables planners to val' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assortment .

ind:customerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.segment. Business justification: Segment-driven demand planning: retail demand planners adjust forecasts based on customer segment behavior (churn risk, purchase frequency, AOV). Linking demand_forecast to the driving customer segmen' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Reference to the store, distribution center (DC), or fulfillment node for which the demand forecast applies. Supports store-level and DC-level replenishment planning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:baselineForecastUnits rdf:type rdf:Property ;
    rdfs:label 'Baseline Forecast Units' ;
    rdfs:comment 'The pure statistical baseline demand forecast in units before any adjustments for promotions, seasonality, or manual overrides. Provides the unadjusted demand signal for comparison against the final consensus forecast.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevelPct rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Pct' ;
    rdfs:comment 'The statistical confidence level (expressed as a percentage, e.g., 95.00) associated with the forecast interval. Indicates the probability that actual demand will fall within the forecast range. Used to set safety stock levels and replenishment buffers.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'The operational system of record that provided the demand signal inputs used to generate this forecast (e.g., SAP_CAR for POS transaction data, Salesforce_Commerce_Cloud for e-commerce demand, ORMS for inventory positions). Supports data lineage and source system auditability.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandCategory rdf:type rdf:Property ;
    rdfs:label 'Demand Category' ;
    rdfs:comment 'Classification of the SKU\'s demand pattern used to select the appropriate forecasting model. \'regular\' indicates stable, predictable demand; \'intermittent\' indicates sporadic demand (Croston model); \'lumpy\' indicates irregular high-volume spikes; \'new_item\' indicates insufficient history; \'end_of_life\' indicates declining/discontinuing SKU.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastBias rdf:type rdf:Property ;
    rdfs:label 'Forecast Bias' ;
    rdfs:comment 'The systematic directional error in the forecast, calculated as the mean of (forecasted units minus actual units) over a rolling period. Positive values indicate over-forecasting (excess inventory risk); negative values indicate under-forecasting (stockout risk). Critical for replenishment safety stock calibration.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastGenerationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Forecast Generation Timestamp' ;
    rdfs:comment 'The exact date and time when this forecast record was generated by the Blue Yonder Demand Planning engine. Serves as the principal business event timestamp for the forecast lifecycle and supports version comparison across planning cycles.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:forecastHorizonWeeks rdf:type rdf:Property ;
    rdfs:label 'Forecast Horizon Weeks' ;
    rdfs:comment 'The total number of weeks into the future covered by this forecast run, measured from the forecast generation date. Determines the planning horizon for replenishment, Open-to-Buy (OTB), and supply chain optimization.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastLowerBoundUnits rdf:type rdf:Property ;
    rdfs:label 'Forecast Lower Bound Units' ;
    rdfs:comment 'The lower bound of the forecast confidence interval in units at the specified confidence level. Represents the low-demand scenario used for minimum order quantity (MOQ) planning and markdown risk assessment.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Period End Date' ;
    rdfs:comment 'The last calendar date of the forecast horizon period covered by this record. Together with forecast_period_start_date, defines the time bucket granularity (daily, weekly, monthly).' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Period Start Date' ;
    rdfs:comment 'The first calendar date of the forecast horizon period covered by this record. Defines the beginning of the time bucket (day, week, or month) for which demand is forecasted.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastRunNumber rdf:type rdf:Property ;
    rdfs:label 'Forecast Run Number' ;
    rdfs:comment 'Identifier for the specific Blue Yonder Demand Planning batch run that generated this forecast record. Enables traceability back to the originating planning cycle and supports audit of forecast lineage.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Status' ;
    rdfs:comment 'Current lifecycle state of the demand forecast record. \'draft\' indicates a preliminary run; \'published\' indicates the forecast is active for replenishment; \'approved\' indicates planner sign-off; \'overridden\' indicates a manual adjustment was applied; \'superseded\' indicates a newer run has replaced this record; \'archived\' indicates the record is retained for historical analysis only.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastType rdf:type rdf:Property ;
    rdfs:label 'Forecast Type' ;
    rdfs:comment 'Classification of the demand forecast by its planning purpose. \'baseline\' is the statistical base demand without uplift; \'promotional\' incorporates promotion lift; \'seasonal\' reflects seasonal index adjustments; \'event_driven\' accounts for specific demand events; \'consensus\' is the final agreed forecast used for replenishment and Open-to-Buy (OTB) planning.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastUpperBoundUnits rdf:type rdf:Property ;
    rdfs:label 'Forecast Upper Bound Units' ;
    rdfs:comment 'The upper bound of the forecast confidence interval in units at the specified confidence level. Represents the high-demand scenario used for safety stock and maximum inventory planning to prevent stockouts.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastVersion rdf:type rdf:Property ;
    rdfs:label 'Forecast Version' ;
    rdfs:comment 'An incrementing integer version number for the forecast record for a given SKU-location-period combination. Enables tracking of forecast revisions across planning cycles and supports comparison of forecast evolution over time.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastedRevenue rdf:type rdf:Property ;
    rdfs:label 'Forecasted Revenue' ;
    rdfs:comment 'The projected revenue in the operating currency derived from the forecasted units multiplied by the expected selling price for the forecast period. Used in financial planning, Open-to-Buy (OTB) budgeting, and Gross Margin Return on Investment (GMROI) analysis.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedUnits rdf:type rdf:Property ;
    rdfs:label 'Forecasted Units' ;
    rdfs:comment 'The statistical model\'s predicted demand quantity in sellable units for the SKU at the specified location during the forecast period. This is the primary quantitative output of the demand planning engine and drives replenishment order quantities.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLatestVersion rdf:type rdf:Property ;
    rdfs:label 'Is Latest Version' ;
    rdfs:comment 'Indicates whether this forecast record is the most current version for the given SKU-location-period combination. True means this record is the active forecast used for replenishment and OTB planning; False means it has been superseded by a newer forecast run.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNewItem rdf:type rdf:Property ;
    rdfs:label 'Is New Item' ;
    rdfs:comment 'Indicates whether the SKU is a new item with insufficient sales history for statistical forecasting. When True, the forecast relies on analogous item modeling or planner input rather than historical demand patterns. Relevant for new product launches and assortment introductions.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverrideApplied rdf:type rdf:Property ;
    rdfs:label 'Is Override Applied' ;
    rdfs:comment 'Indicates whether a demand planner has manually overridden the statistical forecast for this record. True means the final forecasted_units reflect a planner adjustment; False means the forecast is purely statistical. Critical for measuring forecast bias introduced by manual intervention.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPromotionalPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Promotional Period' ;
    rdfs:comment 'Indicates whether the forecast period overlaps with an active promotional event. When True, the promotional_lift_units field is expected to be populated and the forecast incorporates promotion-driven demand uplift.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mape rdf:type rdf:Property ;
    rdfs:label 'Mape' ;
    rdfs:comment 'Mean Absolute Percentage Error (MAPE) measuring the accuracy of the statistical forecast against actual sales for the equivalent prior period. Expressed as a decimal (e.g., 0.12 = 12% error). Lower values indicate higher forecast accuracy. Used as the primary KPI for demand planning performance.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'The version identifier of the statistical forecasting model used to generate this forecast record. Supports model governance, reproducibility, and performance tracking across model upgrades in Blue Yonder Demand Planning.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otbImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Otb Impact Flag' ;
    rdfs:comment 'Indicates whether this forecast record has been incorporated into the Open-to-Buy (OTB) financial plan. When True, the forecasted revenue and units are reflected in the merchandise financial plan and buying budget for the relevant period.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideUnits rdf:type rdf:Property ;
    rdfs:label 'Override Units' ;
    rdfs:comment 'The manually adjusted demand quantity in units entered by a demand planner to replace or supplement the statistical forecast. Populated only when is_override_applied is True. Enables analysis of planner override magnitude and its impact on forecast accuracy.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningChannel rdf:type rdf:Property ;
    rdfs:label 'Planning Channel' ;
    rdfs:comment 'The retail fulfillment channel for which this demand forecast is generated. \'store\' covers brick-and-mortar POS demand; \'ecommerce\' covers digital commerce demand from Salesforce Commerce Cloud; \'omnichannel\' covers unified demand signals; \'dc_replenishment\' covers distribution center stock replenishment; \'bopis\' covers Buy Online Pick Up In Store (BOPIS) demand.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalLiftUnits rdf:type rdf:Property ;
    rdfs:label 'Promotional Lift Units' ;
    rdfs:comment 'The incremental demand units attributed to active promotions during the forecast period. Derived from promotion event modeling in Blue Yonder and used to isolate the promotional demand signal from baseline demand for Pricing and Promotions Management analysis.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentRecommendationUnits rdf:type rdf:Property ;
    rdfs:label 'Replenishment Recommendation Units' ;
    rdfs:comment 'The system-recommended replenishment order quantity in units derived from the demand forecast, current inventory position, safety stock targets, and lead time. Feeds directly into Oracle Retail Merchandising System (ORMS) purchase order generation and Open-to-Buy (OTB) planning.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalityIndex rdf:type rdf:Property ;
    rdfs:label 'Seasonality Index' ;
    rdfs:comment 'A multiplicative seasonal index applied to the baseline forecast to account for recurring seasonal demand patterns (e.g., holiday peaks, back-to-school). A value of 1.0 indicates no seasonal adjustment; values above 1.0 indicate above-average seasonal demand.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statisticalModelCode rdf:type rdf:Property ;
    rdfs:label 'Statistical Model Code' ;
    rdfs:comment 'The identifier or code of the statistical forecasting algorithm used by Blue Yonder Demand Planning to generate this forecast (e.g., ARIMA, Holt-Winters exponential smoothing, Croston for intermittent demand, machine learning ensemble). Enables model performance benchmarking and algorithm governance. [ENUM-REF-CANDIDATE: ARIMA|HOLT_WINTERS|CROSTON|ETS|MOVING_AVG|ML_ENSEMBLE|CAUSAL — promote to reference product]' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeBucketGranularity rdf:type rdf:Property ;
    rdfs:label 'Time Bucket Granularity' ;
    rdfs:comment 'The temporal granularity of the forecast period covered by this record. \'daily\' is used for short-horizon replenishment; \'weekly\' is the standard planning cadence; \'monthly\' is used for financial and Open-to-Buy (OTB) planning.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trendAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Trend Adjustment Factor' ;
    rdfs:comment 'A multiplicative factor representing the long-term demand trend applied to the forecast. Values above 1.0 indicate upward trend; values below 1.0 indicate declining demand trend. Used to capture secular demand shifts beyond seasonal patterns.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weeksOfSupply rdf:type rdf:Property ;
    rdfs:label 'Weeks Of Supply' ;
    rdfs:comment 'Weeks of Supply (WOS) — the projected number of weeks the current on-hand inventory will cover demand based on the forecasted units. A key inventory health metric used in replenishment planning to identify stockout risk and excess inventory positions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmape rdf:type rdf:Property ;
    rdfs:label 'Wmape' ;
    rdfs:comment 'Weighted Mean Absolute Percentage Error (WMAPE) measuring forecast accuracy weighted by sales volume, reducing the distortion caused by low-volume SKUs. Expressed as a decimal. Preferred accuracy metric for high-volume retail assortments where MAPE can be misleading.' ;
    rdfs:domain ind:DemandForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Primary key for purchase_order' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:blanketPoPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Blanket Po Purchase Order Id' ;
    rdfs:comment 'Reference to the parent blanket or framework purchase order from which this release or call-off order was created. Null for standalone standard POs. Enables tracking of spend against blanket agreement limits.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:buyerId rdf:type rdf:Property ;
    rdfs:label 'Buyer Id' ;
    rdfs:comment 'Reference to the internal buyer or purchasing agent responsible for creating and managing this purchase order. Corresponds to SAP EKKO.EKGRP (purchasing group) owner.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Buyer .

ind:dcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Dc Facility Id' ;
    rdfs:comment 'Reference to the distribution center or store location designated as the delivery destination for this purchase order. Corresponds to SAP EKKO.WERKS (plant/site).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:itemHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Item Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to product.item_hierarchy. Business justification: Open-to-Buy (OTB) and category-level PO management: buyers raise POs against a merchandise category node in the item hierarchy. Linking purchase_order to item_hierarchy replaces the denormalized merch' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItemHierarchy .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'The date on which goods were physically received at the destination facility. Populated upon goods receipt posting in SAP (MIGO transaction). Used to calculate supplier on-time delivery performance and lead time actuals.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Authorization workflow status indicating whether the purchase order has been approved by the required approvers per the company\'s procurement authorization matrix. Distinct from po_status as it tracks the internal approval gate specifically.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'The timestamp when the purchase order received final authorization approval. Captures the precise moment the procurement commitment became binding. Used for approval cycle time analytics and compliance auditing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'The date by which the purchase order must be cancelled if goods have not shipped. Also known as the cancel date or cancel-by date in retail procurement. Null if the PO has not been cancelled or does not have a cancellation deadline.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'SAP company code representing the legal entity or business unit issuing the purchase order. Used for financial reporting, P&L allocation, and intercompany reconciliation. Corresponds to SAP EKKO.BUKRS.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The delivery date confirmed by the supplier after PO acknowledgment. May differ from expected_delivery_date if the supplier cannot meet the original requested date. Used to update replenishment plans and manage weeks of supply (WOS).' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total discount or allowance amount applied to the purchase order by the supplier, including volume discounts, promotional allowances, and trade deals. Reduces the net payable amount. Expressed in the currency specified by currency_code.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediTransmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Transmission Status' ;
    rdfs:comment 'Status of the EDI (Electronic Data Interchange) transmission of this purchase order to the supplier. Not Sent = EDI not applicable or not yet initiated; Pending = queued for transmission; Transmitted = EDI 850 PO sent to supplier; Acknowledged = supplier returned EDI 855 acknowledgment; Failed = transmission error; Rejected = supplier rejected the PO via EDI.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Edi Transmitted Timestamp' ;
    rdfs:comment 'The timestamp when the purchase order was transmitted to the supplier via EDI (Electronic Data Interchange) as an EDI 850 transaction set. Null if EDI transmission has not occurred. Used for supplier communication SLA tracking.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign currency exchange rate applied to convert the purchase order amounts from the supplier\'s transaction currency to the company\'s functional currency at the time of PO creation. Corresponds to SAP EKKO.WKURS.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'The agreed-upon date by which the supplier is expected to deliver the ordered goods to the designated distribution center or store. Used for supply chain planning, replenishment scheduling, and SLA monitoring. Corresponds to SAP EKET.EINDT (scheduled delivery date).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fillRatePct rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Pct' ;
    rdfs:comment 'The percentage of ordered units that have been received and fulfilled by the supplier, calculated as (total_received_units / total_ordered_units) * 100. Fill Rate is a key supplier performance KPI measuring order completion. Stored as a pre-computed operational field updated upon each goods receipt.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms 2020) code defining the responsibilities of buyer and seller for delivery, risk transfer, and cost allocation (e.g., FOB = Free On Board, DDP = Delivered Duty Paid, CIF = Cost Insurance Freight). Corresponds to SAP EKKO.INCO1. Critical for import/export compliance and logistics cost allocation. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'The named place or port associated with the Incoterms code, specifying the exact location where risk and cost transfer between buyer and seller (e.g., \'Port of Los Angeles\' for FOB). Corresponds to SAP EKKO.INCO2.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCrossDock rdf:type rdf:Property ;
    rdfs:label 'Is Cross Dock' ;
    rdfs:comment 'Indicates whether this purchase order is designated for cross-docking at the distribution center, meaning goods will be transferred directly from inbound to outbound without putaway storage. Cross-docking reduces DC handling costs and accelerates store replenishment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDropShip rdf:type rdf:Property ;
    rdfs:label 'Is Drop Ship' ;
    rdfs:comment 'Indicates whether this purchase order is a drop ship arrangement where the supplier ships goods directly to the end customer, bypassing the retailer\'s distribution center. Drop ship POs are common in e-commerce and extended aisle assortments.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'The timestamp when the purchase order record was most recently modified in the source system. Used for incremental data loading, change data capture, and audit compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'The minimum quantity the supplier requires for this purchase order, as defined in the supplier agreement or item master. MOQ (Minimum Order Quantity) constraints drive order sizing decisions in replenishment planning and OTB management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPayableAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payable Amount' ;
    rdfs:comment 'The net amount payable to the supplier after applying all discounts, allowances, and adjustments to the gross total order amount. This is the financial commitment recorded in accounts payable. Expressed in the currency specified by currency_code.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for buyer notes, special instructions, or remarks associated with the purchase order. May include delivery instructions, quality requirements, or supplier-specific handling notes. Corresponds to SAP EKKO.IHREZ (your reference) or header text.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The business date on which the purchase order was officially created and issued. This is the principal real-world event date for the procurement commitment. Corresponds to SAP EKKO.BEDAT (document date).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Code representing the agreed payment terms between the retailer and supplier (e.g., NET30, NET60, 2/10NET30 for 2% discount if paid within 10 days). Corresponds to SAP EKKO.ZTERM (terms of payment key). Drives accounts payable scheduling and early payment discount capture.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally-known, human-readable purchase order number assigned by the procurement system (SAP MM or Oracle RMS). Used in EDI transmissions, supplier communications, and receiving workflows. Corresponds to SAP EKKO.EBELN field.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle state of the purchase order from creation through closure. Draft = created but not submitted; Pending Approval = awaiting authorization; Approved = authorized for transmission; Sent = transmitted to supplier via EDI or portal; Partially Received = some goods received; Received = all goods received; Closed = fully processed and closed; Cancelled = voided. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|sent|partially_received|received|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order by procurement method. Standard = regular replenishment PO; Blanket = open-quantity framework agreement; DSD (Direct Store Delivery) = supplier delivers directly to store; Drop Ship = vendor ships direct to customer; Consignment = inventory owned by supplier until sold; RTV (Return to Vendor) = merchandise returned to supplier. [ENUM-REF-CANDIDATE: standard|blanket|direct_store_delivery|drop_ship|consignment|return_to_vendor — promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroupCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group Code' ;
    rdfs:comment 'Code identifying the buyer group or commodity team responsible for this purchase order within the purchasing organization. Used for spend analytics by category and buyer performance reporting. Corresponds to SAP EKKO.EKGRP.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrgCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Org Code' ;
    rdfs:comment 'SAP purchasing organization code representing the organizational unit responsible for procuring goods and services. Defines the legal entity and negotiation authority for the purchase order. Corresponds to SAP EKKO.EKORG.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierPoReference rdf:type rdf:Property ;
    rdfs:label 'Supplier Po Reference' ;
    rdfs:comment 'The supplier\'s own reference number or acknowledgment number for this purchase order, returned via EDI 855 or supplier portal. Used for cross-referencing in supplier invoices, ASNs (Advance Ship Notices), and dispute resolution.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Total Order Amount' ;
    rdfs:comment 'The gross total monetary value of the purchase order before any adjustments, representing the sum of all line item values. Expressed in the currency specified by currency_code. Used for open-to-buy (OTB) tracking, financial commitments, and accounts payable accruals.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderedUnits rdf:type rdf:Property ;
    rdfs:label 'Total Ordered Units' ;
    rdfs:comment 'The total quantity of units ordered across all line items on this purchase order. Used for fill rate calculation, receiving reconciliation, and inventory planning. Expressed in the base unit of measure.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReceivedUnits rdf:type rdf:Property ;
    rdfs:label 'Total Received Units' ;
    rdfs:comment 'The total quantity of units physically received and goods-receipted against this purchase order to date. Used to calculate fill rate (order completion percentage) and identify short shipments or over-deliveries.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each purchase order line item in the Silver Layer lakehouse. Primary key for the po_line data product.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:assortmentItemId rdf:type rdf:Property ;
    rdfs:label 'Assortment Item Id' ;
    rdfs:comment 'Foreign key linking to merchandising.assortment_item. Business justification: Each PO line represents the physical order execution for a specific assortment item. Retail buyers track PO line receipts against assortment_item planned_units and planned_aur. This link enables assor' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssortmentItem .

ind:departmentId rdf:type rdf:Property ;
    rdfs:label 'Department Id' ;
    rdfs:comment 'Reference to the merchandise department or category to which this PO line\'s SKU belongs. Supports departmental OTB tracking, assortment planning, and financial reporting by merchandise hierarchy.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:gtinRegistryId rdf:type rdf:Property ;
    rdfs:label 'Gtin Registry Id' ;
    rdfs:comment 'Foreign key linking to product.gtin_registry. Business justification: EDI/GS1 procurement compliance: purchase order lines reference GTINs per GS1 standards for item identification in EDI transactions. Linking po_line to gtin_registry replaces the denormalized gtin text' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GtinRegistry .

ind:supplyPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Supply Purchase Order Id' ;
    rdfs:comment 'Reference to the parent purchase order header to which this line item belongs. Establishes the header-to-line relationship for PO lifecycle tracking. [HEADER_REFERENCE — TRANSACTION_LINE canonical category]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:uomId rdf:type rdf:Property ;
    rdfs:label 'Uom Id' ;
    rdfs:comment 'Foreign key linking to product.uom. Business justification: Procurement UOM normalization: PO lines specify order quantities in a unit of measure that must resolve to the canonical UOM master for accurate receiving, invoicing, and inventory conversion. Linking' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Uom .

ind:allowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Allowance Amount' ;
    rdfs:comment 'Supplier-granted trade allowance or promotional funding amount applied to this PO line (e.g., off-invoice allowance, scan allowance). Reduces net cost and impacts COGS and GMROI calculations.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancelDate rdf:type rdf:Property ;
    rdfs:label 'Cancel Date' ;
    rdfs:comment 'The latest date by which this PO line must be received; if not received by this date, the line is automatically cancelled. Critical for seasonal and fashion merchandise to prevent late deliveries.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedQty rdf:type rdf:Property ;
    rdfs:label 'Confirmed Qty' ;
    rdfs:comment 'Quantity confirmed by the supplier as available and committed for shipment on this PO line. May differ from ordered quantity due to supplier capacity constraints or MOQ adjustments.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating the country where the product on this PO line was manufactured or produced. Required for customs declarations, import compliance, and consumer labeling regulations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationType rdf:type rdf:Property ;
    rdfs:label 'Destination Type' ;
    rdfs:comment 'Type of destination for this PO line shipment. Indicates whether goods are routed to a Distribution Center (DC), direct to store (DSD), cross-docking facility, drop ship to customer, or Micro-Fulfillment Center (MFC).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedCost rdf:type rdf:Property ;
    rdfs:label 'Extended Cost' ;
    rdfs:comment 'Total cost for this PO line calculated as ordered_qty multiplied by unit_cost. Represents the gross financial commitment for this line item before any allowances or discounts.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'ICC Incoterms code defining the delivery terms and transfer of risk/cost responsibility between buyer and supplier for this PO line (e.g., FOB, DDP, CIF). Critical for landed cost calculation and logistics planning. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Supplier invoice number associated with this PO line for three-way match processing (PO, receipt, invoice). Links to accounts payable for payment processing and FASB ASC 606 revenue recognition compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line item number within the parent purchase order, used to uniquely identify and order line items within a PO. Corresponds to SAP MM item number (EBELP). [LINE_SEQUENCE — TRANSACTION_LINE canonical category]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current workflow status of this PO line item, tracking progression from open through fulfillment or cancellation. Drives replenishment alerts and supplier follow-up actions. [LIFECYCLE_STATUS — TRANSACTION_LINE canonical category]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqCompliant rdf:type rdf:Property ;
    rdfs:label 'Moq Compliant' ;
    rdfs:comment 'Indicates whether the ordered quantity on this PO line meets or exceeds the supplier\'s Minimum Order Quantity (MOQ) requirement. Non-compliant lines may incur supplier penalties or require buyer approval.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netCost rdf:type rdf:Property ;
    rdfs:label 'Net Cost' ;
    rdfs:comment 'Net cost per unit after applying all supplier allowances, discounts, and deductions to the unit cost. Represents the true landed cost basis for COGS and margin calculations.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderUomQty rdf:type rdf:Property ;
    rdfs:label 'Order Uom Qty' ;
    rdfs:comment 'Number of base selling units (eaches) contained within one purchase unit of measure. Enables conversion between purchase UOM and retail selling UOM for inventory and sales reporting (e.g., 12 eaches per case).' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQty rdf:type rdf:Property ;
    rdfs:label 'Ordered Qty' ;
    rdfs:comment 'Total quantity of the SKU ordered on this PO line, expressed in the purchase unit of measure. Represents the buyer\'s original demand signal to the supplier. [LINE_QUANTITY — TRANSACTION_LINE canonical category]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otbConsumed rdf:type rdf:Property ;
    rdfs:label 'Otb Consumed' ;
    rdfs:comment 'Dollar value of Open to Buy (OTB) budget consumed by this PO line at the time of order placement. Used for merchandise financial planning and budget compliance monitoring.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedQty rdf:type rdf:Property ;
    rdfs:label 'Received Qty' ;
    rdfs:comment 'Quantity of the SKU physically received and confirmed at the distribution center or store against this PO line. Drives inventory on-hand updates and three-way match for invoice processing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Reason code or description for any quantity rejected or returned to vendor (RTV) during receiving for this PO line (e.g., damaged goods, wrong item, quality failure). Supports chargeback processing and supplier compliance management.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The date by which the retailer requests delivery of this PO line at the destination (DC or store). Used for lead time compliance monitoring and replenishment planning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retailPrice rdf:type rdf:Property ;
    rdfs:label 'Retail Price' ;
    rdfs:comment 'Planned retail selling price (AUR - Average Unit Retail) for this SKU at the time of PO creation. Used for initial margin calculation and GMROI planning at the line level.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipDate rdf:type rdf:Property ;
    rdfs:label 'Ship Date' ;
    rdfs:comment 'Date on which the supplier shipped goods for this PO line, as reported via ASN or EDI 856. Used to calculate in-transit duration and validate supplier shipping compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippedQty rdf:type rdf:Property ;
    rdfs:label 'Shipped Qty' ;
    rdfs:comment 'Quantity of the SKU that the supplier has physically shipped against this PO line, as reported via ASN (Advance Shipment Notice) or EDI 856. Used to calculate in-transit inventory.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorItemNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Item Number' ;
    rdfs:comment 'Supplier\'s own item number or part number for the product on this PO line. Used in EDI transactions and supplier communications to cross-reference retailer SKU with supplier catalog number.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginTargetId rdf:type rdf:Property ;
    rdfs:label 'Margin Target Id' ;
    rdfs:comment 'Foreign key linking to pricing.margin_target. Business justification: Open-to-Buy (OTB) supply planning in retail is constrained by margin targets — the plan\'s sell_through_rate_pct and weeks_of_supply are set to meet margin_target thresholds. Retail planners need this ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarginTarget .

ind:stockPositionId rdf:type rdf:Property ;
    rdfs:label 'Stock Position Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_position. Business justification: Supply chain plans reference current stock positions for beginning_on_hand_qty and projected inventory calculations. Linking plan to stock_position enables plan accuracy validation and real-time plan ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:allocationPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority Rank' ;
    rdfs:comment 'Numeric rank (1 = highest priority) assigned to this DC for allocation of constrained supply for the SKU. Used by planners to prioritize distribution of limited inventory across DCs and stores during supply-constrained periods.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the supply plan record was approved in the S&OP workflow. Provides a precise audit trail for plan authorization and supports compliance with internal governance controls.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or employee identifier of the supply chain planner or manager who approved this supply plan record in the S&OP workflow. Provides audit trail for plan authorization decisions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beginningOnHandQty rdf:type rdf:Property ;
    rdfs:label 'Beginning On Hand Qty' ;
    rdfs:comment 'Projected on-hand inventory quantity for the SKU at the DC at the start of the planning week, before any receipts or demand consumption. Used as the opening inventory position for supply-demand balancing calculations.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consensusDemandQty rdf:type rdf:Property ;
    rdfs:label 'Consensus Demand Qty' ;
    rdfs:comment 'Agreed demand quantity after S&OP consensus adjustments, incorporating planner overrides, promotional uplifts, and commercial inputs. This is the demand signal used for supply-demand balancing in the approved plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossdockQty rdf:type rdf:Property ;
    rdfs:label 'Crossdock Qty' ;
    rdfs:comment 'Quantity of the SKU planned for cross-docking at the DC, bypassing put-away storage and flowing directly from inbound receipt to outbound shipment. Supports DC throughput optimization and reduces handling costs for high-velocity items.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandForecastQty rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Qty' ;
    rdfs:comment 'Statistical demand forecast quantity for the SKU at the DC for the planning week, expressed in the SKU\'s unit of measure. Sourced from Blue Yonder Demand Planning and represents the baseline demand signal before supply constraints are applied.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excessInventoryFlag rdf:type rdf:Property ;
    rdfs:label 'Excess Inventory Flag' ;
    rdfs:comment 'Indicates whether the projected on-hand quantity exceeds the maximum inventory target for the SKU-DC combination in the planning week. When True, signals a potential dead stock or overstock situation requiring markdown or redistribution action.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inTransitQty rdf:type rdf:Property ;
    rdfs:label 'In Transit Qty' ;
    rdfs:comment 'Quantity of the SKU currently in transit from supplier or another DC, expected to arrive at the destination DC within the planning week. Represents confirmed supply pipeline inventory not yet received.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxInventoryQty rdf:type rdf:Property ;
    rdfs:label 'Max Inventory Qty' ;
    rdfs:comment 'Maximum allowable on-hand inventory quantity for the SKU at the DC, representing the upper bound of the inventory target range. Projected on-hand quantities exceeding this threshold trigger the excess inventory flag.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minOrderQty rdf:type rdf:Property ;
    rdfs:label 'Min Order Qty' ;
    rdfs:comment 'Minimum Order Quantity (MOQ) required by the supplier for this SKU, representing the smallest quantity that can be ordered in a single purchase order. Constrains replenishment order quantities in the supply plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openPoQty rdf:type rdf:Property ;
    rdfs:label 'Open Po Qty' ;
    rdfs:comment 'Quantity on open, unfulfilled Purchase Orders (POs) for this SKU-DC combination expected to be received within the planning week. Sourced from SAP S/4HANA MM and ORMS to represent committed supply.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Business-facing externally-known identifier for the supply plan record, used in S&OP communications, planner workflows, and cross-system references. Typically formatted as a combination of DC code, SKU, and planning week.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedReceiptQty rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Qty' ;
    rdfs:comment 'Total quantity of the SKU planned to be received at the DC during the planning week from all supply sources (open POs, in-transit, cross-dock). Core output of the supply planning process used to assess coverage against demand.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannerNotes rdf:type rdf:Property ;
    rdfs:label 'Planner Notes' ;
    rdfs:comment 'Free-text notes entered by the supply chain planner to document assumptions, exceptions, override rationale, or action items associated with this supply plan record. Supports S&OP review discussions and audit trail.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizonWeeks rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Weeks' ;
    rdfs:comment 'Number of weeks forward from the plan week start date that this supply plan covers. Defines the rolling planning window used for demand-supply balancing and replenishment trigger decisions.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectedOnHandQty rdf:type rdf:Property ;
    rdfs:label 'Projected On Hand Qty' ;
    rdfs:comment 'Projected ending on-hand inventory quantity for the SKU at the DC at the end of the planning week, calculated as beginning on-hand plus planned receipts minus consensus demand. Key metric for identifying coverage gaps and excess inventory.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalUpliftQty rdf:type rdf:Property ;
    rdfs:label 'Promotional Uplift Qty' ;
    rdfs:comment 'Incremental demand quantity attributed to a promotional event for this SKU-DC-week, added on top of the baseline statistical forecast to derive the consensus demand quantity. Sourced from the promotions planning system.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentOrderQty rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Qty' ;
    rdfs:comment 'Recommended replenishment order quantity for the SKU-DC combination for the planning week, calculated by the planning system to bring projected on-hand to the target inventory level. Serves as the basis for generating new purchase orders.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellThroughRatePct rdf:type rdf:Property ;
    rdfs:label 'Sell Through Rate Pct' ;
    rdfs:comment 'Percentage of available inventory for this SKU that has been sold within the planning period, calculated as units sold divided by beginning inventory plus receipts. Used to assess demand velocity and identify slow-moving or dead stock.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockoutRiskScore rdf:type rdf:Property ;
    rdfs:label 'Stockout Risk Score' ;
    rdfs:comment 'Quantitative risk score (0-100) indicating the probability of a stockout event for the SKU at the DC within the planning horizon. Derived from demand variability, supply reliability, and projected on-hand versus safety stock. Used to prioritize replenishment actions.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierFillRatePct rdf:type rdf:Property ;
    rdfs:label 'Supplier Fill Rate Pct' ;
    rdfs:comment 'Historical fill rate percentage for this supplier-SKU combination, representing the percentage of ordered quantity actually delivered on time. Used as a supply reliability input to safety stock and risk score calculations.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Supplier Lead Time Days' ;
    rdfs:comment 'Number of days from purchase order placement to expected receipt at the DC for this SKU-supplier combination. Used in replenishment planning to determine order timing and assess supply pipeline coverage.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplyConstrainedFlag rdf:type rdf:Property ;
    rdfs:label 'Supply Constrained Flag' ;
    rdfs:comment 'Indicates whether the supply plan for this SKU-DC-week is constrained by supplier capacity, lead time, or minimum order quantity (MOQ) limitations. When True, planned receipt quantity is below unconstrained demand, triggering allocation prioritization.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit of measure in which all quantity fields (demand, receipt, on-hand) are expressed for this SKU in the supply plan. Common values include EA (each), CS (case), PK (pack). Ensures consistent quantity interpretation across planning systems. [ENUM-REF-CANDIDATE: EA|CS|PK|LB|KG|OZ|L|M — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Sequential version number of the supply plan, incremented each time the plan is revised within the same planning cycle. Enables planners to track plan evolution and compare versions during S&OP reviews.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weekEndDate rdf:type rdf:Property ;
    rdfs:label 'Week End Date' ;
    rdfs:comment 'The last day (Sunday) of the planning week for which this supply plan record applies. Used in conjunction with plan_week_start_date to define the weekly planning horizon bucket.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:weekStartDate rdf:type rdf:Property ;
    rdfs:label 'Week Start Date' ;
    rdfs:comment 'The first day (Monday) of the planning week for which this supply plan record applies. Defines the weekly time bucket used in S&OP reviews and demand-supply balancing at the SKU-DC-week granularity.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inboundAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Inbound Appointment Id' ;
    rdfs:comment 'Unique system-generated identifier for each dock appointment scheduling record for inbound shipments at distribution centers and stores.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundAppointment .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Identifier of the transportation carrier responsible for delivering the inbound shipment to the facility.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:carrierServiceId rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.carrier_service. Business justification: Dock scheduling by carrier service: carrier service determines appointment duration, dock door requirements, and unload method; linking inbound_appointment to carrier_service enables dock capacity pla' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierService .

ind:inboundShipmentId rdf:type rdf:Property ;
    rdfs:label 'Inbound Shipment Id' ;
    rdfs:comment 'Reference to the inbound shipment record expected at this appointment. Enables traceability from appointment to physical shipment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundShipment .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'The actual date and time the carrier checked in or arrived at the facility gate or dock. Used to calculate on-time performance and dwell time against the scheduled start.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualCartonCount rdf:type rdf:Property ;
    rdfs:label 'Actual Carton Count' ;
    rdfs:comment 'The actual number of cartons or cases physically received during unloading. Discrepancies against expected carton count trigger supplier chargeback or shortage claims.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualPalletCount rdf:type rdf:Property ;
    rdfs:label 'Actual Pallet Count' ;
    rdfs:comment 'The actual number of pallets received and counted during the unloading process. Compared against expected pallet count to identify discrepancies and supplier compliance issues.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualUnloadEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Unload End Timestamp' ;
    rdfs:comment 'The actual date and time when physical unloading was completed and the dock door was cleared. Used to compute actual unload duration and dock utilization.' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualUnloadStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Unload Start Timestamp' ;
    rdfs:comment 'The actual date and time when physical unloading of the trailer or container began at the assigned dock door.' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:advanceShipNoticeNumber rdf:type rdf:Property ;
    rdfs:label 'Advance Ship Notice Number' ;
    rdfs:comment 'The Advance Ship Notice (ASN) number transmitted by the supplier via EDI 856 prior to shipment arrival. Enables pre-receiving, labor planning, and automated appointment creation.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Appointment Duration Minutes' ;
    rdfs:comment 'The planned duration of the dock appointment in minutes, calculated based on expected volume (pallets/cartons) and appointment type. Drives dock door time slot blocking in the WMS scheduler.' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appointmentNotes rdf:type rdf:Property ;
    rdfs:label 'Appointment Notes' ;
    rdfs:comment 'Free-text notes or special instructions associated with the appointment, entered by DC staff, carriers, or the scheduling system. May include special handling requirements, access instructions, or exception details.' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentNumber rdf:type rdf:Property ;
    rdfs:label 'Appointment Number' ;
    rdfs:comment 'Externally-known, human-readable appointment reference number used by carriers, suppliers, and DC staff to identify and communicate about the appointment. Typically generated by the WMS or carrier portal.' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Appointment Status' ;
    rdfs:comment 'Current lifecycle state of the dock appointment. Tracks progression from initial scheduling through completion or exception. Values: scheduled (booked but not confirmed), confirmed (carrier acknowledged), arrived (carrier checked in at gate), completed (unload finished), no_show (carrier did not arrive), cancelled (appointment voided).' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentType rdf:type rdf:Property ;
    rdfs:label 'Appointment Type' ;
    rdfs:comment 'Classification of the inbound appointment by unloading method. Live unload: carrier waits while freight is unloaded. Drop trailer: carrier leaves trailer at dock for later unloading. Cross-dock (cross-docking): freight transferred directly to outbound without storage. Floor load: loose cartons loaded directly on trailer floor.' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'The Bill of Lading (BOL) number issued by the carrier as a receipt of freight and contract of carriage. Key document for inbound receiving reconciliation and dispute resolution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorNumber rdf:type rdf:Property ;
    rdfs:label 'Dock Door Number' ;
    rdfs:comment 'The specific dock door or bay number at the facility assigned to this inbound appointment. Used for physical routing of labor and equipment to the correct location.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorZone rdf:type rdf:Property ;
    rdfs:label 'Dock Door Zone' ;
    rdfs:comment 'The physical zone or section of the facility where the assigned dock door is located (e.g., North Dock, Receiving Zone A). Supports labor planning and traffic flow management.' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Driver License Number' ;
    rdfs:comment 'The commercial driver\'s license (CDL) number of the driver presenting at the facility. Captured for security verification and regulatory compliance at gate check-in.' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverName rdf:type rdf:Property ;
    rdfs:label 'Driver Name' ;
    rdfs:comment 'The name of the truck driver who checked in at the facility for this appointment. Captured at gate check-in for security and compliance purposes.' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCartonCount rdf:type rdf:Property ;
    rdfs:label 'Expected Carton Count' ;
    rdfs:comment 'The total number of cartons or cases expected in the inbound shipment per the ASN or purchase order. Used for receiving accuracy validation.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedPalletCount rdf:type rdf:Property ;
    rdfs:label 'Expected Pallet Count' ;
    rdfs:comment 'The number of pallets expected to be unloaded during this appointment as communicated via ASN or purchase order. Used for dock labor planning and time slot duration calculation.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Expected Weight Kg' ;
    rdfs:comment 'The total expected gross weight of the inbound shipment in kilograms as declared on the Bill of Lading or ASN. Used for dock equipment planning and freight audit.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHazmat rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat' ;
    rdfs:comment 'Indicates whether the inbound shipment contains hazardous materials (Hazmat) requiring special handling, dock equipment, or regulatory compliance procedures at the facility.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Is Temperature Controlled' ;
    rdfs:comment 'Indicates whether the inbound shipment requires temperature-controlled handling (refrigerated or frozen). Triggers assignment to a temperature-controlled dock door and cold chain receiving procedures.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateArrivalReason rdf:type rdf:Property ;
    rdfs:label 'Late Arrival Reason' ;
    rdfs:comment 'Free-text or coded reason captured when a carrier arrives outside the scheduled appointment window. Used for root cause analysis of inbound logistics delays and carrier performance management. [ENUM-REF-CANDIDATE: traffic|weather|mechanical_breakdown|driver_hours|customs_delay|shipper_delay|other — promote to reference product]' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeArrivalFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Arrival Flag' ;
    rdfs:comment 'Indicates whether the carrier arrived within the scheduled appointment window. Derived from comparison of actual arrival timestamp to scheduled start timestamp. Used for carrier on-time performance (OTP) reporting and SLA compliance tracking.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalScheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Original Scheduled Start Timestamp' ;
    rdfs:comment 'The original planned appointment start timestamp before any rescheduling occurred. Preserved for compliance reporting and to measure the impact of rescheduling on DC operations.' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:proNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Number' ;
    rdfs:comment 'The carrier-assigned Progressive (PRO) number, which is the freight bill number used to track the shipment through the carrier\'s system. Standard identifier for LTL and TL freight.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rescheduleCount rdf:type rdf:Property ;
    rdfs:label 'Reschedule Count' ;
    rdfs:comment 'The number of times this appointment has been rescheduled. High reschedule counts indicate carrier reliability issues or supply chain disruptions and are used in supplier/carrier compliance scoring.' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Timestamp' ;
    rdfs:comment 'The planned date and time when the unloading activity is expected to be completed and the dock door released for the next appointment.' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'The planned date and time when the carrier is expected to arrive at the dock door and unloading is scheduled to begin. Principal business event timestamp for the appointment.' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:schedulingSource rdf:type rdf:Property ;
    rdfs:label 'Scheduling Source' ;
    rdfs:comment 'Channel or method through which the appointment was originally created. Carrier portal: self-service web portal. EDI: Electronic Data Interchange automated scheduling. Manual: DC staff entered directly. API: programmatic integration from TMS or OMS.' ;
    rdfs:domain ind:InboundAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'The security seal number affixed to the trailer or container door. Verified at arrival to confirm shipment integrity and detect tampering during transit.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRequirement rdf:type rdf:Property ;
    rdfs:label 'Temperature Requirement' ;
    rdfs:comment 'The specific temperature handling requirement for the inbound shipment. Ambient: room temperature. Chilled: 0–4°C. Frozen: -18°C or below. Ultra-frozen: -40°C or below (e.g., pharmaceutical or specialty frozen goods).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerNumber rdf:type rdf:Property ;
    rdfs:label 'Trailer Number' ;
    rdfs:comment 'The carrier-assigned trailer or container identification number for the inbound shipment. Used for physical asset tracking, seal verification, and RFID scanning at the dock.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storefrontId rdf:type rdf:Property ;
    rdfs:label 'Storefront Id' ;
    rdfs:comment 'Unique surrogate identifier for each digital storefront or online channel record. Primary key for the storefront master data product within the e-commerce domain.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Storefront .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Each e-commerce storefront incurs operating costs (hosting, platform fees, marketing) tracked against a cost center for opex budgeting and P&L reporting. Retail finance teams allocate channel costs to' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:digitalCatalogId rdf:type rdf:Property ;
    rdfs:label 'Digital Catalog Id' ;
    rdfs:comment 'Identifier of the product catalog assigned to this storefront within Salesforce Commerce Cloud or the PIM system. Determines which assortment of SKUs, categories, and product content is surfaced to customers on this channel. Aligns with Oracle Retail Merchandising System (ORMS) assortment planning and Informatica MDM product golden records.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalCatalog .

ind:formatId rdf:type rdf:Property ;
    rdfs:label 'Format Id' ;
    rdfs:comment 'Foreign key linking to store.format. Business justification: Omnichannel assortment and pricing configuration: a storefront inherits format-level assortment breadth, pricing strategy type, and fulfillment capability flags (BOPIS, SFS, ROPIS). Retail operators c' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Format .

ind:ledgerId rdf:type rdf:Property ;
    rdfs:label 'Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.ledger. Business justification: Multi-country retail storefronts post revenue to a designated accounting ledger (e.g., IFRS vs local GAAP). Financial close and revenue recognition reporting require knowing which ledger governs each ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ledger .

ind:priceListId rdf:type rdf:Property ;
    rdfs:label 'Price List Id' ;
    rdfs:comment 'Identifier of the price book or pricing list assigned to this storefront, sourced from Oracle Retail Price Management (RPM) or Salesforce Commerce Cloud. Governs the base retail prices (AUR — Average Unit Retail) and EDLP (Everyday Low Price) rules applied to products displayed on this channel. Critical for channel-specific pricing strategy execution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceList .

ind:priceZoneId rdf:type rdf:Property ;
    rdfs:label 'Price Zone Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_zone. Business justification: A storefront operates within a defined price zone that governs which prices are displayed to online shoppers. Zone-based ecommerce pricing (regional competitive pricing, currency zones) requires store' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceZone .

ind:primaryFulfillmentNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Fulfillment Node Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.fulfillment_node. Business justification: BOPIS, ROPIS, and ship-from-store operations require each storefront to have a primary fulfillment node assignment. Retail operations teams use this link for node capacity planning, SLA configuration ' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentNode .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Each storefront (site, channel, locale) maps to a profit center for P&L reporting, segment analysis, management accounting, and channel profitability tracking in retail finance systems.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Foreign key linking to loyalty.loyalty_program. Business justification: Storefront has is_loyalty_enabled and ecommerce_integration_enabled exists on loyalty_program, but no FK ties a storefront to its operating loyalty program. Retail storefronts must reference their loy' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:promoCalendarId rdf:type rdf:Property ;
    rdfs:label 'Promo Calendar Id' ;
    rdfs:comment 'Foreign key linking to promotion.promo_calendar. Business justification: Each ecommerce storefront operates under a governing promotional calendar that drives event scheduling, blackout periods, and planning lock dates. Retail digital operations teams assign a promo_calend' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoCalendar .

ind:returnPolicyId rdf:type rdf:Property ;
    rdfs:label 'Return Policy Id' ;
    rdfs:comment 'Foreign key linking to returns.return_policy. Business justification: Each e-commerce storefront channel has a distinct return policy (return_policy.sales_channel confirms this). Channel-specific return policy configuration is a standard retail operational requirement —' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReturnPolicy .

ind:vendorContractId rdf:type rdf:Property ;
    rdfs:label 'Vendor Contract Id' ;
    rdfs:comment 'Foreign key linking to supplier.vendor_contract. Business justification: Marketplace/vendor storefront governance: in retail marketplace models, a vendor-operated storefront is authorized and governed by a vendor contract (covering terms, exclusivity, payment). Operations ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorContract .

ind:analyticsTrackingCode rdf:type rdf:Property ;
    rdfs:label 'Analytics Tracking Code' ;
    rdfs:comment 'The web analytics platform tracking identifier assigned to this storefront (e.g., Google Analytics 4 Measurement ID \'G-XXXXXXXXXX\' or Adobe Analytics Report Suite ID). Used to attribute digital customer journey events, CTR (Click-Through Rate), CR (Conversion Rate), and session data to the correct storefront channel. Classified confidential as it represents proprietary analytics configuration.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaOptOutEnabled rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Enabled' ;
    rdfs:comment 'Indicates whether this storefront has activated the CCPA (California Consumer Privacy Act) \'Do Not Sell or Share My Personal Information\' opt-out mechanism, required for storefronts serving California consumers. Governs data sharing controls and consumer rights workflows.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Classification of the digital commerce channel operated by this storefront. Segments storefronts by their primary consumer interface: web (desktop/browser), mobile_app (iOS/Android native), marketplace (third-party platform such as Amazon or eBay), social_commerce (shoppable social media), or dark_store (fulfillment-only digital channel). Drives channel-specific analytics including CTR, CR, and GMV reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code indicating the primary geographic market served by this storefront (e.g., \'USA\', \'CAN\', \'GBR\'). Used for regulatory compliance scoping (GDPR, CCPA, FTC), tax jurisdiction assignment, and regional assortment planning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerServiceEmail rdf:type rdf:Property ;
    rdfs:label 'Customer Service Email' ;
    rdfs:comment 'The operational customer service email address displayed to customers on this storefront for support inquiries, returns (RMA — Return Merchandise Authorization), and complaints. Routed to Salesforce Service Cloud for case management. Classified confidential as an organizational contact identifier.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'The calendar date on which this storefront was or is scheduled to be permanently retired and removed from active digital commerce operations. Nullable for currently active storefronts. Used for channel sunset planning, data retention scheduling, and regulatory compliance archival.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:defaultLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Default Language Code' ;
    rdfs:comment 'ISO 639-1 two-letter language code representing the default display language for this storefront (e.g., \'en\', \'fr\', \'es\'). Used when a customer\'s browser language preference cannot be resolved or when the storefront operates in a single-language mode. Distinct from locale_code which also encodes regional formatting.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domainUrl rdf:type rdf:Property ;
    rdfs:label 'Domain Url' ;
    rdfs:comment 'The primary public-facing domain URL for this storefront (e.g., \'https://www.retail.com\' or \'https://m.retail.com\'). Used for SEO configuration, SSL certificate management, CDN routing, and digital marketing attribution. Classified confidential as it represents proprietary digital infrastructure configuration.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeShippingThreshold rdf:type rdf:Property ;
    rdfs:label 'Free Shipping Threshold' ;
    rdfs:comment 'The minimum order value (in the storefront\'s primary currency) at which free standard shipping is automatically applied at checkout. A key lever for AOV (Average Order Value) optimization and customer acquisition. Configured in Oracle Retail Price Management (RPM) or Salesforce Commerce Cloud promotion rules.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdprConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Required' ;
    rdfs:comment 'Indicates whether this storefront is subject to GDPR (General Data Protection Regulation) consent requirements, triggering cookie consent banners, data processing notices, and opt-in workflows for customers in EU/EEA jurisdictions. Drives compliance configuration in Salesforce Commerce Cloud and CRM systems.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBopisEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Bopis Enabled' ;
    rdfs:comment 'Indicates whether this storefront supports the BOPIS (Buy Online Pick Up In Store) fulfillment mode, allowing customers to purchase online and collect from a physical store location. Drives fulfillment routing logic in the OMS (Order Management System) and store operations workflows.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDropShipEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Drop Ship Enabled' ;
    rdfs:comment 'Indicates whether this storefront supports drop-ship fulfillment, where vendors ship products directly to customers without passing through Retail\'s DC (Distribution Center). Relevant for extended assortment and marketplace-style operations. Aligns with supplier management and EDI (Electronic Data Interchange) integration.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLoyaltyEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Loyalty Enabled' ;
    rdfs:comment 'Indicates whether this storefront is integrated with Retail\'s customer loyalty and engagement program, enabling points accrual, redemption, and CLTV (Customer Lifetime Value) tracking at the digital channel level. Drives loyalty-specific promotional targeting and RFM (Recency Frequency Monetary) segmentation.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRopisEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Ropis Enabled' ;
    rdfs:comment 'Indicates whether this storefront supports ROPIS (Reserve Online Pick Up In Store), allowing customers to reserve items online without payment and collect them in-store. Distinct from BOPIS in that no payment transaction occurs at the digital checkout stage.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isShipFromStoreEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Ship From Store Enabled' ;
    rdfs:comment 'Indicates whether this storefront supports SFS (Ship-from-Store) fulfillment, where physical store locations act as fulfillment centers for online orders. Enables distributed inventory utilization and faster last-mile delivery. Integrates with Manhattan Associates WMS for store-level pick/pack/ship operations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isShipToHomeEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Ship To Home Enabled' ;
    rdfs:comment 'Indicates whether this storefront supports ship-to-home fulfillment, where orders are dispatched from a DC (Distribution Center) or store directly to the customer\'s delivery address. Governs last-mile delivery eligibility and carrier integration activation for this channel.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxInclusivePricing rdf:type rdf:Property ;
    rdfs:label 'Is Tax Inclusive Pricing' ;
    rdfs:comment 'Indicates whether product prices displayed on this storefront include taxes (tax-inclusive, common in EU/UK markets) or exclude taxes (tax-exclusive, common in US markets). Governs price display logic at the product listing and checkout stages. Aligns with Oracle Retail Price Management (RPM) tax display configuration.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'The timestamp when this storefront record was most recently updated in the system of record. Used for change data capture (CDC), incremental ETL processing, and audit trail maintenance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'The calendar date on which this storefront was first made publicly available to customers. Used for channel age analysis, anniversary promotions, and historical performance benchmarking. Represents the effective-from date for the storefront\'s commercial lifecycle.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localeCode rdf:type rdf:Property ;
    rdfs:label 'Locale Code' ;
    rdfs:comment 'IETF BCP 47 locale code defining the primary language and regional formatting for this storefront (e.g., \'en_US\', \'fr_CA\', \'es_MX\'). Controls language display, date/number formatting, and content localization within Salesforce Commerce Cloud. Critical for omnichannel customer experience consistency.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxCartLineItems rdf:type rdf:Property ;
    rdfs:label 'Max Cart Line Items' ;
    rdfs:comment 'The maximum number of distinct line items (SKUs) permitted in a single shopping cart session on this storefront. Governs cart capacity limits configured in Salesforce Commerce Cloud to manage checkout performance and order processing capacity. Relevant for B2B or bulk-purchase storefronts.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Min Order Amount' ;
    rdfs:comment 'The minimum cart value (in the storefront\'s primary currency) required for a customer to complete checkout on this storefront. Used to enforce MOQ (Minimum Order Quantity) value thresholds, qualify for free shipping promotions, or meet marketplace seller requirements. Configured in Salesforce Commerce Cloud checkout rules.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pciComplianceLevel rdf:type rdf:Property ;
    rdfs:label 'Pci Compliance Level' ;
    rdfs:comment 'The PCI DSS (Payment Card Industry Data Security Standard) merchant compliance level assigned to this storefront, determined by annual card transaction volume (Level 1: >6M transactions; Level 2: 1M–6M; Level 3: 20K–1M; Level 4: <20K). Governs the scope of annual security assessments and SAQ (Self-Assessment Questionnaire) requirements. Classified confidential as it reveals security posture.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformVersion rdf:type rdf:Property ;
    rdfs:label 'Platform Version' ;
    rdfs:comment 'The version identifier of the Salesforce Commerce Cloud (SFCC) platform release deployed for this storefront (e.g., \'SFCC 23.7\', \'B2C Commerce 22.10\'). Used for release management, compatibility tracking, and upgrade planning across the digital commerce estate.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:robotsIndexingPolicy rdf:type rdf:Property ;
    rdfs:label 'Robots Indexing Policy' ;
    rdfs:comment 'The default robots meta directive applied to this storefront, controlling whether search engine crawlers may index pages and follow links (e.g., \'index_follow\' for the main site, \'noindex_nofollow\' for staging or dark-store channels). Impacts organic search visibility and SEO strategy.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seoMetaTitle rdf:type rdf:Property ;
    rdfs:label 'Seo Meta Title' ;
    rdfs:comment 'The default HTML meta title tag content for the storefront\'s homepage, used by search engines for indexing and SERP (Search Engine Results Page) display. Impacts organic search traffic and digital marketing performance. Managed within Salesforce Commerce Cloud site preferences.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionTimeoutMinutes rdf:type rdf:Property ;
    rdfs:label 'Session Timeout Minutes' ;
    rdfs:comment 'The number of minutes of customer inactivity after which a shopping session is automatically expired on this storefront. Governs cart abandonment timing, session-based analytics, and security compliance for authenticated customer sessions. Configured in Salesforce Commerce Cloud site security settings.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'The externally-known unique site identifier assigned within Salesforce Commerce Cloud (SFCC) for this storefront. Used as the operational reference key across digital commerce platform configurations, API calls, and integration touchpoints. Aligns to the SFCC Site object\'s siteID field.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storefrontName rdf:type rdf:Property ;
    rdfs:label 'Storefront Name' ;
    rdfs:comment 'Human-readable display name of the digital storefront or online channel (e.g., \'Retail Main Site\', \'Retail Mobile App\', \'Retail Marketplace — Amazon\'). Used in reporting dashboards, operational tooling, and business communications.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storefrontStatus rdf:type rdf:Property ;
    rdfs:label 'Storefront Status' ;
    rdfs:comment 'Current operational lifecycle state of the storefront. \'active\' indicates the storefront is live and accepting customer traffic; \'maintenance\' indicates a temporary service window; \'draft\' indicates pre-launch configuration; \'decommissioned\' indicates the channel has been permanently retired. Governs whether the storefront is eligible for traffic routing, promotional targeting, and digital commerce operations.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedPaymentMethods rdf:type rdf:Property ;
    rdfs:label 'Supported Payment Methods' ;
    rdfs:comment 'Comma-delimited list of payment methods accepted at checkout on this storefront (e.g., \'credit_card,debit_card,paypal,apple_pay,google_pay,gift_card,buy_now_pay_later\'). Governs payment gateway configuration and PCI DSS compliance scope for this channel. Managed within Salesforce Commerce Cloud payment processor settings. [ENUM-REF-CANDIDATE: credit_card|debit_card|paypal|apple_pay|google_pay|gift_card|buy_now_pay_later|bank_transfer — promote to reference product]' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Code identifying the primary tax jurisdiction applicable to this storefront for sales tax, VAT, or GST calculation purposes (e.g., \'US-CA\', \'CA-ON\', \'GB\'). Used by the tax engine integrated with Salesforce Commerce Cloud to apply correct tax rates at checkout. Aligns with FASB ASC 606 revenue recognition and FTC pricing transparency requirements.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:themeCode rdf:type rdf:Property ;
    rdfs:label 'Theme Code' ;
    rdfs:comment 'Identifier referencing the visual theme or template applied to this storefront within Salesforce Commerce Cloud (e.g., \'sfra-retail-v3\', \'pwa-kit-2024\'). Controls the storefront\'s UI/UX presentation layer, including layout, typography, and brand styling. Used by digital merchandising and visual merchandising teams for planogram-equivalent digital shelf configuration.' ;
    rdfs:domain ind:Storefront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the storefront\'s primary operating time zone (e.g., \'America/New_York\', \'America/Los_Angeles\'). Used for scheduling promotional campaigns, flash sales, maintenance windows, and business-hours-based SLA calculations. Aligns with Salesforce Commerce Cloud site time zone configuration.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandId rdf:type rdf:Property ;
    rdfs:label 'Brand Id' ;
    rdfs:comment 'Foreign key linking to product.product_brand. Business justification: Ecommerce brand pages, brand-filtered search, and brand-level promotions require catalog entries to reference the authoritative brand record. brand_name is a denormalized string; a proper FK enables b' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Identifier of the primary digital storefront category (navigation taxonomy node) under which this SKU is merchandised online. May differ from the master merchandise hierarchy in ORMS to reflect digital-specific category management and assortment breadth strategies.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:fulfillingDcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Fulfilling Dc Facility Id' ;
    rdfs:comment 'Foreign key linking to supplychain.dc_facility. Business justification: Drop-ship and delivery promise: digital_catalog.is_drop_ship_eligible requires knowing which DC fulfills the item to display accurate lead times and shipping promises online. Role-prefix \'fulfilling_\'' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:primaryImageId rdf:type rdf:Property ;
    rdfs:label 'Primary Image Id' ;
    rdfs:comment 'Foreign key linking to product.image. Business justification: Ecommerce catalog listings must reference the approved product image record for display. Linking digital_catalog to product.image enforces referential integrity, enables image lifecycle management (ex' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Image .

ind:skuPriceId rdf:type rdf:Property ;
    rdfs:label 'Sku Price Id' ;
    rdfs:comment 'Foreign key linking to pricing.sku_price. Business justification: Digital catalog product pages must display authoritative online prices from sku_price, which maintains channel-specific and zone-specific pricing. Core business process: e-commerce price display and c' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuPrice .

ind:targetSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.segment. Business justification: Segment-targeted catalog publication: retail merchandising teams publish catalogs for specific customer segments (VIP members-only catalog, B2B wholesale catalog). Segment-level catalog visibility con' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:vendorItemId rdf:type rdf:Property ;
    rdfs:label 'Vendor Item Id' ;
    rdfs:comment 'Foreign key linking to supplier.vendor_item. Business justification: Drop-ship catalog management: a digital catalog listing for a drop-ship product must reference the specific vendor_item record to surface accurate lead times, pack configuration, country of origin, an' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorItem .

ind:canonicalUrl rdf:type rdf:Property ;
    rdfs:label 'Canonical Url' ;
    rdfs:comment 'The canonical URL of the product detail page (PDP) used to prevent duplicate content issues across multiple storefront URLs or faceted navigation paths. Declared in the HTML link rel=canonical tag. Managed in Salesforce Commerce Cloud.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentCompletenessScore rdf:type rdf:Property ;
    rdfs:label 'Content Completeness Score' ;
    rdfs:comment 'Percentage score (0.00–100.00) measuring how complete the digital content is for this catalog record, based on presence of required fields such as title, description, images, SEO metadata, and rich media. Used to prioritize content enrichment efforts and improve Conversion Rate (CR).' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hasVideo rdf:type rdf:Property ;
    rdfs:label 'Has Video' ;
    rdfs:comment 'Indicates whether at least one product video (e.g., demonstration, unboxing, lifestyle) is published for this SKU on the storefront. Rich media presence is a key driver of Conversion Rate (CR) improvement in digital commerce.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imageCount rdf:type rdf:Property ;
    rdfs:label 'Image Count' ;
    rdfs:comment 'Total number of product images published for this SKU on the storefront, including hero, alternate angles, lifestyle, and swatch images. Used to measure digital content completeness and identify SKUs requiring additional imagery.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDropShipEligible rdf:type rdf:Property ;
    rdfs:label 'Is Drop Ship Eligible' ;
    rdfs:comment 'Indicates whether this SKU is fulfilled via Drop Ship, where the vendor ships directly to the customer without passing through a Distribution Center (DC). Relevant for extended aisle and marketplace assortment strategies.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFeatured rdf:type rdf:Property ;
    rdfs:label 'Is Featured' ;
    rdfs:comment 'Indicates whether this SKU has been manually designated as a featured product by digital merchandisers, qualifying it for placement in featured product carousels, homepage spotlights, or category hero positions on the storefront.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOnlineAvailable rdf:type rdf:Property ;
    rdfs:label 'Is Online Available' ;
    rdfs:comment 'Indicates whether the SKU is currently available for purchase on the digital storefront. Distinct from publication_status — a product may be published but temporarily unavailable due to inventory depletion or fulfillment constraints. Drives add-to-cart eligibility.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrivateLabel rdf:type rdf:Property ;
    rdfs:label 'Is Private Label' ;
    rdfs:comment 'Indicates whether this SKU is a private label (store brand) product owned and sold exclusively by the retailer. Private label products typically carry higher gross margins and are a key strategic differentiator in assortment planning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSearchable rdf:type rdf:Property ;
    rdfs:label 'Is Searchable' ;
    rdfs:comment 'Indicates whether this SKU is indexed and returned in on-site search results on the digital storefront. A product may be published but excluded from search (e.g., exclusive landing page products or clearance items managed via direct URL only).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPublishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Published Timestamp' ;
    rdfs:comment 'The exact date and time when this digital catalog record was most recently published or re-published to the live storefront. Used for content freshness tracking, cache invalidation, and audit trails in Salesforce Commerce Cloud.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:longDescription rdf:type rdf:Property ;
    rdfs:label 'Long Description' ;
    rdfs:comment 'Full consumer-facing product description displayed on the product detail page (PDP), including features, benefits, materials, and usage instructions. Supports rich HTML formatting. Managed in Salesforce Commerce Cloud content management.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'The consumer-facing product title as displayed on the digital storefront. May differ from the master product name in PIM to reflect channel-specific merchandising copy or A/B tested titles. Satisfies MASTER_RESOURCE IDENTITY_LABEL category.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationStatus rdf:type rdf:Property ;
    rdfs:label 'Publication Status' ;
    rdfs:comment 'Current lifecycle state of the digital catalog record on the storefront. Controls whether the SKU is visible and purchasable by online shoppers. Satisfies MASTER_RESOURCE LIFECYCLE_STATUS category. [ENUM-REF-CANDIDATE: draft|published|unpublished|scheduled|archived|suspended — promote to reference product]' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishEndDate rdf:type rdf:Property ;
    rdfs:label 'Publish End Date' ;
    rdfs:comment 'The date on which this digital catalog record is scheduled to be or was deactivated and removed from the storefront. Used for seasonal assortment management, limited-time offers, and clearance markdown lifecycle management.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publishStartDate rdf:type rdf:Property ;
    rdfs:label 'Publish Start Date' ;
    rdfs:comment 'The date on which this digital catalog record is scheduled to become or became active and visible on the storefront. Used for pre-launch product scheduling and promotional launch coordination in Salesforce Commerce Cloud.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingAverage rdf:type rdf:Property ;
    rdfs:label 'Rating Average' ;
    rdfs:comment 'Average customer review rating for this SKU on the digital storefront, on a scale of 0.00 to 5.00. Aggregated from verified purchase reviews. Used in product ranking algorithms, content completeness scoring, and conversion rate optimization analytics.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewCount rdf:type rdf:Property ;
    rdfs:label 'Review Count' ;
    rdfs:comment 'Total number of published customer reviews for this SKU on the digital storefront. Used alongside rating_average to assess review volume credibility and identify SKUs requiring review generation campaigns.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seoMetaDescription rdf:type rdf:Property ;
    rdfs:label 'Seo Meta Description' ;
    rdfs:comment 'The HTML meta description tag for the product detail page (PDP), summarizing the product for search engine result snippets. Typically 150-160 characters. Drives organic Click-Through Rate (CTR) from search engine results pages.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seoTitle rdf:type rdf:Property ;
    rdfs:label 'Seo Title' ;
    rdfs:comment 'The HTML page title tag for the product detail page (PDP), optimized for search engine indexing. Typically limited to 60 characters per SEO best practices. Managed in Salesforce Commerce Cloud content management.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Brief consumer-facing product description displayed in product listing pages (PLP) and search results. Typically 100-200 characters. Sourced from Salesforce Commerce Cloud product content and may differ from the master description in PIM.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric position used to control the default display sequence of this SKU within its assigned digital category on the storefront. Lower values appear first. Used by merchandisers to manually curate product listing page (PLP) rankings.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Tax Category Code' ;
    rdfs:comment 'Tax classification code assigned to this SKU for digital commerce tax calculation purposes, determining applicable sales tax rates at checkout. Mapped to tax engine rules in Salesforce Commerce Cloud. Relevant for FDA-regulated food items with tax exemptions.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urlSlug rdf:type rdf:Property ;
    rdfs:label 'Url Slug' ;
    rdfs:comment 'The human-readable URL path segment for the product detail page (PDP), used in constructing the storefront URL. Must be lowercase, hyphen-separated, and unique per storefront. Example: \'mens-slim-fit-chino-pants-navy\'.' ;
    rdfs:domain ind:DigitalCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:webSessionId rdf:type rdf:Property ;
    rdfs:label 'Web Session Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual visitor session on the digital storefront. Primary key for the web_session data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WebSession .

ind:cartId rdf:type rdf:Property ;
    rdfs:label 'Cart Id' ;
    rdfs:comment 'Reference to the shopping cart created or interacted with during this session. Enables abandoned cart analysis and cart-level GMV (Gross Merchandise Value) attribution even when no order is placed.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cart .

ind:headerId rdf:type rdf:Property ;
    rdfs:label 'Header Id' ;
    rdfs:comment 'Reference to the order placed during this session, if is_order_placed is True. Enables direct linkage between digital session analytics and order-level GMV (Gross Merchandise Value) and AOV (Average Order Value) reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:loyaltyMembershipId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Membership Id' ;
    rdfs:comment 'Foreign key linking to loyalty.loyalty_membership. Business justification: When a loyalty member logs into the ecommerce storefront, the session must be linked to their membership to drive personalized catalog display, member-tier pricing, and targeted offer presentation. Re' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyMembership .

ind:profileId rdf:type rdf:Property ;
    rdfs:label 'Profile Id' ;
    rdfs:comment 'Reference to the authenticated customer associated with this session. Null for anonymous/guest sessions. Enables online-to-offline attribution and CLTV (Customer Lifetime Value) analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:promoOfferId rdf:type rdf:Property ;
    rdfs:label 'Promo Offer Id' ;
    rdfs:comment 'Foreign key linking to promotion.promo_offer. Business justification: Session-level offer attribution and digital marketing ROI reporting require web sessions to reference the specific promo_offer that drove the visit. Retail digital teams track offer-driven session con' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoOffer .

ind:browserName rdf:type rdf:Property ;
    rdfs:label 'Browser Name' ;
    rdfs:comment 'Name of the web browser used during the session (e.g., Chrome, Safari, Firefox, Edge). Used for compatibility analysis and identifying browser-specific conversion drop-offs in the digital funnel.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browserVersion rdf:type rdf:Property ;
    rdfs:label 'Browser Version' ;
    rdfs:comment 'Version string of the web browser used during the session. Supports technical compatibility analysis and identification of outdated browser populations impacting checkout CR (Conversion Rate).' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'Version identifier of the consent notice or cookie policy presented to the visitor at session start. Enables compliance audit trails demonstrating which consent framework version was in effect at the time of data collection.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Consent Flag' ;
    rdfs:comment 'Indicates whether the visitor provided explicit consent for data collection and tracking during this session, as required under GDPR and CCPA. True = consent granted. Governs permissible use of session data for analytics and personalization.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Category of device used by the visitor during the session. Supports omnichannel digital journey analytics and device-specific CR (Conversion Rate) and AOV (Average Order Value) reporting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitPageUrl rdf:type rdf:Property ;
    rdfs:label 'Exit Page Url' ;
    rdfs:comment 'Full URL of the last page viewed before the visitor ended the session. Used to identify drop-off points in the digital funnel and optimize checkout flow to improve CR (Conversion Rate).' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentType rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Type' ;
    rdfs:comment 'Fulfillment method selected or browsed during the session. BOPIS (Buy Online Pick Up In Store), ROPIS (Reserve Online Pick Up In Store), home_delivery, ship_from_store (SFS), or drop_ship. Supports omnichannel attribution and last-mile delivery analytics.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geo Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code inferred from the visitor\'s IP address or browser locale. Supports international digital commerce analytics and regional GMV (Gross Merchandise Value) reporting.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address of the visitor at session initiation. Used for geolocation inference, fraud detection, and bot traffic filtering. May be considered PII under GDPR/CCPA in some jurisdictions. Stored in compliance with data minimization principles.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBot rdf:type rdf:Property ;
    rdfs:label 'Is Bot' ;
    rdfs:comment 'Indicates whether the session was identified as automated bot or crawler traffic rather than a genuine human visitor. True = bot session. Used to filter non-human traffic from CR (Conversion Rate), CTR (Click-Through Rate), and Footfall analytics.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBounce rdf:type rdf:Property ;
    rdfs:label 'Is Bounce' ;
    rdfs:comment 'Indicates whether the session was a bounce — the visitor viewed only a single page and exited without further interaction. True = bounce session. Used to calculate bounce rate as a digital storefront health KPI.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCartCreated rdf:type rdf:Property ;
    rdfs:label 'Is Cart Created' ;
    rdfs:comment 'Indicates whether the visitor created a shopping cart (added at least one item) during this session. True = cart was created. Key funnel stage flag for CR (Conversion Rate) and abandoned cart analysis in Salesforce Commerce Cloud.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCheckoutInitiated rdf:type rdf:Property ;
    rdfs:label 'Is Checkout Initiated' ;
    rdfs:comment 'Indicates whether the visitor initiated the checkout flow during this session. True = checkout was started. Enables measurement of cart-to-checkout conversion rate and identification of checkout abandonment in the digital funnel.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrderPlaced rdf:type rdf:Property ;
    rdfs:label 'Is Order Placed' ;
    rdfs:comment 'Indicates whether the session resulted in a completed order placement. True = order was placed. Primary conversion flag for CR (Conversion Rate) calculation and GMV (Gross Merchandise Value) attribution to digital sessions.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landingPageUrl rdf:type rdf:Property ;
    rdfs:label 'Landing Page Url' ;
    rdfs:comment 'Full URL of the first page viewed by the visitor upon entering the digital storefront. Critical for measuring landing page CR (Conversion Rate) and identifying high-performing entry points in the digital customer journey.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSearchQuery rdf:type rdf:Property ;
    rdfs:label 'Last Search Query' ;
    rdfs:comment 'The most recent on-site search term entered by the visitor during the session. Supports merchandising and assortment planning by revealing demand signals and zero-result search patterns.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingSystem rdf:type rdf:Property ;
    rdfs:label 'Operating System' ;
    rdfs:comment 'Operating system of the visitor\'s device during the session (e.g., Windows, macOS, iOS, Android). Used for device ecosystem analysis and platform-specific performance optimization.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageViewCount rdf:type rdf:Property ;
    rdfs:label 'Page View Count' ;
    rdfs:comment 'Total number of distinct pages viewed by the visitor during the session. Indicator of session engagement depth and product discovery behavior. Used in basket analysis and digital journey analytics.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'High-level channel classification of how the visitor arrived at the digital storefront. Supports digital marketing attribution, CTR (Click-Through Rate) analysis, and channel-level CR (Conversion Rate) reporting. [ENUM-REF-CANDIDATE: organic_search|paid_search|social|email|direct|affiliate|display|referral|sms|push_notification — promote to reference product]' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralUrl rdf:type rdf:Property ;
    rdfs:label 'Referral Url' ;
    rdfs:comment 'Full URL of the referring page or external site that directed the visitor to the digital storefront. Null for direct traffic. Enables granular attribution analysis beyond high-level referral_source classification.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchQueryCount rdf:type rdf:Property ;
    rdfs:label 'Search Query Count' ;
    rdfs:comment 'Number of on-site search queries executed by the visitor during the session. Indicator of product discovery intent and search effectiveness. Used to optimize PIM (Product Information Management) and assortment depth.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Session Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds between session_start_timestamp and session_end_timestamp. Raw measurement used to compute average session duration KPIs and correlate engagement with CR (Conversion Rate) and AOV (Average Order Value).' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session End Timestamp' ;
    rdfs:comment 'The precise date and time when the visitor session ended, either through explicit logout, timeout, or browser close. Null if session is still active. Used to compute session duration.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Start Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) when the visitor session was initiated on the digital storefront. Principal business event timestamp for session lifecycle analysis.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Current lifecycle state of the web session. \'active\' = session in progress; \'completed\' = session ended with a conversion event; \'abandoned\' = session ended without conversion; \'timed_out\' = session expired due to inactivity; \'bounced\' = single-page session with immediate exit.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionToken rdf:type rdf:Property ;
    rdfs:label 'Session Token' ;
    rdfs:comment 'Externally-known alphanumeric session identifier generated by Salesforce Commerce Cloud (SFCC) at session initiation. Used for cross-system session correlation and digital journey stitching across touchpoints.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmCampaign rdf:type rdf:Property ;
    rdfs:label 'Utm Campaign' ;
    rdfs:comment 'Urchin Tracking Module (UTM) campaign parameter identifying the specific marketing campaign name or promotion (e.g., spring_sale_2024, loyalty_reactivation). Links sessions to Pricing and Promotions Management campaigns.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmContent rdf:type rdf:Property ;
    rdfs:label 'Utm Content' ;
    rdfs:comment 'Urchin Tracking Module (UTM) content parameter used to differentiate ads or links pointing to the same URL (e.g., banner_top, text_link). Supports A/B testing and creative-level CTR (Click-Through Rate) analysis.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmMedium rdf:type rdf:Property ;
    rdfs:label 'Utm Medium' ;
    rdfs:comment 'Urchin Tracking Module (UTM) medium parameter identifying the marketing medium (e.g., cpc, email, social, banner). Used alongside utm_source for multi-channel attribution and GMV (Gross Merchandise Value) contribution analysis.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmSource rdf:type rdf:Property ;
    rdfs:label 'Utm Source' ;
    rdfs:comment 'Urchin Tracking Module (UTM) source parameter from the session entry URL, identifying the advertiser, site, publication, or other source (e.g., google, newsletter, facebook). Core dimension for digital marketing campaign attribution.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmTerm rdf:type rdf:Property ;
    rdfs:label 'Utm Term' ;
    rdfs:comment 'Urchin Tracking Module (UTM) term parameter capturing the paid search keyword that triggered the session. Used for paid search keyword-level ROI (Return on Investment) and CTR (Click-Through Rate) analysis.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitorType rdf:type rdf:Property ;
    rdfs:label 'Visitor Type' ;
    rdfs:comment 'Classification of the visitor for this session. \'new\' = first-time visitor; \'returning\' = previously visited but not authenticated; \'authenticated\' = logged-in registered customer; \'guest\' = checkout without account. Supports CR (Conversion Rate) segmentation and personalization.' ;
    rdfs:domain ind:WebSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: B2B account-based cart management: corporate accounts require credit limit validation and tax-exempt status checks at cart creation. Retail B2B platforms track cart-to-account for approval workflows, ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:couponId rdf:type rdf:Property ;
    rdfs:label 'Coupon Id' ;
    rdfs:comment 'Foreign key linking to promotion.coupon. Business justification: Coupon validation and abandoned-cart coupon recovery reporting require the cart to reference the coupon entity directly. Retail analysts track coupon-driven cart conversion rates by coupon_id. The exi' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Coupon .

ind:shippingAddressId rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Cart-level shipping address pre-selection: customers assign a saved address to the cart for real-time shipping rate calculation, BOPIS eligibility checks, and delivery date estimation before checkout.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:abandonedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Abandoned Timestamp' ;
    rdfs:comment 'The date and time when the cart was classified as abandoned, either by session timeout or explicit inactivity threshold breach. Null for non-abandoned carts. Used to calculate time-to-abandonment metrics, trigger abandoned cart recovery email sequences, and measure recovery window effectiveness.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:abandonmentReason rdf:type rdf:Property ;
    rdfs:label 'Abandonment Reason' ;
    rdfs:comment 'Classified reason code for why the cart was abandoned. \'session_timeout\' indicates the session expired; \'inactivity\' indicates no user action within the inactivity window; \'explicit_exit\' indicates the customer navigated away; \'payment_failure\' indicates checkout was attempted but payment was declined; \'out_of_stock\' indicates items became unavailable; \'price_change\' indicates a price change triggered cart exit. Null for non-abandoned carts. Supports abandonment root cause analysis.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartNumber rdf:type rdf:Property ;
    rdfs:label 'Cart Number' ;
    rdfs:comment 'Human-readable, externally referenceable business identifier for the cart instance. Used in customer service interactions, abandoned cart recovery email communications, and cross-system reconciliation between Salesforce Commerce Cloud and the Order Management System (OMS). Formatted as CART- followed by a 10-digit sequence.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartStatus rdf:type rdf:Property ;
    rdfs:label 'Cart Status' ;
    rdfs:comment 'Current lifecycle state of the shopping cart. \'active\' indicates the cart is open and being interacted with; \'abandoned\' indicates the session timed out or the customer left without checkout; \'converted\' indicates the cart was successfully submitted as an order; \'expired\' indicates the cart exceeded the maximum retention window; \'merged\' indicates the cart was consolidated with another cart (e.g., guest-to-authenticated merge). Drives abandoned cart recovery workflows and Conversion Rate (CR) reporting.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The digital channel or interface through which the cart was created and is being managed. Supports omnichannel analytics distinguishing web browser, native mobile application, mobile web browser, email-link-initiated sessions, and Buy Online Pick Up In Store (BOPIS) kiosk interactions. Critical for channel-level Conversion Rate (CR) and Average Order Value (AOV) analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Converted Timestamp' ;
    rdfs:comment 'The date and time when the cart was successfully converted to an order at checkout completion. Null for carts that have not converted. Used for cart-to-order conversion time analysis, checkout funnel performance measurement, and Conversion Rate (CR) reporting.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedShippingAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Shipping Amount' ;
    rdfs:comment 'Estimated shipping and handling cost calculated for the cart based on the selected fulfillment type, destination, and applicable shipping promotions. This is an estimate at cart stage; final shipping cost is confirmed at order submission. Relevant for BOPIS and ROPIS carts where this may be zero.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Tax Amount' ;
    rdfs:comment 'Estimated sales tax calculated on the cart based on the customer\'s shipping destination and applicable tax jurisdiction rules. This is an estimate at cart stage; final tax is confirmed at order submission. Supports pre-checkout transparency requirements per FTC pricing standards.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Timestamp' ;
    rdfs:comment 'The date and time at which this cart is scheduled to expire and be purged from the active cart pool if not converted or explicitly abandoned. Determined by storefront-level cart retention policy configuration. Used for cart lifecycle management, data retention compliance, and inventory reservation release scheduling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAbandoned rdf:type rdf:Property ;
    rdfs:label 'Is Abandoned' ;
    rdfs:comment 'Boolean flag indicating whether this cart has been classified as abandoned based on session timeout or inactivity threshold rules. True when cart_status is \'abandoned\'. Drives abandoned cart recovery workflow triggers in the abandoned_cart_recovery product. Supports cart abandonment rate KPI reporting.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGuestCart rdf:type rdf:Property ;
    rdfs:label 'Is Guest Cart' ;
    rdfs:comment 'Indicates whether this cart was created by an unauthenticated guest user (True) or an authenticated registered customer (False). Guest carts have limited personalization and recovery capabilities. Used for guest-to-registered conversion analysis and Customer Acquisition Cost (CAC) attribution.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCount rdf:type rdf:Property ;
    rdfs:label 'Item Count' ;
    rdfs:comment 'Total number of distinct line items (unique Stock Keeping Units / SKUs) currently in the cart. Used in Units Per Transaction (UPT) analysis, basket analysis, and assortment effectiveness reporting. Distinct from total_quantity which counts aggregate units across all line items.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyPointsEarned rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Earned' ;
    rdfs:comment 'Estimated number of loyalty reward points the customer will earn upon successful conversion of this cart to an order. Displayed to the customer during checkout to incentivize purchase completion. Actual points are confirmed and awarded at order fulfillment. Supports loyalty program engagement and abandoned cart recovery messaging.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyPointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Redeemed' ;
    rdfs:comment 'Number of customer loyalty reward points applied as a discount on this cart. Supports loyalty program redemption tracking, Customer Lifetime Value (CLTV) analysis, and loyalty ROI measurement. Zero if no loyalty points were applied. Integrates with the Customer Loyalty and Engagement Programs business process.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recoveryEmailSent rdf:type rdf:Property ;
    rdfs:label 'Recovery Email Sent' ;
    rdfs:comment 'Indicates whether an abandoned cart recovery email has been dispatched to the customer for this cart (True) or not yet sent (False). Prevents duplicate recovery communications and supports recovery campaign performance tracking. Integrates with the abandoned_cart_recovery product for full recovery workflow visibility.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:savedForLaterCount rdf:type rdf:Property ;
    rdfs:label 'Saved For Later Count' ;
    rdfs:comment 'Number of items the customer has moved from the active cart to a \'saved for later\' or wishlist holding area within the same session context. Supports purchase intent analysis, re-engagement campaign targeting, and assortment demand signal capture for merchandise planning.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Pre-discount, pre-tax gross merchandise value of all items in the cart at their listed retail prices. Represents the sum of (unit price × quantity) for all line items before any promotions, coupons, or markdowns are applied. Used as the base for Average Order Value (AOV) and Gross Merchandise Value (GMV) calculations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Estimated grand total for the cart calculated as subtotal_amount minus discount_amount plus estimated_tax_amount plus estimated_shipping_amount. Represents the net amount the customer is expected to pay. Used for Average Order Value (AOV) benchmarking and abandoned cart recovery value prioritization.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Quantity' ;
    rdfs:comment 'Aggregate unit count across all line items in the cart (sum of quantities for all SKUs). Supports Units Per Transaction (UPT) calculation and inventory reservation planning. Differs from item_count which counts distinct SKU lines.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartItemId rdf:type rdf:Property ;
    rdfs:label 'Cart Item Id' ;
    rdfs:comment 'Unique surrogate identifier for each line item within a shopping cart. Primary key for the cart_item data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotId rdf:type rdf:Property ;
    rdfs:label 'Lot Id' ;
    rdfs:comment 'Foreign key linking to inventory.lot. Business justification: Perishable/batch-tracked e-commerce items (grocery, pharma) require lot-level traceability for food safety recalls and FEFO fulfillment. Retail domain experts managing online grocery or regulated prod' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:priceOverrideId rdf:type rdf:Property ;
    rdfs:label 'Price Override Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_override. Business justification: When a cart item price is overridden, the system must reference the authorizing price_override record for audit trail, fraud detection, and customer service dispute resolution. cart_item.price_overrid' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceOverride .

ind:reservationId rdf:type rdf:Property ;
    rdfs:label 'Reservation Id' ;
    rdfs:comment 'Foreign key linking to inventory.reservation. Business justification: When a customer adds an item to cart, a soft inventory reservation is created per line item to prevent overselling. Retail e-commerce operations require cart_item to reference its reservation for expi' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Reservation .

ind:addToCartSource rdf:type rdf:Property ;
    rdfs:label 'Add To Cart Source' ;
    rdfs:comment 'The digital touchpoint or page from which the customer added this item to the cart. Supports Click-Through Rate (CTR) and Conversion Rate (CR) attribution analysis and product recommendation engine performance measurement. [ENUM-REF-CANDIDATE: product_detail_page|search_results|recommendation|wishlist|email_campaign|homepage|category_page|social_media|paid_ad — promote to reference product]' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addToCartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Add To Cart Timestamp' ;
    rdfs:comment 'The date and time when the customer added this item to the shopping cart. Principal business event timestamp for this entity. Used for abandoned cart analysis, session duration analytics, and digital customer journey tracking in Salesforce Commerce Cloud.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:giftMessage rdf:type rdf:Property ;
    rdfs:label 'Gift Message' ;
    rdfs:comment 'Optional personalized message entered by the customer for a gift item. Null if is_gift is False or no message was provided. Relevant only when is_gift is True.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGift rdf:type rdf:Property ;
    rdfs:label 'Is Gift' ;
    rdfs:comment 'Indicates whether the customer designated this cart line item as a gift. True if the item is intended as a gift (may include gift wrapping or message); False otherwise. Supports gifting analytics and seasonal demand planning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInStock rdf:type rdf:Property ;
    rdfs:label 'Is In Stock' ;
    rdfs:comment 'Indicates whether the product was in stock at the time the item was added to the cart. True if inventory was available; False if the item was added as a pre-order or back-order. Supports stockout-driven cart abandonment analysis.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemStatus rdf:type rdf:Property ;
    rdfs:label 'Item Status' ;
    rdfs:comment 'Current lifecycle status of the cart line item. \'active\' indicates the item is in the active cart; \'removed\' indicates the customer explicitly removed it; \'saved_for_later\' indicates the item was moved to a wishlist/save-for-later list; \'purchased\' indicates the item was converted to an order; \'expired\' indicates the cart session expired before checkout.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineSequence rdf:type rdf:Property ;
    rdfs:label 'Line Sequence' ;
    rdfs:comment 'Sequential ordering number of this line item within the parent cart. Used to maintain consistent display order and support basket analysis sequencing.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineSubtotal rdf:type rdf:Property ;
    rdfs:label 'Line Subtotal' ;
    rdfs:comment 'The total monetary value of this cart line item calculated as unit_price multiplied by quantity before tax. Contributes to Average Order Value (AOV) and Gross Merchandise Value (GMV) calculations at the cart level.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Purchased Timestamp' ;
    rdfs:comment 'The date and time when this cart line item was converted to a confirmed order line. Null if the item has not been purchased. Used for cart-to-order conversion rate (CR) analysis and Gross Merchandise Value (GMV) attribution.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Number of units of the product added to the cart for this line item. Supports Units Per Transaction (UPT) analysis and inventory reservation checks.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'The inventory quantity available for the SKU at the time the item was added to the cart. Captured as a snapshot from the inventory system. Supports out-of-stock analysis, abandoned cart attribution to stockouts, and Fill Rate reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:removalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Removal Timestamp' ;
    rdfs:comment 'The date and time when the customer explicitly removed this item from the cart. Null if the item has not been removed. Used for abandoned cart item-level recovery workflows and assortment affinity analysis.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:savedForLaterTimestamp rdf:type rdf:Property ;
    rdfs:label 'Saved For Later Timestamp' ;
    rdfs:comment 'The date and time when the customer moved this item from the active cart to the saved-for-later list. Null if the item was never saved. Supports wishlist conversion rate analysis and re-engagement campaign targeting.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'The operational system of record from which this cart line item record originated. Primarily Salesforce Commerce Cloud for digital storefronts. Supports data lineage tracking and Master Data Management (MDM) reconciliation in the Databricks Silver Layer.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'The calculated tax amount applicable to this cart line item based on the product tax category and customer shipping destination. Supports financial reporting and FASB ASC 606 revenue recognition compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'The applicable tax rate (as a decimal fraction, e.g., 0.0875 for 8.75%) applied to this cart line item. Varies by product category and jurisdiction. Supports tax compliance reporting and financial reconciliation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checkoutId rdf:type rdf:Property ;
    rdfs:label 'Checkout Id' ;
    rdfs:comment 'Unique system-generated identifier for a checkout session. Primary key for the checkout data product. Tracks the full funnel progression from cart review through order placement.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Checkout .

ind:fulfillmentInventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Inventory Node Id' ;
    rdfs:comment 'Foreign key linking to inventory.inventory_node. Business justification: BOPIS/ROPIS checkout requires the customer-selected pickup store to be recorded on the checkout record for order routing, node-level capacity management, and store fulfillment assignment. Retail domai' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:fulfillmentNodeId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Node Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.fulfillment_node. Business justification: BOPIS and ROPIS checkout flows require the customer-selected pickup node to be recorded at checkout. Retail operations use this for node-level order volume reporting, pickup slot management, and SLA c' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentNode .

ind:paymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Payment Method Id' ;
    rdfs:comment 'Foreign key linking to customer.payment_method. Business justification: Checkout saved payment method selection: customers select a stored payment method during checkout. The existing plain-text \'payment_method\' column is denormalized. A proper FK enables payment validati' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentMethod .

ind:sfsFulfillmentNodeId rdf:type rdf:Property ;
    rdfs:label 'Sfs Fulfillment Node Id' ;
    rdfs:comment 'Foreign key linking to store.sfs_fulfillment_node. Business justification: Ship-from-store order routing: when checkout fulfillment_mode is SFS, the specific fulfillment node must be captured to validate same-day/next-day cutoff times, picking capacity, and service postal co' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SfsFulfillmentNode .

ind:slaId rdf:type rdf:Property ;
    rdfs:label 'Sla Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.sla. Business justification: The delivery promise shown to customers at checkout is governed by a specific SLA record. Retail operations use this link for checkout promise accuracy audits, SLA breach attribution to checkout chann' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sla .

ind:abandonmentStep rdf:type rdf:Property ;
    rdfs:label 'Abandonment Step' ;
    rdfs:comment 'The checkout funnel step at which the customer abandoned the session. Null for completed checkouts. Identifies the highest-friction point in the checkout funnel for Conversion Rate (CR) optimization and targeted recovery messaging.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Address Validation Status' ;
    rdfs:comment 'Status of the shipping address validation performed during the address entry checkout step. \'not_validated\' = address entry step not yet reached; \'validated\' = address confirmed by address verification service; \'failed\' = address could not be validated; \'overridden\' = customer proceeded with unvalidated address. Impacts last-mile delivery success rates.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkoutNumber rdf:type rdf:Property ;
    rdfs:label 'Checkout Number' ;
    rdfs:comment 'Human-readable, externally visible reference number for the checkout session. Used in customer communications, customer service case management, and cross-system reconciliation with Salesforce Commerce Cloud. Format: CHK- followed by 10 digits.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkoutStatus rdf:type rdf:Property ;
    rdfs:label 'Checkout Status' ;
    rdfs:comment 'Current lifecycle state of the checkout session. \'initiated\' = checkout started from cart; \'in_progress\' = customer is progressing through funnel steps; \'completed\' = order successfully placed; \'abandoned\' = customer exited without placing order; \'expired\' = session timed out before completion. Core field for Conversion Rate (CR) funnel analysis.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Date and time when the checkout was successfully completed and the order was placed. Null if the checkout was abandoned or expired. Marks the boundary between the checkout domain and the order domain.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currentStep rdf:type rdf:Property ;
    rdfs:label 'Current Step' ;
    rdfs:comment 'The most recent checkout funnel step reached by the customer. Tracks progression through: cart_review → address_entry → shipping_selection → payment_entry → order_review → order_placed. Core field for Conversion Rate (CR) funnel step analysis in Salesforce Commerce Cloud.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentMode rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Mode' ;
    rdfs:comment 'The selected fulfillment method for this checkout. \'ship_to_home\' = standard home delivery; \'bopis\' = Buy Online Pick Up In Store (BOPIS); \'ropis\' = Reserve Online Pick Up In Store (ROPIS); \'drop_ship\' = vendor ships directly to customer. Drives omnichannel attribution and last-mile delivery cost analysis.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftCardAmount rdf:type rdf:Property ;
    rdfs:label 'Gift Card Amount' ;
    rdfs:comment 'Total value of gift cards applied as payment during this checkout. Zero if no gift cards were used. Tracked separately from promotional discounts for gift card liability accounting and tender type analysis.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiated Timestamp' ;
    rdfs:comment 'Date and time when the customer first entered the checkout funnel from the cart. Represents the principal business event timestamp (TRANSACTION_HEADER: BUSINESS_EVENT_TIMESTAMP). Used to measure total checkout duration and time-to-abandon metrics.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAddressEntryCompleted rdf:type rdf:Property ;
    rdfs:label 'Is Address Entry Completed' ;
    rdfs:comment 'Indicates whether the customer completed the address entry step of the checkout funnel. True = shipping/billing address entered and validated; False = not yet reached or abandoned at this step.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCartReviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Is Cart Review Completed' ;
    rdfs:comment 'Indicates whether the customer completed the cart review step of the checkout funnel. True = step completed and customer advanced; False = step not yet reached or abandoned at this step. Enables granular step-level Conversion Rate (CR) funnel analysis.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGiftOrder rdf:type rdf:Property ;
    rdfs:label 'Is Gift Order' ;
    rdfs:comment 'Indicates whether the customer designated this checkout as a gift order. True = gift order with gift messaging and/or gift wrapping selected; False = standard order. Drives gift packaging fulfillment instructions and suppresses price display on packing slips.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGuestCheckout rdf:type rdf:Property ;
    rdfs:label 'Is Guest Checkout' ;
    rdfs:comment 'Indicates whether this checkout was completed as a guest (without a registered customer account). True = guest checkout; False = authenticated customer checkout. Used to measure guest-to-registered conversion rates and assess the impact of account creation friction on Conversion Rate (CR).' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrderReviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Is Order Review Completed' ;
    rdfs:comment 'Indicates whether the customer completed the order review step (final summary before placement). True = customer reviewed and confirmed order summary; False = not yet reached or abandoned at this step.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaymentEntryCompleted rdf:type rdf:Property ;
    rdfs:label 'Is Payment Entry Completed' ;
    rdfs:comment 'Indicates whether the customer completed the payment entry step. True = payment instrument entered and validated; False = not yet reached or abandoned at this step. High abandonment at this step may indicate payment friction or trust issues.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isShippingSelectionCompleted rdf:type rdf:Property ;
    rdfs:label 'Is Shipping Selection Completed' ;
    rdfs:comment 'Indicates whether the customer completed the shipping method selection step. True = shipping method selected and confirmed; False = not yet reached or abandoned at this step.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Order Total Amount' ;
    rdfs:comment 'The final net amount due from the customer after applying subtotal, shipping, tax, discounts, gift cards, and store credits. Represents the actual charge to the customer\'s payment instrument. Core metric for Average Order Value (AOV) and Gross Merchandise Value (GMV) reporting.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Status of the payment authorization attempt during checkout. \'pending\' = authorization not yet attempted; \'authorized\' = payment instrument pre-authorized; \'captured\' = funds captured at order placement; \'declined\' = authorization declined by payment processor; \'failed\' = technical failure during authorization. Tracks payment friction in the checkout funnel.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Amount' ;
    rdfs:comment 'The shipping and handling charge applied to this checkout. Zero for free shipping promotions, BOPIS, and ROPIS fulfillment modes. Contributes to total order value and is tracked separately for shipping revenue and promotion effectiveness analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingMethodName rdf:type rdf:Property ;
    rdfs:label 'Shipping Method Name' ;
    rdfs:comment 'Human-readable display name of the selected shipping method as shown to the customer during checkout (e.g., \'Standard Shipping (5-7 Business Days)\', \'Express 2-Day Delivery\'). Preserved for customer-facing reporting and service resolution.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Store Credit Amount' ;
    rdfs:comment 'Total store credit balance applied as payment during this checkout. Zero if no store credit was used. Store credits typically originate from returns, loyalty rewards, or customer service adjustments. Tracked separately for liability accounting.' ;
    rdfs:domain ind:Checkout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalPaymentId rdf:type rdf:Property ;
    rdfs:label 'Digital Payment Id' ;
    rdfs:comment 'Unique surrogate identifier for each digital payment transaction record in the e-commerce channel. Primary key for the digital_payment data product.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ar_invoice. Business justification: Payment reconciliation and cash application require linking payment transactions to AR invoices for revenue recognition, DSO tracking, and financial close processes in retail accounting systems.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:customerPaymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Customer Payment Method Id' ;
    rdfs:comment 'Foreign key linking to customer.payment_method. Business justification: Links payment transaction to stored payment instrument. Business need: payment method performance analysis (authorization rates by card type), fraud pattern detection by instrument, PCI compliance aud' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentMethod .

ind:financialPeriodId rdf:type rdf:Property ;
    rdfs:label 'Financial Period Id' ;
    rdfs:comment 'Foreign key linking to finance.financial_period. Business justification: Digital payments must be assigned to a financial period for period-end cash reconciliation, revenue cutoff reporting, and DSO calculations. Retail finance requires knowing which fiscal period each pay' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialPeriod .

ind:fulfillmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.fulfillment_order. Business justification: Payment authorization gates fulfillment release; payment.fulfillment_order_id enables payment-to-fulfillment reconciliation for fraud holds, authorization-to-ship timing analysis, and financial-operat' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentOrder .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Payment transactions post to specific GL accounts (cash, AR clearing, merchant fees) for financial statement preparation, reconciliation, and audit trail requirements in retail accounting systems.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Every digital payment generates a journal entry (debit cash/AR, credit revenue/liability). Direct FK enables payment-to-GL reconciliation, a mandatory audit control in retail finance. Accountants and ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:returnsRefundId rdf:type rdf:Property ;
    rdfs:label 'Returns Refund Id' ;
    rdfs:comment 'Foreign key linking to returns.refund. Business justification: Payment reversal and refund reconciliation is a critical business process. When returns are processed, the original digital payment must be linked to the refund transaction for accounting, dispute res' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Refund .

ind:taxPostingId rdf:type rdf:Property ;
    rdfs:label 'Tax Posting Id' ;
    rdfs:comment 'Foreign key linking to finance.tax_posting. Business justification: Digital payments include tax_amount for VAT/sales tax collected. The corresponding tax posting record links the payment to the tax authority obligation. Required for tax remittance reconciliation, VAT' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxPosting .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'The alphanumeric authorization code returned by the issuing bank or payment network upon successful authorization of the payment. Required for dispute resolution, chargeback management, and financial reconciliation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorization Timestamp' ;
    rdfs:comment 'The timestamp when the payment authorization response was received from the issuing bank or payment network. Distinct from the initiated timestamp; used for authorization latency monitoring and SLA (Service Level Agreement) tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:avsResultCode rdf:type rdf:Property ;
    rdfs:label 'Avs Result Code' ;
    rdfs:comment 'The Address Verification Service (AVS) result code returned by the issuing bank, indicating whether the billing address provided by the customer matches the address on file. Used for fraud risk assessment and chargeback liability management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 Alpha-3 country code of the customer\'s billing address (e.g., USA, GBR, DEU). Used for fraud geo-risk scoring, tax jurisdiction determination, and international payment compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'The postal/ZIP code of the customer\'s billing address. Used for Address Verification Service (AVS) fraud checks, tax jurisdiction determination, and geographic sales analytics.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Capture Timestamp' ;
    rdfs:comment 'The timestamp when the authorized payment was captured (settled) from the customer\'s account. Marks the point of revenue recognition per FASB ASC 606. Null if payment was not captured (e.g., declined or voided).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cardBin rdf:type rdf:Property ;
    rdfs:label 'Card Bin' ;
    rdfs:comment 'The Bank Identification Number (BIN), the first 6-8 digits of the payment card number, identifying the issuing bank and card network. Used for fraud analytics, card-type classification, and interchange fee analysis. Not a full PAN — PCI DSS compliant to store.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardExpiryMonth rdf:type rdf:Property ;
    rdfs:label 'Card Expiry Month' ;
    rdfs:comment 'The expiration month of the payment card (1–12). Used in conjunction with card_expiry_year for card validity checks and customer payment method management. PCI DSS permits storage of expiry date.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardExpiryYear rdf:type rdf:Property ;
    rdfs:label 'Card Expiry Year' ;
    rdfs:comment 'The four-digit expiration year of the payment card. Used in conjunction with card_expiry_month for card validity checks and customer payment method management. PCI DSS permits storage of expiry date.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardLastFour rdf:type rdf:Property ;
    rdfs:label 'Card Last Four' ;
    rdfs:comment 'The last four digits of the payment card number. PCI DSS permits storage of the last four digits for customer service, dispute resolution, and payment method recognition. Not a full PAN.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardNetwork rdf:type rdf:Property ;
    rdfs:label 'Card Network' ;
    rdfs:comment 'The payment card network associated with the transaction (e.g., Visa, Mastercard, Amex, Discover, UnionPay). Used for interchange fee analysis, network-level fraud monitoring, and tender-mix reporting.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvvResultCode rdf:type rdf:Property ;
    rdfs:label 'Cvv Result Code' ;
    rdfs:comment 'The Card Verification Value (CVV/CVC) check result code returned by the issuing bank (M=Match, N=No Match, P=Not Processed, S=Issuer Not Certified, U=Unknown). Used for fraud risk assessment. Note: The actual CVV value is NEVER stored per PCI DSS Requirement 3.2.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'Numeric fraud risk score assigned by the fraud screening engine, typically on a scale of 0–100 or 0–1000 depending on the provider. Higher scores indicate greater fraud risk. Used for threshold-based decisioning and fraud analytics.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Fraud Screening Result' ;
    rdfs:comment 'The outcome of the automated fraud screening check applied to the payment transaction by the fraud detection engine (e.g., Adyen RevenueProtect, Stripe Radar). Values: pass (cleared), review (flagged for manual review), reject (blocked). Drives order hold and manual review workflows.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayResponseCode rdf:type rdf:Property ;
    rdfs:label 'Gateway Response Code' ;
    rdfs:comment 'The raw response code returned by the payment gateway for the transaction (e.g., \'00\' for approved, \'05\' for declined). Used for decline reason analysis, gateway troubleshooting, and Conversion Rate (CR) optimization.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Gateway Transaction Reference' ;
    rdfs:comment 'The unique transaction identifier assigned by the payment gateway (Adyen, Stripe, PayPal) for this payment. Used for cross-system reconciliation, dispute management, and gateway-level reporting.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installmentCount rdf:type rdf:Property ;
    rdfs:label 'Installment Count' ;
    rdfs:comment 'The number of installment payments agreed upon for Buy Now Pay Later (BNPL) transactions. Null or 1 for non-installment payment methods. Supports BNPL provider reconciliation and deferred revenue tracking.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether this payment is part of a recurring or subscription billing arrangement (True) or a one-time transaction (False). Relevant for subscription commerce, loyalty auto-renewal, and recurring revenue reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTestTransaction rdf:type rdf:Property ;
    rdfs:label 'Is Test Transaction' ;
    rdfs:comment 'Indicates whether this payment record is a test or sandbox transaction (True) rather than a live production transaction (False). Ensures test transactions are excluded from financial reporting, GMV calculations, and fraud analytics.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The net total amount actually charged to the customer after all adjustments (discounts, promotions, taxes). Represents the final settled monetary value of the transaction. Core field for revenue recognition per FASB ASC 606.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'The gross base payment amount submitted by the customer before any adjustments. Represents the principal monetary value of the digital payment transaction. Used in Gross Merchandise Value (GMV) and Average Order Value (AOV) calculations.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'The digital channel interface through which the payment was submitted (e.g., web, mobile app, mobile web, marketplace, Buy Online Pick Up In Store (BOPIS), Reserve Online Pick Up In Store (ROPIS)). Distinct from payment_method_type. Supports omnichannel attribution and channel-level GMV reporting.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentGateway rdf:type rdf:Property ;
    rdfs:label 'Payment Gateway' ;
    rdfs:comment 'The third-party payment gateway provider that processed the digital payment transaction (e.g., Adyen, Stripe, PayPal, Braintree, Worldpay). Used for gateway performance monitoring, fee reconciliation, and failover analysis.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodType rdf:type rdf:Property ;
    rdfs:label 'Payment Method Type' ;
    rdfs:comment 'The payment instrument used by the customer for the digital transaction (e.g., credit card, debit card, PayPal, Buy Now Pay Later (BNPL), gift card, store credit, Apple Pay, Google Pay). Drives tender-mix reporting and payment method preference analytics. [ENUM-REF-CANDIDATE: credit_card|debit_card|paypal|bnpl|gift_card|store_credit|apple_pay|google_pay — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciToken rdf:type rdf:Property ;
    rdfs:label 'Pci Token' ;
    rdfs:comment 'The PCI DSS-compliant tokenization reference that replaces the actual payment card number (PAN) in storage. Ensures cardholder data is never stored in plain text. Issued by the payment gateway tokenization vault.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'The monetary amount refunded to the customer for this payment transaction. Supports partial refund scenarios. Null if no refund has been processed. Used in net revenue and Return Merchandise Authorization (RMA) reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Timestamp' ;
    rdfs:comment 'The timestamp when a refund or partial refund was initiated for this payment transaction. Null if no refund has been processed. Supports return merchandise authorization (RMA) and customer service workflows.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:threeDsStatus rdf:type rdf:Property ;
    rdfs:label 'Three Ds Status' ;
    rdfs:comment 'The result of the 3D Secure (3DS) strong customer authentication challenge applied during checkout. Indicates whether the cardholder was successfully authenticated by their issuing bank. Drives liability shift determination and chargeback risk management.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeDsVersion rdf:type rdf:Property ;
    rdfs:label 'Three Ds Version' ;
    rdfs:comment 'The version of the 3D Secure protocol used during authentication (e.g., 1.0, 2.1, 2.2, 2.3). Relevant for compliance tracking as 3DS 1.0 is deprecated and 3DS 2.x is the current standard.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference' ;
    rdfs:comment 'Externally-known unique transaction reference number assigned by the payment gateway (e.g., Adyen, Stripe, PayPal) at the time of payment initiation. Used for reconciliation, dispute resolution, and cross-system tracing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walletProvider rdf:type rdf:Property ;
    rdfs:label 'Wallet Provider' ;
    rdfs:comment 'The digital wallet provider used when payment_method_type is a wallet-based instrument (e.g., Apple Pay, Google Pay, Samsung Pay, PayPal). Null for non-wallet payment methods. Supports digital wallet adoption analytics.' ;
    rdfs:domain ind:DigitalPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyTierId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier. Business justification: Tier-specific price lists (e.g., Gold Member Price List) are a core retail loyalty pricing mechanism. price_list.loyalty_tier_code is a denormalized plain attribute signaling this relationship; replac' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:baseMarginPct rdf:type rdf:Property ;
    rdfs:label 'Base Margin Pct' ;
    rdfs:comment 'Target gross margin percentage applied as the baseline for cost-plus pricing calculations within this price list. Expressed as a percentage (e.g., 35.00 = 35%). Used in GMROI (Gross Margin Return on Investment) analysis and OTB (Open to Buy) planning. Confidential as it reveals internal margin strategy.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveIndex rdf:type rdf:Property ;
    rdfs:label 'Competitive Index' ;
    rdfs:comment 'Ratio of this price list\'s average price level relative to key competitors, expressed as an index (e.g., 100.00 = price parity; 95.00 = 5% below market; 105.00 = 5% above market). Used in competitive pricing strategy analysis and EDLP positioning validation.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Merchandise department code within the retail hierarchy to which this price list is scoped, as defined in Oracle Retail Merchandising System (ORMS). Enables department-level pricing governance and category management alignment.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'Code identifying the retail division or business unit (e.g., GROCERY, APPAREL, ELECTRONICS, HOUSEHOLD) to which this price list is scoped. Enables division-specific pricing governance and GMROI tracking by merchandise division.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The calendar date after which this price list is no longer active for price resolution. Nullable for open-ended price lists (e.g., permanent EDLP base). When populated, the price list expires at end of this date. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The calendar date from which this price list becomes active and eligible for price resolution at POS and e-commerce checkout. Aligns with Oracle RPM effective dating and SAP S/4HANA SD pricing condition validity. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'The price list identifier as it exists in the originating source system (e.g., Oracle RPM price list ID, SAP SD pricing condition group). Enables cross-system reconciliation and EDI integration with supplier systems.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Indicates whether this price list serves as the default fallback price list when no other price list matches the resolution criteria at POS or e-commerce checkout. Only one price list per channel and price zone should be flagged as default. True = default; False = non-default.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Indicates whether prices in this price list are tax-inclusive (True) or tax-exclusive (False). Tax-inclusive pricing is common in international markets; tax-exclusive is standard in US retail. Drives tax calculation logic at POS and e-commerce checkout.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listType rdf:type rdf:Property ;
    rdfs:label 'List Type' ;
    rdfs:comment 'Classification of the pricing strategy this list represents. EDLP = Everyday Low Price stable baseline; HI_LO = High-Low promotional cadence; PROMOTIONAL = time-limited campaign price; CLEARANCE = markdown/end-of-life pricing; CLUB_MEMBER = loyalty or membership tier pricing; COMPETITIVE = market-response pricing. Drives price resolution logic at POS and e-commerce checkout. [ENUM-REF-CANDIDATE: EDLP|HI_LO|PROMOTIONAL|CLEARANCE|CLUB_MEMBER|COMPETITIVE|COST_PLUS|DYNAMIC — promote to reference product]' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownPct rdf:type rdf:Property ;
    rdfs:label 'Markdown Pct' ;
    rdfs:comment 'Default markdown percentage applied to AUR (Average Unit Retail) for clearance or promotional price lists. Expressed as a percentage reduction from the regular retail price (e.g., 20.00 = 20% off). Drives markdown optimization and end-of-season clearance planning.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Max Selling Price' ;
    rdfs:comment 'Ceiling price above which no SKU within this price list may be sold, ensuring competitive positioning and consumer protection compliance. Expressed in the price list\'s currency. Used in dynamic pricing guardrails to prevent price gouging.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Min Selling Price' ;
    rdfs:comment 'Floor price below which no SKU within this price list may be sold, protecting minimum margin thresholds and preventing below-cost selling. Enforced at POS and e-commerce checkout via Oracle RPM price guardrails. Expressed in the price list\'s currency.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next pricing review of this price list by the category management or pricing team. Used to trigger review workflows in Oracle RPM and ensure timely price updates aligned with market conditions and promotional calendars.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceListCode rdf:type rdf:Property ;
    rdfs:label 'Price List Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the price list within Oracle Retail Price Management (RPM) and SAP S/4HANA SD module. Used as the business key in EDI transactions, POS price resolution, and e-commerce checkout. Examples: EDLP_BASE, HILO_PROMO_Q4, ECOM_MEMBER.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListDescription rdf:type rdf:Property ;
    rdfs:label 'Price List Description' ;
    rdfs:comment 'Detailed business description of the price list\'s purpose, scope, and intended use. Captures the pricing strategy rationale (e.g., EDLP everyday low price baseline, Hi-Lo promotional cadence, competitive response pricing).' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListName rdf:type rdf:Property ;
    rdfs:label 'Price List Name' ;
    rdfs:comment 'Human-readable name of the price list as displayed in Oracle RPM and merchandising systems. Examples: \'EDLP Base Price List\', \'Hi-Lo Promotional Q4 2024\', \'E-Commerce Club Member Pricing\'.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListStatus rdf:type rdf:Property ;
    rdfs:label 'Price List Status' ;
    rdfs:comment 'Current lifecycle state of the price list within Oracle RPM. DRAFT = under construction, not yet approved; ACTIVE = currently in use for price resolution; SUSPENDED = temporarily deactivated; EXPIRED = past effective end date; ARCHIVED = retired and no longer available for assignment.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric rank determining the order of precedence when multiple price lists are applicable to a single SKU at POS or e-commerce checkout. Lower values indicate higher priority (e.g., 1 = highest priority). Critical for price resolution logic in omnichannel environments where EDLP, promotional, and member prices may overlap.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Scheduled cadence at which this price list is reviewed and potentially updated by the pricing team. Drives pricing governance workflows in Oracle RPM. DAILY is typical for dynamic pricing; WEEKLY for Hi-Lo promotional; QUARTERLY for EDLP base reviews. [ENUM-REF-CANDIDATE: DAILY|WEEKLY|BIWEEKLY|MONTHLY|QUARTERLY|ANNUALLY|AD_HOC — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundingRule rdf:type rdf:Property ;
    rdfs:label 'Rounding Rule' ;
    rdfs:comment 'Rule applied to computed prices within this price list to produce consumer-facing shelf prices. NEAREST_CENT = standard rounding; ROUND_UP = always round up; ROUND_DOWN = always round down; CHARM_PRICING = round to nearest .99 or .95 (psychological pricing); NONE = no rounding applied. Configured in Oracle RPM price calculation engine.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentZonePriceZoneId rdf:type rdf:Property ;
    rdfs:label 'Parent Zone Price Zone Id' ;
    rdfs:comment 'Self-referencing identifier pointing to a parent price zone in a zone hierarchy. Enables multi-tier zone structures (e.g., a national zone containing regional sub-zones). Null for top-level zones with no parent. Used in Oracle Retail Price Management (RPM) zone inheritance for pricing rule cascades.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceZone .

ind:basePriceMultiplier rdf:type rdf:Property ;
    rdfs:label 'Base Price Multiplier' ;
    rdfs:comment 'Zone-level multiplier applied to the national base price to derive the zone-specific retail price. A value of 1.0000 means no adjustment; 0.9500 means a 5% reduction; 1.0500 means a 5% premium. Used in Oracle Retail Price Management (RPM) zone pricing calculations to support Hi-Lo and EDLP strategies.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelApplicability rdf:type rdf:Property ;
    rdfs:label 'Channel Applicability' ;
    rdfs:comment 'Defines which retail channels this price zone governs. \'in_store\' applies only to physical POS (Point of Sale) transactions; \'ecommerce\' applies to Salesforce Commerce Cloud digital orders; \'omnichannel\' applies uniformly across all channels supporting BOPIS and ROPIS (Reserve Online Pick Up In Store); \'wholesale\' applies to B2B pricing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentNodeCount rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Node Count' ;
    rdfs:comment 'Current number of e-commerce fulfillment nodes (dark stores, micro-fulfillment centers, distribution centers) assigned to this price zone. Supports omnichannel pricing governance for BOPIS (Buy Online Pick Up In Store) and Ship-from-Store (SFS) operations.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCompetitiveZone rdf:type rdf:Property ;
    rdfs:label 'Is Competitive Zone' ;
    rdfs:comment 'Indicates whether this zone is subject to active competitive price monitoring and response rules. When True, Oracle Retail Price Management (RPM) applies competitive pricing overrides based on competitor intelligence feeds, enabling dynamic Hi-Lo or EDLP adjustments.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultZone rdf:type rdf:Property ;
    rdfs:label 'Is Default Zone' ;
    rdfs:comment 'Indicates whether this zone serves as the fallback default pricing zone when a store or fulfillment node has no explicit zone assignment. Only one zone per country should carry this flag as True. Prevents pricing gaps in Oracle Retail Price Management (RPM).' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEcommerceEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Ecommerce Enabled' ;
    rdfs:comment 'Indicates whether this price zone\'s pricing rules are applied to digital commerce channels via Salesforce Commerce Cloud. When True, zone prices are broadcast to the e-commerce storefront and govern online GMV (Gross Merchandise Value) pricing.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'The most recent calendar date on which this price zone\'s strategy, competitive index, and store assignments were formally reviewed and validated by the pricing governance team. Supports audit trail requirements and zone maintenance SLA (Service Level Agreement) tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketTier rdf:type rdf:Property ;
    rdfs:label 'Market Tier' ;
    rdfs:comment 'Market size and competitive intensity classification for the zone. Tier 1 represents major metropolitan markets with high competitive density; Tier 4 represents rural or low-competition markets. Drives GMROI (Gross Margin Return on Investment) targets and markdown depth thresholds per zone.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxMarkdownPct rdf:type rdf:Property ;
    rdfs:label 'Max Markdown Pct' ;
    rdfs:comment 'The maximum allowable markdown depth (as a percentage of the original retail price) permitted for any SKU within this zone. Governs markdown optimization rules in Oracle Retail Price Management (RPM) to protect zone-level profitability and prevent excessive sell-through distortion.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minMarginPct rdf:type rdf:Property ;
    rdfs:label 'Min Margin Pct' ;
    rdfs:comment 'The minimum acceptable gross margin percentage (COGS-based) enforced for all SKUs priced within this zone. Prevents markdown rules from eroding profitability below the zone\'s GMROI (Gross Margin Return on Investment) floor. Expressed as a percentage (e.g., 18.50 = 18.5%).' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Override Allowed' ;
    rdfs:comment 'Indicates whether store managers or regional pricing teams are permitted to apply local price overrides beyond the zone\'s standard pricing rules. When False, all prices are centrally governed with no local deviation permitted. Supports pricing compliance and FTC advertising standards.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Price Approval Required' ;
    rdfs:comment 'Indicates whether price changes within this zone require explicit managerial approval before activation in Oracle Retail Price Management (RPM). Supports pricing governance workflows and audit trail requirements for high-sensitivity competitive or promotional zones.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceChangeLeadDays rdf:type rdf:Property ;
    rdfs:label 'Price Change Lead Days' ;
    rdfs:comment 'Minimum number of calendar days required between a price change approval and its effective implementation at POS (Point of Sale) for stores in this zone. Accounts for shelf label reprinting, planogram updates, and EDI broadcast lead times to store systems.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'The primary pricing strategy governing all SKUs within this zone. EDLP (Everyday Low Price) maintains stable low prices; Hi-Lo (High-Low) uses promotional spikes and markdowns; cost_plus applies a fixed margin over COGS; competitive mirrors or undercuts competitor prices; dynamic adjusts prices algorithmically based on demand signals from SAP Customer Activity Repository (CAR).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Internal geographic region code used to group price zones for regional merchandise planning and Comp Sales (Comparable Store Sales) reporting. Aligns with Oracle Retail Merchandising System (ORMS) regional hierarchy. Example: \'NE\', \'SE\', \'MW\', \'WEST\'.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rpmZoneCode rdf:type rdf:Property ;
    rdfs:label 'Rpm Zone Code' ;
    rdfs:comment 'Native zone identifier from Oracle Retail Price Management (RPM) source system. Preserved for cross-system reconciliation, EDI integration, and audit trail linkage back to the operational pricing system of record.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPricingConditionGroup rdf:type rdf:Property ;
    rdfs:label 'Sap Pricing Condition Group' ;
    rdfs:comment 'SAP S/4HANA SD module pricing condition group code associated with this price zone. Used to apply zone-specific pricing conditions (VK11/VK12) in SAP for sales order pricing, ensuring consistency between Oracle RPM zone definitions and SAP transactional pricing.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCount rdf:type rdf:Property ;
    rdfs:label 'Store Count' ;
    rdfs:comment 'Current number of physical store locations assigned to this price zone. Used in zone-level Comp Sales (Comparable Store Sales) and SSS (Same-Store Sales) reporting. Updated automatically when store-to-zone assignments change.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the price zone within Oracle Retail Price Management (RPM) and SAP S/4HANA. Used in EDI transactions, pricing rule references, and cross-system integrations. Example: \'PZ_NORTHEAST_01\', \'COMP_URBAN_W\'.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneDescription rdf:type rdf:Property ;
    rdfs:label 'Zone Description' ;
    rdfs:comment 'Free-text business description of the price zone\'s purpose, geographic scope, competitive rationale, and any special pricing governance rules. Used by category management and merchandise planning teams for zone strategy documentation.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Zone Hierarchy Level' ;
    rdfs:comment 'Numeric depth of this zone within the price zone hierarchy (1 = top-level national zone, 2 = regional zone, 3 = sub-regional or competitive cluster). Used to resolve pricing rule inheritance and override precedence in Oracle Retail Price Management (RPM).' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zoneName rdf:type rdf:Property ;
    rdfs:label 'Zone Name' ;
    rdfs:comment 'Human-readable business name for the price zone used in reporting, planogram management, and pricing governance communications. Example: \'Northeast Competitive Urban Zone\', \'Rural EDLP Cluster South\'.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneStatus rdf:type rdf:Property ;
    rdfs:label 'Zone Status' ;
    rdfs:comment 'Current lifecycle status of the price zone within Oracle Retail Price Management (RPM). \'active\' zones are live and applied to store pricing; \'pending\' zones are approved but not yet effective; \'inactive\' zones are suspended; \'archived\' zones are retained for historical audit and markdown optimization analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneType rdf:type rdf:Property ;
    rdfs:label 'Zone Type' ;
    rdfs:comment 'Categorical classification of the price zone indicating the market segmentation strategy applied. \'regional\' zones group stores by geography; \'competitive\' zones respond to local competitor pricing; \'urban\'/\'rural\' zones reflect demographic cost structures; \'omnichannel\' zones unify in-store and digital pricing; \'ecommerce\' zones apply exclusively to digital fulfillment nodes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleId rdf:type rdf:Property ;
    rdfs:label 'Rule Id' ;
    rdfs:comment 'Foreign key linking to pricing.pricing_rule. Business justification: SKU prices may be calculated or adjusted by pricing rules (e.g., dynamic pricing rules, competitive response rules). Adding pricing_rule_id FK tracks which rule generated or last adjusted the price.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rule .

ind:tierId rdf:type rdf:Property ;
    rdfs:label 'Tier Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier. Business justification: Tier-specific SKU prices (member price, Gold price, Platinum price) are a fundamental retail loyalty pricing mechanism. sku_price records the actual retail price per tier; this FK enables POS price re' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:channelPriceVariance rdf:type rdf:Property ;
    rdfs:label 'Channel Price Variance' ;
    rdfs:comment 'The absolute price difference between this channel-specific price and the base in-store retail price for the same SKU, price list, and zone. Quantifies omnichannel price differentiation (e.g., e-commerce price vs. in-store price).' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelPriceVarianceReason rdf:type rdf:Property ;
    rdfs:label 'Channel Price Variance Reason' ;
    rdfs:comment 'Business justification for any price variance between this channel price and the base retail price. Required for compliance with FTC pricing transparency guidelines and internal pricing governance. Examples: \'Online-only promotion\', \'Marketplace fee offset\', \'BOPIS incentive\'.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitivePriceRef rdf:type rdf:Property ;
    rdfs:label 'Competitive Price Ref' ;
    rdfs:comment 'The competitor\'s observed price for this SKU that triggered a competitive match pricing action. Captured when price_type = \'competitive_match\'. Supports competitive pricing analytics and price index reporting.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Name of the competitor whose price was used as the reference for a competitive match pricing action. Populated when price_type = \'competitive_match\'. Used in competitive pricing intelligence reporting.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The calendar date on which this SKU price becomes active and valid for use at Point of Sale (POS) and digital channels. Supports bi-temporal price management and scheduled price changes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'The calendar date on which this SKU price record expires and is no longer valid. Null indicates an open-ended price with no scheduled expiry. Used for Hi-Lo promotional price windows and clearance event management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossMarginPct rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Pct' ;
    rdfs:comment 'Current gross margin percentage for this SKU at the current retail price, accounting for any markdowns applied. Calculated as (retail_price - cost_price) / retail_price * 100. Drives GMROI (Gross Margin Return on Investment) reporting.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initialMarkupPct rdf:type rdf:Property ;
    rdfs:label 'Initial Markup Pct' ;
    rdfs:comment 'The Initial Markup (IMU) percentage calculated as (retail_price - cost_price) / retail_price * 100. Represents the planned gross margin at the time of price setting before any markdowns.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDynamicPricingEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Dynamic Pricing Enabled' ;
    rdfs:comment 'Indicates whether dynamic pricing rules are active for this SKU in this price list, zone, and channel context. When True, the price may be algorithmically adjusted within price_floor and price_ceiling bounds based on demand signals from SAP Customer Activity Repository (CAR).' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPriceLocked rdf:type rdf:Property ;
    rdfs:label 'Is Price Locked' ;
    rdfs:comment 'Indicates whether this price record is locked and protected from automated price changes or markdown optimization algorithms. When True, the price can only be changed through a manual approval workflow in Oracle Retail Price Management (RPM).' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownAmount rdf:type rdf:Property ;
    rdfs:label 'Markdown Amount' ;
    rdfs:comment 'The absolute currency amount by which the original retail price has been reduced (markdown). Markdown = original_retail_price - retail_price. Used for markdown optimization and P&L (Profit and Loss) reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minAdvertisedPrice rdf:type rdf:Property ;
    rdfs:label 'Min Advertised Price' ;
    rdfs:comment 'The Minimum Advertised Price (MAP) floor set by the supplier or brand for this SKU. The retail_price must not be advertised below this threshold. Enforced for compliance with supplier MAP agreements and FTC advertising standards.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Original Retail Price' ;
    rdfs:comment 'The initial retail price at which the SKU was first offered for sale in this zone and channel, prior to any markdowns or price changes. Used for markdown optimization and sell-through rate analysis.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceCeiling rdf:type rdf:Property ;
    rdfs:label 'Price Ceiling' ;
    rdfs:comment 'The maximum allowable retail price for this SKU in this zone and channel. Prevents price gouging and ensures compliance with consumer protection regulations. Used in dynamic pricing guardrails.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeReason rdf:type rdf:Property ;
    rdfs:label 'Price Change Reason' ;
    rdfs:comment 'Business reason code or description explaining why this price was set or changed. Examples: \'Competitive match\', \'Seasonal markdown\', \'Clearance\', \'Cost increase\', \'Promotional event\'. Supports price change audit trail and markdown optimization analysis.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceFloor rdf:type rdf:Property ;
    rdfs:label 'Price Floor' ;
    rdfs:comment 'The minimum allowable retail price for this SKU in this zone and channel, below which the price cannot be set without executive override. Protects gross margin and prevents below-cost selling. Distinct from MAP which is a supplier-imposed advertising constraint.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePerUnitDisplay rdf:type rdf:Property ;
    rdfs:label 'Price Per Unit Display' ;
    rdfs:comment 'The normalized price per standard unit (e.g., price per 100g, price per litre) used for shelf-edge price comparison display. Required by consumer protection regulations for grocery and FMCG categories to enable fair price comparison.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePerUnitUom rdf:type rdf:Property ;
    rdfs:label 'Price Per Unit Uom' ;
    rdfs:comment 'The unit of measure denominator for the price_per_unit_display field (e.g., \'100G\', \'1L\', \'1OZ\'). Required alongside price_per_unit_display for regulatory shelf-edge unit pricing compliance.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceResolutionPriority rdf:type rdf:Property ;
    rdfs:label 'Price Resolution Priority' ;
    rdfs:comment 'Numeric priority rank used by the price resolution engine to determine which price list takes precedence when multiple price lists apply to the same SKU-zone-channel combination. Lower integer = higher priority. Drives POS and digital channel price resolution logic.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Classification of the pricing strategy applied to this SKU-price-list-zone-channel binding. Supports EDLP (Everyday Low Price), Hi-Lo (High-Low Pricing Strategy), clearance, competitive match, markdown, and promotional pricing. [ENUM-REF-CANDIDATE: edlp|hi_lo|clearance|competitive_match|markdown|promotional — promote to reference product]' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemPriceCode rdf:type rdf:Property ;
    rdfs:label 'Source System Price Code' ;
    rdfs:comment 'The native price record identifier from the originating operational system (e.g., Oracle RPM Price Event ID, SAP condition record number). Enables bi-directional traceability between the Silver Layer and the system of record for audit and reconciliation.' ;
    rdfs:domain ind:SkuPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax classification code applied to this SKU for VAT, GST, or sales tax calculation at Point of Sale (POS). Sourced from SAP S/4HANA FI/CO tax configuration. Determines the applicable tax rate for price display and checkout.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomCode rdf:type rdf:Property ;
    rdfs:label 'Uom Code' ;
    rdfs:comment 'The unit of measure for which the retail_price applies (e.g., EA = Each, KG = Kilogram, LB = Pound, L = Litre). Critical for price-per-unit display compliance and weight-based pricing at POS. [ENUM-REF-CANDIDATE: EA|KG|LB|L|ML|M|FT|OZ|PK|CS — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangeId rdf:type rdf:Property ;
    rdfs:label 'Price Change Id' ;
    rdfs:comment 'Unique surrogate identifier for each price change event record in the pricing audit trail. Primary key for the price_change data product.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceChange .

ind:markdownId rdf:type rdf:Property ;
    rdfs:label 'Markdown Id' ;
    rdfs:comment 'Foreign key linking to pricing.markdown. Business justification: Price changes are frequently triggered by markdown events. Adding markdown_id FK allows tracking which markdown event caused a price change. Removes markdown_type as it can be retrieved from markdown.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Markdown .

ind:priceRuleId rdf:type rdf:Property ;
    rdfs:label 'Price Rule Id' ;
    rdfs:comment 'Reference to the pricing rule or pricing strategy definition in Oracle RPM that generated or governs this price change event. Links to the EDLP, Hi-Lo, cost-plus, or competitive pricing rule configuration.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rule .

ind:changeCategory rdf:type rdf:Property ;
    rdfs:label 'Change Category' ;
    rdfs:comment 'High-level classification of the change event: retail_price_change (consumer-facing price), supplier_cost_change (vendor invoice cost), landed_cost_adjustment (total delivered cost including duties/tariffs), or freight_surcharge (transportation cost component).' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Nature of the price change: permanent (indefinite retail price reset), temporary (time-bounded promotional price), markdown (clearance or end-of-season price reduction), or automated (algorithm-driven dynamic pricing adjustment).' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveReferencePrice rdf:type rdf:Property ;
    rdfs:label 'Competitive Reference Price' ;
    rdfs:comment 'The competitor\'s observed price that triggered or informed a competitive_response price change. Captured for competitive pricing analysis, price matching governance, and FTC pricing transparency compliance. Null for non-competitive change reasons.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costChangePct rdf:type rdf:Property ;
    rdfs:label 'Cost Change Pct' ;
    rdfs:comment 'Percentage change in supplier or landed cost relative to the prior cost. Calculated as ((new_cost - prior_cost) / prior_cost) * 100. Key metric for supplier negotiation analysis and tariff impact assessment.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'The precise date and time when the price change event was triggered or submitted in the source pricing system (Oracle RPM or SAP). Represents the real-world business event time, distinct from system audit timestamps.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:executionMode rdf:type rdf:Property ;
    rdfs:label 'Execution Mode' ;
    rdfs:comment 'Method by which the price change was executed: manual (user-initiated via RPM UI), batch (scheduled overnight or periodic bulk update), or real_time (event-driven immediate execution, e.g., dynamic pricing engine).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCostChange rdf:type rdf:Property ;
    rdfs:label 'Is Cost Change' ;
    rdfs:comment 'Indicates whether this price change event includes a supplier or landed cost change component (True) or is a retail-price-only change (False). Enables efficient filtering for COGS recalculation and GMROI impact workflows.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMarginBreach rdf:type rdf:Property ;
    rdfs:label 'Is Margin Breach' ;
    rdfs:comment 'Indicates whether the new_margin_pct resulting from this change falls below the category or SKU-level minimum margin threshold defined in pricing governance rules (True) or remains within acceptable bounds (False). Triggers escalation workflows in Oracle RPM.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newCost rdf:type rdf:Property ;
    rdfs:label 'New Cost' ;
    rdfs:comment 'The supplier or landed cost of the SKU after this change event is applied. Drives COGS recalculation, margin impact assessment, and GMROI analysis.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newMarginPct rdf:type rdf:Property ;
    rdfs:label 'New Margin Pct' ;
    rdfs:comment 'Projected gross margin percentage on the SKU after this change event is applied, calculated as ((new_retail_price - new_cost) / new_retail_price) * 100. Used for margin impact assessment, GMROI recalculation triggers, and pricing governance.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newRetailPrice rdf:type rdf:Property ;
    rdfs:label 'New Retail Price' ;
    rdfs:comment 'The consumer-facing retail selling price of the SKU after this change event is applied. Expressed in local currency. Drives POS (Point of Sale) pricing, e-commerce display price, and AUR calculations.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorCost rdf:type rdf:Property ;
    rdfs:label 'Prior Cost' ;
    rdfs:comment 'The supplier or landed cost of the SKU immediately before this change event. Used for COGS (Cost of Goods Sold) baseline and GMROI (Gross Margin Return on Investment) impact assessment.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorMarginPct rdf:type rdf:Property ;
    rdfs:label 'Prior Margin Pct' ;
    rdfs:comment 'Gross margin percentage on the SKU immediately before this change event, calculated as ((prior_retail_price - prior_cost) / prior_retail_price) * 100. Baseline for margin impact assessment and GMROI analysis.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Prior Retail Price' ;
    rdfs:comment 'The consumer-facing retail selling price of the SKU immediately before this change event. Expressed in local currency. Used for before/after comparison, markdown depth analysis, and AUR (Average Unit Retail) tracking.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Business reason driving the price or cost change. [ENUM-REF-CANDIDATE: competitive_response|cost_increase|seasonal_adjustment|clearance_initiation|tariff_change|contract_renegotiation|raw_material_increase|promotional_event|regulatory_compliance — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailPriceChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Retail Price Change Amount' ;
    rdfs:comment 'Absolute monetary difference between new_retail_price and prior_retail_price. Negative values indicate a price decrease (markdown); positive values indicate a price increase. Used for markdown optimization and pricing governance reporting.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retailPriceChangePct rdf:type rdf:Property ;
    rdfs:label 'Retail Price Change Pct' ;
    rdfs:comment 'Percentage change in retail price relative to the prior retail price. Calculated as ((new_retail_price - prior_retail_price) / prior_retail_price) * 100. Used for markdown depth analysis and Hi-Lo pricing strategy reporting.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Reference Number' ;
    rdfs:comment 'The supplier-provided reference number associated with a cost change event, such as a vendor cost notification letter number, EDI (Electronic Data Interchange) transaction reference, or contract amendment identifier. Null for retail-only price changes.' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerSignal rdf:type rdf:Property ;
    rdfs:label 'Trigger Signal' ;
    rdfs:comment 'The specific signal or event that initiated an automated or algorithm-driven price change. Examples include competitive_price_match, demand_surge, inventory_clearance_threshold, cost_feed_update, or promotional_calendar_event. Null for manually initiated changes. [ENUM-REF-CANDIDATE: competitive_price_match|demand_surge|inventory_clearance_threshold|cost_feed_update|promotional_calendar_event|replenishment_signal — promote to reference product]' ;
    rdfs:domain ind:PriceChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownEventId rdf:type rdf:Property ;
    rdfs:label 'Markdown Event Id' ;
    rdfs:comment 'Foreign key linking to merchandising.markdown_event. Business justification: Merchandising plans markdowns via markdown_event; pricing executes them via markdown. Linking the two enables planned-vs-actual markdown reconciliation — a core retail financial reporting requirement.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarkdownEvent .

ind:memberSegmentId rdf:type rdf:Property ;
    rdfs:label 'Member Segment Id' ;
    rdfs:comment 'Foreign key linking to loyalty.member_segment. Business justification: Member-segment-targeted markdowns (e.g., clearance offers only for high-value lapsed members) are a standard retail CRM-driven markdown strategy. This FK enables markdown eligibility filtering by segm' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MemberSegment .

ind:actualExitDate rdf:type rdf:Property ;
    rdfs:label 'Actual Exit Date' ;
    rdfs:comment 'The actual date on which all inventory units subject to this markdown were fully cleared, returned, or liquidated. Compared against planned_exit_date to measure markdown execution efficiency.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The absolute monetary reduction applied to the original retail price (original_retail_price minus marked_down_price). Used for financial reporting, P&L impact analysis, and markdown budget tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearanceClosureDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Closure Date' ;
    rdfs:comment 'The date on which the clearance event was formally closed, indicating all inventory has been disposed of or the clearance program has ended. Used for clearance lifecycle reporting and dead stock elimination tracking.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceInitiationDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Initiation Date' ;
    rdfs:comment 'The date on which the clearance event was formally initiated for this SKU and location. Marks the start of the clearance lifecycle, distinct from the markdown effective start date which may precede formal clearance designation.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceStage rdf:type rdf:Property ;
    rdfs:label 'Clearance Stage' ;
    rdfs:comment 'Indicates the progression stage within a clearance event lifecycle. Not applicable for non-clearance markdowns. First Reduction: initial clearance price cut; Second Reduction: intermediate further reduction; Final Reduction: last price before disposition or liquidation.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionMethod rdf:type rdf:Property ;
    rdfs:label 'Disposition Method' ;
    rdfs:comment 'The planned or actual method for final inventory disposition after markdown. In-Store Clearance: sold through physical store; Online Clearance: sold through e-commerce channel; RTV (Return to Vendor): returned to supplier; Liquidation: sold to third-party liquidator; Donation: donated to charity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCompetitiveResponse rdf:type rdf:Property ;
    rdfs:label 'Is Competitive Response' ;
    rdfs:comment 'Flag indicating whether this markdown was triggered by a competitive pricing event (e.g., a competitor price reduction requiring a matching response). Supports competitive pricing analytics and FTC pricing transparency compliance.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDeadStock rdf:type rdf:Property ;
    rdfs:label 'Is Dead Stock' ;
    rdfs:comment 'Flag indicating whether this markdown is specifically targeting dead stock (unsold obsolete inventory with no expected organic demand). Dead stock markdowns typically require aggressive pricing or liquidation disposition to eliminate carrying costs.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownNumber rdf:type rdf:Property ;
    rdfs:label 'Markdown Number' ;
    rdfs:comment 'Externally-known business identifier for the markdown event, used in Oracle Retail Price Management (RPM) and cross-system references. Follows the enterprise markdown numbering convention (e.g., MD-202400012345).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownStatus rdf:type rdf:Property ;
    rdfs:label 'Markdown Status' ;
    rdfs:comment 'Current lifecycle state of the markdown event. Tracks progression from planning through execution and closure: draft (being planned), approved (authorized), active (currently applied at POS), completed (sell-through achieved or exit date passed), cancelled (voided before activation).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownType rdf:type rdf:Property ;
    rdfs:label 'Markdown Type' ;
    rdfs:comment 'Classification of the markdown by business purpose. Permanent: lasting price reduction; POS (Point of Sale): temporary promotional reduction applied at checkout; Clearance: inventory liquidation; End-of-Season: seasonal assortment exit; End-of-Life: product discontinuation; Dead Stock: elimination of unsold obsolete inventory.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markedDownPrice rdf:type rdf:Property ;
    rdfs:label 'Marked Down Price' ;
    rdfs:comment 'The new retail price after the markdown is applied. This is the price presented to customers at POS (Point of Sale) or on the e-commerce platform during the markdown event.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandUnitsAtInitiation rdf:type rdf:Property ;
    rdfs:label 'On Hand Units At Initiation' ;
    rdfs:comment 'The number of inventory units on hand at the time the markdown was initiated. Establishes the baseline inventory position for sell-through rate calculation and markdown ROI assessment.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:percent rdf:type rdf:Property ;
    rdfs:label 'Percent' ;
    rdfs:comment 'The markdown expressed as a percentage of the original retail price (markdown_amount / original_retail_price * 100). Used for category management reporting, markdown depth analysis, and sell-through optimization.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedExitDate rdf:type rdf:Property ;
    rdfs:label 'Planned Exit Date' ;
    rdfs:comment 'The target date by which all inventory units subject to this markdown are expected to be sold, returned, or otherwise disposed of. Used for OTB (Open to Buy) planning and clearance lifecycle management.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sellThroughActualPct rdf:type rdf:Property ;
    rdfs:label 'Sell Through Actual Pct' ;
    rdfs:comment 'The actual sell-through rate achieved as of the most recent data refresh (units sold / on_hand_units_at_initiation * 100). Compared against sell_through_target_pct to determine if further markdown action is required.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellThroughTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sell Through Target Pct' ;
    rdfs:comment 'The planned sell-through rate (percentage of on-hand inventory expected to be sold) by the effective end date or planned exit date. Used as the primary KPI for markdown performance evaluation and clearance stage progression decisions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsRemaining rdf:type rdf:Property ;
    rdfs:label 'Units Remaining' ;
    rdfs:comment 'The current number of unsold inventory units still subject to this markdown event. Calculated as on_hand_units_at_initiation minus units_sold. Drives replenishment suppression and dead stock elimination decisions.' ;
    rdfs:domain ind:Markdown ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsSold rdf:type rdf:Property ;
    rdfs:label 'Units Sold' ;
    rdfs:comment 'The cumulative number of units sold at the marked-down price since the markdown became effective. Used to calculate actual sell-through rate and markdown revenue impact.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costZoneId rdf:type rdf:Property ;
    rdfs:label 'Cost Zone Id' ;
    rdfs:comment 'Reference to the geographic or operational cost zone for which this cost applies. Cost zones allow differentiated landed costs by region, distribution center, or market.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostZone .

ind:baseCost rdf:type rdf:Property ;
    rdfs:label 'Base Cost' ;
    rdfs:comment 'The unit purchase cost of the SKU as invoiced by the supplier before any additional charges such as freight, duty, or handling. Represents the ex-works or FOB (Free on Board) cost. Core input for COGS (Cost of Goods Sold) and GMROI (Gross Margin Return on Investment) calculations.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costChangeReason rdf:type rdf:Property ;
    rdfs:label 'Cost Change Reason' ;
    rdfs:comment 'Business reason code explaining why this cost record was created or why the cost changed from the prior record. Supports cost change audit trails, markdown optimization analysis, and procurement performance reporting. [ENUM-REF-CANDIDATE: new_item|supplier_negotiation|commodity_change|fx_adjustment|tariff_change|deal_activation|deal_expiry — promote to reference product]' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the cost components are denominated (e.g., USD, EUR, GBP, CNY). Essential for multi-currency cost management and foreign exchange (FX) rate application in landed cost calculations.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costNotes rdf:type rdf:Property ;
    rdfs:label 'Cost Notes' ;
    rdfs:comment 'Free-text field for buyer or finance team annotations regarding this cost record. May include negotiation context, exception justifications, or temporary cost arrangement details. Supports operational transparency and audit trail completeness.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerInnerPack rdf:type rdf:Property ;
    rdfs:label 'Cost Per Inner Pack' ;
    rdfs:comment 'The landed cost allocated to each inner pack unit within a case or master carton. Supports cost breakdown for items sold in multiple pack configurations (e.g., a case of 12 inner packs). Used in assortment planning and margin analysis at the inner pack level.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Status' ;
    rdfs:comment 'Current lifecycle status of the cost record. Active records are used in margin calculations. Pending records are approved but not yet effective. Expired records have passed their end date. Superseded records have been replaced by a newer cost. Cancelled records were voided before activation.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costType rdf:type rdf:Property ;
    rdfs:label 'Cost Type' ;
    rdfs:comment 'Classification of the cost record indicating the pricing arrangement: standard (catalogue cost), contract (negotiated agreement cost), promotional (temporary supplier deal cost), spot (one-time market cost), or transfer (inter-company transfer cost). Drives cost-plus margin calculations and GMROI analysis.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costUom rdf:type rdf:Property ;
    rdfs:label 'Cost Uom' ;
    rdfs:comment 'The unit of measure to which the cost components apply (e.g., EA=Each, CS=Case, PK=Pack, LB=Pound, KG=Kilogram). Ensures cost-per-unit calculations are correctly interpreted across different pack configurations and ordering units. [ENUM-REF-CANDIDATE: EA|CS|PK|LB|KG|OZ|L|M|FT — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyAmount rdf:type rdf:Property ;
    rdfs:label 'Duty Amount' ;
    rdfs:comment 'Per-unit import duty, customs tariff, and trade compliance charges applied to the SKU upon importation. Varies by country of origin, product classification (HTS code), and applicable trade agreements. Critical for landed cost accuracy on imported merchandise.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutyRatePct rdf:type rdf:Property ;
    rdfs:label 'Duty Rate Pct' ;
    rdfs:comment 'The applicable import duty rate expressed as a percentage of the base cost or customs value. Used to calculate the duty_amount component of landed cost. Varies by HTS code, country of origin, and applicable trade agreements (e.g., USMCA, CAFTA).' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The date on which this cost record ceases to be operative. Null indicates an open-ended cost with no scheduled expiry. Used to manage cost versioning and ensure the correct cost is applied within a given date range.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'Per-unit freight and transportation cost incurred to move the SKU from the supplier origin to the retailer\'s distribution center or store. Includes ocean freight, air freight, or ground transport charges as applicable. Component of total landed cost.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingCost rdf:type rdf:Property ;
    rdfs:label 'Handling Cost' ;
    rdfs:comment 'Per-unit warehousing, distribution center handling, and processing charges allocated to the SKU. Includes DC (Distribution Center) receiving, put-away, and value-added services such as ticketing or re-packaging.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:htsCode rdf:type rdf:Property ;
    rdfs:label 'Hts Code' ;
    rdfs:comment 'The Harmonized Tariff Schedule code classifying the SKU for customs and import duty purposes. Determines the applicable duty rate and trade compliance requirements. Required for accurate duty cost calculation in the landed cost model.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'The International Chamber of Commerce (ICC) Incoterm governing the transfer of risk and cost responsibility between the supplier and the retailer (e.g., FOB=Free on Board, DDP=Delivered Duty Paid, CIF=Cost Insurance Freight). Determines which cost components are borne by the retailer versus the supplier. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrent rdf:type rdf:Property ;
    rdfs:label 'Is Current' ;
    rdfs:comment 'Boolean flag indicating whether this is the currently active cost record for the SKU-supplier-cost zone combination. True for the single active record; False for historical or superseded records. Simplifies queries for current cost without requiring date range filtering.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landedCost rdf:type rdf:Property ;
    rdfs:label 'Landed Cost' ;
    rdfs:comment 'The total per-unit cost of the SKU inclusive of base cost, freight, duty, handling, and other charges. Represents the true buy-side cost used for margin management, GMROI (Gross Margin Return on Investment) tracking, and cost-plus retail price calculations. Sourced from Oracle Retail Merchandising System (ORMS) landed cost module.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landedCostLocal rdf:type rdf:Property ;
    rdfs:label 'Landed Cost Local' ;
    rdfs:comment 'Total landed cost converted to the retailer\'s functional (home) currency using the applied exchange rate. Used for domestic P&L (Profit and Loss) reporting, GMROI calculations, and financial planning in the reporting currency.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorLandedCost rdf:type rdf:Property ;
    rdfs:label 'Prior Landed Cost' ;
    rdfs:comment 'The total landed cost from the immediately preceding active cost record for this SKU-supplier combination. Enables cost variance analysis, markdown optimization, and audit trail review without requiring a self-join to the history table.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemCostCode rdf:type rdf:Property ;
    rdfs:label 'Source System Cost Code' ;
    rdfs:comment 'The native identifier of this cost record in the originating source system (e.g., ORMS cost record number, SAP condition record number). Enables reconciliation between the Silver Layer data product and the operational system of record.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Code' ;
    rdfs:comment 'Alphanumeric code identifying the supplier. Denormalized for audit trail integrity and operational reporting. Sourced from SAP S/4HANA Retail vendor master.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierDealCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Deal Code' ;
    rdfs:comment 'The identifier for the supplier deal, allowance, or promotional agreement that underpins this cost record. Links to vendor deal management in Oracle Retail Merchandising System (ORMS). Applicable when cost_type is \'promotional\' or \'contract\'.' ;
    rdfs:domain ind:CostPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentMethod rdf:type rdf:Property ;
    rdfs:label 'Adjustment Method' ;
    rdfs:comment 'Specifies the mathematical method used to compute the price adjustment. \'percentage\' = apply a % change to the base price (e.g., 15% markdown); \'absolute\' = apply a fixed monetary amount change (e.g., reduce by $5.00); \'index_based\' = adjust relative to a reference index (e.g., competitor price index, CPI).' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentValue rdf:type rdf:Property ;
    rdfs:label 'Adjustment Value' ;
    rdfs:comment 'The numeric magnitude of the price adjustment as defined by the adjustment_method. For \'percentage\', this is the rate (e.g., 15.00 = 15%); for \'absolute\', this is the currency amount (e.g., 5.0000 = $5.00); for \'index_based\', this is the index multiplier. Negative values represent price reductions (markdowns); positive values represent increases.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:algorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Algorithm Version' ;
    rdfs:comment 'Version identifier of the dynamic pricing algorithm or rule engine logic applied by this rule. Used for reproducibility, audit, and A/B testing of pricing models. Example: \'v2.1.0\', \'v3.0\'. Applicable for rule_type = \'dynamic_trigger\', \'demand_based\', or \'inventory_based\'. Null for static manual rules.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableDaysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Applicable Days Of Week' ;
    rdfs:comment 'Comma-separated list of days of the week on which this pricing rule is active. Enables day-parting and weekly promotional cadence (e.g., \'MON,TUE,WED,THU,FRI\' for weekday rules; \'SAT,SUN\' for weekend Hi-Lo swings). Null if the rule applies every day within the effective date range. Format: MON|TUE|WED|THU|FRI|SAT|SUN.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorPriceIndex rdf:type rdf:Property ;
    rdfs:label 'Competitor Price Index' ;
    rdfs:comment 'The reference competitor price index value used as the benchmark for competitive match ceiling or competitive pricing rules. A value of 1.0000 = price parity; values below 1.0 indicate undercutting strategy; values above 1.0 indicate premium positioning. Sourced from competitive intelligence feeds integrated with Oracle RPM.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPlusMarginPct rdf:type rdf:Property ;
    rdfs:label 'Cost Plus Margin Pct' ;
    rdfs:comment 'The gross margin percentage applied above COGS (Cost of Goods Sold) when the rule_type is \'cost_plus_floor\'. Defines the minimum acceptable margin to protect GMROI (Gross Margin Return on Investment) targets. Example: 35.0000 = 35% margin above cost. Sourced from SAP S/4HANA CO (Controlling) module.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyExclusive rdf:type rdf:Property ;
    rdfs:label 'Loyalty Exclusive' ;
    rdfs:comment 'Indicates whether this pricing rule applies exclusively to loyalty program members. True = price adjustment is only available to enrolled loyalty customers (e.g., member-only pricing); False = rule applies to all customers regardless of loyalty status. Integrates with CRM (Customer Relationship Management) loyalty program data.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownDepthPct rdf:type rdf:Property ;
    rdfs:label 'Markdown Depth Pct' ;
    rdfs:comment 'The maximum allowable markdown percentage from the AUR (Average Unit Retail) or original retail price for markdown and clearance rules. Prevents excessive margin erosion. Example: 40.0000 = maximum 40% markdown. Used in markdown optimization workflows within Oracle RPM and Blue Yonder Demand Planning.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxPrice rdf:type rdf:Property ;
    rdfs:label 'Max Price' ;
    rdfs:comment 'The absolute ceiling price above which this rule must not raise the selling price. Prevents price gouging and ensures compliance with FTC consumer protection standards. Used in competitive match ceiling rules to cap price increases. Expressed in the operating currency (USD). Corresponds to the \'price ceiling\' concept in Oracle RPM.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minPrice rdf:type rdf:Property ;
    rdfs:label 'Min Price' ;
    rdfs:comment 'The absolute floor price below which this rule must not reduce the selling price, regardless of adjustment logic. Protects against below-cost selling and ensures compliance with FTC pricing transparency and predatory pricing regulations. Expressed in the operating currency (USD). Corresponds to the \'price floor\' concept in Oracle RPM.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Override Approval Required' ;
    rdfs:comment 'Indicates whether a manual price override for this rule requires supervisory approval before taking effect. True = approval workflow triggered in Oracle RPM; False = override can be applied immediately by authorized users. Relevant only when override_permitted = True.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overridePermitted rdf:type rdf:Property ;
    rdfs:label 'Override Permitted' ;
    rdfs:comment 'Indicates whether a merchant or store manager is permitted to manually override this pricing rule at the POS (Point of Sale) or in Oracle RPM. True = override allowed with appropriate role-based authorization; False = rule is locked and cannot be overridden (common for EDLP lock and regulatory compliance rules).' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Integer ranking that determines execution order when multiple pricing rules apply to the same SKU simultaneously. Lower numeric value = higher priority (1 = highest). Used by Oracle RPM\'s rule conflict resolution engine to determine which rule wins in overlapping scenarios. Critical for Hi-Lo vs EDLP conflict resolution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the pricing rule, used in Oracle Retail Price Management (RPM) and SAP S/4HANA SD module for cross-system reference and audit trail correlation. Example: \'EDLP-GRC-001\', \'HILO-APP-Q4\'.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Free-text narrative description of the pricing rule\'s business purpose, scope, and rationale. Authored by the pricing analyst or category manager in Oracle RPM. Provides context for audit reviews, merchant onboarding, and pricing governance documentation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable descriptive name for the pricing rule, used by merchants and pricing analysts to identify the rule in Oracle RPM dashboards and reporting. Example: \'Grocery EDLP Floor — Q1 2025\', \'Electronics Hi-Lo Weekend Swing\'.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle state of the pricing rule within Oracle RPM. Controls whether the rule is eligible for execution in batch or real-time pricing engines. \'draft\' = under configuration; \'active\' = live and enforced; \'inactive\' = disabled but retained; \'suspended\' = temporarily halted; \'expired\' = past effective end date.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Categorical classification of the pricing rule\'s business logic. Defines the algorithmic or policy basis for price determination. [ENUM-REF-CANDIDATE: cost_plus_floor|competitive_match_ceiling|edlp_lock|hilo_swing_limit|rounding|dynamic_trigger|demand_based|inventory_based|time_of_day|markdown — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuScope rdf:type rdf:Property ;
    rdfs:label 'Sku Scope' ;
    rdfs:comment 'Defines the breadth of SKU (Stock Keeping Unit) applicability for this pricing rule. \'all_skus\' applies enterprise-wide; \'category\' scopes to a merchandise category; \'department\' scopes to a department; \'specific_sku\' targets individual SKUs; \'price_zone\' applies to a geographic price zone. Aligns with Oracle Retail Merchandising System (ORMS) hierarchy.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRuleCode rdf:type rdf:Property ;
    rdfs:label 'Source System Rule Code' ;
    rdfs:comment 'The native identifier of this pricing rule in the originating operational system of record (Oracle Retail Price Management RPM). Enables bidirectional traceability between the lakehouse silver layer and the RPM source system for audit and reconciliation purposes.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackable rdf:type rdf:Property ;
    rdfs:label 'Stackable' ;
    rdfs:comment 'Indicates whether this pricing rule can be combined (stacked) with other active pricing rules or promotions for the same SKU. True = rule can stack with other discounts/promotions; False = rule is exclusive and prevents other rules from applying simultaneously. Critical for promotion conflict management in Oracle RPM.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeOfDayEnd rdf:type rdf:Property ;
    rdfs:label 'Time Of Day End' ;
    rdfs:comment 'The daily end time (HH:MM in 24-hour format) at which this rule ceases to be active for intraday pricing windows. Paired with time_of_day_start to define the active window. Null if the rule applies all day.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeOfDayStart rdf:type rdf:Property ;
    rdfs:label 'Time Of Day Start' ;
    rdfs:comment 'The daily start time (HH:MM in 24-hour format) from which this rule is active, applicable when trigger_type = \'time_based\' or rule_type = \'time_of_day\'. Enables intraday dynamic pricing (e.g., happy hour markdowns, peak-hour surcharges). Null if the rule applies all day.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Trigger Threshold Value' ;
    rdfs:comment 'The numeric threshold value that must be breached to activate the trigger condition. Interpretation depends on trigger_type: for \'inventory_threshold\' this is the WOS (Weeks of Supply) or unit count; for \'demand_surge\' this is the demand index multiplier; for \'sell_through_rate\' this is the percentage. Sourced from Blue Yonder Demand Planning signals.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerType rdf:type rdf:Property ;
    rdfs:label 'Trigger Type' ;
    rdfs:comment 'The business condition or event that activates this pricing rule. Defines what must occur for the rule to fire. [ENUM-REF-CANDIDATE: inventory_threshold|demand_surge|competitor_undercut|time_based|weather|event_driven|scheduled|manual_override|sell_through_rate — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMarginCategoryId rdf:type rdf:Property ;
    rdfs:label 'Primary Margin Category Id' ;
    rdfs:comment 'Reference to the product category within the department (e.g., Men\'s Outerwear, Fresh Produce, Laptops) for which this margin target is defined. Supports category management and assortment planning.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The calendar date on which this margin target was formally approved by the authorized merchandise planning or finance leader. Required for audit trail and governance documentation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aspTarget rdf:type rdf:Property ;
    rdfs:label 'Asp Target' ;
    rdfs:comment 'Planned Average Selling Price (ASP) for the category or subcategory during the planning period, in the denominated currency. ASP accounts for all promotional and markdown events and may differ from AUR when mix effects are significant.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aurTarget rdf:type rdf:Property ;
    rdfs:label 'Aur Target' ;
    rdfs:comment 'Planned Average Unit Retail (AUR) price point for the category or subcategory during the planning period, in the denominated currency. AUR is a key retail KPI representing the average selling price per unit and is used to validate margin targets against pricing strategy.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandClassification rdf:type rdf:Property ;
    rdfs:label 'Brand Classification' ;
    rdfs:comment 'Classifies the brand type for which this margin target applies. \'private_label\' refers to store-owned brands; \'national_brand\' refers to manufacturer brands; \'exclusive_brand\' refers to retailer-exclusive third-party brands; \'licensed_brand\' refers to licensed intellectual property brands. Supports private label vs. national brand differential margin targeting.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetUtilizationPct rdf:type rdf:Property ;
    rdfs:label 'Budget Utilization Pct' ;
    rdfs:comment 'Percentage of the total markdown budget that has been consumed, expressed as a decimal (e.g., 0.6500 = 65.00%). Calculated as consumed markdown budget divided by total markdown budget. Used to monitor markdown pacing against plan.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cogsRatePct rdf:type rdf:Property ;
    rdfs:label 'Cogs Rate Pct' ;
    rdfs:comment 'Planned Cost of Goods Sold (COGS) as a percentage of net sales for the planning period, expressed as a decimal (e.g., 0.5800 = 58.00%). Complements the gross margin target and is used for cost-plus margin validation in Oracle Retail Price Management (RPM).' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmroiTarget rdf:type rdf:Property ;
    rdfs:label 'Gmroi Target' ;
    rdfs:comment 'Planned Gross Margin Return on Investment (GMROI) threshold for the planning period, expressed as a ratio (e.g., 2.5000 = $2.50 gross margin per $1.00 of average inventory investment). Used to evaluate inventory productivity and pricing efficiency.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Indicates whether this margin target record is locked and cannot be further revised. When True, the target is frozen for the planning period and no additional budget revisions are permitted. Used to enforce financial close controls.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownBudgetConsumed rdf:type rdf:Property ;
    rdfs:label 'Markdown Budget Consumed' ;
    rdfs:comment 'Actual markdown dollars consumed against the total markdown budget as of the last refresh. Tracks cumulative markdown spend to date within the planning period, enabling real-time budget utilization monitoring.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownBudgetRemaining rdf:type rdf:Property ;
    rdfs:label 'Markdown Budget Remaining' ;
    rdfs:comment 'Remaining markdown budget available for the planning period, calculated as total markdown budget minus consumed markdown budget. Provides planners with real-time visibility into available markdown capacity.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownBudgetTotal rdf:type rdf:Property ;
    rdfs:label 'Markdown Budget Total' ;
    rdfs:comment 'Total planned markdown budget in currency units allocated for the planning period, equivalent to the Open-to-Buy (OTB) markdown dollars. Represents the maximum allowable markdown spend to achieve sell-through targets without breaching margin floors.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownOptimizationStrategy rdf:type rdf:Property ;
    rdfs:label 'Markdown Optimization Strategy' ;
    rdfs:comment 'The pricing and markdown strategy governing how markdowns are applied within this margin target. \'edlp\' = Everyday Low Price (EDLP); \'hi_lo\' = High-Low promotional pricing; \'clearance\' = end-of-season clearance markdown; \'dynamic\' = algorithmic dynamic pricing; \'cost_plus\' = cost-plus margin-based pricing.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumMarginFloorPct rdf:type rdf:Property ;
    rdfs:label 'Minimum Margin Floor Pct' ;
    rdfs:comment 'The absolute minimum acceptable gross margin percentage below which pricing decisions must not fall, expressed as a decimal (e.g., 0.2500 = 25.00%). Acts as a hard pricing guardrail to prevent margin erosion during markdowns or promotional events.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:privateLabelMarginPremiumPct rdf:type rdf:Property ;
    rdfs:label 'Private Label Margin Premium Pct' ;
    rdfs:comment 'The incremental gross margin percentage premium targeted for private label (store brand) products over national brand equivalents, expressed as a decimal (e.g., 0.0800 = 8.00% premium). Supports private label vs. national brand differential margin strategy.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential revision counter tracking how many times this margin target record has been revised or updated. Revision 0 represents the original plan; each subsequent revision increments by 1. Supports budget revision history and audit trail requirements.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Free-text description of the business reason for the most recent revision to this margin target, such as \'Competitive price response\', \'Seasonal demand shift\', or \'Inventory clearance event\'. Supports audit trail and governance documentation.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRefCode rdf:type rdf:Property ;
    rdfs:label 'Source System Ref Code' ;
    rdfs:comment 'The native identifier of this margin target record in the originating operational system (e.g., Oracle RPM plan ID, SAP cost center plan number). Enables cross-system traceability and reconciliation.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCode rdf:type rdf:Property ;
    rdfs:label 'Target Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the margin target record, used in Oracle Retail Price Management (RPM) and SAP S/4HANA for cross-system reference and audit trail linkage.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGrossMarginPct rdf:type rdf:Property ;
    rdfs:label 'Target Gross Margin Pct' ;
    rdfs:comment 'Planned gross margin percentage for the defined scope and planning period, expressed as a decimal (e.g., 0.4200 = 42.00%). Calculated as (Net Sales - COGS) / Net Sales. Serves as the primary pricing guardrail for category managers and merchandise planners.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetName rdf:type rdf:Property ;
    rdfs:label 'Target Name' ;
    rdfs:comment 'Human-readable descriptive name for the margin target plan, such as \'Q2 FY2025 Electronics Gross Margin Target\' or \'Holiday Season Apparel Markdown Budget\'. Used by category managers and merchandise planners for identification.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSellThroughRatePct rdf:type rdf:Property ;
    rdfs:label 'Target Sell Through Rate Pct' ;
    rdfs:comment 'Planned sell-through rate (percentage of inventory sold) for the planning period, expressed as a decimal (e.g., 0.8500 = 85.00%). Used in conjunction with markdown budget to optimize markdown timing and depth to achieve margin targets.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetStatus rdf:type rdf:Property ;
    rdfs:label 'Target Status' ;
    rdfs:comment 'Current lifecycle state of the margin target record. \'draft\' indicates under construction; \'active\' means currently governing pricing decisions; \'approved\' means signed off by finance/merchandising leadership; \'superseded\' means replaced by a revised target; \'closed\' means the planning period has ended; \'cancelled\' means the target was voided.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetWeeksOfSupply rdf:type rdf:Property ;
    rdfs:label 'Target Weeks Of Supply' ;
    rdfs:comment 'Planned Weeks of Supply (WOS) — the number of weeks of inventory coverage targeted at the end of the planning period. Used alongside margin targets to balance inventory investment and markdown risk.' ;
    rdfs:domain ind:MarginTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:posTerminalId rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Id' ;
    rdfs:comment 'The identifier of the Point of Sale (POS) terminal or register where the override was applied. Used for terminal-level override frequency analysis and shrinkage monitoring. Populated for in-store channel overrides; null for e-commerce.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosTerminal .

ind:posTransactionId rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Id' ;
    rdfs:comment 'Reference to the Point of Sale (POS) or e-commerce transaction in which this price override was applied. Links the override to its originating sales event in SAP Customer Activity Repository (CAR) or Salesforce Commerce Cloud.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosTransaction .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether this override type or amount threshold required explicit manager authorization before being applied at the Point of Sale (POS). Drives workflow routing in Oracle Retail Price Management (RPM) and supports discount abuse detection controls.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitorPrice rdf:type rdf:Property ;
    rdfs:label 'Competitor Price' ;
    rdfs:comment 'The price offered by the competing retailer that was matched, applicable when override_type is \'price_match\'. Used to validate price match eligibility and support competitive pricing analytics in Oracle Retail Price Management (RPM).' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceedsThreshold rdf:type rdf:Property ;
    rdfs:label 'Exceeds Threshold' ;
    rdfs:comment 'Indicates whether the override amount or percentage exceeded the authorizing employee\'s configured override limit threshold. True triggers escalation workflow and flags the record for discount abuse review.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalPrice rdf:type rdf:Property ;
    rdfs:label 'Original Price' ;
    rdfs:comment 'The regular or shelf price of the item before the override was applied, as defined in Oracle Retail Price Management (RPM). Represents the Average Unit Retail (AUR) or Everyday Low Price (EDLP) baseline used to calculate override variance and markdown impact.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideAmount rdf:type rdf:Property ;
    rdfs:label 'Override Amount' ;
    rdfs:comment 'The absolute monetary value of the price reduction applied by the override, calculated as original_price minus override_price. Used for markdown optimization, shrinkage monitoring, and Gross Margin Return on Investment (GMROI) impact analysis.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideLimitThreshold rdf:type rdf:Property ;
    rdfs:label 'Override Limit Threshold' ;
    rdfs:comment 'The maximum monetary amount or percentage discount that the authorizing employee\'s role is permitted to apply without escalation, as configured in Oracle Retail Price Management (RPM). Used to flag overrides that exceeded authorization limits for discount abuse detection.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overridePercentage rdf:type rdf:Property ;
    rdfs:label 'Override Percentage' ;
    rdfs:comment 'The price override expressed as a percentage discount relative to the original price (override_amount / original_price * 100). Used for threshold-based discount abuse detection rules and override variance reporting.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overridePrice rdf:type rdf:Property ;
    rdfs:label 'Override Price' ;
    rdfs:comment 'The final selling price applied to the item after the override, as recorded at the Point of Sale (POS) or e-commerce checkout. This is the price the customer was charged and the value recognized for revenue reporting under FASB ASC 606.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Override Reference Number' ;
    rdfs:comment 'Externally visible alphanumeric reference number assigned to this price override event, used for audit trail tracking, customer receipts, and reconciliation with Point of Sale (POS) systems and Oracle Retail Price Management (RPM).' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideStatus rdf:type rdf:Property ;
    rdfs:label 'Override Status' ;
    rdfs:comment 'Current lifecycle state of the price override record. \'applied\' indicates the override was executed at POS; \'pending_approval\' indicates it awaits manager authorization; \'rejected\' indicates it was denied; \'voided\' indicates it was cancelled before completion; \'reversed\' indicates a post-transaction correction was made.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideTimestamp rdf:type rdf:Property ;
    rdfs:label 'Override Timestamp' ;
    rdfs:comment 'The exact date and time when the price override was applied at the Point of Sale (POS) terminal or e-commerce checkout. This is the principal business event timestamp for this transaction record, recorded in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:overrideType rdf:type rdf:Property ;
    rdfs:label 'Override Type' ;
    rdfs:comment 'Classification of the business reason driving the price override. \'manager_discount\' is a discretionary reduction authorized by a supervisor; \'price_match\' is a competitive price adjustment; \'damaged_goods\' is a markdown for defective or impaired merchandise; \'loyalty_benefit\' is a discount applied via a customer loyalty program; \'error_correction\' is a fix for a pricing system error.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text narrative description entered by the authorizing employee to explain the business justification for the price override. Supplements the structured reason code with contextual detail for audit and investigation purposes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shrinkageRelated rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Related' ;
    rdfs:comment 'Indicates whether this price override is associated with a shrinkage event (e.g., damaged goods markdown, theft-related adjustment). Used for inventory shrinkage monitoring and loss prevention analytics.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'The retailer-assigned Stock Keeping Unit code identifying the specific product variant (size, color, style) subject to the price override. Aligns with the GS1 product identification standard and Oracle Retail Merchandising System (ORMS) item master.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemOverrideCode rdf:type rdf:Property ;
    rdfs:label 'Source System Override Code' ;
    rdfs:comment 'The native identifier assigned to this price override record in the originating operational system (e.g., SAP CAR document number, RPM override ID). Enables cross-system reconciliation and data lineage tracing.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOverrideImpact rdf:type rdf:Property ;
    rdfs:label 'Total Override Impact' ;
    rdfs:comment 'The total monetary impact of the price override across all units in the transaction line, calculated as override_amount multiplied by quantity. Represents the gross markdown exposure for financial reporting and Gross Margin Return on Investment (GMROI) analysis.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upc rdf:type rdf:Property ;
    rdfs:label 'Upc' ;
    rdfs:comment 'The 12-digit Universal Product Code barcode identifier for the item subject to the price override, as scanned at the Point of Sale (POS) terminal. Conforms to GS1 UPC-A standard.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidReason rdf:type rdf:Property ;
    rdfs:label 'Void Reason' ;
    rdfs:comment 'Free-text or coded explanation for why the price override was voided or reversed. Supports audit trail completeness and post-transaction correction analysis.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidTimestamp rdf:type rdf:Property ;
    rdfs:label 'Void Timestamp' ;
    rdfs:comment 'The date and time when the price override was voided or reversed, if applicable. Null for active or applied overrides. Used for override lifecycle tracking and financial reconciliation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:warehouseZoneId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Zone Id' ;
    rdfs:comment 'Foreign key linking to supplychain.warehouse_zone. Business justification: DC stock positions are physically located within warehouse zones. Linking stock_position to warehouse_zone enables zone-level inventory visibility and slotting optimization — a named retail DC slottin' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseZone .

ind:availableToPromiseQty rdf:type rdf:Property ;
    rdfs:label 'Available To Promise Qty' ;
    rdfs:comment 'Quantity of the SKU available to commit to new customer orders or fulfillment requests. Calculated as on-hand minus reserved, damaged, and quarantine quantities. Authoritative ATP signal consumed by Salesforce Commerce Cloud for omnichannel order promising (BOPIS, ROPIS, Ship-from-Store).' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgDailySalesQty rdf:type rdf:Property ;
    rdfs:label 'Avg Daily Sales Qty' ;
    rdfs:comment 'Rolling average quantity of the SKU sold per day at this node, calculated from SAP Customer Activity Repository (CAR) POS transaction data. Used to compute Weeks of Supply (WOS), reorder point, and safety stock. Input to Blue Yonder Demand Planning forecasts.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Supplier or manufacturer batch/lot number for the current inventory of this SKU at this node. Required for batch-managed products (food, pharmaceuticals, cosmetics) to support FDA recall traceability, CPSC compliance, and Return to Vendor (RTV) processing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damagedQty rdf:type rdf:Property ;
    rdfs:label 'Damaged Qty' ;
    rdfs:comment 'Quantity of the SKU identified as damaged, defective, or unsellable at the inventory node. Excluded from Available-to-Promise (ATP) calculations. Tracked for shrinkage reporting, Return to Vendor (RTV) processing, and COGS (Cost of Goods Sold) write-down.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryValuationMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Method' ;
    rdfs:comment 'Accounting method used to value this SKU\'s inventory for financial reporting. FIFO (First In First Out), LIFO (Last In First Out), WAC (Weighted Average Cost), standard_cost, or retail_method. Governed by FASB ASC 330 and reported in financial P&L statements.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRfidTracked rdf:type rdf:Property ;
    rdfs:label 'Is Rfid Tracked' ;
    rdfs:comment 'Indicates whether this SKU at this node is tracked using RFID (Radio Frequency Identification) technology for real-time inventory visibility. True enables automated cycle counts and reduces manual scanning overhead. Relevant for apparel and high-value electronics categories.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVmi rdf:type rdf:Property ;
    rdfs:label 'Is Vmi' ;
    rdfs:comment 'Indicates whether this SKU-node stock position is managed under a Vendor Managed Inventory (VMI) agreement, where the supplier is responsible for maintaining stock levels. When true, replenishment is supplier-initiated via EDI (Electronic Data Interchange) rather than retailer-triggered.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAdjustmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Adjustment Date' ;
    rdfs:comment 'Date of the most recent manual or system-generated inventory adjustment (positive or negative) for this SKU at this node. Adjustments include shrinkage write-offs, cycle count corrections, and damage write-downs posted in SAP S/4HANA MM.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date of the most recent physical cycle count or inventory audit performed for this SKU at this node. Used to assess on-hand quantity accuracy, identify shrinkage, and schedule next count. Supports OSHA and internal audit compliance for inventory accuracy.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastGoodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Receipt Date' ;
    rdfs:comment 'Date of the most recent goods receipt (inbound delivery) that updated the on-hand quantity for this SKU at this node. Sourced from SAP S/4HANA MM goods receipt postings and Manhattan Associates WMS inbound transactions. Used for freshness and lead time analysis.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSaleDate rdf:type rdf:Property ;
    rdfs:label 'Last Sale Date' ;
    rdfs:comment 'Date of the most recent Point of Sale (POS) or e-commerce sale transaction that depleted stock for this SKU at this node. Sourced from SAP Customer Activity Repository (CAR). Used for dead stock identification, velocity scoring, and markdown trigger analysis.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxStockQty rdf:type rdf:Property ;
    rdfs:label 'Max Stock Qty' ;
    rdfs:comment 'Maximum allowable on-hand quantity for this SKU at this node, used to prevent overstock and optimize shelf/storage capacity. Defined in Oracle Retail Merchandising System (ORMS) and used by replenishment planning to cap order quantities within Open-to-Buy (OTB) constraints.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandQty rdf:type rdf:Property ;
    rdfs:label 'On Hand Qty' ;
    rdfs:comment 'Total physical quantity of the SKU currently present at the inventory node, including all stock categories (sellable, reserved, damaged). Sourced from Manhattan Associates WMS goods receipt and adjustment transactions. Core metric for inventory visibility.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle status of the stock position record. Active: normal sellable stock; frozen: temporarily locked pending investigation; quarantine: damaged or suspect stock held for quality review; blocked: SAP-blocked stock not available for sale; closed: position deactivated (zero stock, node closed).' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Position Timestamp' ;
    rdfs:comment 'The precise date and time at which this stock position snapshot was captured or last updated. Represents the real-world event time of the inventory state. Critical for real-time ATP (Available-to-Promise) accuracy and omnichannel fulfillment SLA compliance.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quarantineQty rdf:type rdf:Property ;
    rdfs:label 'Quarantine Qty' ;
    rdfs:comment 'Quantity of the SKU placed in quarantine pending quality inspection, regulatory hold, or recall investigation. Separate from damaged stock. Relevant for FDA food safety holds, CPSC recall compliance, and supplier quality disputes.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderPointQty rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Qty' ;
    rdfs:comment 'Minimum on-hand quantity threshold at which a replenishment order is automatically triggered for this SKU at this node. Calculated by Blue Yonder Demand Planning based on lead time, demand velocity, and safety stock parameters. Core input to replenishment trigger logic.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentStatus rdf:type rdf:Property ;
    rdfs:label 'Replenishment Status' ;
    rdfs:comment 'Current replenishment workflow status for this SKU-node combination. normal: no action needed; triggered: reorder point breached, order pending; in_progress: replenishment order placed and open; suspended: replenishment paused (e.g., seasonal end, discontinuation); vmi: under Vendor Managed Inventory (VMI) control.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservedQty rdf:type rdf:Property ;
    rdfs:label 'Reserved Qty' ;
    rdfs:comment 'Quantity of the SKU reserved against confirmed customer orders, BOPIS (Buy Online Pick Up In Store), ROPIS (Reserve Online Pick Up In Store), or internal transfer orders. Not available for new ATP commitments until reservation is released or fulfilled.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellThroughRate rdf:type rdf:Property ;
    rdfs:label 'Sell Through Rate' ;
    rdfs:comment 'Percentage of received inventory that has been sold within a defined period, expressed as a decimal (e.g., 0.7500 = 75%). Key performance indicator for assortment efficiency, markdown timing, and dead stock identification. Calculated from SAP Customer Activity Repository (CAR) POS data.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shrinkageQty rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Qty' ;
    rdfs:comment 'Cumulative quantity of inventory loss attributed to shrinkage (theft, administrative error, vendor fraud, or damage) since the last cycle count or physical inventory. Used for shrinkage monitoring, loss prevention analytics, and COGS adjustment reporting.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The native record identifier from the originating operational system (e.g., SAP material document number, Manhattan Associates WMS inventory record ID). Enables traceability back to the system of record for reconciliation, audit, and EDI dispute resolution.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Specific storage location, bin, aisle, or zone within the inventory node where this SKU is physically stored. Sourced from Manhattan Associates WMS. Used for pick/pack/ship operations, cycle counts, and planogram (POG) compliance in store operations.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Standard cost per unit of the SKU used for inventory valuation and Cost of Goods Sold (COGS) calculation. Sourced from SAP S/4HANA FI/CO module. Confidential as it reflects supplier pricing and margin strategy. Used for GMROI (Gross Margin Return on Investment) analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:velocityBand rdf:type rdf:Property ;
    rdfs:label 'Velocity Band' ;
    rdfs:comment 'ABC/D velocity classification of the SKU at this node based on sales frequency and volume. A: fast-moving (top sellers); B: medium-moving; C: slow-moving; D: very slow or non-moving (dead stock candidate). Used for replenishment prioritization, planogram slotting, and markdown strategy.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockLedgerId rdf:type rdf:Property ;
    rdfs:label 'Stock Ledger Id' ;
    rdfs:comment 'Unique surrogate identifier for each stock ledger transaction record. Primary key for the perpetual inventory ledger at the SKU-location-date level.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockLedger .

ind:inventoryTransferId rdf:type rdf:Property ;
    rdfs:label 'Inventory Transfer Id' ;
    rdfs:comment 'Foreign key linking to supplychain.inventory_transfer. Business justification: Inter-node inventory transfers generate stock_ledger entries at origin (debit) and destination (credit). Linking stock_ledger to inventory_transfer enables transfer reconciliation and in-transit valua' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryTransfer .

ind:orderLineId rdf:type rdf:Property ;
    rdfs:label 'Order Line Id' ;
    rdfs:comment 'Foreign key linking to order.order_line. Business justification: Order fulfillment COGS reporting and inventory deduction audit: when an order line is picked/shipped, a stock_ledger entry records the inventory movement. Linking to order_line enables line-level COGS' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:outboundShipmentId rdf:type rdf:Property ;
    rdfs:label 'Outbound Shipment Id' ;
    rdfs:comment 'Foreign key linking to supplychain.outbound_shipment. Business justification: Outbound shipments from DCs to stores generate stock_ledger debit entries. Linking stock_ledger to outbound_shipment enables outbound movement reconciliation and shrinkage detection between pick confi' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundShipment .

ind:receivingEventId rdf:type rdf:Property ;
    rdfs:label 'Receiving Event Id' ;
    rdfs:comment 'Foreign key linking to supplychain.receiving_event. Business justification: Receiving events at DCs trigger stock_ledger postings (goods receipt movements). Linking stock_ledger to receiving_event enables cross-system audit trails for discrepancy resolution and financial reco' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReceivingEvent .

ind:reversedTransactionStockLedgerId rdf:type rdf:Property ;
    rdfs:label 'Reversed Transaction Stock Ledger Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original stock_ledger_id that this record reverses. Populated only when reversal_flag = True. Enables bidirectional audit trail linking between original and reversal entries.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockLedger .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.shipment. Business justification: Inventory deduction audit: when goods ship, the stock ledger entry must be traceable to the specific shipment for inventory-to-shipment reconciliation reporting. Retail finance and loss-prevention tea' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:deadStockFlag rdf:type rdf:Property ;
    rdfs:label 'Dead Stock Flag' ;
    rdfs:comment 'Indicates whether this stock movement is associated with dead stock (unsold, obsolete inventory being written off or liquidated). True = dead stock write-off or clearance movement. Supports inventory health reporting and markdown decision-making.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dsdFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Flag' ;
    rdfs:comment 'Indicates whether this receipt transaction was fulfilled via Direct Store Delivery (DSD), where the supplier delivers directly to the store bypassing the Distribution Center (DC). True = DSD transaction. Impacts supply chain routing and vendor compliance tracking.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extendedRetailValue rdf:type rdf:Property ;
    rdfs:label 'Extended Retail Value' ;
    rdfs:comment 'Total retail value of this stock movement, calculated as movement_quantity multiplied by unit_retail_price. Used in the retail inventory method for inventory valuation and supports gross margin return on investment (GMROI) reporting.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movementQuantity rdf:type rdf:Property ;
    rdfs:label 'Movement Quantity' ;
    rdfs:comment 'The quantity of units moved in this transaction. Positive values indicate stock increases (receipts, returns, transfer-in); negative values indicate stock decreases (sales, write-offs, transfer-out). Expressed in the SKU\'s base unit of measure.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movementReasonCode rdf:type rdf:Property ;
    rdfs:label 'Movement Reason Code' ;
    rdfs:comment 'Standardized reason code providing additional context for the stock movement (e.g., VENDOR_RETURN, DAMAGED_GOODS, CYCLE_COUNT_VARIANCE, THEFT_SHRINKAGE, EXPIRED_PRODUCT, PROMOTIONAL_WRITE_DOWN). Supports shrinkage analysis and loss prevention reporting. [ENUM-REF-CANDIDATE: VENDOR_RETURN|DAMAGED_GOODS|CYCLE_COUNT_VARIANCE|THEFT_SHRINKAGE|EXPIRED_PRODUCT|PROMOTIONAL_WRITE_DOWN|CUSTOMER_RETURN|INTER_DC_TRANSFER — promote to reference product]' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onHandQuantityAfter rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity After' ;
    rdfs:comment 'The total on-hand inventory quantity for this SKU at this location immediately after this transaction was applied. Represents the running balance of the perpetual inventory ledger and is the authoritative stock position for omnichannel fulfillment visibility.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandQuantityBefore rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity Before' ;
    rdfs:comment 'The total on-hand inventory quantity for this SKU at this location immediately before this transaction was applied. Enables point-in-time inventory reconstruction and audit trail validation of the perpetual ledger.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The accounting date on which this stock movement is posted to the general ledger and inventory valuation records. May differ from transaction_timestamp due to cut-off processing, period-end adjustments, or delayed DSD confirmations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'The source document number from the originating business transaction that triggered this stock movement (e.g., Purchase Order number, Transfer Order number, POS receipt number, Return Merchandise Authorization (RMA) number). Enables end-to-end traceability.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'The type of source document associated with this stock movement (e.g., PURCHASE_ORDER, TRANSFER_ORDER, POS_RECEIPT, RMA = Return Merchandise Authorization, CYCLE_COUNT, WRITE_OFF_ORDER). Enables document-level drill-through for audit and reconciliation.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this stock ledger entry is a reversal (counter-entry) of a previously posted transaction. True = this record reverses a prior movement. Used to identify corrective entries and maintain a clean audit trail for financial reconciliation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidTracked rdf:type rdf:Property ;
    rdfs:label 'Rfid Tracked' ;
    rdfs:comment 'Indicates whether this stock movement was captured or validated using Radio Frequency Identification (RFID) technology. True = RFID-confirmed movement. Supports inventory accuracy benchmarking and RFID program performance reporting.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'The unique serial number of the specific inventory unit involved in this transaction. Applicable for high-value electronics, appliances, and serialized items. Supports specific identification costing, warranty tracking, and CPSC recall management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shrinkageFlag rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Flag' ;
    rdfs:comment 'Indicates whether this stock movement represents inventory shrinkage (loss due to theft, damage, administrative error, or vendor fraud). True = shrinkage event. Used for shrinkage monitoring, loss prevention analytics, and CPSC/NRF compliance reporting.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Externally-known business identifier for this stock movement transaction, sourced from the originating system (e.g., SAP material document number, ORMS transaction reference). Used for cross-system reconciliation and audit tracing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle state of the stock ledger transaction. POSTED = confirmed and applied to on-hand balance; PENDING = awaiting confirmation; REVERSED = corrected by a counter-entry; VOIDED = cancelled before posting; ERROR = failed validation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'The precise real-world date and time when the stock movement event occurred (e.g., POS scan time, receiving dock timestamp, cycle count completion time). This is the principal business event time, distinct from system audit timestamps.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the stock movement event driving this ledger entry. RECEIPT = inbound from supplier or DC; SALE = Point of Sale (POS) depletion; TRANSFER_IN/OUT = inter-location movement; ADJUSTMENT = cycle count correction; RETURN = customer or Return to Vendor (RTV); WRITE_OFF = shrinkage or dead stock removal. [ENUM-REF-CANDIDATE: RECEIPT|SALE|TRANSFER_IN|TRANSFER_OUT|ADJUSTMENT|RETURN|WRITE_OFF|DSD_RECEIPT|MARKDOWN_WRITE_DOWN|CYCLE_COUNT — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Retail Price' ;
    rdfs:comment 'The retail selling price per unit at the time of the transaction. Used for inventory valuation under the retail inventory method and for calculating gross margin. Supports Average Unit Retail (AUR) analytics and sell-through rate calculations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'The inventory costing method applied to this stock movement for financial valuation purposes. FIFO = First In First Out; WAC = Weighted Average Cost; RETAIL_METHOD = retail inventory method; LIFO = Last In First Out (where permitted); SPECIFIC_ID = specific identification for high-value items.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmfFlag rdf:type rdf:Property ;
    rdfs:label 'Vmf Flag' ;
    rdfs:comment 'Indicates whether this stock movement is part of a Vendor Managed Inventory (VMI) arrangement, where the supplier is responsible for maintaining stock levels. True = VMI-managed transaction. Impacts replenishment ownership and supplier performance tracking.' ;
    rdfs:domain ind:StockLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address of the inventory node facility. Used for carrier routing, last-mile delivery coordination, and regulatory filings.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address detail (suite, dock number, building identifier) for the inventory node facility.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City in which the inventory node is located. Used for geographic reporting, tax jurisdiction assignment, and carrier zone mapping.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Calendar date on which the inventory node was permanently closed or decommissioned. Null for active nodes. Used for historical inventory reporting and asset disposal tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cycleCountFrequency rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency' ;
    rdfs:comment 'Scheduled frequency at which physical inventory cycle counts are conducted at this node. Drives WMS task scheduling and shrinkage monitoring cadence.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:districtCode rdf:type rdf:Property ;
    rdfs:label 'District Code' ;
    rdfs:comment 'Internal district code within a region, used for field management span-of-control, district-level KPI reporting, and workforce scheduling via Workday HCM.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorCount rdf:type rdf:Property ;
    rdfs:label 'Dock Door Count' ;
    rdfs:comment 'Number of inbound/outbound dock doors at the node. Determines receiving throughput capacity, inbound appointment scheduling windows, and cross-docking feasibility in Manhattan Associates WMS.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formatCode rdf:type rdf:Property ;
    rdfs:label 'Format Code' ;
    rdfs:comment 'Retail format identifier assigned to the node (e.g., \'HYPERMARKET\', \'DISCOUNT\', \'DEPT_STORE\', \'ECOMM_FC\'). Drives assortment breadth/depth rules in ORMS and planogram (POG) assignments.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gln rdf:type rdf:Property ;
    rdfs:label 'Gln' ;
    rdfs:comment 'GS1-issued 13-digit Global Location Number uniquely identifying this node in the global supply chain. Used in EDI transactions (ASC X12 / EDIFACT), RFID-based receiving, and supplier communications.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDropShipOrigin rdf:type rdf:Property ;
    rdfs:label 'Is Drop Ship Origin' ;
    rdfs:comment 'Indicates whether this node acts as a drop-ship origin point where a vendor ships directly to the end customer on behalf of the retailer, bypassing DC inventory.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRfidEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Rfid Enabled' ;
    rdfs:comment 'Indicates whether the node is equipped with RFID infrastructure for real-time inventory tracking, cycle count automation, and shrinkage reduction.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVmiEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Vmi Enabled' ;
    rdfs:comment 'Indicates whether this node participates in a Vendor Managed Inventory (VMI) program where the supplier is responsible for maintaining stock levels.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'WGS-84 decimal latitude coordinate of the node. Enables geospatial proximity analysis for BOPIS radius calculations, last-mile routing optimization, and store clustering.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'WGS-84 decimal longitude coordinate of the node. Used alongside latitude for geospatial routing, catchment area analysis, and omnichannel fulfillment optimization.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Name of the store manager, DC operations manager, or facility lead responsible for this inventory node. Used for escalation routing, audit accountability, and Workday HCM workforce reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxSkuCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Sku Capacity' ;
    rdfs:comment 'Maximum number of distinct SKUs (Stock Keeping Units) the node can actively stock based on shelf slots, bin locations, and planogram (POG) configuration. Used in assortment planning and OTB (Open to Buy) calculations.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the node as maintained in SAP S/4HANA WM and Oracle Retail Merchandising System (ORMS). Used in EDI transactions, purchase orders, and replenishment plans to reference the location. Serves as the BUSINESS_IDENTIFIER (MASTER_RESOURCE canonical category).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Human-readable display name of the inventory node (e.g., \'Chicago Midway DC\', \'Store #0421 – Oak Park\'). Used in operational reports, planograms, and WMS screens. Serves as the IDENTITY_LABEL (MASTER_RESOURCE canonical category).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Calendar date on which the inventory node became operationally active and began receiving or fulfilling inventory. Used for comp sales (SSS) eligibility determination and new-store ramp analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current lifecycle state of the inventory node. Controls whether the node is eligible to receive stock, fulfill orders, or appear in replenishment plans. Serves as the LIFECYCLE_STATUS (MASTER_RESOURCE canonical category).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Legal ownership or operating arrangement for the node facility. Drives lease accounting under FASB ASC 842, asset capitalization rules, and P&L cost allocation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary operational phone number for the inventory node facility. Used for carrier coordination, inbound appointment confirmation, and emergency contact.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the inventory node. Used for carrier zone determination, last-mile delivery routing, and geographic market analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDcNodeCode rdf:type rdf:Property ;
    rdfs:label 'Primary Dc Node Code' ;
    rdfs:comment 'Node code of the primary Distribution Center (DC) that replenishes this node. Used in replenishment routing, inbound appointment scheduling, and supply chain network optimization.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Replenishment Lead Time Days' ;
    rdfs:comment 'Standard number of days from replenishment order placement to stock receipt at this node. Used by Blue Yonder Demand Planning to calculate reorder points, weeks of supply (WOS), and safety stock levels.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockDays rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Days' ;
    rdfs:comment 'Minimum days of supply maintained as safety stock buffer at this node to protect against demand variability and supply disruptions. Feeds Blue Yonder replenishment planning and WOS calculations.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sellingAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Selling Area Sqft' ;
    rdfs:comment 'Net selling floor area in square feet, excluding back-of-house, receiving docks, and storage. Used for sales-per-square-foot KPI, planogram space allocation, and GMROI analysis.' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'ISO 3166-2 state or province code for the node location. Drives sales tax rules, labor law compliance, and regional reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Secondary classification providing finer granularity within node_type (e.g., hypermarket, department_store, discount_outlet, cross_dock_dc, ambient_dc, cold_chain_dc, ship_from_store_hub). [ENUM-REF-CANDIDATE: hypermarket|department_store|discount_outlet|cross_dock_dc|ambient_dc|cold_chain_dc|ship_from_store_hub|ecommerce_fc — promote to reference product]' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Storage temperature classification for the node. Governs which SKU categories (grocery, frozen, pharma) can be stocked and drives cold-chain compliance requirements under FDA food safety regulations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalStorageCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Total Storage Capacity Sqft' ;
    rdfs:comment 'Total physical storage area of the node measured in square feet. Used for capacity planning, space utilization analysis, and GMROI calculations. Serves as the MEASUREMENT_OR_VALUE (MASTER_RESOURCE canonical category).' ;
    rdfs:domain ind:InventoryNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Id' ;
    rdfs:comment 'Unique surrogate identifier for the replenishment order record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReplenishmentOrder .

ind:destinationNodeInventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Node Inventory Node Id' ;
    rdfs:comment 'Reference to the receiving fulfillment node (store, DC, or MFC) where replenished inventory will be delivered. Drives last-mile delivery routing and receiving dock scheduling.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:leadTimeAgreementId rdf:type rdf:Property ;
    rdfs:label 'Lead Time Agreement Id' ;
    rdfs:comment 'Foreign key linking to supplier.lead_time_agreement. Business justification: replenishment_order.lead_time_days is a denormalization of lead_time_agreement. The governing SLA agreement must be referenced for on-time delivery tracking, chargeback triggering, and vendor scorecar' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeadTimeAgreement .

ind:otbBudgetId rdf:type rdf:Property ;
    rdfs:label 'Otb Budget Id' ;
    rdfs:comment 'Foreign key linking to merchandising.otb_budget. Business justification: OTB consumption tracking: replenishment orders consume Open-to-Buy budget. Retail buyers need visibility into how auto-replenishment orders consume OTB vs. discretionary buying orders — a standard ret' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OtbBudget .

ind:primaryReplenishmentInventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Replenishment Inventory Node Id' ;
    rdfs:comment 'Reference to the originating fulfillment node (Distribution Center, Micro-Fulfillment Center, or supplier location) from which inventory will be shipped. Supports omnichannel inventory routing logic.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:approvedQuantity rdf:type rdf:Property ;
    rdfs:label 'Approved Quantity' ;
    rdfs:comment 'The quantity confirmed and approved for fulfillment after supplier acceptance, MOQ compliance checks, and buyer review. May differ from ordered_quantity due to supplier constraints or buyer adjustments.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyerNotes rdf:type rdf:Property ;
    rdfs:label 'Buyer Notes' ;
    rdfs:comment 'Free-text notes entered by the merchandise buyer or replenishment analyst providing context for manual overrides, special handling instructions, or supplier communication details for this replenishment order.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'The business reason for cancelling the replenishment order. Overstock = destination node already has sufficient inventory; supplier_oos = supplier cannot fulfill; price_discrepancy = cost mismatch; duplicate_order = order already exists; demand_change = forecast revision eliminated need. Nullable for non-cancelled orders.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'The date and time the replenishment order was cancelled, if applicable. Nullable for active or completed orders. Used for supplier chargeback processing and demand planning feedback loops.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfillmentChannel rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Channel' ;
    rdfs:comment 'The physical supply chain channel through which this replenishment order will be fulfilled. dc_to_store = Distribution Center to store; supplier_to_store = Direct Store Delivery (DSD); supplier_to_dc = inbound to DC; cross_dock = Cross-Docking without DC storage; dsd = Direct Store Delivery; drop_ship = vendor ships directly to end customer. [ENUM-REF-CANDIDATE: dc_to_store|supplier_to_store|supplier_to_dc|cross_dock|dsd|drop_ship — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmergency rdf:type rdf:Property ;
    rdfs:label 'Is Emergency' ;
    rdfs:comment 'Indicates whether this replenishment order was flagged as an emergency order due to an imminent or active out-of-stock situation. Emergency orders bypass standard lead time and approval workflows. True = emergency; False = standard.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally-known business identifier for the replenishment order, sourced from Blue Yonder Demand Planning or SAP S/4HANA MM module. Used for cross-system traceability and supplier communication via EDI.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle state of the replenishment order. Tracks progression from draft creation through approval, shipment, receipt at destination node, and closure. Cancelled indicates the order was voided before fulfillment. [ENUM-REF-CANDIDATE: draft|submitted|approved|in_transit|received|partially_received|cancelled|closed — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of how the replenishment order was triggered. Auto-replenishment is system-generated based on reorder policy thresholds; manual is buyer-initiated; VMI (Vendor Managed Inventory) is supplier-driven; emergency covers urgent out-of-stock situations; cross_dock bypasses DC storage; drop_ship routes directly from vendor to destination. [ENUM-REF-CANDIDATE: auto_replenishment|manual|vmi|emergency|cross_dock|drop_ship — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'The quantity of the SKU originally requested in the replenishment order, expressed in the SKU\'s base unit of measure (e.g., each, case, pallet). This is the raw demand signal before supplier approval or MOQ adjustment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority assigned to this replenishment order, used to sequence fulfillment and allocate DC resources. Critical = imminent out-of-stock risk; high = elevated demand or promotional support; standard = routine replenishment; low = opportunistic or pre-build.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'The actual quantity of the SKU physically received and confirmed at the destination node. Used to calculate fill rate and identify short shipments. Populated upon goods receipt in Manhattan Associates WMS or SAP S/4HANA WM.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemOrderRef rdf:type rdf:Property ;
    rdfs:label 'Source System Order Ref' ;
    rdfs:comment 'The native order identifier from the originating source system (e.g., SAP MM document number, Blue Yonder order ID, ORMS order number). Enables reverse lookup and reconciliation with the system of record.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOrderCost rdf:type rdf:Property ;
    rdfs:label 'Total Order Cost' ;
    rdfs:comment 'The total cost of the replenishment order calculated as approved_quantity multiplied by unit_cost. Represents the financial commitment for this replenishment event. Used for Open to Buy (OTB) budget tracking and P&L reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCountId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Id' ;
    rdfs:comment 'Unique system-generated identifier for each cycle count event record at the SKU-location level.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Id' ;
    rdfs:comment 'Reference to the inventory adjustment record created as a result of this cycle count variance exceeding the tolerance threshold. Links the count event to its financial reconciliation record.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'ABC classification of the SKU at the time of the cycle count, indicating inventory value and velocity tier. A = high-value/high-velocity; B = medium; C = low-value/low-velocity; D = dead stock. Drives count frequency prioritization.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentGenerated rdf:type rdf:Property ;
    rdfs:label 'Adjustment Generated' ;
    rdfs:comment 'Indicates whether an inventory_adjustment record has been generated from this cycle count variance. When True, the variance has been posted to the inventory ledger for reconciliation.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Count Device Code' ;
    rdfs:comment 'Identifier of the handheld scanner, mobile device, or RFID reader used to perform the physical count. Supports device-level audit trail and equipment calibration tracking.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count End Timestamp' ;
    rdfs:comment 'The precise date and time when the physical counting activity was completed and the count was submitted by the assigned counter.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countFrequency rdf:type rdf:Property ;
    rdfs:label 'Count Frequency' ;
    rdfs:comment 'The scheduled counting frequency for this SKU-location combination, typically driven by ABC classification or velocity. High-velocity A-items are counted more frequently than slow-moving C-items.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countNotes rdf:type rdf:Property ;
    rdfs:label 'Count Notes' ;
    rdfs:comment 'Free-text field for the counter or supervisor to record observations, exceptions, or explanations related to the cycle count result (e.g., damaged packaging, items in transit, display stock not included).' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countNumber rdf:type rdf:Property ;
    rdfs:label 'Count Number' ;
    rdfs:comment 'Externally-known business reference number assigned to the cycle count event, used for cross-system tracking and audit trail. Typically generated by the WMS (e.g., Manhattan Associates) or SAP WM module.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Count Start Timestamp' ;
    rdfs:comment 'The precise date and time when the physical counting activity was initiated by the assigned counter. Used for cycle time analysis and labor tracking.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current workflow state of the cycle count event. \'scheduled\' = count is planned but not started; \'in_progress\' = counting is underway; \'completed\' = physical count recorded; \'reconciled\' = variance reviewed and inventory adjustment posted; \'cancelled\' = count was voided.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Classification of the cycle count method. \'scheduled\' = routine planned count; \'ad_hoc\' = unplanned triggered count; \'blind\' = counter does not see system quantity; \'directed\' = WMS-directed count task; \'rfid_assisted\' = count performed using Radio Frequency Identification (RFID) technology.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'The actual physical quantity of the SKU observed and recorded by the counter during the cycle count. This is the primary measured outcome of the count event.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planogramLocation rdf:type rdf:Property ;
    rdfs:label 'Planogram Location' ;
    rdfs:comment 'The planogram (POG) shelf position or fixture reference for the SKU at the store location, used to direct the counter to the correct physical location during in-store cycle counts.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountNumber rdf:type rdf:Property ;
    rdfs:label 'Recount Number' ;
    rdfs:comment 'Sequential count of how many times this SKU-location has been recounted within the same cycle count event. First count = 1; first recount = 2; etc. Supports escalation workflows when repeated recounts still show variance.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recountRequired rdf:type rdf:Property ;
    rdfs:label 'Recount Required' ;
    rdfs:comment 'Indicates whether a recount of this SKU-location is required because the variance exceeded the tolerance threshold or the count was flagged for discrepancy. When True, a follow-up count must be performed before reconciliation.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The calendar date on which the cycle count was planned to be performed, as set in the WMS count schedule.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shrinkageCategory rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Category' ;
    rdfs:comment 'Classification of the root cause of inventory shrinkage identified through this cycle count. Populated during the reconciliation phase when a negative variance is confirmed. Supports shrinkage investigation and loss prevention analytics.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageBin rdf:type rdf:Property ;
    rdfs:label 'Storage Bin' ;
    rdfs:comment 'The specific warehouse storage bin, shelf, or slot location within the inventory node where the SKU is physically stored and counted. Granular location identifier used by the WMS for directed counting.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageZone rdf:type rdf:Property ;
    rdfs:label 'Storage Zone' ;
    rdfs:comment 'The logical zone or area within the inventory node (e.g., ambient, refrigerated, frozen, high-value, bulk) where the SKU is stored. Used for zone-based cycle count scheduling and analysis.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemQuantity rdf:type rdf:Property ;
    rdfs:label 'System Quantity' ;
    rdfs:comment 'The inventory quantity recorded in the Warehouse Management System (WMS) or ERP at the exact time the cycle count was initiated. This is the \'book\' quantity against which the physical count is compared.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerReason rdf:type rdf:Property ;
    rdfs:label 'Trigger Reason' ;
    rdfs:comment 'Business reason that initiated this cycle count. Supports shrinkage investigation and root cause analysis. [ENUM-REF-CANDIDATE: routine|negative_inventory|shrinkage_alert|receiving_discrepancy|customer_complaint|audit_request|rfid_discrepancy — promote to reference product]' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceCost rdf:type rdf:Property ;
    rdfs:label 'Variance Cost' ;
    rdfs:comment 'The monetary value of the inventory variance, calculated as variance_quantity multiplied by the unit cost at time of count. Expressed in the local operating currency. Used for Cost of Goods Sold (COGS) impact assessment and financial reporting.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'The variance quantity expressed as a percentage of the system on-hand quantity, calculated as (variance_quantity / system_quantity) * 100. Used to assess inventory accuracy and trigger shrinkage investigations when thresholds are exceeded.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'The difference between the physically counted quantity and the system on-hand quantity (counted_quantity minus system_quantity). A negative value indicates shrinkage or loss; a positive value indicates an overcount or unrecorded receipt.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Tolerance Pct' ;
    rdfs:comment 'The maximum acceptable variance percentage for this SKU-location before a recount or inventory adjustment is triggered. Variances exceeding this threshold generate inventory_adjustment records for reconciliation.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationId rdf:type rdf:Property ;
    rdfs:label 'Cancellation Id' ;
    rdfs:comment 'Foreign key linking to order.cancellation. Business justification: Cancellation-driven inventory reinstatement audit: when an order is cancelled, inventory is released and an adjustment records the reinstatement. Linking adjustment to cancellation supports the invent' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cancellation .

ind:reversalOfAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Reversal Of Adjustment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original adjustment record that this record is reversing. Populated only for reversal entries to maintain a complete audit trail of corrections. Nullable for original (non-reversal) adjustments.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:serviceCaseId rdf:type rdf:Property ;
    rdfs:label 'Service Case Id' ;
    rdfs:comment 'Foreign key linking to customer.service_case. Business justification: Customer complaint, recall, or return dispute resolution drives inventory adjustments in retail. The \'customer-complaint-driven inventory adjustment\' process requires traceability from service case to' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCase .

ind:adjustedQuantity rdf:type rdf:Property ;
    rdfs:label 'Adjusted Quantity' ;
    rdfs:comment 'The net quantity change applied to on-hand inventory for the SKU at the specified location. Negative values represent inventory reductions (shrinkage, damage, write-offs); positive values represent inventory additions (found stock, receiving corrections). Expressed in the SKU\'s unit of measure.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for the adjustment transaction. Used in audit trails, loss prevention case references, and cross-system reconciliation with SAP S/4HANA and ORMS. Format: ADJ- followed by 10 digits.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current workflow lifecycle state of the adjustment record. Controls whether the adjustment has been applied to the stock ledger. \'posted\' indicates the adjustment has updated on-hand quantities; \'reversed\' indicates a correcting entry was made.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Timestamp' ;
    rdfs:comment 'The principal real-world date and time when the inventory adjustment event occurred (e.g., when shrinkage was detected, when a cycle count discrepancy was identified, when damage was observed). Distinct from system audit timestamps. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:costImpact rdf:type rdf:Property ;
    rdfs:label 'Cost Impact' ;
    rdfs:comment 'Total financial impact of the inventory adjustment on Cost of Goods Sold (COGS), calculated as adjusted_quantity multiplied by unit_cost. Negative values represent write-downs (losses); positive values represent write-ups (gains). Posted to the general ledger via SAP FI/CO integration.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'The method by which the inventory discrepancy or adjustment need was identified. Supports shrinkage root-cause analysis and RFID (Radio Frequency Identification) program effectiveness measurement. [ENUM-REF-CANDIDATE: cycle_count|physical_inventory|rfid_scan|pos_exception|receiving_audit|system_alert|manual_observation|loss_prevention_investigation — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isShrinkage rdf:type rdf:Property ;
    rdfs:label 'Is Shrinkage' ;
    rdfs:comment 'Boolean flag indicating whether this adjustment represents a shrinkage event (inventory loss due to theft, damage, administrative error, or vendor fraud). Used to filter and aggregate shrinkage metrics for loss prevention reporting and GMROI (Gross Margin Return on Investment) analysis.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSystemGenerated rdf:type rdf:Property ;
    rdfs:label 'Is System Generated' ;
    rdfs:comment 'Boolean flag indicating whether the adjustment was automatically generated by a system process (e.g., Blue Yonder replenishment system, RFID reconciliation engine, WMS cycle count automation) rather than manually entered by a user.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the inventory node type where the adjustment occurred. Distinguishes between store-level adjustments, Distribution Center (DC) adjustments, Micro-Fulfillment Center (MFC) adjustments, and dark store adjustments for segmented shrinkage and variance reporting.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lpCaseReference rdf:type rdf:Property ;
    rdfs:label 'Lp Case Reference' ;
    rdfs:comment 'Reference number linking this inventory adjustment to an active or closed Loss Prevention (LP) investigation case (e.g., shoplifting incident, employee theft case). Nullable — only populated when the adjustment is associated with a formal LP case in Salesforce Service Cloud or a dedicated LP system.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAfterAdjustment rdf:type rdf:Property ;
    rdfs:label 'Quantity After Adjustment' ;
    rdfs:comment 'The on-hand inventory quantity for the SKU at the location immediately after this adjustment is applied. Derived at posting time and stored for audit trail and stock ledger reconciliation. Expressed in the SKU\'s unit of measure.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityBeforeAdjustment rdf:type rdf:Property ;
    rdfs:label 'Quantity Before Adjustment' ;
    rdfs:comment 'The on-hand inventory quantity for the SKU at the location immediately prior to this adjustment being applied. Captured at the time of adjustment for audit trail completeness and variance analysis. Expressed in the SKU\'s unit of measure.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCategory rdf:type rdf:Property ;
    rdfs:label 'Reason Category' ;
    rdfs:comment 'High-level classification of why the inventory adjustment is being made. Drives reporting buckets for shrinkage monitoring, COGS (Cost of Goods Sold) impact analysis, and loss prevention dashboards. [ENUM-REF-CANDIDATE: shrinkage|damage|cycle_count_correction|receiving_variance|expiry_write_off|rtv|admin_correction|found_stock — promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonSubCategory rdf:type rdf:Property ;
    rdfs:label 'Reason Sub Category' ;
    rdfs:comment 'Granular sub-classification within the reason category providing specific cause detail. Examples for shrinkage: shoplifting, employee theft, administrative error, vendor fraud. Examples for damage: in-transit damage, handling damage, shelf damage. Feeds loss prevention case analysis and shrinkage root-cause reporting. [ENUM-REF-CANDIDATE: shoplifting|employee_theft|admin_error|vendor_fraud|in_transit_damage|handling_damage|shelf_damage|expired|recalled|mis-ship — promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Boolean flag indicating whether this inventory adjustment is associated with a product recall event initiated by the CPSC, FDA, or the retailer. Enables rapid identification and financial quantification of recall-related inventory write-offs.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidTagCount rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Count' ;
    rdfs:comment 'Number of RFID (Radio Frequency Identification) tags scanned during the detection event that triggered this adjustment. Populated only for RFID-based detection methods. Supports RFID program accuracy measurement and tag read-rate analysis.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Source Document Number' ;
    rdfs:comment 'The reference number of the originating source document (e.g., cycle count ID, RTV authorization number, receiving document number, damage report ID). Enables cross-system traceability and audit trail linkage.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Source Document Type' ;
    rdfs:comment 'The type of source business document that triggered or supports this inventory adjustment. Provides traceability back to the originating business process (e.g., cycle count sheet, Return to Vendor (RTV) authorization, receiving document). [ENUM-REF-CANDIDATE: cycle_count|physical_inventory|rtv_authorization|receiving_document|damage_report|expiry_report|pos_exception_report — promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTransferId rdf:type rdf:Property ;
    rdfs:label 'Stock Transfer Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for each inter-node stock transfer record in the inventory management system.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockTransfer .

ind:primaryStockInventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Inventory Node Id' ;
    rdfs:comment 'Identifier of the originating inventory node (store, DC, MFC, or vendor location) from which the stock transfer is dispatched. Supports network balancing and omnichannel fulfillment analytics.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:actualReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Date' ;
    rdfs:comment 'Calendar date on which the stock transfer was physically received and confirmed at the destination node. Compared against expected_receipt_date to measure carrier and DC performance against SLA targets.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:destinationNodeType rdf:type rdf:Property ;
    rdfs:label 'Destination Node Type' ;
    rdfs:comment 'Classification of the receiving inventory node. STORE: retail store; DC: distribution center; MFC: micro-fulfillment center; VENDOR: supplier location for RTV; DARK_STORE: fulfillment-only location.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Expected Receipt Date' ;
    rdfs:comment 'Planned calendar date by which the stock transfer is expected to arrive at the destination node. Used for replenishment planning, weeks of supply (WOS) calculations, and SLA compliance monitoring.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inventoryCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Inventory Cost Per Unit' ;
    rdfs:comment 'Cost of Goods Sold (COGS) value per unit for the transferred SKU at time of transfer, used for inventory valuation, GMROI calculations, and financial reporting. Sourced from SAP S/4HANA FI/CO standard cost or moving average cost.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isShipFromStore rdf:type rdf:Property ;
    rdfs:label 'Is Ship From Store' ;
    rdfs:comment 'Flag indicating whether this stock transfer is part of a ship-from-store (SFS) omnichannel fulfillment flow, where a retail store acts as a fulfillment node dispatching inventory to satisfy an e-commerce or BOPIS order.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVendorManaged rdf:type rdf:Property ;
    rdfs:label 'Is Vendor Managed' ;
    rdfs:comment 'Flag indicating whether this stock transfer is part of a Vendor Managed Inventory (VMI) program, where the supplier initiates and manages the replenishment transfer rather than the retailer\'s internal planning team.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidEnabled rdf:type rdf:Property ;
    rdfs:label 'Rfid Enabled' ;
    rdfs:comment 'Flag indicating whether this stock transfer was tracked using RFID (Radio Frequency Identification) technology for real-time inventory visibility during transit. Supports RFID-based inventory accuracy programs.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Date' ;
    rdfs:comment 'Calendar date on which the stock transfer was physically dispatched from the source node. Used for lead time calculation, carrier SLA tracking, and inventory in-transit reporting.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceNodeType rdf:type rdf:Property ;
    rdfs:label 'Source Node Type' ;
    rdfs:comment 'Classification of the originating inventory node. STORE: retail store; DC: distribution center; MFC: micro-fulfillment center; VENDOR: supplier location for RTV or DSD; DARK_STORE: fulfillment-only location.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-assigned shipment tracking number for the stock transfer, enabling real-time in-transit visibility and last-mile delivery monitoring. Used for exception management and carrier SLA validation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferCost rdf:type rdf:Property ;
    rdfs:label 'Transfer Cost' ;
    rdfs:comment 'Total logistics cost incurred for executing this stock transfer, including carrier freight charges, handling fees, and any 3PL surcharges. Used for inventory valuation (COGS), P&L allocation, and supply chain cost optimization.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Number' ;
    rdfs:comment 'Externally-known business reference number for the stock transfer, used for tracking and communication across supply chain partners, carriers, and store operations. Sourced from SAP S/4HANA MM transfer order numbering.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferQuantity rdf:type rdf:Property ;
    rdfs:label 'Transfer Quantity' ;
    rdfs:comment 'Number of units of the SKU authorized and dispatched in this stock transfer. Represents the planned transfer quantity as recorded at time of transfer creation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferReasonCode rdf:type rdf:Property ;
    rdfs:label 'Transfer Reason Code' ;
    rdfs:comment 'Business reason code explaining why the stock transfer was initiated. REPLENISHMENT: routine inventory restocking; NETWORK_BALANCE: lateral balancing to address overstock/understock; RTV: return to vendor; RECALL: product safety recall per CPSC; DAMAGE_RETURN: return of damaged goods; OMNICHANNEL: ship-from-store or BOPIS fulfillment support.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle state of the stock transfer. DRAFT: initiated but not yet dispatched; IN_TRANSIT: shipment dispatched from source node; RECEIVED: confirmed receipt at destination node; CANCELLED: transfer voided before completion; EXCEPTION: discrepancy or damage reported during transit.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the inter-node inventory movement. DC_TO_STORE: distribution center replenishment to store; STORE_TO_STORE: lateral balancing between stores; STORE_TO_DC: reverse logistics or consolidation; CROSS_DOCK: direct transfer without storage per cross-docking (DSD) model; RTV: Return to Vendor; MFC_TO_STORE: micro-fulfillment center to store for omnichannel fulfillment (ship-from-store).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Reason code explaining the cause of any quantity variance between dispatched and received units. Used for shrinkage root cause analysis, carrier chargeback (RMA) processing, and inventory reconciliation.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for each goods receipt record in the inventory domain. Primary key for the goods_receipt data product.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ap_invoice. Business justification: Three-way match (PO + GR + AP Invoice) is a core retail AP process. Linking goods_receipt to ap_invoice enables payment authorization, invoice-to-receipt reconciliation, and chargeback processing. Ret' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApInvoice .

ind:buyingOrderId rdf:type rdf:Property ;
    rdfs:label 'Buying Order Id' ;
    rdfs:comment 'Foreign key linking to merchandising.buying_order. Business justification: Receiving discrepancy reporting against the merchandising buy plan: retail operations match goods receipts to the buying_order to validate received quantities vs. ordered quantities at the merchandisi' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BuyingOrder .

ind:acceptedQty rdf:type rdf:Property ;
    rdfs:label 'Accepted Qty' ;
    rdfs:comment 'Quantity of units accepted into inventory after quality inspection. Excludes rejected, damaged, or wrong-SKU units. This is the quantity inducted into on-hand inventory and used for COGS valuation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackEligible rdf:type rdf:Property ;
    rdfs:label 'Chargeback Eligible' ;
    rdfs:comment 'Indicates whether this goods receipt record has identified discrepancies that qualify for a vendor compliance chargeback. True = chargeback may be issued to supplier; False = no chargeback applicable. Drives the vendor compliance chargeback workflow.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Resolution Status' ;
    rdfs:comment 'Current status of the discrepancy resolution workflow. \'pending\' = discrepancy logged, not yet actioned; \'under_review\' = being investigated with supplier; \'resolved\' = discrepancy closed; \'chargeback_issued\' = vendor compliance chargeback raised; \'waived\' = discrepancy accepted without penalty.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyType rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Type' ;
    rdfs:comment 'Classification of the primary discrepancy identified during receiving. \'shortage\' = fewer units than expected; \'overage\' = more units than expected; \'wrong_sku\' = incorrect item received; \'damage\' = merchandise physically damaged; \'expired\' = past sell-by or use-by date; \'none\' = no discrepancy. Drives chargeback and resolution workflows.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedQty rdf:type rdf:Property ;
    rdfs:label 'Expected Qty' ;
    rdfs:comment 'Quantity of units expected at the receiving node based on the ASN or replenishment plan. May differ from ordered quantity due to partial shipments or split deliveries. Used for receiving dock planning and discrepancy detection.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'Date on which the quality inspection of received merchandise was completed. Used for compliance reporting, CPSC/FDA audit trails, and receiving cycle time analysis.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overageQty rdf:type rdf:Property ;
    rdfs:label 'Overage Qty' ;
    rdfs:comment 'Quantity of units received in excess of the ASN or PO expectation (received_qty minus expected_qty when positive). Overages require disposition decisions and may trigger vendor compliance chargebacks.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Status of the quality inspection performed on received merchandise. \'not_required\' = inspection waived per supplier agreement; \'pending\' = awaiting inspection; \'passed\' = all units meet quality standards; \'failed\' = units do not meet standards; \'partial_pass\' = some units accepted, some rejected. Drives accepted/rejected quantity split.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Calendar date on which the physical goods receipt was posted. Used for inventory valuation, vendor compliance reporting, and lead time analysis. Aligns with SAP Posting Date (BUDAT) in the MM module.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptMethod rdf:type rdf:Property ;
    rdfs:label 'Receipt Method' ;
    rdfs:comment 'Method by which merchandise was physically received. \'dsd\' = Direct Store Delivery from supplier; \'dc_to_store\' = replenishment from Distribution Center; \'cross_dock\' = direct transfer without storage; \'drop_ship\' = vendor direct-to-customer; \'transfer_order\' = inter-node stock transfer. Drives receiving workflow and inventory valuation logic.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptNotes rdf:type rdf:Property ;
    rdfs:label 'Receipt Notes' ;
    rdfs:comment 'Free-text notes entered by the receiving associate documenting special conditions, discrepancy details, handling instructions, or other observations at the time of receipt. Supports discrepancy investigation and vendor communication.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Externally-known business identifier for the goods receipt document, typically generated by the WMS or ERP upon physical receipt confirmation. Maps to SAP Material Document Number (MBLNR) or Manhattan WMS Receipt Number.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle state of the goods receipt workflow. \'draft\' indicates initiated but not confirmed; \'open\' indicates awaiting physical receipt; \'in_progress\' indicates receiving underway; \'completed\' indicates fully processed and inventory inducted; \'cancelled\' indicates voided; \'on_hold\' indicates paused pending resolution. [ENUM-REF-CANDIDATE: draft|open|in_progress|completed|cancelled|on_hold — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'The principal real-world event timestamp recording when the physical merchandise was received and confirmed at the receiving node (DC, store, or MFC). Distinct from system audit timestamps. Maps to SAP Posting Date/Time in MIGO.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivingNodeType rdf:type rdf:Property ;
    rdfs:label 'Receiving Node Type' ;
    rdfs:comment 'Classification of the physical location type where goods were received. \'dc\' = Distribution Center; \'store\' = retail store; \'mfc\' = Micro-Fulfillment Center; \'dark_store\' = fulfillment-only location. Determines applicable receiving workflows and inventory induction rules.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedQty rdf:type rdf:Property ;
    rdfs:label 'Rejected Qty' ;
    rdfs:comment 'Quantity of units rejected during quality inspection and not inducted into inventory. Drives Return to Vendor (RTV) processing, vendor compliance chargebacks, and RMA initiation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfidVerified rdf:type rdf:Property ;
    rdfs:label 'Rfid Verified' ;
    rdfs:comment 'Indicates whether the received merchandise was verified using RFID (Radio Frequency Identification) scanning during the receiving process. True = RFID scan confirmed; False = manual or barcode-only verification. Supports inventory accuracy at point of induction.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rtvInitiated rdf:type rdf:Property ;
    rdfs:label 'Rtv Initiated' ;
    rdfs:comment 'Indicates whether a Return to Vendor (RTV) process has been initiated for rejected units from this goods receipt. True = RTV in progress; False = no RTV initiated. Supports reverse logistics and vendor debit memo processing.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortageQty rdf:type rdf:Property ;
    rdfs:label 'Shortage Qty' ;
    rdfs:comment 'Quantity of units short-shipped relative to the ASN or PO expectation (expected_qty minus received_qty when negative). Used for vendor compliance chargeback calculation and fill rate reporting.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReceiptCost rdf:type rdf:Property ;
    rdfs:label 'Total Receipt Cost' ;
    rdfs:comment 'Total cost of accepted merchandise received (accepted_qty × unit_cost). Used for inventory valuation, COGS posting, and financial reconciliation. Classified as confidential due to commercial sensitivity.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentLineId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Line Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.fulfillment_line. Business justification: Reservations are SKU-level allocations matching fulfillment line granularity. Retail WMS systems reserve specific SKU quantities for specific order lines during wave planning and pick task generation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentLine .

ind:authorizingDepartment rdf:type rdf:Property ;
    rdfs:label 'Authorizing Department' ;
    rdfs:comment 'Name or code of the business department that authorized the hold (e.g., Quality Assurance, Legal, Compliance, Store Operations, E-Commerce Fulfillment). Supports departmental accountability reporting and hold resolution workflows.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Case Reference Number' ;
    rdfs:comment 'Reference to the service case, quality investigation, legal matter, or regulatory recall case that authorized a hard hold. Populated for quality_hold, legal_hold, regulatory_recall, and damage_hold encumbrance types. Links to Salesforce Service Cloud case management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encumbranceType rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Type' ;
    rdfs:comment 'Classifies the nature of the inventory encumbrance. Soft allocations (e.g., BOPIS reservation, ship-from-store allocation, e-commerce hold) are temporary and customer-driven; hard holds (quality hold, regulatory recall, legal hold, damage hold, price investigation) restrict stock from sale pending resolution. [ENUM-REF-CANDIDATE: soft_allocation|hard_hold|quality_hold|regulatory_recall|legal_hold|damage_hold|price_investigation — promote to reference product]' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Retail fiscal period (year and period number, e.g., 2024-P07) during which the reservation was created. Supports financial reporting of encumbered inventory valuation, OTB (Open to Buy) impact analysis, and period-end inventory reconciliation per FASB ASC 330.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'Standardized code identifying the specific business reason for the reservation or hold (e.g., BOPIS_ALLOC, SFS_ALLOC, ECOM_HOLD, QA_FAIL, RECALL_CPSC, LEGAL_HOLD, DMG_INBOUND, PRICE_INVEST). Enables operational reporting and root-cause analysis of inventory encumbrances.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Description' ;
    rdfs:comment 'Free-text narrative describing the specific reason for the inventory hold or reservation, providing operational context beyond the structured hold_reason_code. Required for legal holds and regulatory recalls per compliance documentation standards.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecalled rdf:type rdf:Property ;
    rdfs:label 'Is Recalled' ;
    rdfs:comment 'Indicates whether this reservation was created in response to a regulatory product recall (CPSC, FDA, or other governing body). When true, the hold cannot be released without explicit compliance authorization. Supports mandatory recall reporting and quarantine workflows.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseNotes rdf:type rdf:Property ;
    rdfs:label 'Release Notes' ;
    rdfs:comment 'Free-text field capturing resolution details, disposition instructions, or compliance notes recorded at the time of hold release. Required for regulatory recalls and legal holds to document the resolution rationale for audit purposes.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Approval workflow status for releasing a hard hold. \'pending\' — release request submitted awaiting authorization; \'approved\' — release authorized by responsible department; \'rejected\' — release denied, hold remains active; \'auto_released\' — system-triggered release upon expiry or order fulfillment; \'escalated\' — requires senior authorization.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'Actual date and time when the reservation was released, cancelled, or converted. Null while the reservation is active. Used for hold duration analysis, SLA compliance reporting, and ATP recalculation upon release.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'Externally-visible, human-readable business identifier for the reservation, used in operational communications, order management, and customer-facing references (e.g., BOPIS confirmation codes). Sourced from OMS or WMS upon creation.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationStatus rdf:type rdf:Property ;
    rdfs:label 'Reservation Status' ;
    rdfs:comment 'Current lifecycle state of the inventory reservation. \'active\' — stock is currently encumbered; \'expired\' — reservation lapsed past expiry without fulfillment; \'released\' — hold manually or systematically lifted; \'cancelled\' — reservation voided before fulfillment; \'pending_release\' — awaiting authorization to release; \'converted\' — soft allocation fulfilled and converted to a shipment.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reservation Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone offset) when the inventory encumbrance was created — the principal business event timestamp. For BOPIS/e-commerce holds, this is when the customer completed checkout. For quality/legal holds, this is when the hold was authorized.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Number of units of the SKU encumbered by this reservation. Subtracted from on-hand quantity to derive ATP (Available to Promise) on the stock_position product. Must be positive and not exceed available on-hand at time of reservation creation.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asnId rdf:type rdf:Property ;
    rdfs:label 'Asn Id' ;
    rdfs:comment 'Unique surrogate identifier for the Advance Shipment Notice record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asn .

ind:asnInventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Asn Inventory Node Id' ;
    rdfs:comment 'Reference to the originating inventory node (DC, MFC, store, or supplier facility) from which the shipment was dispatched. Used for inter-node transfer ASNs.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:asnSupplierVendorId rdf:type rdf:Property ;
    rdfs:label 'Asn Supplier Vendor Id' ;
    rdfs:comment 'FK to supplier.vendor' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:asnVendorId rdf:type rdf:Property ;
    rdfs:label 'Asn Vendor Id' ;
    rdfs:comment 'Reference to the supplier or vendor who originated the shipment. Populated when asn_type is \'supplier\' or \'drop_ship\'. Links to the supplier master record in Informatica MDM.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'Date the shipment physically arrived at the destination node dock. Compared against expected_arrival_date to measure carrier on-time delivery performance and lead time actuals.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:asnNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Number' ;
    rdfs:comment 'Externally-known business identifier for the ASN as transmitted by the supplier or DC via EDI 856 or API. Used for cross-system reconciliation and dock scheduling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnStatus rdf:type rdf:Property ;
    rdfs:label 'Asn Status' ;
    rdfs:comment 'Current lifecycle state of the ASN. \'sent\' = transmitted by sender; \'in_transit\' = shipment en route; \'arrived\' = at destination dock; \'receiving\' = active receiving in WMS; \'received\' = fully received; \'discrepant\' = quantity or SKU variance detected; \'cancelled\' = voided prior to receipt. [ENUM-REF-CANDIDATE: sent|in_transit|arrived|receiving|received|discrepant|cancelled — promote to reference product]' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnType rdf:type rdf:Property ;
    rdfs:label 'Asn Type' ;
    rdfs:comment 'Classification of the ASN by origin and fulfillment pattern. \'supplier\' = inbound from vendor; \'dc_transfer\' = inter-DC or DC-to-store transfer; \'cross_dock\' = direct cross-dock flow; \'drop_ship\' = vendor direct-to-customer; \'return_to_dc\' = store or customer return to DC.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Indicates whether a receiving discrepancy (quantity overage, shortage, or SKU mismatch) was detected when comparing the ASN to the actual goods receipt. Triggers discrepancy resolution workflow.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Date' ;
    rdfs:comment 'Scheduled date the shipment is expected to arrive at the destination node. Drives dock door scheduling, labor planning, and replenishment availability projections.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Freight payment responsibility terms for the shipment. \'prepaid\' = supplier pays freight; \'collect\' = receiver pays; \'third_party\' = billed to a third party. Drives accounts payable freight accruals.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receiving Complete Timestamp' ;
    rdfs:comment 'Timestamp when all line items on the ASN were fully received and confirmed in the WMS. Marks the transition from \'receiving\' to \'received\' or \'discrepant\' status.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shipmentMode rdf:type rdf:Property ;
    rdfs:label 'Shipment Mode' ;
    rdfs:comment 'Transportation mode used for the shipment. Drives freight cost benchmarking, carrier selection analytics, and carbon footprint reporting. [ENUM-REF-CANDIDATE: truckload|ltl|parcel|rail|air|ocean|intermodal — promote to reference product]' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCartons rdf:type rdf:Property ;
    rdfs:label 'Total Cartons' ;
    rdfs:comment 'Total number of cartons (cases/boxes) included in the shipment as declared on the ASN. Used for dock receiving verification, pallet count planning, and discrepancy detection.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPallets rdf:type rdf:Property ;
    rdfs:label 'Total Pallets' ;
    rdfs:comment 'Total number of pallets in the shipment as declared on the ASN. Used for dock door capacity planning, unloading labor scheduling, and yard management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnits rdf:type rdf:Property ;
    rdfs:label 'Total Units' ;
    rdfs:comment 'Total number of sellable units across all SKU lines declared on the ASN. Used for pre-receiving inventory projection and receiving discrepancy detection against goods receipt.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Volume M3' ;
    rdfs:comment 'Total cubic volume of the shipment in cubic meters as declared on the ASN. Used for trailer utilization analysis, DC storage capacity planning, and freight density calculations.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Gross weight of the entire shipment in kilograms as declared on the ASN. Used for freight cost calculation, carrier compliance, and dock equipment planning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transmissionMethod rdf:type rdf:Property ;
    rdfs:label 'Transmission Method' ;
    rdfs:comment 'Channel through which the ASN was received. \'edi_856\' = GS1 EDI 856 standard; \'api\' = REST/SOAP API integration; \'manual\' = entered by receiving staff; \'portal\' = supplier self-service portal.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmission Timestamp' ;
    rdfs:comment 'Timestamp when the ASN was transmitted by the supplier or DC via EDI 856 or API. Distinct from created_timestamp; used to measure EDI lead time and supplier advance notice compliance.' ;
    rdfs:domain ind:Asn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualYtdAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Ytd Amount' ;
    rdfs:comment 'Cumulative actual expenses posted to this cost center from the start of the fiscal year to the current reporting period. Sourced from SAP FI/CO actuals. Used for budget variance, EBITDA tracking, and financial close reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to allocate or distribute costs from this cost center to other cost objects (e.g., direct posting, SAP assessment cycle, distribution cycle, activity-based costing). Governs how overhead is spread across stores, DCs, and product categories.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'Total approved annual budget allocated to this cost center for the current fiscal year, expressed in the cost center currency. Used for Open to Buy (OTB) tracking, budget vs. actuals variance analysis, and financial planning.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetFiscalYear rdf:type rdf:Property ;
    rdfs:label 'Budget Fiscal Year' ;
    rdfs:comment 'The fiscal year (four-digit integer, e.g., 2025) to which the annual budget amount applies. Aligns with the SAP fiscal year variant for period-based budget vs. actuals comparison.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'SAP Business Area (GSBER) to which this cost center is assigned. Enables cross-company-code P&L reporting by business segment (e.g., Grocery, Apparel, E-Commerce). Supports FASB ASC 280 segment disclosures.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Commitment Amount' ;
    rdfs:comment 'Total open purchase order and contract commitment amounts encumbered against this cost center\'s budget but not yet invoiced. Supports available budget calculation and OTB management in SAP CO-OM.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'SAP Controlling Area (KOKRS) to which this cost center belongs. The controlling area defines the organizational unit within which cost accounting is performed. All cost centers within a controlling area share the same chart of accounts and fiscal year variant.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'SAP cost center category (KOSAR) that controls which business transactions are allowed for this cost center (e.g., \'A\' for general cost centers, \'E\' for production cost centers). Governs posting rules in FI/CO.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The externally-known alphanumeric code that uniquely identifies the cost center within the controlling area, as defined in SAP S/4HANA CO module (field: KOSTL). Used in P&L reporting, budget allocation, and expense posting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Long-form description of the cost center\'s business purpose, scope of expenses, and organizational context. Corresponds to SAP S/4HANA field LTEXT.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterLevel rdf:type rdf:Property ;
    rdfs:label 'Cost Center Level' ;
    rdfs:comment 'Numeric level of this cost center within the enterprise cost center hierarchy (1 = top/enterprise, higher numbers = more granular). Enables hierarchical roll-up queries for consolidated P&L and EBITDA reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'Human-readable name of the cost center as maintained in SAP S/4HANA (field: KTEXT). Describes the organizational unit, e.g., \'Store 042 - Chicago Loop\', \'DC Atlanta\', \'Corporate Finance\'.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. \'active\' = open for postings; \'locked\' = temporarily blocked for new postings (SAP lock indicator); \'inactive\' = no longer in use; \'pending\' = awaiting activation; \'archived\' = closed and retained for historical reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center by organizational unit type. Drives expense allocation rules, budget templates, and P&L reporting hierarchies. [ENUM-REF-CANDIDATE: store|distribution_center|corporate|regional_office|ecommerce|shared_services|manufacturing|logistics — promote to reference product]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'SAP fiscal year variant (PERIV) assigned to this cost center\'s controlling area. Defines the fiscal calendar (e.g., \'K4\' for calendar year, \'V3\' for April–March). Critical for period-based budget vs. actuals comparison and FASB-compliant financial close.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'SAP Functional Area (FKBER) classifying the cost center by business function (e.g., Sales, Administration, Production, Logistics). Used for cost-of-sales accounting and functional P&L reporting per FASB ASC 220.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountBudget rdf:type rdf:Property ;
    rdfs:label 'Headcount Budget' ;
    rdfs:comment 'Approved headcount (number of full-time equivalent employees) budgeted for this cost center in the current fiscal year. Used for workforce cost planning, Workday HCM integration, and labor cost as a percentage of sales analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyArea rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Area' ;
    rdfs:comment 'Node within the standard cost center hierarchy (SAP field: KOSAR/KHINR) that positions this cost center in the enterprise organizational tree. Used for roll-up reporting in P&L, EBITDA tracking, and budget consolidation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderCode rdf:type rdf:Property ;
    rdfs:label 'Internal Order Code' ;
    rdfs:comment 'SAP Internal Order (AUFNR) code linked to this cost center for detailed cost monitoring of specific activities or projects (e.g., marketing campaigns, store remodels). Enables granular expense tracking beyond standard cost center reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLockedForPosting rdf:type rdf:Property ;
    rdfs:label 'Is Locked For Posting' ;
    rdfs:comment 'Indicates whether this cost center is currently locked against new financial postings (SAP lock indicator). True = no new postings allowed; False = postings permitted. Used during period-end close and cost center restructuring.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStatistical rdf:type rdf:Property ;
    rdfs:label 'Is Statistical' ;
    rdfs:comment 'Indicates whether this cost center is a statistical cost center (SAP field: STAT). Statistical cost centers receive postings for informational/reporting purposes only and do not carry real costs. True = statistical; False = real cost center.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'SAP Work Breakdown Structure (WBS) element code associated with this cost center for project-based cost tracking. Used when the cost center is linked to a capital project (e.g., store renovation, DC expansion) for CAPEX vs. OPEX classification per FASB ASC 842.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'Start date of the cost center\'s validity period (SAP field: DATAB). The cost center is open for expense postings from this date. Supports fiscal year-aligned budget and actuals reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validTo rdf:type rdf:Property ;
    rdfs:label 'Valid To' ;
    rdfs:comment 'End date of the cost center\'s validity period (SAP field: DATBI). After this date, no new postings are permitted. Null or 9999-12-31 indicates an open-ended cost center with no planned closure.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualCogsBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Cogs Budget' ;
    rdfs:comment 'Planned annual Cost of Goods Sold (COGS) budget for this profit center. Used to calculate budgeted gross margin and GMROI targets. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualOpexBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Opex Budget' ;
    rdfs:comment 'Planned annual operating expense (OPEX) budget for this profit center, excluding COGS. Includes store labor, occupancy, marketing, and overhead. Used for EBITDA planning and P&L variance reporting. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRevenueBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Budget' ;
    rdfs:comment 'Planned annual revenue target for this profit center in the profit center currency. Used for P&L variance analysis, comp sales (SSS) benchmarking, and EBITDA forecasting. Sourced from SAP CO-PCA budget planning. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asc280ReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Asc280 Reportable Flag' ;
    rdfs:comment 'Indicates whether this profit center qualifies as a reportable segment under FASB ASC 280 (Segment Reporting) based on the 10% quantitative thresholds for revenue, profit/loss, or assets (True = reportable segment). Drives external financial disclosure requirements.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetPeriod rdf:type rdf:Property ;
    rdfs:label 'Budget Period' ;
    rdfs:comment 'The fiscal year or fiscal year-period (YYYY or YYYY-MM) for which the current budget is active for this profit center. Used in Open to Buy (OTB) planning, financial forecasting, and variance analysis against actuals.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date on which this profit center was deactivated or archived. Null if the profit center is currently active. Used for historical P&L analysis, store closure reporting, and comp sales (SSS) exclusion logic.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Elimination Flag' ;
    rdfs:comment 'Indicates whether intercompany transactions for this profit center are subject to elimination during consolidated financial reporting (True = elimination required). Used in group consolidation to remove internal P&L and balance sheet effects per FASB ASC 810.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hierarchyNodeCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node Code' ;
    rdfs:comment 'Code of the standard hierarchy node to which this profit center is assigned in SAP CO-PCA. Enables rollup P&L reporting across organizational levels (e.g., store → region → banner → enterprise). Used for segment reporting per ASC 280.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseAccountingFlag rdf:type rdf:Property ;
    rdfs:label 'Lease Accounting Flag' ;
    rdfs:comment 'Indicates whether this profit center has active lease obligations subject to ASC 842 lease accounting (True = lease obligations exist). Triggers right-of-use (ROU) asset and lease liability recognition in the financial close process for store and DC profit centers.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mdmSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Mdm Source System' ;
    rdfs:comment 'Identifies the authoritative source system from which this profit center master record was originated or last mastered (e.g., \'SAP_S4HANA\', \'INFORMATICA_MDM\'). Supports data lineage, MDM golden record management, and audit traceability.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Block Flag' ;
    rdfs:comment 'Indicates whether financial postings to this profit center are currently blocked (True = blocked, False = open). Set during financial close periods, audits, or when a profit center is being restructured. Prevents erroneous postings during sensitive periods.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Profit Center Category' ;
    rdfs:comment 'Management accounting classification indicating the primary financial role of the profit center: \'revenue\' (generates external revenue), \'cost\' (internal cost allocation only), \'investment\' (capital-intensive with ROI tracking), \'service\' (shared service provider). Drives transfer pricing rules and internal P&L treatment.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the profit center within the controlling area, as defined in SAP S/4HANA CO-PCA (e.g., \'PC_STORE_0042\', \'PC_ECOM_US\'). Used in journal entries, cost allocations, and management reports. Satisfies MASTER_RESOURCE BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'Detailed business description of the profit center\'s purpose, scope, and the business unit it represents. Provides context for financial analysts, auditors, and management reporting consumers.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterLevel rdf:type rdf:Property ;
    rdfs:label 'Profit Center Level' ;
    rdfs:comment 'Numeric level of this profit center within the management accounting hierarchy (e.g., 1 = enterprise, 2 = banner, 3 = region, 4 = store). Used for hierarchical P&L rollup, drill-down reporting, and segment aggregation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'Human-readable name of the profit center (e.g., \'Chicago Flagship Store\', \'US E-Commerce Channel\', \'Private Label Apparel\'). Used in P&L reports, dashboards, and management presentations. Satisfies MASTER_RESOURCE IDENTITY_LABEL category.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle state of the profit center master record. \'active\' — open for postings; \'inactive\' — temporarily closed; \'locked\' — blocked for new postings (e.g., during financial close); \'pending\' — awaiting activation; \'archived\' — historical record, no postings allowed. Satisfies MASTER_RESOURCE LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the autonomous business unit represented by this profit center. Determines the nature of P&L reporting: \'store\' (physical retail location), \'channel\' (e-commerce, BOPIS, DSD), \'product_line\' (private label, electronics, apparel), \'banner\' (hypermarket, discount outlet), \'region\' (geographic grouping), \'corporate\' (shared services). Satisfies MASTER_RESOURCE CLASSIFICATION_OR_TYPE category.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleManager rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager' ;
    rdfs:comment 'Full name or employee ID of the manager accountable for this profit center\'s financial performance. Used in management reporting, budget approval workflows, and P&L accountability assignments in SAP CO-PCA.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Financial reporting segment assigned to this profit center per FASB ASC 280 (Segment Reporting). Maps profit centers to reportable segments (e.g., \'GROCERY\', \'APPAREL\', \'ECOMMERCE\', \'INTERNATIONAL\') for external financial disclosures and SEC filings.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated display name for the profit center used in space-constrained reports, POS system displays, and financial dashboards (e.g., \'CHI-FLAGSHIP\', \'ECOM-US\').' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeNumber rdf:type rdf:Property ;
    rdfs:label 'Store Number' ;
    rdfs:comment 'Physical store identifier associated with this profit center when profit_center_type is \'store\'. Links to the store master for footfall, planogram, and comp sales (SSS) reporting. Null for non-store profit centers.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPriceFlag rdf:type rdf:Property ;
    rdfs:label 'Transfer Price Flag' ;
    rdfs:comment 'Indicates whether transfer pricing rules apply to transactions involving this profit center (True = transfer pricing active). Relevant for intercompany transactions between profit centers, particularly for cross-border operations subject to OECD transfer pricing guidelines.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'Date from which this profit center is valid and open for financial postings in SAP CO-PCA. Defines the start of the profit center\'s active period for time-dependent master data management and fiscal year planning.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'Date until which this profit center is valid for financial postings. After this date, the profit center is locked for new transactions. Null indicates an open-ended validity period. Used for profit center lifecycle management and financial close.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'SAP account group (KTOKS) that controls the number range and field selection for the GL account. Groups accounts by functional category such as cash accounts, receivables, payables, revenue accounts, COGS accounts, and operating expense accounts. [ENUM-REF-CANDIDATE: cash|receivables|payables|revenue|cogs|opex|assets|liabilities|equity|statistical — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountLongName rdf:type rdf:Property ;
    rdfs:label 'Account Long Name' ;
    rdfs:comment 'Extended descriptive name of the GL account providing full business context beyond the short name. Used in detailed financial reporting, audit documentation, and regulatory disclosures.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Human-readable short description of the GL account as maintained in SAP S/4HANA (SKAT table). Used in financial statements, P&L reports, and EBITDA dashboards for display and labeling purposes.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'The externally-known GL account number as defined in the SAP S/4HANA chart of accounts (SKA1/SKB1 tables). Used in all financial postings, journal entries, and regulatory reporting. Typically a 6–10 digit numeric code aligned to the company\'s account numbering scheme.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the GL account. \'active\' permits financial postings; \'blocked\' prevents new postings while retaining history; \'marked_for_deletion\' flags the account for archival after period-end close; \'inactive\' denotes accounts no longer in use. Maps to SAP field XSPEB (posting block) and XLOEV (deletion flag).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Fundamental classification of the GL account per GAAP balance sheet and income statement structure. Drives financial statement placement: asset/liability/equity for balance sheet; revenue/expense for P&L. Maps to SAP field KTOKS (account group) and XBILK (balance sheet indicator).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Alternative Account Number' ;
    rdfs:comment 'Country-specific or group-level alternative account number used for local statutory reporting or group consolidation mapping. Enables cross-mapping between the operational chart of accounts and a group/statutory chart of accounts. Maps to SAP field ALTKT in SKB1.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetAccount rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Account' ;
    rdfs:comment 'Indicates whether this account is a balance sheet account (True) or a P&L income statement account (False). Balance sheet accounts carry forward balances at year-end; P&L accounts are closed to retained earnings. Maps to SAP field XBILK in SKA1.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chartOfAccountsCode rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Code' ;
    rdfs:comment 'Identifier for the chart of accounts to which this GL account belongs in SAP S/4HANA (e.g., \'INT\' for international, \'CAUS\' for US GAAP). A single enterprise may maintain multiple charts of accounts for group vs. local reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentManagement rdf:type rdf:Property ;
    rdfs:label 'Commitment Management' ;
    rdfs:comment 'Indicates whether commitment management (budget encumbrance) is active (True) for this GL account. When enabled, purchase orders and purchase requisitions create budget commitments against this account, supporting Open-to-Buy (OTB) budget control in merchandise planning.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'Indicates whether this GL account is linked to a CO (Controlling) cost element and its category. \'primary\' cost elements correspond to P&L accounts (e.g., COGS, operating expenses); \'secondary\' are internal allocation accounts; \'not_applicable\' for balance sheet accounts. Drives EBITDA and P&L cost center reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferredRevenueIndicator rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue Indicator' ;
    rdfs:comment 'Indicates whether this GL account is used to record deferred revenue (True), such as gift card liabilities, loyalty point deferrals, or advance payments not yet recognized under ASC 606. Supports balance sheet classification and revenue recognition scheduling.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'The date from which this GL account became active and available for financial postings. Supports temporal validity tracking for chart of accounts changes during fiscal year transitions and regulatory reporting periods.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'The date after which this GL account is no longer valid for new financial postings. Null indicates an open-ended account with no planned expiry. Used to manage account lifecycle during chart of accounts restructuring and fiscal year-end close.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fasbClassification rdf:type rdf:Property ;
    rdfs:label 'Fasb Classification' ;
    rdfs:comment 'FASB Accounting Standards Codification (ASC) topic or subtopic to which this GL account is primarily aligned (e.g., \'ASC 606\' for revenue recognition accounts, \'ASC 842\' for lease liability/ROU asset accounts, \'ASC 330\' for inventory/COGS accounts). Supports FASB-compliant regulatory reporting and audit readiness. [ENUM-REF-CANDIDATE: ASC_606|ASC_842|ASC_330|ASC_350|ASC_360|ASC_420 — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'SAP field status group code (e.g., G001, G004) assigned to this GL account that controls which fields are required, optional, or suppressed during document entry. Enforces data quality and completeness rules at the point of financial posting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementVersion rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Version' ;
    rdfs:comment 'SAP Financial Statement Version (FSV) code that determines how this account is grouped and displayed in statutory financial statements (balance sheet, P&L). Supports GAAP, IFRS, and management reporting views. Maps to SAP table T011.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsItemCode rdf:type rdf:Property ;
    rdfs:label 'Fs Item Code' ;
    rdfs:comment 'The financial statement line item code to which this GL account is assigned within the Financial Statement Version. Enables aggregation of multiple GL accounts into a single P&L or balance sheet line for external reporting and FASB-compliant disclosures.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'SAP functional area classification that segments costs by business function for cost-of-sales P&L reporting (e.g., \'SALES\', \'ADMIN\', \'LOGISTICS\', \'MARKETING\', \'STORE_OPS\'). Enables functional income statement presentation per IFRS IAS 1 and management reporting. [ENUM-REF-CANDIDATE: sales|administration|logistics|marketing|store_operations|ecommerce|supply_chain — promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:houseBankAccount rdf:type rdf:Property ;
    rdfs:label 'House Bank Account' ;
    rdfs:comment 'Indicates whether this GL account is a bank account (True) linked to a house bank in SAP FI-TR (Treasury). Bank GL accounts are used for cash management, bank reconciliation, and PCI DSS-compliant payment processing.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyAccount rdf:type rdf:Property ;
    rdfs:label 'Intercompany Account' ;
    rdfs:comment 'Indicates whether this GL account is designated for intercompany transactions (True) between legal entities within the retail group. Intercompany accounts are eliminated during group consolidation. Maps to SAP intercompany account configuration.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Changed Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this GL account master record in SAP S/4HANA. Used for change detection in ETL pipelines, audit compliance, and Sarbanes-Oxley (SOX) internal control documentation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:leaseAccountType rdf:type rdf:Property ;
    rdfs:label 'Lease Account Type' ;
    rdfs:comment 'Classifies the GL account\'s role under FASB ASC 842 lease accounting. \'rou_asset\' identifies Right-of-Use asset accounts for operating and finance leases; \'lease_liability\' identifies corresponding liability accounts; \'lease_expense\' identifies amortization/interest expense accounts; \'not_applicable\' for non-lease accounts. Critical for ASC 842 compliance reporting in retail store lease portfolios.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemDisplay rdf:type rdf:Property ;
    rdfs:label 'Line Item Display' ;
    rdfs:comment 'Indicates whether individual line items posted to this account are stored and displayable (True) in the FI line item report. Required for accounts needing detailed transaction-level audit trails. Maps to SAP field XKRES in SKB1.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagement rdf:type rdf:Property ;
    rdfs:label 'Open Item Management' ;
    rdfs:comment 'Indicates whether open item management is active (True) for this account, enabling individual line items to be matched and cleared (e.g., for clearing accounts, GR/IR accounts, bank clearing). Maps to SAP field XOPVW in SKB1.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningRelevant rdf:type rdf:Property ;
    rdfs:label 'Planning Relevant' ;
    rdfs:comment 'Indicates whether this GL account is included in financial planning and budgeting processes (True). Planning-relevant accounts are available for budget entry in SAP BPC or S/4HANA Financial Planning, supporting annual budgeting and rolling forecast cycles.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingBlocked rdf:type rdf:Property ;
    rdfs:label 'Posting Blocked' ;
    rdfs:comment 'Indicates whether financial postings to this GL account are currently blocked (True) or permitted (False). A blocked account cannot receive new journal entries but retains its historical balance. Maps to SAP field XSPEB in SKA1/SKB1.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterRelevant rdf:type rdf:Property ;
    rdfs:label 'Profit Center Relevant' ;
    rdfs:comment 'Indicates whether postings to this GL account are distributed to profit centers (True) for segment and store-level P&L reporting. Profit center-relevant accounts enable comparable store sales (Comp Sales/SSS) analysis and GMROI reporting by retail location.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitLossCategory rdf:type rdf:Property ;
    rdfs:label 'Profit Loss Category' ;
    rdfs:comment 'Business classification of the GL account within the P&L statement structure. Enables EBITDA tracking, gross margin analysis, and COGS reporting. \'revenue\' includes net sales and other income; \'cogs\' covers Cost of Goods Sold; \'gross_margin\' is a subtotal indicator; \'operating_expense\' covers SG&A and store operations; \'ebitda\' marks EBITDA-relevant accounts. [ENUM-REF-CANDIDATE: revenue|cogs|gross_margin|operating_expense|ebitda|depreciation|interest|tax|not_applicable — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationAccountType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Type' ;
    rdfs:comment 'Identifies whether this GL account serves as a reconciliation (control) account for a subledger. \'customer\' links to accounts receivable subledger; \'vendor\' links to accounts payable subledger; \'asset\' links to fixed asset subledger; \'none\' indicates a standalone GL account. Maps to SAP field MITKZ in SKB1.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'Specifies the ASC 606 revenue recognition pattern applicable to this revenue GL account. \'point_in_time\' applies to standard retail POS and e-commerce sales; \'over_time\' applies to gift card breakage, loyalty program deferrals, and subscription revenues; \'not_applicable\' for non-revenue accounts. Drives automated revenue recognition scheduling in SAP FI.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'Three-digit SAP sort key that determines which document field is used to populate the allocation field in line items posted to this account (e.g., \'001\' = posting date, \'012\' = document number). Drives line item sorting in account statements and aging reports.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalAccount rdf:type rdf:Property ;
    rdfs:label 'Statistical Account' ;
    rdfs:comment 'Indicates whether this is a statistical GL account (True) used for management reporting and KPI tracking without affecting the legal financial statements. Statistical accounts capture quantities or values for internal analytics such as footfall, units sold, or headcount.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Defines the tax relevance of the GL account for input/output tax determination. Controls whether tax codes are required, optional, or not applicable during posting. Maps to SAP field MWSKZ in SKB1. [ENUM-REF-CANDIDATE: input_tax|output_tax|not_relevant|tax_only|deferred_tax|use_tax — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxPostingRequired rdf:type rdf:Property ;
    rdfs:label 'Tax Posting Required' ;
    rdfs:comment 'Indicates whether a tax code is mandatory (True) when posting to this GL account. Enforces tax compliance controls at the point of financial entry, ensuring all taxable transactions are properly coded for regulatory reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toleranceGroup rdf:type rdf:Property ;
    rdfs:label 'Tolerance Group' ;
    rdfs:comment 'SAP tolerance group assigned to this GL account that defines acceptable variance thresholds for payment differences, rounding, and clearing. Controls automatic clearing of small differences during accounts payable and receivable processing.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualIndicator rdf:type rdf:Property ;
    rdfs:label 'Accrual Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry represents an accrual posting (True) — i.e., an expense or revenue recognized in the current period but not yet cash-settled. Supports accrual accounting under FASB ASC 606 and period-end close processes.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'SAP FI assignment field (ZUONR) used for sorting and matching open items in accounts payable and receivable clearing. Typically populated with the purchase order number, sales order number, or payment reference for automated clearing and reconciliation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'SAP FI business area code representing an organizational unit for which an internal balance sheet and P&L can be created. Used in retail for segment reporting across hypermarkets, department stores, discount outlets, and e-commerce channels.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether the journal entry header represents a debit (D) or credit (C) posting at the document level. Fundamental double-entry bookkeeping indicator used in SAP FI-GL for balance validation and financial statement preparation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentAmount rdf:type rdf:Property ;
    rdfs:label 'Document Amount' ;
    rdfs:comment 'Gross total amount of the journal entry in the document (transaction) currency. Represents the sum of all debit or credit line items before netting. Used for financial reporting, reconciliation, and audit trail in retail P&L and balance sheet analysis.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Document Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the transaction currency in which the journal entry amounts are originally recorded (e.g., USD, EUR, GBP). Distinct from local/company code currency. Required for multi-currency retail operations and FX reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date of the original source document (invoice, receipt, contract, etc.) that triggered the journal entry. May differ from the posting date and is used for aging analysis, vendor/customer reconciliation, and audit trail purposes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'SAP FI accounting document number uniquely identifying the journal entry within a company code and fiscal year. This is the externally-known business identifier used in audit trails, reconciliation, and cross-system references (e.g., EDI, ERP).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'SAP FI two-character document type code classifying the nature of the accounting document (e.g., SA=General Ledger, KR=Vendor Invoice, DR=Customer Invoice, AA=Asset Posting, AB=Accounting Document, ZP=Payment Clearing, RV=Revenue). Drives number range assignment and account type determination. [ENUM-REF-CANDIDATE: SA|KR|DR|AA|AB|ZP|RV|KZ|DZ|WA|WE|RE — promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enteredBy rdf:type rdf:Property ;
    rdfs:label 'Entered By' ;
    rdfs:comment 'SAP user ID of the person or system process that created the journal entry in SAP S/4HANA FI-GL. Required for FASB-compliant audit trail, SOX internal controls, and financial close accountability.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The exact date and time when the journal entry record was first created and saved in SAP S/4HANA FI-GL. Serves as the RECORD_AUDIT_CREATED timestamp for audit trail and FASB-compliant financial close documentation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Classification of the journal entry by its accounting purpose: \'standard\' = normal business transaction; \'accrual\' = expense/revenue accrual; \'reversal\' = reversal of a prior entry; \'adjustment\' = period-end correction; \'intercompany\' = elimination entry; \'depreciation\' = fixed asset depreciation; \'lease\' = ASC 842 lease expense; \'reclassification\' = account reclassification. [ENUM-REF-CANDIDATE: standard|accrual|reversal|adjustment|intercompany|depreciation|lease|reclassification|deferred_revenue|cogs — promote to reference product]' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year in which the journal entry is recorded (e.g., 2024). Used for period-end financial close, P&L reporting, and EBITDA tracking aligned with the retail fiscal calendar.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxRate rdf:type rdf:Property ;
    rdfs:label 'Fx Rate' ;
    rdfs:comment 'Exchange rate applied to translate document currency amounts to local currency at the time of posting. Sourced from SAP FI exchange rate tables. Critical for multi-currency retail operations, FX gain/loss accounting, and FASB ASC 830 compliance.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headerText rdf:type rdf:Property ;
    rdfs:label 'Header Text' ;
    rdfs:comment 'Free-text description or business justification entered at the journal entry header level in SAP FI-GL. Provides context for the posting (e.g., \'Q3 Rent Accrual\', \'COGS Adjustment - Store 1042\', \'Intercompany Elimination - FY2024 Q4\'). Required for audit trail and financial close documentation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry involves a transaction between two legal entities within the same corporate group (True). Used for intercompany elimination in consolidated financial statements under FASB ASC 810.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localAmount rdf:type rdf:Property ;
    rdfs:label 'Local Amount' ;
    rdfs:comment 'Total amount of the journal entry translated into the company code\'s local (functional) currency using the FX rate at posting date. Used for statutory P&L, balance sheet, and EBITDA reporting under FASB standards.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the company code\'s local (functional) currency. Used for statutory reporting and local GAAP compliance. Amounts are translated from document currency to local currency using the FX rate.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'SAP FI two-digit posting key controlling the debit/credit assignment, account type, and field selection for the journal entry (e.g., 40=Debit G/L, 50=Credit G/L, 01=Customer Invoice, 31=Vendor Invoice). Fundamental SAP FI-GL configuration element.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle state of the journal entry in the SAP FI-GL workflow. \'draft\' = entry in preparation; \'posted\' = fully posted to ledger; \'parked\' = saved but not yet posted (pending approval); \'held\' = temporarily saved; \'reversed\' = entry has been reversed; \'error\' = posting failed validation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry is a reversal of a previously posted document (True) or an original posting (False). Used in SAP FI-GL for accrual reversal management and period-end close processes.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The SAP accounting document number of the original entry that this journal entry reverses. Populated only when reversal_indicator is True. Provides the audit trail link between reversal and original posting for FASB-compliant financial close.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledReversalDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Reversal Date' ;
    rdfs:comment 'The date on which SAP S/4HANA is scheduled to automatically reverse this journal entry (typically the first day of the following period for accrual entries). Populated when accrual_indicator is True. Supports automated period-end close and accrual management.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceModule rdf:type rdf:Property ;
    rdfs:label 'Source Module' ;
    rdfs:comment 'SAP S/4HANA module that originated the journal entry posting (e.g., FI-AP=Accounts Payable, FI-AR=Accounts Receivable, FI-AA=Asset Accounting, FI-TX=Tax Accounting, MM=Materials Management, SD=Sales & Distribution, CO=Controlling). Enables source-system traceability and cross-module reconciliation. [ENUM-REF-CANDIDATE: FI-AP|FI-AR|FI-AA|FI-TX|FI-GL|MM|SD|CO|PP|WM — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'SAP company code of the intercompany trading partner involved in this journal entry. Populated only when intercompany_indicator is True. Required for intercompany reconciliation and elimination in consolidated P&L and balance sheet reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each journal entry line item in the general ledger. Primary key for this silver-layer data product, aligned to SAP FI-GL line item table (BSEG).' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:posTransactionLineId rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Line Id' ;
    rdfs:comment 'Foreign key linking to order.pos_transaction_line. Business justification: Store-level GL reconciliation: POS transaction lines drive revenue and COGS journal entries. Retail store controllers trace journal entry lines to POS transaction lines for daily close reconciliation,' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosTransactionLine .

ind:amountDocCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Doc Currency' ;
    rdfs:comment 'The transaction amount in the document (transaction) currency, corresponding to SAP BSEG-WRBTR. Used for multi-currency financial reporting and foreign exchange analysis.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Group Currency' ;
    rdfs:comment 'The transaction amount translated to the group (consolidation) currency, corresponding to SAP BSEG-KURSF-derived group currency amount. Supports consolidated P&L and EBITDA reporting across all legal entities.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Local Currency' ;
    rdfs:comment 'The transaction amount translated to the company code local currency, corresponding to SAP BSEG-DMBTR. Used for statutory financial reporting and local GAAP compliance.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignment rdf:type rdf:Property ;
    rdfs:label 'Assignment' ;
    rdfs:comment 'Free-form assignment field used for line item sorting and allocation, corresponding to SAP BSEG-ZUONR. Typically populated with a reference number (e.g., purchase order, cost object) to facilitate reconciliation and reporting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date on which this open item was cleared (AUGDT in SAP BSEG). Null for uncleared items. Used for days-payable-outstanding (DPO) and days-sales-outstanding (DSO) calculations.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'SAP clearing document number (AUGBL) assigned when this open item is cleared against a payment or offsetting entry. Null for uncleared items. Used in accounts payable/receivable reconciliation and aging analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Doc Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the document (transaction) currency, corresponding to SAP BSEG-WAERS. Enables multi-currency P&L and balance sheet reporting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'Reference to the SAP internal order (AUFNR) to which this line item is assigned. Used for project-level cost tracking, capital expenditure monitoring, and marketing campaign cost allocation.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isReversed rdf:type rdf:Property ;
    rdfs:label 'Is Reversed' ;
    rdfs:comment 'Indicates whether this journal entry line has been reversed (True) or is active (False), derived from SAP BKPF-STBLG. Reversed entries must be excluded from financial statement totals to prevent double-counting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'SAP ledger group (LDGRP) identifying the accounting principle under which this line is posted (e.g., leading ledger for GAAP, non-leading ledger for IFRS). Supports parallel accounting for multi-GAAP reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Descriptive text for this journal entry line item, corresponding to SAP BSEG-SGTXT. Provides narrative context for auditors, financial analysts, and during financial close review.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'SAP material number (MATNR in BSEG) corresponding to the Stock Keeping Unit (SKU) associated with this line item. Populated for inventory valuation, COGS, and goods movement postings. Enables drill-down from GL to product-level cost analysis.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'The SAP document number of the reversing entry (STBLG from BKPF), if this line has been reversed. Enables audit trail tracing from original posting to reversal for financial close and SOX compliance.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialGlIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Gl Indicator' ;
    rdfs:comment 'SAP special GL indicator (UMSKZ) used for down payments, guarantees, and other special transactions that are posted to alternative reconciliation accounts. Blank for standard postings.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The effective date for cash flow and bank reconciliation purposes, corresponding to SAP BSEG-VALUT. Used in treasury and accounts payable/receivable aging analysis.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'SAP WBS element (PROJK) for project-based cost assignment, corresponding to capital expenditure projects such as store openings, DC expansions, or IT implementations. Supports CAPEX tracking and ASC 842 lease accounting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackAmount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Amount' ;
    rdfs:comment 'Amount deducted from the invoice payment as a vendor compliance penalty (chargeback) for violations such as late delivery, labeling errors, or EDI non-compliance. Reduces net payment to vendor.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'Last date by which payment must be made to capture the early payment cash discount offered by the vendor (e.g., 2/10 Net 30 — discount expires on day 10). Critical for cash discount capture optimization.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Reason code for invoices placed in disputed status during three-way match or AP review. Drives dispute resolution workflow and vendor communication in SAP FI-AP and Salesforce Service Cloud. [ENUM-REF-CANDIDATE: price_discrepancy|quantity_discrepancy|duplicate_invoice|missing_po|quality_issue|chargeback|other — promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Calculated date by which payment must be made to the vendor to comply with agreed payment terms and avoid late payment penalties. Derived from invoice date plus payment terms net days in SAP FI-AP.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total gross invoice amount before any deductions, discounts, or tax adjustments as stated on the vendor invoice. Represents the full obligation prior to netting. Corresponds to WRBTR in SAP FI.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date printed on the vendor invoice document. Used as the baseline date for payment terms calculation (e.g., Net 30 from invoice date) and cash discount eligibility. Corresponds to BLDAT in SAP FI.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current workflow state of the AP invoice through the invoice-to-payment cycle. Drives AP aging analysis, payment run eligibility, and period-end close. [ENUM-REF-CANDIDATE: received|under_review|approved|posted|scheduled|paid|disputed|cancelled — promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice document type as defined in SAP FI-AP document type configuration. Determines posting logic, payment terms applicability, and GL account determination. [ENUM-REF-CANDIDATE: standard|credit_memo|debit_memo|recurring|intercompany|proforma — promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEdiReceived rdf:type rdf:Property ;
    rdfs:label 'Is Edi Received' ;
    rdfs:comment 'Indicates whether the invoice was received electronically via EDI (Electronic Data Interchange) transmission from the vendor, as opposed to paper or email. EDI invoices (e.g., ANSI X12 810) enable straight-through processing.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentBlock rdf:type rdf:Property ;
    rdfs:label 'Payment Block' ;
    rdfs:comment 'Indicator specifying whether and why the invoice is blocked from automatic payment processing. Corresponds to ZLSPR in SAP FI-AP. A value of \'none\' means the invoice is eligible for the next payment run.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Actual date on which payment was executed and disbursed to the vendor via the selected payment method (ACH, wire, check). Populated upon successful payment run completion in SAP FI-AP.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'SAP FI document number generated for the payment transaction that clears this invoice. Used for bank reconciliation, remittance advice, and audit trail of the payment-to-invoice clearing.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Method by which the invoice will be or was settled (e.g., ACH electronic transfer, wire transfer, check, virtual card, EFT). Corresponds to ZLSCH in SAP FI-AP and determines payment run processing logic.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceReference rdf:type rdf:Property ;
    rdfs:label 'Remittance Reference' ;
    rdfs:comment 'Reference number or text included in the payment remittance advice sent to the vendor, enabling the vendor to match the payment to their outstanding invoices. Supports vendor reconciliation and dispute prevention.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'Internal SAP FI document number (BELNR) assigned upon posting of the invoice in SAP S/4HANA. Used for cross-reference with the general ledger and FI-AP subledger.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Result of the three-way matching process comparing the purchase order (PO), goods receipt (GR), and vendor invoice quantities and amounts in SAP FI-AP/MM. Exceptions require AP team resolution before payment approval.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorBankAccount rdf:type rdf:Property ;
    rdfs:label 'Vendor Bank Account' ;
    rdfs:comment 'Masked or tokenized reference to the vendor bank account used for payment disbursement. Stored in compliance with PCI DSS requirements. Full account details are maintained in SAP FI-AP vendor master banking data.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionId rdf:type rdf:Property ;
    rdfs:label 'Subscription Id' ;
    rdfs:comment 'Foreign key linking to order.subscription. Business justification: Subscription revenue recognition: recurring subscription billing generates periodic AR invoices. ASC 606 deferred revenue tracking and subscription lifecycle reporting require linking AR invoices to t' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscription .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'Total amount of payments and credits applied against this invoice to date. Used to calculate the outstanding open balance and support partial payment tracking in cash application.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankClearingDate rdf:type rdf:Property ;
    rdfs:label 'Bank Clearing Date' ;
    rdfs:comment 'Date on which the payment was cleared through the bank and matched to this invoice in SAP FI-AR. Null until payment is received and cleared. Used for cash flow reporting and bank reconciliation.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingCategory rdf:type rdf:Property ;
    rdfs:label 'Billing Category' ;
    rdfs:comment 'Business category of the receivable indicating the commercial relationship type. Supports segmented AR reporting across wholesale accounts, franchise fee billing, commercial receivables, intercompany settlements, and drop-ship vendor billing.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Billing Document Number' ;
    rdfs:comment 'Externally-known SAP FI-AR billing document number (BELNR) assigned at invoice creation. Used for customer remittance matching, EDI reconciliation, and dispute resolution. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER minimum category.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Discount Amount' ;
    rdfs:comment 'Early payment discount amount available to the customer if payment is received within the discount period defined in payment terms (e.g., 2% if paid within 10 days on 2/10NET30 terms).' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashDiscountDueDate rdf:type rdf:Property ;
    rdfs:label 'Cash Discount Due Date' ;
    rdfs:comment 'Last date by which the customer must pay to qualify for the early payment cash discount. Calculated from invoice_date and payment_terms_code discount period.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:comment 'Standardized SAP reason code for the customer dispute (e.g., pricing discrepancy, short shipment, quality issue, chargeback). Used for dispute root-cause analysis and vendor chargeback management.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current status of any customer dispute raised against this invoice. Drives collections workflow routing and dunning block management in SAP FI-AR and Salesforce Service Cloud.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningBlock rdf:type rdf:Property ;
    rdfs:label 'Dunning Block' ;
    rdfs:comment 'Indicates whether dunning notices are blocked for this invoice (True = blocked). Set when a dispute is open, a payment arrangement is in place, or the account is under review.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunningDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Date' ;
    rdfs:comment 'Date of the most recent dunning notice sent to the customer for this invoice. Used to track collections activity and enforce dunning interval rules.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning escalation level (0–4) assigned to this invoice in SAP FI-AR dunning program. Level 0 = no dunning; higher levels indicate escalating collection notices sent to the customer.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openAmount rdf:type rdf:Property ;
    rdfs:label 'Open Amount' ;
    rdfs:comment 'Remaining unpaid balance on the invoice (net_amount minus applied_amount). Drives AR aging analysis, dunning escalation, and collections workflow prioritization.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which revenue from this invoice was recognized under ASC 606 criteria (performance obligation satisfied). May differ from invoice_date for multi-element arrangements or deferred revenue scenarios.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Status' ;
    rdfs:comment 'ASC 606 revenue recognition status for this invoice. Indicates whether revenue has been recognized, is deferred pending performance obligation fulfillment, or has been reversed. Critical for FASB-compliant financial reporting.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrgCode rdf:type rdf:Property ;
    rdfs:label 'Sales Org Code' ;
    rdfs:comment 'SAP sales organization (VKORG) responsible for this invoice. Enables P&L reporting and revenue attribution by sales channel, region, or business unit.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'Amount written off as uncollectible bad debt for this invoice. Used for bad debt expense reporting, allowance for doubtful accounts calculation, and FASB-compliant AR reserve management.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'Date on which the invoice balance was written off as bad debt in SAP FI-AR. Null until a write-off is executed. Required for bad debt aging and allowance for doubtful accounts reporting.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'The actual financial amount posted to the GL account and cost center for this budget period. Sourced from SAP S/4HANA FI actuals for budget vs. actual variance analysis.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level financial classification of the budget line: Capital Expenditure (CAPEX), Operating Expenditure (OPEX), Cost of Goods Sold (COGS), labor costs, or revenue. Drives P&L and EBITDA reporting segmentation.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the budget record, used in financial planning communications, approval workflows, and audit trails. Format: BDG-YYYY-NNNNNN.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsProjection rdf:type rdf:Property ;
    rdfs:label 'Cogs Projection' ;
    rdfs:comment 'Planned Cost of Goods Sold (COGS) for the budget period, used to project gross margin and support merchandise planning and Open to Buy (OTB) calculations.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'The amount of the budget that has been formally committed through purchase orders or contracts but not yet expensed. Supports Open to Buy (OTB) integration and encumbrance accounting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebitdaProjection rdf:type rdf:Property ;
    rdfs:label 'Ebitda Projection' ;
    rdfs:comment 'Planned Earnings Before Interest, Taxes, Depreciation, and Amortization (EBITDA) for the budget period. Key metric for investor financial guidance and enterprise P&L reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter (1–4) within the fiscal year for this budget record. Used for quarterly reforecast cycles, investor financial guidance, and quarterly P&L reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastAmount rdf:type rdf:Property ;
    rdfs:label 'Forecast Amount' ;
    rdfs:comment 'The latest forward-looking financial estimate for this budget line, updated during rolling forecast or reforecast cycles. Used for forecast vs. prior forecast variance analysis and investor guidance.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastMethod rdf:type rdf:Property ;
    rdfs:label 'Forecast Method' ;
    rdfs:comment 'The methodology used to derive the forecast or budget amounts: top-down (executive-driven allocation), bottom-up (cost center aggregation), driver-based (KPI-linked), statistical (model-driven), or zero-based budgeting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossMarginProjection rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Projection' ;
    rdfs:comment 'Planned gross margin (revenue minus COGS) for the budget period and business unit. Supports Gross Margin Return on Investment (GMROI) analysis and financial close reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isReforecast rdf:type rdf:Property ;
    rdfs:label 'Is Reforecast' ;
    rdfs:comment 'Indicates whether this budget record represents a reforecast (True) rather than the original budget plan (False). Distinguishes reforecast iterations from baseline budget entries for variance tracking.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockDate rdf:type rdf:Property ;
    rdfs:label 'Lock Date' ;
    rdfs:comment 'The date on which this budget record was locked to prevent further modifications, typically at period-end close. Supports financial close process integrity and audit compliance.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:otbAmount rdf:type rdf:Property ;
    rdfs:label 'Otb Amount' ;
    rdfs:comment 'The Open to Buy (OTB) amount representing the remaining purchasing budget available for merchandise procurement in this period. Calculated as planned inventory budget minus committed and received inventory costs.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'The end date of the planning period covered by this budget record. Defines the effective close of the budget window for financial reporting and period-end close processes.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'The start date of the planning period covered by this budget record. Defines the effective beginning of the budget window for financial close and reporting alignment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planVersionType rdf:type rdf:Property ;
    rdfs:label 'Plan Version Type' ;
    rdfs:comment 'Classifies the budget record by planning cycle type: original budget (initial annual plan), revised budget (approved amendment), rolling forecast (monthly update), quarterly reforecast, or annual plan. Maps to SAP CO plan version category.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Amount' ;
    rdfs:comment 'The original planned financial amount for this budget line item in the functional currency. Represents the baseline against which actuals and forecasts are compared in budget vs. actual reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorForecastAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Forecast Amount' ;
    rdfs:comment 'The forecast amount from the immediately preceding forecast cycle, retained for forecast vs. prior forecast variance analysis and trend tracking in financial planning.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueProjection rdf:type rdf:Property ;
    rdfs:label 'Revenue Projection' ;
    rdfs:comment 'Forward-looking revenue estimate for the business unit and channel in this budget period. Supports top-line financial planning, investor guidance, and Gross Merchandise Value (GMV) tracking.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'The date on which this budget record was formally submitted for approval in the financial planning workflow. Supports submission tracking and planning cycle compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submittedBy rdf:type rdf:Property ;
    rdfs:label 'Submitted By' ;
    rdfs:comment 'The name or employee identifier of the person who submitted this budget record for approval. Supports submission tracking and financial planning accountability.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The absolute difference between planned amount and actual amount (actual_amount minus planned_amount) for this budget line. Positive value indicates overspend; negative indicates underspend. Supports budget vs. actual reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Pct' ;
    rdfs:comment 'The percentage variance between planned and actual amounts ((actual - planned) / planned * 100). Used in financial dashboards and P&L reporting to flag material variances requiring management action.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:comparablePeriodId rdf:type rdf:Property ;
    rdfs:label 'Comparable Period Id' ;
    rdfs:comment 'Reference to the corresponding financial period in the prior fiscal year used for same-store sales (SSS/Comp Sales) and year-over-year (YoY) financial comparisons. Accounts for 53-week year shifts in the NRF retail calendar.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialPeriod .

ind:priorYearPeriodFinancialPeriodId rdf:type rdf:Property ;
    rdfs:label 'Prior Year Period Financial Period Id' ;
    rdfs:comment 'Reference to the exact same period number in the immediately preceding fiscal year. Used for year-over-year (YoY) financial variance analysis, P&L comparisons, and FASB comparative financial statement preparation. Distinct from comparable_period_id which accounts for 53-week calendar shifts.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialPeriod .

ind:apPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Ap Posting Allowed' ;
    rdfs:comment 'Indicates whether accounts payable (AP) postings are permitted for this financial period. AP periods may be managed independently from GL periods in SAP S/4HANA to support vendor invoice processing timelines and COGS accruals.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Ar Posting Allowed' ;
    rdfs:comment 'Indicates whether accounts receivable (AR) postings are permitted for this financial period. AR periods may be managed independently to support customer payment processing, revenue recognition (ASC 606), and loyalty program financial settlements.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Identifier for the budget or plan version associated with this financial period (e.g., \'ORIGINAL\', \'REVISED_Q2\', \'FORECAST_V3\'). Links the period to the corresponding financial plan in SAP CO for budget vs. actual variance analysis and financial planning cycles.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarType rdf:type rdf:Property ;
    rdfs:label 'Calendar Type' ;
    rdfs:comment 'The retail fiscal calendar convention used for this period. The 4-5-4 and 4-4-5 calendars are NRF industry standards that divide the fiscal year into 4-week and 5-week periods to align comparable store sales (SSS) reporting across years.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeCycleDays rdf:type rdf:Property ;
    rdfs:label 'Close Cycle Days' ;
    rdfs:comment 'Number of calendar days allocated for completing the financial close process for this period (from period end date to scheduled close date). A KPI for finance operations efficiency; industry benchmark for retail is typically 5–10 business days for month-end close.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closeStatus rdf:type rdf:Property ;
    rdfs:label 'Close Status' ;
    rdfs:comment 'Status of the financial close process for this period. Tracks progression through the month-end or year-end close cycle. \'not_started\' indicates close activities have not begun; \'in_progress\' means close tasks are underway; \'completed\' means the period is fully closed and reconciled; \'reopened\' means a closed period was reopened for corrections.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'SAP CO controlling area code associated with this financial period. The controlling area defines the organizational unit for cost accounting, P&L reporting, and EBITDA tracking within SAP S/4HANA CO module.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Allowed' ;
    rdfs:comment 'Indicates whether general ledger (GL) journal entry postings are currently permitted for this financial period. Derived from posting_status but maintained as an explicit business flag for integration with downstream systems that check posting eligibility.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:is53WeekYear rdf:type rdf:Property ;
    rdfs:label 'Is 53 Week Year' ;
    rdfs:comment 'Indicates whether the fiscal year containing this period is a 53-week year. Under the NRF 4-5-4 calendar, a 53rd week occurs approximately every 5–6 years to realign the fiscal calendar with the Gregorian calendar. Impacts comparable store sales (SSS) comparisons and year-over-year financial analysis.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAdjustmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Adjustment Period' ;
    rdfs:comment 'Indicates whether this is a special adjustment period (periods 13–16 in SAP) used exclusively for year-end audit adjustments, accrual reversals, and FASB-required restatements. Adjustment periods do not correspond to calendar time.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQuarterEndPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Quarter End Period' ;
    rdfs:comment 'Indicates whether this period is the final period of a fiscal quarter, triggering quarterly close procedures, quarterly P&L reporting, and SEC 10-Q filing preparation for publicly traded retail entities.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isYearEndPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Year End Period' ;
    rdfs:comment 'Indicates whether this period is the final period of the fiscal year requiring year-end close procedures, including balance sheet finalization, retained earnings posting, and annual financial statement preparation per FASB standards.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mmPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Mm Posting Allowed' ;
    rdfs:comment 'Indicates whether materials management (MM) postings — including goods receipts, inventory adjustments, and COGS postings — are permitted for this financial period in SAP S/4HANA MM module. Critical for inventory valuation and COGS accuracy.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodCloseDate rdf:type rdf:Property ;
    rdfs:label 'Period Close Date' ;
    rdfs:comment 'The calendar date on which the financial period was officially closed in SAP S/4HANA FI, preventing further postings. Critical for financial close scheduling, audit compliance, and FASB revenue recognition cutoff enforcement.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodLengthDays rdf:type rdf:Property ;
    rdfs:label 'Period Length Days' ;
    rdfs:comment 'Number of calendar days in the financial period (typically 28 or 35 days for 4-week or 5-week NRF periods). Used for daily average calculations, proration of fixed costs, and lease accounting (ASC 842) period allocations.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name for the financial period (e.g., \'FY2024 Period 1\', \'Q1 FY2024 Week 1\', \'January 2024\'). Used in financial reports, P&L statements, and EBITDA dashboards for period labeling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodNumber rdf:type rdf:Property ;
    rdfs:label 'Period Number' ;
    rdfs:comment 'Sequential period number within the fiscal year (1–12 for regular periods, 13–16 for special/adjustment periods). Maps to SAP S/4HANA posting period (MONAT) in table BKPF. Controls which periods are open for posting in the general ledger.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodOpenDate rdf:type rdf:Property ;
    rdfs:label 'Period Open Date' ;
    rdfs:comment 'The calendar date on which the posting period was officially opened for journal entry postings in SAP S/4HANA FI. Used for financial close audit trails and compliance with FASB reporting timelines.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodShortCode rdf:type rdf:Property ;
    rdfs:label 'Period Short Code' ;
    rdfs:comment 'Standardized short code uniquely identifying the financial period across systems (e.g., \'FY2024P01\', \'FY2024P13\'). Used as a business key for cross-system integration between SAP S/4HANA, Oracle Retail Merchandising System (ORMS), and financial reporting tools.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Classification of the period by its accounting purpose. \'regular\' periods are standard operating periods; \'adjustment\' periods are used for year-end adjustments; \'closing\' periods are used for financial close entries; \'opening\' periods for balance carryforward; \'special\' for audit or correction postings.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarterName rdf:type rdf:Property ;
    rdfs:label 'Quarter Name' ;
    rdfs:comment 'Human-readable fiscal quarter label (e.g., \'Q1 FY2024\', \'Q4 FY2023\'). Used in financial reporting dashboards, investor relations materials, and comparable store sales (SSS/Comp Sales) analysis.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarterNumber rdf:type rdf:Property ;
    rdfs:label 'Quarter Number' ;
    rdfs:comment 'Fiscal quarter (1–4) to which this period belongs within the fiscal year. Used for quarterly P&L reporting, EBITDA tracking, and SEC/FASB quarterly financial disclosures.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reopenDate rdf:type rdf:Property ;
    rdfs:label 'Reopen Date' ;
    rdfs:comment 'The date on which a previously closed financial period was reopened for additional postings or corrections. Populated only when close_status is \'reopened\'. Supports audit trail requirements for FASB restatements.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reopenReason rdf:type rdf:Property ;
    rdfs:label 'Reopen Reason' ;
    rdfs:comment 'Business justification for reopening a previously closed financial period (e.g., \'Audit adjustment required\', \'Revenue recognition restatement per ASC 606\', \'Vendor chargeback correction\'). Required for SOX compliance and audit trail documentation.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCloseDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Close Date' ;
    rdfs:comment 'The planned/target date for completing the financial close process for this period, as defined in the financial close calendar. Used to track close cycle performance and SLA adherence for the finance operations team.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'The first calendar date of the financial period. Defines the inclusive lower boundary for transaction posting, revenue recognition (ASC 606), and financial close scheduling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:weekNumber rdf:type rdf:Property ;
    rdfs:label 'Week Number' ;
    rdfs:comment 'Fiscal week number within the fiscal year (1–52 or 1–53 for 53-week years). Critical for weekly retail performance reporting, same-store sales (SSS) comparisons, and Open-to-Buy (OTB) planning cycles.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalPostingTaxPostingId rdf:type rdf:Property ;
    rdfs:label 'Original Posting Tax Posting Id' ;
    rdfs:comment 'Reference to the original tax posting ID that this record reverses (populated only when reversal_flag is true).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxPosting .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Cross-reference to supporting documentation for tax audit defense (original invoice, receipt, exemption certificate, tax calculation log).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'The timestamp when this tax posting record was last modified (for correction postings or adjustments).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nexusIndicator rdf:type rdf:Property ;
    rdfs:label 'Nexus Indicator' ;
    rdfs:comment 'Flag indicating whether the retailer has established tax nexus (physical or economic presence) in this jurisdiction, triggering tax collection obligation.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reverseChargeFlag rdf:type rdf:Property ;
    rdfs:label 'Reverse Charge Flag' ;
    rdfs:comment 'Indicates whether this is a reverse charge VAT transaction where the customer is responsible for self-assessing and remitting VAT.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxAmountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Tax Amount Local Currency' ;
    rdfs:comment 'The tax amount converted to local reporting currency for financial statement consolidation.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Name' ;
    rdfs:comment 'The name of the government tax authority to which this tax will be remitted (e.g., California Department of Tax and Fee Administration, IRS).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Tax Determination Date' ;
    rdfs:comment 'The business event date used to determine applicable tax rates and jurisdiction (typically transaction date or delivery date).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxDirection rdf:type rdf:Property ;
    rdfs:label 'Tax Direction' ;
    rdfs:comment 'Indicates whether this is input tax (paid to suppliers) or output tax (collected from customers).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether this transaction qualified for tax exemption (e.g., resale certificate, government entity, non-profit exemption).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate Number' ;
    rdfs:comment 'The exemption certificate number provided by the customer to support tax-exempt status (resale certificate, government ID, non-profit certificate).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCity rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction City' ;
    rdfs:comment 'City or municipality name for city-level sales tax jurisdictions (applicable in US multi-jurisdiction tax scenarios).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCountry rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Country' ;
    rdfs:comment 'Three-letter ISO country code of the tax jurisdiction where the tax obligation arises.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCounty rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction County' ;
    rdfs:comment 'County or district name for county-level sales tax jurisdictions (applicable in US multi-jurisdiction tax scenarios).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionState rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction State' ;
    rdfs:comment 'Two-letter state or province code within the country for state-level sales tax (US) or provincial tax (Canada).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxPointDate rdf:type rdf:Property ;
    rdfs:label 'Tax Point Date' ;
    rdfs:comment 'The date when the tax liability arises for VAT purposes (typically invoice date or goods delivery date per VAT regulations).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'The effective tax rate percentage applied to the taxable base (e.g., 8.25000 for 8.25% sales tax).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Registration Number' ;
    rdfs:comment 'The retailer\'s tax registration number with the jurisdiction\'s tax authority (sales tax permit number, VAT registration number, GST number).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'The category of tax being posted (sales tax, VAT, use tax, excise duty, withholding tax, customs duty).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Base Amount' ;
    rdfs:comment 'The gross transaction amount subject to tax before tax calculation, in transaction currency.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the tax transaction was recorded.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcePurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Source Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to supplychain.purchase_order. Business justification: Retail drop-ship orders where vendor ships directly to customer require tracking the source supplier PO for cost reconciliation, vendor chargeback processing, and fulfillment exception handling. Essen' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'First line of the billing address associated with the payment method.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Second line of the billing address for apartment, suite, or unit number.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City or municipality for the billing address.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State, province, or region for the billing address.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Code' ;
    rdfs:comment 'Code identifying the shipping carrier or third-party logistics (3PL) provider handling delivery (e.g., UPS, FedEx, USPS).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerEmail rdf:type rdf:Property ;
    rdfs:label 'Customer Email' ;
    rdfs:comment 'Email address provided by the customer for order confirmation and communication.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPhone rdf:type rdf:Property ;
    rdfs:label 'Customer Phone' ;
    rdfs:comment 'Contact phone number for delivery coordination and customer service.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grandTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Grand Total Amount' ;
    rdfs:comment 'Final order total including subtotal, tax, shipping, minus discounts. Amount charged to customer payment method.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locale rdf:type rdf:Property ;
    rdfs:label 'Locale' ;
    rdfs:comment 'Language and regional locale for the order (e.g., en_US, fr_CA). Used for localized content and formatting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omsReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Oms Reference Code' ;
    rdfs:comment 'External reference identifier from the Order Management System for end-to-end order orchestration and tracking.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'Date committed to the customer for order delivery. Used for SLA compliance measurement.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line1' ;
    rdfs:comment 'First line of the shipping address including street number and name. Primary delivery location identifier.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line2' ;
    rdfs:comment 'Second line of the shipping address for apartment, suite, or unit number. Optional address detail.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCity rdf:type rdf:Property ;
    rdfs:label 'Shipping City' ;
    rdfs:comment 'City or municipality for the shipping address.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the shipping address (e.g., USA, CAN, GBR).' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the shipping address. Critical for carrier routing and delivery zone determination.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Shipping State Province' ;
    rdfs:comment 'State, province, or region for the shipping address. Used for tax jurisdiction and carrier routing.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Customer-provided delivery instructions or notes (e.g., gate code, leave at door, signature required).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualRuleId rdf:type rdf:Property ;
    rdfs:label 'Accrual Rule Id' ;
    rdfs:comment 'Foreign key linking to loyalty.accrual_rule. Business justification: Each order line earns points under a specific accrual rule (product category multiplier, promo bonus). Recording the applied rule per line enables points audit trails, member dispute resolution, and l' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccrualRule .

ind:buyingOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Buying Order Line Id' ;
    rdfs:comment 'Foreign key linking to merchandising.buying_order_line. Business justification: Sell-through and vendor performance reporting requires tracing customer order lines back to the buying order line that sourced the inventory. Retail merchandisers use this link to measure actual vs. p' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BuyingOrderLine .

ind:fulfillingLocationId rdf:type rdf:Property ;
    rdfs:label 'Fulfilling Location Id' ;
    rdfs:comment 'Foreign key linking to store.location. Business justification: Ship-from-store and BOPIS fulfillment: individual order lines can be fulfilled from different store locations. Store-level fulfillment attribution per line drives store inventory depletion, store P&L ' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:itemBundleId rdf:type rdf:Property ;
    rdfs:label 'Item Bundle Id' ;
    rdfs:comment 'Foreign key linking to product.item_bundle. Business justification: When a customer orders a product bundle, the order line must reference the bundle definition to enforce bundle pricing rules, validate component quantities, apply bundle discounts, and drive component' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItemBundle .

ind:memberOfferId rdf:type rdf:Property ;
    rdfs:label 'Member Offer Id' ;
    rdfs:comment 'Foreign key linking to loyalty.member_offer. Business justification: Each online/omnichannel order line may be fulfilled under a specific personalized member offer. Needed for offer attribution reporting, loyalty personalization ROI analysis, and member offer redemptio' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MemberOffer .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'Actual date when this line item was shipped from the fulfillment node. Used for SLA performance measurement and delivery estimation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backorderFlag rdf:type rdf:Property ;
    rdfs:label 'Backorder Flag' ;
    rdfs:comment 'Indicates whether this line item is on backorder due to insufficient inventory at order time. True if the item will be shipped when inventory becomes available.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Standardized code indicating why this line was cancelled. Populated only when line_status is CANCELLED. Enables root cause analysis of order cancellations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledQuantity rdf:type rdf:Property ;
    rdfs:label 'Cancelled Quantity' ;
    rdfs:comment 'Quantity cancelled and not fulfilled. Tracks partial cancellations where only a portion of the ordered quantity is cancelled.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costOfGoodsSold rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods Sold' ;
    rdfs:comment 'Unit cost of the product at the time of order fulfillment. Used for margin analysis and profitability reporting. Business-confidential financial data.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedShipDate rdf:type rdf:Property ;
    rdfs:label 'Expected Ship Date' ;
    rdfs:comment 'Planned date when this line item is expected to ship from the fulfillment node. Used for customer communication and Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extendedPrice rdf:type rdf:Property ;
    rdfs:label 'Extended Price' ;
    rdfs:comment 'Total price for this line item before discounts and taxes. Calculated as ordered_quantity multiplied by unit_retail_price.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentMethod rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Method' ;
    rdfs:comment 'Method by which this line will be fulfilled. Supports omnichannel fulfillment including ship-to-home, Buy Online Pick Up In Store (BOPIS), Reserve Online Pick Up In Store (ROPIS), Ship-from-Store (SFS), and drop-ship.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Flag' ;
    rdfs:comment 'Indicates whether this line item is marked as a gift. True if the customer designated this item for gift wrapping, gift messaging, or special handling.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gtin rdf:type rdf:Property ;
    rdfs:label 'Gtin' ;
    rdfs:comment '14-digit Global Trade Item Number. International standard for product identification across the supply chain.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginAmount rdf:type rdf:Property ;
    rdfs:label 'Margin Amount' ;
    rdfs:comment 'Gross margin for this line item calculated as line_total minus cost_of_goods_sold. Key metric for profitability analysis and Gross Margin Return on Investment (GMROI) calculations.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalSku rdf:type rdf:Property ;
    rdfs:label 'Original Sku' ;
    rdfs:comment 'Original SKU that was ordered by the customer, populated only when substitution_flag is true. Enables tracking of substitution patterns and customer acceptance rates.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationNotes rdf:type rdf:Property ;
    rdfs:label 'Personalization Notes' ;
    rdfs:comment 'Special instructions for product personalization such as monogramming, engraving, or custom text. Captured at order time and passed to fulfillment operations.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized code indicating why this line was returned by the customer. Populated when returned_quantity is greater than zero. Supports Return Merchandise Authorization (RMA) processing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnedQuantity rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity' ;
    rdfs:comment 'Quantity returned by the customer after delivery. Supports partial returns and links to Return Merchandise Authorization (RMA) processing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedQuantity rdf:type rdf:Property ;
    rdfs:label 'Shipped Quantity' ;
    rdfs:comment 'Actual quantity shipped to the customer. May differ from ordered_quantity due to partial fulfillment, substitutions, or inventory constraints.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Flag' ;
    rdfs:comment 'Indicates whether this line item is a substitution for an out-of-stock product. True if a substitute product was provided instead of the originally ordered item.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:total rdf:type rdf:Property ;
    rdfs:label 'Total' ;
    rdfs:comment 'Final total amount for this line item after discounts and taxes. Calculated as extended_price minus discount_amount plus tax_amount.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Status History Id' ;
    rdfs:comment 'Unique identifier for each status transition record in the order lifecycle. Primary key for the immutable audit trail.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'The exact date and time when the order was successfully delivered to the customer. Populated only for DELIVERED status. Critical for SLA compliance measurement.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignedToTeamCode rdf:type rdf:Property ;
    rdfs:label 'Assigned To Team Code' ;
    rdfs:comment 'Code identifying the team or department responsible for resolving this exception. Supports workload distribution and capacity planning.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByProcess rdf:type rdf:Property ;
    rdfs:label 'Created By Process' ;
    rdfs:comment 'Identifier of the ETL job, API call, or data ingestion process that created this record in the lakehouse. Supports data lineage and troubleshooting.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationChannel rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Channel' ;
    rdfs:comment 'The communication channel used to notify the customer of this status change. Null if no notification was sent.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent Flag' ;
    rdfs:comment 'Indicator of whether a customer notification (email, SMS, push) was sent for this status transition. Supports customer communication audit.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationInPreviousStatusMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration In Previous Status Minutes' ;
    rdfs:comment 'The number of minutes the order spent in the previous status before this transition. Enables stage-level performance analysis.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'Projected delivery date communicated to the customer at this status transition. Updated as the order progresses through fulfillment stages.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Sequence Number' ;
    rdfs:comment 'Sequential number indicating the order of status transitions for this order. Enables chronological sorting and gap detection.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionCategory rdf:type rdf:Property ;
    rdfs:label 'Exception Category' ;
    rdfs:comment 'High-level classification of the exception type. Enables exception trend analysis and root cause identification. [ENUM-REF-CANDIDATE: INVENTORY|PAYMENT|ADDRESS|CARRIER|FRAUD|QUALITY|SYSTEM|CUSTOMER|NONE — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Indicator of whether this status transition represents an exception or abnormal condition requiring intervention. True for statuses like FAILED, ON_HOLD, CANCELLED.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fulfillmentNodeType rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Node Type' ;
    rdfs:comment 'Classification of the fulfillment node handling this order stage. Supports omnichannel fulfillment strategy analysis. [ENUM-REF-CANDIDATE: STORE|DC|MFC|DARK_STORE|VENDOR|3PL|CROSS_DOCK — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStatusCode rdf:type rdf:Property ;
    rdfs:label 'Previous Status Code' ;
    rdfs:comment 'The status that the order was in immediately before this transition. Enables tracking of status flow and identifying invalid state transitions. [ENUM-REF-CANDIDATE: CREATED|CONFIRMED|ALLOCATED|PICKED|PACKED|SHIPPED|IN_TRANSIT|OUT_FOR_DELIVERY|DELIVERED|CANCELLED|RETURNED|REFUNDED|FAILED|ON_HOLD|BACKORDERED — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Resolution Required Flag' ;
    rdfs:comment 'Indicator of whether this status transition requires manual resolution or intervention. True for exceptions that cannot be auto-resolved.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaBreachDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Duration Minutes' ;
    rdfs:comment 'The number of minutes by which the SLA was breached. Null if no breach occurred. Enables quantitative analysis of service failures.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicator of whether this status transition violated the defined SLA target. True if transition occurred after the SLA target timestamp.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Target Timestamp' ;
    rdfs:comment 'The target date and time by which this status transition should have occurred per the service level agreement. Enables SLA breach detection.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceOrderChannel rdf:type rdf:Property ;
    rdfs:label 'Source Order Channel' ;
    rdfs:comment 'The originating channel through which the order was placed. Denormalized for performance in channel-specific SLA analysis. [ENUM-REF-CANDIDATE: WEB|MOBILE_APP|STORE|CALL_CENTER|MARKETPLACE|SOCIAL|KIOSK — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Source System Transaction Code' ;
    rdfs:comment 'Unique transaction or event identifier from the originating system. Enables end-to-end traceability and reconciliation across systems.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusCode rdf:type rdf:Property ;
    rdfs:label 'Status Code' ;
    rdfs:comment 'The new status that the order transitioned to at this point in time. Represents the current state in the order fulfillment lifecycle. [ENUM-REF-CANDIDATE: CREATED|CONFIRMED|ALLOCATED|PICKED|PACKED|SHIPPED|IN_TRANSIT|OUT_FOR_DELIVERY|DELIVERED|CANCELLED|RETURNED|REFUNDED|FAILED|ON_HOLD|BACKORDERED — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Code' ;
    rdfs:comment 'Standardized code explaining why the status transition occurred. Enables root cause analysis for exceptions and delays. [ENUM-REF-CANDIDATE: CUSTOMER_REQUEST|INVENTORY_UNAVAILABLE|PAYMENT_FAILED|ADDRESS_INVALID|CARRIER_DELAY|SYSTEM_ERROR|FRAUD_DETECTED|QUALITY_ISSUE|DAMAGED_IN_TRANSIT|CUSTOMER_REFUSED|BUSINESS_RULE|MANUAL_OVERRIDE|AUTOMATED_PROCESS — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Description' ;
    rdfs:comment 'Free-text explanation providing additional context for the status transition. Captures details not covered by the standardized reason code.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Timestamp' ;
    rdfs:comment 'The exact date and time when the order status changed to the new status. Critical for SLA (Service Level Agreement) tracking and customer-facing order tracking.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:triggeringSystemCode rdf:type rdf:Property ;
    rdfs:label 'Triggering System Code' ;
    rdfs:comment 'Identifier of the system or application that initiated this status transition. Enables system-level performance analysis and troubleshooting. [ENUM-REF-CANDIDATE: OMS|WMS|TMS|POS|ECOM|CARRIER_API|PAYMENT_GATEWAY|FRAUD_ENGINE|CSR_PORTAL|BATCH_JOB|EDI|MOBILE_APP — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringUserName rdf:type rdf:Property ;
    rdfs:label 'Triggering User Name' ;
    rdfs:comment 'Display name of the user who triggered the status change. Provides human-readable context for manual interventions.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTransactionPosTransactionId rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Pos Transaction Id' ;
    rdfs:comment 'Reference to the original POS transaction being returned or exchanged when transaction_type is return or exchange.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosTransaction .

ind:primaryPosLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Pos Location Id' ;
    rdfs:comment 'Identifier of the retail store location where the transaction occurred.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:businessDate rdf:type rdf:Property ;
    rdfs:label 'Business Date' ;
    rdfs:comment 'Retail business day to which this transaction is attributed for financial reporting. May differ from transaction timestamp for transactions after store closing but before end-of-day processing.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:changeAmount rdf:type rdf:Property ;
    rdfs:label 'Change Amount' ;
    rdfs:comment 'Cash change returned to the customer when tender_amount exceeds total_amount.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:couponCount rdf:type rdf:Property ;
    rdfs:label 'Coupon Count' ;
    rdfs:comment 'Number of coupons redeemed in the transaction including manufacturer coupons and store coupons.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Fiscal Receipt Number' ;
    rdfs:comment 'Government-mandated fiscal receipt identifier for tax compliance and audit purposes. Required in jurisdictions with fiscal receipt regulations.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyCardNumber rdf:type rdf:Property ;
    rdfs:label 'Loyalty Card Number' ;
    rdfs:comment 'Loyalty program card number scanned during the transaction for points accrual and customer identification.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Manager Override Flag' ;
    rdfs:comment 'Indicates whether a manager override was required during the transaction for actions such as large discounts, voids, or policy exceptions.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentMethodCount rdf:type rdf:Property ;
    rdfs:label 'Payment Method Count' ;
    rdfs:comment 'Number of distinct payment methods used in the transaction. Supports split-tender analysis.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionCount rdf:type rdf:Property ;
    rdfs:label 'Promotion Count' ;
    rdfs:comment 'Number of distinct promotions applied to the transaction. Used for promotional effectiveness analysis.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receiptEmail rdf:type rdf:Property ;
    rdfs:label 'Receipt Email' ;
    rdfs:comment 'Email address provided by the customer for digital receipt delivery.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptPhone rdf:type rdf:Property ;
    rdfs:label 'Receipt Phone' ;
    rdfs:comment 'Phone number provided by the customer for SMS receipt delivery or order pickup notifications.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registerNumber rdf:type rdf:Property ;
    rdfs:label 'Register Number' ;
    rdfs:comment 'Physical register or checkout lane number within the store where the transaction was processed.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenderAmount rdf:type rdf:Property ;
    rdfs:label 'Tender Amount' ;
    rdfs:comment 'Total amount tendered by the customer across all payment methods. May exceed total_amount when cash change is given.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingModeFlag rdf:type rdf:Property ;
    rdfs:label 'Training Mode Flag' ;
    rdfs:comment 'Indicates whether the transaction was processed in training mode for new cashier onboarding. Training transactions are excluded from financial reporting.' ;
    rdfs:domain ind:PosTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:voidReasonCode rdf:type rdf:Property ;
    rdfs:label 'Void Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for voiding the transaction when transaction_status is voided. Used for fraud detection and operational quality monitoring.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ean rdf:type rdf:Property ;
    rdfs:label 'Ean' ;
    rdfs:comment '13-digit European Article Number for international product identification. Used for global product tracking and cross-border commerce.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Human-readable description of the product as it appears on the receipt. Includes brand, product name, size, and variant details.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netLineAmount rdf:type rdf:Property ;
    rdfs:label 'Net Line Amount' ;
    rdfs:comment 'Net amount for this line item after markdown but before tax. Calculated as extended price minus markdown amount.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:privateLabelFlag rdf:type rdf:Property ;
    rdfs:label 'Private Label Flag' ;
    rdfs:comment 'Indicates whether this product is a store brand or private label item. True for private label, false for national brands.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantitySold rdf:type rdf:Property ;
    rdfs:label 'Quantity Sold' ;
    rdfs:comment 'Number of units sold for this line item. Supports fractional quantities for variable-weight items such as produce and deli products.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnFlag rdf:type rdf:Property ;
    rdfs:label 'Return Flag' ;
    rdfs:comment 'Indicates whether this line item represents a product return. True for returned items, false for normal sales.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scannedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scanned Timestamp' ;
    rdfs:comment 'Date and time when this item was scanned or entered at the point of sale. Used for transaction timing analysis and basket sequence.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalLineAmount rdf:type rdf:Property ;
    rdfs:label 'Total Line Amount' ;
    rdfs:comment 'Final total amount for this line item including tax. Sum of net line amount and tax amount.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidedFlag rdf:type rdf:Property ;
    rdfs:label 'Voided Flag' ;
    rdfs:comment 'Indicates whether this line item was voided or cancelled during the transaction. True for voided items, false for completed sales.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightActual rdf:type rdf:Property ;
    rdfs:label 'Weight Actual' ;
    rdfs:comment 'Actual weight of variable-weight items measured at point of sale. Captured for produce, deli, meat, and bakery items sold by weight.' ;
    rdfs:domain ind:PosTransactionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Unit' ;
    rdfs:comment 'Unit of measure for the actual weight. Indicates whether weight is measured in pounds, kilograms, ounces, or grams.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Unique identifier for the payment tender record. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:giftCardId rdf:type rdf:Property ;
    rdfs:label 'Gift Card Id' ;
    rdfs:comment 'Masked or tokenized gift card number used for this payment tender. Applicable only when payment method type is gift card.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GiftCard .

ind:redemptionId rdf:type rdf:Property ;
    rdfs:label 'Redemption Id' ;
    rdfs:comment 'Foreign key linking to loyalty.redemption. Business justification: Payments made via \'pay with points\' (loyalty redemption as tender) must link to the specific redemption event. Enables payment reconciliation reports, fraud detection for points-as-payment, and loyalt' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Redemption .

ind:bnplProvider rdf:type rdf:Property ;
    rdfs:label 'Bnpl Provider' ;
    rdfs:comment 'Name of the Buy Now Pay Later (BNPL) service provider (e.g., Affirm, Klarna, Afterpay). Applicable only when payment method type is BNPL.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardBrand rdf:type rdf:Property ;
    rdfs:label 'Card Brand' ;
    rdfs:comment 'Brand or network of the payment card used (e.g., Visa, Mastercard, American Express, Discover). Applicable only when payment method type is credit or debit card. [ENUM-REF-CANDIDATE: visa|mastercard|amex|discover|jcb|diners_club|unionpay — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderName rdf:type rdf:Property ;
    rdfs:label 'Cardholder Name' ;
    rdfs:comment 'Name of the cardholder as it appears on the payment card. Used for verification and fraud prevention. Stored securely per PCI DSS and GDPR requirements.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalWalletType rdf:type rdf:Property ;
    rdfs:label 'Digital Wallet Type' ;
    rdfs:comment 'Type of digital wallet used for this payment tender (e.g., Apple Pay, Google Pay, Samsung Pay, PayPal, Venmo). Applicable only when payment method type is digital wallet.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudDecision rdf:type rdf:Property ;
    rdfs:label 'Fraud Decision' ;
    rdfs:comment 'Decision outcome from fraud detection system. Indicates whether the payment was approved, declined, flagged for manual review, or challenged with additional authentication.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maskedPan rdf:type rdf:Property ;
    rdfs:label 'Masked Pan' ;
    rdfs:comment 'Masked or truncated version of the payment card Primary Account Number (PAN), typically showing only the last four digits (e.g., ****1234). Used for display and customer service without exposing full card number.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodType rdf:type rdf:Property ;
    rdfs:label 'Method Type' ;
    rdfs:comment 'Type of payment instrument used for this tender. Includes credit card, debit card, gift card, loyalty points, BNPL (Buy Now Pay Later), cash, digital wallet (e.g., Apple Pay, Google Pay), or check. [ENUM-REF-CANDIDATE: credit_card|debit_card|gift_card|loyalty_points|bnpl|cash|digital_wallet|check — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Processor Reference Code' ;
    rdfs:comment 'Unique transaction identifier assigned by the payment gateway or processor. Used for tracing and reconciliation with external payment systems.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Settlement Timestamp' ;
    rdfs:comment 'Date and time when the payment was settled and funds were transferred from the customer\'s account to the merchant\'s account. Final step in payment lifecycle.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tenderSequence rdf:type rdf:Property ;
    rdfs:label 'Tender Sequence' ;
    rdfs:comment 'Sequence number indicating the order in which this payment tender was applied in a split-tender scenario. First tender is 1, second is 2, etc.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:threeDsAuthenticationResult rdf:type rdf:Property ;
    rdfs:label 'Three Ds Authentication Result' ;
    rdfs:comment 'Result of 3-D Secure (3DS) authentication protocol for card-not-present transactions. Indicates whether cardholder was successfully authenticated, reducing fraud liability.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:token rdf:type rdf:Property ;
    rdfs:label 'Token' ;
    rdfs:comment 'Tokenized reference to the payment instrument, replacing sensitive card data. Token is generated by PCI DSS compliant tokenization service and used for recurring payments or stored payment methods.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountId rdf:type rdf:Property ;
    rdfs:label 'Discount Id' ;
    rdfs:comment 'Primary key for discount' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedAtLevel rdf:type rdf:Property ;
    rdfs:label 'Applied At Level' ;
    rdfs:comment 'Indicates whether the discount was applied at the order header level (affecting the entire order) or at the line item level (affecting a specific product).' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Applied Timestamp' ;
    rdfs:comment 'The date and time when the discount was applied to the order or line item. Represents the business event time of discount application.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discountCode rdf:type rdf:Property ;
    rdfs:label 'Discount Code' ;
    rdfs:comment 'The promotional code, coupon code, or discount identifier entered or applied by the customer or system. Examples include promo codes, loyalty reward codes, employee discount codes.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountMethod rdf:type rdf:Property ;
    rdfs:label 'Discount Method' ;
    rdfs:comment 'The calculation method used to determine the discount value. Indicates whether the discount is a percentage off, fixed dollar amount, tiered based on quantity or spend, Buy One Get One (BOGO) offer, or free shipping.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'Classification of the discount mechanism. Indicates the nature of the discount applied (e.g., coupon, promotional code, loyalty reward, markdown, Buy One Get One (BOGO), clearance, employee discount, volume discount, seasonal promotion, bundle discount, price override, manager override). [ENUM-REF-CANDIDATE: coupon|promo_code|loyalty_reward|markdown|bogo|clearance|employee_discount|volume_discount|seasonal_promotion|bundle_discount|price_override|manager_override — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalPrice rdf:type rdf:Property ;
    rdfs:label 'Final Price' ;
    rdfs:comment 'The final price after the discount has been applied. Represents the net amount the customer pays for the discounted item or order.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentage rdf:type rdf:Property ;
    rdfs:label 'Percentage' ;
    rdfs:comment 'The percentage discount applied to the order or line item. Populated when discount_method is percentage. Expressed as a decimal (e.g., 15.00 for 15% off).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemDiscountCode rdf:type rdf:Property ;
    rdfs:label 'Source System Discount Code' ;
    rdfs:comment 'The unique identifier for this discount record in the source system. Used for traceability and reconciliation with upstream systems.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackableFlag rdf:type rdf:Property ;
    rdfs:label 'Stackable Flag' ;
    rdfs:comment 'Indicates whether this discount can be combined (stacked) with other discounts on the same order or line item. True if stackable, False if exclusive.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxTreatmentFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment Flag' ;
    rdfs:comment 'Indicates whether the discount is applied before tax calculation (pre-tax) or after tax calculation (post-tax). Affects the taxable amount and final tax computation.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableAmountAdjustment rdf:type rdf:Property ;
    rdfs:label 'Taxable Amount Adjustment' ;
    rdfs:comment 'The adjustment to the taxable base amount resulting from this discount. Used to recalculate sales tax when discount affects the tax basis.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rmaId rdf:type rdf:Property ;
    rdfs:label 'Rma Id' ;
    rdfs:comment 'Foreign key linking to returns.rma. Business justification: Post-shipment cancellations generate RMAs for already-shipped items. Linking cancellation to rma enables post-shipment cancellation workflows, refund reconciliation, and inventory recovery tracking. R' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rma .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether the cancellation requires managerial or supervisory approval before execution. True for high-value orders or policy exceptions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationNumber rdf:type rdf:Property ;
    rdfs:label 'Cancellation Number' ;
    rdfs:comment 'Business-facing unique cancellation reference number used for customer communication and tracking. Format: CXL-XXXXXXXXXX.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationStatus rdf:type rdf:Property ;
    rdfs:label 'Cancellation Status' ;
    rdfs:comment 'Current processing status of the cancellation request. Tracks the cancellation through its approval and execution workflow.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Date and time when the cancellation was initiated or requested. Represents the business event time of the cancellation action.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancelledAmount rdf:type rdf:Property ;
    rdfs:label 'Cancelled Amount' ;
    rdfs:comment 'Total order or line value that was cancelled, including product cost, taxes, and fees. Represents the gross cancelled transaction value.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Timestamp' ;
    rdfs:comment 'Date and time when the cancellation confirmation notification was sent to the customer. Null if notification not sent or failed.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Administrative or processing fee charged for the cancellation. Zero if no cancellation fee applies per business policy or customer segment.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Flag' ;
    rdfs:comment 'Indicates whether the cancellation was triggered by fraud detection rules or suspected fraudulent activity. True if fraud-related cancellation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatorType rdf:type rdf:Property ;
    rdfs:label 'Initiator Type' ;
    rdfs:comment 'Category of entity that initiated the cancellation. Distinguishes between customer-initiated, system-initiated, agent-initiated, and automated rule-based cancellations.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inventory Release Timestamp' ;
    rdfs:comment 'Date and time when allocated inventory was released back to available stock following the cancellation. Null if inventory was never allocated or not yet released.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inventoryReleasedFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Released Flag' ;
    rdfs:comment 'Indicates whether inventory allocated to the cancelled order or line has been released back to available stock. True if inventory release confirmed.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingSystemCode rdf:type rdf:Property ;
    rdfs:label 'Processing System Code' ;
    rdfs:comment 'Identifier of the system or automated process that executed the cancellation. Used for system-initiated cancellations to track which rule engine or service triggered the action.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Refund Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the refund amount. Indicates the currency in which the refund will be processed.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Refund Eligible Flag' ;
    rdfs:comment 'Indicates whether the cancelled order or line is eligible for a refund based on payment status and business rules. True if refund should be processed.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundMethod rdf:type rdf:Property ;
    rdfs:label 'Refund Method' ;
    rdfs:comment 'Method by which the refund will be issued to the customer. Typically matches the original payment method but may differ based on business rules.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundProcessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Processed Timestamp' ;
    rdfs:comment 'Date and time when the refund was successfully processed and submitted to the payment gateway or finance system. Null if refund not yet processed.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restockingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Amount' ;
    rdfs:comment 'Fee charged to the customer for cancelling the order after certain fulfillment stages. Zero if no restocking fee applies per business policy.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Free-text explanation of why the cancellation was reversed. Captures business justification for reinstating the order.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'Date and time when the cancellation was reversed and the order reinstated. Null if no reversal occurred.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Order fulfillment stage at which the cancellation occurred. Indicates how far the order progressed before cancellation and impacts inventory release and refund processing.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'The channel through which the customer was originally acquired, used for CAC (Customer Acquisition Cost) analysis and channel effectiveness measurement.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date when the customer first engaged with the business, marking the start of the customer lifecycle.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cacAmount rdf:type rdf:Property ;
    rdfs:label 'Cac Amount' ;
    rdfs:comment 'Total cost incurred to acquire this customer, including marketing spend, promotional discounts, and channel costs. Used for CLTV (Customer Lifetime Value) to CAC ratio analysis.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ccpaOptOutDate rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Date' ;
    rdfs:comment 'Timestamp when CCPA opt-out request was processed, required for compliance audit trails.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ccpaOptOutFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted out of personal data sale under CCPA regulations.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cltvScore rdf:type rdf:Property ;
    rdfs:label 'Cltv Score' ;
    rdfs:comment 'Predicted total revenue value this customer will generate over their entire relationship with the business, calculated using RFM (Recency Frequency Monetary) models and predictive analytics.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerType rdf:type rdf:Property ;
    rdfs:label 'Customer Type' ;
    rdfs:comment 'Classification of customer as individual consumer (B2C) or corporate buyer (B2B), including special categories such as employee or VIP.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Date of birth of the customer, used for age verification, lifecycle marketing, and personalized birthday promotions.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for customer communication across all channels including e-commerce, loyalty programs, and promotional campaigns.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Email Opt In Flag' ;
    rdfs:comment 'Boolean flag indicating customer consent to receive promotional emails and newsletters.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeFlag rdf:type rdf:Property ;
    rdfs:label 'Employee Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer is an employee eligible for employee discount programs.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Legal first name or given name of the customer as recorded in the master data management system.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Complete legal name of the customer, typically concatenated from first, middle, and last name components.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Date' ;
    rdfs:comment 'Timestamp when GDPR consent was granted by the customer, required for compliance audit trails.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer has provided explicit consent for data processing under GDPR requirements.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Self-identified gender of the customer, used for personalized merchandising and assortment planning.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Interaction Date' ;
    rdfs:comment 'Date of the customer\'s most recent interaction with the business across any touchpoint including POS, e-commerce, mobile app, or customer service.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Legal last name or family name of the customer as recorded in the master data management system.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'Date of the customer\'s most recent purchase transaction across all channels, used for recency analysis in RFM (Recency Frequency Monetary) segmentation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current stage in the customer lifecycle journey, used for targeted marketing campaigns and retention strategies. [ENUM-REF-CANDIDATE: prospect|new|active|at_risk|dormant|churned|reactivated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyTier rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier' ;
    rdfs:comment 'Current tier level in the loyalty program, determining benefits, discounts, and personalized services.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Consent Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer has consented to receive marketing communications including email, SMS, and direct mail.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mdmConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Mdm Confidence Score' ;
    rdfs:comment 'Confidence score (0-100) from Informatica MDM indicating the quality and reliability of the golden record match and data completeness.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mdmLastMatchDate rdf:type rdf:Property ;
    rdfs:label 'Mdm Last Match Date' ;
    rdfs:comment 'Timestamp of the last MDM matching and survivorship process execution that updated this golden record.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the customer. Nullable field for customers without a middle name.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile phone number used for SMS notifications, mobile app authentication, and last-mile delivery coordination.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the customer\'s nationality or citizenship.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Most recent Net Promoter Score indicating customer satisfaction and likelihood to recommend, scored from -100 to 100.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Customer\'s preferred method for receiving communications and notifications from the business.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-2 three-letter language code representing the customer\'s preferred language for communication and marketing materials.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current operational status of the customer profile, controlling access to services and transactions across all channels.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Sms Opt In Flag' ;
    rdfs:comment 'Boolean flag indicating customer consent to receive promotional SMS messages and mobile notifications.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vipFlag rdf:type rdf:Property ;
    rdfs:label 'Vip Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer is designated as a VIP for special clienteling services and exclusive offers.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignedBuyerId rdf:type rdf:Property ;
    rdfs:label 'Assigned Buyer Id' ;
    rdfs:comment 'Foreign key linking to merchandising.buyer. Business justification: In B2B retail, customer accounts are assigned a dedicated merchandising buyer who manages product selection and vendor negotiations on their behalf. This account-level buyer assignment drives B2B acco' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Buyer .

ind:billingAddressId rdf:type rdf:Property ;
    rdfs:label 'Billing Address Id' ;
    rdfs:comment 'Reference to the default billing address for this account. Used for invoicing, credit checks, and payment processing. Null if no billing address on file.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:defaultStorefrontId rdf:type rdf:Property ;
    rdfs:label 'Default Storefront Id' ;
    rdfs:comment 'Foreign key linking to ecommerce.storefront. Business justification: B2B account default storefront assignment: corporate accounts are routed to dedicated storefronts (procurement portals, wholesale channels). Retail B2B operations use account-storefront assignment for' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Storefront .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Service tier or membership level of the account, determining benefits, discounts, and service priority. Standard is base tier; premium, VIP, and platinum offer escalating benefits.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:b2bPricingFlag rdf:type rdf:Property ;
    rdfs:label 'B2b Pricing Flag' ;
    rdfs:comment 'Indicates whether this account receives B2B contract pricing instead of standard retail pricing. True for wholesale and corporate accounts; false for consumer accounts.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum credit amount (in base currency) extended to this account for deferred payment or credit purchases. Null for cash-only accounts. Used for credit management and risk assessment.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent' ;
    rdfs:comment 'Indicates whether the account holder has consented to sharing their data with third-party partners for analytics, advertising, or personalization. True if consented; false otherwise. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeDiscountEligible rdf:type rdf:Property ;
    rdfs:label 'Employee Discount Eligible' ;
    rdfs:comment 'Indicates whether this account is eligible for employee discount pricing. True for employee accounts and authorized family members; false otherwise.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'Date of the most recent purchase or transaction on this account. Used for recency analysis, dormancy detection, and customer lifecycle segmentation (RFM analysis).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether the account holder has consented to receive marketing communications (email, SMS, direct mail). True if opted in; false if opted out. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingOptInDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Date' ;
    rdfs:comment 'Timestamp when the account holder provided marketing consent. Null if never opted in. Used for consent audit trail and compliance reporting.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:marketingOptOutDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt Out Date' ;
    rdfs:comment 'Timestamp when the account holder withdrew marketing consent. Null if currently opted in or never opted in. Used for consent audit trail and compliance reporting.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Current outstanding balance owed by the account holder (in base currency). Positive values indicate amounts owed to Retail; negative values indicate credit balances. Used for accounts receivable and collections.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Channel' ;
    rdfs:comment 'Customer\'s preferred interaction channel for shopping and service. Used for omnichannel routing, personalized marketing, and channel-specific offers.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'Date when the account was most recently suspended. Null if never suspended or currently active. Used for compliance and risk management reporting.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Free-text explanation of why the account was suspended (e.g., payment default, fraud investigation, customer request, policy violation). Null if never suspended.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Certificate Number' ;
    rdfs:comment 'Government-issued tax exemption certificate number for tax-exempt accounts. Null for non-exempt accounts. Required for audit and compliance verification.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Expiry Date' ;
    rdfs:comment 'Expiration date of the tax exemption certificate. Null for non-exempt accounts or perpetual exemptions. Used for compliance monitoring and renewal reminders.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalLifetimeOrders rdf:type rdf:Property ;
    rdfs:label 'Total Lifetime Orders' ;
    rdfs:comment 'Cumulative count of all orders placed by this account since inception. Used for frequency analysis in RFM segmentation and customer value scoring.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Unique identifier for the contact method record. Primary key.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:bounceCount rdf:type rdf:Property ;
    rdfs:label 'Bounce Count' ;
    rdfs:comment 'The cumulative number of times communication attempts via this contact method have bounced or failed. Used to trigger contact validation workflows and suppress invalid addresses.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentSource rdf:type rdf:Property ;
    rdfs:label 'Consent Source' ;
    rdfs:comment 'The channel or touchpoint where the customer provided consent for this contact method (e.g., web registration, mobile app, POS, call center, in-store signup). Supports consent audit trails. [ENUM-REF-CANDIDATE: web|mobile_app|pos|call_center|email|in_store|third_party — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact method. Active indicates usable for communication; bounced/invalid indicates delivery failure; suppressed indicates customer request or compliance block; pending_verification indicates awaiting confirmation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'The type or category of contact method (e.g., primary email, mobile phone, work phone, WhatsApp, SMS, fax). Determines the channel and priority for omnichannel outreach. [ENUM-REF-CANDIDATE: primary_email|secondary_email|mobile|home_phone|work_phone|whatsapp|sms|fax — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactValue rdf:type rdf:Property ;
    rdfs:label 'Contact Value' ;
    rdfs:comment 'The actual contact point value: email address, phone number, or social media handle. This is the primary data element used for customer communication and CRM campaigns via Salesforce Service Cloud. Classified as restricted PII as it may contain email, phone, or other personal identifiers.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Boolean flag indicating whether this is the primary contact method for the customer. Used to prioritize communication channels in omnichannel campaigns and clienteling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Boolean flag indicating whether the contact method has been verified (e.g., email verification link clicked, phone number confirmed via OTP). Ensures data quality for marketing and transactional communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the customers preferred language for communications via this contact method (e.g., en, es, fr). Supports personalized omnichannel outreach.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastBounceDate rdf:type rdf:Property ;
    rdfs:label 'Last Bounce Date' ;
    rdfs:comment 'The date of the most recent bounce or delivery failure for this contact method. Nullable if no bounces have occurred.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'The date when this contact method was last successfully used for customer communication (email sent, SMS delivered, call completed). Helps identify stale or inactive contact points.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInDate rdf:type rdf:Property ;
    rdfs:label 'Opt In Date' ;
    rdfs:comment 'The date when the customer provided consent for communication via this contact method. Required for audit trails under GDPR and CCPA.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInMarketing rdf:type rdf:Property ;
    rdfs:label 'Opt In Marketing' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive marketing communications via this contact method. Critical for GDPR and CCPA consent enforcement.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInTransactional rdf:type rdf:Property ;
    rdfs:label 'Opt In Transactional' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive transactional communications (order confirmations, shipping updates, receipts) via this contact method.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optOutDate rdf:type rdf:Property ;
    rdfs:label 'Opt Out Date' ;
    rdfs:comment 'The date when the customer withdrew consent or opted out of communications via this contact method. Nullable if customer has not opted out.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date when the contact method was last verified by the customer. Used to track data freshness and trigger re-verification workflows.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Unique identifier for the address record. Primary key.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active addresses are available for use in orders and shipments.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of the address purpose: billing, shipping, store pickup (BOPIS/ROPIS), home, work, or mailing.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Special delivery instructions provided by the customer (e.g., gate code, leave at door, ring bell).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPointBarcode rdf:type rdf:Property ;
    rdfs:label 'Delivery Point Barcode' ;
    rdfs:comment 'USPS Delivery Point Barcode (DPBC) or equivalent postal barcode for automated mail sorting and delivery.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultBilling rdf:type rdf:Property ;
    rdfs:label 'Is Default Billing' ;
    rdfs:comment 'Flag indicating whether this address is the default billing address for the customer.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultShipping rdf:type rdf:Property ;
    rdfs:label 'Is Default Shipping' ;
    rdfs:comment 'Flag indicating whether this address is the default shipping destination for the customer.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line including street number, street name, and unit/apartment number.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for additional location details such as building name, floor, suite, or department.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:militaryAddressFlag rdf:type rdf:Property ;
    rdfs:label 'Military Address Flag' ;
    rdfs:comment 'Indicates whether the address is a military address (APO/FPO/DPO). Requires special handling for international military mail.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nickname rdf:type rdf:Property ;
    rdfs:label 'Nickname' ;
    rdfs:comment 'Customer-provided friendly name for the address (e.g., Home, Office, Mom\'s House) for easy identification.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poBoxFlag rdf:type rdf:Property ;
    rdfs:label 'Po Box Flag' ;
    rdfs:comment 'Indicates whether the address is a PO Box. Some carriers and products cannot deliver to PO Boxes.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residentialFlag rdf:type rdf:Property ;
    rdfs:label 'Residential Flag' ;
    rdfs:comment 'Indicates whether the address is a residential location (true) or commercial/business location (false). Impacts shipping rates and delivery windows.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardizationFlag rdf:type rdf:Property ;
    rdfs:label 'Standardization Flag' ;
    rdfs:comment 'Indicates whether the address has been standardized to postal service formatting rules (USPS Publication 28, etc.).' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Status of address validation against postal service standards (USPS, Canada Post, etc.). Validated addresses reduce delivery failures.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Timestamp when the address was last verified against postal service databases or address validation services.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Primary key for segment' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandAffinityProductBrandId rdf:type rdf:Property ;
    rdfs:label 'Brand Affinity Product Brand Id' ;
    rdfs:comment 'Foreign key linking to product.product_brand. Business justification: Brand-affinity segmentation is a core retail CRM process — segments like \'premium brand loyalists\' or \'private label shoppers\' are defined by brand preference. This FK enables brand-targeted campaign ' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:preferredCategoryId rdf:type rdf:Property ;
    rdfs:label 'Preferred Category Id' ;
    rdfs:comment 'Foreign key linking to merchandising.category. Business justification: Customer segments defined by category affinity ("Premium Electronics Buyers", "Organic Enthusiasts") for category-targeted campaigns and segment-aware assortment planning. Replaces denormalized prefer' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:preferredItemHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Preferred Item Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to product.item_hierarchy. Business justification: Customer segments are often defined by product category affinity. Existing \'preferred_product_category\' text field should be proper FK to item_hierarchy for segment-based assortment planning, targeted' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItemHierarchy .

ind:autoRefreshFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Refresh Flag' ;
    rdfs:comment 'Indicates whether customer membership in this segment is automatically recalculated on a scheduled basis (True) or manually managed (False). True for dynamic segments (e.g., RFM tiers recalculated nightly); False for static segments (e.g., one-time campaign lists).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageAov rdf:type rdf:Property ;
    rdfs:label 'Average Aov' ;
    rdfs:comment 'Mean Average Order Value for customers in this segment over the measurement period. Key metric for pricing strategy, promotion design, and basket optimization. Expressed in base currency (USD).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageCltv rdf:type rdf:Property ;
    rdfs:label 'Average Cltv' ;
    rdfs:comment 'Mean Customer Lifetime Value across all customers currently assigned to this segment. Used for segment valuation, investment prioritization, and ROI forecasting. Expressed in base currency (USD).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averagePurchaseFrequency rdf:type rdf:Property ;
    rdfs:label 'Average Purchase Frequency' ;
    rdfs:comment 'Mean number of transactions per customer in this segment over the measurement period (typically 12 months). Used for replenishment forecasting, loyalty program design, and churn prediction.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:b2bB2cIndicator rdf:type rdf:Property ;
    rdfs:label 'B2b B2c Indicator' ;
    rdfs:comment 'Indicates whether this segment applies to B2B customers (business accounts, wholesale, corporate), B2C customers (individual consumers), or both. Drives differentiated engagement strategies, pricing models, and service levels.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaOptOutHonoredFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Honored Flag' ;
    rdfs:comment 'Indicates whether this segment respects CCPA \'Do Not Sell My Personal Information\' opt-out requests (True) or is exempt (False, e.g., service-related communications). Ensures compliance for California residents.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:churnRiskScore rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Score' ;
    rdfs:comment 'Aggregate churn risk score for this segment, ranging from 0.00 (no risk) to 100.00 (high risk). Calculated from recency, frequency, and engagement metrics. Drives retention campaign prioritization and at-risk customer interventions.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountSensitivity rdf:type rdf:Property ;
    rdfs:label 'Discount Sensitivity' ;
    rdfs:comment 'Behavioral classification of segment\'s responsiveness to promotional pricing. High: primarily purchases on promotion (Hi-Lo shoppers). Medium: balanced full-price and promotional purchases. Low: primarily full-price purchases (EDLP preference or premium segment).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Required Flag' ;
    rdfs:comment 'Indicates whether explicit customer consent is required under GDPR for marketing communications to this segment (True) or whether legitimate interest or other legal basis applies (False). Ensures regulatory compliance for EU customers.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Geographic boundary or region to which this segment applies (e.g., \'USA\', \'Northeast Region\', \'Urban Markets\', \'Global\'). Supports localized segmentation strategies and regional campaign targeting. Use ISO 3166-1 alpha-3 country codes where applicable.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Timestamp' ;
    rdfs:comment 'Date and time when segment membership was last recalculated and customer assignments were updated. Critical for data freshness validation and SLA monitoring.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxRfmScore rdf:type rdf:Property ;
    rdfs:label 'Max Rfm Score' ;
    rdfs:comment 'Maximum RFM composite score for customer assignment to this segment (if segment_type is rfm_tier). Defines the upper bound of the RFM tier. Null for non-RFM segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:membershipCount rdf:type rdf:Property ;
    rdfs:label 'Membership Count' ;
    rdfs:comment 'Current count of customers assigned to this segment. Updated periodically based on auto-refresh schedule. Used for segment sizing, campaign planning, and capacity forecasting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minRfmScore rdf:type rdf:Property ;
    rdfs:label 'Min Rfm Score' ;
    rdfs:comment 'Minimum RFM composite score required for customer assignment to this segment (if segment_type is rfm_tier). RFM scores typically range from 3 (lowest: 1-1-1) to 15 (highest: 5-5-5). Null for non-RFM segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:owningBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Owning Business Unit' ;
    rdfs:comment 'Name of the business unit or department responsible for defining, maintaining, and governing this segment (e.g., \'Marketing Analytics\', \'Customer Insights\', \'Loyalty Program Management\'). Establishes accountability for segment quality and usage.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityTier rdf:type rdf:Property ;
    rdfs:label 'Priority Tier' ;
    rdfs:comment 'Service and engagement priority level assigned to this segment. Platinum: highest CLTV, white-glove service. Gold: high-value, priority support. Silver: mid-value, standard service. Bronze: emerging value. Standard: baseline service. Drives clienteling strategies and resource allocation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCriteria rdf:type rdf:Property ;
    rdfs:label 'Qualification Criteria' ;
    rdfs:comment 'Summary of the business rules and thresholds used to assign customers to this segment (e.g., \'Purchased in last 30 days AND total spend > $5000 in last 12 months\', \'RFM Score >= 9\', \'Age 25-34 AND lives in urban area\'). Human-readable representation of the segmentation logic.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'Cadence at which segment membership is recalculated for auto-refresh segments. Daily: high-velocity behavioral segments. Weekly: standard RFM tiers. Monthly: demographic or lifecycle segments. Quarterly: strategic value tiers. On-Demand: manual trigger only.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative describing the segment\'s defining characteristics, business rationale, and strategic purpose. Includes target customer profile, expected behaviors, and recommended engagement strategies.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the segment (e.g., \'VIP Gold Tier\', \'Lapsed Customers - 90 Days\', \'High-Value B2B Accounts\'). Used in reporting, dashboards, and customer-facing communications.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment definition. Active: in production use for customer assignment and campaigns. Inactive: temporarily suspended, no new assignments. Archived: retired, historical reference only. Draft: under development, not yet released.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segmentation methodology applied. RFM Tier: Recency, Frequency, Monetary analysis. Demographic: age, gender, income. Behavioral: purchase patterns, product affinity. Psychographic: lifestyle, values. Lifecycle Stage: new, active, at-risk, lapsed. Geographic: region, climate zone. Channel Preference: omnichannel, e-commerce-only, store-only. Value Tier: CLTV-based stratification. [ENUM-REF-CANDIDATE: rfm_tier|demographic|behavioral|psychographic|lifecycle_stage|geographic|channel_preference|value_tier — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarketingChannel rdf:type rdf:Property ;
    rdfs:label 'Target Marketing Channel' ;
    rdfs:comment 'Primary communication channel recommended for engaging customers in this segment. Aligns segment strategy with channel preference and regulatory consent. All Channels: omnichannel engagement strategy. [ENUM-REF-CANDIDATE: email|sms|push_notification|direct_mail|in_store|call_center|social_media|all_channels — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceId rdf:type rdf:Property ;
    rdfs:label 'Preference Id' ;
    rdfs:comment 'Unique identifier for the customer preference record. Primary key.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredProductBrandId rdf:type rdf:Property ;
    rdfs:label 'Preferred Product Brand Id' ;
    rdfs:comment 'Foreign key linking to product.product_brand. Business justification: Retail CRM captures explicit brand preferences for personalization, brand-specific email campaigns, and loyalty program brand partnerships. Customers opt into brand communications (e.g., Nike, store p' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:preferredSkuId rdf:type rdf:Property ;
    rdfs:label 'Preferred Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Customer product preferences at SKU level (favorite items, repeat purchases) drive personalization engines, targeted promotions, and replenishment recommendations. Retail personalization requires link' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:supersededByPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Preference Id' ;
    rdfs:comment 'Identifier of the preference record that supersedes or replaces this preference. Nullable if this is the current active preference. Supports preference lineage and history tracking.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Preference .

ind:applicationCount rdf:type rdf:Property ;
    rdfs:label 'Application Count' ;
    rdfs:comment 'The cumulative number of times this preference has been applied or used in customer interactions, recommendations, or personalization events. Supports preference effectiveness measurement and RFM (Recency Frequency Monetary) analytics.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelCaptured rdf:type rdf:Property ;
    rdfs:label 'Channel Captured' ;
    rdfs:comment 'The channel or touchpoint through which the preference was originally captured (e.g., web, mobile app, POS (Point of Sale), call center, in-store kiosk, email, survey, third-party). Supports omnichannel attribution and data quality assessment. [ENUM-REF-CANDIDATE: web|mobile_app|pos|call_center|in_store_kiosk|email|survey|third_party — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Numeric confidence score (0.00 to 100.00) indicating the reliability or certainty of the preference, especially for inferred or behavioral preferences. Higher values indicate stronger confidence. Self-declared preferences typically have 100.00 confidence.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentGiven rdf:type rdf:Property ;
    rdfs:label 'Consent Given' ;
    rdfs:comment 'Boolean flag indicating whether the customer has provided explicit consent for this preference to be used for personalization, marketing, or data processing. True indicates consent granted; False indicates consent not granted or withdrawn.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'The timestamp when the customer provided or withdrew consent for this preference. Required for GDPR and CCPA compliance audit trails. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'Three-letter ISO 639-2 language code indicating the language in which the preference was captured or should be displayed (e.g., ENG for English, SPA for Spanish, FRA for French). Supports multilingual customer experience and localization.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAppliedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Applied Timestamp' ;
    rdfs:comment 'The timestamp when this preference was last actively used or applied in a customer interaction, personalization event, or recommendation. Supports preference relevance scoring and decay analysis. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optOutFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted out of having this preference used for personalization or marketing. True indicates customer has opted out; False indicates customer has not opted out. Supports GDPR right to object and CCPA opt-out requirements.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opt Out Timestamp' ;
    rdfs:comment 'The timestamp when the customer opted out of this preference. Required for compliance audit trails. Nullable if customer has not opted out. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preferenceCategory rdf:type rdf:Property ;
    rdfs:label 'Preference Category' ;
    rdfs:comment 'The category or type of preference being captured (e.g., communication channel, product category affinity, dietary restriction, brand preference, store preference, language, notification frequency, privacy consent, marketing opt-in, delivery preference, payment method preference, shopping time preference). Supports segmentation and personalization across all Retail channels. [ENUM-REF-CANDIDATE: communication_channel|product_category_affinity|dietary_restriction|brand_preference|store_preference|language|notification_frequency|privacy_consent|marketing_opt_in|delivery_preference|payment_method_preference|shopping_time_preference — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceDescription rdf:type rdf:Property ;
    rdfs:label 'Preference Description' ;
    rdfs:comment 'Free-text description or additional context about the preference, especially useful for complex or custom preferences that require explanation. Supports customer service and clienteling use cases.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceSource rdf:type rdf:Property ;
    rdfs:label 'Preference Source' ;
    rdfs:comment 'The origin of the preference data. Self-declared indicates customer explicitly provided the preference; behavioral indicates derived from purchase or browsing history; inferred indicates algorithmic prediction; third-party indicates sourced from external data provider; imported indicates migrated from legacy system.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Current lifecycle status of the preference. Active indicates currently in use; inactive indicates temporarily disabled; expired indicates no longer valid due to time constraints; superseded indicates replaced by a newer preference.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceValue rdf:type rdf:Property ;
    rdfs:label 'Preference Value' ;
    rdfs:comment 'The specific value or selection for the preference category (e.g., \'email\', \'organic produce\', \'Nike\', \'Store #1234\', \'Spanish\', \'weekly\'). Free-text or structured value depending on category.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Optional granular subcategory within the preference category for more detailed segmentation (e.g., within \'product_category_affinity\', subcategory could be \'organic_produce\', \'gluten_free_bakery\', \'athletic_footwear\'). Supports fine-grained personalization.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Indicates whether the preference has been verified or validated through customer confirmation, behavioral validation, or data quality checks. Verified indicates confirmed accuracy; unverified indicates not yet validated; pending_verification indicates in validation process; verification_failed indicates validation attempt unsuccessful.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of this preference record, incremented each time the preference is updated. Supports preference history tracking and change management. Initial version is 1.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weight rdf:type rdf:Property ;
    rdfs:label 'Weight' ;
    rdfs:comment 'Numeric weight (0.00 to 100.00) assigned to this preference for use in recommendation algorithms and personalization scoring. Higher weights indicate stronger influence on recommendations. Used by AI/ML models for CLTV (Customer Lifetime Value) and next-best-action predictions.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentId rdf:type rdf:Property ;
    rdfs:label 'Consent Id' ;
    rdfs:comment 'Primary key for consent' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionChannel rdf:type rdf:Property ;
    rdfs:label 'Collection Channel' ;
    rdfs:comment 'The channel through which the consent was collected: web (e-commerce site), mobile app, POS (point of sale terminal), paper form (in-store signup), call center, email campaign, or in-store kiosk. [ENUM-REF-CANDIDATE: web|mobile_app|pos|paper_form|call_center|email|in_store_kiosk — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'The method by which consent was obtained: explicit opt-in (customer actively checked box), implicit opt-in (inferred from action), pre-checked box (legacy, non-compliant), verbal (phone), or written signature (paper form).' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentScope rdf:type rdf:Property ;
    rdfs:label 'Consent Scope' ;
    rdfs:comment 'Detailed description of the scope and purpose of the consent. Explains what data will be used for and how, ensuring transparency and specificity required by privacy regulations.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current status of the consent: granted (customer opted in), withdrawn (customer opted out), pending (awaiting customer action), expired (consent period ended), or revoked (administratively cancelled).' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'The specific type of consent being recorded: marketing email, SMS, push notifications, data sharing with partners, profiling for personalization, cookie tracking, or third-party data sharing. [ENUM-REF-CANDIDATE: marketing_email|marketing_sms|marketing_push|data_sharing|profiling|cookies|third_party_sharing — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectRightsNotice rdf:type rdf:Property ;
    rdfs:label 'Data Subject Rights Notice' ;
    rdfs:comment 'Boolean flag indicating whether the customer was informed of their data subject rights (right to access, rectification, erasure, restriction, portability, objection) at the time of consent collection.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInConfirmed rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Confirmed' ;
    rdfs:comment 'Boolean flag indicating whether the customer confirmed their consent via a double opt-in process (e.g., email confirmation link). Best practice for email marketing consent.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Timestamp' ;
    rdfs:comment 'The date and time when the customer confirmed their consent via double opt-in. Null if double opt-in was not used or not yet confirmed.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'The date on which this consent expires and must be re-obtained. Null if consent does not expire. Used for consent refresh workflows.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:granularity rdf:type rdf:Property ;
    rdfs:label 'Granularity' ;
    rdfs:comment 'The level of granularity at which consent was obtained: global (all purposes), channel-specific (email vs SMS), purpose-specific (marketing vs analytics), or brand-specific (for multi-brand retailers).' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'The legal jurisdiction (country or state code) under which this consent was collected and is governed. Determines applicable privacy regulations (GDPR, CCPA, etc.).' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'The legal basis under GDPR for processing this data: consent, contract fulfillment, legal obligation, vital interest, public task, or legitimate interest. Required for GDPR Article 6 compliance.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Minor Consent Flag' ;
    rdfs:comment 'Boolean flag indicating whether this consent record pertains to a minor (under age of digital consent in jurisdiction). Triggers additional parental consent requirements under GDPR Article 8 and COPPA.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalConsentVerified rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Verified' ;
    rdfs:comment 'Boolean flag indicating whether parental or guardian consent has been verified for a minor. Required for COPPA and GDPR Article 8 compliance.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privacyPolicyVersion rdf:type rdf:Property ;
    rdfs:label 'Privacy Policy Version' ;
    rdfs:comment 'The specific version of the privacy policy document that was in effect and accepted by the customer at the time of consent. Required for regulatory audit trails.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Proof Document Url' ;
    rdfs:comment 'URL or storage path to the digitally signed or archived copy of the consent form as presented to the customer. Used for audit and regulatory inspection.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'System timestamp when this consent record was first created in the data platform. Immutable. Used for audit trail and data lineage.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'The name or identifier of the source system that originated this consent record (e.g., Salesforce Commerce Cloud, POS system, call center CRM). Used for data lineage and troubleshooting.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'The browser or application user agent string captured at the time of consent. Provides additional context for consent collection environment.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Optional free-text reason provided by the customer for withdrawing consent. Used for customer experience analysis and compliance documentation.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Timestamp' ;
    rdfs:comment 'The exact date and time when the customer withdrew their consent. Null if consent has not been withdrawn. Critical for right-to-erasure workflows.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceId rdf:type rdf:Property ;
    rdfs:label 'Compliance Id' ;
    rdfs:comment 'Foreign key linking to product.product_compliance. Business justification: Product recall management is a critical retail regulatory process — when a recall is issued, service cases are opened for affected customers. Linking service_case to product_compliance supports recall' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Compliance .

ind:parentCaseServiceCaseId rdf:type rdf:Property ;
    rdfs:label 'Parent Case Service Case Id' ;
    rdfs:comment 'Identifier of the parent service case if this case is a child or follow-up case. Supports hierarchical case relationships and tracking of related issues.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCase .

ind:vendorContactId rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Id' ;
    rdfs:comment 'Foreign key linking to supplier.vendor_contact. Business justification: In retail customer service operations, when a case involves a defective or disputed vendor product, agents must engage a specific vendor representative. Linking service_case to vendor_contact enables ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorContact .

ind:assignedTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Team' ;
    rdfs:comment 'Name or code of the service team or queue to which this case is assigned for resolution.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally visible unique case number assigned by the service system for customer reference and tracking.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseOwnerType rdf:type rdf:Property ;
    rdfs:label 'Case Owner Type' ;
    rdfs:comment 'Type of owner currently assigned to the case: individual agent, team queue, or automated system. Used for workload distribution analytics.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle status of the service case. Tracks progression from new through resolution to closure. [ENUM-REF-CANDIDATE: new|open|in_progress|pending_customer|pending_vendor|escalated|resolved|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the service case by the nature of the customer issue or inquiry. Includes return inquiry, billing dispute, product complaint, delivery issue, loyalty query, order inquiry, technical support, and general inquiry. [ENUM-REF-CANDIDATE: return_inquiry|billing_dispute|product_complaint|delivery_issue|loyalty_query|order_inquiry|technical_support|general_inquiry — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Timestamp when the case was formally closed in the system. May differ from resolution timestamp if additional verification or customer confirmation was required.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactAttempts rdf:type rdf:Property ;
    rdfs:label 'Contact Attempts' ;
    rdfs:comment 'Number of times the service team attempted to contact the customer during the case lifecycle. Used for tracking customer engagement and responsiveness.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Rating' ;
    rdfs:comment 'Customer satisfaction score provided by the customer after case resolution, typically on a scale of 1 to 5. Used to calculate CSAT and NPS metrics.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Boolean indicator of whether the case was escalated to a higher support tier, supervisor, or specialized team during its lifecycle.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Reason or justification for escalating the case, such as complexity, customer request, or SLA breach.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Response Timestamp' ;
    rdfs:comment 'Timestamp when the first agent response was provided to the customer after case creation. Key metric for measuring initial response time SLA.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionCount rdf:type rdf:Property ;
    rdfs:label 'Interaction Count' ;
    rdfs:comment 'Total number of customer-agent interactions or touchpoints recorded during the lifecycle of this case. Includes calls, emails, chats, and in-person contacts.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isClosed rdf:type rdf:Property ;
    rdfs:label 'Is Closed' ;
    rdfs:comment 'Boolean indicator of whether the case is currently in a closed status. Simplifies filtering for open vs closed case analytics.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Code' ;
    rdfs:comment 'Standardized code indicating the type of resolution or action taken to close the service case. Used for resolution analytics and process improvement. [ENUM-REF-CANDIDATE: refund_issued|replacement_sent|information_provided|escalated_to_vendor|no_action_required|customer_withdrew|policy_exception_approved — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Free-text notes documenting the resolution details, actions taken, and any follow-up required for the case.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Timestamp when the case was marked as resolved by the service agent. Represents the point at which the issue was addressed.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rmaNumber rdf:type rdf:Property ;
    rdfs:label 'Rma Number' ;
    rdfs:comment 'Return Merchandise Authorization number issued for return-related cases. Links the service case to the formal return process and inventory tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCaseDescription rdf:type rdf:Property ;
    rdfs:label 'Service Case Description' ;
    rdfs:comment 'Detailed narrative description of the customer issue, inquiry, or complaint as captured by the service agent or customer.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'Target number of hours within which the case should be resolved according to the applicable SLA policy based on case type and priority.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief summary or subject line describing the nature of the customer service case.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Liability Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Gift cards and store credit (payment_method has gift_card_balance, store_credit_balance) represent deferred revenue liabilities that must be tracked in specific GL accounts. Required for ASC 606 reven' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:primaryPaymentDigitalWalletAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Digital Wallet Account Id' ;
    rdfs:comment 'Tokenized identifier for the digital wallet account. Used for digital wallet transactions and reconciliation.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:binNumber rdf:type rdf:Property ;
    rdfs:label 'Bin Number' ;
    rdfs:comment 'First six digits of the card number (Bank Identification Number). Used for card type identification, fraud detection, and routing. Not considered sensitive under PCI DSS.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardCountryCode rdf:type rdf:Property ;
    rdfs:label 'Card Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the country where the card was issued. Derived from BIN lookup. Used for fraud detection and international transaction processing.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentChannel rdf:type rdf:Property ;
    rdfs:label 'Consent Channel' ;
    rdfs:comment 'Channel through which the customer provided consent to store this payment method (web, mobile app, POS, call center, in-store). Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deactivated Timestamp' ;
    rdfs:comment 'Timestamp when this payment method was deactivated. Null if the payment method is still active. Used for lifecycle tracking and compliance reporting.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deactivationReason rdf:type rdf:Property ;
    rdfs:label 'Deactivation Reason' ;
    rdfs:comment 'Reason why the payment method was deactivated. Used for customer service, fraud analysis, and operational reporting.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalWalletProvider rdf:type rdf:Property ;
    rdfs:label 'Digital Wallet Provider' ;
    rdfs:comment 'Provider of the digital wallet (Apple Pay, Google Pay, PayPal, Samsung Pay, Venmo). Applicable only when payment_method_type is digital_wallet.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryMonth rdf:type rdf:Property ;
    rdfs:label 'Expiry Month' ;
    rdfs:comment 'Expiration month of the payment card (1-12). Used to validate card validity at checkout and trigger proactive customer notifications for expiring cards.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryYear rdf:type rdf:Property ;
    rdfs:label 'Expiry Year' ;
    rdfs:comment 'Expiration year of the payment card (four-digit year). Used to validate card validity at checkout and trigger proactive customer notifications for expiring cards.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:giftCardBalance rdf:type rdf:Property ;
    rdfs:label 'Gift Card Balance' ;
    rdfs:comment 'Current balance remaining on the gift card. Updated after each transaction. Applicable only when payment_method_type is gift_card.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftCardNumber rdf:type rdf:Property ;
    rdfs:label 'Gift Card Number' ;
    rdfs:comment 'Tokenized or masked gift card number. Applicable only when payment_method_type is gift_card. Used for gift card balance inquiries and redemption.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Flag indicating whether this payment method is currently active and available for use. Inactive methods are retained for historical transaction reference but cannot be used for new purchases.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingBank rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank' ;
    rdfs:comment 'Name of the bank or financial institution that issued the payment card. Used for transaction routing and fraud detection.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFourDigits rdf:type rdf:Property ;
    rdfs:label 'Last Four Digits' ;
    rdfs:comment 'Last four digits of the card number for customer recognition and display purposes. Used in clienteling and checkout confirmation screens.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProcessor rdf:type rdf:Property ;
    rdfs:label 'Payment Processor' ;
    rdfs:comment 'Name of the payment processor or gateway used to process transactions with this payment method (e.g., Stripe, Adyen, Braintree, Cybersource). Used for transaction routing and reconciliation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorToken rdf:type rdf:Property ;
    rdfs:label 'Processor Token' ;
    rdfs:comment 'Payment processor-specific token for this payment method. Used for transaction processing and vault management.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCreditBalance rdf:type rdf:Property ;
    rdfs:label 'Store Credit Balance' ;
    rdfs:comment 'Current balance of store credit available to the customer. Typically issued from returns or promotional campaigns. Applicable only when payment_method_type is store_credit.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Total number of times this payment method has been used for transactions. Used for RFM analytics and customer behavior analysis.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Dc Facility Id' ;
    rdfs:comment 'Foreign key linking to supplychain.dc_facility. Business justification: Every store has a primary DC assignment for standard replenishment routing. Fundamental retail supply chain topology required for: replenishment order routing, freight cost allocation, lead time calcu' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:accessibilityCertified rdf:type rdf:Property ;
    rdfs:label 'Accessibility Certified' ;
    rdfs:comment 'Indicates whether the store location is certified as fully accessible for customers with disabilities, meeting ADA (Americans with Disabilities Act) or equivalent local accessibility standards. True = certified accessible; False = not certified or non-compliant.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assortmentBreadthNorm rdf:type rdf:Property ;
    rdfs:label 'Assortment Breadth Norm' ;
    rdfs:comment 'Standard assortment breadth (range of categories) for this store format. Narrow = limited category count (convenience); Moderate = balanced category mix; Broad = wide category range; Very Broad = full-line assortment (hypermarket). Used for merchandising strategy.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assortmentDepthNorm rdf:type rdf:Property ;
    rdfs:label 'Assortment Depth Norm' ;
    rdfs:comment 'Standard assortment depth (variety within a category) for this store format. Shallow = limited SKU count per category; Moderate = balanced SKU selection; Deep = extensive SKU variety; Very Deep = maximum SKU variety. Used for category management and space planning.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bannerBrand rdf:type rdf:Property ;
    rdfs:label 'Banner Brand' ;
    rdfs:comment 'The retail banner or brand under which this location operates (e.g., \'Retail Hypermarket\', \'Retail Discount\', \'Retail Express\'). Used for brand segmentation, assortment planning, and marketing strategy.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bopisCapable rdf:type rdf:Property ;
    rdfs:label 'Bopis Capable' ;
    rdfs:comment 'Indicates whether this store location supports BOPIS (Buy Online Pick Up In Store) fulfillment. True = BOPIS enabled with dedicated pickup area; False = BOPIS not available. Used for omnichannel order routing and customer service.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:climateZone rdf:type rdf:Property ;
    rdfs:label 'Climate Zone' ;
    rdfs:comment 'Climate zone classification for the store location. Used for seasonal assortment planning, HVAC energy management, and merchandise mix optimization (e.g., winter apparel depth in continental zones).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'The date this store location permanently ceased operations. Null for active stores. Used for historical analysis, lease termination tracking, and asset disposition planning.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dsdReceiving rdf:type rdf:Property ;
    rdfs:label 'Dsd Receiving' ;
    rdfs:comment 'Indicates whether this store location accepts Direct Store Delivery (DSD) from vendors, bypassing the distribution center (DC). True = DSD receiving enabled; False = all inventory flows through DC. Common for beverages, snacks, and bread.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formatSizeBand rdf:type rdf:Property ;
    rdfs:label 'Format Size Band' ;
    rdfs:comment 'Size classification band for the store format, used for assortment planning and operational benchmarking. Small = <20K sq ft; Medium = 20K-50K sq ft; Large = 50K-100K sq ft; Extra Large = >100K sq ft. Bands are format-specific.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRemodelDate rdf:type rdf:Property ;
    rdfs:label 'Last Remodel Date' ;
    rdfs:comment 'The date of the most recent major remodel or renovation of this store location. Used for capital expenditure tracking, store refresh planning, and performance analysis post-remodel.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'The legal entity name under which this store location operates. Used for regulatory filings, tax reporting, and legal compliance. May differ from the trading name.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current operational status of the store location in its lifecycle. Planned = approved but not yet built; Under Construction = site work in progress; Open = actively trading; Temporarily Closed = closed for short-term reasons (weather, emergency); Permanently Closed = ceased operations; Remodeling = closed for renovation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfFloors rdf:type rdf:Property ;
    rdfs:label 'Number Of Floors' ;
    rdfs:comment 'Total number of customer-accessible floors in the store location. Used for store layout planning, accessibility compliance, and customer flow analysis.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'The date this store location first opened for business. Used for comp sales (SSS - Same-Store Sales) calculations, anniversary planning, and store maturity analysis. Null for planned stores not yet opened.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours for the store location, typically in format \'Mon-Fri 8:00-22:00, Sat-Sun 9:00-21:00\'. Used for workforce scheduling, customer communications, and omnichannel order fulfillment time windows.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingCapacity rdf:type rdf:Property ;
    rdfs:label 'Parking Capacity' ;
    rdfs:comment 'Total number of customer parking spaces available at the store location. Used for site selection, customer convenience analysis, and BOPIS/ROPIS pickup planning. Null for urban locations without dedicated parking.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ropisCapable rdf:type rdf:Property ;
    rdfs:label 'Ropis Capable' ;
    rdfs:comment 'Indicates whether this store location supports ROPIS (Reserve Online Pick Up In Store) fulfillment, where customers reserve items online and complete purchase in-store. True = ROPIS enabled; False = ROPIS not available.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sellingSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Selling Square Footage' ;
    rdfs:comment 'Square footage of customer-accessible selling floor space, excluding back-of-house, storage, and office areas. Used for sales per square foot calculations, planogram (POG) planning, and merchandising density analysis.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sfsCapable rdf:type rdf:Property ;
    rdfs:label 'Sfs Capable' ;
    rdfs:comment 'Indicates whether this store location is enabled as a Ship-from-Store (SFS) fulfillment node, capable of picking, packing, and shipping e-commerce orders directly from store inventory. True = SFS enabled; False = SFS not available.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:staffingModelType rdf:type rdf:Property ;
    rdfs:label 'Staffing Model Type' ;
    rdfs:comment 'The staffing model classification for this store format. Full Service = high staff-to-customer ratio with clienteling; Limited Service = moderate staffing; Self Service = minimal staff, customer self-checkout; Automated = dark store or MFC with no customer-facing staff.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeName rdf:type rdf:Property ;
    rdfs:label 'Store Name' ;
    rdfs:comment 'The trading name or display name of the store location as it appears to customers (e.g., \'Retail Superstore Downtown\', \'Retail Express Market Hill\'). Used for customer communications, receipts, and marketing materials.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Total Square Footage' ;
    rdfs:comment 'Total building square footage of the store location, including selling floor, back-of-house, storage, and office space. Used for productivity metrics (sales per square foot), lease accounting, and facility management.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assortmentBreadthLevel rdf:type rdf:Property ;
    rdfs:label 'Assortment Breadth Level' ;
    rdfs:comment 'Typical range of product categories carried by this format. Narrow = few categories (e.g., convenience); broad = many categories (e.g., hypermarket).' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assortmentDepthLevel rdf:type rdf:Property ;
    rdfs:label 'Assortment Depth Level' ;
    rdfs:comment 'Typical variety within each product category for this format. Shallow = limited SKU (Stock Keeping Unit) variety per category; deep = extensive SKU variety per category.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bopisCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Bopis Capable Flag' ;
    rdfs:comment 'Indicates whether stores of this format are capable of supporting BOPIS (Buy Online Pick Up In Store) fulfillment. True if BOPIS is supported; false otherwise.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientelingServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Clienteling Service Flag' ;
    rdfs:comment 'Indicates whether stores of this format offer clienteling (personalized in-store service) to customers. True if clienteling is offered; false otherwise.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dsdReceivingFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Receiving Flag' ;
    rdfs:comment 'Indicates whether stores of this format receive DSD (Direct Store Delivery) shipments directly from vendors, bypassing the DC (Distribution Center). True if DSD receiving is supported; false otherwise.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endcapCountTypical rdf:type rdf:Property ;
    rdfs:label 'Endcap Count Typical' ;
    rdfs:comment 'Typical number of endcaps (end-of-aisle displays) available for promotional merchandising in stores of this format.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formatDescription rdf:type rdf:Property ;
    rdfs:label 'Format Description' ;
    rdfs:comment 'Detailed description of the store format including its purpose, target customer segment, and operational characteristics.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatName rdf:type rdf:Property ;
    rdfs:label 'Format Name' ;
    rdfs:comment 'Full descriptive name of the store format (e.g., Hypermarket, Superstore, Department Store, Discount Outlet, Convenience Store, Dark Store, Micro-Fulfillment Center, Ship-from-Store Node).' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatStatus rdf:type rdf:Property ;
    rdfs:label 'Format Status' ;
    rdfs:comment 'Current lifecycle status of the store format. Active formats are in use across the banner portfolio; deprecated formats are being phased out; pilot formats are under testing.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatType rdf:type rdf:Property ;
    rdfs:label 'Format Type' ;
    rdfs:comment 'High-level classification of the format: physical_retail (customer-facing), fulfillment_only (dark store, MFC), or hybrid (ship-from-store capable retail location).' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gondolaConfigurationType rdf:type rdf:Property ;
    rdfs:label 'Gondola Configuration Type' ;
    rdfs:comment 'Typical gondola (shelving unit) configuration used in stores of this format. Defines the standard shelving layout and fixture type.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursType rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Type' ;
    rdfs:comment 'Typical operating hours pattern for stores of this format. 24_7 = open 24 hours; extended = long hours (e.g., 6am-midnight); standard = typical retail hours; limited = short hours; variable = hours vary by location.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingCapacityTypical rdf:type rdf:Property ;
    rdfs:label 'Parking Capacity Typical' ;
    rdfs:comment 'Typical number of parking spaces available at stores of this format. Null for formats without customer parking (e.g., dark stores, MFCs).' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planogramTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Planogram Template Code' ;
    rdfs:comment 'Code identifying the standard planogram (POG - Shelf Layout Diagram) template used for visual merchandising in stores of this format. Links to master planogram library.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posTerminalCountMax rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Count Max' ;
    rdfs:comment 'Maximum number of POS (Point of Sale) terminals typically deployed in stores of this format. Defines the upper bound of checkout capacity.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:posTerminalCountMin rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Count Min' ;
    rdfs:comment 'Minimum number of POS (Point of Sale) terminals typically deployed in stores of this format. Defines the lower bound of checkout capacity.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingStrategyType rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy Type' ;
    rdfs:comment 'Typical pricing strategy employed by stores of this format. EDLP (Everyday Low Price) = consistent low prices; Hi-Lo (High-Low Pricing Strategy) = regular prices with frequent promotions; premium = higher prices with quality focus; discount = below-market pricing; dynamic = algorithmic pricing.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Enabled Flag' ;
    rdfs:comment 'Indicates whether stores of this format use RFID (Radio Frequency Identification) technology for inventory tracking and shrinkage prevention. True if RFID is deployed; false otherwise.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ropisCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Ropis Capable Flag' ;
    rdfs:comment 'Indicates whether stores of this format are capable of supporting ROPIS (Reserve Online Pick Up In Store) fulfillment. True if ROPIS is supported; false otherwise.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sfsCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Sfs Capable Flag' ;
    rdfs:comment 'Indicates whether stores of this format are capable of serving as SFS (Ship-from-Store) fulfillment nodes for e-commerce orders. True if SFS is supported; false otherwise.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sizeBandMaxSqft rdf:type rdf:Property ;
    rdfs:label 'Size Band Max Sqft' ;
    rdfs:comment 'Maximum store size in square feet for this format. Defines the upper bound of the typical size range.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sizeBandMinSqft rdf:type rdf:Property ;
    rdfs:label 'Size Band Min Sqft' ;
    rdfs:comment 'Minimum store size in square feet for this format. Defines the lower bound of the typical size range.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetDemographic rdf:type rdf:Property ;
    rdfs:label 'Target Demographic' ;
    rdfs:comment 'Primary customer demographic segment targeted by this store format (e.g., value-conscious families, urban professionals, convenience shoppers, bulk buyers).' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalSkuCountMax rdf:type rdf:Property ;
    rdfs:label 'Typical Sku Count Max' ;
    rdfs:comment 'Maximum number of SKUs (Stock Keeping Units) typically carried by stores of this format. Defines the upper bound of product assortment size.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:typicalSkuCountMin rdf:type rdf:Property ;
    rdfs:label 'Typical Sku Count Min' ;
    rdfs:comment 'Minimum number of SKUs (Stock Keeping Units) typically carried by stores of this format. Defines the lower bound of product assortment size.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wmsIntegrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Wms Integration Required Flag' ;
    rdfs:comment 'Indicates whether stores of this format require integration with WMS (Warehouse Management System) for inventory management. True for fulfillment-heavy formats (dark stores, MFCs, SFS nodes); false for traditional retail-only formats.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:barcodeScannerType rdf:type rdf:Property ;
    rdfs:label 'Barcode Scanner Type' ;
    rdfs:comment 'Type of barcode scanner peripheral attached to the POS terminal. Determines scanning workflow and throughput capabilities.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashDrawerEnabled rdf:type rdf:Property ;
    rdfs:label 'Cash Drawer Enabled' ;
    rdfs:comment 'Indicates whether the terminal is connected to a cash drawer for handling cash transactions. False for self-checkout kiosks and mobile POS devices that do not accept cash.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactlessEnabled rdf:type rdf:Property ;
    rdfs:label 'Contactless Enabled' ;
    rdfs:comment 'Indicates whether the terminal supports Near Field Communication (NFC) contactless payments (tap-to-pay, mobile wallets like Apple Pay, Google Pay).' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerDisplayType rdf:type rdf:Property ;
    rdfs:label 'Customer Display Type' ;
    rdfs:comment 'Type of customer-facing display device attached to the terminal. Shows transaction details, pricing, and promotional messages to the customer during checkout.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebtSnapEnabled rdf:type rdf:Property ;
    rdfs:label 'Ebt Snap Enabled' ;
    rdfs:comment 'Indicates whether the terminal is certified to accept Electronic Benefits Transfer (EBT) and Supplemental Nutrition Assistance Program (SNAP) payments. Required for grocery retailers serving SNAP recipients.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emvChipEnabled rdf:type rdf:Property ;
    rdfs:label 'Emv Chip Enabled' ;
    rdfs:comment 'Indicates whether the terminal supports EMV chip card transactions (contact chip reading). Required for PCI DSS compliance and fraud reduction.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encryptionEnabled rdf:type rdf:Property ;
    rdfs:label 'Encryption Enabled' ;
    rdfs:comment 'Indicates whether the terminal encrypts payment card data at the point of interaction (P2PE - Point-to-Point Encryption). Required for PCI DSS compliance and fraud prevention.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hardwareModel rdf:type rdf:Property ;
    rdfs:label 'Hardware Model' ;
    rdfs:comment 'Manufacturer model number or identifier for the POS terminal hardware (e.g., \'NCR RealPOS 82XRT\', \'Toshiba TCx Sky\', \'Zebra TC52\'). Critical for maintenance planning and compatibility management.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardwareSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Hardware Serial Number' ;
    rdfs:comment 'Manufacturer-assigned unique serial number for the physical POS terminal device. Used for warranty tracking, asset management, and theft prevention.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the POS terminal was first installed and commissioned at the store location. Used for asset lifecycle tracking and depreciation calculations.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:laneNumber rdf:type rdf:Property ;
    rdfs:label 'Lane Number' ;
    rdfs:comment 'Physical lane or checkout position number within the store layout. Used for customer wayfinding and operational reporting. Null for mobile POS devices.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent preventive maintenance or repair service performed on the terminal. Used for maintenance schedule compliance tracking.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTransactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Timestamp' ;
    rdfs:comment 'Timestamp of the most recent transaction processed by this terminal. Used for terminal utilization analysis and anomaly detection (e.g., identifying inactive terminals).' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:macAddress rdf:type rdf:Property ;
    rdfs:label 'Mac Address' ;
    rdfs:comment 'Media Access Control (MAC) address of the POS terminal network interface. Unique hardware identifier used for network access control and device authentication.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileWalletEnabled rdf:type rdf:Property ;
    rdfs:label 'Mobile Wallet Enabled' ;
    rdfs:comment 'Indicates whether the terminal supports mobile wallet payment methods (Apple Pay, Google Pay, Samsung Pay, etc.). Typically requires NFC hardware.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkZone rdf:type rdf:Property ;
    rdfs:label 'Network Zone' ;
    rdfs:comment 'Network security zone or segment where the POS terminal is deployed. Cardholder Data Environment (CDE) terminals are subject to stricter PCI DSS controls.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date when the next preventive maintenance service is scheduled for the terminal. Used for proactive maintenance planning and resource allocation.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pciDssCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Certification Date' ;
    rdfs:comment 'Date when the terminal last passed Payment Card Industry Data Security Standard (PCI DSS) compliance certification. Must be renewed annually to maintain payment acceptance capabilities.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pciDssCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Certification Expiry Date' ;
    rdfs:comment 'Date when the current PCI DSS certification expires. Terminals must be recertified before this date to continue processing payment card transactions.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pinDebitEnabled rdf:type rdf:Property ;
    rdfs:label 'Pin Debit Enabled' ;
    rdfs:comment 'Indicates whether the terminal supports PIN-based debit card transactions. Requires secure PIN pad hardware.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qrCodePaymentEnabled rdf:type rdf:Property ;
    rdfs:label 'Qr Code Payment Enabled' ;
    rdfs:comment 'Indicates whether the terminal supports QR code-based payment methods (e.g., Alipay, WeChat Pay, retailer-specific QR payment apps).' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptPrinterModel rdf:type rdf:Property ;
    rdfs:label 'Receipt Printer Model' ;
    rdfs:comment 'Model identifier for the receipt printer peripheral attached to the POS terminal. Used for consumables ordering and maintenance scheduling.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteManagementEnabled rdf:type rdf:Property ;
    rdfs:label 'Remote Management Enabled' ;
    rdfs:comment 'Indicates whether the terminal can be remotely monitored, configured, and updated from a central management system. Enables efficient fleet management and rapid issue resolution.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scaleIntegrated rdf:type rdf:Property ;
    rdfs:label 'Scale Integrated' ;
    rdfs:comment 'Indicates whether the terminal has an integrated scale for weighing produce, bulk items, or other variable-weight merchandise. Common in grocery checkout lanes.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureCaptureEnabled rdf:type rdf:Property ;
    rdfs:label 'Signature Capture Enabled' ;
    rdfs:comment 'Indicates whether the terminal supports electronic signature capture for credit card transactions and delivery confirmations.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:softwareVersion rdf:type rdf:Property ;
    rdfs:label 'Software Version' ;
    rdfs:comment 'Version number of the POS application software currently installed on the terminal. Critical for security patch management and feature compatibility.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalName rdf:type rdf:Property ;
    rdfs:label 'Terminal Name' ;
    rdfs:comment 'Human-readable name or label for the POS terminal, often indicating its location or purpose within the store (e.g., \'Lane 5\', \'Customer Service Desk\', \'Pharmacy Register\').' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalNumber rdf:type rdf:Property ;
    rdfs:label 'Terminal Number' ;
    rdfs:comment 'Business identifier for the POS terminal, typically displayed on the terminal and used in operational communications. Unique within a store location.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalStatus rdf:type rdf:Property ;
    rdfs:label 'Terminal Status' ;
    rdfs:comment 'Current operational status of the POS terminal. Determines whether the terminal is available for transaction processing. Active terminals are in production use; offline terminals are temporarily unavailable; maintenance terminals are undergoing service; decommissioned terminals are permanently retired.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalType rdf:type rdf:Property ;
    rdfs:label 'Terminal Type' ;
    rdfs:comment 'Classification of the POS terminal based on its operational function and staffing model. Determines transaction workflows and customer interaction patterns.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Tokenization Enabled' ;
    rdfs:comment 'Indicates whether the terminal supports payment tokenization, replacing sensitive card data with non-sensitive tokens for storage and transmission. Reduces PCI DSS scope.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trafficCountId rdf:type rdf:Property ;
    rdfs:label 'Traffic Count Id' ;
    rdfs:comment 'Primary key for traffic_count' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accuracyConfidencePercent rdf:type rdf:Property ;
    rdfs:label 'Accuracy Confidence Percent' ;
    rdfs:comment 'Estimated accuracy confidence level of the measurement as a percentage (e.g., 95.5 indicates 95.5% confidence). Provided by advanced sensor systems with built-in quality scoring.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDwellTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Dwell Time Minutes' ;
    rdfs:comment 'Average time in minutes that customers spent in the counting zone during the measurement interval. Calculated from inbound/outbound timing data. Indicates customer engagement and shopping behavior.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Date' ;
    rdfs:comment 'Date when the sensor device was last calibrated or validated for accuracy. Sensors require periodic calibration to maintain measurement precision; this attribute supports data quality auditing.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Conversion Rate Percent' ;
    rdfs:comment 'Percentage of footfall that resulted in a transaction during the measurement interval. Calculated by dividing POS transaction count by inbound count. Key KPI for store performance and merchandising effectiveness.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countingZoneCode rdf:type rdf:Property ;
    rdfs:label 'Counting Zone Code' ;
    rdfs:comment 'Code identifying the specific zone or area within the store where traffic was measured (e.g., MAIN_ENTRANCE, DEPT_ELECTRONICS, CHECKOUT_AREA, ENDCAP_A1). Enables zone-level footfall analysis.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countingZoneName rdf:type rdf:Property ;
    rdfs:label 'Counting Zone Name' ;
    rdfs:comment 'Human-readable name of the counting zone (e.g., Main Entrance, Electronics Department, Checkout Area 1). Provides business-friendly identification of the measurement location.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Indicator of the reliability and completeness of the traffic count measurement. Used to filter or adjust analytics based on data quality issues.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Day Of Week' ;
    rdfs:comment 'Day of the week when the measurement was taken. Footfall patterns vary significantly by day of week; this attribute supports day-of-week trend analysis and staffing optimization. [ENUM-REF-CANDIDATE: monday|tuesday|wednesday|thursday|friday|saturday|sunday — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hourOfDay rdf:type rdf:Property ;
    rdfs:label 'Hour Of Day' ;
    rdfs:comment 'Hour of the day (0-23) when the measurement was taken. Enables intraday footfall pattern analysis and peak-hour identification for workforce scheduling.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inboundCount rdf:type rdf:Property ;
    rdfs:label 'Inbound Count' ;
    rdfs:comment 'Number of customers or individuals entering the counting zone during the measurement interval. Core footfall metric for traffic volume analysis.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isHoliday rdf:type rdf:Property ;
    rdfs:label 'Is Holiday' ;
    rdfs:comment 'Flag indicating whether the measurement occurred on a recognized retail holiday or peak shopping day (e.g., Black Friday, Cyber Monday, Christmas Eve). Holidays significantly impact footfall patterns.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPromotionalEvent rdf:type rdf:Property ;
    rdfs:label 'Is Promotional Event' ;
    rdfs:comment 'Flag indicating whether a store-level promotional event or special sale was active during the measurement period. Used to isolate promotional lift in footfall analysis.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStoreOpen rdf:type rdf:Property ;
    rdfs:label 'Is Store Open' ;
    rdfs:comment 'Flag indicating whether the store was open for business during the measurement interval. Distinguishes operational footfall from after-hours activity (e.g., restocking, maintenance).' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementIntervalMinutes rdf:type rdf:Property ;
    rdfs:label 'Measurement Interval Minutes' ;
    rdfs:comment 'Duration of the measurement interval in minutes (e.g., 15, 60, 1440 for daily). Defines the time window over which traffic counts were aggregated.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The precise date and time when the traffic count measurement was captured by the sensor system. Represents the business event time of the footfall observation.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:netOccupancyEstimate rdf:type rdf:Property ;
    rdfs:label 'Net Occupancy Estimate' ;
    rdfs:comment 'Estimated number of customers present in the zone at the end of the measurement interval, calculated as cumulative inbound minus outbound. Used for real-time capacity management and safety compliance.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outboundCount rdf:type rdf:Property ;
    rdfs:label 'Outbound Count' ;
    rdfs:comment 'Number of customers or individuals exiting the counting zone during the measurement interval. Used to calculate net occupancy and dwell time.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peakOccupancy rdf:type rdf:Property ;
    rdfs:label 'Peak Occupancy' ;
    rdfs:comment 'Maximum number of customers simultaneously present in the zone during the measurement interval. Used for capacity planning, safety compliance, and staffing optimization.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sensorDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Sensor Device Code' ;
    rdfs:comment 'Unique identifier of the people-counting sensor or camera system that captured the measurement. Used for device performance tracking and data quality auditing.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorType rdf:type rdf:Property ;
    rdfs:label 'Sensor Type' ;
    rdfs:comment 'Technology type of the counting sensor (e.g., thermal imaging, video analytics with AI, infrared beam, RFID, WiFi tracking, Bluetooth beacon). Impacts measurement accuracy and privacy considerations.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Temperature Fahrenheit' ;
    rdfs:comment 'Outdoor temperature in degrees Fahrenheit at the time of measurement. Used for weather-adjusted footfall modeling and seasonal trend analysis.' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCount rdf:type rdf:Property ;
    rdfs:label 'Transaction Count' ;
    rdfs:comment 'Number of POS transactions completed during the measurement interval in the counting zone. Used to calculate conversion rate and sales per visitor metrics.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weatherConditionCode rdf:type rdf:Property ;
    rdfs:label 'Weather Condition Code' ;
    rdfs:comment 'Weather condition at the time of measurement. Footfall is highly correlated with weather; this attribute enables weather-adjusted traffic forecasting and comp sales analysis. [ENUM-REF-CANDIDATE: clear|rain|snow|fog|storm|extreme_heat|extreme_cold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrafficCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plId rdf:type rdf:Property ;
    rdfs:label 'Pl Id' ;
    rdfs:comment 'Unique identifier for the store-level profit and loss record. Primary key for the store P&L data product.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atvAmount rdf:type rdf:Property ;
    rdfs:label 'Atv Amount' ;
    rdfs:comment 'Average dollar value per transaction, calculated as net sales divided by transaction count. Key metric for store performance and basket analysis.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cogsAmount rdf:type rdf:Property ;
    rdfs:label 'Cogs Amount' ;
    rdfs:comment 'Total cost of merchandise sold at the store during the period, including product cost, inbound freight, and direct product costs. Used to calculate gross margin.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compSalesFlag rdf:type rdf:Property ;
    rdfs:label 'Comp Sales Flag' ;
    rdfs:comment 'Indicates whether this store qualifies for comparable store sales (SSS - Same-Store Sales) analysis for the period. Typically true if the store has been open for at least 12 months.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compSalesGrowthPercent rdf:type rdf:Property ;
    rdfs:label 'Comp Sales Growth Percent' ;
    rdfs:comment 'Year-over-year percentage change in net sales for this store during the period, used for same-store sales (SSS) performance tracking.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Depreciation Amount' ;
    rdfs:comment 'Depreciation expense for store fixtures, equipment, POS terminals, gondolas, and other fixed assets allocated to the store for the period.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountsAmount rdf:type rdf:Property ;
    rdfs:label 'Discounts Amount' ;
    rdfs:comment 'Total value of markdowns, promotional discounts, and price reductions applied to merchandise sales during the period.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebitdaAmount rdf:type rdf:Property ;
    rdfs:label 'Ebitda Amount' ;
    rdfs:comment 'Store contribution to enterprise EBITDA, calculated as gross margin minus operating expenses (excluding depreciation). Key metric for store-level profitability and GMROI analysis.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebitdaPercent rdf:type rdf:Property ;
    rdfs:label 'Ebitda Percent' ;
    rdfs:comment 'EBITDA as a percentage of net sales. Used for store performance benchmarking and profitability comparison across locations.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalizedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Finalized Timestamp' ;
    rdfs:comment 'Date and time when this store P&L record was marked as final and locked for audit purposes. Null if still preliminary.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:grossMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Amount' ;
    rdfs:comment 'Net sales minus COGS. Represents the profit available to cover operating expenses and contribute to EBITDA.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Percent' ;
    rdfs:comment 'Gross margin as a percentage of net sales. Key profitability metric used for store performance benchmarking and GMROI analysis.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Sales Amount' ;
    rdfs:comment 'Total merchandise sales at the store before deducting returns, allowances, and discounts. Used to calculate return rates and discount penetration.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Amount' ;
    rdfs:comment 'Total store labor expenses including wages, salaries, benefits, payroll taxes, and overtime for store associates and management during the period.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Marketing Expense Amount' ;
    rdfs:comment 'Store-level marketing and advertising expenses including local promotions, signage, endcap displays, and community engagement costs for the period.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Net Sales Amount' ;
    rdfs:comment 'Total revenue from merchandise sales at the store during the period, net of returns, allowances, and discounts. Represents the top line of the store P&L.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:occupancyCostAmount rdf:type rdf:Property ;
    rdfs:label 'Occupancy Cost Amount' ;
    rdfs:comment 'Total store occupancy expenses including rent, common area maintenance (CAM) charges, property taxes, utilities, and facility maintenance costs for the period.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The last calendar date of the fiscal period covered by this P&L record.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The first calendar date of the fiscal period covered by this P&L record.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plStatus rdf:type rdf:Property ;
    rdfs:label 'Pl Status' ;
    rdfs:comment 'Current status of the P&L record indicating whether the figures are preliminary estimates, final audited values, or restated corrections.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingEntity rdf:type rdf:Property ;
    rdfs:label 'Reporting Entity' ;
    rdfs:comment 'Legal entity or business unit responsible for this store P&L record, used for consolidated financial reporting and intercompany reconciliation.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnsAmount rdf:type rdf:Property ;
    rdfs:label 'Returns Amount' ;
    rdfs:comment 'Total value of merchandise returned by customers during the period. Subtracted from gross sales to arrive at net sales.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shrinkageAmount rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Amount' ;
    rdfs:comment 'Total inventory loss due to theft, damage, spoilage, or administrative errors during the period. Recorded as an operating expense.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Supply Expense Amount' ;
    rdfs:comment 'Total cost of store supplies including bags, packaging materials, cleaning supplies, POS consumables, and other operational supplies consumed during the period.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOperatingExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Total Operating Expense Amount' ;
    rdfs:comment 'Sum of all operating expenses including shrinkage, occupancy, labor, supplies, marketing, depreciation, and other operating costs for the period.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upt rdf:type rdf:Property ;
    rdfs:label 'Upt' ;
    rdfs:comment 'Average number of units sold per transaction, calculated as units sold divided by transaction count. Indicates basket size and cross-selling effectiveness.' ;
    rdfs:domain ind:Pl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shrinkageEventId rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Event Id' ;
    rdfs:comment 'Unique identifier for the shrinkage event record. Primary key.' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costValueLost rdf:type rdf:Property ;
    rdfs:label 'Cost Value Lost' ;
    rdfs:comment 'The total cost value (COGS - Cost of Goods Sold) of inventory lost in this shrinkage event. Used for financial accounting and inventory valuation adjustments.' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'The date on which the shrinkage event was identified or occurred. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Business-facing unique reference number for the shrinkage event, used for tracking and case management (e.g., SHR-0000012345).' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReportFiled rdf:type rdf:Property ;
    rdfs:label 'Incident Report Filed' ;
    rdfs:comment 'Indicates whether a formal incident report was filed with Loss Prevention or law enforcement for this shrinkage event.' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryAdjustmentPosted rdf:type rdf:Property ;
    rdfs:label 'Inventory Adjustment Posted' ;
    rdfs:comment 'Indicates whether the inventory adjustment for this shrinkage event has been posted to the inventory ledger and financial systems (WMS - Warehouse Management System and ERP).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policeReportNumber rdf:type rdf:Property ;
    rdfs:label 'Police Report Number' ;
    rdfs:comment 'Law enforcement report number if the shrinkage event involved external theft and was reported to police.' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Human-readable description of the product(s) involved in the shrinkage event.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityLost rdf:type rdf:Property ;
    rdfs:label 'Quantity Lost' ;
    rdfs:comment 'The quantity of units lost in the shrinkage event. May include fractional units for weight-based or bulk items.' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Amount' ;
    rdfs:comment 'The monetary value recovered from the shrinkage event through restitution, insurance claims, vendor credits, or merchandise recovery. Null or zero if no recovery occurred.' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryMethod rdf:type rdf:Property ;
    rdfs:label 'Recovery Method' ;
    rdfs:comment 'The method by which value was recovered: merchandise physically recovered, restitution from perpetrator, insurance claim payout, vendor credit (RTV - Return to Vendor), chargeback to vendor, or none.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The date on which the shrinkage event case was resolved or closed. Null if still open or under investigation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current status of the shrinkage event case: open (newly identified), under investigation, resolved (cause identified and addressed), closed unresolved, or recovered (merchandise or value recovered).' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyType rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Type' ;
    rdfs:comment 'Classification of the party responsible for the shrinkage: external (customer/shoplifter), employee (internal theft), vendor (fraud/error), unknown, or not applicable (e.g., damage, administrative error).' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shrinkageType rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Type' ;
    rdfs:comment 'Classification of the root cause of the shrinkage event: external theft (shoplifting), internal theft (employee), administrative error (paperwork/system), vendor fraud, damage (spoilage/breakage), or unknown.' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRetailValueLost rdf:type rdf:Property ;
    rdfs:label 'Total Retail Value Lost' ;
    rdfs:comment 'The total estimated retail value of inventory lost in this shrinkage event (quantity_lost × unit_retail_value). Directly impacts store P&L (Profit and Loss).' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitRetailValue rdf:type rdf:Property ;
    rdfs:label 'Unit Retail Value' ;
    rdfs:comment 'The retail price per unit of the product at the time of the shrinkage event. Used to calculate total estimated loss.' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneLocation rdf:type rdf:Property ;
    rdfs:label 'Zone Location' ;
    rdfs:comment 'Specific zone, aisle, or area within the store where the shrinkage event was detected (e.g., Aisle 12, Backroom, Checkout Lane 5).' ;
    rdfs:domain ind:ShrinkageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseId rdf:type rdf:Property ;
    rdfs:label 'License Id' ;
    rdfs:comment 'Foreign key linking to store.license. Business justification: department currently stores denormalized license data: license_number (STRING), license_expiry_date (DATE), and licensed_department_flag (BOOLEAN). These attributes exist because licensed departments ' ;
    rdfs:domain ind:Store ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:License .

ind:departmentStatus rdf:type rdf:Property ;
    rdfs:label 'Department Status' ;
    rdfs:comment 'Current operational status of the department. Active departments are open for business; inactive departments are closed or not yet operational.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentType rdf:type rdf:Property ;
    rdfs:label 'Department Type' ;
    rdfs:comment 'Classification of the department by merchandise category. Determines merchandising strategy, planogram standards, and operational procedures. [ENUM-REF-CANDIDATE: grocery|apparel|electronics|household|pharmacy|bakery|deli|produce|frozen|health_beauty|seasonal|home_garden|automotive|sporting_goods|toys|jewelry|furniture — 17 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endcapCount rdf:type rdf:Property ;
    rdfs:label 'Endcap Count' ;
    rdfs:comment 'Number of endcap display positions (end-of-aisle promotional displays) available in the department. Prime real estate for high-margin or promotional items.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fixtureCount rdf:type rdf:Property ;
    rdfs:label 'Fixture Count' ;
    rdfs:comment 'Total number of fixtures (gondolas, endcaps, shelving units, display cases) assigned to the department. Used for planogram capacity planning.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:floorNumber rdf:type rdf:Property ;
    rdfs:label 'Floor Number' ;
    rdfs:comment 'Floor level where the department is located within the store. Ground floor is typically 1, basement levels may be 0 or negative.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gondolaCount rdf:type rdf:Property ;
    rdfs:label 'Gondola Count' ;
    rdfs:comment 'Number of gondola shelving units (freestanding double-sided shelving) in the department. Key metric for planogram assignment and merchandising capacity.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossMarginTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Target Percent' ;
    rdfs:comment 'Target gross margin percentage for the department. Used to measure profitability and pricing effectiveness.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborBudgetMonthly rdf:type rdf:Property ;
    rdfs:label 'Labor Budget Monthly' ;
    rdfs:comment 'Monthly labor budget allocation for the department in local currency. Used for workforce scheduling and labor-to-sales ratio management.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User ID or system identifier of the person or process that last modified the department record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omnichannelFulfillmentEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Omnichannel Fulfillment Enabled Flag' ;
    rdfs:comment 'Indicates whether the department supports omnichannel fulfillment operations (BOPIS, ROPIS, ship-from-store). True if omnichannel fulfillment is enabled.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planogramCount rdf:type rdf:Property ;
    rdfs:label 'Planogram Count' ;
    rdfs:comment 'Number of active planograms (shelf layout diagrams) assigned to the department. Each planogram defines product placement and facings for a fixture or section.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:posTerminalCount rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Count' ;
    rdfs:comment 'Number of POS terminals or checkout lanes assigned to or located within the department. Relevant for departments with dedicated checkout (e.g., pharmacy, jewelry).' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesTargetMonthly rdf:type rdf:Property ;
    rdfs:label 'Sales Target Monthly' ;
    rdfs:comment 'Monthly sales target or quota for the department in local currency. Used for performance management and comp sales (SSS) analysis.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellingAreaSqFt rdf:type rdf:Property ;
    rdfs:label 'Selling Area Sq Ft' ;
    rdfs:comment 'Total selling floor space allocated to the department measured in square feet. Used to calculate sales per square foot and space productivity metrics.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shrinkageRatePercent rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Rate Percent' ;
    rdfs:comment 'Historical shrinkage rate (inventory loss due to theft, damage, spoilage) for the department expressed as a percentage of sales. Used for loss prevention planning.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether the department requires temperature-controlled environment (e.g., frozen, refrigerated, deli, bakery). True if climate control is required.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureRangeMaxF rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max F' ;
    rdfs:comment 'Maximum temperature threshold in Fahrenheit for temperature-controlled departments. Null for non-temperature-controlled departments.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinF rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min F' ;
    rdfs:comment 'Minimum temperature threshold in Fahrenheit for temperature-controlled departments. Null for non-temperature-controlled departments.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visualMerchandisingStandard rdf:type rdf:Property ;
    rdfs:label 'Visual Merchandising Standard' ;
    rdfs:comment 'Code or reference to the visual merchandising standard or guideline applied to the department. Defines display aesthetics, signage, and presentation rules.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDepartmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Department Id' ;
    rdfs:comment 'Foreign key linking to store.department. Business justification: An SFS fulfillment node (dark store, MFC, or ship-from-store area) operates out of specific departments or picking zones within a store. The sfs_fulfillment_node already has picking_zone_count and pic' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date when this fulfillment node was first activated and began accepting orders for fulfillment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:averagePackTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Pack Time Minutes' ;
    rdfs:comment 'Average time in minutes required to pack a standard order at this fulfillment node. Used for capacity planning and throughput estimation.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averagePickTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Pick Time Minutes' ;
    rdfs:comment 'Average time in minutes required to pick a standard order at this fulfillment node. Used for capacity planning and Service Level Agreement (SLA) estimation.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Account Number' ;
    rdfs:comment 'Account number or identifier used for billing and tracking with the primary carrier. Business-confidential information used for shipment processing.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address of the primary operational contact for this fulfillment node. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the primary operational contact or fulfillment manager for this node. Business-confidential organizational contact information.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number of the primary operational contact for this fulfillment node. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerOrder rdf:type rdf:Property ;
    rdfs:label 'Cost Per Order' ;
    rdfs:comment 'Average operational cost in local currency to fulfill one order from this node, including labor, packaging, and overhead. Used for profitability analysis and routing optimization.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyCapacityOrders rdf:type rdf:Property ;
    rdfs:label 'Daily Capacity Orders' ;
    rdfs:comment 'Maximum number of orders this fulfillment node can process per day, based on staffing, space, and operational constraints. Used by OMS for capacity-based order routing.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dailyCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Daily Capacity Units' ;
    rdfs:comment 'Maximum number of individual units (SKUs) this fulfillment node can pick, pack, and ship per day. Complements order capacity for more granular planning.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventorySyncFrequencyMinutes rdf:type rdf:Property ;
    rdfs:label 'Inventory Sync Frequency Minutes' ;
    rdfs:comment 'Frequency in minutes at which inventory positions at this fulfillment node are synchronized with the central inventory system. Lower values enable more accurate real-time inventory visibility.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextDayCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Next Day Cutoff Time' ;
    rdfs:comment 'Local time cutoff (HH:MM format) by which orders must be placed to qualify for next-day delivery from this node. Null if next-day delivery is not supported.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:omsIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Oms Integration Enabled' ;
    rdfs:comment 'Indicates whether this fulfillment node is integrated with the Order Management System (OMS) for automated order routing and status updates. True if OMS integration is active; false otherwise.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickingZoneCount rdf:type rdf:Property ;
    rdfs:label 'Picking Zone Count' ;
    rdfs:comment 'Number of active picking zones configured within this fulfillment node. Zones organize inventory by category or location to optimize picking efficiency.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickingZoneIdentifiers rdf:type rdf:Property ;
    rdfs:label 'Picking Zone Identifiers' ;
    rdfs:comment 'Comma-separated list of picking zone codes or identifiers active in this fulfillment node (e.g., \'ZONE-A,ZONE-B,ZONE-C\'). Used for WMS integration and picker assignment.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Primary Carrier Code' ;
    rdfs:comment 'Code identifying the primary Third-Party Logistics (3PL) carrier or delivery service provider assigned to this fulfillment node (e.g., \'UPS\', \'FEDEX\', \'USPS\', \'DHL\').' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sameDayCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Same Day Cutoff Time' ;
    rdfs:comment 'Local time cutoff (HH:MM format) by which orders must be placed to qualify for same-day delivery from this node. Null if same-day delivery is not supported.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:servicePostalCodes rdf:type rdf:Property ;
    rdfs:label 'Service Postal Codes' ;
    rdfs:comment 'Comma-separated list of postal codes or postal code prefixes this fulfillment node serves. Used for zone-based order routing when radius-based routing is insufficient.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRadiusKm rdf:type rdf:Property ;
    rdfs:label 'Service Radius Km' ;
    rdfs:comment 'Geographic service radius in kilometers from this fulfillment node. Orders within this radius are eligible for fulfillment from this node. Used by OMS for proximity-based routing.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportsBopis rdf:type rdf:Property ;
    rdfs:label 'Supports Bopis' ;
    rdfs:comment 'Indicates whether this fulfillment node supports Buy Online Pick Up In Store (BOPIS) service. True if BOPIS is available; false otherwise.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsCurbsidePickup rdf:type rdf:Property ;
    rdfs:label 'Supports Curbside Pickup' ;
    rdfs:comment 'Indicates whether this fulfillment node offers curbside pickup service where customers can collect orders without entering the store. True if curbside pickup is available; false otherwise.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsNextDayDelivery rdf:type rdf:Property ;
    rdfs:label 'Supports Next Day Delivery' ;
    rdfs:comment 'Indicates whether this fulfillment node offers next-day delivery service. True if next-day delivery is available; false otherwise.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsSameDayDelivery rdf:type rdf:Property ;
    rdfs:label 'Supports Same Day Delivery' ;
    rdfs:comment 'Indicates whether this fulfillment node offers same-day delivery service. True if same-day delivery is available; false otherwise.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier for this fulfillment node (e.g., \'America/New_York\', \'Europe/London\'). Used to interpret cutoff times and operating hours in local time.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'User identifier or system account that last modified this fulfillment node record. Audit trail for accountability and compliance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Wms Integration Enabled' ;
    rdfs:comment 'Indicates whether this fulfillment node is integrated with the Warehouse Management System (WMS) for automated pick/pack/ship workflows. True if WMS integration is active; false if manual processes are used.' ;
    rdfs:domain ind:SfsFulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiry Date' ;
    rdfs:comment 'Expiration date of the current master supply agreement or contract with this vendor. Used for contract renewal planning and vendor relationship management.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:diversityCertification rdf:type rdf:Property ;
    rdfs:label 'Diversity Certification' ;
    rdfs:comment 'Diversity certification status of the vendor for supplier diversity programs. MBE (Minority Business Enterprise), WBE (Women Business Enterprise), DBE (Disadvantaged Business Enterprise), VBE (Veteran Business Enterprise), LGBTBE (LGBT Business Enterprise), SDVOSB (Service-Disabled Veteran-Owned Small Business), or none if not certified. [ENUM-REF-CANDIDATE: mbe|wbe|dbe|vbe|lgbtbe|sdvosb|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit unique identifier assigned by Dun & Bradstreet to identify business entities globally. Used for vendor qualification, credit assessment, and supplier risk management.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Capable Flag' ;
    rdfs:comment 'Boolean indicator of whether the vendor supports EDI (Electronic Data Interchange) for automated exchange of purchase orders, advance ship notices, invoices, and other business documents. True indicates EDI capability is enabled.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediIdentifier rdf:type rdf:Property ;
    rdfs:label 'Edi Identifier' ;
    rdfs:comment 'Unique EDI identifier or interchange ID used to route electronic documents to this vendor in EDI transactions (e.g., ISA ID, GS1 GLN).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Expiry Date' ;
    rdfs:comment 'Expiration date of the vendor\'s general liability and product liability insurance certificate. Used to ensure vendors maintain required insurance coverage as per contract terms.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPurchaseOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Order Date' ;
    rdfs:comment 'Date of the most recent purchase order issued to this vendor. Used to identify inactive vendors and support vendor rationalization initiatives.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'User ID or system identifier of the person or process that last modified this vendor record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqUnits rdf:type rdf:Property ;
    rdfs:label 'Moq Units' ;
    rdfs:comment 'Minimum Order Quantity (MOQ) in units that must be ordered from this vendor per purchase order or per SKU (Stock Keeping Unit). Used in procurement planning and order optimization.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeDeliveryRatePct rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate Pct' ;
    rdfs:comment 'Vendor performance metric representing the percentage of orders delivered on or before the requested delivery date. Used in vendor scorecards and supplier performance management.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date when the vendor was officially onboarded and approved for transactions in the vendor master system. Represents the start of the vendor relationship.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary contact person for operational communication, order management, and issue resolution.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary contact person at the vendor organization, typically the account manager or sales representative responsible for the business relationship.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Primary telephone number for the vendor contact person, including country code and extension if applicable.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAcceptanceRatePct rdf:type rdf:Property ;
    rdfs:label 'Quality Acceptance Rate Pct' ;
    rdfs:comment 'Vendor performance metric representing the percentage of received goods that pass quality inspection and are accepted into inventory without rejection or return. Used to monitor product quality and vendor compliance.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceEmail rdf:type rdf:Property ;
    rdfs:label 'Remittance Email' ;
    rdfs:comment 'Email address for sending payment remittance advice and electronic payment notifications to the vendor\'s accounts receivable department.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall risk assessment rating for the vendor based on financial stability, operational performance, compliance history, and supply chain risk factors. Low indicates minimal risk, medium indicates moderate risk requiring monitoring, high indicates elevated risk requiring mitigation plans, and critical indicates severe risk requiring immediate action or alternative sourcing.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certified Flag' ;
    rdfs:comment 'Boolean indicator of whether the vendor holds recognized sustainability or environmental certifications (e.g., ISO 14001, B Corp, Fair Trade, Rainforest Alliance). True indicates the vendor has sustainability credentials.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Classification' ;
    rdfs:comment 'Tax classification of the vendor for withholding and reporting purposes. W-9 US person indicates a domestic US entity, W-8 foreign entity indicates a non-US entity subject to withholding, exempt organization indicates tax-exempt status, and government entity indicates a governmental body.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'The vendor\'s tax identification number (TIN) or Employer Identification Number (EIN) used for tax reporting and compliance. Format varies by jurisdiction (e.g., EIN in USA, VAT number in EU).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'The full legal name of the vendor or supplier as registered with governing authorities. Used for contracts, purchase orders, and legal documentation.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Status' ;
    rdfs:comment 'Current operational status of the vendor in the vendor lifecycle. Active vendors are approved for transactions, inactive vendors are not currently used but remain in the system, suspended vendors are temporarily blocked due to performance or compliance issues, pending approval vendors are undergoing onboarding qualification, blocked vendors cannot transact due to critical issues, and terminated vendors have ended their relationship with the business.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorType rdf:type rdf:Property ;
    rdfs:label 'Vendor Type' ;
    rdfs:comment 'Classification of the vendor based on the type of goods or services provided. National brand manufacturers supply branded products, private label producers manufacture store-brand products, DSD (Direct Store Delivery) vendors deliver directly to stores bypassing distribution centers, 3PL (Third-Party Logistics) partners provide logistics and fulfillment services, service providers offer non-product services, and raw material suppliers provide ingredients or components for private label manufacturing.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmiEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Vmi Enabled Flag' ;
    rdfs:comment 'Boolean indicator of whether this vendor participates in Vendor Managed Inventory (VMI) programs where the vendor monitors inventory levels and initiates replenishment orders. True indicates VMI is active for this vendor.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'First line of the business address for the vendor contact\'s office location. Typically includes street number and name.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Second line of the business address for additional location details such as suite, floor, or building number.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'The department or business unit within the vendor organization where this contact works (e.g., Sales, Logistics, Quality Assurance, Finance).' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for the vendor contact, if still used for formal document transmission.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEscalationContact rdf:type rdf:Property ;
    rdfs:label 'Is Escalation Contact' ;
    rdfs:comment 'Indicates whether this contact should be included in escalation workflows for critical issues such as compliance violations, quality failures, or delivery delays.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is the primary point of contact for the vendor. Used for default routing of communications and escalations.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'The official job title or position of the contact within the vendor organization (e.g., Account Manager, Supply Chain Director, Compliance Officer).' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'The most recent date when this vendor contact was engaged in business communication. Used for relationship health monitoring and engagement tracking.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:officeLocation rdf:type rdf:Property ;
    rdfs:label 'Office Location' ;
    rdfs:comment 'The physical office location or site where this contact is based (e.g., headquarters, regional office, manufacturing plant).' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s preferred method for receiving business communications. Supports personalized engagement and improved response rates.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorAddressId rdf:type rdf:Property ;
    rdfs:label 'Vendor Address Id' ;
    rdfs:comment 'Unique identifier for the vendor address record. Primary key.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorAddress .

ind:addressLine3 rdf:type rdf:Property ;
    rdfs:label 'Address Line 3' ;
    rdfs:comment 'Tertiary address line for complex addresses requiring additional location specification. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:VendorAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressName rdf:type rdf:Property ;
    rdfs:label 'Address Name' ;
    rdfs:comment 'Descriptive name or label for the address location (e.g., \'Main Distribution Center\', \'Corporate HQ\', \'Returns Processing Facility\').' ;
    rdfs:domain ind:VendorAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDsdLocation rdf:type rdf:Property ;
    rdfs:label 'Is Dsd Location' ;
    rdfs:comment 'Flag indicating whether this address is a DSD (Direct Store Delivery) origin location where vendors deliver directly to retail stores bypassing distribution centers. True if DSD location, False otherwise.' ;
    rdfs:domain ind:VendorAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryAddress rdf:type rdf:Property ;
    rdfs:label 'Is Primary Address' ;
    rdfs:comment 'Flag indicating whether this is the primary or default address for the vendor. True if primary, False otherwise.' ;
    rdfs:domain ind:VendorAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRemittanceAddress rdf:type rdf:Property ;
    rdfs:label 'Is Remittance Address' ;
    rdfs:comment 'Flag indicating whether this address is used for payment remittance and accounts payable processing. True if remittance address, False otherwise.' ;
    rdfs:domain ind:VendorAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRtvAddress rdf:type rdf:Property ;
    rdfs:label 'Is Rtv Address' ;
    rdfs:comment 'Flag indicating whether this address is designated for RTV (Return to Vendor) processing and merchandise returns. True if RTV address, False otherwise. Critical for reverse logistics and vendor compliance.' ;
    rdfs:domain ind:VendorAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date when the address was last validated against postal authority or third-party address verification services. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:VendorAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationSource rdf:type rdf:Property ;
    rdfs:label 'Validation Source' ;
    rdfs:comment 'Name of the service or system used to validate the address (e.g., USPS Address Validation API, Canada Post AddressComplete, UPS Address Validation, manual verification).' ;
    rdfs:domain ind:VendorAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingLocationId rdf:type rdf:Property ;
    rdfs:label 'Receiving Location Id' ;
    rdfs:comment 'Foreign key linking to store.location. Business justification: DSD and direct-delivery vendor contracts are scoped to specific store receiving locations. Retail contract compliance reporting and store-level vendor management require this link. receiving_location_' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the contract automatically renews at expiration. True if the contract extends for another term unless either party provides termination notice. False if the contract expires without action.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargebackTerms rdf:type rdf:Property ;
    rdfs:label 'Chargeback Terms' ;
    rdfs:comment 'Description of vendor compliance penalties and chargeback conditions. Defines scenarios where the buyer may deduct fees from vendor payments for non-compliance (late delivery, incorrect labeling, missing ASN, pallet configuration errors).' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationsRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications Required' ;
    rdfs:comment 'List of regulatory and industry certifications the vendor must maintain to fulfill this contract. Examples include FDA registration for food suppliers, CPSC compliance for consumer products, organic certifications, fair trade certifications, and safety standards.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Contract Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the contract value and payment terms. All financial terms in this contract are denominated in this currency.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'Uniform Resource Locator pointing to the digitally stored contract document. Links to the document management system or secure file repository where the full contract PDF or scanned image is stored.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally visible business identifier for the vendor contract. Used in procurement documents, purchase orders, and vendor communications.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the vendor contract. Draft contracts are under negotiation. Pending approval contracts await internal sign-off. Active contracts are in force. Suspended contracts are temporarily paused. Terminated contracts are ended before expiry. Expired contracts have passed their end date. Renewed contracts have been extended. [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|terminated|expired|renewed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the vendor contract. National brand contracts cover branded merchandise from manufacturers. Private label contracts govern store-brand product manufacturing. DSD (Direct Store Delivery) contracts define vendor-managed delivery terms. Master service agreements cover ongoing services. Blanket orders establish terms for recurring purchases. Framework agreements set umbrella terms for multiple purchase orders.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValueAmount rdf:type rdf:Property ;
    rdfs:label 'Contract Value Amount' ;
    rdfs:comment 'Total monetary value committed under this vendor contract. Represents the aggregate purchase commitment or spending cap over the contract term. Used for budget planning and vendor performance tracking.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Standard discount rate applied to purchases under this contract. Expressed as a percentage off list price. Used for volume discounts, early payment discounts, or negotiated pricing agreements.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ediEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Enabled Flag' ;
    rdfs:comment 'Indicates whether Electronic Data Interchange is enabled for transactions under this contract. True if purchase orders, invoices, and shipping notices are exchanged via EDI. False for manual or email-based document exchange.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediQualifier rdf:type rdf:Property ;
    rdfs:label 'Edi Qualifier' ;
    rdfs:comment 'EDI interchange identifier qualifier for the vendor. Examples include 01 (DUNS number), 12 (phone number), 14 (UPC), ZZ (mutually defined). Used to route EDI messages to the correct vendor system.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether this contract grants the vendor exclusive rights to supply specific products or categories. True if the buyer commits to purchasing exclusively from this vendor for the covered scope. False for non-exclusive agreements.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Description of the product categories, geographic regions, or channels covered by the exclusivity clause. Applicable only when exclusivity_flag is true. Defines the boundaries of the exclusive supply arrangement.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirements rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirements' ;
    rdfs:comment 'Minimum insurance coverage the vendor must carry to fulfill this contract. Typically includes general liability, product liability, and cargo insurance with specified coverage limits.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moqUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Moq Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the minimum order quantity. Examples include EA (each), CS (case), PLT (pallet), KG (kilogram), LB (pound). Must align with vendor catalog and purchase order units.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAssuranceTerms rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Terms' ;
    rdfs:comment 'Quality standards and inspection requirements for goods supplied under this contract. Defines acceptable quality levels, sampling procedures, defect rates, and vendor quality certifications required.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Duration in months for each automatic renewal period. Applicable only when auto_renewal_flag is true. Contract extends by this duration at each renewal.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnToVendorPolicy rdf:type rdf:Property ;
    rdfs:label 'Return To Vendor Policy' ;
    rdfs:comment 'Terms governing the return of defective, damaged, or unsold merchandise to the vendor. Defines RTV authorization process, restocking fees, return shipping responsibility, and credit issuance timeline.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingPoint rdf:type rdf:Property ;
    rdfs:label 'Shipping Point' ;
    rdfs:comment 'Vendor facility or distribution center from which goods are shipped under this contract. Used for logistics planning, freight cost calculation, and delivery time estimation.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'Date when the contract was signed by the authorized buyer representative. Used for contract validity verification and audit trail.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of calendar days advance notice required to terminate the contract. Either party must provide written notice this many days before the desired termination date.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Vendor Signatory Name' ;
    rdfs:comment 'Full name of the authorized representative who signed the contract on behalf of the vendor organization. Used for contract validation and audit trail.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Vendor Signatory Title' ;
    rdfs:comment 'Job title or role of the vendor authorized signatory. Examples include CEO, VP Sales, Director of Business Development. Used to verify vendor signing authority.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Signature Date' ;
    rdfs:comment 'Date when the contract was signed by the authorized vendor representative. Used for contract validity verification and audit trail.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargebackId rdf:type rdf:Property ;
    rdfs:label 'Chargeback Id' ;
    rdfs:comment 'Unique identifier for the vendor compliance chargeback penalty record.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnReceiptId rdf:type rdf:Property ;
    rdfs:label 'Return Receipt Id' ;
    rdfs:comment 'Foreign key linking to returns.return_receipt. Business justification: Chargebacks for receiving violations (damaged goods, short shipments) are triggered by return receipt inspection findings. The AP compliance process requires linking chargeback to the physical return ' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReturnReceipt .

ind:returnsRmaId rdf:type rdf:Property ;
    rdfs:label 'Returns Rma Id' ;
    rdfs:comment 'Foreign key linking to returns.rma. Business justification: Vendor chargebacks often stem from customer returns (damaged/defective goods). AP teams reconcile chargebacks against originating RMAs to validate penalty legitimacy and negotiate vendor disputes. Ena' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rma .

ind:rtvRequestId rdf:type rdf:Property ;
    rdfs:label 'Rtv Request Id' ;
    rdfs:comment 'Foreign key linking to supplier.rtv_request. Business justification: In retail vendor compliance, chargebacks can be issued as a direct result of RTV process violations — for example, when a vendor fails to comply with return routing instructions, labeling requirements' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RtvRequest .

ind:violationLocationId rdf:type rdf:Property ;
    rdfs:label 'Violation Location Id' ;
    rdfs:comment 'Foreign key linking to store.store_location. Business justification: Chargebacks for routing guide violations, labeling errors, or receiving discrepancies originate at specific receiving locations (stores or DCs). Tracking the violation location supports root cause ana' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:affectedUnits rdf:type rdf:Property ;
    rdfs:label 'Affected Units' ;
    rdfs:comment 'The number of units (SKUs, cartons, or pallets) impacted by the compliance violation.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargebackNumber rdf:type rdf:Property ;
    rdfs:label 'Chargeback Number' ;
    rdfs:comment 'Externally visible business identifier for the chargeback penalty, used in vendor communications and dispute resolution.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackStatus rdf:type rdf:Property ;
    rdfs:label 'Chargeback Status' ;
    rdfs:comment 'Current lifecycle state of the chargeback penalty in the dispute and recovery workflow. [ENUM-REF-CANDIDATE: pending|issued|disputed|under_review|approved|rejected|paid|written_off|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackType rdf:type rdf:Property ;
    rdfs:label 'Chargeback Type' ;
    rdfs:comment 'High-level category of the compliance violation that triggered the chargeback penalty. [ENUM-REF-CANDIDATE: routing_guide_violation|labeling_non_compliance|edi_failure|late_shipment|fill_rate_shortfall|asn_error|packaging_defect|quality_defect|documentation_error|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Debit Memo Number' ;
    rdfs:comment 'The external document number of the debit memo issued to the vendor for the chargeback penalty, if applicable.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionDate rdf:type rdf:Property ;
    rdfs:label 'Detection Date' ;
    rdfs:comment 'The date on which the compliance violation was formally identified and logged in the system, which may differ from the violation date.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'The date on which the vendor formally disputed the chargeback penalty.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isRepeatViolation rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Violation' ;
    rdfs:comment 'Flag indicating whether this chargeback represents a repeat violation of the same compliance rule by the vendor within a defined time window.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'The communication channel used to notify the vendor of the chargeback penalty.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'The date on which the chargeback notification was sent to the vendor through the vendor portal or EDI channel.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'The monetary value of the chargeback penalty assessed against the vendor for the compliance violation.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Penalty Calculation Method' ;
    rdfs:comment 'The method used to calculate the chargeback penalty amount, such as a fixed flat fee or a percentage of the order value.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyPercentage rdf:type rdf:Property ;
    rdfs:label 'Penalty Percentage' ;
    rdfs:comment 'The percentage rate applied to the order or shipment value when the penalty calculation method is percentage-based.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousViolationCount rdf:type rdf:Property ;
    rdfs:label 'Previous Violation Count' ;
    rdfs:comment 'The number of prior chargebacks issued to this vendor for the same violation category within the trailing 12-month period.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recoveryDate rdf:type rdf:Property ;
    rdfs:label 'Recovery Date' ;
    rdfs:comment 'The date on which the chargeback penalty amount was successfully recovered from the vendor through the specified recovery method.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorScorecardImpact rdf:type rdf:Property ;
    rdfs:label 'Vendor Scorecard Impact' ;
    rdfs:comment 'The negative impact score applied to the vendors performance scorecard as a result of this chargeback, used in vendor relationship management and future sourcing decisions.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:violationCategory rdf:type rdf:Property ;
    rdfs:label 'Violation Category' ;
    rdfs:comment 'Detailed classification of the specific compliance rule or requirement that was violated, such as GS1-128 labeling failure, RFID tag missing, or incorrect pallet configuration.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationDate rdf:type rdf:Property ;
    rdfs:label 'Violation Date' ;
    rdfs:comment 'The date on which the compliance violation occurred or was detected by the receiving facility or quality control process.' ;
    rdfs:domain ind:Chargeback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User ID or system identifier of the person or automated process that created the chargeback record.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Id' ;
    rdfs:comment 'Identifier of the vendor facility or location where the returned merchandise is to be delivered.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:originLocationId rdf:type rdf:Property ;
    rdfs:label 'Origin Location Id' ;
    rdfs:comment 'Identifier of the retailer location (store, distribution center, or warehouse) from which the merchandise is being returned.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:originatingReturnsRmaId rdf:type rdf:Property ;
    rdfs:label 'Originating Returns Rma Id' ;
    rdfs:comment 'Foreign key linking to returns.rma. Business justification: Supplier RTVs are frequently triggered by customer returns. Buyers analyze which customer return reasons drive vendor RTVs to negotiate better contract terms and identify systemic quality issues. Enab' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rma .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'The name of the retailer manager or authorized personnel who approved the RTV request before submission to the vendor.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'The date when the vendor approved and authorized the return, issuing the RMA number.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chargebackReason rdf:type rdf:Property ;
    rdfs:label 'Chargeback Reason' ;
    rdfs:comment 'Explanation of the vendor compliance violation or quality issue that resulted in the chargeback penalty.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditDate rdf:type rdf:Property ;
    rdfs:label 'Credit Date' ;
    rdfs:comment 'The date when the vendor issued credit or replacement for the returned merchandise.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'The credit memo number issued by the vendor to document the financial credit provided for the returned merchandise.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediControlNumber rdf:type rdf:Property ;
    rdfs:label 'Edi Control Number' ;
    rdfs:comment 'The unique control number assigned to the EDI transmission of this RTV request for tracking and reconciliation purposes.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediTransactionSet rdf:type rdf:Property ;
    rdfs:label 'Edi Transaction Set' ;
    rdfs:comment 'The EDI transaction set identifier used for electronic communication of this RTV request with the vendor (e.g., EDI 180 Return Merchandise Authorization).' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightResponsibility rdf:type rdf:Property ;
    rdfs:label 'Freight Responsibility' ;
    rdfs:comment 'Indicates which party (vendor or retailer) is responsible for paying the freight costs associated with returning the merchandise.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResult rdf:type rdf:Property ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'The outcome of the vendor\'s quality inspection of the returned merchandise, determining eligibility for credit or replacement.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecallRelated rdf:type rdf:Property ;
    rdfs:label 'Is Recall Related' ;
    rdfs:comment 'Boolean flag indicating whether this RTV request is related to a product recall mandated by regulatory authorities or the manufacturer.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Boolean flag indicating whether the vendor requires a quality inspection of the returned merchandise before issuing credit or replacement.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Number' ;
    rdfs:comment 'The official recall identification number issued by the regulatory body or manufacturer if this RTV is recall-related.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'The date when the vendor confirmed receipt of the returned merchandise at their facility.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'The date when the RTV request was initiated by the retailer. This is the principal business event timestamp for the transaction.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Return Reason Description' ;
    rdfs:comment 'Detailed free-text explanation of the reason for the return, providing additional context beyond the standardized reason code.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtvStatus rdf:type rdf:Property ;
    rdfs:label 'Rtv Status' ;
    rdfs:comment 'Current lifecycle status of the RTV request indicating its position in the return workflow from draft through final credit or closure. [ENUM-REF-CANDIDATE: draft|submitted|approved|rejected|in_transit|received|credited|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalReturnQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Return Quantity' ;
    rdfs:comment 'The total quantity of units being returned to the vendor across all SKUs in this RTV request, measured in the base unit of measure.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReturnValue rdf:type rdf:Property ;
    rdfs:label 'Total Return Value' ;
    rdfs:comment 'The total monetary value of the merchandise being returned, calculated at cost basis. Represents the expected credit or reimbursement amount.' ;
    rdfs:domain ind:RtvRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorScorecardId rdf:type rdf:Property ;
    rdfs:label 'Vendor Scorecard Id' ;
    rdfs:comment 'Unique identifier for the vendor scorecard record. Primary key. Role: TRANSACTION_HEADER (scorecard is a periodic performance evaluation event).' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargebackCount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Count' ;
    rdfs:comment 'Total number of chargebacks (vendor compliance penalties) issued to the vendor during the scoring period for violations such as late delivery, incorrect labeling, or packaging non-compliance.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compositeScore rdf:type rdf:Property ;
    rdfs:label 'Composite Score' ;
    rdfs:comment 'Weighted overall vendor performance score calculated from individual KPI values (on-time delivery, fill rate, quality, etc.). Scale typically 0-100. Used for vendor tier classification.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Deadline by which the vendor must submit a corrective action plan if required.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Flag indicating whether the vendor is required to submit a corrective action plan based on scorecard results (true if performance is below acceptable thresholds).' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Edi Compliance Rate' ;
    rdfs:comment 'Percentage of transactions (purchase orders, ASNs, invoices) successfully transmitted via EDI without errors or manual intervention during the scoring period.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Date' ;
    rdfs:comment 'Date when the scorecard was completed and finalized by the evaluator.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fillRate rdf:type rdf:Property ;
    rdfs:label 'Fill Rate' ;
    rdfs:comment 'Percentage of ordered quantity that was fulfilled by the vendor during the scoring period. Measures vendor ability to meet demand without stockouts.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Invoice Accuracy Rate' ;
    rdfs:comment 'Percentage of invoices submitted without pricing, quantity, or calculation errors during the scoring period. Measures vendor billing quality.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimeAdherenceRate rdf:type rdf:Property ;
    rdfs:label 'Lead Time Adherence Rate' ;
    rdfs:comment 'Percentage of orders where the vendor met the agreed lead time from order placement to delivery during the scoring period.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderQuantityComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity Compliance Rate' ;
    rdfs:comment 'Percentage of orders where the vendor honored MOQ agreements without imposing additional fees or rejecting orders during the scoring period.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeDeliveryRate rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate' ;
    rdfs:comment 'Percentage of purchase orders or shipments delivered on or before the promised delivery date during the scoring period. Key KPI for vendor reliability.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodCompositeScore rdf:type rdf:Property ;
    rdfs:label 'Prior Period Composite Score' ;
    rdfs:comment 'Composite score from the previous scoring period, used to calculate trend and performance improvement or decline.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productQualityScore rdf:type rdf:Property ;
    rdfs:label 'Product Quality Score' ;
    rdfs:comment 'Composite quality score based on defect rates, customer returns, and quality inspection results for products supplied by the vendor during the scoring period. Scale typically 0-100.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnToVendorAmount rdf:type rdf:Property ;
    rdfs:label 'Return To Vendor Amount' ;
    rdfs:comment 'Total monetary value of goods returned to the vendor during the scoring period, typically in USD.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnToVendorCount rdf:type rdf:Property ;
    rdfs:label 'Return To Vendor Count' ;
    rdfs:comment 'Total number of RTV transactions initiated during the scoring period due to defects, overstock, or non-compliance.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scoreTrend rdf:type rdf:Property ;
    rdfs:label 'Score Trend' ;
    rdfs:comment 'Directional trend of vendor performance compared to the prior period (improving, stable, or declining).' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardNumber rdf:type rdf:Property ;
    rdfs:label 'Scorecard Number' ;
    rdfs:comment 'Business identifier for the scorecard, typically formatted as SC-YYYYMMDD or similar pattern for external reference and reporting.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardStatus rdf:type rdf:Property ;
    rdfs:label 'Scorecard Status' ;
    rdfs:comment 'Current lifecycle status of the scorecard indicating whether it is in draft, published for vendor review, under internal review, finalized, or archived.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoringPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Scoring Period End Date' ;
    rdfs:comment 'The end date of the evaluation period covered by this scorecard (e.g., end of quarter or month).' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scoringPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Scoring Period Start Date' ;
    rdfs:comment 'The start date of the evaluation period covered by this scorecard (e.g., beginning of quarter or month).' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalPurchaseOrderCount rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Order Count' ;
    rdfs:comment 'Total number of purchase orders issued to the vendor during the scoring period. Provides context for volume-based KPI interpretation.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPurchaseOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Order Value' ;
    rdfs:comment 'Total monetary value of purchase orders issued to the vendor during the scoring period, typically in USD. Provides spend context for scorecard evaluation.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Acknowledgment Date' ;
    rdfs:comment 'Date when the vendor acknowledged receipt and review of the scorecard.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Notification Date' ;
    rdfs:comment 'Date when the scorecard was shared with the vendor for review and discussion.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorTier rdf:type rdf:Property ;
    rdfs:label 'Vendor Tier' ;
    rdfs:comment 'Classification tier assigned to the vendor based on the composite score and strategic importance. Preferred vendors receive priority, probation vendors face restrictions, suspended vendors are blocked from new orders.' ;
    rdfs:domain ind:VendorScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationInventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Inventory Node Id' ;
    rdfs:comment 'Foreign key linking to inventory.inventory_node. Business justification: Lead time agreements specify delivery terms to specific DCs, stores, or cross-dock facilities. Essential for replenishment planning, inbound appointment scheduling, and on-time delivery SLA measuremen' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:productCategoryId rdf:type rdf:Property ;
    rdfs:label 'Product Category Id' ;
    rdfs:comment 'Reference to the product category covered by this agreement when scope_level is category or subcategory.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive name or title of the lead time agreement for easy identification.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Business identifier for the lead time agreement, used for external reference and vendor communication.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the lead time agreement.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the lead time agreement based on its purpose and operational context. VMI indicates Vendor Managed Inventory agreements.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compliancePenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Compliance Penalty Rate' ;
    rdfs:comment 'Percentage rate applied as chargeback penalty for vendor non-compliance with lead time or delivery terms.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryFrequency rdf:type rdf:Property ;
    rdfs:label 'Delivery Frequency' ;
    rdfs:comment 'Standard frequency of deliveries from vendor. DSD indicates Direct Store Delivery model.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowEndTime rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End Time' ;
    rdfs:comment 'End time of the agreed delivery window at distribution center (HH:MM format).' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryWindowStartTime rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start Time' ;
    rdfs:comment 'Start time of the agreed delivery window at distribution center (HH:MM format).' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expeditedLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Expedited Lead Time Days' ;
    rdfs:comment 'Reduced lead time in days available for rush or expedited orders, typically at premium cost.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fillRateSlaPercent rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Sla Percent' ;
    rdfs:comment 'Target percentage of ordered quantity that vendor must deliver to meet order completion SLA.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:innerPackQuantity rdf:type rdf:Property ;
    rdfs:label 'Inner Pack Quantity' ;
    rdfs:comment 'Number of consumer units in an inner pack within the master case, used for store-level replenishment.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onTimeDeliverySlaPercent rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Sla Percent' ;
    rdfs:comment 'Target percentage of deliveries that must arrive within the agreed lead time window to meet SLA.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderIncrementQuantity rdf:type rdf:Property ;
    rdfs:label 'Order Increment Quantity' ;
    rdfs:comment 'Quantity increment in which orders must be placed above the MOQ (e.g., must order in multiples of 12 units).' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originLocation rdf:type rdf:Property ;
    rdfs:label 'Origin Location' ;
    rdfs:comment 'Geographic location or facility from which vendor ships products (city, state, country).' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packSize rdf:type rdf:Property ;
    rdfs:label 'Pack Size' ;
    rdfs:comment 'Number of consumer units contained in a single vendor pack or case.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:palletQuantity rdf:type rdf:Property ;
    rdfs:label 'Pallet Quantity' ;
    rdfs:comment 'Standard number of cases or units per pallet for warehouse receiving and cross-docking operations.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days advance notice required before agreement renewal or termination.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scopeLevel rdf:type rdf:Property ;
    rdfs:label 'Scope Level' ;
    rdfs:comment 'Granularity level at which this lead time agreement applies: vendor-wide, product category, subcategory, individual SKU, or product group.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalLeadTimeAdjustmentDays rdf:type rdf:Property ;
    rdfs:label 'Seasonal Lead Time Adjustment Days' ;
    rdfs:comment 'Additional days added to standard lead time during peak seasonal periods (e.g., holiday season, back-to-school).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal Period End Date' ;
    rdfs:comment 'End date of the seasonal period when lead time adjustments apply.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonalPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal Period Start Date' ;
    rdfs:comment 'Start date of the seasonal period when lead time adjustments apply.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standardLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Standard Lead Time Days' ;
    rdfs:comment 'Standard number of days from purchase order placement to goods receipt at distribution center under normal operating conditions.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportationMode rdf:type rdf:Property ;
    rdfs:label 'Transportation Mode' ;
    rdfs:comment 'Primary mode of transportation used for shipments under this agreement.' ;
    rdfs:domain ind:LeadTimeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casePackQuantity rdf:type rdf:Property ;
    rdfs:label 'Case Pack Quantity' ;
    rdfs:comment 'Number of individual units contained in one vendor case pack. Used for ordering and receiving calculations.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the unit cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Cost Effective Date' ;
    rdfs:comment 'The date from which the current unit cost is effective. Used for cost change tracking and historical cost analysis.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Cost Expiration Date' ;
    rdfs:comment 'The date through which the current unit cost remains valid. Null indicates open-ended pricing.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dsdEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Eligible Flag' ;
    rdfs:comment 'Indicates whether this item can be delivered directly to stores by the vendor, bypassing the DC (Distribution Center). Common for beverages, bread, and snacks.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCostChangeDate rdf:type rdf:Property ;
    rdfs:label 'Last Cost Change Date' ;
    rdfs:comment 'The date when the unit cost was last modified. Used for cost trend analysis and vendor negotiation tracking.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Order Date' ;
    rdfs:comment 'The date when this vendor-item combination was last ordered. Used to identify slow-moving or obsolete vendor relationships.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:palletHi rdf:type rdf:Property ;
    rdfs:label 'Pallet Hi' ;
    rdfs:comment 'Number of layers (tiers) stacked on a pallet. Part of the TI/HI pallet configuration used in warehouse and DC operations.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:palletTi rdf:type rdf:Property ;
    rdfs:label 'Pallet Ti' ;
    rdfs:comment 'Number of cases per layer on a pallet. Part of the TI/HI pallet configuration used in warehouse and DC (Distribution Center) operations.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Indicates whether this vendor is the preferred source for this item when multiple vendors supply the same product. Used in automated sourcing decisions.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorItemCategory rdf:type rdf:Property ;
    rdfs:label 'Vendor Item Category' ;
    rdfs:comment 'The vendor\'s product category classification for this item. May differ from internal merchandising hierarchy.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorItemDescription rdf:type rdf:Property ;
    rdfs:label 'Vendor Item Description' ;
    rdfs:comment 'The vendor\'s description of the item as it appears in their catalog. May differ from internal product description.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorItemStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Item Status' ;
    rdfs:comment 'Current lifecycle status of this vendor-item relationship. Active items are available for ordering; discontinued items are being phased out.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPackConfiguration rdf:type rdf:Property ;
    rdfs:label 'Vendor Pack Configuration' ;
    rdfs:comment 'Description of how the vendor packages this item (e.g., case pack, master carton, pallet). Defines the vendor\'s standard shipping unit.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryTurnTarget rdf:type rdf:Property ;
    rdfs:label 'Inventory Turn Target' ;
    rdfs:comment 'Target number of times inventory is expected to turn (sell through and be replenished) during the plan period.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otbBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Otb Budget Amount' ;
    rdfs:comment 'Total Open to Buy budget allocated for purchasing inventory within this plan, representing the financial commitment available for buying decisions.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Business identifier for the merchandise plan, used for external reference and reporting.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Descriptive name of the merchandise plan (e.g., \'Spring 2024 Apparel Plan\', \'Holiday Electronics Plan\').' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNotes rdf:type rdf:Property ;
    rdfs:label 'Plan Notes' ;
    rdfs:comment 'Free-text notes and commentary about the merchandise plan, including strategic rationale, market conditions, and special considerations.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedBeginningInventoryAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Beginning Inventory Amount' ;
    rdfs:comment 'Planned retail value of inventory at the start of the plan period.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Cost Amount' ;
    rdfs:comment 'Total planned cost of goods to be purchased under this merchandise plan.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEndingInventoryAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Ending Inventory Amount' ;
    rdfs:comment 'Planned retail value of inventory at the end of the plan period.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Margin Amount' ;
    rdfs:comment 'Expected gross margin (planned sales minus planned cost) to be achieved during the plan period.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Planned Margin Percent' ;
    rdfs:comment 'Target gross margin percentage (planned margin divided by planned sales) for the merchandise plan.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMarkdownAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Markdown Amount' ;
    rdfs:comment 'Anticipated markdown dollars to be taken during the plan period for price reductions and promotions.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMarkdownPercent rdf:type rdf:Property ;
    rdfs:label 'Planned Markdown Percent' ;
    rdfs:comment 'Target markdown rate as a percentage of planned sales.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReceiptAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Receipt Amount' ;
    rdfs:comment 'Total retail value of inventory receipts planned to arrive during the plan period.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Sales Amount' ;
    rdfs:comment 'Forecasted retail sales revenue expected to be generated during the plan period.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedUnits rdf:type rdf:Property ;
    rdfs:label 'Planned Units' ;
    rdfs:comment 'Total number of inventory units planned to be purchased and sold during the plan period.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorYearMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Prior Year Margin Percent' ;
    rdfs:comment 'Actual gross margin percentage achieved during the comparable period in the prior year.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorYearSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Year Sales Amount' ;
    rdfs:comment 'Actual sales amount from the comparable period in the prior year, used for year-over-year comparison.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorYearUnits rdf:type rdf:Property ;
    rdfs:label 'Prior Year Units' ;
    rdfs:comment 'Actual units sold during the comparable period in the prior year.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sellThroughTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Sell Through Target Percent' ;
    rdfs:comment 'Target percentage of inventory expected to be sold during the plan period.' ;
    rdfs:domain ind:MerchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryAssortmentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Primary Assortment Category Id' ;
    rdfs:comment 'Reference to the merchandise category this assortment plan covers. Links to the product category hierarchy for strategic alignment.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:assortmentBreadthTarget rdf:type rdf:Property ;
    rdfs:label 'Assortment Breadth Target' ;
    rdfs:comment 'Target number of distinct product lines or styles to be carried, representing the width of the assortment offering across the category.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assortmentDepthTarget rdf:type rdf:Property ;
    rdfs:label 'Assortment Depth Target' ;
    rdfs:comment 'Target number of variants (sizes, colors, styles) within each product line to achieve desired assortment depth. Balances customer choice with inventory complexity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clusterStrategyDescription rdf:type rdf:Property ;
    rdfs:label 'Cluster Strategy Description' ;
    rdfs:comment 'Detailed description of the assortment strategy tailored for the store cluster, including rationale for SKU selection, depth/breadth decisions, and localization considerations.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusteringMethodology rdf:type rdf:Property ;
    rdfs:label 'Clustering Methodology' ;
    rdfs:comment 'Methodology used to define the store cluster for this assortment plan: sales_volume (grouped by revenue tiers), demographics (customer profile similarity), climate (weather-driven assortment needs), format (store size/type), geographic (regional proximity), or hybrid (combination of multiple factors).' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalPlanReference rdf:type rdf:Property ;
    rdfs:label 'External Plan Reference' ;
    rdfs:comment 'External reference identifier for the assortment plan in upstream or partner systems, used for cross-system reconciliation and integration.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalBrandSkuCount rdf:type rdf:Property ;
    rdfs:label 'National Brand Sku Count' ;
    rdfs:comment 'Number of national brand (vendor brand) SKUs included in the assortment plan. Complements private label count to show brand mix strategy.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otbCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Otb Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the OTB (Open to Buy) budget amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedSkuCount rdf:type rdf:Property ;
    rdfs:label 'Planned Sku Count' ;
    rdfs:comment 'Total number of distinct SKUs (Stock Keeping Units) planned to be carried under this assortment plan. Represents assortment breadth and is a key metric for space planning and inventory investment.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planogramRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Planogram Required Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether a planogram (POG - shelf layout diagram) is required for this assortment plan. True indicates visual merchandising and space planning are needed.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privateLabelMixPercent rdf:type rdf:Property ;
    rdfs:label 'Private Label Mix Percent' ;
    rdfs:comment 'Target percentage of private label SKUs within the total assortment, expressed as a percentage (0.00 to 100.00). Key metric for margin management and brand positioning strategy.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:privateLabelSkuCount rdf:type rdf:Property ;
    rdfs:label 'Private Label Sku Count' ;
    rdfs:comment 'Number of private label (store brand) SKUs included in the assortment plan. Used to track private label penetration strategy and margin optimization.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetGmroi rdf:type rdf:Property ;
    rdfs:label 'Target Gmroi' ;
    rdfs:comment 'Target GMROI (Gross Margin Return on Investment) for the assortment plan, measuring gross margin dollars earned for every dollar of average inventory investment. Key profitability metric for assortment performance evaluation.' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetInventoryTurnRate rdf:type rdf:Property ;
    rdfs:label 'Target Inventory Turn Rate' ;
    rdfs:comment 'Target number of times inventory should turn (sell and replenish) during the plan period. Higher turns indicate better inventory productivity and reduced carrying costs.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSellThroughRatePercent rdf:type rdf:Property ;
    rdfs:label 'Target Sell Through Rate Percent' ;
    rdfs:comment 'Target sell-through rate (percentage of inventory sold within the plan period) for this assortment plan, expressed as a percentage (0.00 to 100.00). Critical KPI (Key Performance Indicator) for inventory productivity and markdown risk management.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Id' ;
    rdfs:comment 'Reference to the parent node in the merchandise hierarchy. Null for top-level departments.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:actualGmroi rdf:type rdf:Property ;
    rdfs:label 'Actual Gmroi' ;
    rdfs:comment 'Most recent actual GMROI (Gross Margin Return on Investment) achieved by the category.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSellThroughRate rdf:type rdf:Property ;
    rdfs:label 'Actual Sell Through Rate' ;
    rdfs:comment 'Most recent actual sell-through rate achieved by the category. Expressed as percentage (e.g., 82.30 = 82.3%).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assortmentGapFindings rdf:type rdf:Property ;
    rdfs:label 'Assortment Gap Findings' ;
    rdfs:comment 'Documented gaps in the current assortment identified during category review (e.g., missing price points, underrepresented styles, competitor advantages).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Business identifier code for the category used across systems and reporting. Unique within hierarchy level.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed description of the category scope, assortment strategy, and business purpose.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Human-readable name of the merchandise category (e.g., Women\'s Apparel, Consumer Electronics, Fresh Produce).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryRole rdf:type rdf:Property ;
    rdfs:label 'Category Role' ;
    rdfs:comment 'Strategic role of the category in the assortment (destination=traffic driver, routine=frequent purchase, convenience=fill-in, seasonal=time-bound, occasional=infrequent).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryStatus rdf:type rdf:Property ;
    rdfs:label 'Category Status' ;
    rdfs:comment 'Current lifecycle status of the category in the merchandise hierarchy.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:division rdf:type rdf:Property ;
    rdfs:label 'Division' ;
    rdfs:comment 'Top-level business division (e.g., Hardlines, Softlines, Grocery, Electronics). Applicable to department-level nodes.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric level in the merchandise hierarchy (1=Department, 2=Category, 3=Subcategory, 4=Segment).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Full path from root to this node (e.g., /01/01-05/01-05-03) for efficient hierarchy traversal and reporting.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLeafNode rdf:type rdf:Property ;
    rdfs:label 'Is Leaf Node' ;
    rdfs:comment 'Indicates whether this category is a leaf node (lowest level) in the hierarchy with no child categories. True for segments, false for departments and categories with children.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:merchandiseType rdf:type rdf:Property ;
    rdfs:label 'Merchandise Type' ;
    rdfs:comment 'High-level merchandise classification for strategic planning and reporting. [ENUM-REF-CANDIDATE: hardlines|softlines|grocery|electronics|home|health_beauty|seasonal|services — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakSeason rdf:type rdf:Property ;
    rdfs:label 'Peak Season' ;
    rdfs:comment 'Primary selling season for seasonal categories (e.g., Q4 Holiday, Spring, Back-to-School, Summer).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceVarianceNotes rdf:type rdf:Property ;
    rdfs:label 'Performance Variance Notes' ;
    rdfs:comment 'Narrative explanation of performance gaps between actual and target metrics, including root cause analysis and contributing factors.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelPenetrationTarget rdf:type rdf:Property ;
    rdfs:label 'Private Label Penetration Target' ;
    rdfs:comment 'Target percentage of category sales from private label (store brand) products. Expressed as percentage (e.g., 25.00 = 25%).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedActions rdf:type rdf:Property ;
    rdfs:label 'Recommended Actions' ;
    rdfs:comment 'Strategic and tactical recommendations from the most recent category review (e.g., expand assortment, rationalize SKUs, adjust pricing, increase promotions).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalityFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonality Flag' ;
    rdfs:comment 'Indicates whether the category exhibits significant seasonal demand patterns requiring seasonal planning and inventory strategies.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strategicObjective rdf:type rdf:Property ;
    rdfs:label 'Strategic Objective' ;
    rdfs:comment 'Current strategic goal for the category (e.g., market share growth, margin expansion, assortment rationalization, private label penetration).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetInventoryTurns rdf:type rdf:Property ;
    rdfs:label 'Target Inventory Turns' ;
    rdfs:comment 'Target number of inventory turns per year for the category (COGS divided by average inventory value).' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Target Margin Percent' ;
    rdfs:comment 'Target gross margin percentage for the category. Expressed as percentage (e.g., 42.50 = 42.5%).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSellThroughRate rdf:type rdf:Property ;
    rdfs:label 'Target Sell Through Rate' ;
    rdfs:comment 'Target sell-through rate (percentage of inventory sold within a period) for the category. Expressed as percentage (e.g., 85.00 = 85%).' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedCategoryCodes rdf:type rdf:Property ;
    rdfs:label 'Assigned Category Codes' ;
    rdfs:comment 'Comma-separated list of category codes for which this buyer has purchasing and assortment planning responsibility. Categories are sub-groupings within departments (e.g., Men\'s Shirts, Laptops, Bedding).' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedDepartmentCodes rdf:type rdf:Property ;
    rdfs:label 'Assigned Department Codes' ;
    rdfs:comment 'Comma-separated list of department codes for which this buyer has purchasing responsibility. Departments represent high-level merchandise groupings (e.g., Apparel, Electronics, Home Goods).' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assortmentPlanningSystemAccess rdf:type rdf:Property ;
    rdfs:label 'Assortment Planning System Access' ;
    rdfs:comment 'Level of access the buyer has to the assortment planning and space optimization systems. Full access allows creation and modification of planograms and assortment plans.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerCode rdf:type rdf:Property ;
    rdfs:label 'Buyer Code' ;
    rdfs:comment 'Short alphanumeric code identifying the buyer in purchase orders, vendor contracts, and merchandising reports. Often used as a business key in legacy systems.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerName rdf:type rdf:Property ;
    rdfs:label 'Buyer Name' ;
    rdfs:comment 'Full legal name of the merchandise buyer or category manager.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerStatus rdf:type rdf:Property ;
    rdfs:label 'Buyer Status' ;
    rdfs:comment 'Current employment and operational status of the buyer. Inactive or terminated buyers cannot approve purchase orders or modify OTB budgets.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerType rdf:type rdf:Property ;
    rdfs:label 'Buyer Type' ;
    rdfs:comment 'Classification of the buyer role indicating seniority and scope of responsibility. Determines approval authority and OTB (Open to Buy) limits.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyingAuthorityLimit rdf:type rdf:Property ;
    rdfs:label 'Buying Authority Limit' ;
    rdfs:comment 'Maximum dollar amount the buyer can approve for a single purchase order without requiring additional management approval. Expressed in the company\'s reporting currency.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationCredentials rdf:type rdf:Property ;
    rdfs:label 'Certification Credentials' ;
    rdfs:comment 'Comma-separated list of professional certifications held by the buyer (e.g., Certified Professional in Supply Management, Retail Management Certificate). Used for professional development tracking.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the buyer was hired into the organization. Used for tenure analysis and performance benchmarking.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internationalSourcingFlag rdf:type rdf:Property ;
    rdfs:label 'International Sourcing Flag' ;
    rdfs:comment 'Indicates whether the buyer is authorized to source products from international vendors and manage cross-border procurement. True if international sourcing is within scope.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageProficiency rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency' ;
    rdfs:comment 'Comma-separated list of languages the buyer is proficient in, relevant for international vendor negotiations and global sourcing activities.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User ID or system identifier of the person or process that last modified the buyer record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'Date of the buyer\'s most recent formal performance review. Used to track review cycles and identify buyers due for evaluation.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:markdownPercentageLimit rdf:type rdf:Property ;
    rdfs:label 'Markdown Percentage Limit' ;
    rdfs:comment 'Maximum allowable markdown percentage the buyer can authorize without additional approval. Expressed as a percentage of original retail price (e.g., 30.00 means up to 30% markdown is allowed).' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:officeLocationCode rdf:type rdf:Property ;
    rdfs:label 'Office Location Code' ;
    rdfs:comment 'Code identifying the physical office or buying center where the buyer is based. Used for travel expense allocation and regional vendor assignments.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otbBudgetLimit rdf:type rdf:Property ;
    rdfs:label 'Otb Budget Limit' ;
    rdfs:comment 'Total OTB (Open to Buy) budget allocated to this buyer for the current fiscal period. Represents the maximum inventory investment the buyer can commit to across all assigned categories.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredVendorCount rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Count' ;
    rdfs:comment 'Number of preferred or strategic vendors the buyer actively manages relationships with. Used to assess vendor portfolio concentration and diversification strategy.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:privateLabelFocusFlag rdf:type rdf:Property ;
    rdfs:label 'Private Label Focus Flag' ;
    rdfs:comment 'Indicates whether the buyer has primary responsibility for private label (store brand) product development and sourcing. True if the buyer manages private label assortments.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sellThroughRateTarget rdf:type rdf:Property ;
    rdfs:label 'Sell Through Rate Target' ;
    rdfs:comment 'Target sell-through rate percentage assigned to the buyer for their assigned categories. Represents the percentage of inventory that should be sold within a defined period (typically a season). Expressed as a percentage (e.g., 85.00 means 85% of inventory should sell through).' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date the buyer left the organization or was terminated. Null for active employees. Triggers reassignment of assigned categories and vendors.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorNegotiationRating rdf:type rdf:Property ;
    rdfs:label 'Vendor Negotiation Rating' ;
    rdfs:comment 'Performance rating reflecting the buyer\'s effectiveness in negotiating favorable commercial terms with vendors. Based on achieved cost reductions, payment terms, and markdown allowances.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfBuyingExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Buying Experience' ;
    rdfs:comment 'Total number of years the individual has worked in merchandise buying roles, including experience prior to joining the current organization. Used for capability assessment and succession planning.' ;
    rdfs:domain ind:Buyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buyDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Buy Deadline Date' ;
    rdfs:comment 'The final date by which all purchase orders for the season must be committed to vendors. Ensures timely receipt of merchandise for season launch.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceExitDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Exit Date' ;
    rdfs:comment 'The target date by which all seasonal merchandise should be sold through or removed from active selling floor. Marks the end of clearance activities.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstReceiptDate rdf:type rdf:Property ;
    rdfs:label 'First Receipt Date' ;
    rdfs:comment 'The target date for the first merchandise receipts to arrive at distribution centers or stores for the season. Marks the beginning of inventory flow.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineReviewDate rdf:type rdf:Property ;
    rdfs:label 'Line Review Date' ;
    rdfs:comment 'Key milestone date when the merchandising team reviews and approves the product line assortment for the season. Critical gate for buying decisions.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:markdownEntryDate rdf:type rdf:Property ;
    rdfs:label 'Markdown Entry Date' ;
    rdfs:comment 'The date when initial markdown pricing strategies are activated to accelerate sell-through of seasonal merchandise. Signals transition to promotional phase.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Start Date' ;
    rdfs:comment 'The date when pre-season planning activities begin, including assortment planning, OTB (Open to Buy) budget allocation, and category strategy development.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonCode rdf:type rdf:Property ;
    rdfs:label 'Season Code' ;
    rdfs:comment 'Short alphanumeric code representing the season (e.g., SS24 for Spring/Summer 2024, FW24 for Fall/Winter 2024). Used as the business identifier across merchandising systems.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonName rdf:type rdf:Property ;
    rdfs:label 'Season Name' ;
    rdfs:comment 'Full descriptive name of the season (e.g., Spring/Summer 2024, Holiday 2024, Back-to-School 2024). Human-readable label for business users.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonStatus rdf:type rdf:Property ;
    rdfs:label 'Season Status' ;
    rdfs:comment 'Current lifecycle status of the season. Planning: pre-season planning phase. Open-to-Buy: OTB budgets active, buying in progress. In-Season: merchandise on floor, active selling. Post-Season: season ended, analysis and clearance. Closed: season archived.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonType rdf:type rdf:Property ;
    rdfs:label 'Season Type' ;
    rdfs:comment 'Classification of the season by merchandising cycle (e.g., spring/summer, fall/winter, holiday, back-to-school). Drives assortment planning and buying strategies.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualReceiptsAtCost rdf:type rdf:Property ;
    rdfs:label 'Actual Receipts At Cost' ;
    rdfs:comment 'The total actual merchandise receipts at cost that have been received into inventory during this budget period. Updated as goods receipts are posted from purchase orders.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableOtbBalance rdf:type rdf:Property ;
    rdfs:label 'Available Otb Balance' ;
    rdfs:comment 'The remaining budget balance available for new purchase commitments. Calculated as: Planned Receipts + Adjustments - Actual Receipts - Committed Amount. This is the authoritative field that determines whether a buyer can place new orders.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Adjustment Amount' ;
    rdfs:comment 'The cumulative net adjustment to the original planned receipts budget. Includes increases, decreases, and transfers from other budgets. Positive values increase available OTB; negative values decrease it.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetDecreaseAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Decrease Amount' ;
    rdfs:comment 'The total amount of budget decreases applied to this OTB budget. Decreases may occur due to lower-than-expected sales, inventory overstock, or strategic reallocation to other categories.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetEndDate rdf:type rdf:Property ;
    rdfs:label 'Budget End Date' ;
    rdfs:comment 'The effective end date of the OTB budget period. After this date, the budget is typically closed and no further commitments are allowed unless extended.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetIncreaseAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Increase Amount' ;
    rdfs:comment 'The total amount of budget increases applied to this OTB budget. Increases are typically approved by senior merchandising leadership to support higher-than-planned demand or strategic opportunities.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetStartDate rdf:type rdf:Property ;
    rdfs:label 'Budget Start Date' ;
    rdfs:comment 'The effective start date of the OTB budget period. Buyers can begin committing purchases on or after this date.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of the OTB budget. Draft = under planning; Active = buyers can commit purchases; Frozen = temporarily locked for review; Closed = planning period ended; Cancelled = budget withdrawn.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetTransferInAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Transfer In Amount' ;
    rdfs:comment 'The total amount of budget transferred into this OTB budget from other budgets. Transfers allow buyers to reallocate funds between categories or departments within the same season.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetTransferOutAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Transfer Out Amount' ;
    rdfs:comment 'The total amount of budget transferred out of this OTB budget to other budgets. Recorded as a positive value; reduces the available OTB balance of this budget.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'The date when this OTB budget was last reconciled with SAP S/4HANA MM purchase order and goods receipt data. Used to ensure data consistency between ORMS and ERP systems.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:markdownBudgetPct rdf:type rdf:Property ;
    rdfs:label 'Markdown Budget Pct' ;
    rdfs:comment 'The planned markdown percentage allocated for this OTB budget. Represents the expected price reductions as a percentage of planned receipts at retail. Used for margin planning and promotional strategy.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReceiptsAtCost rdf:type rdf:Property ;
    rdfs:label 'Planned Receipts At Cost' ;
    rdfs:comment 'The total planned merchandise receipts at cost for this budget period. Represents the initial budget allocation before any adjustments or commitments. Expressed in the budget currency.' ;
    rdfs:domain ind:OtbBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingFulfillmentNodeId rdf:type rdf:Property ;
    rdfs:label 'Receiving Fulfillment Node Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.node. Business justification: Inbound purchase orders must specify receiving DC/warehouse for inventory routing and capacity planning. Retail operations require knowing which fulfillment node will process incoming vendor shipments' ;
    rdfs:domain ind:Merchandising ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentNode .

ind:approvalWorkflowCode rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Code' ;
    rdfs:comment 'Identifier of the approval workflow instance used to authorize this buying order. Tracks multi-level approvals based on order value thresholds and buyer authority limits.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyCost rdf:type rdf:Property ;
    rdfs:label 'Duty Cost' ;
    rdfs:comment 'Estimated or actual customs duty and import taxes for international shipments. Used to calculate landed cost and COGS (Cost of Goods Sold).' ;
    rdfs:domain ind:BuyingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fobTerms rdf:type rdf:Property ;
    rdfs:label 'Fob Terms' ;
    rdfs:comment 'Incoterms defining the point at which ownership and risk transfer from supplier to retailer. Determines freight responsibility and cost allocation. [ENUM-REF-CANDIDATE: fob_origin|fob_destination|exw|fca|cif|dap|ddp — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BuyingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Negotiated payment terms with the supplier (e.g., Net 30, Net 60, 2/10 Net 30). Defines the payment due date and any early payment discounts.' ;
    rdfs:domain ind:BuyingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Ship Window End Date' ;
    rdfs:comment 'Latest date the supplier must ship the merchandise to meet planned receipt date. Defines the end of the acceptable shipping window; late shipments may incur chargebacks.' ;
    rdfs:domain ind:BuyingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Ship Window Start Date' ;
    rdfs:comment 'Earliest date the supplier is authorized to ship the merchandise. Defines the beginning of the acceptable shipping window for timely assortment flow.' ;
    rdfs:domain ind:BuyingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Order Quantity' ;
    rdfs:comment 'Total quantity of units ordered across all SKUs (Stock Keeping Units) in this buying order. Aggregated from line-level quantities.' ;
    rdfs:domain ind:BuyingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Order Number' ;
    rdfs:comment 'Supplier\'s own order reference number assigned when they acknowledge the buying order. Used for order tracking and supplier communication.' ;
    rdfs:domain ind:BuyingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBuyingCategoryId rdf:type rdf:Property ;
    rdfs:label 'Primary Buying Category Id' ;
    rdfs:comment 'Reference to the merchandise class within the department. Provides finer-grained categorization for assortment depth and breadth analysis.' ;
    rdfs:domain ind:BuyingOrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:allocationQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocation Quantity' ;
    rdfs:comment 'Quantity of this SKU allocated to the specified store cluster. Supports pre-distribution planning and ensures inventory is directed to the right locations based on demand forecasts.' ;
    rdfs:domain ind:BuyingOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Expected delivery date for this line item to the distribution center or store. Used for receipt planning, inventory replenishment scheduling, and vendor performance tracking.' ;
    rdfs:domain ind:BuyingOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dropShipFlag rdf:type rdf:Property ;
    rdfs:label 'Drop Ship Flag' ;
    rdfs:comment 'Indicates whether this line item will be drop shipped directly from vendor to customer rather than through the retailers distribution network. Supports omnichannel fulfillment strategies.' ;
    rdfs:domain ind:BuyingOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storeClusterCode rdf:type rdf:Property ;
    rdfs:label 'Store Cluster Code' ;
    rdfs:comment 'Code identifying the store cluster or group for which this merchandise is allocated. Enables assortment planning by store type, geography, or performance tier.' ;
    rdfs:domain ind:BuyingOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorStyleNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Style Number' ;
    rdfs:comment 'Vendor-assigned style or model number for this product. Used for cross-referencing with vendor catalogs and facilitating reorder processes.' ;
    rdfs:domain ind:BuyingOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assortmentDepthTier rdf:type rdf:Property ;
    rdfs:label 'Assortment Depth Tier' ;
    rdfs:comment 'Classification of how many variants (sizes, colors, styles) of this item are carried within its category. Deep assortments offer extensive choice within a category, narrow assortments offer limited variety.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assortmentRole rdf:type rdf:Property ;
    rdfs:label 'Assortment Role' ;
    rdfs:comment 'Strategic role of this item within the assortment. Core items are year-round staples, seasonal items are time-bound, trend items capture emerging demand, clearance items are being phased out, promotional items support campaigns, and test items are being evaluated.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributesChecklistComplete rdf:type rdf:Property ;
    rdfs:label 'Attributes Checklist Complete' ;
    rdfs:comment 'Indicates whether all required product attributes (dimensions, weight, materials, care instructions, etc.) have been captured in the Product Information Management (PIM) system for this SKU.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearanceStrategy rdf:type rdf:Property ;
    rdfs:label 'Clearance Strategy' ;
    rdfs:comment 'Planned approach for clearing remaining inventory of discontinued items. Markdown uses progressive price reductions, liquidation sells to third parties, RTV returns unsold units to vendor, donation gives to charity, disposal destroys unsellable goods.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Cpsc Certification Status' ;
    rdfs:comment 'Status of CPSC safety certification for products requiring consumer safety compliance (toys, children\'s products, electronics, etc.). Not required for all product categories.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationReason rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Reason' ;
    rdfs:comment 'Business reason for discontinuing this SKU from the assortment. Captures strategic rationale for removal decisions to inform future assortment planning.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Fda Certification Status' ;
    rdfs:comment 'Status of FDA certification for food, beverage, pharmaceutical, and cosmetic products requiring regulatory approval. Not required for non-food/drug categories.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalDispositionDate rdf:type rdf:Property ;
    rdfs:label 'Final Disposition Date' ;
    rdfs:comment 'Date when all remaining inventory of this discontinued SKU must be cleared from stores and distribution centers. Marks the end of the item lifecycle in this assortment.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goLiveDate rdf:type rdf:Property ;
    rdfs:label 'Go Live Date' ;
    rdfs:comment 'Planned or actual date when this SKU becomes available for sale in the designated store cluster. Critical milestone for new item launches and seasonal transitions.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inclusionStatus rdf:type rdf:Property ;
    rdfs:label 'Inclusion Status' ;
    rdfs:comment 'Current inclusion or exclusion status of this SKU in the assortment plan. Indicates whether the item is actively carried, excluded from the plan, or pending final decision.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumPresentationQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Presentation Quantity' ;
    rdfs:comment 'Minimum number of units that must be displayed on the shelf to maintain visual impact and avoid out-of-stock perception. Used for store replenishment triggers.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Detailed status of new item onboarding process. Tracks progress through attribute setup, compliance certification, and go-live readiness for items in onboarding lifecycle stage.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAur rdf:type rdf:Property ;
    rdfs:label 'Planned Aur' ;
    rdfs:comment 'Target average selling price per unit for this SKU during the season, accounting for planned markdowns and promotions. Used for revenue forecasting and Gross Margin Return on Investment (GMROI) calculations.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedGmroi rdf:type rdf:Property ;
    rdfs:label 'Planned Gmroi' ;
    rdfs:comment 'Target Gross Margin Return on Investment for this assortment item. Measures how many dollars of gross margin are returned for every dollar invested in inventory. Key profitability metric for assortment decisions.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedSellThroughRate rdf:type rdf:Property ;
    rdfs:label 'Planned Sell Through Rate' ;
    rdfs:comment 'Target percentage of inventory expected to sell during the season without markdown. Key metric for assortment performance planning and Open to Buy (OTB) budgeting. Expressed as percentage (e.g., 85.50 for 85.5%).' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedWeeksOfSupply rdf:type rdf:Property ;
    rdfs:label 'Planned Weeks Of Supply' ;
    rdfs:comment 'Target number of weeks that planned inventory should last based on forecasted demand. Critical for replenishment planning and avoiding overstock or stockouts.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planogramPositionRequired rdf:type rdf:Property ;
    rdfs:label 'Planogram Position Required' ;
    rdfs:comment 'Indicates whether this SKU requires a specific shelf position defined in store planograms. True for items with strategic placement requirements (endcaps, eye-level, checkout displays).' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:upcRegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'Upc Registration Status' ;
    rdfs:comment 'Status of UPC or GTIN registration with GS1 for this SKU. Required for point-of-sale scanning and supply chain tracking.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualMarginImpact rdf:type rdf:Property ;
    rdfs:label 'Actual Margin Impact' ;
    rdfs:comment 'Realized gross margin dollar impact of the markdown event, calculated from actual sales and COGS data. Used for post-markdown profitability analysis and GMROI performance measurement. Null until markdown period completes.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualRevenueImpact rdf:type rdf:Property ;
    rdfs:label 'Actual Revenue Impact' ;
    rdfs:comment 'Realized total revenue impact of the markdown event, calculated from actual sales data. Used for post-markdown financial analysis and Return on Investment (ROI) measurement. Null until markdown period completes.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSellThroughLiftPercentage rdf:type rdf:Property ;
    rdfs:label 'Actual Sell Through Lift Percentage' ;
    rdfs:comment 'Realized increase in sell-through rate after the markdown was executed, expressed as a percentage. Measured post-markdown for effectiveness analysis and future markdown planning. Null until markdown period completes.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualUnitsSold rdf:type rdf:Property ;
    rdfs:label 'Actual Units Sold' ;
    rdfs:comment 'Realized quantity of units sold during the markdown period. Captured from Point of Sale (POS) transaction data for markdown effectiveness measurement. Null until markdown period completes.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:markdownPercentage rdf:type rdf:Property ;
    rdfs:label 'Markdown Percentage' ;
    rdfs:comment 'The percentage reduction from original price to markdown price, calculated as ((original_price - markdown_price) / original_price) * 100. Key metric for promotional intensity and margin sacrifice analysis.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownPrice rdf:type rdf:Property ;
    rdfs:label 'Markdown Price' ;
    rdfs:comment 'The new reduced retail price after the markdown is applied. Represents the new selling price point for the affected merchandise.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownReason rdf:type rdf:Property ;
    rdfs:label 'Markdown Reason' ;
    rdfs:comment 'Business rationale for initiating the markdown event. Seasonal clearance indicates end-of-season inventory reduction; slow seller indicates poor sell-through performance; competitive response indicates market-driven pricing adjustment; end-of-life indicates product discontinuation; damaged indicates impaired merchandise; obsolete indicates outdated or superseded products.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectedMarginImpact rdf:type rdf:Property ;
    rdfs:label 'Projected Margin Impact' ;
    rdfs:comment 'Forecasted gross margin dollar impact of the markdown event, accounting for Cost of Goods Sold (COGS) and markdown amount. Critical for Gross Margin Return on Investment (GMROI) target management and merchandising profitability planning.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedRevenueImpact rdf:type rdf:Property ;
    rdfs:label 'Projected Revenue Impact' ;
    rdfs:comment 'Forecasted total revenue impact of the markdown event, calculated as (markdown_price * projected_units_sold) minus baseline revenue. Negative values indicate revenue sacrifice; used for Profit and Loss (P&L) planning.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedSellThroughLiftPercentage rdf:type rdf:Property ;
    rdfs:label 'Projected Sell Through Lift Percentage' ;
    rdfs:comment 'Forecasted increase in sell-through rate as a result of the markdown, expressed as a percentage. Used for markdown effectiveness planning and inventory turn optimization. Based on historical markdown elasticity models.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedUnitsSold rdf:type rdf:Property ;
    rdfs:label 'Projected Units Sold' ;
    rdfs:comment 'Forecasted quantity of units expected to sell during the markdown period. Used for inventory planning and Open to Buy (OTB) budget impact assessment.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Vendor Contribution Amount' ;
    rdfs:comment 'Dollar amount contributed by the vendor toward the markdown cost as per vendor support agreement. Used for vendor chargeback processing and net markdown cost calculation. Zero or null when no vendor support exists.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Fee Amount' ;
    rdfs:comment 'Recurring annual membership fee for subscription-based loyalty programs. Zero for free programs.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bannerAffiliation rdf:type rdf:Property ;
    rdfs:label 'Banner Affiliation' ;
    rdfs:comment 'Retail banner or brand name this loyalty program is associated with. Supports multi-banner retailers operating distinct programs for different store formats (e.g., Hypermarket Rewards, Discount Club, Premium Grocery).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:charitableDonationEnabled rdf:type rdf:Property ;
    rdfs:label 'Charitable Donation Enabled' ;
    rdfs:comment 'Indicates whether members can donate their earned points or rewards to charitable organizations through the loyalty program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerServicePhone rdf:type rdf:Property ;
    rdfs:label 'Customer Service Phone' ;
    rdfs:comment 'Dedicated customer service phone number for loyalty program member inquiries, support, and issue resolution.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecommerceIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Ecommerce Integration Enabled' ;
    rdfs:comment 'Indicates whether the loyalty program is integrated with the retailers e-commerce platform for online member identification, points accrual, and redemption during digital checkout.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentEligibilityRule rdf:type rdf:Property ;
    rdfs:label 'Enrollment Eligibility Rule' ;
    rdfs:comment 'Business rule defining who can enroll in the program (e.g., age 18+, US residents only, minimum purchase requirement, invitation only). Free-text description of eligibility criteria.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Enrollment Fee Amount' ;
    rdfs:comment 'One-time fee charged to enroll in the loyalty program. Zero for free programs.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gamificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Gamification Enabled' ;
    rdfs:comment 'Indicates whether the loyalty program incorporates gamification elements such as challenges, badges, leaderboards, or bonus point events to drive engagement.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mobileAppEnabled rdf:type rdf:Property ;
    rdfs:label 'Mobile App Enabled' ;
    rdfs:comment 'Indicates whether the loyalty program has a dedicated mobile application or is accessible through the retailers mobile app for member self-service, digital card, and personalized offers.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:omnichannelRecognitionEnabled rdf:type rdf:Property ;
    rdfs:label 'Omnichannel Recognition Enabled' ;
    rdfs:comment 'Indicates whether loyalty program benefits and points accrual are recognized across all customer touchpoints (in-store POS, e-commerce, mobile app, call center). True for unified omnichannel programs.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerCoalitionEnabled rdf:type rdf:Property ;
    rdfs:label 'Partner Coalition Enabled' ;
    rdfs:comment 'Indicates whether this loyalty program participates in a coalition with external partners (e.g., airlines, hotels, other retailers) allowing members to earn and redeem across multiple brands.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personalizationEngineEnabled rdf:type rdf:Property ;
    rdfs:label 'Personalization Engine Enabled' ;
    rdfs:comment 'Indicates whether the loyalty program leverages AI/ML-driven personalization to deliver individualized offers, recommendations, and communications to members based on purchase history and behavior.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsCurrencyName rdf:type rdf:Property ;
    rdfs:label 'Points Currency Name' ;
    rdfs:comment 'Name of the points currency used in this program (e.g., Rewards Points, Stars, Miles, Cash Back Dollars). Null for non-points programs.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsEarnRate rdf:type rdf:Property ;
    rdfs:label 'Points Earn Rate' ;
    rdfs:comment 'Base rate at which members earn points per unit of spend (e.g., 1.0 = 1 point per dollar, 0.5 = 1 point per 2 dollars). Null for non-points programs.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsExpiryDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Duration Months' ;
    rdfs:comment 'Number of months until points expire, applicable when points_expiry_policy is rolling_months or activity_based. Null for non-expiring programs.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsExpiryPolicy rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Policy' ;
    rdfs:comment 'Policy governing when earned points expire: never (no expiration), rolling_months (expire N months after earn date), calendar_year (expire end of year), fixed_date (expire on specific date), activity_based (expire if no activity for N months).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsRedemptionRate rdf:type rdf:Property ;
    rdfs:label 'Points Redemption Rate' ;
    rdfs:comment 'Base rate at which points convert to monetary value for redemption (e.g., 0.01 = 1 point = $0.01, 100 points = $1). Null for non-points programs.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:posIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Pos Integration Enabled' ;
    rdfs:comment 'Indicates whether the loyalty program is integrated with in-store POS systems for real-time member identification, points accrual, and redemption at checkout.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privacyPolicyUrl rdf:type rdf:Property ;
    rdfs:label 'Privacy Policy Url' ;
    rdfs:comment 'URL to the privacy policy specific to the loyalty program, detailing how member data is collected, used, and protected.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Externally-known unique business identifier for the loyalty program (e.g., REWARDS_PLUS, GOLD_CLUB). Used in operational systems, customer communications, and integrations.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Detailed description of the loyalty programs value proposition, benefits, and key features. Used for internal reference and customer-facing communications.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Human-readable marketing name of the loyalty program displayed to customers (e.g., Rewards Plus, Gold Member Club, Everyday Savings).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the loyalty program: active (accepting enrollments and accruals), inactive (temporarily paused), suspended (enrollment closed but existing members active), planned (designed but not launched), retired (permanently closed).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the loyalty program structure: tiered (multiple membership levels with escalating benefits), points_based (earn and redeem points), cashback (percentage rebate), coalition (multi-retailer partnership), co_branded_card (linked to credit card), subscription (paid membership with benefits).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralProgramEnabled rdf:type rdf:Property ;
    rdfs:label 'Referral Program Enabled' ;
    rdfs:comment 'Indicates whether the loyalty program includes a member-get-member referral component where existing members earn rewards for referring new enrollees.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Target Customer Segment' ;
    rdfs:comment 'Primary customer demographic or behavioral segment this loyalty program is designed to attract and retain (e.g., high-value shoppers, frequent buyers, millennials, grocery-focused).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAndConditionsUrl rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Url' ;
    rdfs:comment 'URL to the official terms and conditions document governing the loyalty program, including member rights, obligations, and program rules.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierEvaluationPeriod rdf:type rdf:Property ;
    rdfs:label 'Tier Evaluation Period' ;
    rdfs:comment 'Time window over which tier qualification is evaluated: calendar_year (Jan-Dec), rolling_12_months (trailing 12 months), program_year (anniversary-based), lifetime (cumulative since enrollment). Null for non-tiered programs.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierQualificationMetric rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Metric' ;
    rdfs:comment 'Primary metric used to qualify members for tier advancement: annual_spend (total dollars spent), points_earned (total points accumulated), transaction_count (number of purchases), hybrid (combination of metrics). Null for non-tiered programs.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierStructureEnabled rdf:type rdf:Property ;
    rdfs:label 'Tier Structure Enabled' ;
    rdfs:comment 'Indicates whether this loyalty program has a tiered membership structure with multiple levels (e.g., Silver, Gold, Platinum). True for tiered programs, false for flat programs.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentTierId rdf:type rdf:Property ;
    rdfs:label 'Current Tier Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier. Business justification: Critical normalization opportunity. membership.current_tier is currently a STRING field (likely storing tier code or name). This should be normalized to a FK to tier.tier_id. The tier table is the aut' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:primaryLoyaltyLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Loyalty Location Id' ;
    rdfs:comment 'Store location where the customer enrolled, if enrollment occurred in-store. Null for digital enrollments.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:primaryStorefrontId rdf:type rdf:Property ;
    rdfs:label 'Primary Storefront Id' ;
    rdfs:comment 'Foreign key linking to ecommerce.storefront. Business justification: Members enroll and transact through specific digital storefronts; tracking primary storefront enables channel-specific loyalty offers, omnichannel recognition, and storefront-level member segmentation' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Storefront .

ind:referredByMemberLoyaltyMembershipId rdf:type rdf:Property ;
    rdfs:label 'Referred By Member Loyalty Membership Id' ;
    rdfs:comment 'Reference to the member who referred this customer to the loyalty program. Null if not a referral enrollment.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyMembership .

ind:anniversaryDate rdf:type rdf:Property ;
    rdfs:label 'Anniversary Date' ;
    rdfs:comment 'Annual anniversary date of membership enrollment. Used for anniversary campaigns and special offers.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the membership was permanently closed or terminated. Null for active, suspended, or lapsed memberships.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedReason rdf:type rdf:Property ;
    rdfs:label 'Closed Reason' ;
    rdfs:comment 'Reason code or description for membership closure. Examples: customer_request, fraud, terms_violation, duplicate_account, deceased.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Current Points Balance' ;
    rdfs:comment 'Current available points balance that can be redeemed. Calculated as lifetime earned minus lifetime redeemed minus expired points.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'Channel through which the customer enrolled in the loyalty program. Supports omnichannel enrollment tracking and channel effectiveness analysis. [ENUM-REF-CANDIDATE: in_store|online|mobile_app|call_center|referral|partner|social_media — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date when the customer enrolled in the loyalty program. Used for tenure analysis and anniversary campaigns.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent member activity (purchase, points redemption, offer engagement, or interaction). Used for lapse risk scoring and reactivation targeting.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRedemptionDate rdf:type rdf:Property ;
    rdfs:label 'Last Redemption Date' ;
    rdfs:comment 'Date of the most recent points redemption by the member. Used for engagement analysis and redemption behavior tracking.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimePointsEarned rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Earned' ;
    rdfs:comment 'Total points earned by the member since enrollment. Includes base points, bonus points, and promotional points. Used for tier qualification and CLTV (Customer Lifetime Value) analysis.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimePointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Redeemed' ;
    rdfs:comment 'Total points redeemed by the member since enrollment. Used for engagement analysis and points liability tracking.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memberNumber rdf:type rdf:Property ;
    rdfs:label 'Member Number' ;
    rdfs:comment 'Externally visible unique member identifier used for program recognition across all touchpoints (POS, e-commerce, mobile app). Customer-facing identifier.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of the membership. Active members can earn and redeem points; suspended members are temporarily blocked; lapsed members have not engaged within retention window; closed memberships are permanently terminated.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Next Expiry Date' ;
    rdfs:comment 'Date when the next batch of points will expire. Null if no points are set to expire.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInDirectMail rdf:type rdf:Property ;
    rdfs:label 'Opt In Direct Mail' ;
    rdfs:comment 'Indicates whether the member has opted in to receive loyalty program communications via postal mail.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInEmail rdf:type rdf:Property ;
    rdfs:label 'Opt In Email' ;
    rdfs:comment 'Indicates whether the member has opted in to receive loyalty program communications via email.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInPush rdf:type rdf:Property ;
    rdfs:label 'Opt In Push' ;
    rdfs:comment 'Indicates whether the member has opted in to receive loyalty program push notifications via mobile app.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInSms rdf:type rdf:Property ;
    rdfs:label 'Opt In Sms' ;
    rdfs:comment 'Indicates whether the member has opted in to receive loyalty program communications via SMS text messages.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsExpiringSoon rdf:type rdf:Property ;
    rdfs:label 'Points Expiring Soon' ;
    rdfs:comment 'Points balance that will expire within the next 90 days. Used for expiration reminder campaigns and urgency messaging.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referralCode rdf:type rdf:Property ;
    rdfs:label 'Referral Code' ;
    rdfs:comment 'Unique referral code assigned to this member for referring new customers to the loyalty program. Used in member-get-member campaigns.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Status Effective Date' ;
    rdfs:comment 'Date when the current membership status became effective. Used for status duration analysis and reactivation campaigns.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statusReason rdf:type rdf:Property ;
    rdfs:label 'Status Reason' ;
    rdfs:comment 'Reason code or description for the current membership status. Examples: fraud_detected, customer_request, inactivity, terms_violation.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Tier Expiry Date' ;
    rdfs:comment 'Date when the current tier status expires and re-qualification is required. Null for lifetime tiers.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Date' ;
    rdfs:comment 'Date when the member qualified for their current tier. Used for tier tenure tracking and re-qualification calculations.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Total Spend Amount' ;
    rdfs:comment 'Total monetary value of all purchases by the member since enrollment. Used for monetary analysis, tier qualification, and CLTV (Customer Lifetime Value) calculation.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTransactions rdf:type rdf:Property ;
    rdfs:label 'Total Transactions' ;
    rdfs:comment 'Total number of purchase transactions completed by the member since enrollment. Used for frequency analysis and tier qualification.' ;
    rdfs:domain ind:LoyaltyMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:badgeColor rdf:type rdf:Property ;
    rdfs:label 'Badge Color' ;
    rdfs:comment 'Hex color code or color name for the tier badge displayed in digital channels and physical membership cards (e.g., #C0C0C0 for Silver, #FFD700 for Gold, #E5E4E2 for Platinum, #B9F2FF for Diamond).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:badgeIconUrl rdf:type rdf:Property ;
    rdfs:label 'Badge Icon Url' ;
    rdfs:comment 'URL to the digital asset (icon or badge image) representing this tier in mobile apps, websites, and digital communications.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitsSummary rdf:type rdf:Property ;
    rdfs:label 'Benefits Summary' ;
    rdfs:comment 'Textual summary of key benefits and privileges associated with this tier (e.g., free shipping, priority customer service, exclusive access to sales, birthday rewards, concierge service). Used for customer communication and marketing.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'Sequence number controlling the display order of tiers in customer-facing interfaces (websites, mobile apps, marketing materials). Lower numbers appear first.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downgradeRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Downgrade Rule Description' ;
    rdfs:comment 'Textual description of the rules and conditions under which a customer is downgraded from this tier (e.g., automatic if maintenance threshold not met, grace period of 3 months, no downgrades for lifetime tiers).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gracePeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Grace Period Months' ;
    rdfs:comment 'Number of months a customer retains tier status after failing to meet maintenance threshold before being downgraded. Null if no grace period is offered.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invitationOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Invitation Only Flag' ;
    rdfs:comment 'Indicates whether this tier is available only by invitation from the company (True) or can be achieved through standard qualification rules (False). Typically used for ultra-premium or VIP tiers.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifetimeTierFlag rdf:type rdf:Property ;
    rdfs:label 'Lifetime Tier Flag' ;
    rdfs:comment 'Indicates whether this tier, once achieved, is retained for the customer\'s lifetime regardless of future activity (True) or is subject to periodic review and potential downgrade (False).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenancePeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Maintenance Period Months' ;
    rdfs:comment 'Number of months over which the maintenance threshold must be met to retain tier status (e.g., 12 for annual review). Null if no maintenance requirement.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Maintenance Threshold Value' ;
    rdfs:comment 'Numeric value a customer must achieve to maintain this tier after initial qualification. Often lower than qualification threshold to encourage retention. Null if maintenance equals qualification.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingDescription rdf:type rdf:Property ;
    rdfs:label 'Marketing Description' ;
    rdfs:comment 'Extended marketing copy describing the tier\'s value proposition, benefits, and aspirational messaging. Used in promotional materials, program brochures, and enrollment campaigns.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsEarningMultiplier rdf:type rdf:Property ;
    rdfs:label 'Points Earning Multiplier' ;
    rdfs:comment 'Multiplier applied to base points earning rate for members of this tier (e.g., 1.0 for base tier, 1.5 for Gold, 2.0 for Platinum). Higher tiers earn points faster.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsRedemptionDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Points Redemption Discount Pct' ;
    rdfs:comment 'Percentage discount applied to points required for redemption rewards for this tier (e.g., 0 for base tier, 10 for Gold means 10% fewer points needed, 20 for Platinum). Enhances redemption value for premium tiers.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Qualification Period Months' ;
    rdfs:comment 'Number of months over which the qualification threshold must be met (e.g., 12 for annual qualification, 3 for quarterly). Null indicates lifetime qualification.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationThresholdType rdf:type rdf:Property ;
    rdfs:label 'Qualification Threshold Type' ;
    rdfs:comment 'The metric used to determine tier qualification: spend (total monetary spend), points (loyalty points earned), transactions (number of purchases), or hybrid (combination of multiple metrics).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Qualification Threshold Value' ;
    rdfs:comment 'Numeric value a customer must achieve to qualify for this tier (e.g., $5000 annual spend, 10000 points earned, 50 transactions). Interpretation depends on qualification_threshold_type.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the tier within the program (e.g., SILVER, GOLD, PLAT, DIAM). Used for system integration and reporting.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Human-readable name of the loyalty tier displayed to customers (e.g., Silver Member, Gold Member, Platinum Elite, Diamond VIP).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierRank rdf:type rdf:Property ;
    rdfs:label 'Tier Rank' ;
    rdfs:comment 'Ordinal ranking of the tier within the loyalty program hierarchy. Lower numbers indicate entry-level tiers; higher numbers indicate premium tiers (e.g., 1=Silver, 2=Gold, 3=Platinum, 4=Diamond).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Status' ;
    rdfs:comment 'Current lifecycle status of the tier. Active tiers are available for customer enrollment and qualification; inactive tiers are no longer offered but may have legacy members; deprecated tiers are being phased out; planned tiers are under development.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Upgrade Rule Description' ;
    rdfs:comment 'Textual description of the rules and conditions under which a customer is upgraded to this tier (e.g., automatic upon reaching threshold, manual review required, invitation-only for top tier).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsLedgerId rdf:type rdf:Property ;
    rdfs:label 'Points Ledger Id' ;
    rdfs:comment 'Unique identifier for each points ledger entry. Primary key for the immutable append-only ledger.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PointsLedger .

ind:redemptionRuleId rdf:type rdf:Property ;
    rdfs:label 'Redemption Rule Id' ;
    rdfs:comment 'Foreign key linking to loyalty.redemption_rule. Business justification: Points ledger entries of type \'redeem\' should reference which redemption rule was applied. Parallel to accrual_rule_id, this enables audit trail for rule enforcement, compliance reporting, and analyti' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RedemptionRule .

ind:reversalReferencePointsLedgerId rdf:type rdf:Property ;
    rdfs:label 'Reversal Reference Points Ledger Id' ;
    rdfs:comment 'Points ledger ID of the original transaction being reversed. Populated only for transaction_type = reversal. Creates audit trail linking correction to original entry.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PointsLedger .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Free-text explanation for manual points adjustments. Populated only for transaction_type = adjust. Provides business context for non-standard transactions requiring audit trail.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Base Currency Amount' ;
    rdfs:comment 'Monetary value in base currency (USD, EUR, etc.) that generated the points earn. Used to calculate points-per-dollar ratio and Customer Lifetime Value (CLTV). Null for non-purchase transactions.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakageRate rdf:type rdf:Property ;
    rdfs:label 'Breakage Rate' ;
    rdfs:comment 'Expected percentage of points that will never be redeemed (expire or go unused). Applied at transaction time for liability calculation. Expressed as decimal (e.g., 0.15 for 15% breakage).' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earnMultiplier rdf:type rdf:Property ;
    rdfs:label 'Earn Multiplier' ;
    rdfs:comment 'Multiplier applied to base earn rate for this transaction. Standard earn is 1.0, promotional or tier-based accelerators may be 2.0, 3.0, etc. Null for non-earn transactions.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPromotional rdf:type rdf:Property ;
    rdfs:label 'Is Promotional' ;
    rdfs:comment 'Flag indicating whether this points transaction was part of a promotional or bonus program (True) or standard program rules (False). Used to segment promotional vs. organic points activity.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newTier rdf:type rdf:Property ;
    rdfs:label 'New Tier' ;
    rdfs:comment 'Loyalty membership tier after this transaction. Populated only for transaction_type = tier_qualify. Records the tier achieved through qualification event.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsAmount rdf:type rdf:Property ;
    rdfs:label 'Points Amount' ;
    rdfs:comment 'Signed points value for this transaction. Positive for earn/bonus/transfer-in, negative for redeem/expire/transfer-out. Supports fractional points for partner conversions.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Points Liability Amount' ;
    rdfs:comment 'Estimated monetary liability (in base currency) associated with the points in this transaction. Calculated using breakage-adjusted redemption value. Critical for ASC 606 deferred revenue accounting.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousTier rdf:type rdf:Property ;
    rdfs:label 'Previous Tier' ;
    rdfs:comment 'Loyalty membership tier before this transaction. Populated only for transaction_type = tier_qualify. Captures tier transition history for member journey analysis.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Qualification Period End' ;
    rdfs:comment 'End date of the evaluation period used to assess tier qualification. Populated only for transaction_type = tier_qualify. Completes the qualification window definition.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Qualification Period Start' ;
    rdfs:comment 'Start date of the evaluation period used to assess tier qualification. Populated only for transaction_type = tier_qualify. Defines the rolling window or calendar period for tier assessment.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingPointsAmount rdf:type rdf:Property ;
    rdfs:label 'Qualifying Points Amount' ;
    rdfs:comment 'Total points earned that qualified the member for tier change. Populated only for transaction_type = tier_qualify. Alternative or complementary qualification metric to spend.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualifyingSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Qualifying Spend Amount' ;
    rdfs:comment 'Total spend amount that qualified the member for tier change. Populated only for transaction_type = tier_qualify. Provides evidence for tier qualification audit.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionValuePerPoint rdf:type rdf:Property ;
    rdfs:label 'Redemption Value Per Point' ;
    rdfs:comment 'Estimated monetary value (in base currency) of one loyalty point at time of transaction. Used to calculate points liability. May vary by tier, promotion, or partner agreement.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runningBalance rdf:type rdf:Property ;
    rdfs:label 'Running Balance' ;
    rdfs:comment 'Cumulative points balance for the membership after this transaction is applied. Provides snapshot of available points at this moment in time.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Source Reference Code' ;
    rdfs:comment 'Identifier of the originating transaction or event in the source system. Links back to POS transaction ID, order number, promotion code, partner transaction ID, or adjustment ticket number for full audit trail.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceType rdf:type rdf:Property ;
    rdfs:label 'Source Reference Type' ;
    rdfs:comment 'Category of the originating business event that triggered this points transaction: pos_transaction (in-store purchase via Point of Sale), order (e-commerce or omnichannel order), promotion (marketing campaign or offer), partner (third-party loyalty partner activity), tier_evaluation (automated tier qualification assessment), manual_adjustment (customer service or program admin correction), campaign (targeted engagement initiative). [ENUM-REF-CANDIDATE: pos_transaction|order|promotion|partner|tier_evaluation|manual_adjustment|campaign — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableStoreFormatId rdf:type rdf:Property ;
    rdfs:label 'Applicable Store Format Id' ;
    rdfs:comment 'Foreign key linking to store.store_format. Business justification: Earning rules vary by store format (hypermarkets 1x, premium formats 2x) to reflect margin structures and customer expectations. Retail loyalty programs differentiate point accrual by format for profi' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Format .

ind:accrualRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Accrual Rule Status' ;
    rdfs:comment 'Current lifecycle status of the accrual rule: draft (under development), active (in use), inactive (disabled), expired (past effective period), suspended (temporarily paused).' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableChannel rdf:type rdf:Property ;
    rdfs:label 'Applicable Channel' ;
    rdfs:comment 'Sales channel(s) where this accrual rule applies: all channels, in-store (POS), online (e-commerce), mobile app, BOPIS (Buy Online Pick Up In Store), ROPIS (Reserve Online Pick Up In Store).' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableSkuList rdf:type rdf:Property ;
    rdfs:label 'Applicable Sku List' ;
    rdfs:comment 'Specific SKUs to which this accrual rule applies. Null if rule applies broadly. Comma-separated list if multiple SKUs.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusMultiplier rdf:type rdf:Property ;
    rdfs:label 'Bonus Multiplier' ;
    rdfs:comment 'Multiplier applied to the base earning rate for bonus promotions (e.g., 2.0 for double points, 1.5 for 50% bonus). Null if not a multiplier rule.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dayOfWeekRestriction rdf:type rdf:Property ;
    rdfs:label 'Day Of Week Restriction' ;
    rdfs:comment 'Specific days of the week when this accrual rule applies (e.g., \'Monday,Wednesday,Friday\'). Null if rule applies all days.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earningBasis rdf:type rdf:Property ;
    rdfs:label 'Earning Basis' ;
    rdfs:comment 'The basis on which points are earned: spend amount (dollars spent), unit quantity (items purchased), transaction count (number of transactions), or visit count (store visits).' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excludedProductCategory rdf:type rdf:Property ;
    rdfs:label 'Excluded Product Category' ;
    rdfs:comment 'Product categories explicitly excluded from this accrual rule (e.g., alcohol, tobacco, gift cards). Null if no exclusions. Comma-separated list if multiple.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excludedSkuList rdf:type rdf:Property ;
    rdfs:label 'Excluded Sku List' ;
    rdfs:comment 'Specific SKUs explicitly excluded from this accrual rule. Null if no exclusions. Comma-separated list if multiple SKUs.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRuleCode rdf:type rdf:Property ;
    rdfs:label 'External Rule Code' ;
    rdfs:comment 'Identifier of this accrual rule in the source system, used for cross-system reconciliation and integration.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestriction rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction' ;
    rdfs:comment 'Geographic scope where this accrual rule applies (e.g., specific countries, states, regions, or store locations). Null if no geographic restriction.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPointsPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Maximum Points Per Transaction' ;
    rdfs:comment 'Cap on the number of points that can be earned in a single transaction under this rule. Null if no cap.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberTierEligibility rdf:type rdf:Property ;
    rdfs:label 'Member Tier Eligibility' ;
    rdfs:comment 'Loyalty program membership tier(s) eligible for this accrual rule. \'all\' if rule applies to all tiers, or specific tier names.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumSpendThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Spend Threshold' ;
    rdfs:comment 'Minimum transaction amount required for the accrual rule to apply. Null if no minimum threshold.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethodRestriction rdf:type rdf:Property ;
    rdfs:label 'Payment Method Restriction' ;
    rdfs:comment 'Specific payment methods required for this accrual rule to apply (e.g., \'store_credit_card\', \'mobile_wallet\'). Null if no payment method restriction.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsPerUnit rdf:type rdf:Property ;
    rdfs:label 'Points Per Unit' ;
    rdfs:comment 'Number of loyalty points earned per unit of the earning basis (e.g., 1 point per dollar spent, 10 points per item purchased).' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingStrategyAlignment rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy Alignment' ;
    rdfs:comment 'Indicates which pricing strategy this accrual rule supports: EDLP (Everyday Low Price), Hi-Lo (High-Low promotional pricing), or hybrid.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulePriority rdf:type rdf:Property ;
    rdfs:label 'Rule Priority' ;
    rdfs:comment 'Priority ranking for conflict resolution when multiple accrual rules apply to the same transaction. Lower numbers indicate higher priority (1 = highest).' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stackingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Stacking Allowed Flag' ;
    rdfs:comment 'Indicates whether this accrual rule can be combined (stacked) with other accrual rules in the same transaction. True = stacking allowed, False = exclusive rule.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeOfDayRestriction rdf:type rdf:Property ;
    rdfs:label 'Time Of Day Restriction' ;
    rdfs:comment 'Specific time windows when this accrual rule applies (e.g., \'09:00-12:00\', \'happy hour\'). Null if rule applies all day.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutEndDate rdf:type rdf:Property ;
    rdfs:label 'Blackout End Date' ;
    rdfs:comment 'End date of blackout period during which redemptions under this rule are not allowed. Nullable if no blackout applies.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blackoutStartDate rdf:type rdf:Property ;
    rdfs:label 'Blackout Start Date' ;
    rdfs:comment 'Start date of blackout period during which redemptions under this rule are not allowed. Nullable if no blackout applies.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:combinableWithPromotionsFlag rdf:type rdf:Property ;
    rdfs:label 'Combinable With Promotions Flag' ;
    rdfs:comment 'Indicates whether this redemption rule can be combined with other promotional offers (True) or must be used exclusively (False).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleChannels rdf:type rdf:Property ;
    rdfs:label 'Eligible Channels' ;
    rdfs:comment 'Comma-separated list of channels where this redemption rule can be applied (e.g., store, online, mobile_app, call_center).' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleRewardTypes rdf:type rdf:Property ;
    rdfs:label 'Eligible Reward Types' ;
    rdfs:comment 'Comma-separated list of reward types that can be redeemed under this rule (e.g., merchandise, gift_card, discount, cashback, travel).' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Liability Impact Category' ;
    rdfs:comment 'Classification of how this redemption rule impacts loyalty points liability accounting (immediate recognition, deferred, conditional on fulfillment, or no impact).' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingMessage rdf:type rdf:Property ;
    rdfs:label 'Marketing Message' ;
    rdfs:comment 'Customer-facing marketing message or promotional text to be displayed when presenting this redemption rule to members.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPointsThreshold rdf:type rdf:Property ;
    rdfs:label 'Maximum Points Threshold' ;
    rdfs:comment 'Maximum number of loyalty points that can be redeemed in a single transaction under this rule. Nullable for unlimited redemptions.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumRedemptionsPerDay rdf:type rdf:Property ;
    rdfs:label 'Maximum Redemptions Per Day' ;
    rdfs:comment 'Maximum number of redemption transactions allowed per member per day under this rule. Nullable for unlimited daily usage.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumRedemptionsPerMember rdf:type rdf:Property ;
    rdfs:label 'Maximum Redemptions Per Member' ;
    rdfs:comment 'Maximum number of times a single member can use this redemption rule within the effective period. Nullable for unlimited usage.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumMembershipTier rdf:type rdf:Property ;
    rdfs:label 'Minimum Membership Tier' ;
    rdfs:comment 'Minimum loyalty program tier required for a member to use this redemption rule (e.g., bronze, silver, gold, platinum). Nullable if no tier restriction.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumPointsThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Points Threshold' ;
    rdfs:comment 'Minimum number of loyalty points required to initiate a redemption transaction under this rule.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partialRedemptionAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Redemption Allowed Flag' ;
    rdfs:comment 'Indicates whether members can redeem points in amounts less than the full reward value (True) or must redeem in full increments only (False).' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posIntegrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pos Integration Required Flag' ;
    rdfs:comment 'Indicates whether this redemption rule requires real-time integration with Point of Sale (POS) systems for in-store redemptions (True) or can be processed offline (False).' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redemptionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Redemption Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the monetary value associated with point redemptions.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionRate rdf:type rdf:Property ;
    rdfs:label 'Redemption Rate' ;
    rdfs:comment 'Conversion rate defining how many points equal one unit of currency or reward value (e.g., 100 points = 1 USD).' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Rule Status' ;
    rdfs:comment 'Current lifecycle status of the redemption rule indicating its operational state.' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Approval Flag' ;
    rdfs:comment 'Indicates whether redemptions under this rule require manager or system approval before processing (True) or are auto-approved (False).' ;
    rdfs:domain ind:RedemptionRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rewardId rdf:type rdf:Property ;
    rdfs:label 'Reward Id' ;
    rdfs:comment 'Unique identifier for the reward in the loyalty program catalog. Primary key.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Reward .

ind:eligibleStoreFormatId rdf:type rdf:Property ;
    rdfs:label 'Eligible Store Format Id' ;
    rdfs:comment 'Foreign key linking to store.store_format. Business justification: Reward eligibility restricted by format (experiential rewards only at flagship, bulk discounts only at warehouse). Retail loyalty catalogs curated per format to match inventory, service capabilities, ' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Format .

ind:partnerVendorId rdf:type rdf:Property ;
    rdfs:label 'Partner Vendor Id' ;
    rdfs:comment 'External identifier for the partner vendor in the vendor management system. Null for internally-fulfilled rewards.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:productSkuId rdf:type rdf:Property ;
    rdfs:label 'Product Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Loyalty rewards can be product-based (e.g., \'redeem points for this SKU\'). The reward.product_sku_restriction field suggests SKU-level restrictions exist. This links loyalty rewards to the product cat' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:brandRestriction rdf:type rdf:Property ;
    rdfs:label 'Brand Restriction' ;
    rdfs:comment 'Comma-separated list of brand codes this reward applies to or excludes. Null if no brand restriction. Supports brand-sponsored rewards.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelAvailability rdf:type rdf:Property ;
    rdfs:label 'Channel Availability' ;
    rdfs:comment 'Channels where this reward can be redeemed: in-store (physical locations), online (e-commerce site), mobile app, call center, or all channels (omnichannel). Supports channel-specific reward strategies.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costToBusiness rdf:type rdf:Property ;
    rdfs:label 'Cost To Business' ;
    rdfs:comment 'Internal cost to the business for fulfilling this reward (e.g., wholesale cost, partner fee). Used for program ROI analysis and points liability valuation. Business-confidential.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User identifier or system account that created this reward record. Part of audit trail.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:descriptionLong rdf:type rdf:Property ;
    rdfs:label 'Description Long' ;
    rdfs:comment 'Detailed customer-facing description of the reward, including benefits, usage instructions, and value proposition. Used in reward detail pages.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:descriptionShort rdf:type rdf:Property ;
    rdfs:label 'Description Short' ;
    rdfs:comment 'Brief customer-facing description of the reward (typically 1-2 sentences), used in catalog list views and mobile notifications.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountValue rdf:type rdf:Property ;
    rdfs:label 'Discount Value' ;
    rdfs:comment 'Numeric value of the discount. For percentage discounts, this is the percentage (e.g., 15.00 for 15%). For fixed amount, this is the currency amount. Null for non-discount rewards.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:displayPriority rdf:type rdf:Property ;
    rdfs:label 'Display Priority' ;
    rdfs:comment 'Numeric priority for sorting rewards in catalog displays. Lower numbers appear first. Used for merchandising control of reward visibility.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibleMemberTiers rdf:type rdf:Property ;
    rdfs:label 'Eligible Member Tiers' ;
    rdfs:comment 'Comma-separated list of loyalty tier codes eligible to redeem this reward (e.g., \'SILVER,GOLD,PLATINUM\'). Null or \'ALL\' if available to all tiers. Enables tier-exclusive rewards.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imageUrl rdf:type rdf:Property ;
    rdfs:label 'Image Url' ;
    rdfs:comment 'URL to the primary image asset for this reward, used in customer-facing catalog displays and mobile app.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCombinable rdf:type rdf:Property ;
    rdfs:label 'Is Combinable' ;
    rdfs:comment 'Boolean flag indicating whether this reward can be combined with other rewards or promotions in a single transaction. True if combinable, false if exclusive.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marginPercentage rdf:type rdf:Property ;
    rdfs:label 'Margin Percentage' ;
    rdfs:comment 'Calculated margin percentage between monetary value and cost to business ((monetary_value - cost_to_business) / monetary_value * 100). Used for reward profitability analysis. Business-confidential.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Discount Amount' ;
    rdfs:comment 'Cap on the discount amount for percentage-based rewards (e.g., 20% off up to $50 maximum discount). Null if no cap applies.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Purchase Amount' ;
    rdfs:comment 'Minimum transaction amount required to redeem this reward. Null if no minimum applies. Used to enforce redemption rules and protect margin.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monetaryValue rdf:type rdf:Property ;
    rdfs:label 'Monetary Value' ;
    rdfs:comment 'Approximate monetary value of the reward in the base currency, used for points liability accounting and customer value communication.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsCost rdf:type rdf:Property ;
    rdfs:label 'Points Cost' ;
    rdfs:comment 'Number of loyalty points required to redeem this reward. Core pricing mechanism for the loyalty program.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productSkuRestriction rdf:type rdf:Property ;
    rdfs:label 'Product Sku Restriction' ;
    rdfs:comment 'Comma-separated list of SKU codes this reward applies to or excludes. Used for product-specific rewards (e.g., free product reward for specific SKU). Null if no SKU restriction.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityLimitPerMember rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Per Member' ;
    rdfs:comment 'Maximum number of times a single loyalty member can redeem this reward within the validity period. Null for no limit.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionValidityDays rdf:type rdf:Property ;
    rdfs:label 'Redemption Validity Days' ;
    rdfs:comment 'Number of days from redemption date that the reward voucher or certificate remains valid for use. Null for instant-use rewards.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rewardCategory rdf:type rdf:Property ;
    rdfs:label 'Reward Category' ;
    rdfs:comment 'Business classification grouping for the reward (e.g., \'Grocery\', \'Apparel\', \'Electronics\', \'Travel\', \'Dining\', \'Wellness\'). Used for catalog navigation and reporting.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardCode rdf:type rdf:Property ;
    rdfs:label 'Reward Code' ;
    rdfs:comment 'Externally-facing unique alphanumeric code for the reward, used in customer communications and redemption interfaces.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardName rdf:type rdf:Property ;
    rdfs:label 'Reward Name' ;
    rdfs:comment 'Customer-facing display name of the reward (e.g., \'$10 Off Next Purchase\', \'Free Coffee\', \'Premium Gift Card\').' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardStatus rdf:type rdf:Property ;
    rdfs:label 'Reward Status' ;
    rdfs:comment 'Current lifecycle status of the reward in the catalog. Active: available for redemption. Inactive: temporarily unavailable. Sold out: inventory depleted. Discontinued: permanently removed. Pending approval: awaiting merchandising review.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardType rdf:type rdf:Property ;
    rdfs:label 'Reward Type' ;
    rdfs:comment 'Classification of the reward by its nature: discount voucher (percentage or fixed amount off), free product (complimentary item), gift card (prepaid card), experience (event or service), charitable donation (contribution to cause), cashback (monetary return), or points multiplier (bonus points on future purchases). [ENUM-REF-CANDIDATE: discount_voucher|free_product|gift_card|experience|charitable_donation|cashback|points_multiplier — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAndConditions rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions' ;
    rdfs:comment 'Legal terms and conditions governing the redemption and use of this reward. Includes exclusions, restrictions, and compliance disclaimers.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Url' ;
    rdfs:comment 'URL to the thumbnail image for this reward, optimized for list views and quick loading.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'User identifier or system account that last modified this reward record. Part of audit trail.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudDetectionScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Detection Score' ;
    rdfs:comment 'Numerical risk score (0-100) assigned by fraud detection algorithms at the time of redemption. Higher scores indicate higher fraud risk.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFraudulent rdf:type rdf:Property ;
    rdfs:label 'Is Fraudulent' ;
    rdfs:comment 'Boolean flag indicating whether the redemption was identified as fraudulent by fraud detection systems or manual review. True if fraudulent, False otherwise.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Points Redeemed' ;
    rdfs:comment 'Number of loyalty points deducted from the member\'s account for this redemption. Drives points liability reduction in financial reporting.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionNumber rdf:type rdf:Property ;
    rdfs:label 'Redemption Number' ;
    rdfs:comment 'Human-readable business identifier for the redemption transaction, used for customer service inquiries and operational tracking.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Status' ;
    rdfs:comment 'Current lifecycle state of the redemption: issued (voucher/code generated), activated (member claimed), used (redeemed at point of sale or fulfillment), expired (passed validity period), cancelled (member or system cancelled), reversed (points restored due to return or error).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Redemption Timestamp' ;
    rdfs:comment 'Date and time when the member initiated the redemption transaction. Represents the business event time for points liability reduction and reward issuance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:redemptionType rdf:type rdf:Property ;
    rdfs:label 'Redemption Type' ;
    rdfs:comment 'Discriminator indicating the category of redemption: catalog reward (standard rewards catalog item), personalized offer (targeted member-specific offer), promotional offer (campaign-driven offer), partner reward (third-party partner reward), instant discount (point-of-sale discount), or voucher (gift certificate or coupon).' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierAtRedemption rdf:type rdf:Property ;
    rdfs:label 'Tier At Redemption' ;
    rdfs:comment 'The loyalty program tier level of the member at the time of redemption (e.g., Silver, Gold, Platinum). Captured for tier-based redemption analysis and benefit tracking.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageTimestamp rdf:type rdf:Property ;
    rdfs:label 'Usage Timestamp' ;
    rdfs:comment 'Date and time when the voucher or reward was actually used in a transaction. Null if status is issued or activated but not yet used.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:voucherCode rdf:type rdf:Property ;
    rdfs:label 'Voucher Code' ;
    rdfs:comment 'Unique alphanumeric code issued to the member for redemption at point of sale or online checkout. Used to track usage and prevent fraud.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activation Timestamp' ;
    rdfs:comment 'Date and time when the member activated or accepted the offer. Null if not yet activated.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bonusPointsAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Points Amount' ;
    rdfs:comment 'Fixed number of bonus points awarded upon offer redemption or qualifying action. Null if offer is not a fixed-points bonus.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibleProductCategory rdf:type rdf:Property ;
    rdfs:label 'Eligible Product Category' ;
    rdfs:comment 'Product category or categories eligible for this offer (e.g., \'Apparel\', \'Electronics\'). Null if offer applies to all products.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Liability Amount' ;
    rdfs:comment 'Estimated financial liability or cost to the business if this offer is fully redeemed, used for points liability and financial planning.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiration Timestamp' ;
    rdfs:comment 'Date and time when the offer expired without being redeemed. Null if offer is still active or was redeemed.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxRedemptions rdf:type rdf:Property ;
    rdfs:label 'Max Redemptions' ;
    rdfs:comment 'Maximum number of times this offer can be redeemed by the member. Null for unlimited redemptions within validity period.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Quantity' ;
    rdfs:comment 'Minimum number of items or units required to qualify for the offer. Null if no quantity requirement.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Spend Amount' ;
    rdfs:comment 'Minimum purchase amount required to qualify for the offer. Null if no minimum spend requirement.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User ID or system identifier of the person or process that last modified this offer record.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerCode rdf:type rdf:Property ;
    rdfs:label 'Offer Code' ;
    rdfs:comment 'Unique alphanumeric code representing this offer, used for tracking and redemption. Externally visible identifier.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerDescription rdf:type rdf:Property ;
    rdfs:label 'Offer Description' ;
    rdfs:comment 'Detailed description of the offer terms, benefits, and conditions as communicated to the member.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerName rdf:type rdf:Property ;
    rdfs:label 'Offer Name' ;
    rdfs:comment 'Human-readable name of the offer as presented to the member (e.g., \'Birthday Bonus Points\', \'Welcome Back Discount\').' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerSource rdf:type rdf:Property ;
    rdfs:label 'Offer Source' ;
    rdfs:comment 'Origin of the offer assignment: automated (system-generated based on rules), manual (created by loyalty manager), campaign (part of marketing campaign), clienteling (personalized by store associate), tier_benefit (automatic tier-based perk).' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerStatus rdf:type rdf:Property ;
    rdfs:label 'Offer Status' ;
    rdfs:comment 'Current lifecycle status of the offer: pending (assigned but not yet presented), presented (communicated to member), activated (member accepted), redeemed (member used), expired (validity period ended), declined (member rejected), cancelled (offer withdrawn by business). [ENUM-REF-CANDIDATE: pending|presented|activated|redeemed|expired|declined|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerType rdf:type rdf:Property ;
    rdfs:label 'Offer Type' ;
    rdfs:comment 'Category of the offer benefit: bonus_points (points multiplier or fixed bonus), discount (percentage or fixed amount off), free_item (complimentary product), early_access (exclusive access to sales or products), experiential_reward (event tickets, services), tier_upgrade (accelerated tier progression).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationScore rdf:type rdf:Property ;
    rdfs:label 'Personalization Score' ;
    rdfs:comment 'Algorithmic score indicating the degree of personalization or relevance of this offer to the member, typically 0.00 to 1.00. Used for offer optimization and analytics.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsMultiplier rdf:type rdf:Property ;
    rdfs:label 'Points Multiplier' ;
    rdfs:comment 'Multiplier applied to points accrual for qualifying purchases (e.g., 2.0 for double points, 1.5 for 50% bonus). Null if offer is not points-based.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:presentationPriority rdf:type rdf:Property ;
    rdfs:label 'Presentation Priority' ;
    rdfs:comment 'Numeric priority for displaying this offer when multiple offers are available to the member. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:presentationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Presentation Timestamp' ;
    rdfs:comment 'Date and time when the offer was first presented or communicated to the member. Null if not yet presented.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:redemptionCount rdf:type rdf:Property ;
    rdfs:label 'Redemption Count' ;
    rdfs:comment 'Number of times this offer has been redeemed by the member to date.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageAnnualSpend rdf:type rdf:Property ;
    rdfs:label 'Average Annual Spend' ;
    rdfs:comment 'Average annual spend (trailing 12 months) of members in this segment. Used for spend-based segmentation validation and campaign ROI forecasting. Currency implied by program configuration.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageLtv rdf:type rdf:Property ;
    rdfs:label 'Average Ltv' ;
    rdfs:comment 'Average Customer Lifetime Value (CLTV) of members in this segment. Calculated metric used for segment value ranking and ROI analysis. Currency implied by program configuration.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averagePointsBalance rdf:type rdf:Property ;
    rdfs:label 'Average Points Balance' ;
    rdfs:comment 'Average loyalty points balance across all members in this segment. Used for points liability forecasting and segment value analysis.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Business rationale and expected outcomes for creating this segment. Documents strategic intent, target KPIs, and success criteria. Supports segment portfolio governance and ROI tracking.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Campaign Eligibility Flag' ;
    rdfs:comment 'Boolean flag indicating whether members in this segment are eligible for targeted marketing campaigns. False may indicate test segments or internal analytical segments not intended for outbound communication.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:definitionCriteria rdf:type rdf:Property ;
    rdfs:label 'Definition Criteria' ;
    rdfs:comment 'Business rules or criteria defining segment membership. May be SQL-like expression, natural language rule description, or reference to external rule engine configuration. Examples: \'Points earned > 5000 in last 90 days AND redemption count >= 2\', \'RFM score R>=4 AND F>=3\'.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'Boolean flag indicating whether members can belong to only this segment (true) or can be assigned to multiple segments simultaneously (false). Supports mutually exclusive vs. overlapping segmentation strategies.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberCount rdf:type rdf:Property ;
    rdfs:label 'Member Count' ;
    rdfs:comment 'Current count of loyalty members assigned to this segment. Updated with each segment refresh cycle. Used for campaign sizing and ROI forecasting.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mlModelReference rdf:type rdf:Property ;
    rdfs:label 'Ml Model Reference' ;
    rdfs:comment 'Reference identifier to the ML model used for segment assignment (e.g., model name, version, registry URI). Null for non-ML-based segments. Enables model lineage tracking and reproducibility.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mlModelVersion rdf:type rdf:Property ;
    rdfs:label 'Ml Model Version' ;
    rdfs:comment 'Version identifier of the ML model used for segment assignment. Supports model versioning and A/B testing of segmentation strategies.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Refresh Timestamp' ;
    rdfs:comment 'Scheduled timestamp for the next segment membership refresh. Null for on-demand segments. Supports proactive monitoring and capacity planning.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:offerEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Offer Eligibility Flag' ;
    rdfs:comment 'Boolean flag indicating whether members in this segment are eligible for personalized offers and promotions. Supports offer targeting and exclusion rules.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Comma-separated list of business tags or labels for segment categorization and search (e.g., high-value, seasonal, test, omnichannel). Supports flexible segment discovery and reporting.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMemberCount rdf:type rdf:Property ;
    rdfs:label 'Target Member Count' ;
    rdfs:comment 'Target or expected member count for this segment based on business planning. Used to monitor segment size drift and validate segmentation model performance.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierQualificationFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Flag' ;
    rdfs:comment 'Boolean flag indicating whether this segment is used for loyalty tier qualification or upgrade/downgrade decisions. True for segments that drive tier movement logic.' ;
    rdfs:domain ind:MemberSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outboundOrderId rdf:type rdf:Property ;
    rdfs:label 'Outbound Order Id' ;
    rdfs:comment 'Foreign key linking to supplychain.outbound_order. Business justification: Store replenishment orders fulfilled from DC create both outbound_order (DC perspective) and fulfillment_order (execution). Links DC dispatch to fulfillment execution for ship-to-store scenarios, enab' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundOrder .

ind:actualFulfillmentHours rdf:type rdf:Property ;
    rdfs:label 'Actual Fulfillment Hours' ;
    rdfs:comment 'The actual elapsed time in hours from fulfillment order creation to completion. Used for performance measurement against SLA.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentAssignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Assigned Timestamp' ;
    rdfs:comment 'Timestamp when the fulfillment order was assigned to a specific fulfillment node and became actionable.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfillmentCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Created Timestamp' ;
    rdfs:comment 'Timestamp when this fulfillment order record was created in the system. Marks the start of fulfillment processing.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfillmentOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Number' ;
    rdfs:comment 'Human-readable business identifier for the fulfillment order, used for tracking and communication across systems and with partners.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current lifecycle state of the fulfillment order in the pick-pack-ship workflow. [ENUM-REF-CANDIDATE: created|assigned|picking|picked|packing|packed|shipped|ready_for_pickup|completed|cancelled — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCount rdf:type rdf:Property ;
    rdfs:label 'Package Count' ;
    rdfs:comment 'Number of physical packages or parcels created for this fulfillment order. Orders may be split across multiple packages.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packingCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packing Completed Timestamp' ;
    rdfs:comment 'Timestamp when the fulfillment order was packed and ready for shipment or pickup.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packingSlipUrl rdf:type rdf:Property ;
    rdfs:label 'Packing Slip Url' ;
    rdfs:comment 'URL to the packing slip document that accompanies the shipment, listing order contents.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickingCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picking Completed Timestamp' ;
    rdfs:comment 'Timestamp when all items in the fulfillment order were successfully picked from inventory.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickingStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picking Started Timestamp' ;
    rdfs:comment 'Timestamp when the picking process began for this fulfillment order.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickupLocationCode rdf:type rdf:Property ;
    rdfs:label 'Pickup Location Code' ;
    rdfs:comment 'Designated area or counter code within the store where BOPIS/ROPIS orders are staged for customer pickup.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shipped Timestamp' ;
    rdfs:comment 'Timestamp when the fulfillment order was handed off to the carrier for delivery.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shippingCostAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost Amount' ;
    rdfs:comment 'Actual cost incurred for carrier services to ship this fulfillment order. Used for profitability analysis and cost allocation.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingLabelUrl rdf:type rdf:Property ;
    rdfs:label 'Shipping Label Url' ;
    rdfs:comment 'URL to the generated shipping label document for this fulfillment order, used by warehouse staff for package labeling.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Additional instructions for fulfillment staff regarding fragile items, gift wrapping, temperature control, or other special requirements.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalItemQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Item Quantity' ;
    rdfs:comment 'Total number of individual units across all line items in this fulfillment order. Used for capacity planning and picker productivity.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLineCount rdf:type rdf:Property ;
    rdfs:label 'Total Line Count' ;
    rdfs:comment 'Number of distinct SKU line items in this fulfillment order. Impacts picking complexity and time.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cubic Meters' ;
    rdfs:comment 'Total volumetric size of the fulfillment order in cubic meters, used for transportation planning and dimensional weight pricing.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentPackageId rdf:type rdf:Property ;
    rdfs:label 'Shipment Package Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.shipment_package. Business justification: A fulfillment line is packed into a specific shipment package (carton). This granular FK enables package-level traceability for each SKU, supports contents_summary validation, enables package weight/d' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipmentPackage .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Code identifying any exception or issue encountered during fulfillment of this line (stockout, damage, mispick, etc.). Null if no exception occurred.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Detailed description of the fulfillment exception or issue. Provides context for exception resolution and process improvement.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentSourceType rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Source Type' ;
    rdfs:comment 'Type of fulfillment location from which this line was fulfilled (distribution center, store, dark store, vendor direct, third-party logistics). Enables omnichannel fulfillment analysis.' ;
    rdfs:domain ind:FulfillmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Timestamp' ;
    rdfs:comment 'Date and time when this line was packed into a shipping container. Used for throughput analysis and bottleneck identification.' ;
    rdfs:domain ind:FulfillmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickLocation rdf:type rdf:Property ;
    rdfs:label 'Pick Location' ;
    rdfs:comment 'The warehouse location (aisle, bin, shelf) from which this item was picked. Used for inventory tracking and pick path optimization.' ;
    rdfs:domain ind:FulfillmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Timestamp' ;
    rdfs:comment 'Date and time when this line was physically picked from inventory. Critical for cycle time analysis and SLA tracking.' ;
    rdfs:domain ind:FulfillmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantityAllocated rdf:type rdf:Property ;
    rdfs:label 'Quantity Allocated' ;
    rdfs:comment 'The quantity of inventory allocated or reserved for this fulfillment line. Represents inventory commitment before physical picking.' ;
    rdfs:domain ind:FulfillmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityCancelled rdf:type rdf:Property ;
    rdfs:label 'Quantity Cancelled' ;
    rdfs:comment 'The quantity cancelled and not fulfilled for this line. Represents unfulfilled demand due to stockouts, customer cancellation, or other exceptions.' ;
    rdfs:domain ind:FulfillmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'The quantity of this item originally requested in the order. Represents the customer demand that fulfillment is attempting to satisfy.' ;
    rdfs:domain ind:FulfillmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityPacked rdf:type rdf:Property ;
    rdfs:label 'Quantity Packed' ;
    rdfs:comment 'The quantity successfully packed into shipping containers for this line. Represents items ready for shipment.' ;
    rdfs:domain ind:FulfillmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityPicked rdf:type rdf:Property ;
    rdfs:label 'Quantity Picked' ;
    rdfs:comment 'The actual quantity physically picked from inventory for this line. May differ from ordered quantity due to stockouts or picking errors.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityShipped rdf:type rdf:Property ;
    rdfs:label 'Quantity Shipped' ;
    rdfs:comment 'The quantity actually shipped to the customer for this line. Final fulfilled quantity that left the facility.' ;
    rdfs:domain ind:FulfillmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ship Timestamp' ;
    rdfs:comment 'Date and time when this line was shipped from the facility. Marks completion of fulfillment execution and start of delivery.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:substitutionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Substitution Reason Code' ;
    rdfs:comment 'Reason code explaining why a substitution was made. Used for root cause analysis and inventory planning.' ;
    rdfs:domain ind:FulfillmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierRateId rdf:type rdf:Property ;
    rdfs:label 'Carrier Rate Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.carrier_rate. Business justification: A shipment is executed at a specific contracted carrier rate. Linking shipment to carrier_rate enables freight cost reconciliation (actual shipping_cost_amount vs contracted base_rate_amount), rate au' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierRate .

ind:shipFromLocationId rdf:type rdf:Property ;
    rdfs:label 'Ship From Location Id' ;
    rdfs:comment 'Foreign key linking to store.location. Business justification: Ship-from-store operations require attributing each outbound shipment to its originating store location for store-level shipment volume reporting, carrier pickup scheduling, and store P&L cost allocat' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:waveId rdf:type rdf:Property ;
    rdfs:label 'Wave Id' ;
    rdfs:comment 'Foreign key linking to supplychain.wave. Business justification: DC wave-to-shipment reconciliation: retail DCs release waves that produce shipments; linking shipment to wave enables wave throughput reporting, carrier load planning, and SLA breach root-cause analys' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wave .

ind:carrierChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Carrier Charge Amount' ;
    rdfs:comment 'Actual cost charged by the carrier for transporting this shipment. Used for freight cost accounting and margin analysis.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierChargeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Charge Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the carrier charge amount (e.g., USD, CAD, EUR).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueAmount rdf:type rdf:Property ;
    rdfs:label 'Declared Value Amount' ;
    rdfs:comment 'Declared monetary value of the shipment contents for insurance and customs purposes. Used to determine carrier liability limits.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Declared Value Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the declared value amount (e.g., USD, CAD, EUR).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverySignatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Delivery Signature Required Flag' ;
    rdfs:comment 'Indicates whether a recipient signature is required upon delivery for proof of receipt. True if signature required, false otherwise.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether the shipment contains hazardous materials requiring special handling and documentation. True if hazmat, false otherwise.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'Shortest dimension of the shipment in centimeters. Used for carrier rating and dimensional weight calculations.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'Longest dimension of the shipment in centimeters. Used for carrier rating and dimensional weight calculations.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipFromLocationType rdf:type rdf:Property ;
    rdfs:label 'Ship From Location Type' ;
    rdfs:comment 'Classification of the originating fulfillment location type. Supports omnichannel fulfillment analytics including ship-from-store (SFS) and dark store operations.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToContactName rdf:type rdf:Property ;
    rdfs:label 'Ship To Contact Name' ;
    rdfs:comment 'Name of the recipient or contact person at the delivery destination. Used for delivery confirmation and communication.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Ship To Email Address' ;
    rdfs:comment 'Email address for shipment tracking notifications and delivery updates sent to the recipient.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Ship To Phone Number' ;
    rdfs:comment 'Contact phone number for the shipment recipient. Used by carriers for delivery coordination and customer notifications.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Externally visible unique shipment identifier used for customer tracking and carrier communication. Business identifier for the shipment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment in the fulfillment workflow. Tracks progression from creation through final delivery or return. [ENUM-REF-CANDIDATE: created|picked|packed|manifested|in_transit|out_for_delivery|delivered|failed_delivery|returned|cancelled — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the shipping cost amount (e.g., USD, CAD, EUR).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureName rdf:type rdf:Property ;
    rdfs:label 'Signature Name' ;
    rdfs:comment 'Name of the person who signed for the shipment upon delivery. Captured for proof of delivery and dispute resolution.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'Middle dimension of the shipment in centimeters. Used for carrier rating and dimensional weight calculations.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billableWeightKg rdf:type rdf:Property ;
    rdfs:label 'Billable Weight Kg' ;
    rdfs:comment 'The greater of actual weight or dimensional weight, used as the basis for carrier shipping charges.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentsSummary rdf:type rdf:Property ;
    rdfs:label 'Contents Summary' ;
    rdfs:comment 'High-level description of package contents, often used for customs declarations or customer communication (e.g., \'Apparel and Electronics\').' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryConfirmationMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmation Method' ;
    rdfs:comment 'Method used to confirm successful delivery of the package (e.g., signature, photo proof, GPS coordinates, contactless delivery). [ENUM-REF-CANDIDATE: signature|photo|gps|contactless|left_at_door|handed_to_resident|locker — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Notes' ;
    rdfs:comment 'Free-text notes from the carrier or driver regarding delivery (e.g., \'Left at front door\', \'Delivered to neighbor\').' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Dimensional Weight Kg' ;
    rdfs:comment 'Calculated dimensional weight based on package volume, used by carriers for rating when dimensional weight exceeds actual weight.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceValueAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Value Amount' ;
    rdfs:comment 'Declared value of the package contents for insurance purposes.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isInsured rdf:type rdf:Property ;
    rdfs:label 'Is Insured' ;
    rdfs:comment 'Indicates whether the package has been insured for loss or damage during transit.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLabelPrinted rdf:type rdf:Property ;
    rdfs:label 'Is Label Printed' ;
    rdfs:comment 'Indicates whether the shipping label has been printed for this package.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isManifested rdf:type rdf:Property ;
    rdfs:label 'Is Manifested' ;
    rdfs:comment 'Indicates whether the package has been included in a carrier manifest and is ready for pickup.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSealed rdf:type rdf:Property ;
    rdfs:label 'Is Sealed' ;
    rdfs:comment 'Indicates whether the package has been sealed and is ready for shipment.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Is Signature Required' ;
    rdfs:comment 'Indicates whether a signature is required upon delivery for this package.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labeledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Labeled Timestamp' ;
    rdfs:comment 'Date and time when the shipping label was printed and affixed to the package.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manifestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manifested Timestamp' ;
    rdfs:comment 'Date and time when the package was included in the carrier manifest, indicating readiness for carrier pickup.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packageNumber rdf:type rdf:Property ;
    rdfs:label 'Package Number' ;
    rdfs:comment 'Human-readable business identifier for the package, often printed on the label. May follow internal numbering conventions.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageSequence rdf:type rdf:Property ;
    rdfs:label 'Package Sequence' ;
    rdfs:comment 'Sequential position of this package within the parent shipment (e.g., package 1 of 3).' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle status of the package in the fulfillment and delivery process. [ENUM-REF-CANDIDATE: created|packed|sealed|labeled|manifested|picked_up|in_transit|out_for_delivery|delivered|exception|returned — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Type of packaging container used for this package.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packed Timestamp' ;
    rdfs:comment 'Date and time when the package was packed and sealed, marking readiness for shipment.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickedUpTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picked Up Timestamp' ;
    rdfs:comment 'Date and time when the carrier physically picked up the package from the fulfillment location.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Fulfillment method used for this package (e.g., Ship-from-Store (SFS), Distribution Center (DC) fulfillment, Buy Online Pick Up In Store (BOPIS), Reserve Online Pick Up In Store (ROPIS), drop ship). [ENUM-REF-CANDIDATE: ship_from_store|dc_fulfillment|drop_ship|bopis|ropis|curbside|locker — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPackagesInShipment rdf:type rdf:Property ;
    rdfs:label 'Total Packages In Shipment' ;
    rdfs:comment 'Total number of packages in the parent shipment, providing context for the package sequence.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitCount rdf:type rdf:Property ;
    rdfs:label 'Unit Count' ;
    rdfs:comment 'Total quantity of units across all items in the package (sum of quantities for all SKUs).' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Actual weight of the package in kilograms, including contents and packaging materials. Used for carrier rating and shipping cost calculation.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickTaskId rdf:type rdf:Property ;
    rdfs:label 'Pick Task Id' ;
    rdfs:comment 'Primary key for pick_task' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PickTask .

ind:aisle rdf:type rdf:Property ;
    rdfs:label 'Aisle' ;
    rdfs:comment 'Aisle location within the warehouse where the item is stored. Part of the physical location hierarchy for item retrieval.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'Date and time when the task was assigned to the warehouse associate. Marks the start of the task lifecycle.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bay rdf:type rdf:Property ;
    rdfs:label 'Bay' ;
    rdfs:comment 'Bay location within the aisle where the item is stored. Provides granular location detail for picking accuracy.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Date and time when the task was completed by the associate. Used for throughput analysis and SLA tracking.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Status' ;
    rdfs:comment 'Customer approval status for the substitution. Tracks whether customer accepted the replacement item for BOPIS and delivery orders.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionReason rdf:type rdf:Property ;
    rdfs:label 'Exception Reason' ;
    rdfs:comment 'Detailed description of the exception or issue encountered during task execution. Provides context for exception resolution.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelApplied rdf:type rdf:Property ;
    rdfs:label 'Label Applied' ;
    rdfs:comment 'Indicates whether the shipping label was successfully applied to the package. Critical checkpoint for shipment readiness.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packingSlipPrinted rdf:type rdf:Property ;
    rdfs:label 'Packing Slip Printed' ;
    rdfs:comment 'Indicates whether the packing slip was printed and included in the package. Required for customer order verification.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packingStationCode rdf:type rdf:Property ;
    rdfs:label 'Packing Station Code' ;
    rdfs:comment 'Identifier for the packing station where the item is packed. Used for pack tasks and station utilization tracking.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickTaskStatus rdf:type rdf:Property ;
    rdfs:label 'Pick Task Status' ;
    rdfs:comment 'Current lifecycle state of the pick task. Tracks progression from assignment through completion or exception handling. [ENUM-REF-CANDIDATE: pending|assigned|in_progress|completed|exception|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCheckOutcome rdf:type rdf:Property ;
    rdfs:label 'Quality Check Outcome' ;
    rdfs:comment 'Result of the quality check performed on the picked items. Ensures accuracy and condition standards before shipment.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Original quantity of the item requested for picking. Represents the target quantity from the order or wave plan.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelf rdf:type rdf:Property ;
    rdfs:label 'Shelf' ;
    rdfs:comment 'Shelf level within the bay where the item is stored. Completes the physical location coordinates for item retrieval.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Date and time when the associate began executing the task. Used to calculate task duration and associate productivity.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:substitutedSku rdf:type rdf:Property ;
    rdfs:label 'Substituted Sku' ;
    rdfs:comment 'Replacement SKU provided when original item was unavailable. Used for substitution analysis and customer communication.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionOccurred rdf:type rdf:Property ;
    rdfs:label 'Substitution Occurred' ;
    rdfs:comment 'Indicates whether a product substitution was made during picking. Common in grocery and BOPIS fulfillment when original item is unavailable.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taskDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Task Duration Seconds' ;
    rdfs:comment 'Total time in seconds from task start to completion. Used for associate productivity analysis and labor standards calibration.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskMethod rdf:type rdf:Property ;
    rdfs:label 'Task Method' ;
    rdfs:comment 'Picking methodology used for task execution. Defines how items are grouped and picked for optimal efficiency.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskNumber rdf:type rdf:Property ;
    rdfs:label 'Task Number' ;
    rdfs:comment 'Human-readable business identifier for the pick task. Used by warehouse associates to reference and track tasks.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Classification of the fulfillment task activity. Determines the workflow and execution requirements for the task.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidFillUsed rdf:type rdf:Property ;
    rdfs:label 'Void Fill Used' ;
    rdfs:comment 'Indicates whether void fill material was used in the package. Tracks packaging material usage for cost and sustainability reporting.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workZone rdf:type rdf:Property ;
    rdfs:label 'Work Zone' ;
    rdfs:comment 'Designated zone within the fulfillment location where the task is performed. Used for zone-based picking and associate assignment.' ;
    rdfs:domain ind:PickTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTaskId rdf:type rdf:Property ;
    rdfs:label 'Pack Task Id' ;
    rdfs:comment 'Unique identifier for the packing task record. Primary key for the pack task entity.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PackTask .

ind:exceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Notes' ;
    rdfs:comment 'Free-text notes describing the exception or special handling required. Provides context for exception resolution and audit trail.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftMessageIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Message Included Flag' ;
    rdfs:comment 'Indicates whether a personalized gift message was printed and included in the package per customer request.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:giftWrapFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Wrap Flag' ;
    rdfs:comment 'Indicates whether gift wrapping service was requested and applied to this package. Impacts packing time and material cost.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemsPackedCount rdf:type rdf:Property ;
    rdfs:label 'Items Packed Count' ;
    rdfs:comment 'Total number of individual items (SKUs) packed into the package for this task. Used for productivity measurement and quality verification.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Pack Duration Seconds' ;
    rdfs:comment 'Total time in seconds spent on the packing operation from start to completion. Key metric for labor standards and productivity analysis.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack End Timestamp' ;
    rdfs:comment 'Timestamp when the packing operation was completed and the package was sealed. Used to calculate pack cycle time and throughput.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Start Timestamp' ;
    rdfs:comment 'Timestamp when the packer began the packing operation. Used to calculate pack cycle time and labor productivity.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packageHeightCm rdf:type rdf:Property ;
    rdfs:label 'Package Height Cm' ;
    rdfs:comment 'Height dimension of the package in centimeters. Used for dimensional weight calculation and carrier compliance.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageLengthCm rdf:type rdf:Property ;
    rdfs:label 'Package Length Cm' ;
    rdfs:comment 'Length dimension of the package in centimeters. Used for dimensional weight calculation and carrier compliance.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageSize rdf:type rdf:Property ;
    rdfs:label 'Package Size' ;
    rdfs:comment 'Standardized size designation of the package selected. Used for dimensional weight calculation and carrier rate determination. [ENUM-REF-CANDIDATE: XS|S|M|L|XL|XXL|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageWeightKg rdf:type rdf:Property ;
    rdfs:label 'Package Weight Kg' ;
    rdfs:comment 'Actual weight of the sealed package in kilograms, measured at the packing station. Used for carrier rate calculation and compliance verification.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageWidthCm rdf:type rdf:Property ;
    rdfs:label 'Package Width Cm' ;
    rdfs:comment 'Width dimension of the package in centimeters. Used for dimensional weight calculation and carrier compliance.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packingSlipPrintedFlag rdf:type rdf:Property ;
    rdfs:label 'Packing Slip Printed Flag' ;
    rdfs:comment 'Indicates whether the packing slip document was successfully printed and included in the package. Required for customer order verification.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityCheckPerformedBy rdf:type rdf:Property ;
    rdfs:label 'Quality Check Performed By' ;
    rdfs:comment 'Identifier of the associate who performed the quality inspection. Used for accountability and training needs identification.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Check Status' ;
    rdfs:comment 'Result of the quality inspection performed on the packed package. Failed status triggers rework or escalation.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingLabelAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Shipping Label Applied Flag' ;
    rdfs:comment 'Indicates whether the carrier shipping label was successfully printed and affixed to the package. Required for carrier acceptance.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Required Flag' ;
    rdfs:comment 'Indicates whether the shipment requires recipient signature upon delivery. Impacts carrier service selection and cost.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taskPriority rdf:type rdf:Property ;
    rdfs:label 'Task Priority' ;
    rdfs:comment 'Priority level assigned to the pack task based on order SLA, shipping cutoff time, or customer tier. Determines task sequencing at the packing station.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle state of the packing task. Tracks progression from assignment through completion or exception handling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsPackedCount rdf:type rdf:Property ;
    rdfs:label 'Units Packed Count' ;
    rdfs:comment 'Total quantity of units packed across all items. Differs from items_packed_count when multiple units of the same SKU are included.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voidFillType rdf:type rdf:Property ;
    rdfs:label 'Void Fill Type' ;
    rdfs:comment 'Type of void fill material used to protect items and prevent shifting during transit. Impacts packaging cost and sustainability metrics.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Api Integration Flag' ;
    rdfs:comment 'Indicates whether the carrier provides API integration capabilities for real-time rate shopping, booking, and tracking.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseRatePerLb rdf:type rdf:Property ;
    rdfs:label 'Base Rate Per Lb' ;
    rdfs:comment 'Negotiated base shipping rate per pound for standard service level, before surcharges and adjustments.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bopisReadyFlag rdf:type rdf:Property ;
    rdfs:label 'Bopis Ready Flag' ;
    rdfs:comment 'Indicates whether the carrier supports BOPIS fulfillment logistics including store-to-customer handoff coordination.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'The legal business name of the carrier or third-party logistics (3PL) provider.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Status' ;
    rdfs:comment 'Current operational status of the carrier relationship indicating whether the carrier is available for shipment assignment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Classification of the carrier based on service model: parcel (small package), LTL (Less Than Truckload), FTL (Full Truckload), last-mile delivery, same-day delivery, or third-party logistics (3PL) provider.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Date when the carrier service contract expires or is scheduled for renewal.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Date when the carrier service contract or agreement became effective.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cutoffTimeLocal rdf:type rdf:Property ;
    rdfs:label 'Cutoff Time Local' ;
    rdfs:comment 'Daily cutoff time in local warehouse time zone (HH:MM format) by which shipments must be tendered to the carrier to qualify for same-day pickup and service level commitment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionalWeightFactor rdf:type rdf:Property ;
    rdfs:label 'Dimensional Weight Factor' ;
    rdfs:comment 'Divisor used to calculate dimensional weight from package dimensions (length x width x height / factor). Common values are 139 for domestic and 166 for international.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extendedAreaSurcharge rdf:type rdf:Property ;
    rdfs:label 'Extended Area Surcharge' ;
    rdfs:comment 'Additional fee charged for deliveries to remote or extended service areas beyond standard coverage zones.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargePercentage rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Percentage' ;
    rdfs:comment 'Current fuel surcharge percentage applied to base shipping rates, typically adjusted monthly based on fuel price indices.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Description of the geographic regions and countries where the carrier provides service coverage. May include restrictions or limitations.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether the carrier is certified and authorized to transport hazardous materials under Department of Transportation (DOT) regulations.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Flag' ;
    rdfs:comment 'Indicates whether the carrier offers shipment insurance or declared value coverage for high-value packages.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxHeightInches rdf:type rdf:Property ;
    rdfs:label 'Max Height Inches' ;
    rdfs:comment 'Maximum package height dimension in inches that the carrier will accept for shipment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxLengthInches rdf:type rdf:Property ;
    rdfs:label 'Max Length Inches' ;
    rdfs:comment 'Maximum package length dimension in inches that the carrier will accept for shipment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Max Weight Lbs' ;
    rdfs:comment 'Maximum package weight in pounds that the carrier will accept for shipment under standard service terms.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWidthInches rdf:type rdf:Property ;
    rdfs:label 'Max Width Inches' ;
    rdfs:comment 'Maximum package width dimension in inches that the carrier will accept for shipment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiatedDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Negotiated Discount Percentage' ;
    rdfs:comment 'Volume-based discount percentage negotiated off published carrier rates based on annual shipping commitment.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Rate Effective Date' ;
    rdfs:comment 'Date when the current rate card and pricing terms became effective.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Rate Expiry Date' ;
    rdfs:comment 'Date when the current rate card expires and requires renegotiation or renewal.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:residentialDeliverySurcharge rdf:type rdf:Property ;
    rdfs:label 'Residential Delivery Surcharge' ;
    rdfs:comment 'Additional flat fee charged for deliveries to residential addresses versus commercial addresses.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scacCode rdf:type rdf:Property ;
    rdfs:label 'Scac Code' ;
    rdfs:comment 'Standard Carrier Alpha Code assigned by the National Motor Freight Traffic Association for freight carriers in North America.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelGround rdf:type rdf:Property ;
    rdfs:label 'Service Level Ground' ;
    rdfs:comment 'Indicates whether the carrier offers standard ground shipping service.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLevelOvernight rdf:type rdf:Property ;
    rdfs:label 'Service Level Overnight' ;
    rdfs:comment 'Indicates whether the carrier offers overnight express shipping service.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLevelSameDay rdf:type rdf:Property ;
    rdfs:label 'Service Level Same Day' ;
    rdfs:comment 'Indicates whether the carrier offers same-day delivery service for local or regional shipments.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLevelTwoDay rdf:type rdf:Property ;
    rdfs:label 'Service Level Two Day' ;
    rdfs:comment 'Indicates whether the carrier offers two-day expedited shipping service.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trackingCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Tracking Capability Flag' ;
    rdfs:comment 'Indicates whether the carrier provides real-time shipment tracking and visibility capabilities.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transitDaysZone1 rdf:type rdf:Property ;
    rdfs:label 'Transit Days Zone 1' ;
    rdfs:comment 'Standard number of business days for ground shipment delivery to Zone 1 (typically local or adjacent regions).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitDaysZone2 rdf:type rdf:Property ;
    rdfs:label 'Transit Days Zone 2' ;
    rdfs:comment 'Standard number of business days for ground shipment delivery to Zone 2 (typically regional).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitDaysZone3 rdf:type rdf:Property ;
    rdfs:label 'Transit Days Zone 3' ;
    rdfs:comment 'Standard number of business days for ground shipment delivery to Zone 3 (typically extended regional).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseRate rdf:type rdf:Property ;
    rdfs:label 'Base Rate' ;
    rdfs:comment 'Base shipping rate for this carrier service in the default currency. Used as starting point for total shipping cost calculation before surcharges and discounts.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bopisEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Bopis Eligible Flag' ;
    rdfs:comment 'Indicates whether this carrier service is eligible for BOPIS (Buy Online Pick Up In Store) fulfillment scenarios. Used in omnichannel order routing.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carbonNeutralFlag rdf:type rdf:Property ;
    rdfs:label 'Carbon Neutral Flag' ;
    rdfs:comment 'Indicates whether this carrier service is certified as carbon-neutral or participates in carbon offset programs. Used in sustainability reporting and eco-conscious customer service selection.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cutoffTime rdf:type rdf:Property ;
    rdfs:label 'Cutoff Time' ;
    rdfs:comment 'Daily cutoff time (HH:MM format, 24-hour) by which orders must be placed to qualify for same-day shipment with this service. Critical for order routing and fulfillment scheduling.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cutoffTimezone rdf:type rdf:Property ;
    rdfs:label 'Cutoff Timezone' ;
    rdfs:comment 'Timezone identifier for the cutoff time (e.g., EST, PST, CST, UTC). Ensures accurate cutoff enforcement across distributed fulfillment centers.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction Type' ;
    rdfs:comment 'Type of geographic restriction applied to this carrier service (e.g., domestic only, specific regions, postal code whitelist/blacklist). Used in carrier eligibility filtering.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Eligible Flag' ;
    rdfs:comment 'Indicates whether this carrier service is certified to transport hazardous materials. Used in carrier selection for restricted product categories.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holidayDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Holiday Delivery Flag' ;
    rdfs:comment 'Indicates whether this carrier service supports delivery on recognized holidays. Used in delivery date estimation and peak season planning.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Included Flag' ;
    rdfs:comment 'Indicates whether shipment insurance is automatically included with this carrier service. Affects cost calculations and risk management decisions.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceMaxValue rdf:type rdf:Property ;
    rdfs:label 'Insurance Max Value' ;
    rdfs:comment 'Maximum insured value (in base currency) covered by this carrier service. Orders exceeding this value may require additional insurance or alternative services.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internationalEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'International Eligible Flag' ;
    rdfs:comment 'Indicates whether this carrier service supports international cross-border shipments. Used in carrier selection for international orders.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxGirthCm rdf:type rdf:Property ;
    rdfs:label 'Max Girth Cm' ;
    rdfs:comment 'Maximum package girth (length + 2×width + 2×height) in centimeters. Some carriers enforce combined dimensional limits beyond individual dimension constraints.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxHeightCm rdf:type rdf:Property ;
    rdfs:label 'Max Height Cm' ;
    rdfs:comment 'Maximum package height dimension in centimeters accepted by this carrier service. Used in dimensional eligibility checks during carrier selection.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxLengthCm rdf:type rdf:Property ;
    rdfs:label 'Max Length Cm' ;
    rdfs:comment 'Maximum package length dimension in centimeters accepted by this carrier service. Used in dimensional eligibility checks during carrier selection.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Weight Kg' ;
    rdfs:comment 'Maximum shipment weight in kilograms that this carrier service can handle. Used in carrier selection logic to filter eligible services based on order weight.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWidthCm rdf:type rdf:Property ;
    rdfs:label 'Max Width Cm' ;
    rdfs:comment 'Maximum package width dimension in centimeters accepted by this carrier service. Used in dimensional eligibility checks during carrier selection.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perishableEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Perishable Eligible Flag' ;
    rdfs:comment 'Indicates whether this carrier service supports temperature-controlled or time-sensitive perishable goods (e.g., groceries, fresh food). Used in carrier selection for perishable SKUs.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedCountries rdf:type rdf:Property ;
    rdfs:label 'Restricted Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this carrier service is NOT available. Used in international order routing and carrier selection.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedPostalCodes rdf:type rdf:Property ;
    rdfs:label 'Restricted Postal Codes' ;
    rdfs:comment 'Comma-separated list of postal codes or postal code prefixes where this carrier service is NOT available. Used in carrier eligibility filtering during order routing.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saturdayDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Saturday Delivery Flag' ;
    rdfs:comment 'Indicates whether this carrier service supports Saturday delivery. Used in delivery date estimation and customer service selection.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the carrier service offering (e.g., GROUND, 2DAY, OVERNIGHT, SAMEDAY). Used in carrier selection logic and order routing.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceName rdf:type rdf:Property ;
    rdfs:label 'Service Name' ;
    rdfs:comment 'Human-readable name of the carrier service offering (e.g., Ground Shipping, Two-Day Express, Overnight Priority, Same-Day Delivery).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'Current operational status of the carrier service. Determines availability for order routing and fulfillment selection.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Classification of the carrier service by delivery speed and priority level. Used for service tier segmentation and customer selection.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipFromStoreEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Ship From Store Eligible Flag' ;
    rdfs:comment 'Indicates whether this carrier service is eligible for SFS (Ship From Store) fulfillment scenarios. Used in omnichannel order routing and inventory optimization.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaDeliveryGuaranteeFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Delivery Guarantee Flag' ;
    rdfs:comment 'Indicates whether this carrier service includes a contractual SLA (Service Level Agreement) delivery guarantee with refund or credit for late deliveries. Used in service selection and customer promise management.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sundayDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Sunday Delivery Flag' ;
    rdfs:comment 'Indicates whether this carrier service supports Sunday delivery. Used in delivery date estimation and customer service selection.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surchargeTypes rdf:type rdf:Property ;
    rdfs:label 'Surcharge Types' ;
    rdfs:comment 'Comma-separated list of surcharge types applicable to this carrier service (e.g., fuel_surcharge, residential_delivery, remote_area, oversized, peak_season). Used in total shipping cost calculation.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitDaysMax rdf:type rdf:Property ;
    rdfs:label 'Transit Days Max' ;
    rdfs:comment 'Maximum number of business days required for delivery from shipment date. Used in delivery date estimation and SLA (Service Level Agreement) calculations.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitDaysMin rdf:type rdf:Property ;
    rdfs:label 'Transit Days Min' ;
    rdfs:comment 'Minimum number of business days required for delivery from shipment date. Used in delivery date estimation and SLA (Service Level Agreement) calculations.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Degree of automation in fulfillment operations: manual (human-only picking/packing), semi_automated (conveyor systems, pick-to-light), fully_automated (robotic picking, automated storage and retrieval systems).' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bopisEnabled rdf:type rdf:Property ;
    rdfs:label 'Bopis Enabled' ;
    rdfs:comment 'Indicates whether this node supports Buy Online Pick Up In Store (BOPIS) fulfillment capability. True if customers can place online orders for in-store pickup at this location.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:curbsidePickupEnabled rdf:type rdf:Property ;
    rdfs:label 'Curbside Pickup Enabled' ;
    rdfs:comment 'Indicates whether this node supports curbside pickup fulfillment. True if customers can pick up orders without entering the building.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryZoneCoverageRadiusMiles rdf:type rdf:Property ;
    rdfs:label 'Delivery Zone Coverage Radius Miles' ;
    rdfs:comment 'Maximum delivery radius in miles from this fulfillment node for last-mile delivery services. Used for order routing and delivery zone assignment.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified' ;
    rdfs:comment 'Indicates whether this node is certified to handle and store hazardous materials per OSHA and DOT regulations. True if hazmat fulfillment is permitted.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextDayDeliveryEnabled rdf:type rdf:Property ;
    rdfs:label 'Next Day Delivery Enabled' ;
    rdfs:comment 'Indicates whether this node supports next-day delivery fulfillment. True if orders can be delivered to customers on the day following order placement.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nodeStatus rdf:type rdf:Property ;
    rdfs:label 'Node Status' ;
    rdfs:comment 'Current operational lifecycle status of the fulfillment node. Active nodes are available for order routing; inactive/temporarily_closed nodes are excluded from fulfillment logic.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard operating hours for weekdays (Monday-Friday) in format HH:MM-HH:MM (e.g., 08:00-20:00). Used for order cutoff time calculations and fulfillment scheduling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekend rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekend' ;
    rdfs:comment 'Standard operating hours for weekends (Saturday-Sunday) in format HH:MM-HH:MM (e.g., 09:00-18:00). Used for order cutoff time calculations and fulfillment scheduling.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packStationCount rdf:type rdf:Property ;
    rdfs:label 'Pack Station Count' ;
    rdfs:comment 'Number of packing stations available at this fulfillment node. Determines packing throughput capacity for ship-from-store and DC operations.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickCapacityOrdersPerHour rdf:type rdf:Property ;
    rdfs:label 'Pick Capacity Orders Per Hour' ;
    rdfs:comment 'Maximum number of orders that can be picked per hour at this fulfillment node under normal operating conditions. Used for capacity planning and order routing decisions.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refrigeratedStorageEnabled rdf:type rdf:Property ;
    rdfs:label 'Refrigerated Storage Enabled' ;
    rdfs:comment 'Indicates whether this node has refrigerated storage capability for perishable goods (dairy, produce, frozen foods). True if cold chain fulfillment is supported.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ropisEnabled rdf:type rdf:Property ;
    rdfs:label 'Ropis Enabled' ;
    rdfs:comment 'Indicates whether this node supports Reserve Online Pick Up In Store (ROPIS) fulfillment capability. True if customers can reserve items online for later in-store pickup and payment.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sameDayDeliveryEnabled rdf:type rdf:Property ;
    rdfs:label 'Same Day Delivery Enabled' ;
    rdfs:comment 'Indicates whether this node supports same-day delivery fulfillment. True if orders can be delivered to customers on the same day they are placed.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipFromStoreEnabled rdf:type rdf:Property ;
    rdfs:label 'Ship From Store Enabled' ;
    rdfs:comment 'Indicates whether this node supports Ship From Store (SFS) fulfillment capability. True if this location can pick, pack, and ship online orders directly to customers.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageCapacitySquareFeet rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Square Feet' ;
    rdfs:comment 'Total storage capacity of the fulfillment node measured in square feet. Used for inventory capacity planning and space utilization analysis.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageZoneCount rdf:type rdf:Property ;
    rdfs:label 'Storage Zone Count' ;
    rdfs:comment 'Number of distinct storage zones within the fulfillment node (e.g., ambient, refrigerated, frozen, hazmat). Used for inventory placement and pick path optimization.' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wmsSystemCode rdf:type rdf:Property ;
    rdfs:label 'Wms System Code' ;
    rdfs:comment 'Identifier of the WMS system instance managing this fulfillment node. Links to the operational WMS platform (e.g., Manhattan Associates instance ID).' ;
    rdfs:domain ind:FulfillmentNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionId rdf:type rdf:Property ;
    rdfs:label 'Exception Id' ;
    rdfs:comment 'Primary key for exception' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warehouseTaskId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Task Id' ;
    rdfs:comment 'Foreign key linking to supplychain.warehouse_task. Business justification: Warehouse task exception management: fulfillment exceptions (pick errors, putaway failures, mislabeled items) are raised against specific warehouse tasks; this link enables root-cause analysis, task-l' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseTask .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Description of preventive measures or process changes implemented to avoid recurrence of similar exceptions.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notified Flag' ;
    rdfs:comment 'Indicates whether the customer was notified about the exception and its impact on their order.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectedAtStage rdf:type rdf:Property ;
    rdfs:label 'Detected At Stage' ;
    rdfs:comment 'Fulfillment process stage where the exception was identified. [ENUM-REF-CANDIDATE: picking|packing|quality_check|staging|loading|carrier_handoff|in_transit|delivery — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Number indicating how many times the exception has been escalated through management hierarchy. Zero indicates no escalation.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionNumber rdf:type rdf:Property ;
    rdfs:label 'Exception Number' ;
    rdfs:comment 'Human-readable business identifier for the exception, used for tracking and communication across fulfillment teams.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Status' ;
    rdfs:comment 'Current lifecycle state of the exception in the resolution workflow.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exception Timestamp' ;
    rdfs:comment 'Date and time when the exception was first detected or logged in the fulfillment system.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionType rdf:type rdf:Property ;
    rdfs:label 'Exception Type' ;
    rdfs:comment 'Category of fulfillment exception encountered. Classifies the nature of the operational disruption. [ENUM-REF-CANDIDATE: out_of_stock_at_pick|damaged_item|mispick|carrier_pickup_missed|address_validation_failure|delivery_attempt_failure|item_not_found|quantity_shortage|quality_issue|packaging_failure|label_printing_error|system_error — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated or actual financial cost of the exception in local currency, including refunds, credits, expedited shipping, or inventory write-offs.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerType rdf:type rdf:Property ;
    rdfs:label 'Owner Type' ;
    rdfs:comment 'Role or system component responsible for the exception occurrence or resolution. [ENUM-REF-CANDIDATE: picker|packer|quality_inspector|carrier|system|supervisor|customer_service — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAffected rdf:type rdf:Property ;
    rdfs:label 'Quantity Affected' ;
    rdfs:comment 'Number of units impacted by the exception. Relevant for quantity shortages, damaged items, or mispicks.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Corrective action taken or planned to resolve the exception. [ENUM-REF-CANDIDATE: substitute_item|cancel_line|reroute_order|reschedule_delivery|issue_refund|contact_customer|escalate_to_supervisor|reprocess — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Resolution Duration Minutes' ;
    rdfs:comment 'Time elapsed in minutes from exception detection to resolution. Used for SLA tracking and performance analysis.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level classification of the underlying cause of the exception. Used for trend analysis and process improvement. [ENUM-REF-CANDIDATE: inventory_accuracy|process_error|system_failure|carrier_issue|product_quality|human_error|external_factor — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToHolidays rdf:type rdf:Property ;
    rdfs:label 'Applies To Holidays' ;
    rdfs:comment 'Indicates whether this SLA rule applies to orders placed on recognized holidays. If false, holiday orders may follow different SLA rules.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToWeekdays rdf:type rdf:Property ;
    rdfs:label 'Applies To Weekdays' ;
    rdfs:comment 'Indicates whether this SLA rule applies to orders placed on weekdays (Monday-Friday).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToWeekends rdf:type rdf:Property ;
    rdfs:label 'Applies To Weekends' ;
    rdfs:comment 'Indicates whether this SLA rule applies to orders placed on weekends (Saturday-Sunday).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold Hours' ;
    rdfs:comment 'Number of hours before the SLA deadline at which an alert or escalation should be triggered if the order is not yet fulfilled. Used for proactive SLA risk management.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold Percentage' ;
    rdfs:comment 'Percentage of the total SLA time window at which an alert should be triggered (e.g., 80% means alert when 80% of allowed time has elapsed). Alternative to breach_threshold_hours.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Carrier Cutoff Time' ;
    rdfs:comment 'Daily cutoff time (HH:MM in 24-hour format, local node time) by which orders must be ready for carrier pickup to meet the SLA. Null if not applicable.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting any regulatory, contractual, or business policy requirements that govern this SLA rule (e.g., \'Required by premium membership terms\', \'State law mandates 24-hour BOPIS readiness\').' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRule rdf:type rdf:Property ;
    rdfs:label 'Escalation Rule' ;
    rdfs:comment 'Business rule or workflow identifier defining what actions to take when SLA breach risk is detected (e.g., \'NOTIFY_STORE_MANAGER\', \'REROUTE_TO_ALTERNATE_NODE\', \'UPGRADE_CARRIER_SERVICE\').' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excludedDates rdf:type rdf:Property ;
    rdfs:label 'Excluded Dates' ;
    rdfs:comment 'Comma-separated list of specific dates (YYYY-MM-DD format) on which this SLA rule does not apply (e.g., peak season blackout dates, facility closures).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderChannel rdf:type rdf:Property ;
    rdfs:label 'Order Channel' ;
    rdfs:comment 'The sales channel through which the order was placed: web, mobile app, in-store, call center, marketplace, or social commerce.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Order Cutoff Time' ;
    rdfs:comment 'Daily cutoff time (HH:MM in 24-hour format, local node time) by which orders must be placed to qualify for this SLA (e.g., same-day delivery cutoff at 14:00). Null if no order cutoff applies.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderValueMax rdf:type rdf:Property ;
    rdfs:label 'Order Value Max' ;
    rdfs:comment 'Maximum order total amount (in currency_code) for which this SLA applies. Null if no maximum order value threshold exists.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderValueMin rdf:type rdf:Property ;
    rdfs:label 'Order Value Min' ;
    rdfs:comment 'Minimum order total amount (in currency_code) required for this SLA to apply. Null if no minimum order value threshold exists.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postalCodePattern rdf:type rdf:Property ;
    rdfs:label 'Postal Code Pattern' ;
    rdfs:comment 'Regex pattern or prefix defining the postal/ZIP codes this SLA applies to (e.g., \'^90[0-9]{3}$\' for Los Angeles area). Null if SLA is not postal-code-specific.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedHoursToDeliver rdf:type rdf:Property ;
    rdfs:label 'Promised Hours To Deliver' ;
    rdfs:comment 'Total number of hours from order placement to final delivery to the customer. Used for end-to-end delivery SLAs (same-day, next-day, standard ground).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promisedHoursToReady rdf:type rdf:Property ;
    rdfs:label 'Promised Hours To Ready' ;
    rdfs:comment 'Number of hours from order placement to when the order must be ready for customer pickup (for BOPIS/ROPIS) or ready for carrier pickup (for ship-from-store). Null if not applicable to this SLA type.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promisedHoursToShip rdf:type rdf:Property ;
    rdfs:label 'Promised Hours To Ship' ;
    rdfs:comment 'Number of hours from order placement to when the shipment must be handed off to the carrier. Applies to ship-to-home and ship-from-store fulfillment methods.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaCode rdf:type rdf:Property ;
    rdfs:label 'Sla Code' ;
    rdfs:comment 'Business-readable unique code identifying this SLA rule (e.g., BOPIS_2HR, SAMEDAY_SHIP, NEXTDAY_DEL).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaName rdf:type rdf:Property ;
    rdfs:label 'Sla Name' ;
    rdfs:comment 'Human-readable descriptive name of the SLA rule (e.g., \'Buy Online Pick Up In Store - 2 Hour Ready\', \'Same-Day Shipping Cutoff\').' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Category of SLA commitment: BOPIS readiness, ROPIS readiness, same-day ship cutoff, next-day delivery, standard ground, express delivery, or ship-from-store. [ENUM-REF-CANDIDATE: BOPIS_READINESS|ROPIS_READINESS|SAME_DAY_SHIP|NEXT_DAY_DELIVERY|STANDARD_GROUND|EXPRESS_DELIVERY|SHIP_FROM_STORE — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseRateAmount rdf:type rdf:Property ;
    rdfs:label 'Base Rate Amount' ;
    rdfs:comment 'Base shipping rate amount before surcharges and discounts. This is the starting point for freight cost calculation.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the shipment destination (e.g., USA, CAN, MEX).' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code' ;
    rdfs:comment 'Postal code of the shipment destination (customer delivery address).' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargeRate rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Rate' ;
    rdfs:comment 'Fuel surcharge rate expressed as a decimal percentage (e.g., 0.1250 for 12.50%). Applied to base rate to account for fuel cost fluctuations.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHazmatEligible rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Eligible' ;
    rdfs:comment 'Flag indicating whether this carrier service level can handle hazardous materials shipments under applicable regulations.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInternational rdf:type rdf:Property ;
    rdfs:label 'Is International' ;
    rdfs:comment 'Flag indicating whether this rate applies to international shipments (cross-border) or domestic shipments within a single country.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge Amount' ;
    rdfs:comment 'Minimum shipping charge that will be applied regardless of calculated rate. Ensures carrier covers base handling costs.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the shipment origin (e.g., USA, CAN, MEX).' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originPostalCode rdf:type rdf:Property ;
    rdfs:label 'Origin Postal Code' ;
    rdfs:comment 'Postal code of the shipment origin location (fulfillment center, store, or warehouse).' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oversizedPackageSurcharge rdf:type rdf:Property ;
    rdfs:label 'Oversized Package Surcharge' ;
    rdfs:comment 'Additional fee for packages exceeding standard size limits (length + girth thresholds vary by carrier).' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratePerKg rdf:type rdf:Property ;
    rdfs:label 'Rate Per Kg' ;
    rdfs:comment 'Incremental rate charged per kilogram above the weight break minimum. Used for weight-based pricing calculations.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateSource rdf:type rdf:Property ;
    rdfs:label 'Rate Source' ;
    rdfs:comment 'Source system or method by which this rate was obtained: carrier API (real-time), manual entry, contract upload, rate shopping engine, or third-party logistics provider.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of the carrier rate: active (in use), inactive (not in use), pending (awaiting activation), expired (past expiry date), suspended (temporarily disabled).' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the rate: base (standard published rate), negotiated (custom contract rate), published (carrier list price), spot (one-time rate), or contract (long-term agreement rate).' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateVersion rdf:type rdf:Property ;
    rdfs:label 'Rate Version' ;
    rdfs:comment 'Version number of this rate record. Incremented when rate terms are updated, enabling rate history tracking and audit trails.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateZone rdf:type rdf:Property ;
    rdfs:label 'Rate Zone' ;
    rdfs:comment 'Geographic zone or region for which this rate applies. Carriers use zone-based pricing to calculate shipping costs based on origin and destination distance.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saturdayDeliverySurcharge rdf:type rdf:Property ;
    rdfs:label 'Saturday Delivery Surcharge' ;
    rdfs:comment 'Additional fee for Saturday delivery service, which is outside standard weekday delivery schedules.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Type of shipping service offered by the carrier (e.g., ground, express, overnight, two-day, economy, priority, standard). [ENUM-REF-CANDIDATE: ground|express|overnight|two_day|economy|priority|standard — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureRequiredSurcharge rdf:type rdf:Property ;
    rdfs:label 'Signature Required Surcharge' ;
    rdfs:comment 'Additional fee charged when signature confirmation is required upon delivery.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitDays rdf:type rdf:Property ;
    rdfs:label 'Transit Days' ;
    rdfs:comment 'Expected number of business days for shipment transit from origin to destination using this service level.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightBreakMaxKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Max Kg' ;
    rdfs:comment 'Maximum weight in kilograms for this rate tier. Null indicates no upper limit for the highest tier.' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBreakMinKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Min Kg' ;
    rdfs:comment 'Minimum weight in kilograms for this rate tier. Carriers use weight breaks to define tiered pricing (e.g., 0-5kg, 5-10kg, 10-20kg).' ;
    rdfs:domain ind:CarrierRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentPromoCampaignId rdf:type rdf:Property ;
    rdfs:label 'Parent Promo Campaign Id' ;
    rdfs:comment 'Self-referencing FK on promo_campaign (parent_promo_campaign_id)' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoCampaign .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Total allocated budget for the promotional campaign including discounts, advertising, and operational costs.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the campaign budget amount.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Externally-known unique business identifier for the campaign used across systems and communications.' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignDescription rdf:type rdf:Property ;
    rdfs:label 'Campaign Description' ;
    rdfs:comment 'Detailed description of the campaign objectives, target audience, and promotional strategy.' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Human-readable name of the promotional campaign for business user identification and reporting.' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the promotional campaign by strategic purpose and funding model.' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelScope rdf:type rdf:Property ;
    rdfs:label 'Channel Scope' ;
    rdfs:comment 'Distribution channels where the promotional campaign is active (omnichannel, in-store, e-commerce, mobile).' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circularAdFlag rdf:type rdf:Property ;
    rdfs:label 'Circular Ad Flag' ;
    rdfs:comment 'Indicates whether the campaign is featured in printed or digital circular advertisements.' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:digitalPromotionFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Promotion Flag' ;
    rdfs:comment 'Indicates whether the campaign includes digital promotions delivered via e-commerce, mobile app, or email.' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountStrategy rdf:type rdf:Property ;
    rdfs:label 'Discount Strategy' ;
    rdfs:comment 'Primary discount mechanism used in the campaign (percentage off, fixed amount, BOGO, bundle pricing, tiered discounts, rebate).' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventClassification rdf:type rdf:Property ;
    rdfs:label 'Event Classification' ;
    rdfs:comment 'Specific promotional event type within the campaign (e.g., Flash Sale, Doorbuster, BOGO). [ENUM-REF-CANDIDATE: flash_sale|doorbuster|holiday_sale|weekly_circular|bogo|markdown|rebate — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyExclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Loyalty Exclusive Flag' ;
    rdfs:comment 'Indicates whether the campaign offers are exclusive to loyalty program members.' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Email' ;
    rdfs:comment 'Email address of the campaign owner for communication and escalation.' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Name of the marketing manager or business owner responsible for the campaign execution and performance.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoCampaignStatus rdf:type rdf:Property ;
    rdfs:label 'Promo Campaign Status' ;
    rdfs:comment 'Current lifecycle status of the promotional campaign.' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCustomerReach rdf:type rdf:Property ;
    rdfs:label 'Target Customer Reach' ;
    rdfs:comment 'Number of unique customers the campaign aims to reach or engage.' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetRevenue rdf:type rdf:Property ;
    rdfs:label 'Target Revenue' ;
    rdfs:comment 'Expected revenue target for the promotional campaign period.' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetUnitsSold rdf:type rdf:Property ;
    rdfs:label 'Target Units Sold' ;
    rdfs:comment 'Target number of units expected to be sold during the promotional campaign.' ;
    rdfs:domain ind:PromoCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorFundedFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Funded Flag' ;
    rdfs:comment 'Indicates whether the promotional campaign is partially or fully funded by vendor cooperative marketing agreements.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:activationTrigger rdf:type rdf:Property ;
    rdfs:label 'Activation Trigger' ;
    rdfs:comment 'Event or condition that activates this offer for a customer. manual = customer enters code; cart_threshold = automatically applied when cart meets criteria; login = activated upon customer login; geofence = triggered by location; time_based = activated at specific time; event_based = triggered by business event.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelEligibility rdf:type rdf:Property ;
    rdfs:label 'Channel Eligibility' ;
    rdfs:comment 'Sales channels where this offer is valid. POS = in-store Point of Sale; ecommerce = online web storefront; mobile = mobile app; BOPIS = Buy Online Pick Up In Store; ROPIS = Reserve Online Pick Up In Store; all_channels = valid across all channels. [ENUM-REF-CANDIDATE: POS|ecommerce|mobile|BOPIS|ROPIS|call_center|kiosk — promote to reference product]' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Share Percentage' ;
    rdfs:comment 'Percentage of promotional discount cost borne by the vendor (0-100). Null if not applicable or fully retailer-funded.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Delivery Flag' ;
    rdfs:comment 'Indicates whether this offer is delivered digitally (e.g., via email, mobile app push notification, personalized web banner). True = digital delivery; False = traditional circular/print or in-store signage only.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayMessage rdf:type rdf:Property ;
    rdfs:label 'Display Message' ;
    rdfs:comment 'Customer-facing promotional message displayed at Point of Sale (POS), e-commerce checkout, and mobile app. Concise marketing copy highlighting the offer value.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndTime rdf:type rdf:Property ;
    rdfs:label 'Effective End Time' ;
    rdfs:comment 'Precise timestamp when this promotional offer expires, supporting time-of-day specific promotions. Null indicates no specific end time constraint.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveStartTime rdf:type rdf:Property ;
    rdfs:label 'Effective Start Time' ;
    rdfs:comment 'Precise timestamp when this promotional offer becomes active, supporting time-of-day specific promotions (e.g., happy hour deals, flash sales).' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:jurisdictionRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Restriction Flag' ;
    rdfs:comment 'Indicates whether this offer has jurisdiction-specific restrictions (e.g., state-level promotional laws, EU consumer protection price display requirements). True = restrictions apply; False = no jurisdiction restrictions.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumRedemptionPerCustomer rdf:type rdf:Property ;
    rdfs:label 'Maximum Redemption Per Customer' ;
    rdfs:comment 'Maximum number of times a single customer can redeem this offer. Null indicates unlimited redemptions per customer.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumRedemptionTotal rdf:type rdf:Property ;
    rdfs:label 'Maximum Redemption Total' ;
    rdfs:comment 'Maximum total number of redemptions allowed across all customers for this offer. Null indicates unlimited total redemptions.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumPurchaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Purchase Quantity' ;
    rdfs:comment 'Minimum quantity of eligible items required to qualify for this promotional offer. Null if no quantity threshold applies.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerPriority rdf:type rdf:Property ;
    rdfs:label 'Offer Priority' ;
    rdfs:comment 'Priority ranking for offer application when multiple offers are eligible. Lower numbers indicate higher priority. Used by Point of Sale (POS) and e-commerce checkout engines to resolve offer conflicts.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:personalizationFlag rdf:type rdf:Property ;
    rdfs:label 'Personalization Flag' ;
    rdfs:comment 'Indicates whether this offer is personalized to individual customers based on purchase history, preferences, or predictive analytics. True = personalized; False = mass-market offer.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productEligibilityScope rdf:type rdf:Property ;
    rdfs:label 'Product Eligibility Scope' ;
    rdfs:comment 'Defines which products are eligible for this offer. all_products = applies to entire catalog; category = applies to specific product categories; SKU_list = applies to specific Stock Keeping Units (SKUs); brand = applies to specific brands; excluded_products = applies to all products except specified exclusions.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedJurisdictions rdf:type rdf:Property ;
    rdfs:label 'Restricted Jurisdictions' ;
    rdfs:comment 'Comma-separated list of jurisdiction codes (ISO 3166-1 alpha-3 country codes or state/province codes) where this offer is restricted or prohibited due to regulatory compliance requirements. Null if no restrictions.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeEligibilityScope rdf:type rdf:Property ;
    rdfs:label 'Store Eligibility Scope' ;
    rdfs:comment 'Defines the scope of store eligibility for this offer. all_stores = valid at all retail locations; store_group = valid at a defined group of stores; individual_store = valid at specific stores only; excluded_stores = valid everywhere except specified stores.' ;
    rdfs:domain ind:PromoOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'UPC or EAN barcode number for physical coupon scanning at POS. May be 12-digit UPC-A or 13-digit EAN format.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponCode rdf:type rdf:Property ;
    rdfs:label 'Coupon Code' ;
    rdfs:comment 'Alphanumeric code that customers enter or scan to redeem the coupon. Unique business identifier for the coupon across all channels.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponStatus rdf:type rdf:Property ;
    rdfs:label 'Coupon Status' ;
    rdfs:comment 'Current lifecycle state of the coupon. active means available for redemption, inactive means not yet released, expired means past expiration_date, suspended means temporarily disabled, redeemed means fully used (for single-use coupons).' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponType rdf:type rdf:Property ;
    rdfs:label 'Coupon Type' ;
    rdfs:comment 'Classification of coupon by issuing authority and format. Manufacturer coupons are vendor-funded, store coupons are retailer-funded, digital coupons are app/email-based, paper coupons are physical print, loyalty coupons are tied to loyalty programs, vendor_funded are supplier co-op promotions.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalDistributionQuantity rdf:type rdf:Property ;
    rdfs:label 'Digital Distribution Quantity' ;
    rdfs:comment 'Total number of digital coupon codes issued via email, app, or SMS. Null for paper-only coupons.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:digitalWalletEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Wallet Enabled Flag' ;
    rdfs:comment 'Indicates whether this coupon can be stored in a digital wallet (mobile app, Apple Wallet, Google Pay) for redemption (True) or is paper-only (False).' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleChannel rdf:type rdf:Property ;
    rdfs:label 'Eligible Channel' ;
    rdfs:comment 'Sales channels where the coupon can be redeemed. all_channels means omnichannel, pos is in-store only, ecommerce is online only, mobile_app is app-only, bopis is buy-online-pickup-in-store.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleProductScope rdf:type rdf:Property ;
    rdfs:label 'Eligible Product Scope' ;
    rdfs:comment 'Defines the breadth of products to which the coupon applies. all_products means store-wide, category restricts to a product category, brand restricts to a specific brand, sku restricts to specific SKUs, basket applies to entire cart total.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionList rdf:type rdf:Property ;
    rdfs:label 'Exclusion List' ;
    rdfs:comment 'Comma-separated list of product SKUs, categories, or brands explicitly excluded from coupon eligibility. Null if no exclusions apply.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faceValue rdf:type rdf:Property ;
    rdfs:label 'Face Value' ;
    rdfs:comment 'Nominal discount value of the coupon. For fixed_amount coupons, this is the dollar discount. For percentage coupons, this is the percentage (e.g., 15.00 for 15% off). For BOGO, may represent the value of the free item.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issueChannel rdf:type rdf:Property ;
    rdfs:label 'Issue Channel' ;
    rdfs:comment 'Distribution channel through which the coupon was issued to customers. Circular refers to weekly print ads, mobile_app and email are digital channels, in_store_kiosk is physical print at store, website is online portal, social_media includes Facebook/Instagram ads, direct_mail is postal delivery, SMS is text message. [ENUM-REF-CANDIDATE: circular|mobile_app|email|in_store_kiosk|website|social_media|direct_mail|sms — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date on which the coupon was first made available to customers. Marks the start of the coupons validity window.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Entity responsible for funding and issuing the coupon. Retailer indicates store-funded, manufacturer indicates vendor-funded, vendor indicates supplier co-op, third_party indicates external promotion partner.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printQuantity rdf:type rdf:Property ;
    rdfs:label 'Print Quantity' ;
    rdfs:comment 'Total number of physical paper coupons printed for distribution. Null for digital-only coupons.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionLimitPerCustomer rdf:type rdf:Property ;
    rdfs:label 'Redemption Limit Per Customer' ;
    rdfs:comment 'Maximum number of times a single customer can redeem this coupon. Null or 0 indicates unlimited redemptions per customer.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:singleUseFlag rdf:type rdf:Property ;
    rdfs:label 'Single Use Flag' ;
    rdfs:comment 'Indicates whether the coupon can only be used once (True) or multiple times (False) by the same customer, subject to redemption_limit_per_customer.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalRedemptionLimit rdf:type rdf:Property ;
    rdfs:label 'Total Redemption Limit' ;
    rdfs:comment 'Maximum total number of redemptions allowed across all customers for this coupon. Null or 0 indicates unlimited total redemptions.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rebateId rdf:type rdf:Property ;
    rdfs:label 'Rebate Id' ;
    rdfs:comment 'Unique identifier for the rebate program. Primary key.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rebate .

ind:exclusionProductList rdf:type rdf:Property ;
    rdfs:label 'Exclusion Product List' ;
    rdfs:comment 'Comma-separated list of Stock Keeping Unit (SKU) codes or product categories explicitly excluded from the rebate program.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicEligibility rdf:type rdf:Property ;
    rdfs:label 'Geographic Eligibility' ;
    rdfs:comment 'Comma-separated list of three-letter ISO country codes or region codes where the rebate is valid (e.g., USA, CAN, GBR). Null if available in all operating regions.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumRebateAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Rebate Amount' ;
    rdfs:comment 'Cap on the total rebate value that can be claimed per transaction or per customer. Null if no cap applies.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentProcessingDays rdf:type rdf:Property ;
    rdfs:label 'Payment Processing Days' ;
    rdfs:comment 'Expected number of business days from rebate approval to payment issuance. Used for customer Service Level Agreement (SLA) communication.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingProductList rdf:type rdf:Property ;
    rdfs:label 'Qualifying Product List' ;
    rdfs:comment 'Comma-separated list of Stock Keeping Unit (SKU) codes, Universal Product Code (UPC) numbers, or product category codes that qualify for the rebate. Null if rebate applies to all products.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateDescription rdf:type rdf:Property ;
    rdfs:label 'Rebate Description' ;
    rdfs:comment 'Detailed internal description of the rebate program purpose, target audience, and business objectives. Used for internal planning and reporting.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateName rdf:type rdf:Property ;
    rdfs:label 'Rebate Name' ;
    rdfs:comment 'Marketing name of the rebate program displayed to customers and used in promotional materials.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateNumber rdf:type rdf:Property ;
    rdfs:label 'Rebate Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the rebate program, used in customer communications and vendor agreements.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateStatus rdf:type rdf:Property ;
    rdfs:label 'Rebate Status' ;
    rdfs:comment 'Current lifecycle state of the rebate program: draft (being configured), active (live and accepting submissions), paused (temporarily suspended), expired (past end date), cancelled (terminated early), or completed (ended successfully).' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateType rdf:type rdf:Property ;
    rdfs:label 'Rebate Type' ;
    rdfs:comment 'Classification of the rebate mechanism: instant rebate (applied at Point of Sale), mail-in rebate (customer submits proof of purchase), vendor-funded rebate (supplier-sponsored), digital rebate (online redemption), promotional allowance (trade promotion), or volume rebate (quantity-based incentive).' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionLimitPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Redemption Limit Per Transaction' ;
    rdfs:comment 'Maximum number of rebate instances that can be applied in a single transaction. Null if no limit applies.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresProofOfPurchase rdf:type rdf:Property ;
    rdfs:label 'Requires Proof Of Purchase' ;
    rdfs:comment 'Indicates whether customers must submit receipt or purchase documentation to claim the rebate. True for mail-in rebates, false for instant rebates applied at Point of Sale.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stackableWithOtherPromotions rdf:type rdf:Property ;
    rdfs:label 'Stackable With Other Promotions' ;
    rdfs:comment 'Indicates whether this rebate can be combined with other promotional offers (coupons, markdowns, Buy One Get One (BOGO) deals) in the same transaction.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline Date' ;
    rdfs:comment 'Final date by which customers must submit rebate claims for purchases made during the effective period. Typically extends beyond the effective end date for mail-in rebates.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Budget Amount' ;
    rdfs:comment 'Total financial budget allocated for the rebate program. Used for cost control and Return on Investment (ROI) tracking. Null if budget is uncapped.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorFundingPercentage rdf:type rdf:Property ;
    rdfs:label 'Vendor Funding Percentage' ;
    rdfs:comment 'Percentage of the rebate cost funded by the vendor in co-op promotional agreements (e.g., 75.00 means vendor pays 75%, retailer pays 25%). Null for fully retailer-funded rebates.' ;
    rdfs:domain ind:Rebate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorPromoAgreementId rdf:type rdf:Property ;
    rdfs:label 'Vendor Promo Agreement Id' ;
    rdfs:comment 'Unique identifier for the vendor-funded promotional agreement record. Primary key.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorPromoAgreement .

ind:accrualMethod rdf:type rdf:Property ;
    rdfs:label 'Accrual Method' ;
    rdfs:comment 'Method used to calculate promotional funding accrual. Purchase-based: accrues on retailer purchase volume. Sales-based: accrues on consumer sales (scan data). Display-based: accrues on compliance with display requirements. Hybrid: combination of methods.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adPlacementRequired rdf:type rdf:Property ;
    rdfs:label 'Ad Placement Required' ;
    rdfs:comment 'Indicates whether the retailer must feature the product in circular ads, digital promotions, or other marketing materials to qualify for co-op advertising funding.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargebackPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Penalty Amount' ;
    rdfs:comment 'Fixed monetary penalty amount per chargeback incident for vendor non-compliance, in the agreement currency. Nullable if chargeback is not eligible or penalty is variable.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the signed legal contract or agreement document stored in the document management system.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Display Compliance Required' ;
    rdfs:comment 'Indicates whether the retailer must meet specific in-store display requirements (endcap placement, planogram compliance, shelf positioning) to qualify for funding.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fundingAmount rdf:type rdf:Property ;
    rdfs:label 'Funding Amount' ;
    rdfs:comment 'Total monetary value of vendor promotional funding committed under this agreement, in the agreement currency.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Funding Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the funding amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingPercentage rdf:type rdf:Property ;
    rdfs:label 'Funding Percentage' ;
    rdfs:comment 'Percentage of qualifying costs or sales that the vendor will fund, expressed as a decimal (e.g., 15.00 for 15%). Used for co-op advertising and scan-based allowances.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceObligationDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Description' ;
    rdfs:comment 'Detailed narrative of the retailer\'s obligations under this agreement, including display requirements, advertising commitments, volume targets, and reporting duties.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingProductScope rdf:type rdf:Property ;
    rdfs:label 'Qualifying Product Scope' ;
    rdfs:comment 'Defines which products are eligible for promotional funding under this agreement. Specific SKU: single item. Product category: all items in a category. Brand: all items of a vendor brand. Private label: retailer-branded items.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Frequency' ;
    rdfs:comment 'Frequency at which funding settlements or accruals are processed under this agreement.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTerms rdf:type rdf:Property ;
    rdfs:label 'Settlement Terms' ;
    rdfs:comment 'Defines how and when the vendor funding will be paid or credited. Upfront credit: applied at purchase. Monthly accrual: credited monthly. Quarterly settlement: paid quarterly. Post-event claim: retailer submits claim after promotion ends. Scan-based settlement: paid based on POS scan data.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Explanation for early termination of the agreement, such as vendor non-compliance, retailer strategic change, or mutual agreement. Nullable if not terminated.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAccruedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Accrued Amount' ;
    rdfs:comment 'Cumulative amount of promotional funding accrued to date under this agreement, in the agreement currency. Updated as qualifying events occur.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSettledAmount rdf:type rdf:Property ;
    rdfs:label 'Total Settled Amount' ;
    rdfs:comment 'Cumulative amount of promotional funding that has been paid or credited to the retailer to date, in the agreement currency.' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorPromoAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Promo Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the promotional agreement. Draft: under negotiation. Pending approval: awaiting internal sign-off. Active: in effect and accruing. Suspended: temporarily paused. Completed: ended normally. Terminated: ended early. Settled: financially reconciled. [ENUM-REF-CANDIDATE: draft|pending approval|active|suspended|completed|terminated|settled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorPromoAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Promo Redemption Id' ;
    rdfs:comment 'Unique identifier for each promotional offer redemption instance. Primary key for the promo_redemption product.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoRedemption .

ind:processingSystem rdf:type rdf:Property ;
    rdfs:label 'Processing System' ;
    rdfs:comment 'The system or platform that processed and validated the promotion redemption. Identifies the source system for audit and reconciliation purposes.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionTier rdf:type rdf:Property ;
    rdfs:label 'Promotion Tier' ;
    rdfs:comment 'The tier or level of the promotion when tiered discount structures are used (e.g., spend $50 get 10% off, spend $100 get 20% off). Indicates which threshold was achieved.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRedeemed rdf:type rdf:Property ;
    rdfs:label 'Quantity Redeemed' ;
    rdfs:comment 'The number of units or items to which the promotion was applied. For BOGO offers, represents the number of qualifying item sets. For single-item discounts, typically 1.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionChannel rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel' ;
    rdfs:comment 'The sales channel through which the promotion was redeemed. Distinguishes between in-store POS, e-commerce platforms, mobile apps, and other customer touchpoints.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionLimitType rdf:type rdf:Property ;
    rdfs:label 'Redemption Limit Type' ;
    rdfs:comment 'The scope of redemption limits enforced for this promotion. Indicates whether limits apply per customer, per transaction, per day, or across the entire campaign period.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionMechanism rdf:type rdf:Property ;
    rdfs:label 'Redemption Mechanism' ;
    rdfs:comment 'Method by which the promotion was applied to the transaction. Indicates whether the discount was automatically triggered by system rules, manually entered via coupon code, applied through loyalty program, or activated through other channels. [ENUM-REF-CANDIDATE: automatic_system_triggered|coupon_code_entry|loyalty_auto_apply|cart_rule|manual_cashier_apply|mobile_app_clip|digital_wallet — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Redemption Sequence Number' ;
    rdfs:comment 'The sequential count of this redemption within the applicable limit scope. For example, if limit is per_customer, this tracks which redemption number this is for that customer (1st, 2nd, 3rd, etc.).' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stackSequence rdf:type rdf:Property ;
    rdfs:label 'Stack Sequence' ;
    rdfs:comment 'The order in which this promotion was applied within a stacked promotion scenario. Determines calculation precedence when multiple discounts are layered.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationErrorCode rdf:type rdf:Property ;
    rdfs:label 'Validation Error Code' ;
    rdfs:comment 'System error code returned when a redemption attempt fails validation. Provides technical detail for troubleshooting invalid redemptions. Null for successful redemptions.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Validation Error Message' ;
    rdfs:comment 'Human-readable error message explaining why a redemption was rejected. Displayed to customers or cashiers. Null for successful redemptions.' ;
    rdfs:domain ind:PromoRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoBudgetId rdf:type rdf:Property ;
    rdfs:label 'Promo Budget Id' ;
    rdfs:comment 'Unique identifier for the promotional budget record. Primary key for the promotional budget master data.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financeCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Finance Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Promotion budgets are allocated to finance cost centers for accounting and budget tracking. The cost_center_code column becomes redundant as it can be joined from finance.cost_center. This links promo' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:actualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Amount' ;
    rdfs:comment 'Cumulative actual spend to date against this promotional budget, including all posted promotional costs, markdowns, vendor co-op claims, and advertising expenses. Updated in real-time as promotional transactions are processed.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetOwnerType rdf:type rdf:Property ;
    rdfs:label 'Budget Owner Type' ;
    rdfs:comment 'Classification of the organizational unit responsible for managing and executing this promotional budget. Department indicates merchandising department ownership; category indicates product category team ownership; brand indicates brand management team ownership; channel indicates channel-specific ownership (e-commerce, stores); region indicates geographic region ownership; store cluster indicates store group ownership.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the promotional budget source and purpose. Internal marketing budgets are company-funded campaigns; vendor co-op budgets are supplier-funded promotional agreements; markdown allowance budgets cover planned price reductions; clearance reserve budgets are set aside for end-of-season inventory liquidation; trade promotion budgets support B2B channel incentives; digital advertising budgets fund online and mobile promotional campaigns.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circularAdAllocation rdf:type rdf:Property ;
    rdfs:label 'Circular Ad Allocation' ;
    rdfs:comment 'Portion of the total budget allocated specifically for circular advertising and weekly ad production, including print circulars, digital circulars, and featured promotional items in weekly ad campaigns.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mobileChannelAllocation rdf:type rdf:Property ;
    rdfs:label 'Mobile Channel Allocation' ;
    rdfs:comment 'Portion of the total budget allocated specifically for mobile app promotional activities, including app-exclusive offers, push notification campaigns, and mobile wallet coupons. Supports omnichannel budget planning and mobile channel ROI tracking.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otbIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Otb Integration Flag' ;
    rdfs:comment 'Boolean indicator of whether this promotional budget is integrated with the Open to Buy (OTB) merchandise planning system. When true, promotional markdowns and clearance budgets are factored into inventory purchasing decisions and margin planning.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Spend Amount' ;
    rdfs:comment 'Total planned or forecasted spend amount for the promotional budget based on campaign planning and historical performance. May be less than or equal to total budget amount, representing the expected utilization.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:posChannelAllocation rdf:type rdf:Property ;
    rdfs:label 'Pos Channel Allocation' ;
    rdfs:comment 'Portion of the total budget allocated specifically for in-store point-of-sale promotional activities, including store markdowns, in-store coupons, and physical promotional displays. Supports omnichannel budget planning and channel-specific ROI tracking.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Budget Amount' ;
    rdfs:comment 'Available budget remaining for new promotional activities, calculated as total budget amount minus actual spend amount minus committed amount. Represents the unallocated budget available for additional promotional planning.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Amount' ;
    rdfs:comment 'Absolute amount threshold for budget variance alerts. When actual spend deviates from planned spend by more than this amount, automated alerts are triggered to budget owners and finance teams. Used in conjunction with or as an alternative to percentage-based thresholds.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percent' ;
    rdfs:comment 'Percentage threshold for budget variance alerts. When actual spend deviates from planned spend by more than this percentage, automated alerts are triggered to budget owners and finance teams. Typical values range from 5% to 20%.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorFundedAmount rdf:type rdf:Property ;
    rdfs:label 'Vendor Funded Amount' ;
    rdfs:comment 'Portion of the total budget that is funded by vendor co-op agreements, trade promotion allowances, or supplier marketing development funds. Represents external funding contribution to the promotional budget.' ;
    rdfs:domain ind:PromoBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableBannerCodes rdf:type rdf:Property ;
    rdfs:label 'Applicable Banner Codes' ;
    rdfs:comment 'Comma-separated list of banner codes to which this promotional period applies. Populated only when banner_applicability is \'banner_specific\'.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableMarketCodes rdf:type rdf:Property ;
    rdfs:label 'Applicable Market Codes' ;
    rdfs:comment 'Comma-separated list of market or region codes to which this promotional period applies. Populated when market_applicability is \'regional\' or \'local\'.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Name of the executive or manager who approved this promotional calendar period.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bannerApplicability rdf:type rdf:Property ;
    rdfs:label 'Banner Applicability' ;
    rdfs:comment 'Indicates whether this promotional period applies across all retail banners (enterprise-wide) or is specific to individual banners (banner-specific). Supports multi-banner coordination.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutReason rdf:type rdf:Property ;
    rdfs:label 'Blackout Reason' ;
    rdfs:comment 'Business justification for why this period is designated as a promotional blackout (e.g., inventory transition, system maintenance, post-holiday recovery).' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circularProductionDeadline rdf:type rdf:Property ;
    rdfs:label 'Circular Production Deadline' ;
    rdfs:comment 'The deadline by which all promotional circular materials (print ads, digital circulars) must be finalized for production and distribution.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitiveResponseFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Response Flag' ;
    rdfs:comment 'Indicates whether this promotional period was created as a competitive response to rival retailer promotions (true) or is part of the planned calendar (false).' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitiveTriggerDescription rdf:type rdf:Property ;
    rdfs:label 'Competitive Trigger Description' ;
    rdfs:comment 'Description of the competitive market event or rival promotion that triggered this promotional period. Populated when competitive_response_flag is true.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedSalesLiftPct rdf:type rdf:Property ;
    rdfs:label 'Expected Sales Lift Pct' ;
    rdfs:comment 'Forecasted percentage increase in sales revenue expected during this promotional period compared to baseline or prior year.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedTrafficLiftPct rdf:type rdf:Property ;
    rdfs:label 'Expected Traffic Lift Pct' ;
    rdfs:comment 'Forecasted percentage increase in customer traffic (footfall and digital visits) expected during this promotional period compared to baseline.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryBuildStartDate rdf:type rdf:Property ;
    rdfs:label 'Inventory Build Start Date' ;
    rdfs:comment 'The date when inventory positioning and build-up for this promotional period should begin to ensure adequate stock levels.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isBlackoutPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Blackout Period' ;
    rdfs:comment 'Flag indicating whether this period is a promotional blackout window where no new promotions should be launched (true) or a normal promotional period (false).' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketApplicability rdf:type rdf:Property ;
    rdfs:label 'Market Applicability' ;
    rdfs:comment 'Geographic scope of the promotional period indicating whether it applies nationally, regionally, or to specific local markets.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningLockDate rdf:type rdf:Property ;
    rdfs:label 'Planning Lock Date' ;
    rdfs:comment 'The date by which all promotional planning for this period must be finalized and locked. After this date, changes require executive approval.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Planning Owner Email' ;
    rdfs:comment 'Email address of the planning owner for coordination and communication regarding this promotional period.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningOwnerName rdf:type rdf:Property ;
    rdfs:label 'Planning Owner Name' ;
    rdfs:comment 'Name of the merchandising or marketing manager responsible for planning and executing this promotional period.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningStatus rdf:type rdf:Property ;
    rdfs:label 'Planning Status' ;
    rdfs:comment 'Current lifecycle status of the promotional calendar period (draft - under development, locked - finalized for execution, active - currently running, archived - completed and historical).' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:themeDescription rdf:type rdf:Property ;
    rdfs:label 'Theme Description' ;
    rdfs:comment 'Marketing theme or creative concept for the promotional period (e.g., \'Summer Savings\', \'Holiday Gift Guide\', \'New Year New You\').' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorNegotiationDeadline rdf:type rdf:Property ;
    rdfs:label 'Vendor Negotiation Deadline' ;
    rdfs:comment 'The deadline by which all vendor-funded promotional agreements and co-op advertising commitments must be finalized.' ;
    rdfs:domain ind:PromoCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bondedWarehouseFlag rdf:type rdf:Property ;
    rdfs:label 'Bonded Warehouse Flag' ;
    rdfs:comment 'Indicates whether the facility is a customs-bonded warehouse authorized to store imported goods before duties and taxes are paid, enabling deferred duty payment and re-export options.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Business-assigned unique alphanumeric code for the facility used in operational systems, shipping documents, and cross-system integration. Typically 4-12 characters.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Facility Email Address' ;
    rdfs:comment 'Primary email address for the facility used for operational communications, appointment confirmations, and document exchange.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityManagerName rdf:type rdf:Property ;
    rdfs:label 'Facility Manager Name' ;
    rdfs:comment 'Full name of the facility manager or site director responsible for day-to-day operations and performance.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Official business name of the distribution center or fulfillment facility (e.g., \'Northeast Regional DC\', \'Manhattan MFC-01\').' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Facility Phone Number' ;
    rdfs:comment 'Primary contact phone number for the facility used for carrier coordination, supplier communication, and operational inquiries.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityStatus rdf:type rdf:Property ;
    rdfs:label 'Facility Status' ;
    rdfs:comment 'Current operational lifecycle status of the facility. Active facilities are fully operational; planned facilities are approved but not yet built; under construction facilities are being built; decommissioned facilities are permanently closed; temporarily closed facilities are inactive but may reopen; seasonal facilities operate only during peak periods.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the facility based on its primary operational purpose: regional DC (large-scale distribution), micro-fulfillment center (MFC for rapid e-commerce), dark store (fulfillment-only, no retail), cross-dock hub (transshipment), returns center (reverse logistics), or forward stocking location (FSL).' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundDockDoorCount rdf:type rdf:Property ;
    rdfs:label 'Inbound Dock Door Count' ;
    rdfs:comment 'Number of dock doors dedicated to inbound receiving operations from suppliers and carriers.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiration Date' ;
    rdfs:comment 'Date when the current facility lease agreement expires. Null for owned facilities. Used for lease renewal planning and financial forecasting.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date when the facility first became operational and began processing inventory and orders.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outboundDockDoorCount rdf:type rdf:Property ;
    rdfs:label 'Outbound Dock Door Count' ;
    rdfs:comment 'Number of dock doors dedicated to outbound shipping operations to stores, customers, or other facilities.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:owningRegionCode rdf:type rdf:Property ;
    rdfs:label 'Owning Region Code' ;
    rdfs:comment 'Business region or geographic division code that owns and manages this facility (e.g., \'NORTHEAST\', \'WEST\', \'CENTRAL\'). Used for organizational hierarchy and P&L reporting.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'Two-letter ISO 3166-2 subdivision code for the state, province, or region (e.g., \'CA\' for California, \'ON\' for Ontario).' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacityCubicFeet rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Cubic Feet' ;
    rdfs:comment 'Total volumetric storage capacity of the facility measured in cubic feet, accounting for vertical storage utilization.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCapacityPalletPositions rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Pallet Positions' ;
    rdfs:comment 'Maximum number of standard pallet positions available for inventory storage in racking and floor storage.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureZoneAmbientFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone Ambient Flag' ;
    rdfs:comment 'Indicates whether the facility has ambient temperature storage zones (room temperature, non-climate-controlled) for general merchandise.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureZoneChilledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone Chilled Flag' ;
    rdfs:comment 'Indicates whether the facility has refrigerated (chilled) storage zones typically maintained at 32-40°F for perishable goods like dairy and produce.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureZoneFrozenFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone Frozen Flag' ;
    rdfs:comment 'Indicates whether the facility has frozen storage zones typically maintained at 0°F or below for frozen foods and ice cream.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:twentyFourSevenOperationFlag rdf:type rdf:Property ;
    rdfs:label 'Twenty Four Seven Operation Flag' ;
    rdfs:comment 'Indicates whether the facility operates continuously 24 hours per day, 7 days per week to support high-volume or time-sensitive fulfillment requirements.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warehouseSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Warehouse Square Footage' ;
    rdfs:comment 'Square footage dedicated to warehouse operations including storage, picking, packing, and staging areas. Measured in square feet.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsInstanceCode rdf:type rdf:Property ;
    rdfs:label 'Wms Instance Code' ;
    rdfs:comment 'Identifier for the Manhattan WMS instance or system deployment that manages this facility\'s warehouse operations. Used for system integration and data routing.' ;
    rdfs:domain ind:DcFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aisleRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Aisle Range End' ;
    rdfs:comment 'Ending aisle identifier for the zone, defining the end of the physical aisle range contained within this zone for pick path optimization.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aisleRangeStart rdf:type rdf:Property ;
    rdfs:label 'Aisle Range Start' ;
    rdfs:comment 'Starting aisle identifier for the zone, defining the beginning of the physical aisle range contained within this zone for pick path optimization.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationType rdf:type rdf:Property ;
    rdfs:label 'Automation Type' ;
    rdfs:comment 'Level and type of automation deployed in the zone. ASRS = Automated Storage and Retrieval System, AMR = Autonomous Mobile Robot, AGV = Automated Guided Vehicle. [ENUM-REF-CANDIDATE: manual|conveyor|asrs|shuttle|amr|agv|robotic_pick — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeScanningRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Barcode Scanning Required Flag' ;
    rdfs:comment 'Indicates whether barcode scanning is mandatory for all inventory movements within the zone to ensure location accuracy and inventory integrity.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentOccupancyPct rdf:type rdf:Property ;
    rdfs:label 'Current Occupancy Pct' ;
    rdfs:comment 'Current space utilization percentage of the zone, calculated as occupied capacity divided by total capacity, used for capacity management and slotting decisions.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationCount rdf:type rdf:Property ;
    rdfs:label 'Location Count' ;
    rdfs:comment 'Total number of individual storage locations (bins, slots, shelves, pallet positions) contained within this zone for granular inventory tracking.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextScheduledCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Cycle Count Date' ;
    rdfs:comment 'Planned date for the next physical inventory cycle count in the zone, used for operational planning and resource scheduling.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pickMethod rdf:type rdf:Property ;
    rdfs:label 'Pick Method' ;
    rdfs:comment 'Primary order picking methodology used in the zone, determining workflow design and labor productivity metrics.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rackConfigurationType rdf:type rdf:Property ;
    rdfs:label 'Rack Configuration Type' ;
    rdfs:comment 'Type of racking system installed in the zone, determining storage density, accessibility, and material handling equipment requirements.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Replenishment Priority Rank' ;
    rdfs:comment 'Priority ranking for zone replenishment tasks, with lower numbers indicating higher priority for maintaining forward pick face availability.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Security classification of the zone determining access control requirements, used for high-value merchandise, controlled substances, or restricted inventory.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slottingStrategy rdf:type rdf:Property ;
    rdfs:label 'Slotting Strategy' ;
    rdfs:comment 'Inventory slotting methodology applied to the zone for optimizing pick efficiency, labor productivity, and space utilization.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureClassification rdf:type rdf:Property ;
    rdfs:label 'Temperature Classification' ;
    rdfs:comment 'Temperature control requirement for the zone, critical for grocery retail operations managing perishable goods and food safety compliance.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Celsius' ;
    rdfs:comment 'Maximum allowable temperature threshold for temperature-controlled zones, measured in degrees Celsius. Used for cold chain monitoring and food safety compliance.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Celsius' ;
    rdfs:comment 'Minimum allowable temperature threshold for temperature-controlled zones, measured in degrees Celsius. Used for cold chain monitoring and food safety compliance.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCapacityCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Cubic Meters' ;
    rdfs:comment 'Total volumetric storage capacity of the zone measured in cubic meters, used for space utilization analysis and capacity planning.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCapacityPalletPositions rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Pallet Positions' ;
    rdfs:comment 'Total number of standard pallet positions available in the zone, critical for slotting optimization and inventory capacity management.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Weight Capacity Kg' ;
    rdfs:comment 'Maximum weight capacity of the zone in kilograms, constrained by floor loading limits and rack weight ratings for safety compliance.' ;
    rdfs:domain ind:WarehouseZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originFacilityDcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Dc Facility Id' ;
    rdfs:comment 'Identifier of the originating facility for inter-facility transfers. Null for supplier-direct shipments.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:primaryInboundDcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Inbound Dc Facility Id' ;
    rdfs:comment 'Identifier of the distribution center or micro-fulfillment center receiving this shipment. Determines facility-specific receiving workflows and capacity planning.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:actualWeightKg rdf:type rdf:Property ;
    rdfs:label 'Actual Weight Kg' ;
    rdfs:comment 'Total actual weight of the shipment in kilograms as measured during receiving. Used for freight cost verification and variance analysis.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossDockFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Flag' ;
    rdfs:comment 'Indicates whether this shipment is designated for cross-docking operations, bypassing putaway and moving directly to outbound staging.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Timestamp' ;
    rdfs:comment 'Precise date and time the shipment is expected to arrive at the distribution center. Used for appointment scheduling and dock door allocation.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedCubeM3 rdf:type rdf:Property ;
    rdfs:label 'Expected Cube M3' ;
    rdfs:comment 'Total expected volume of the shipment in cubic meters. Used for warehouse space planning and transportation capacity optimization.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Amount' ;
    rdfs:comment 'Total freight transportation cost for this inbound shipment. Used for landed cost calculation and freight spend analysis.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the freight cost amount. Enables multi-currency freight cost tracking and consolidation.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateArrivalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Late Arrival Reason Code' ;
    rdfs:comment 'Standardized code explaining the reason for late arrival when on-time arrival flag is false. Used for root cause analysis and carrier accountability.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receiving Start Timestamp' ;
    rdfs:comment 'Date and time when receiving operations began for this shipment. Marks the start of unloading and inspection activities.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Classification of the inbound shipment based on origin and purpose. Determines receiving workflow and handling requirements.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Compliant Flag' ;
    rdfs:comment 'Indicates whether the shipment maintained required temperature throughout transit. False triggers quality inspection and potential rejection.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitVarianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Unit Variance Quantity' ;
    rdfs:comment 'Difference between shipped_qty and received_qty for this PO line on this shipment. A non-zero value triggers discrepancy resolution workflows (vendor chargebacks, shortage claims). Belongs to the intersection, not to either parent entity.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Unit Quantity' ;
    rdfs:comment 'The total number of individual units (eaches) physically received and verified during the receiving event.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cartonVarianceCount rdf:type rdf:Property ;
    rdfs:label 'Carton Variance Count' ;
    rdfs:comment 'The difference between expected and actual carton count (actual minus expected). Positive indicates overage, negative indicates shortage.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:damageFlag rdf:type rdf:Property ;
    rdfs:label 'Damage Flag' ;
    rdfs:comment 'Indicates whether any damaged goods were identified during the receiving event.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:damagedUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Damaged Unit Quantity' ;
    rdfs:comment 'The number of units identified as damaged during the receiving inspection.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discrepancyReasonCode rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Reason Code' ;
    rdfs:comment 'Code indicating the reason for any discrepancy between expected and actual quantities (e.g., supplier short ship, damaged in transit, incorrect ASN).' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Expected Unit Quantity' ;
    rdfs:comment 'The total number of individual units (eaches) expected to be received based on the advance shipment notice or purchase order.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overageFlag rdf:type rdf:Property ;
    rdfs:label 'Overage Flag' ;
    rdfs:comment 'Indicates whether the receiving event resulted in an overage (more units received than expected).' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:palletVarianceCount rdf:type rdf:Property ;
    rdfs:label 'Pallet Variance Count' ;
    rdfs:comment 'The difference between expected and actual pallet count (actual minus expected). Positive indicates overage, negative indicates shortage.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:putawayTaskGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Putaway Task Generated Flag' ;
    rdfs:comment 'Indicates whether putaway tasks have been automatically generated in the WMS following the receiving event.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether the received goods require quality inspection before being made available for putaway or sale.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivingEventNumber rdf:type rdf:Property ;
    rdfs:label 'Receiving Event Number' ;
    rdfs:comment 'Business-readable unique identifier for the receiving event, used for tracking and reporting.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingNotes rdf:type rdf:Property ;
    rdfs:label 'Receiving Notes' ;
    rdfs:comment 'Free-text notes entered by the receiving clerk documenting any observations, issues, or special handling instructions.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingStatus rdf:type rdf:Property ;
    rdfs:label 'Receiving Status' ;
    rdfs:comment 'Current lifecycle status of the receiving event.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingType rdf:type rdf:Property ;
    rdfs:label 'Receiving Type' ;
    rdfs:comment 'Type of receiving operation: blind receiving (no advance shipment notice), directed receiving (with ASN), cross-dock, return to vendor, or inter-facility transfer.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealIntactFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Intact Flag' ;
    rdfs:comment 'Indicates whether the security seal was found intact upon arrival. False indicates potential tampering or security breach.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortageFlag rdf:type rdf:Property ;
    rdfs:label 'Shortage Flag' ;
    rdfs:comment 'Indicates whether the receiving event resulted in a shortage (fewer units received than expected).' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureReading rdf:type rdf:Property ;
    rdfs:label 'Temperature Reading' ;
    rdfs:comment 'The actual temperature reading (in Celsius) recorded upon arrival for temperature-controlled shipments.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unloadDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Unload Duration Minutes' ;
    rdfs:comment 'Total time in minutes taken to unload the shipment, calculated from start to end timestamp.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unloadEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unload End Timestamp' ;
    rdfs:comment 'The timestamp when the unloading of the inbound shipment was completed.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unloadStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unload Start Timestamp' ;
    rdfs:comment 'The timestamp when the unloading of the inbound shipment began at the dock door.' ;
    rdfs:domain ind:ReceivingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceWarehouseZoneId rdf:type rdf:Property ;
    rdfs:label 'Source Warehouse Zone Id' ;
    rdfs:comment 'Foreign key linking to supplychain.warehouse_zone. Business justification: warehouse_task currently stores source_zone as a STRING code. Replacing with source_warehouse_zone_id → warehouse_zone.warehouse_zone_id normalizes the zone reference, enabling joins to zone capacity,' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseZone .

ind:targetDepartmentId rdf:type rdf:Property ;
    rdfs:label 'Target Department Id' ;
    rdfs:comment 'Foreign key linking to store.department. Business justification: DC warehouse tasks for store replenishment must reference the destination store department to enable direct-to-department putaway routing and department-level replenishment task tracking. Retail DC op' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:actualQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity' ;
    rdfs:comment 'The actual quantity of units completed or processed by the warehouse operator for this task. May differ from planned quantity in case of shorts or overages.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Type of material handling equipment required or used for this task: forklift (counterbalance lift), reach_truck (narrow aisle reach), pallet_jack (manual or powered), order_picker (vertical picker), conveyor (automated transport), AMR (Autonomous Mobile Robot), AGV (Automated Guided Vehicle), manual (no equipment), tugger (tow tractor), or clamp_truck (specialized forklift). [ENUM-REF-CANDIDATE: forklift|reach_truck|pallet_jack|order_picker|conveyor|amr|agv|manual|tugger|clamp_truck — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Exception Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for task exception: short_pick (insufficient inventory), damaged_product, location_blocked, equipment_failure, quality_hold, mispick, system_error, or other predefined exception types.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'The quantity of units originally planned or requested for this warehouse task as generated by the WMS.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardLaborMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Labor Minutes' ;
    rdfs:comment 'Engineered labor standard time in minutes expected for this task type and quantity. Used for productivity variance analysis and incentive pay calculation.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetZone rdf:type rdf:Property ;
    rdfs:label 'Target Zone' ;
    rdfs:comment 'Logical warehouse zone classification for the target location. Used for labor planning and travel time optimization.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskAssignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Assigned Timestamp' ;
    rdfs:comment 'Date and time when the task was assigned to a warehouse operator. Used for measuring task queue time and labor allocation efficiency.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Completed Timestamp' ;
    rdfs:comment 'Date and time when the task was successfully completed or closed. Used for cycle time analysis and throughput measurement.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Created Timestamp' ;
    rdfs:comment 'Date and time when the warehouse task was originally generated by the WMS. Represents the business event timestamp for task creation.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Task Duration Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from task start to completion. Used for labor standards validation and engineered labor standards comparison.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taskStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Started Timestamp' ;
    rdfs:comment 'Date and time when the operator began actively working on the task. Used for calculating actual labor time and productivity metrics.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:travelDistanceFeet rdf:type rdf:Property ;
    rdfs:label 'Travel Distance Feet' ;
    rdfs:comment 'Calculated or measured travel distance in feet between source and target locations. Used for slotting optimization and labor planning.' ;
    rdfs:domain ind:WarehouseTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerAccountId rdf:type rdf:Property ;
    rdfs:label 'Customer Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: B2B wholesale DC fulfillment: retail DCs fulfill outbound orders against B2B customer accounts (wholesale buyers, franchise operators). Linking outbound_order to customer account enables account-level' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:demandPlanId rdf:type rdf:Property ;
    rdfs:label 'Demand Plan Id' ;
    rdfs:comment 'Reference to the demand planning forecast or consensus demand plan that triggered this replenishment order. Links outbound execution to upstream planning.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:destinationDcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Destination Dc Facility Id' ;
    rdfs:comment 'Identifier of the destination node (store, customer, DC, 3PL facility) receiving this shipment. Polymorphic reference interpreted based on destination_type.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:primaryOutboundDcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Outbound Dc Facility Id' ;
    rdfs:comment 'Identifier of the distribution center or micro-fulfillment center (MFC) fulfilling this outbound order.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:carrierServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Level' ;
    rdfs:comment 'Transportation service level selected for this shipment: ground (standard), express (expedited), next-day, two-day, same-day, LTL (Less Than Truckload), or FTL (Full Truckload). [ENUM-REF-CANDIDATE: ground|express|next_day|two_day|same_day|ltl|ftl — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Replenishment Reason Code' ;
    rdfs:comment 'Code indicating the business reason for this replenishment order: stockout prevention, promotional support, seasonal refresh, new item introduction, etc.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentType rdf:type rdf:Property ;
    rdfs:label 'Replenishment Type' ;
    rdfs:comment 'For store replenishment orders: method used to determine replenishment quantities. Push (DC-initiated based on forecast), pull (store-requested), min-max (reorder point triggered), VMI (Vendor Managed Inventory), promotional (event-driven), seasonal (seasonal assortment), or new store (initial stock). [ENUM-REF-CANDIDATE: push|pull|min_max|vmi|promotional|seasonal|new_store — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedShipDate rdf:type rdf:Property ;
    rdfs:label 'Requested Ship Date' ;
    rdfs:comment 'Date by which the order is requested to ship from the distribution center or micro-fulfillment center. Used for planning and wave assignment.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the order must be delivered to the destination node to meet business commitments or replenishment schedules.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalCubeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Cube M3' ;
    rdfs:comment 'Total cubic volume of the outbound order in cubic meters. Used for trailer capacity planning and freight optimization.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLines rdf:type rdf:Property ;
    rdfs:label 'Total Lines' ;
    rdfs:comment 'Total number of distinct SKU line items included in this outbound order.' ;
    rdfs:domain ind:OutboundOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualPickEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Pick End Timestamp' ;
    rdfs:comment 'Actual date and time when the last pick task in this wave was completed.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualPickStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Pick Start Timestamp' ;
    rdfs:comment 'Actual date and time when the first pick task in this wave was started by warehouse associates.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignedPickZones rdf:type rdf:Property ;
    rdfs:label 'Assigned Pick Zones' ;
    rdfs:comment 'Comma-separated list of warehouse pick zone identifiers assigned to this wave for zone-based picking strategies.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationLocation rdf:type rdf:Property ;
    rdfs:label 'Consolidation Location' ;
    rdfs:comment 'Warehouse staging area or dock door where picked items from this wave are consolidated for packing and shipping.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationMethod rdf:type rdf:Property ;
    rdfs:label 'Generation Method' ;
    rdfs:comment 'Method used to create this wave: scheduled (time-based automatic), manual (planner-initiated), demand_triggered (order volume threshold), threshold_based (inventory or capacity rule).' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborHoursActual rdf:type rdf:Property ;
    rdfs:label 'Labor Hours Actual' ;
    rdfs:comment 'Actual total labor hours consumed by warehouse associates to complete this wave, measured from task start to completion.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborHoursPlanned rdf:type rdf:Property ;
    rdfs:label 'Labor Hours Planned' ;
    rdfs:comment 'Estimated total labor hours required to complete picking, packing, and staging for this wave, used for workforce scheduling.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickedUnits rdf:type rdf:Property ;
    rdfs:label 'Picked Units' ;
    rdfs:comment 'Actual quantity of units successfully picked and confirmed for this wave.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedPickEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Pick End Timestamp' ;
    rdfs:comment 'Scheduled date and time for picking operations to complete for this wave.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedPickStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Pick Start Timestamp' ;
    rdfs:comment 'Scheduled date and time for picking operations to begin for this wave.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shortShipDisposition rdf:type rdf:Property ;
    rdfs:label 'Short Ship Disposition' ;
    rdfs:comment 'Business rule applied to handle short-picked units: cancel (remove from order), backorder (fulfill later), substitute (offer alternative SKU), split_shipment (ship partial now).' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortUnits rdf:type rdf:Property ;
    rdfs:label 'Short Units' ;
    rdfs:comment 'Quantity of units that could not be picked due to inventory shortage or location discrepancies.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Reference to the wave template configuration that defines the rules and parameters used to generate this wave.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalOrderLines rdf:type rdf:Property ;
    rdfs:label 'Total Order Lines' ;
    rdfs:comment 'Total count of order line items included in this wave batch for picking.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsPerHour rdf:type rdf:Property ;
    rdfs:label 'Units Per Hour' ;
    rdfs:comment 'Productivity metric calculated as picked_units divided by labor_hours_actual, measuring warehouse picking efficiency.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waveNumber rdf:type rdf:Property ;
    rdfs:label 'Wave Number' ;
    rdfs:comment 'Business-facing wave identifier used for operational tracking and communication across warehouse teams.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveStatus rdf:type rdf:Property ;
    rdfs:label 'Wave Status' ;
    rdfs:comment 'Current lifecycle state of the wave: planned (created but not released), released (available for picking), in-progress (actively being picked), short-closed (closed with shortages), complete (all lines picked), cancelled (wave aborted).' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveType rdf:type rdf:Property ;
    rdfs:label 'Wave Type' ;
    rdfs:comment 'Classification of wave picking strategy: single-order (discrete pick per order), multi-order (batch pick across orders), cluster (cart-based multi-order), zone (pick within assigned zones), wave-less (continuous release), demand-based (dynamic priority-driven release).' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierScacCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Scac Code' ;
    rdfs:comment 'Four-letter code uniquely identifying the transportation carrier, assigned by the National Motor Freight Traffic Association.' ;
    rdfs:domain ind:Supplychain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestNumber rdf:type rdf:Property ;
    rdfs:label 'Manifest Number' ;
    rdfs:comment 'Unique identifier for the carrier manifest document that groups multiple shipments for a single carrier pickup or route.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Flag' ;
    rdfs:comment 'Indicates whether the shipment was delivered on or before the estimated delivery date, used for carrier performance measurement.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationFacilityDcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Dc Facility Id' ;
    rdfs:comment 'Identifier of the facility to which inventory is being transferred. Target location for the stock movement.' ;
    rdfs:domain ind:InventoryTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:originInventoryNodeId rdf:type rdf:Property ;
    rdfs:label 'Origin Inventory Node Id' ;
    rdfs:comment 'Foreign key linking to inventory.inventory_node. Business justification: Store-to-store and DC-to-store transfers require origin_inventory_node_id to track stock movement from specific nodes. Existing origin_facility_id targets dc_facility only; retail needs inventory_node' ;
    rdfs:domain ind:InventoryTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryNode .

ind:primaryInventoryDcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Dc Facility Id' ;
    rdfs:comment 'Identifier of the facility from which inventory is being transferred. Source location for the stock movement.' ;
    rdfs:domain ind:InventoryTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:destinationFacilityType rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Type' ;
    rdfs:comment 'Type classification of the destination facility. Indicates whether the target is a Distribution Center (DC), Micro-Fulfillment Center (MFC), store, Third-Party Logistics (3PL) provider, or vendor location.' ;
    rdfs:domain ind:InventoryTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Lot or batch number for the inventory being transferred. Used for traceability, quality control, and recall management, particularly for perishable or regulated goods.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originFacilityType rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Type' ;
    rdfs:comment 'Type classification of the origin facility. Indicates whether the source is a Distribution Center (DC), Micro-Fulfillment Center (MFC), store, Third-Party Logistics (3PL) provider, or vendor location.' ;
    rdfs:domain ind:InventoryTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'Flag indicating whether the inventory requires temperature-controlled transportation and storage. True if temperature-sensitive, false otherwise.' ;
    rdfs:domain ind:InventoryTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalTransferValue rdf:type rdf:Property ;
    rdfs:label 'Total Transfer Value' ;
    rdfs:comment 'Total monetary value of the inventory transfer calculated as unit cost multiplied by transfer quantity. Used for financial reporting and inventory valuation.' ;
    rdfs:domain ind:InventoryTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Number' ;
    rdfs:comment 'Business-facing unique transfer order number used for tracking and reference across systems and facilities. Externally visible identifier for the transfer transaction.' ;
    rdfs:domain ind:InventoryTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Age Restriction Flag' ;
    rdfs:comment 'Indicates whether this SKU has age restrictions for purchase (e.g., alcohol, tobacco, mature-rated products). True if age-restricted, False if not.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cube rdf:type rdf:Property ;
    rdfs:label 'Cube' ;
    rdfs:comment 'Cubic volume of the SKU package calculated as length × width × height. Used for warehouse space planning and transportation optimization. Measured in cubic feet or cubic meters.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dimensionUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Dimension Unit Of Measure' ;
    rdfs:comment 'Unit of measure for length, width, and height fields. IN (Inch), CM (Centimeter), FT (Foot), M (Meter).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date when this SKU will be or was discontinued and removed from the active assortment. Null if the SKU is not planned for discontinuation. Follows format yyyy-MM-dd.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossWeight rdf:type rdf:Property ;
    rdfs:label 'Gross Weight' ;
    rdfs:comment 'Total weight of the SKU including packaging, measured in the unit specified by weight_unit_of_measure. Used for shipping and logistics calculations.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:height rdf:type rdf:Property ;
    rdfs:label 'Height' ;
    rdfs:comment 'Height dimension of the SKU package, measured in the unit specified by dimension_unit_of_measure. Used for space planning and logistics.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hi rdf:type rdf:Property ;
    rdfs:label 'Hi' ;
    rdfs:comment 'Number of layers (tiers) that can be stacked on a pallet. Part of the Ti-Hi pallet configuration used in warehouse and distribution center operations.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalItemNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Item Number' ;
    rdfs:comment 'Retailer-specific internal product identifier used in legacy systems and internal operations. May differ from external GTIN/UPC.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:length rdf:type rdf:Property ;
    rdfs:label 'Length' ;
    rdfs:comment 'Length dimension of the SKU package, measured in the unit specified by dimension_unit_of_measure. Used for space planning and logistics.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumAgeRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Age Requirement' ;
    rdfs:comment 'Minimum age in years required to purchase this SKU. Null if no age restriction applies. Typically 18 or 21 for restricted products.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netWeight rdf:type rdf:Property ;
    rdfs:label 'Net Weight' ;
    rdfs:comment 'Weight of the product contents excluding packaging, measured in the unit specified by weight_unit_of_measure. Used for regulatory compliance and consumer information.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Number of days the product remains sellable and safe for consumption from the date of manufacture or receipt. Critical for perishable goods and inventory rotation.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skuDescription rdf:type rdf:Property ;
    rdfs:label 'Sku Description' ;
    rdfs:comment 'Detailed textual description of the SKU including key product attributes, features, and specifications. Used for product information management and customer-facing displays.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ti rdf:type rdf:Property ;
    rdfs:label 'Ti' ;
    rdfs:comment 'Number of units per layer on a pallet. Part of the Ti-Hi pallet configuration used in warehouse and distribution center operations.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volume rdf:type rdf:Property ;
    rdfs:label 'Volume' ;
    rdfs:comment 'Volume or capacity of the product, measured in the unit specified by volume_unit_of_measure. Relevant for liquid and bulk products.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Volume Unit Of Measure' ;
    rdfs:comment 'Unit of measure for volume field. GAL (Gallon), LTR (Liter), ML (Milliliter), OZ (Fluid Ounce), QT (Quart).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Weight Unit Of Measure' ;
    rdfs:comment 'Unit of measure for gross_weight and net_weight fields. LB (Pound), KG (Kilogram), OZ (Ounce), G (Gram).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:width rdf:type rdf:Property ;
    rdfs:label 'Width' ;
    rdfs:comment 'Width dimension of the SKU package, measured in the unit specified by dimension_unit_of_measure. Used for space planning and logistics.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentHierarchyNodeItemHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Parent Hierarchy Node Item Hierarchy Id' ;
    rdfs:comment 'Foreign key reference to the parent node in the hierarchy tree. Self-referencing relationship enabling tree traversal and roll-up aggregations. Null for top-level division nodes.' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItemHierarchy .

ind:allowsDirectSkuAssignment rdf:type rdf:Property ;
    rdfs:label 'Allows Direct Sku Assignment' ;
    rdfs:comment 'Boolean flag indicating whether SKUs can be directly assigned to this hierarchy node. Typically True for leaf nodes (subcategory, segment, class) and False for parent nodes (division, department, category). Controls data quality and hierarchy integrity in PIM (Product Information Management) systems.' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoryManagerName rdf:type rdf:Property ;
    rdfs:label 'Category Manager Name' ;
    rdfs:comment 'Name of the category manager responsible for strategic category management, assortment optimization, and category P&L performance. Category managers define assortment breadth and depth targets and drive GMROI (Gross Margin Return on Investment).' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Automated data quality score (0-100) calculated by Informatica MDM based on completeness, accuracy, consistency, and timeliness rules. Scores below threshold trigger data stewardship workflows. Supports master data governance and continuous improvement.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hierarchyDescription rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Description' ;
    rdfs:comment 'Detailed description of the hierarchy node purpose, scope, and business rules. Includes category definition, inclusion/exclusion criteria, and merchandising guidelines. Used for training, onboarding, and cross-functional alignment.' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyNodeName rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node Name' ;
    rdfs:comment 'Human-readable name of the hierarchy node. Examples: Electronics, Home Appliances, Televisions, 4K Smart TVs. Used in reporting, planograms, and category management dashboards.' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Type' ;
    rdfs:comment 'Classification of the hierarchy purpose. Operational hierarchies support daily store operations and planograms. Strategic hierarchies support category management and assortment planning. Financial hierarchies align with P&L reporting. Planning hierarchies support OTB (Open to Buy) and MRP (Material Requirements Planning).' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownCadence rdf:type rdf:Property ;
    rdfs:label 'Markdown Cadence' ;
    rdfs:comment 'Frequency and timing of planned price markdowns for this category. Weekly and biweekly cadences support fast fashion and perishables. Monthly cadences support durable goods. Seasonal cadences align with end-of-season clearance. Event-driven markdowns respond to competitive pressure or excess inventory. Managed in Oracle Retail Price Management (RPM).' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omnichannelEnabled rdf:type rdf:Property ;
    rdfs:label 'Omnichannel Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this category is available across all channels (stores, e-commerce, mobile app, BOPIS, ship-from-store). True for omnichannel categories, False for channel-specific categories. Supports unified commerce strategy and cross-channel inventory visibility.' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannerName rdf:type rdf:Property ;
    rdfs:label 'Planner Name' ;
    rdfs:comment 'Name of the merchandise planner responsible for demand forecasting, inventory planning, and replenishment for this category. Planners use Blue Yonder Demand Planning to optimize inventory levels and minimize stockouts and overstock.' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelPenetrationTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Private Label Penetration Target Percent' ;
    rdfs:comment 'Target percentage of category sales from private label (store brand) products. Private label products typically offer higher margins than national brands. Used in assortment planning and supplier negotiations to optimize category profitability.' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockWeeks rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Weeks' ;
    rdfs:comment 'Target safety stock level expressed in weeks of supply (WOS). Buffer inventory to protect against demand variability and supply chain disruptions. Calculated based on service level targets and lead time variability in Blue Yonder Demand Planning.' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalityIndicator rdf:type rdf:Property ;
    rdfs:label 'Seasonality Indicator' ;
    rdfs:comment 'Seasonal demand pattern classification for this category. Non-seasonal categories have consistent year-round demand. Seasonal categories have predictable demand peaks tied to calendar periods. Used in demand forecasting, markdown planning, and inventory optimization. [ENUM-REF-CANDIDATE: non_seasonal|spring|summer|fall|winter|holiday|back_to_school — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicClassification rdf:type rdf:Property ;
    rdfs:label 'Strategic Classification' ;
    rdfs:comment 'Strategic role of the category in the overall merchandising strategy. Destination categories drive store traffic and differentiation. Routine categories are frequently purchased staples. Convenience categories are impulse or fill-in purchases. Seasonal categories have time-bound demand. Private label vs. national brand classification supports margin optimization.' ;
    rdfs:domain ind:ItemHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributeId rdf:type rdf:Property ;
    rdfs:label 'Attribute Id' ;
    rdfs:comment 'Unique identifier for the product attribute record. Primary key for the product_attribute entity.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributeGroup rdf:type rdf:Property ;
    rdfs:label 'Attribute Group' ;
    rdfs:comment 'Logical grouping or category of the attribute (e.g., \'physical\', \'technical\', \'descriptive\', \'nutritional\', \'environmental\', \'regulatory\', \'marketing\', \'quality\', \'packaging\', \'pricing\'). Enables faceted search and attribute organization in PIM systems. [ENUM-REF-CANDIDATE: physical|technical|descriptive|nutritional|environmental|regulatory|marketing|quality|packaging|pricing — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributeName rdf:type rdf:Property ;
    rdfs:label 'Attribute Name' ;
    rdfs:comment 'The name or label of the product attribute (e.g., \'color\', \'size\', \'fabric\', \'flavor\', \'wattage\', \'nutritional_info\'). Represents the semantic key in the entity-attribute-value (EAV) pattern.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributeStatus rdf:type rdf:Property ;
    rdfs:label 'Attribute Status' ;
    rdfs:comment 'Current lifecycle status of this attribute record (e.g., \'active\', \'inactive\', \'pending_approval\', \'deprecated\', \'archived\'). Supports attribute governance and PIM workflow management.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributeValue rdf:type rdf:Property ;
    rdfs:label 'Attribute Value' ;
    rdfs:comment 'The actual value of the product attribute (e.g., \'Red\', \'Large\', \'100% Cotton\', \'Vanilla\', \'60W\', \'15g protein per serving\'). Stores the descriptive, technical, or measurement data for the attribute.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'The name of the organization or authority that certified this attribute value (e.g., \'USDA Organic\', \'Energy Star\', \'Fair Trade\', \'UL Listed\'). Applicable when is_certified is True.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'The date on which this attribute value was certified. Applicable when is_certified is True. Supports audit trails and compliance reporting.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionFactor rdf:type rdf:Property ;
    rdfs:label 'Conversion Factor' ;
    rdfs:comment 'Numeric conversion factor to translate this attribute\'s unit of measure to a base or standard unit (e.g., 1 lb = 0.453592 kg). Enables cross-UOM calculations and reporting.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataType rdf:type rdf:Property ;
    rdfs:label 'Data Type' ;
    rdfs:comment 'The data type of the attribute value (e.g., \'string\', \'numeric\', \'boolean\', \'date\', \'timestamp\', \'decimal\'). Used for validation and type-safe processing in downstream systems.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCertified rdf:type rdf:Property ;
    rdfs:label 'Is Certified' ;
    rdfs:comment 'Boolean flag indicating whether this attribute value has been certified or verified by an authoritative source (e.g., environmental certification, organic certification, safety compliance). True if certified, False otherwise.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isComparable rdf:type rdf:Property ;
    rdfs:label 'Is Comparable' ;
    rdfs:comment 'Boolean flag indicating whether this attribute should be displayed in product comparison views (True) or not (False). Supports side-by-side product comparison features in e-commerce.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryRequired rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Required' ;
    rdfs:comment 'Boolean flag indicating whether this attribute is required by regulatory or legal mandate (e.g., FDA nutritional labeling, CPSC safety warnings, FTC advertising disclosures). True if mandated, False otherwise.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRequired rdf:type rdf:Property ;
    rdfs:label 'Is Required' ;
    rdfs:comment 'Boolean flag indicating whether this attribute is mandatory for the product (True) or optional (False). Used for data completeness scoring and GS1 GDSN readiness checks.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Citation or reference to the specific regulation, statute, or standard that mandates this attribute (e.g., \'FDA 21 CFR 101.9\', \'CPSC 16 CFR 1500\', \'FTC 16 CFR Part 255\'). Applicable when is_regulatory_required is True.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationRule rdf:type rdf:Property ;
    rdfs:label 'Validation Rule' ;
    rdfs:comment 'Business rule or regex pattern used to validate the attribute value (e.g., \'must be positive integer\', \'must match color palette\', \'must be ISO 8601 date\'). Enforces data quality at attribute capture time.' ;
    rdfs:domain ind:Attribute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the brand for internal identification and system integration. Used in merchandising, procurement, and reporting systems.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandDescription rdf:type rdf:Property ;
    rdfs:label 'Brand Description' ;
    rdfs:comment 'Detailed narrative describing the brand positioning, value proposition, target customer segment, and key differentiators. Used for internal merchandising guidance and external marketing content.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'Official registered name of the brand as it appears on product packaging and marketing materials. Consumer-facing brand identifier.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Status' ;
    rdfs:comment 'Current lifecycle status of the brand in the retail assortment. Active brands are available for new item setup and replenishment; inactive brands are temporarily suspended; discontinued brands are permanently removed; pending approval brands are under review for introduction.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandTier rdf:type rdf:Property ;
    rdfs:label 'Brand Tier' ;
    rdfs:comment 'Market positioning tier indicating price point and quality perception. Premium brands command higher margins and target affluent consumers; value and economy brands focus on price-sensitive segments. Drives assortment strategy and shelf placement.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandType rdf:type rdf:Property ;
    rdfs:label 'Brand Type' ;
    rdfs:comment 'Classification of brand ownership and distribution model. National brands are manufacturer-owned and widely distributed; private label are retailer-owned store brands; exclusive brands are sold only through specific retail partnerships; licensed brands use third-party intellectual property.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOriginCode rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the primary country where products under this brand are manufactured or sourced. Required for customs compliance and consumer transparency.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLicensed rdf:type rdf:Property ;
    rdfs:label 'Is Licensed' ;
    rdfs:comment 'Boolean flag indicating whether this brand operates under a licensing agreement using third-party intellectual property (e.g., character brands, celebrity brands, sports team brands). True for licensed brands, false otherwise. Impacts royalty payments and contract management.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'License Expiration Date' ;
    rdfs:comment 'Date when the licensing agreement for this brand expires. Null for non-licensed brands. Used for contract renewal planning and inventory liquidation strategy for expiring licenses.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:logoAssetUrl rdf:type rdf:Property ;
    rdfs:label 'Logo Asset Url' ;
    rdfs:comment 'Reference URL or path to the digital brand logo asset stored in the Product Information Management (PIM) or Digital Asset Management (DAM) system. Used for e-commerce product pages, marketing materials, and mobile app display.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerCountryCode rdf:type rdf:Property ;
    rdfs:label 'Owner Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country where the brand owner is headquartered. Used for country-of-origin reporting and supplier diversity analytics.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioGroup rdf:type rdf:Property ;
    rdfs:label 'Portfolio Group' ;
    rdfs:comment 'Higher-level grouping of related brands under a common portfolio or brand family. Enables portfolio-level margin analysis, vendor negotiations, and strategic assortment planning across brand families.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Internal quality assessment score for the brand based on product defect rates, customer returns, and quality audits. Scale of 0.00 to 5.00. Used for vendor scorecard evaluation and assortment quality management.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnRatePercent rdf:type rdf:Property ;
    rdfs:label 'Return Rate Percent' ;
    rdfs:comment 'Percentage of units sold under this brand that are returned by customers. Calculated as (units returned / units sold) * 100. High return rates may indicate quality issues or misaligned customer expectations.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityCertification rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification' ;
    rdfs:comment 'Environmental or social responsibility certifications held by the brand (e.g., Fair Trade, Organic, B Corp, Carbon Neutral). Supports ESG reporting and consumer filtering on e-commerce platforms for sustainable products.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official website URL for the brand, providing additional product information, brand story, and consumer engagement content. Used for e-commerce product page enrichment and customer education.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemVariantId rdf:type rdf:Property ;
    rdfs:label 'Item Variant Id' ;
    rdfs:comment 'Unique identifier for the item variant relationship record. Primary key.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryItemSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Item Sku Id' ;
    rdfs:comment 'Reference to the parent or source SKU in the variant or substitution relationship. For variant relationships, this is the parent style or base item. For substitution relationships, this is the original SKU being substituted.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:targetItemSkuId rdf:type rdf:Property ;
    rdfs:label 'Target Item Sku Id' ;
    rdfs:comment 'Reference to the child or target SKU in the variant or substitution relationship. For variant relationships, this is the child SKU (specific size, color, flavor). For substitution relationships, this is the replacement SKU.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:autoSubstituteFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Substitute Flag' ;
    rdfs:comment 'Indicates whether this substitution can be applied automatically by fulfillment systems without manual intervention. True enables automatic substitution during picking when the source item is out of stock. False requires manual approval or customer consent.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerConsentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Consent Required Flag' ;
    rdfs:comment 'Indicates whether explicit customer consent is required before applying this substitution. True means the customer must approve the substitution (e.g., for price upgrades or significant product differences). False means the substitution can be applied automatically (e.g., for equivalent items). Applicable primarily for substitution relationships.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displaySequence rdf:type rdf:Property ;
    rdfs:label 'Display Sequence' ;
    rdfs:comment 'Numeric order for displaying variants in e-commerce product pages, mobile apps, and digital catalogs. Lower numbers appear first. Used to control the presentation order of size-color grids and variant selectors.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryInterchangeableFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Interchangeable Flag' ;
    rdfs:comment 'Indicates whether the source and target items can be treated as interchangeable for inventory allocation and fulfillment purposes. True means inventory of either item can fulfill demand for the other. False means they must be tracked separately. Relevant for substitution relationships.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceDifferentialAmount rdf:type rdf:Property ;
    rdfs:label 'Price Differential Amount' ;
    rdfs:comment 'The price difference between the source and target items. Positive values indicate the target is more expensive (upgrade). Negative values indicate the target is less expensive (downgrade). Zero or null indicates equivalent pricing. Used for substitution cost impact analysis.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current lifecycle status of the variant or substitution relationship. Active means the relationship is in use. Inactive means temporarily disabled. Pending means awaiting approval or activation. Discontinued means permanently retired.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Type of relationship between source and target items. Variant indicates parent-child SKU relationship (e.g., style to size-color). Substitution indicates approved replacement for out-of-stock scenarios. Cross-sell and upsell support merchandising. Bundle and accessory support product associations.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Substitution Priority Rank' ;
    rdfs:comment 'Numeric rank indicating the priority order for substitution when multiple substitutes are available. Lower numbers indicate higher priority. Used by fulfillment systems to select the best substitute when the source item is out of stock.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substitutionType rdf:type rdf:Property ;
    rdfs:label 'Substitution Type' ;
    rdfs:comment 'Classification of the substitution relationship. Equivalent indicates same quality and price point. Upgrade indicates higher quality or price. Downgrade indicates lower quality or price. Alternative indicates different but acceptable replacement. Applicable only when relationship_type is substitution.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantDimensionType rdf:type rdf:Property ;
    rdfs:label 'Variant Dimension Type' ;
    rdfs:comment 'The dimension along which the variant differs from the parent item. Applicable only when relationship_type is variant. Examples: size for apparel, flavor for beverages, scent for personal care, pack configuration for multi-packs. [ENUM-REF-CANDIDATE: size|color|flavor|scent|pack_configuration|material|style|fit|length|width — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantDimensionValue rdf:type rdf:Property ;
    rdfs:label 'Variant Dimension Value' ;
    rdfs:comment 'The specific value of the variant dimension for the target item. Examples: Small, Medium, Large for size; Red, Blue, Green for color; Vanilla, Chocolate for flavor; 6-pack, 12-pack for pack configuration.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variantEan rdf:type rdf:Property ;
    rdfs:label 'Variant Ean' ;
    rdfs:comment 'The 13-digit EAN barcode assigned to the target variant item. Used internationally for product identification and scanning. Common in European and global retail operations.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantGroupCode rdf:type rdf:Property ;
    rdfs:label 'Variant Group Code' ;
    rdfs:comment 'A code that groups related variants together under a common parent style or product family. Used to aggregate sales, inventory, and performance metrics across all variants of a base item. Supports category management and assortment planning.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantGtin rdf:type rdf:Property ;
    rdfs:label 'Variant Gtin' ;
    rdfs:comment 'The Global Trade Item Number assigned to the target variant item. GTIN is the umbrella term for UPC, EAN, and other GS1 product identifiers. Used for global supply chain and EDI transactions.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantUpc rdf:type rdf:Property ;
    rdfs:label 'Variant Upc' ;
    rdfs:comment 'The 12-digit UPC barcode assigned to the target variant item. Used for point-of-sale scanning and inventory tracking. Each variant SKU typically has its own unique UPC.' ;
    rdfs:domain ind:ItemVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imageId rdf:type rdf:Property ;
    rdfs:label 'Image Id' ;
    rdfs:comment 'Unique identifier for the product image asset record.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aspectRatio rdf:type rdf:Property ;
    rdfs:label 'Aspect Ratio' ;
    rdfs:comment 'The proportional relationship between width and height (e.g., 1:1, 4:3, 16:9). Used for responsive design and layout planning.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundColor rdf:type rdf:Property ;
    rdfs:label 'Background Color' ;
    rdfs:comment 'The hexadecimal color code of the image background (e.g., #FFFFFF for white). Used for consistent product presentation and dynamic background replacement.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caption rdf:type rdf:Property ;
    rdfs:label 'Caption' ;
    rdfs:comment 'Optional marketing or descriptive caption displayed alongside the image in certain contexts (e.g., lifestyle images with usage tips).' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnAssetReference rdf:type rdf:Property ;
    rdfs:label 'Cdn Asset Reference' ;
    rdfs:comment 'The unique identifier or key used by the Content Delivery Network to cache and serve this image asset globally.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorProfile rdf:type rdf:Property ;
    rdfs:label 'Color Profile' ;
    rdfs:comment 'The color space or profile used in the image (sRGB, Adobe RGB, ProPhoto RGB, CMYK). Critical for color accuracy across web, print, and in-store displays.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copyrightHolder rdf:type rdf:Property ;
    rdfs:label 'Copyright Holder' ;
    rdfs:comment 'The legal entity or individual who holds the copyright to this image asset. Critical for rights management and legal compliance.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpi rdf:type rdf:Property ;
    rdfs:label 'Dpi' ;
    rdfs:comment 'The resolution of the image in dots per inch. Typically 72 DPI for web and 300 DPI for print. Used to determine print quality suitability.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'The digital file format of the image asset (JPEG, PNG, GIF, WEBP, SVG, TIFF).' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeKb rdf:type rdf:Property ;
    rdfs:label 'File Size Kb' ;
    rdfs:comment 'The file size of the image asset in kilobytes. Used for performance optimization and bandwidth management.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hasTransparency rdf:type rdf:Property ;
    rdfs:label 'Has Transparency' ;
    rdfs:comment 'Boolean flag indicating whether the image contains transparent pixels (alpha channel). Relevant for PNG and GIF formats used in layered designs.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imageType rdf:type rdf:Property ;
    rdfs:label 'Image Type' ;
    rdfs:comment 'Classification of the image purpose: hero (primary product shot), alternate (additional angles), swatch (color/material sample), lifestyle (in-use context), packaging (box/container), detail (close-up feature).' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'The licensing model under which the retailer has rights to use this image: owned (created in-house), licensed (paid third-party), royalty_free (unlimited use), creative_commons (open license), vendor_supplied (provided by supplier).' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileOptimized rdf:type rdf:Property ;
    rdfs:label 'Mobile Optimized' ;
    rdfs:comment 'Boolean flag indicating whether this image has been optimized for mobile device display (compressed, resized, or formatted for mobile bandwidth and screen size).' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photographerCredit rdf:type rdf:Property ;
    rdfs:label 'Photographer Credit' ;
    rdfs:comment 'Attribution to the photographer or content creator who produced the image. Used for rights management and licensing compliance.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramEligible rdf:type rdf:Property ;
    rdfs:label 'Planogram Eligible' ;
    rdfs:comment 'Boolean flag indicating whether this image is suitable for use in planogram design and shelf layout planning. Typically requires consistent background and perspective.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:printReady rdf:type rdf:Property ;
    rdfs:label 'Print Ready' ;
    rdfs:comment 'Boolean flag indicating whether this image meets the resolution and color profile requirements for print media (catalogs, circulars, in-store signage).' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'A computed or manually assigned quality score (0.00 to 5.00) representing the technical and aesthetic quality of the image. Used for quality control and merchandising decisions.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionHeight rdf:type rdf:Property ;
    rdfs:label 'Resolution Height' ;
    rdfs:comment 'The height of the image in pixels. Used to determine image quality and suitability for different channels (web, mobile, print).' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionWidth rdf:type rdf:Property ;
    rdfs:label 'Resolution Width' ;
    rdfs:comment 'The width of the image in pixels. Used to determine image quality and suitability for different channels (web, mobile, print).' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seoKeywords rdf:type rdf:Property ;
    rdfs:label 'Seo Keywords' ;
    rdfs:comment 'Comma-separated list of keywords associated with this image for search engine optimization and internal search relevance.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'The display order of this image within the product\'s image gallery. Lower numbers appear first in the carousel or gallery view.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uploadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upload Timestamp' ;
    rdfs:comment 'The date and time when this image was first uploaded to the digital asset management system.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:url rdf:type rdf:Property ;
    rdfs:label 'Url' ;
    rdfs:comment 'The full URL path to the digital image asset, typically hosted on a Content Delivery Network (CDN) or digital asset management system.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsNotes rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Notes' ;
    rdfs:comment 'Free-text field capturing any special terms, restrictions, or notes regarding the usage rights of this image (e.g., geographic restrictions, channel limitations, attribution requirements).' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewAngle rdf:type rdf:Property ;
    rdfs:label 'View Angle' ;
    rdfs:comment 'The perspective or angle from which the product is photographed (front, back, left, right, top, bottom, angle). Helps customers understand product dimensions and features. [ENUM-REF-CANDIDATE: front|back|left|right|top|bottom|angle — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoomEnabled rdf:type rdf:Property ;
    rdfs:label 'Zoom Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this image supports zoom functionality on the e-commerce platform. High-resolution images typically enable zoom for detailed product inspection.' ;
    rdfs:domain ind:Image ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ageRestrictionRequired rdf:type rdf:Property ;
    rdfs:label 'Age Restriction Required' ;
    rdfs:comment 'Indicates whether the product requires age verification at point of sale due to regulatory restrictions (e.g., alcohol, tobacco, certain chemicals).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenDeclarationCompliant rdf:type rdf:Property ;
    rdfs:label 'Allergen Declaration Compliant' ;
    rdfs:comment 'Indicates whether the product labeling complies with allergen disclosure requirements (e.g., contains milk, eggs, peanuts, tree nuts, fish, shellfish, soy, wheat).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Unique certification or approval number issued by the certifying body for this compliance record.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBody rdf:type rdf:Property ;
    rdfs:label 'Certifying Body' ;
    rdfs:comment 'Name of the regulatory authority or third-party organization that issued the compliance certification (e.g., FDA, CPSC, UL, NSF, USDA).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance status of the product for this regulatory requirement.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceType rdf:type rdf:Property ;
    rdfs:label 'Compliance Type' ;
    rdfs:comment 'Category of regulatory compliance requirement (e.g., food safety, product safety, hazardous material classification, age restriction, import/export, labeling, environmental). [ENUM-REF-CANDIDATE: food_safety|product_safety|hazmat|age_restriction|import_export|labeling|environmental — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOriginCompliant rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin Compliant' ;
    rdfs:comment 'Indicates whether the product labeling meets country-of-origin marking requirements for customs and consumer disclosure.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fdaFoodFacilityRegistration rdf:type rdf:Property ;
    rdfs:label 'Fda Food Facility Registration' ;
    rdfs:comment 'FDA registration number for the manufacturing facility where food products are produced. Required for food safety compliance. Null for non-food items.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatClassification rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classification' ;
    rdfs:comment 'Classification code for hazardous materials according to transportation and storage regulations (e.g., UN number, DOT hazard class). Null if product is not hazardous.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Import License Number' ;
    rdfs:comment 'Government-issued import license or permit number required for cross-border trade of regulated products. Null if not applicable.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent compliance audit or inspection conducted by the certifying body or internal quality assurance team.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumAgeYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Age Years' ;
    rdfs:comment 'Minimum age in years required to purchase this product. Null if no age restriction applies.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'Scheduled date for the next compliance audit or inspection. Used for proactive compliance management.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nutritionLabelingCompliant rdf:type rdf:Property ;
    rdfs:label 'Nutrition Labeling Compliant' ;
    rdfs:comment 'Indicates whether the product meets FDA nutrition labeling requirements (Nutrition Facts panel). Applicable to food and beverage products.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organicCertification rdf:type rdf:Property ;
    rdfs:label 'Organic Certification' ;
    rdfs:comment 'Organic certification number or designation (e.g., USDA Organic, EU Organic). Null if product is not certified organic.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prop65ChemicalList rdf:type rdf:Property ;
    rdfs:label 'Prop 65 Chemical List' ;
    rdfs:comment 'Comma-separated list of Prop 65 chemicals present in the product that trigger warning requirements. Null if no Prop 65 warning required.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prop65WarningRequired rdf:type rdf:Property ;
    rdfs:label 'Prop 65 Warning Required' ;
    rdfs:comment 'Indicates whether the product requires a California Prop 65 warning label due to presence of chemicals known to cause cancer, birth defects, or reproductive harm.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallDate rdf:type rdf:Property ;
    rdfs:label 'Recall Date' ;
    rdfs:comment 'Date when the product recall was initiated. Null if no recall has been issued.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallReason rdf:type rdf:Property ;
    rdfs:label 'Recall Reason' ;
    rdfs:comment 'Detailed explanation of the reason for the product recall (e.g., contamination, safety hazard, labeling error). Null if no recall.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallSeverityLevel rdf:type rdf:Property ;
    rdfs:label 'Recall Severity Level' ;
    rdfs:comment 'FDA classification of recall severity: Class 1 (serious health hazard or death), Class 2 (temporary health problem), Class 3 (unlikely to cause adverse health effects). Null if no recall.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallStatus rdf:type rdf:Property ;
    rdfs:label 'Recall Status' ;
    rdfs:comment 'Current recall status of the product indicating whether it is subject to a safety or quality recall.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyContact rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Contact' ;
    rdfs:comment 'Contact information (phone or email) for the responsible party. Used for regulatory inquiries and recall coordination.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Tariff Classification Code' ;
    rdfs:comment 'Harmonized Tariff Schedule (HTS) code used for customs classification and duty calculation for imported products.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReportNumber rdf:type rdf:Property ;
    rdfs:label 'Test Report Number' ;
    rdfs:comment 'Unique identifier for the compliance test report issued by the testing laboratory. Null if no test report available.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingLaboratory rdf:type rdf:Property ;
    rdfs:label 'Testing Laboratory' ;
    rdfs:comment 'Name of the accredited third-party laboratory that conducted compliance testing (e.g., UL, Intertek, SGS, Bureau Veritas). Null if no third-party testing performed.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleSkuId rdf:type rdf:Property ;
    rdfs:label 'Bundle Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: item_bundle.bundle_sku (STRING) should be normalized to a proper FK. The bundle itself is a SKU in the catalog. This links the bundle definition to its SKU master record. bundle_gtin can be retrieved ' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:assortmentCategory rdf:type rdf:Property ;
    rdfs:label 'Assortment Category' ;
    rdfs:comment 'The merchandising category or department this bundle belongs to for assortment planning and category management (e.g., Grocery, Apparel, Electronics).' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleDescription rdf:type rdf:Property ;
    rdfs:label 'Bundle Description' ;
    rdfs:comment 'Detailed description of the bundle contents and value proposition for merchandising and marketing purposes.' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleName rdf:type rdf:Property ;
    rdfs:label 'Bundle Name' ;
    rdfs:comment 'The customer-facing name of the bundle (e.g., \'Summer BBQ Pack\', \'Family Meal Deal\', \'Holiday Gift Set\').' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundlePriceAmount rdf:type rdf:Property ;
    rdfs:label 'Bundle Price Amount' ;
    rdfs:comment 'The selling price of the bundle when pricing_method is bundle_price. Represents the total customer-facing price.' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bundleStatus rdf:type rdf:Property ;
    rdfs:label 'Bundle Status' ;
    rdfs:comment 'Current lifecycle status of the bundle: active (available for sale), inactive (temporarily unavailable), pending (awaiting approval), discontinued (permanently removed), seasonal (available during specific periods).' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleType rdf:type rdf:Property ;
    rdfs:label 'Bundle Type' ;
    rdfs:comment 'Classification of the bundle configuration: fixed_bundle (pre-defined components), mix_and_match (customer selects from options), gift_set (curated gift collection), kit (assembly required), variety_pack (multiple flavors/variants), multi_pack (quantity of same item).' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentQuantity rdf:type rdf:Property ;
    rdfs:label 'Component Quantity' ;
    rdfs:comment 'The quantity of the component SKU included in one unit of the bundle. Supports fractional quantities for weight-based items.' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentSequence rdf:type rdf:Property ;
    rdfs:label 'Component Sequence' ;
    rdfs:comment 'The display order or assembly sequence of this component within the bundle. Used for kit assembly instructions and merchandising display.' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentSku rdf:type rdf:Property ;
    rdfs:label 'Component Sku' ;
    rdfs:comment 'The SKU of an individual component item included in this bundle. References the product master catalog.' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentSubstitutionAllowed rdf:type rdf:Property ;
    rdfs:label 'Component Substitution Allowed' ;
    rdfs:comment 'Indicates whether this component can be substituted with an equivalent item during fulfillment (e.g., out-of-stock scenarios, mix-and-match bundles).' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryDeductionMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Deduction Method' ;
    rdfs:comment 'Defines how inventory is tracked and decremented: component_level (deduct each component SKU), bundle_level (track bundle as single inventory unit), hybrid (track both bundle and components).' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyPointsEligible rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Eligible' ;
    rdfs:comment 'Indicates whether customers can earn loyalty program points on bundle purchases.' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumPurchaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Purchase Quantity' ;
    rdfs:comment 'The maximum number of bundle units a customer can purchase in a single transaction. Used to prevent stockouts and ensure fair distribution of limited-time offers.' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingMethod rdf:type rdf:Property ;
    rdfs:label 'Pricing Method' ;
    rdfs:comment 'Defines how the bundle price is calculated: bundle_price (fixed price for entire bundle), component_sum (sum of individual component prices), discount_percentage (percentage off component sum), discount_amount (fixed dollar discount off component sum).' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionEligible rdf:type rdf:Property ;
    rdfs:label 'Promotion Eligible' ;
    rdfs:comment 'Indicates whether this bundle can be included in additional promotional offers or discounts beyond its configured bundle pricing.' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Return Policy Code' ;
    rdfs:comment 'Reference code to the specific return policy applicable to this bundle (e.g., standard 30-day, final sale, exchange only).' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnable rdf:type rdf:Property ;
    rdfs:label 'Returnable' ;
    rdfs:comment 'Indicates whether the bundle can be returned. Some bundles (e.g., opened gift sets, perishable meal kits) may not be returnable.' ;
    rdfs:domain ind:ItemBundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:barcodeImageUrl rdf:type rdf:Property ;
    rdfs:label 'Barcode Image Url' ;
    rdfs:comment 'URL reference to the digital barcode image asset (PNG, SVG, or EPS format). Used for printing labels, packaging artwork, and digital commerce applications. Points to asset management system or CDN location.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeSymbology rdf:type rdf:Property ;
    rdfs:label 'Barcode Symbology' ;
    rdfs:comment 'The barcode encoding standard used to represent this GTIN. EAN (European Article Number bars), UPC (Universal Product Code bars), ITF-14 (Interleaved 2 of 5 for cases), GS1-128 (application identifier barcodes), QR (2D matrix code). Determines scanner compatibility.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkDigit rdf:type rdf:Property ;
    rdfs:label 'Check Digit' ;
    rdfs:comment 'The final digit of the GTIN calculated using GS1 check digit algorithm (modulo 10). Used to validate GTIN integrity during scanning and data entry. Automatically calculated but stored for validation purposes.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childGtinQuantity rdf:type rdf:Property ;
    rdfs:label 'Child Gtin Quantity' ;
    rdfs:comment 'Number of child GTINs (next lower packaging level) contained within this GTIN. For example, a case GTIN with child_gtin_quantity=24 contains 24 unit GTINs. Null for unit-level GTINs. Used to calculate inventory at different packaging levels.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countryOfSale rdf:type rdf:Property ;
    rdfs:label 'Country Of Sale' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where this GTIN is authorized for sale. A single SKU may have different GTINs for different countries due to regulatory labeling requirements. For example, USA, CAN, MEX, GBR, DEU, FRA.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsnLastSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gdsn Last Sync Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful synchronization of this GTIN data to the GDSN data pool. Used to track data freshness and identify GTINs requiring re-publication after attribute changes.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdsnPublicationStatus rdf:type rdf:Property ;
    rdfs:label 'Gdsn Publication Status' ;
    rdfs:comment 'Status of this GTIN in the GS1 Global Data Synchronization Network. Published (live in GDSN data pool), unpublished (not yet shared), pending (awaiting data pool validation), synchronized (confirmed by trading partners), rejected (validation errors). Required for supplier collaboration and EDI.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightUnit rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Unit' ;
    rdfs:comment 'Unit of measure for gross_weight_value. Typically g (gram), kg (kilogram), oz (ounce), or lb (pound). Must be consistent across supply chain for accurate logistics planning.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightValue rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Value' ;
    rdfs:comment 'Total weight of the packaged item including product and packaging materials. Used for shipping calculations, freight costing, and warehouse capacity planning. Measured in gross_weight_unit.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gtinType rdf:type rdf:Property ;
    rdfs:label 'Gtin Type' ;
    rdfs:comment 'The specific GTIN format type. UPC-A (12-digit North America standard), UPC-E (8-digit compressed UPC), EAN-13 (13-digit international standard), EAN-8 (8-digit short EAN), GTIN-14 (14-digit case/pallet level), ITF-14 (Interleaved 2 of 5 barcode for GTIN-14).' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBaseUnit rdf:type rdf:Property ;
    rdfs:label 'Is Base Unit' ;
    rdfs:comment 'Indicates whether this GTIN is the base unit of measure for inventory tracking. Typically true for the smallest sellable unit (each). All other packaging levels are multiples of the base unit. Used for inventory conversion calculations.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConsumerUnit rdf:type rdf:Property ;
    rdfs:label 'Is Consumer Unit' ;
    rdfs:comment 'Indicates whether this GTIN represents a consumer-facing unit sold at POS. True for retail each units. False for case/pallet GTINs used only in supply chain. Determines whether GTIN should appear in e-commerce catalog and POS systems.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrderableUnit rdf:type rdf:Property ;
    rdfs:label 'Is Orderable Unit' ;
    rdfs:comment 'Indicates whether this GTIN can be ordered directly via EDI purchase orders. True for case and pallet GTINs typically ordered from suppliers. False for unit GTINs that are only sold at retail. Controls EDI transaction validation.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVariableMeasure rdf:type rdf:Property ;
    rdfs:label 'Is Variable Measure' ;
    rdfs:comment 'Indicates whether this GTIN represents a variable measure item (e.g., meat, produce, cheese sold by weight). True for items where price varies by weight/quantity. Affects POS scanning behavior and pricing logic.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netContentUnit rdf:type rdf:Property ;
    rdfs:label 'Net Content Unit' ;
    rdfs:comment 'The unit of measure for net_content_value. Standard units: g (gram), kg (kilogram), mg (milligram), oz (ounce), lb (pound), mL (milliliter), L (liter), gal (gallon), qt (quart), pt (pint), ea (each), ct (count). Must align with regulatory labeling requirements. [ENUM-REF-CANDIDATE: g|kg|mg|oz|lb|mL|L|gal|qt|pt|ea|ct — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netContentValue rdf:type rdf:Property ;
    rdfs:label 'Net Content Value' ;
    rdfs:comment 'The numeric quantity of product contained in this GTIN package. For example, 500 (when unit is mL), 12 (when unit is oz), 1.5 (when unit is kg). Used with net_content_unit to describe package size. Required for GDSN synchronization.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageDepthValue rdf:type rdf:Property ;
    rdfs:label 'Package Depth Value' ;
    rdfs:comment 'Depth dimension of the package. Used with height and width for cubic volume calculations. Essential for warehouse bin sizing and transportation load planning. Measured in package_dimension_unit.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageDimensionUnit rdf:type rdf:Property ;
    rdfs:label 'Package Dimension Unit' ;
    rdfs:comment 'Unit of measure for package dimensions (height, width, depth). Standard units: mm (millimeter), cm (centimeter), m (meter), in (inch), ft (foot). Must be consistent for all three dimensions.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageHeightValue rdf:type rdf:Property ;
    rdfs:label 'Package Height Value' ;
    rdfs:comment 'Height dimension of the package. Used with package_width_value and package_depth_value to calculate cubic volume for warehouse slotting, transportation planning, and shelf space allocation. Measured in package_dimension_unit.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageWidthValue rdf:type rdf:Property ;
    rdfs:label 'Package Width Value' ;
    rdfs:comment 'Width dimension of the package. Critical for planogram design, shelf allocation, and transportation cube optimization. Measured in package_dimension_unit.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingLevel rdf:type rdf:Property ;
    rdfs:label 'Packaging Level' ;
    rdfs:comment 'The packaging hierarchy level this GTIN represents. Unit (each/consumer unit), inner pack (multi-pack sold as one), case (shipping carton), pallet (full pallet load), display (retail display shipper). Critical for warehouse receiving and inventory management.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of this GTIN registration. Active (in use), inactive (temporarily disabled), pending (awaiting approval), suspended (compliance issue), retired (permanently discontinued). Controls whether the GTIN can be used in transactions.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Status' ;
    rdfs:comment 'Indicates whether this GTIN meets all applicable regulatory requirements for its country of sale. Compliant (approved for sale), non_compliant (blocked), pending_review (under evaluation), exempt (not subject to specific regulations). Enforced by quality assurance and legal teams.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementGtin rdf:type rdf:Property ;
    rdfs:label 'Replacement Gtin' ;
    rdfs:comment 'The new GTIN that supersedes this one when discontinued. Used for packaging changes, reformulations, or product transitions. Enables automatic substitution in ordering systems and maintains continuity in assortment planning.' ;
    rdfs:domain ind:GtinRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeOrderId rdf:type rdf:Property ;
    rdfs:label 'Exchange Order Id' ;
    rdfs:comment 'Reference to the new order created for an exchange transaction, linking the return to the replacement order.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExchangeOrder .

ind:returnLocationId rdf:type rdf:Property ;
    rdfs:label 'Return Location Id' ;
    rdfs:comment 'Reference to the store or distribution center where the returned merchandise will be received and processed.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:customerComments rdf:type rdf:Property ;
    rdfs:label 'Customer Comments' ;
    rdfs:comment 'Free-text comments provided by the customer explaining the reason for return or providing additional details about the issue.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'Code indicating the final disposition of the returned merchandise: restock to inventory, liquidate through clearance channel, rework/refurbish, scrap/destroy, RTV (Return to Vendor), or donate to charity.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReturnValueAmount rdf:type rdf:Property ;
    rdfs:label 'Expected Return Value Amount' ;
    rdfs:comment 'The total monetary value of merchandise expected to be returned under this RMA, calculated from the original order line items.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Result of the merchandise inspection indicating whether items meet return acceptance criteria.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Precise timestamp when the returned merchandise was received, used for SLA tracking and operational metrics.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundProcessedDate rdf:type rdf:Property ;
    rdfs:label 'Refund Processed Date' ;
    rdfs:comment 'The date when the refund payment was processed and issued to the customer.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnMethod rdf:type rdf:Property ;
    rdfs:label 'Return Method' ;
    rdfs:comment 'The logistics method by which the customer will return the merchandise (ship to distribution center, drop at store, carrier pickup from customer location, or direct return to vendor).' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnShippingCost rdf:type rdf:Property ;
    rdfs:label 'Return Shipping Cost' ;
    rdfs:comment 'Cost of shipping the returned merchandise back to the retailer, which may be borne by customer or retailer depending on return reason and policy.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnShippingPaidBy rdf:type rdf:Property ;
    rdfs:label 'Return Shipping Paid By' ;
    rdfs:comment 'Indicates which party is responsible for paying the return shipping cost.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnType rdf:type rdf:Property ;
    rdfs:label 'Return Type' ;
    rdfs:comment 'The type of resolution requested or authorized for this return: full refund to original payment method, exchange for different item, store credit, or replacement of defective item.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaStatus rdf:type rdf:Property ;
    rdfs:label 'Rma Status' ;
    rdfs:comment 'Current lifecycle status of the RMA. Tracks progression from initial request through final disposition. [ENUM-REF-CANDIDATE: pending|authorized|received|inspected|approved|denied|closed|cancelled|expired — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCreditIssuedAmount rdf:type rdf:Property ;
    rdfs:label 'Store Credit Issued Amount' ;
    rdfs:comment 'The amount of store credit issued to the customer as part of the return resolution.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rmaLineId rdf:type rdf:Property ;
    rdfs:label 'Rma Line Id' ;
    rdfs:comment 'Primary key for rma_line' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RmaLine .

ind:originalOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Original Order Line Id' ;
    rdfs:comment 'Reference to the specific line item on the original sales order. Enables precise traceability from return to original purchase.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:originalPosTransactionLineId rdf:type rdf:Property ;
    rdfs:label 'Original Pos Transaction Line Id' ;
    rdfs:comment 'Foreign key linking to order.pos_transaction_line. Business justification: In-store returns require line-level reference to the original POS transaction line for unit price validation, tax recalculation, and return policy enforcement per item. rma_line has original_order_lin' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosTransactionLine .

ind:originalSkuPriceId rdf:type rdf:Property ;
    rdfs:label 'Original Sku Price Id' ;
    rdfs:comment 'Foreign key linking to pricing.sku_price. Business justification: rma_line.unit_retail_price is denormalized from sku_price. Retail returns processing and refund calculation require the authoritative sku_price record for the original selling price to validate refund' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuPrice .

ind:conditionCode rdf:type rdf:Property ;
    rdfs:label 'Condition Code' ;
    rdfs:comment 'Physical condition of the item upon receipt at the returns facility. Determines restocking eligibility and disposition path.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Extended Cost Amount' ;
    rdfs:comment 'Total cost value for this line (quantity × unit cost). Used for inventory and cost of goods sold adjustments.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extendedRetailAmount rdf:type rdf:Property ;
    rdfs:label 'Extended Retail Amount' ;
    rdfs:comment 'Total retail value for this line (quantity × unit retail price). Represents the total refund exposure for this line item.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidationSaleAmount rdf:type rdf:Property ;
    rdfs:label 'Liquidation Sale Amount' ;
    rdfs:comment 'Amount recovered from selling the returned item through liquidation channels (discount outlets, third-party liquidators, online auctions). Used to calculate net return loss.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityAuthorized rdf:type rdf:Property ;
    rdfs:label 'Quantity Authorized' ;
    rdfs:comment 'Number of units authorized for return on this RMA line. Represents the maximum quantity the customer is permitted to return.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'Actual number of units physically received back from the customer for this line item. May differ from quantity authorized.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restockingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Restocking Eligible Flag' ;
    rdfs:comment 'Indicates whether the returned item is in suitable condition to be restocked and resold. True if item can return to sellable inventory.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Vendor Credit Amount' ;
    rdfs:comment 'Credit amount expected or received from the vendor for this returned item. Used in accounts payable adjustments and vendor chargeback reconciliation.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnRequestId rdf:type rdf:Property ;
    rdfs:label 'Return Request Id' ;
    rdfs:comment 'Unique identifier for the return request. Primary key for the return request entity.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReturnRequest .

ind:pickupAddressId rdf:type rdf:Property ;
    rdfs:label 'Pickup Address Id' ;
    rdfs:comment 'Identifier of the address from which the return items should be picked up, if pickup was requested.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:customerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Email' ;
    rdfs:comment 'Email address provided by the customer for communication regarding this return request.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Phone' ;
    rdfs:comment 'Phone number provided by the customer for communication regarding this return request.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReasonCode rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for denial if the return request was rejected (e.g., outside return window, final sale item, missing proof of purchase, item condition not acceptable).' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Description' ;
    rdfs:comment 'Detailed explanation provided to the customer explaining why the return request was denied.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialTimestamp rdf:type rdf:Property ;
    rdfs:label 'Denial Timestamp' ;
    rdfs:comment 'Date and time when the return request was denied, if applicable.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Refund Amount' ;
    rdfs:comment 'Estimated monetary value of the refund if the return request is approved, calculated based on original purchase price and applicable return policy rules.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudRiskScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Risk Score' ;
    rdfs:comment 'Calculated risk score (0-100) indicating the likelihood that this return request is fraudulent, based on customer history, return patterns, and fraud detection algorithms.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isWithinReturnWindow rdf:type rdf:Property ;
    rdfs:label 'Is Within Return Window' ;
    rdfs:comment 'Boolean flag indicating whether the return request was submitted within the eligible return window defined by the applicable return policy.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Original Purchase Date' ;
    rdfs:comment 'Date when the original order was placed, used to validate return eligibility against return window policies.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pickupRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Pickup Requested Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer has requested carrier pickup of the return items from their location.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredResolutionType rdf:type rdf:Property ;
    rdfs:label 'Preferred Resolution Type' ;
    rdfs:comment 'Customer-indicated preference for how they would like the return to be resolved (refund to original payment method, exchange for different item, store credit, or replacement of same item).' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Human-readable business identifier for the return request, typically displayed to customers and service representatives. Format: RR followed by 10 digits.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the return request in the approval workflow.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Date and time when the customer initiated the return request. Represents the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnWindowExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Return Window Expiry Date' ;
    rdfs:comment 'Last date by which the return request must be submitted to be eligible under the applicable return policy (typically 30, 60, or 90 days from purchase).' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Internal notes added by the returns specialist during the review process, documenting decision rationale, policy exceptions, or special handling instructions.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseDueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Response Due Timestamp' ;
    rdfs:comment 'Target date and time by which the return request must be reviewed and responded to, based on applicable SLA (Service Level Agreement) commitments.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalItemsRequested rdf:type rdf:Property ;
    rdfs:label 'Total Items Requested' ;
    rdfs:comment 'Total count of distinct line items included in this return request.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalQuantityRequested rdf:type rdf:Property ;
    rdfs:label 'Total Quantity Requested' ;
    rdfs:comment 'Total quantity of units across all line items requested for return.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivingDepartmentId rdf:type rdf:Property ;
    rdfs:label 'Receiving Department Id' ;
    rdfs:comment 'Foreign key linking to store.department. Business justification: Returned goods received in-store are routed to a specific department (e.g., customer service, receiving dock). Department-level return volume reporting drives staffing decisions and shrinkage rate cal' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:authorizedQuantity rdf:type rdf:Property ;
    rdfs:label 'Authorized Quantity' ;
    rdfs:comment 'Total quantity of items authorized for return in the original RMA. Used to detect over-returns and under-returns.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Tracking Number' ;
    rdfs:comment 'Tracking number from the shipping carrier for mail-in or shipped returns. Used to reconcile carrier delivery events with physical receipt.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionAssessment rdf:type rdf:Property ;
    rdfs:label 'Condition Assessment' ;
    rdfs:comment 'Assessment of the physical condition of the returned merchandise at the time of receipt. Drives disposition decision and restocking eligibility. [ENUM-REF-CANDIDATE: new_unopened|like_new|good|fair|poor|damaged|defective|unsellable — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Free-text notes describing the nature of the discrepancy. Provides context for exception resolution and audit trail.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionRecommendation rdf:type rdf:Property ;
    rdfs:label 'Disposition Recommendation' ;
    rdfs:comment 'Recommended disposition action for the returned merchandise based on condition, value, and business rules. May be overridden by final disposition decision. [ENUM-REF-CANDIDATE: restock|liquidate|donate|destroy|rtv|repair|pending — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRecoveryValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Recovery Value' ;
    rdfs:comment 'Estimated financial recovery value of the returned merchandise based on condition and disposition recommendation. Used for financial planning and shrinkage analysis.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Completed Timestamp' ;
    rdfs:comment 'Date and time when detailed quality inspection was completed. Null if inspection not required or not yet performed.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Indicates whether detailed quality inspection is required before disposition. Triggered by high-value items, electronics, or condition concerns.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingCondition rdf:type rdf:Property ;
    rdfs:label 'Packaging Condition' ;
    rdfs:comment 'Condition of the product packaging at receipt. Impacts resale value and disposition options.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the quantity fields. Ensures consistent interpretation of quantity values across different product types. [ENUM-REF-CANDIDATE: each|case|pallet|pound|kilogram|liter|gallon — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Receipt Source System' ;
    rdfs:comment 'Name of the operational system that captured the return receipt event. Supports data lineage and reconciliation.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptSourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Receipt Source System Code' ;
    rdfs:comment 'Unique identifier of this receipt record in the source operational system. Enables traceability and reconciliation.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingLocationType rdf:type rdf:Property ;
    rdfs:label 'Receiving Location Type' ;
    rdfs:comment 'Type of facility that received the returned merchandise. Determines downstream processing workflows and disposition options.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Recovery Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated recovery value. Supports multi-currency operations.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundHoldReason rdf:type rdf:Property ;
    rdfs:label 'Refund Hold Reason' ;
    rdfs:comment 'Reason why customer refund is being held pending resolution. Null or none if refund processed immediately upon receipt.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Refund Triggered Flag' ;
    rdfs:comment 'Indicates whether the receipt event triggered a customer refund workflow. Links physical receipt to financial refund processing.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionId rdf:type rdf:Property ;
    rdfs:label 'Disposition Id' ;
    rdfs:comment 'Unique identifier for the disposition record. Primary key for the disposition entity.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Disposition .

ind:dispositionLiquidationPartnerVendorId rdf:type rdf:Property ;
    rdfs:label 'Disposition Liquidation Partner Vendor Id' ;
    rdfs:comment 'Identifier of the third-party liquidation partner if disposition type is liquidation. Tracks which liquidator handled the item for recovery value reconciliation.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:dispositionVendorId rdf:type rdf:Property ;
    rdfs:label 'Disposition Vendor Id' ;
    rdfs:comment 'Identifier of the vendor to whom the item will be returned if disposition type is return_to_vendor. Used for vendor compliance and credit processing.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:inventoryStockLedgerId rdf:type rdf:Property ;
    rdfs:label 'Inventory Stock Ledger Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_ledger. Business justification: Return dispositions (restock, liquidate, destroy) generate inventory transactions that should be tracked in the stock ledger. This links returns disposition decisions to inventory accounting. No visib' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockLedger .

ind:supplierRtvRequestId rdf:type rdf:Property ;
    rdfs:label 'Supplier Rtv Request Id' ;
    rdfs:comment 'Foreign key linking to supplier.rtv_request. Business justification: Disposition decisions (restock/RTV/liquidate) directly trigger supplier RTV requests. Loss prevention teams measure recovery rates by linking disposition outcomes to vendor credit receipts. Enables cl' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RtvRequest .

ind:actualRecoveryValue rdf:type rdf:Property ;
    rdfs:label 'Actual Recovery Value' ;
    rdfs:comment 'Realized financial recovery value after disposition execution. Populated after liquidation sale, vendor credit, or restock completion. Used for variance analysis against estimates.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date when the disposition action was fully executed (item restocked, shipped to vendor, transferred to liquidator, or destroyed). Used for cycle time measurement.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionGrade rdf:type rdf:Property ;
    rdfs:label 'Condition Grade' ;
    rdfs:comment 'Quality assessment grade assigned during inspection. A=New/Unopened, B=Like New/Minor Packaging Damage, C=Good/Visible Wear, D=Fair/Functional Defects, F=Unsellable/Damaged. Drives disposition type and recovery value estimation.' ;
    rdfs:domain ind:Returns ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'The date when the disposition decision was made by the returns processing team or system. Key timestamp for cycle time analytics.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Precise timestamp when the disposition decision was recorded in the system. Used for audit trail and process timing analysis.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:defectCode rdf:type rdf:Property ;
    rdfs:label 'Defect Code' ;
    rdfs:comment 'Standardized code identifying the specific defect or damage type found during inspection. Used for quality analytics and vendor chargeback justification.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Disposition Status' ;
    rdfs:comment 'Current lifecycle status of the disposition action. Tracks progress from decision through execution.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionType rdf:type rdf:Property ;
    rdfs:label 'Disposition Type' ;
    rdfs:comment 'The final fate decision for the returned item. Determines the next step in the reverse logistics workflow and impacts inventory valuation and recovery value.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSerialized rdf:type rdf:Property ;
    rdfs:label 'Is Serialized' ;
    rdfs:comment 'Flag indicating whether the item has a unique serial number requiring individual tracking through disposition process. Common for electronics and high-value goods.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restockingFeeApplied rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Applied' ;
    rdfs:comment 'Flag indicating whether a restocking fee was charged to the customer for this return. Impacts refund amount and customer satisfaction metrics.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundId rdf:type rdf:Property ;
    rdfs:label 'Refund Id' ;
    rdfs:comment 'Primary key for refund' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Actual Settlement Date' ;
    rdfs:comment 'Actual date when the refund funds were confirmed as settled and available to the customer. Used for SLA compliance measurement and financial reconciliation. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Additional positive or negative adjustment applied to the refund for reasons such as damage, missing components, promotional credits, or goodwill gestures.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Expected Settlement Date' ;
    rdfs:comment 'Anticipated date when the refund funds will be available to the customer in their account. Used for customer communication and service level agreement (SLA) tracking. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:merchandiseAmount rdf:type rdf:Property ;
    rdfs:label 'Merchandise Amount' ;
    rdfs:comment 'The gross value of returned merchandise being refunded, before any fees, taxes, or adjustments. Represents the base product value from the original transaction.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'Date and time when the refund was submitted to the payment processor for execution. Indicates when the financial transaction was initiated. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processorResponseCode rdf:type rdf:Property ;
    rdfs:label 'Processor Response Code' ;
    rdfs:comment 'Standardized response code returned by the payment processor indicating success, failure, or specific error condition. Used for operational monitoring and troubleshooting.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorResponseMessage rdf:type rdf:Property ;
    rdfs:label 'Processor Response Message' ;
    rdfs:comment 'Human-readable message from the payment processor providing additional context about the transaction result. Used for customer service and technical support.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundNumber rdf:type rdf:Property ;
    rdfs:label 'Refund Number' ;
    rdfs:comment 'Human-readable business identifier for the refund transaction. Used for customer communication, customer service lookup, and external reporting. Format: RFN-XXXXXXXXXX.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundStatus rdf:type rdf:Property ;
    rdfs:label 'Refund Status' ;
    rdfs:comment 'Current lifecycle status of the refund transaction. Tracks progression from initiation through final settlement or failure. Used for operational monitoring and customer service inquiries. [ENUM-REF-CANDIDATE: pending|approved|processing|completed|failed|reversed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundType rdf:type rdf:Property ;
    rdfs:label 'Refund Type' ;
    rdfs:comment 'Classification of the refund based on the portion of the original transaction being refunded and any adjustments applied.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockingFee rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee' ;
    rdfs:comment 'Fee deducted from the refund amount to cover costs of processing, inspecting, and restocking returned merchandise. Applied per return policy terms.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Total Refund Amount' ;
    rdfs:comment 'The final net amount refunded to the customer after all fees, taxes, and adjustments. This is the actual monetary value transferred back to the customer.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryExchangeHeaderId rdf:type rdf:Property ;
    rdfs:label 'Primary Exchange Header Id' ;
    rdfs:comment 'Reference to the original order from which the returned item originated.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:replacementSkuId rdf:type rdf:Property ;
    rdfs:label 'Replacement Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Exchange fulfillment requires direct replacement SKU reference for inventory allocation, ATP (available-to-promise) checking, and like-for-like exchange policy enforcement. Essential for retail exchan' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:replacementSkuPriceId rdf:type rdf:Property ;
    rdfs:label 'Replacement Sku Price Id' ;
    rdfs:comment 'Foreign key linking to pricing.sku_price. Business justification: Exchange orders require the replacement SKU\'s current sku_price to compute the price differential the customer owes or is owed. price_differential_amount is denormalized from sku_price comparison. Ret' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuPrice .

ind:exchangeApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exchange Approved Timestamp' ;
    rdfs:comment 'Date and time when the exchange request was approved by the returns management system or customer service representative.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exchange Completed Timestamp' ;
    rdfs:comment 'Date and time when the entire exchange transaction was finalized, including receipt of returned item and delivery of replacement.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeDeliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exchange Delivered Timestamp' ;
    rdfs:comment 'Date and time when the replacement item was successfully delivered to the customer.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Initiated Date' ;
    rdfs:comment 'Date when the customer first requested the exchange, typically when the RMA was created.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Exchange Order Number' ;
    rdfs:comment 'Human-readable business identifier for the exchange order, used for customer communication and tracking.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Exchange Order Status' ;
    rdfs:comment 'Current lifecycle status of the exchange order in the fulfillment workflow. [ENUM-REF-CANDIDATE: pending|approved|processing|shipped|delivered|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Exchange Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason the customer requested an exchange rather than a refund.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Exchange Reason Description' ;
    rdfs:comment 'Free-text description providing additional context about why the customer requested an exchange.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeShippedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exchange Shipped Timestamp' ;
    rdfs:comment 'Date and time when the replacement item was shipped to the customer.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeType rdf:type rdf:Property ;
    rdfs:label 'Exchange Type' ;
    rdfs:comment 'Classification of the exchange based on the relationship between returned and replacement items.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expeditedShippingFlag rdf:type rdf:Property ;
    rdfs:label 'Expedited Shipping Flag' ;
    rdfs:comment 'Indicates whether expedited shipping was used for the replacement item delivery.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceDifferentialCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Price Differential Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the price differential amount.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementQuantity rdf:type rdf:Property ;
    rdfs:label 'Replacement Quantity' ;
    rdfs:comment 'Number of units of the replacement SKU being sent to the customer.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnedSku rdf:type rdf:Property ;
    rdfs:label 'Returned Sku' ;
    rdfs:comment 'SKU of the product being returned by the customer as part of the exchange.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCostWaivedFlag rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost Waived Flag' ;
    rdfs:comment 'Indicates whether shipping costs for the replacement item have been waived as a customer service gesture.' ;
    rdfs:domain ind:ExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptedCondition rdf:type rdf:Property ;
    rdfs:label 'Accepted Condition' ;
    rdfs:comment 'Required condition of merchandise for return acceptance. Defines whether items must be unopened, unused, or can be returned in any condition.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeAllowed rdf:type rdf:Property ;
    rdfs:label 'Exchange Allowed' ;
    rdfs:comment 'Indicates whether direct product exchanges (size, color, model) are permitted under this policy without requiring a full return and repurchase.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extendedWindowDays rdf:type rdf:Property ;
    rdfs:label 'Extended Window Days' ;
    rdfs:comment 'Extended return window duration for premium loyalty tier members or special promotional periods. Nullable if no extension applies.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holidayExtensionApplicable rdf:type rdf:Property ;
    rdfs:label 'Holiday Extension Applicable' ;
    rdfs:comment 'Indicates whether this policy includes extended return windows for holiday season purchases (e.g., purchases made in November-December returnable through mid-January).' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionSlaHours rdf:type rdf:Property ;
    rdfs:label 'Inspection Sla Hours' ;
    rdfs:comment 'Target time in hours for completing merchandise inspection and condition assessment after return receipt. Used for operational SLA measurement.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:liquidationEligible rdf:type rdf:Property ;
    rdfs:label 'Liquidation Eligible' ;
    rdfs:comment 'Indicates whether returned merchandise under this policy can be sent to liquidation channels (discount outlets, bulk resellers) for recovery.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonReturnableItemExceptions rdf:type rdf:Property ;
    rdfs:label 'Non Returnable Item Exceptions' ;
    rdfs:comment 'Comma-separated list of item types or SKU patterns that are explicitly excluded from returns under this policy (e.g., perishables, intimate apparel, custom orders, clearance items).' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalPackagingRequired rdf:type rdf:Property ;
    rdfs:label 'Original Packaging Required' ;
    rdfs:comment 'Indicates whether the item must be returned in its original packaging for acceptance. Common for electronics and high-value items.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Business identifier for the return policy, used in operational systems and customer communications. Unique alphanumeric code.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Detailed text description of the return policy terms and conditions, including any special provisions, exclusions, or customer-facing language.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Human-readable name of the return policy (e.g., \'Standard 30-Day Return\', \'Electronics Extended Return\', \'Final Sale No Return\').' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the return policy indicating the policy category and applicability scope.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyUrl rdf:type rdf:Property ;
    rdfs:label 'Policy Url' ;
    rdfs:comment 'Web URL where the full return policy terms are published for customer reference. Required for e-commerce compliance.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfPurchaseRequired rdf:type rdf:Property ;
    rdfs:label 'Proof Of Purchase Required' ;
    rdfs:comment 'Indicates whether proof of purchase (receipt, order confirmation, transaction lookup) is mandatory for return processing.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundProcessingSlaHours rdf:type rdf:Property ;
    rdfs:label 'Refund Processing Sla Hours' ;
    rdfs:comment 'Target time in hours for completing refund processing from return acceptance to funds disbursement. Used for operational SLA measurement.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restockingFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Applicable' ;
    rdfs:comment 'Indicates whether a restocking fee is charged for returns under this policy. Common for high-value electronics and special-order items.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restockingFeeFlatAmount rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Flat Amount' ;
    rdfs:comment 'Fixed dollar amount charged as a restocking fee, regardless of purchase price. Nullable if percentage-based or no fee applies.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restockingFeePercent rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Percent' ;
    rdfs:comment 'Percentage of the original purchase price charged as a restocking fee. Nullable if no restocking fee applies. Typical range is 10-25%.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restockingSlaHours rdf:type rdf:Property ;
    rdfs:label 'Restocking Sla Hours' ;
    rdfs:comment 'Target time in hours for restocking accepted returned merchandise back into available inventory. Used for operational SLA measurement.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnPolicyStatus rdf:type rdf:Property ;
    rdfs:label 'Return Policy Status' ;
    rdfs:comment 'Current lifecycle status of the return policy. Only active policies are applied to new transactions.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnWindowDays rdf:type rdf:Property ;
    rdfs:label 'Return Window Days' ;
    rdfs:comment 'Number of days from purchase date during which a return is accepted under this policy. Standard retail windows range from 14 to 90 days.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmaAutoApprovalEnabled rdf:type rdf:Property ;
    rdfs:label 'Rma Auto Approval Enabled' ;
    rdfs:comment 'Indicates whether RMA requests are automatically approved based on policy rules without manual review. Drives automated return authorization logic.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'Sales channel(s) to which this return policy applies. Policies may vary by channel (e.g., online purchases may have different return windows than in-store). [ENUM-REF-CANDIDATE: in_store|online|mobile_app|bopis|ropis|call_center|all_channels — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCreditExpiryDays rdf:type rdf:Property ;
    rdfs:label 'Store Credit Expiry Days' ;
    rdfs:comment 'Number of days until store credit issued for returns expires. Nullable if store credit does not expire. Subject to state-specific gift card laws.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorReturnEligible rdf:type rdf:Property ;
    rdfs:label 'Vendor Return Eligible' ;
    rdfs:comment 'Indicates whether merchandise returned under this policy is eligible for Return to Vendor (RTV) processing to recover costs from suppliers.' ;
    rdfs:domain ind:ReturnPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restockEventId rdf:type rdf:Property ;
    rdfs:label 'Restock Event Id' ;
    rdfs:comment 'Unique identifier for the restock event. Primary key for this operational record capturing the restocking of a returned item back into sellable or clearance inventory.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restockLocationId rdf:type rdf:Property ;
    rdfs:label 'Restock Location Id' ;
    rdfs:comment 'Reference to the specific store, distribution center, or fulfillment node where the item was restocked into inventory. Links to the location master data.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:aisleNumber rdf:type rdf:Property ;
    rdfs:label 'Aisle Number' ;
    rdfs:comment 'The aisle identifier where the restocked item was placed on the sales floor or in the warehouse. Supports store operations and inventory locating.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'The specific bin, shelf, or storage location identifier within the warehouse or store where the item was placed during restocking. Used for precise inventory tracking and picking operations.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCompleted rdf:type rdf:Property ;
    rdfs:label 'Inspection Completed' ;
    rdfs:comment 'Boolean flag indicating whether required quality inspection has been completed for the restocked item. True when inspection is finished and item is cleared for sale.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Required' ;
    rdfs:comment 'Boolean flag indicating whether the restocked item requires additional quality inspection before being made available for sale. True for items with condition concerns or regulatory requirements.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'The date and time when quality inspection was completed for the restocked item. Null if no inspection was required or inspection is still pending.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inventoryAdjustmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inventory Adjustment Timestamp' ;
    rdfs:comment 'The date and time when the inventory adjustment transaction was posted to the WMS and inventory systems. May differ from restock_timestamp if there is a processing delay.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'The inventory status assigned to the restocked item. Determines whether the item is available for sale at full price, marked for clearance, held for inspection, or quarantined.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalCost rdf:type rdf:Property ;
    rdfs:label 'Original Cost' ;
    rdfs:comment 'The original cost of goods sold (COGS) for the restocked item. Used for inventory valuation and financial reconciliation of returned merchandise.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRestocked rdf:type rdf:Property ;
    rdfs:label 'Quantity Restocked' ;
    rdfs:comment 'The quantity of units restocked back into inventory in this event. Supports fractional quantities for items sold by weight or volume.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restockLocationType rdf:type rdf:Property ;
    rdfs:label 'Restock Location Type' ;
    rdfs:comment 'The type of facility where the item was restocked. Indicates whether restocking occurred at a retail store, distribution center (DC), micro-fulfillment center (MFC), dark store, or was returned to vendor.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockReasonCode rdf:type rdf:Property ;
    rdfs:label 'Restock Reason Code' ;
    rdfs:comment 'The reason code explaining why this item was restocked. Distinguishes between customer returns that passed inspection, vendor returns, warranty exchanges, and other restock scenarios.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockTimestamp rdf:type rdf:Property ;
    rdfs:label 'Restock Timestamp' ;
    rdfs:comment 'The date and time when the restocking action was completed and the item was placed back into available inventory. This is the principal business event timestamp for the restock transaction.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restockedValue rdf:type rdf:Property ;
    rdfs:label 'Restocked Value' ;
    rdfs:comment 'The inventory value assigned to the restocked item after any markdown or condition adjustment. Represents the expected recoverable value of the returned merchandise.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfPosition rdf:type rdf:Property ;
    rdfs:label 'Shelf Position' ;
    rdfs:comment 'The specific shelf or position identifier within the aisle where the item was restocked. Enables precise planogram compliance and inventory locating.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Reference' ;
    rdfs:comment 'The unique transaction identifier from the source system that generated this restock event. Enables traceability back to the originating system record for audit and reconciliation.' ;
    rdfs:domain ind:RestockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCreditId rdf:type rdf:Property ;
    rdfs:label 'Store Credit Id' ;
    rdfs:comment 'Unique identifier for the store credit instrument. Primary key.' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuingStorefrontId rdf:type rdf:Property ;
    rdfs:label 'Issuing Storefront Id' ;
    rdfs:comment 'Foreign key linking to ecommerce.storefront. Business justification: Store credit issued by a specific e-commerce storefront carries channel-specific redemption restrictions (store_credit.redemption_channel_restriction). Linking to the issuing storefront enables channe' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Storefront .

ind:breakageEstimateAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Breakage Estimate Applied Flag' ;
    rdfs:comment 'Indicates whether a breakage revenue estimate (expected non-redemption) has been applied to this store credit for financial reporting purposes under ASC 606.' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditCode rdf:type rdf:Property ;
    rdfs:label 'Credit Code' ;
    rdfs:comment 'Externally-visible unique alphanumeric code printed on the store credit instrument or provided digitally. Used for redemption at POS or e-commerce checkout.' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditType rdf:type rdf:Property ;
    rdfs:label 'Credit Type' ;
    rdfs:comment 'Classification of the reason or business context for issuing this store credit. Distinguishes between return-driven credits, promotional incentives, and service recovery gestures.' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escheatmentDate rdf:type rdf:Property ;
    rdfs:label 'Escheatment Date' ;
    rdfs:comment 'Calendar date on which the unredeemed balance must be reported and remitted to the state as unclaimed property. Null if not subject to escheatment.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escheatmentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Escheatment Eligible Flag' ;
    rdfs:comment 'Indicates whether the unredeemed balance is subject to state escheatment (unclaimed property) laws. Supports regulatory compliance for abandoned store credits.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuedAmount rdf:type rdf:Property ;
    rdfs:label 'Issued Amount' ;
    rdfs:comment 'Original monetary value of the store credit at the time of issuance. Represents the full stored-value balance before any redemptions.' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pinCode rdf:type rdf:Property ;
    rdfs:label 'Pin Code' ;
    rdfs:comment 'Optional security PIN required for redemption of the store credit. Protects against unauthorized use if the credit code is compromised.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionChannelRestriction rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel Restriction' ;
    rdfs:comment 'Policy constraint on where the store credit can be redeemed. Supports business rules for channel-specific credits.' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance' ;
    rdfs:comment 'Current unredeemed monetary value available on the store credit. Decreases with each partial redemption until fully redeemed or expired.' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storeCreditStatus rdf:type rdf:Property ;
    rdfs:label 'Store Credit Status' ;
    rdfs:comment 'Current lifecycle state of the store credit. Tracks progression from issuance through redemption, expiration, or voiding. [ENUM-REF-CANDIDATE: issued|active|partially_redeemed|fully_redeemed|expired|voided|suspended — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferableFlag rdf:type rdf:Property ;
    rdfs:label 'Transferable Flag' ;
    rdfs:comment 'Indicates whether the store credit can be transferred or gifted to another customer. False means the credit is locked to the original recipient.' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:voidDate rdf:type rdf:Property ;
    rdfs:label 'Void Date' ;
    rdfs:comment 'Calendar date on which the store credit was voided. Null if the credit has not been voided.' ;
    rdfs:domain ind:StoreCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewedFromLicenseId rdf:type rdf:Property ;
    rdfs:label 'Renewed From License Id' ;
    rdfs:comment 'Self-referencing FK on license (renewed_from_license_id)' ;
    rdfs:domain ind:License ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:License .

ind:inspectionFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Months' ;
    rdfs:comment 'Number of months between required regulatory inspections. Used to calculate next inspection due dates.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent regulatory inspection conducted for this license. Tracks compliance verification cadence.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastViolationDate rdf:type rdf:Property ;
    rdfs:label 'Last Violation Date' ;
    rdfs:comment 'Date of the most recent violation or citation issued for this license. Used for risk assessment and compliance monitoring.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Date by which the next regulatory inspection must be completed to maintain license compliance.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reinstatementConditions rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Conditions' ;
    rdfs:comment 'Conditions or requirements that must be met for the license to be reinstated after suspension or revocation.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Eligible Flag' ;
    rdfs:comment 'Indicates whether the license is eligible for reinstatement after suspension or revocation. True if reinstatement is possible, False otherwise.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Lead Time Days' ;
    rdfs:comment 'Number of days before expiration that the renewal process must be initiated to ensure continuity. Supports automated renewal alerting.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'Date the license was permanently revoked by the regulatory authority. Populated only when license_status is revoked.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Reason provided by the regulatory authority for revoking the license. Populated only when license_status is revoked.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Reference' ;
    rdfs:comment 'Reference identifier or URL to the scanned license document, certificate, or permit stored in the document management system.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'Date the license suspension is scheduled to end or was lifted. Nullable if suspension is indefinite.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'Date the license suspension became effective. Populated only when license_status is suspended.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:violationCount rdf:type rdf:Property ;
    rdfs:label 'Violation Count' ;
    rdfs:comment 'Total number of violations or citations issued against this license since its issue date. Tracks compliance history.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseUomId rdf:type rdf:Property ;
    rdfs:label 'Base Uom Id' ;
    rdfs:comment 'Self-referencing FK on uom (base_uom_id)' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Uom .

ind:gs1UomCode rdf:type rdf:Property ;
    rdfs:label 'Gs1 Uom Code' ;
    rdfs:comment 'Standardized GS1 unit of measure code used for Electronic Data Interchange (EDI) and global supply chain interoperability. Maps internal UOM codes to GS1 standards.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inverseConversionFactor rdf:type rdf:Property ;
    rdfs:label 'Inverse Conversion Factor' ;
    rdfs:comment 'Reciprocal of the conversion factor, used for reverse conversions from base unit to this unit. Calculated as 1 divided by conversion_factor.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFractionalAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Fractional Allowed' ;
    rdfs:comment 'Boolean flag indicating whether fractional quantities are permitted for this unit of measure (True for weight/volume units like pounds or liters, False for discrete count units like cases or pallets).' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInventoryTracked rdf:type rdf:Property ;
    rdfs:label 'Is Inventory Tracked' ;
    rdfs:comment 'Boolean flag indicating whether inventory quantities are tracked and managed in this unit of measure (True if used in Warehouse Management System (WMS) and inventory systems, False if conversion-only).' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrderable rdf:type rdf:Property ;
    rdfs:label 'Is Orderable' ;
    rdfs:comment 'Boolean flag indicating whether this unit of measure can be used for purchase order creation and supplier ordering (True if valid for procurement, False if display-only or internal-use).' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoUomCode rdf:type rdf:Property ;
    rdfs:label 'Iso Uom Code' ;
    rdfs:comment 'International Organization for Standardization (ISO) unit code per ISO 80000 and ISO 31 standards, ensuring global consistency in measurement representation.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precisionDecimalPlaces rdf:type rdf:Property ;
    rdfs:label 'Precision Decimal Places' ;
    rdfs:comment 'Number of decimal places to which quantities in this unit of measure should be rounded for display and calculation purposes (e.g., 0 for whole units like cases, 2 for currency-like precision, 3 for weight measurements).' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByUomCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Uom Code' ;
    rdfs:comment 'Code of the replacement unit of measure that supersedes this one when deprecated. Used to maintain continuity during UOM transitions and system migrations.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:symbol rdf:type rdf:Property ;
    rdfs:label 'Symbol' ;
    rdfs:comment 'Standard abbreviated symbol for the unit of measure (e.g., kg for kilogram, lb for pound, L for liter, oz for ounce). Used in labels, reports, and user interfaces.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uneceCode rdf:type rdf:Property ;
    rdfs:label 'Unece Code' ;
    rdfs:comment 'United Nations Economic Commission for Europe (UN/ECE) Recommendation 20 unit code, widely used in international trade and customs documentation.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomClass rdf:type rdf:Property ;
    rdfs:label 'Uom Class' ;
    rdfs:comment 'Classification of the unit of measure by measurement type: weight (mass), volume (capacity), count (discrete units), length (distance), area (surface), or time (duration).' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomDescription rdf:type rdf:Property ;
    rdfs:label 'Uom Description' ;
    rdfs:comment 'Detailed description of the unit of measure, including usage context and business rules for application across retail operations.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomName rdf:type rdf:Property ;
    rdfs:label 'Uom Name' ;
    rdfs:comment 'Full descriptive name of the unit of measure (e.g., Each, Case, Pound, Kilogram, Liter, Ounce, Pallet).' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomType rdf:type rdf:Property ;
    rdfs:label 'Uom Type' ;
    rdfs:comment 'Functional type indicating the primary business context where this UOM is used: base (fundamental unit), alternate (conversion unit), display (customer-facing), ordering (procurement), inventory (stock tracking), pricing (selling unit), or shipping (logistics). [ENUM-REF-CANDIDATE: base|alternate|display|ordering|inventory|pricing|shipping — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageContext rdf:type rdf:Property ;
    rdfs:label 'Usage Context' ;
    rdfs:comment 'Textual description of the business contexts and operational scenarios where this unit of measure is typically applied (e.g., used for bulk ordering of dry goods, used for pricing fresh produce, used for shipping pallet quantities).' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryGiftProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Gift Profile Id' ;
    rdfs:comment 'Identifier of the customer who purchased the gift card. May differ from the recipient. Nullable if purchased anonymously or by guest.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:primaryReplacementForCardGiftCardId rdf:type rdf:Property ;
    rdfs:label 'Primary Replacement For Card Gift Card Id' ;
    rdfs:comment 'Identifier of the original gift card that this card replaces (e.g., lost or damaged card replacement). Nullable for original issuances. Balance is typically transferred from original card.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GiftCard .

ind:cardNumber rdf:type rdf:Property ;
    rdfs:label 'Card Number' ;
    rdfs:comment 'Unique card number printed or encoded on the gift card. Typically 16-19 digits. Used for identification and redemption at Point of Sale (POS) or e-commerce checkout.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardStatus rdf:type rdf:Property ;
    rdfs:label 'Card Status' ;
    rdfs:comment 'Current lifecycle status of the gift card. Inactive: issued but not yet activated; Active: available for use; Suspended: temporarily blocked; Expired: past validity period; Depleted: balance fully redeemed; Cancelled: voided or returned.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardType rdf:type rdf:Property ;
    rdfs:label 'Card Type' ;
    rdfs:comment 'Type of gift card instrument. Physical cards are tangible plastic cards; digital/virtual cards are delivered electronically via email or app; mobile wallet cards are provisioned into digital wallets (Apple Pay, Google Pay).' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'Remaining monetary value available on the gift card after all redemptions, adjustments, and fees. Updated in real-time with each transaction.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudReasonCode rdf:type rdf:Property ;
    rdfs:label 'Fraud Reason Code' ;
    rdfs:comment 'Code indicating the reason for fraud flag (e.g., STOLEN, COUNTERFEIT, BALANCE_TAMPERING, SUSPICIOUS_ACTIVITY). Nullable if fraud_flag is false.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialBalance rdf:type rdf:Property ;
    rdfs:label 'Initial Balance' ;
    rdfs:comment 'Original monetary value loaded onto the gift card at the time of issuance or purchase. Represents the starting balance before any redemptions or adjustments.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuingChannel rdf:type rdf:Property ;
    rdfs:label 'Issuing Channel' ;
    rdfs:comment 'Sales channel through which the gift card was originally issued or purchased. Store: in-store POS; Ecommerce: online storefront; Mobile App: mobile commerce; Call Center: phone order; Corporate Sales: bulk B2B sales; Third Party: external marketplace or partner.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qrCode rdf:type rdf:Property ;
    rdfs:label 'Qr Code' ;
    rdfs:comment 'Quick Response (QR) code data for mobile wallet provisioning or contactless redemption. Encoded with card number and validation data.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientEmail rdf:type rdf:Property ;
    rdfs:label 'Recipient Email' ;
    rdfs:comment 'Email address of the gift card recipient. Used for digital card delivery and balance notifications. Required for digital/virtual cards.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientPhone rdf:type rdf:Property ;
    rdfs:label 'Recipient Phone' ;
    rdfs:comment 'Phone number of the gift card recipient. Used for SMS delivery of digital cards and balance inquiries.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reloadCount rdf:type rdf:Property ;
    rdfs:label 'Reload Count' ;
    rdfs:comment 'Total number of times the gift card has been reloaded with additional funds since issuance. Zero for non-reloadable or never-reloaded cards.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reloadableFlag rdf:type rdf:Property ;
    rdfs:label 'Reloadable Flag' ;
    rdfs:comment 'Indicates whether the gift card can be reloaded with additional funds after initial issuance. True: reloadable; False: single-load only.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsAndConditionsVersion rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Version' ;
    rdfs:comment 'Version identifier of the terms and conditions that govern this gift card (e.g., expiration policy, fee schedule, usage restrictions). Used for compliance and customer service.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFeesCharged rdf:type rdf:Property ;
    rdfs:label 'Total Fees Charged' ;
    rdfs:comment 'Cumulative fees deducted from the gift card balance (e.g., dormancy fees, maintenance fees, replacement fees). Subject to regulatory restrictions (e.g., CARD Act limits dormancy fees).' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRedeemedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Redeemed Amount' ;
    rdfs:comment 'Cumulative monetary value redeemed from the gift card across all transactions since activation. Equals initial_balance + total_reloaded_amount - current_balance - total_fees.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReloadedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Reloaded Amount' ;
    rdfs:comment 'Cumulative monetary value added to the gift card through all reload transactions since issuance. Excludes initial balance.' ;
    rdfs:domain ind:GiftCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewedFromSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Renewed From Subscription Id' ;
    rdfs:comment 'Self-referencing FK on subscription (renewed_from_subscription_id)' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscription .

ind:revenueGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Revenue Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Subscription revenue recognition requires GL account assignment for deferred revenue, recognized revenue, and ASC 606 compliance. Role-prefixed to distinguish from potential expense or liability GL ac' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'Frequency at which the customer is charged for the subscription: per_delivery for charges with each order, monthly for monthly billing regardless of delivery frequency, quarterly for every 3 months, annual for yearly billing, or upfront for prepaid subscriptions.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Description' ;
    rdfs:comment 'Free-text explanation of the subscription cancellation reason, providing additional context beyond the standardized code.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Frequency Days' ;
    rdfs:comment 'Numeric representation of the delivery interval in days. Used for custom frequencies and precise scheduling calculations.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalSubscriptionCode rdf:type rdf:Property ;
    rdfs:label 'External Subscription Code' ;
    rdfs:comment 'Subscription identifier from the source system or external platform, used for cross-system reconciliation and integration.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftSubscriptionFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Subscription Flag' ;
    rdfs:comment 'Indicates whether this subscription was purchased as a gift for another person. True for gift subscriptions, false for self-purchased subscriptions.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Last Delivery Date' ;
    rdfs:comment 'Date when the most recent subscription order was delivered to the customer. Null if no deliveries have occurred yet.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Next Delivery Date' ;
    rdfs:comment 'Date when the next subscription order is scheduled to be fulfilled and shipped to the customer.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pauseEndDate rdf:type rdf:Property ;
    rdfs:label 'Pause End Date' ;
    rdfs:comment 'Date when a paused subscription is scheduled to resume. Null for indefinite pauses or active subscriptions.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pauseStartDate rdf:type rdf:Property ;
    rdfs:label 'Pause Start Date' ;
    rdfs:comment 'Date when the subscription was paused. Null if the subscription has never been paused or is currently active.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:skipNextDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Skip Next Delivery Flag' ;
    rdfs:comment 'Indicates whether the customer has requested to skip the next scheduled delivery. True when the upcoming order should be skipped, false for normal delivery processing.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subscriptionNumber rdf:type rdf:Property ;
    rdfs:label 'Subscription Number' ;
    rdfs:comment 'Human-readable business identifier for the subscription, used in customer communications and service interactions.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Subscription Status' ;
    rdfs:comment 'Current lifecycle state of the subscription: active for ongoing subscriptions, paused for temporarily suspended deliveries, cancelled for terminated subscriptions, expired for subscriptions past their end date, pending_activation for new subscriptions awaiting first order, or suspended for subscriptions on hold due to payment or compliance issues.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionType rdf:type rdf:Property ;
    rdfs:label 'Subscription Type' ;
    rdfs:comment 'Classification of the subscription model: subscribe-and-save for recurring product delivery, auto-replenishment for inventory-triggered orders, meal kit for prepared meal subscriptions, curated box for personalized selections, membership for access-based subscriptions, or service plan for ongoing service contracts.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDeliveriesCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Deliveries Completed' ;
    rdfs:comment 'Cumulative count of subscription orders that have been successfully delivered to the customer since subscription inception.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDeliveriesSkipped rdf:type rdf:Property ;
    rdfs:label 'Total Deliveries Skipped' ;
    rdfs:comment 'Cumulative count of scheduled deliveries that were skipped at the customer\'s request or due to system holds.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentLotId rdf:type rdf:Property ;
    rdfs:label 'Parent Lot Id' ;
    rdfs:comment 'Self-referencing FK on lot (parent_lot_id)' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'Current quantity available for sale or allocation from this lot. Decreases as units are sold or reserved.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bestBeforeDate rdf:type rdf:Property ;
    rdfs:label 'Best Before Date' ;
    rdfs:comment 'Date indicating optimal quality period. Product may still be safe after this date but quality may degrade. Distinct from expiry date.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationCode rdf:type rdf:Property ;
    rdfs:label 'Certification Code' ;
    rdfs:comment 'Product certification or compliance code for the lot. Examples: organic, kosher, halal, fair trade, non-GMO. Supports labeling and marketing claims.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fefoSequence rdf:type rdf:Property ;
    rdfs:label 'Fefo Sequence' ;
    rdfs:comment 'Sequence number for FEFO picking logic. Lower numbers indicate earlier expiry and should be picked first to minimize waste.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Status' ;
    rdfs:comment 'Current lifecycle status of the lot. Determines whether the lot is available for sale, held for quality inspection, or restricted. [ENUM-REF-CANDIDATE: available|quarantine|hold|released|expired|recalled|disposed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date when the product lot was manufactured or produced. Critical for shelf life calculation and food safety compliance.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Status' ;
    rdfs:comment 'Quality inspection outcome for the lot. Approved lots are available for sale; rejected lots must be returned or disposed.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Reference Number' ;
    rdfs:comment 'Official recall case or reference number issued by regulatory authority or manufacturer. Links to recall management system.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Remaining Shelf Life Days' ;
    rdfs:comment 'Number of days remaining until expiry as of the current date. Calculated field used for near-expiry alerts and markdown triggers.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierLotReference rdf:type rdf:Property ;
    rdfs:label 'Supplier Lot Reference' ;
    rdfs:comment 'Supplier\'s original lot or batch identifier. Used for traceability back to the supplier\'s manufacturing records.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerMembershipId rdf:type rdf:Property ;
    rdfs:label 'Customer Membership Id' ;
    rdfs:comment 'Primary key for customer_membership' ;
    rdfs:domain ind:CustomerMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrollmentLocationId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Location Id' ;
    rdfs:comment 'Foreign key linking to store.location. Business justification: Retail loyalty programs track the enrolling store location for attribution reporting, localized loyalty benefit activation, and store-level membership KPIs. The enrollment store is a distinct business' ;
    rdfs:domain ind:CustomerMembership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:assignmentConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Assignment Confidence Score' ;
    rdfs:comment 'Confidence score (0.00-100.00) indicating the strength of this customer\'s qualification for this segment. For rule-based assignments, reflects how strongly the customer meets qualification criteria. For ML-based assignments, reflects model prediction confidence. Used for prioritizing marketing outreach and identifying borderline members.' ;
    rdfs:domain ind:CustomerMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'Mechanism by which this customer was assigned to this segment. AutoRefresh: automatically assigned via scheduled segment refresh process. ManualOverride: manually assigned by business user overriding qualification rules. RuleEngine: assigned via real-time rule evaluation. MLModel: assigned via predictive model scoring. BulkImport: assigned via batch data load.' ;
    rdfs:domain ind:Retail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerMembershipStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Membership Status' ;
    rdfs:comment 'Current operational status of this segment membership. Active: customer currently qualifies and membership is in effect. Expired: membership ended due to disqualification or time-based expiry. Suspended: temporarily inactive due to business rules. PendingQualification: awaiting next refresh cycle to confirm eligibility.' ;
    rdfs:domain ind:CustomerMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastQualificationCheckDate rdf:type rdf:Property ;
    rdfs:label 'Last Qualification Check Date' ;
    rdfs:comment 'Timestamp of the most recent evaluation of this customer\'s eligibility for this segment. Updated during auto-refresh cycles or manual re-qualification checks. Used for audit trails and determining when next qualification check is due.' ;
    rdfs:domain ind:CustomerMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manualOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Manual Override Flag' ;
    rdfs:comment 'Boolean flag indicating whether this membership was manually assigned by a business user, overriding automated qualification rules. True: manual override in effect, customer may not meet standard qualification criteria. False: standard rule-based or automated assignment. Used for governance and audit purposes.' ;
    rdfs:domain ind:CustomerMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text explanation provided by business user when manual_override_flag is true. Documents business justification for overriding automated qualification rules (e.g., \'VIP customer per executive request\', \'Strategic account exception\', \'Retention offer\'). Null when no override is in effect.' ;
    rdfs:domain ind:CustomerMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPriority rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority' ;
    rdfs:comment 'Priority ranking for inventory allocation when supply is constrained. Lower numbers indicate higher priority (1 = highest priority). Used by allocation engines to determine which nodes receive inventory first during shortages. Typically based on sales velocity, strategic importance, or customer service level agreements.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Effective Date' ;
    rdfs:comment 'Date when this SKU was first authorized to be stocked at this node. Marks the beginning of the assortment assignment. Used for assortment history tracking and performance analysis.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'Date when this SKU was removed from the authorized assortment at this node. Null for currently active assignments. Used for assortment history and discontinued product tracking.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Last Received Date' ;
    rdfs:comment 'Date when this SKU was last received into inventory at this node. Used to identify slow-moving or stale inventory, support FIFO/FEFO rotation, and flag potential obsolescence. Updated by warehouse management system upon receipt confirmation.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Max Stock Quantity' ;
    rdfs:comment 'Maximum inventory quantity that should be stocked at this node for this SKU. Prevents overstocking and ensures efficient use of storage capacity. Set based on storage constraints, demand forecasts, and inventory turn targets. Node-specific based on storage capacity and sales velocity.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Min Stock Quantity' ;
    rdfs:comment 'Minimum inventory quantity that should be maintained at this node for this SKU. Triggers replenishment when on-hand inventory falls below this threshold. Set based on lead time demand, safety stock calculations, and service level targets. Node-specific based on local demand patterns.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stockingStatus rdf:type rdf:Property ;
    rdfs:label 'Stocking Status' ;
    rdfs:comment 'Current stocking status of this SKU at this specific node. ACTIVE (currently stocked and replenished), DISCONTINUED (no longer carried at this location), SEASONAL (stocked only during specific seasons), CLEARANCE (final inventory selldown), PENDING_SETUP (authorized but not yet received), TEMPORARY_OUT (temporarily not stocked). This is node-specific and can differ from the SKU\'s global lifecycle_status.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentLedgerId rdf:type rdf:Property ;
    rdfs:label 'Parent Ledger Id' ;
    rdfs:comment 'Self-referencing FK on ledger (parent_ledger_id)' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ledger .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'The accounting standard or framework that governs this ledger (e.g., US GAAP, IFRS).' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationVersion rdf:type rdf:Property ;
    rdfs:label 'Consolidation Version' ;
    rdfs:comment 'Version identifier for consolidation scenarios when this ledger is used for group reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConsolidationLedger rdf:type rdf:Property ;
    rdfs:label 'Is Consolidation Ledger' ;
    rdfs:comment 'Boolean flag indicating whether this ledger is used for group consolidation and intercompany elimination purposes.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeadingLedger rdf:type rdf:Property ;
    rdfs:label 'Is Leading Ledger' ;
    rdfs:comment 'Boolean flag indicating whether this is the primary leading ledger for the organization (true) or a secondary/parallel ledger (false).' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastClosedDate rdf:type rdf:Property ;
    rdfs:label 'Last Closed Date' ;
    rdfs:comment 'The date when the most recent period close was completed for this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastClosedPeriod rdf:type rdf:Property ;
    rdfs:label 'Last Closed Period' ;
    rdfs:comment 'The most recent fiscal period (YYYYMM format) that has been closed in this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerCategory rdf:type rdf:Property ;
    rdfs:label 'Ledger Category' ;
    rdfs:comment 'High-level categorization of the ledger based on reporting purpose and accounting framework alignment.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerCode rdf:type rdf:Property ;
    rdfs:label 'Ledger Code' ;
    rdfs:comment 'Unique business identifier code for the ledger used in financial reporting and system integration.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerDescription rdf:type rdf:Property ;
    rdfs:label 'Ledger Description' ;
    rdfs:comment 'Detailed textual description of the ledger purpose, scope, and usage within the financial reporting framework.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerName rdf:type rdf:Property ;
    rdfs:label 'Ledger Name' ;
    rdfs:comment 'Full descriptive name of the ledger for human-readable identification.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerStatus rdf:type rdf:Property ;
    rdfs:label 'Ledger Status' ;
    rdfs:comment 'Current operational status of the ledger in the financial system lifecycle.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerType rdf:type rdf:Property ;
    rdfs:label 'Ledger Type' ;
    rdfs:comment 'Classification of the ledger based on its functional purpose in the financial accounting system.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingPeriodVariant rdf:type rdf:Property ;
    rdfs:label 'Posting Period Variant' ;
    rdfs:comment 'Code defining the number and structure of posting periods (e.g., 12 regular periods plus special periods) for this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitLossAccount rdf:type rdf:Property ;
    rdfs:label 'Profit Loss Account' ;
    rdfs:comment 'General ledger account number used for profit and loss statement aggregation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainedEarningsAccount rdf:type rdf:Property ;
    rdfs:label 'Retained Earnings Account' ;
    rdfs:comment 'General ledger account number used for retained earnings carry-forward during year-end closing.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsCostCenter rdf:type rdf:Property ;
    rdfs:label 'Supports Cost Center' ;
    rdfs:comment 'Boolean flag indicating whether this ledger supports cost center accounting for overhead allocation and analysis.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsProfitCenter rdf:type rdf:Property ;
    rdfs:label 'Supports Profit Center' ;
    rdfs:comment 'Boolean flag indicating whether this ledger supports profit center accounting for internal management reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsSegmentReporting rdf:type rdf:Property ;
    rdfs:label 'Supports Segment Reporting' ;
    rdfs:comment 'Boolean flag indicating whether this ledger supports segment-level financial reporting as required by FASB ASC 280.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valuationView rdf:type rdf:Property ;
    rdfs:label 'Valuation View' ;
    rdfs:comment 'The valuation perspective or view that this ledger represents for parallel accounting purposes.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCostZoneId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Zone Id' ;
    rdfs:comment 'Reference to a parent cost zone in a hierarchical cost zone structure, enabling nested or regional rollup of cost zones.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostZone .

ind:annualRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Amount' ;
    rdfs:comment 'Estimated or actual annual revenue generated within this cost zone in the zone\'s currency.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualVolumeUnits rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Units' ;
    rdfs:comment 'Estimated or actual annual sales volume in units for this cost zone, used for cost allocation and pricing optimization.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Amount' ;
    rdfs:comment 'Monetary threshold above which pricing changes in this zone require additional approval levels.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveIntensity rdf:type rdf:Property ;
    rdfs:label 'Competitive Intensity' ;
    rdfs:comment 'Level of competitive pressure in this cost zone affecting pricing flexibility and margin targets.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Cost Adjustment Factor' ;
    rdfs:comment 'Multiplier applied to base costs to account for zone-specific cost variations, typically ranging from 0.8 to 1.5.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Cost Review Frequency' ;
    rdfs:comment 'Scheduled frequency for reviewing and updating cost factors and margins for this cost zone.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costZoneCode rdf:type rdf:Property ;
    rdfs:label 'Cost Zone Code' ;
    rdfs:comment 'Business identifier code for the cost zone used in pricing systems and external integrations. Typically alphanumeric and unique across the enterprise.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costZoneDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Zone Description' ;
    rdfs:comment 'Detailed description of the cost zone including its purpose, geographic coverage, and business rationale.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costZoneName rdf:type rdf:Property ;
    rdfs:label 'Cost Zone Name' ;
    rdfs:comment 'Human-readable name of the cost zone for display and reporting purposes.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costZoneStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Zone Status' ;
    rdfs:comment 'Current lifecycle status of the cost zone indicating whether it is actively used in pricing calculations.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costZoneType rdf:type rdf:Property ;
    rdfs:label 'Cost Zone Type' ;
    rdfs:comment 'Classification of the cost zone based on the segmentation strategy used (geographic regions, sales channels, store formats, vendor agreements, product categories, or custom business rules).' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultCostMethod rdf:type rdf:Property ;
    rdfs:label 'Default Cost Method' ;
    rdfs:comment 'Primary costing methodology applied to products within this cost zone for inventory valuation and pricing calculations.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyFactorPercentage rdf:type rdf:Property ;
    rdfs:label 'Duty Factor Percentage' ;
    rdfs:comment 'Percentage applied to base product cost to account for import duties and tariffs applicable to this cost zone.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightFactorPercentage rdf:type rdf:Property ;
    rdfs:label 'Freight Factor Percentage' ;
    rdfs:comment 'Percentage applied to base product cost to account for freight and transportation expenses specific to this cost zone.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCostReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Cost Review Date' ;
    rdfs:comment 'Date when cost factors and pricing parameters for this zone were last reviewed and validated.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumMarginPercentage rdf:type rdf:Property ;
    rdfs:label 'Minimum Margin Percentage' ;
    rdfs:comment 'Minimum acceptable gross margin percentage for products sold within this cost zone, used as a pricing floor constraint.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextCostReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Cost Review Date' ;
    rdfs:comment 'Scheduled date for the next cost review and potential adjustment of zone parameters.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overheadFactorPercentage rdf:type rdf:Property ;
    rdfs:label 'Overhead Factor Percentage' ;
    rdfs:comment 'Percentage applied to base product cost to account for warehousing, handling, and operational overhead costs in this zone.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMarginPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Margin Percentage' ;
    rdfs:comment 'Target gross margin percentage that pricing strategies aim to achieve for products in this cost zone.' ;
    rdfs:domain ind:CostZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memberSegmentAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Member Segment Assignment Id' ;
    rdfs:comment 'Primary key for the member_segment_assignment association' ;
    rdfs:domain ind:MemberSegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'The date on which this member was assigned to this segment. Sourced from detection phase relationship data. Used for cohort analysis and assignment history tracking.' ;
    rdfs:domain ind:MemberSegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'Confidence score (0.0000 to 1.0000) for this specific member-segment assignment, applicable when assignment_method is ml-model. Sourced from detection phase relationship data. Enables filtering assignments below the segment\'s minimum_confidence_score threshold.' ;
    rdfs:domain ind:MemberSegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:method rdf:type rdf:Property ;
    rdfs:label 'Method' ;
    rdfs:comment 'The method used to assign this specific member to this segment: rule-based (deterministic business rules), ml-model (probabilistic model output), or manual (human override). Moved from member_segment.assignment_method which was incorrectly placed at segment definition level rather than per-assignment level.' ;
    rdfs:domain ind:MemberSegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Minimum Confidence Score' ;
    rdfs:comment 'Minimum confidence threshold (0.0000 to 1.0000) required for ML-based segment assignment. Members with confidence scores below this threshold are not assigned to the segment. Null for rule-based segments. [Moved from member_segment: minimum_confidence_score is a threshold used to filter ML-based assignments — it is a segment-level configuration attribute and should REMAIN on member_segment as a definition parameter. It is NOT moved; it stays on Product B as the threshold against which individual assignment confidence_scores are compared. Noted here to clarify the distinction.]' ;
    rdfs:domain ind:MemberSegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether this assignment was manually overridden by a business user, superseding the rule-based or ML-model assignment result. Referenced in Product B description as an individual member assignment attribute, confirming it belongs at the assignment record level, not the segment definition level.' ;
    rdfs:domain ind:MemberSegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .
